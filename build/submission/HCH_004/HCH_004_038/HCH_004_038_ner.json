[
  {
    "sentence_id": "HCH_004_038_000001",
    "sentence": "辛術",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000002",
    "sentence": "辛術，字懷哲，少明敏，有識度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000003",
    "sentence": "解褐司空胄曹參軍，與僕射高隆之共典營構鄴都宮室，術有思理，百工克濟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000004",
    "sentence": "再遷尚書右丞。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000005",
    "sentence": "出為清河太守，政有能名。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000006",
    "sentence": "追授幷州長史，遭父憂去職。",
    "entities": [
      {
        "text": "追授幷州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000007",
    "sentence": "清河父老數百人詣闕請立碑頌德。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000008",
    "sentence": "文襄嗣事，與尚書左丞宋遊道、中書侍郎李繪等並追詣晉陽，俱為上客。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000009",
    "sentence": "累遷散騎常侍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000010",
    "sentence": "武定八年 ，侯景叛，除東南道行臺尚書，封江夏縣男，與高岳等破侯景，擒蕭明。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "封江夏縣",
        "label": "LOC",
        "start": 19,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000011",
    "sentence": "遷東徐州刺史，為淮南經略使。",
    "entities": [
      {
        "text": "遷東徐州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000012",
    "sentence": "齊 天保元年 ，侯景徵江西租稅，術率諸軍渡淮斷之，燒其稻數百萬石。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000013",
    "sentence": "還鎮下邳，人隨術北渡淮者三千餘家。",
    "entities": [
      {
        "text": "還鎮",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000014",
    "sentence": "東徐州刺史郭誌殺郡守。",
    "entities": [
      {
        "text": "東徐州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000015",
    "sentence": "文宣聞之，勑術自今所統十餘州地諸有犯法者，刺史先啟聽報，以下先斷後表聞。",
    "entities": [
      {
        "text": "自今所統十餘州",
        "label": "LOC",
        "start": 7,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000016",
    "sentence": "齊代行臺兼總人事，自術始也。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 0,
        "end": 1
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000017",
    "sentence": "安州刺史、臨清太守、盱眙蘄城二鎮將犯法，術皆案奏殺之。",
    "entities": [
      {
        "text": "安州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "盱眙蘄城二鎮",
        "label": "LOC",
        "start": 10,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000018",
    "sentence": "睢州刺史及所部郡守俱犯大辟，朝廷以其奴婢百口及資財盡賜術，三辭不見許，術乃送詣所司，不復以聞。",
    "entities": [
      {
        "text": "睢州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000019",
    "sentence": "邢卲聞之，遺術書曰：「昔鐘離意云『孔子忍渴於盜泉』，便以珠璣委地，足下今能如此，可謂異代一時。」及王僧辯破侯景，術招攜安撫，城鎮相繼款附，前後二十餘州。",
    "entities": [
      {
        "text": "王僧辯",
        "label": "PER",
        "start": 49,
        "end": 52
      },
      {
        "text": "城鎮",
        "label": "LOC",
        "start": 62,
        "end": 64
      },
      {
        "text": "前後二十餘州",
        "label": "LOC",
        "start": 69,
        "end": 75
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000020",
    "sentence": "於是移鎮廣陵。",
    "entities": [
      {
        "text": "於是移鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000021",
    "sentence": "獲傳國璽送鄴，文宣以璽告於太廟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000022",
    "sentence": "此璽卽秦所制，方四寸，上紐交盤龍，其文曰：「受命于天，旣壽永昌。」二漢相傳，又傳魏、晉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000023",
    "sentence": "懷帝敗，沒於劉聰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000024",
    "sentence": "聰敗，沒於石氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000025",
    "sentence": "石氏敗，晉穆帝永和中，濮陽太守戴僧施得之，遣督護何融送于建鄴。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000026",
    "sentence": "歷宋、齊、梁，梁敗，侯景得之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000027",
    "sentence": "景敗，侍中趙思賢以璽投景南兗州刺史郭元建，送于術，故術以進焉。",
    "entities": [
      {
        "text": "以璽投景南兗州",
        "label": "LOC",
        "start": 8,
        "end": 15
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000028",
    "sentence": "尋徵為殿中尚書，領太常卿，仍與朝賢議定律令。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000029",
    "sentence": "遷吏部尚書，食南兗州梁郡幹。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "食南兗州梁郡",
        "label": "LOC",
        "start": 6,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000030",
    "sentence": "遷鄴以後，大選之職，知名者數四，互有得失，未能盡美。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000031",
    "sentence": "文襄帝少年高朗，所弊者疏；袁叔德沉密謹厚，所傷者細；楊愔風流辨給，取士失於浮華。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000032",
    "sentence": "唯術性尚貞明，取士以才器，循名責實，新舊參舉，管庫必擢，門閥不遺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000033",
    "sentence": "考之前後銓衡，在術最為折衷，甚為當時所稱舉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000034",
    "sentence": "天保末，文宣嘗令術選百員官，參選者二三千人，術題目士子，人無謗讟，其所旌擢，後亦皆致通顯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000035",
    "sentence": "術清儉，寡嗜欲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000036",
    "sentence": "勤於所職，未嘗暫懈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000037",
    "sentence": "臨軍以威嚴，牧人有惠政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000038",
    "sentence": "少愛文史，晚更修學，雖在戎旅，手不釋卷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000039",
    "sentence": "及定淮南，凡諸資物一毫無犯，唯大收典籍，多是宋、齊、梁時佳本，鳩集萬餘卷，幷顧、陸之徒名畫、二王已下法書數亦不少，俱不上王府，唯入私門。",
    "entities": [
      {
        "text": "梁",
        "label": "ORG",
        "start": 26,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000040",
    "sentence": "及還朝，頗以饋遺權要，物議以此少之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000041",
    "sentence": "十年卒，年六十。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000042",
    "sentence": "皇建二年 ，贈開府儀同三司、中書監、青州刺史。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "青州",
        "label": "LOC",
        "start": 18,
        "end": 20
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000043",
    "sentence": "子閣卿，尚書郎。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000044",
    "sentence": "閣卿弟衡卿，有識學，開府參軍事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000045",
    "sentence": "隋大業初，卒於太常丞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000046",
    "sentence": "元文遙",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000047",
    "sentence": "元文遙，字德遠，河南洛陽人，魏昭成皇帝六世孫也。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 10,
        "end": 12
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000048",
    "sentence": "五世祖常山王遵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000049",
    "sentence": "父晞，有孝行，父卒，廬於墓側而終。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000050",
    "sentence": "文遙貴，贈特進、開府儀同三司、中書監，諡曰孝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000051",
    "sentence": "文遙敏慧夙成，濟陰王暉業每云：「此子王佐才也。」暉業嘗大會賓客，有人將《何遜集》初入洛，諸賢皆贊賞之。",
    "entities": [
      {
        "text": "《何遜集》",
        "label": "TITLE",
        "start": 35,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000052",
    "sentence": "河間邢卲試命文遙：「誦之幾遍可得？」文遙一覽便誦，時年十餘歲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000053",
    "sentence": "濟陰王曰：「我家千里駒，今定如何？」邢云：「此殆古來未有。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000054",
    "sentence": "起家員外散騎常侍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000055",
    "sentence": "遭父喪，服闋，除太尉東閤祭酒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000056",
    "sentence": "以天下方亂，遂解官侍養，隱於林慮山。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000057",
    "sentence": "武定中，文襄徵為大將軍府功曹。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000058",
    "sentence": "齊受禪，於登壇所受中書舍人，宣傳文武號令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000059",
    "sentence": "楊遵彥每云：「堪解穰侯印者，必在斯人。」後忽被中旨幽執，竟不知所由。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000060",
    "sentence": "如此積年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000061",
    "sentence": "文宣後自幸禁獄，執手愧謝，親解所著金帶及御服賜之，卽日起為尚書祠部郎中。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000062",
    "sentence": "孝昭攝政，除大丞相府功曹參軍，典機密。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000063",
    "sentence": "及踐祚，除中書侍郎，封永樂縣伯，參軍國大事。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "封永樂縣",
        "label": "LOC",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000064",
    "sentence": "及帝大漸，與平秦王歸彥、趙郡王叡等同受顧託，迎立武成。",
    "entities": [
      {
        "text": "趙郡",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000065",
    "sentence": "卽位，任遇轉隆，歷給事黃門侍郎、散騎常侍、侍中、中書監。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000066",
    "sentence": "天統二年 ，詔特賜姓高氏，籍屬宗正，子弟依例歲時入朝。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000067",
    "sentence": "再遷尚書左僕射，進封寧都郡公、侍中。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "進封寧都郡",
        "label": "LOC",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000068",
    "sentence": "文遙歷事三主，明達世務，每臨軒，多命宣勑，號令文武，聲韻高朗，發吐無滯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000069",
    "sentence": "然探測上旨，時有委巷之言，故不為知音所重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000070",
    "sentence": "齊因魏朝，宰縣多用廝濫，至於士流恥居百里。",
    "entities": [
      {
        "text": "魏朝",
        "label": "ORG",
        "start": 2,
        "end": 4
      },
      {
        "text": "宰縣",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000071",
    "sentence": "文遙以縣令為字人之切，遂請革選。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000072",
    "sentence": "於是密令搜揚貴遊子弟，發勑用之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000073",
    "sentence": "猶恐其披訴，總召集神武門，令趙郡王叡宣旨唱名，厚加慰喻。",
    "entities": [
      {
        "text": "令趙郡",
        "label": "LOC",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000074",
    "sentence": "士人為縣，自此始也。",
    "entities": [
      {
        "text": "士人為縣",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000075",
    "sentence": "旣與趙彥深、和士開同被任遇，雖不如彥深清貞守道，又不為士開貪淫亂政，在於季、孟之間。",
    "entities": [
      {
        "text": "趙彥深",
        "label": "PER",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000076",
    "sentence": "然性和厚，與物無競，故時論不在彥深之下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000077",
    "sentence": "初，文遙自洛遷鄴，惟有地十頃，家貧，所資衣食而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000078",
    "sentence": "魏之將季，宗姓被侮，有人冒相侵奪，文遙卽以與之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000079",
    "sentence": "及貴，此人尚在，乃將家逃竄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000080",
    "sentence": "文遙大驚，追加慰撫，還以與之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000081",
    "sentence": "彼人愧而不受，彼此俱讓，遂為閑田。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000082",
    "sentence": "至後主嗣位，趙郡王叡、婁定遠等謀出和士開，文遙亦參其議。",
    "entities": [
      {
        "text": "趙郡",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000083",
    "sentence": "叡見殺，文遙由是出為西兗州刺史。",
    "entities": [
      {
        "text": "由是出為西兗州",
        "label": "LOC",
        "start": 6,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000084",
    "sentence": "詣士開別，士開曰：「處得言地，使元家兒作令仆，深愧朝廷。」旣言而悔，仍執手慰勉之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000085",
    "sentence": "猶慮文遙自疑，用其子行恭為尚書郎，以慰其心。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000086",
    "sentence": "士開死，自東徐州刺史徵入朝，竟不用，卒。",
    "entities": [
      {
        "text": "自東徐州",
        "label": "LOC",
        "start": 4,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000087",
    "sentence": "行恭美姿貌，有父風，兼俊才，位中書舍人，待詔文林館。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000088",
    "sentence": "齊亡，陽休之等十八人同入關，稍遷司勳下大夫。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "等十八人同入關",
        "label": "LOC",
        "start": 6,
        "end": 13
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000089",
    "sentence": "隋開皇中，位尚書郎，坐事徙瓜州而卒。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "坐事徙瓜州",
        "label": "LOC",
        "start": 10,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000090",
    "sentence": "行恭少頗驕恣，文遙令與范陽盧思道交遊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000091",
    "sentence": "文遙嘗謂思道云：「小兒比日微有所知，是大弟之力，然白擲劇飲，甚得師風。」思道答云：「郎辭情俊邁，自是克荷堂構，而白擲劇飲，亦天性所得。」行恭弟行如，亦聰慧早成，武平末，任著作佐郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000092",
    "sentence": "趙彥深",
    "entities": [
      {
        "text": "趙彥深",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000093",
    "sentence": "趙彥深，自云南陽宛人，漢太傅熹之後。",
    "entities": [
      {
        "text": "趙彥深",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000094",
    "sentence": "高祖父難，為清河太守，有惠政，遂家焉，清河後改為平原，故為平原人也。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000095",
    "sentence": "本名隱，避齊廟諱，改以字行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000096",
    "sentence": "父奉伯，仕魏位中書舍人、行洛陽令。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000097",
    "sentence": "彥深貴，贈司空。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000098",
    "sentence": "彥深幼孤貧，事母甚孝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000099",
    "sentence": "年十歲，曾候司徒崔光。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000100",
    "sentence": "光謂賓客曰：「古人觀眸子以知人，此人當必遠至。」性聰敏，善書計，安閑樂道，不雜交遊，為雅論所歸服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000101",
    "sentence": "昧爽，輒自掃門外，不使人見，率以為常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000102",
    "sentence": "初為尚書令司馬子如賤客，供寫書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000103",
    "sentence": "子如善其無誤，欲將入觀省舍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000104",
    "sentence": "隱靴無氊，衣帽穿弊，子如給之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000105",
    "sentence": "用為書令史，月餘，補正令史。",
    "entities": [
      {
        "text": "令史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "令史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000106",
    "sentence": "神武在晉陽，索二史，子如舉彥深。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000107",
    "sentence": "後拜子如開府參軍，超拜水部郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000108",
    "sentence": "及文襄為尚書令攝選，沙汰諸曹郎，彥深以地寒被出為滄州別駕，辭不行。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "地寒被出為滄州",
        "label": "LOC",
        "start": 19,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000109",
    "sentence": "子如言於神武，徵補大丞相功曹參軍，專掌機密，文翰多出其手，稱為敏給。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000110",
    "sentence": "神武曾與對坐，遣造軍令，以手捫其額曰：「若天假卿年，必大有所至。」每謂司徒孫騰曰：「彥深小心恭慎，曠古絕倫。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000111",
    "sentence": "及神武崩，秘喪事，文襄慮河南有變，仍自巡撫，乃委彥深後事，轉大行臺都官郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000112",
    "sentence": "臨發，握手泣曰：「以母弟相托，幸得此心。」旣而內外寧靜，彥深之力。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000113",
    "sentence": "及還發喪，深加褒美，乃披郡縣簿為選，封安國縣伯。",
    "entities": [
      {
        "text": "乃披郡縣",
        "label": "LOC",
        "start": 10,
        "end": 14
      },
      {
        "text": "封安國縣",
        "label": "LOC",
        "start": 18,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000114",
    "sentence": "從征潁川，時引水灌城，城雉將沒，西魏將王思政猶欲死戰。",
    "entities": [
      {
        "text": "時引水灌城",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000115",
    "sentence": "文襄令彥深單身入城告喻，卽日降之，便手牽思政出城。",
    "entities": [
      {
        "text": "令彥深單身入城",
        "label": "LOC",
        "start": 2,
        "end": 9
      },
      {
        "text": "便手牽思政出城",
        "label": "LOC",
        "start": 17,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000116",
    "sentence": "先是，文襄謂彥深曰：「吾昨夜夢獵，遇一群豕，吾射盡獲之，獨一大豕不可得。卿言當為吾取，須臾獲豕而進。」至是，文襄笑曰：「夢驗矣。」卽解思政佩刀與彥深曰：「使卿常獲此利。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000117",
    "sentence": "文宣嗣位，仍典機密，進爵為侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000118",
    "sentence": "天保初，累遷秘書監。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000119",
    "sentence": "以為忠謹，每郊廟，必令兼太僕卿，執御陪乘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000120",
    "sentence": "轉大司農。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000121",
    "sentence": "帝或巡幸，卽輔贊太子，知後事。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000122",
    "sentence": "出為東南道行臺尚書、徐州刺史，為政尚恩信，為吏人所懷，多所降下。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "徐州",
        "label": "LOC",
        "start": 10,
        "end": 12
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000123",
    "sentence": "所營軍處，士庶追思，號趙行臺頓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000124",
    "sentence": "文宣璽書勞勉，徵為侍中，仍掌機密。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000125",
    "sentence": "河清元年 ，進爵安樂公，累遷尚書左僕射、齊州大中正、監國史，遷尚書令，為特進，封宜陽王。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "齊州",
        "label": "LOC",
        "start": 20,
        "end": 22
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000126",
    "sentence": "武平二年 拜司空，為祖珽所間，出為西兗州刺史。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "出為西兗州",
        "label": "LOC",
        "start": 15,
        "end": 20
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000127",
    "sentence": "四年，徵為司空，轉司徒。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000128",
    "sentence": "丁母憂，尋起為本官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000129",
    "sentence": "七年六月暴疾薨，時年七十。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_038_000130",
    "sentence": "彥深歷事累朝，常參機近，溫柔謹慎，喜怒不形於色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000131",
    "sentence": "自皇建以還，禮遇稍重，每有引見，或升御榻，常呼官號而不名也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000132",
    "sentence": "凡諸選舉，先令銓定，提獎人物，皆行業為先，輕薄之徒，弗之齒也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000133",
    "sentence": "孝昭旣執朝權，群臣密多勸進，彥深獨不致言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000134",
    "sentence": "孝昭嘗謂王晞云：「若言眾心皆謂天下有歸，何不見彥深有語？」晞以告，彥深不獲已，陳請，其為時重如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000135",
    "sentence": "常遜言恭己，未嘗以驕矜待物，所以或出或處，去而復還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000136",
    "sentence": "母傅氏，雅有操識。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000137",
    "sentence": "彥深三歲，傅便孀居，家人欲以改適，自誓以死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000138",
    "sentence": "彥深五歲，傅謂之曰：「家貧兒小，何以能濟？」彥深泣而言曰：「若天哀矜，兒大當仰報。」傅感其意，對之流涕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000139",
    "sentence": "及彥深拜太常卿，還，不脫朝服，先入見母，跪陳幼小孤露，蒙訓得至於此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000140",
    "sentence": "母子相泣久之，然後改服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000141",
    "sentence": "後為宜陽國太妃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000142",
    "sentence": "彥深有七子，仲將知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000143",
    "sentence": "仲將，沉敏有父風，溫良恭儉，雖對妻子，亦未嘗怠慢，終日儼然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000144",
    "sentence": "學涉群書，善草隸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_038_000145",
    "sentence": "雖與弟書，書字楷正，云草不可不解，若施之於人，卽似相輕易，若與當家中卑幼，又恐其疑所在宜爾，是以必須隸筆。",
    "entities": []
  },
