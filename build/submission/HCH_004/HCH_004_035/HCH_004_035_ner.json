  {
    "sentence_id": "HCH_004_035_000070",
    "sentence": "高岳征潁川，復以爲都督中兵參軍兼記室。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000071",
    "sentence": "宴之文士，兼有武幹，每與岳帷帳之謀，又常以短兵接刃，親獲首級，深爲岳所嗟賞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000072",
    "sentence": "天保初，文宣爲高陽王納宴之女爲妃，令赴晉陽成禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000073",
    "sentence": "宴之後園陪宴，坐客皆賦詩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000074",
    "sentence": "宴之詩云：「天下有道，主明臣直，雖休勿休，永貽世則。」文宣笑曰：「得卿箴諷，深以慰懷。」後行北徐州事，尋卽真，爲吏人所愛。",
    "entities": [
      {
        "text": "後行北徐州",
        "label": "LOC",
        "start": 44,
        "end": 49
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000075",
    "sentence": "御史崔子武督察州郡，至北徐州，無所案劾，唯得百姓所制《清德頌》數篇。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "至北徐州",
        "label": "LOC",
        "start": 10,
        "end": 14
      },
      {
        "text": "《清德頌》",
        "label": "TITLE",
        "start": 26,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000076",
    "sentence": "乃歎曰：「本求罪狀，遂聞頌聲。」遷兗州刺史，未拜，卒。",
    "entities": [
      {
        "text": "遷兗州",
        "label": "LOC",
        "start": 16,
        "end": 19
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000077",
    "sentence": "贈齊州刺史。",
    "entities": [
      {
        "text": "贈齊州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000078",
    "sentence": "陸卬",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000079",
    "sentence": "陸卬，字雲駒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000080",
    "sentence": "少機悟，美風神，好學不倦，博覽群書，五經多通大義。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000081",
    "sentence": "善屬文，甚爲河間邢卲所賞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000082",
    "sentence": "卲又與卬父子彰交遊，嘗謂子彰曰：「吾以卿老蚌，遂出明珠，意欲爲羣拜紀可乎？」由是名譽日高，儒雅搢紳，尤所推許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000083",
    "sentence": "起家員外散騎侍郎，歷文襄大將軍主簿，中書舍人，兼中書侍郎，以本職兼太子洗馬。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 12,
        "end": 15
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 26,
        "end": 28
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000084",
    "sentence": "自梁、魏通和，歲有交聘，卬每兼官燕接。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000085",
    "sentence": "在帝席賦詩，卬必先成，雖未能盡工，以敏速見美。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000086",
    "sentence": "除中書侍郎，修國史。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000087",
    "sentence": "以父憂去職，居喪盡禮，哀毀骨立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000088",
    "sentence": "詔以本官起。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000089",
    "sentence": "文襄時鎮鄴，嘉其至行，親詣門以慰勉之。",
    "entities": [
      {
        "text": "文襄時鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000090",
    "sentence": "卬母魏上庸公主，初封藍田，高明婦人也，甚有志操。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000091",
    "sentence": "卬昆季六人，並主所生。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000092",
    "sentence": "故邢卲常謂人云：「藍田生玉，固不虛矣。」主教訓諸子，皆稟義方，雖創巨痛深，出於天性，然動依禮度，亦母氏之訓焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000093",
    "sentence": "卬兄弟相率廬於墓側，負土成墳，朝廷深所嗟尚，發詔褒揚，改其所居里爲孝終里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000094",
    "sentence": "服竟當襲，不忍嗣侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000095",
    "sentence": "天保初，常山王薦卬器幹，文宣面授給事黃門侍郎，遷吏部郎中。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000096",
    "sentence": "上洛王思宗爲清都尹，辟爲邑中正，食貝丘縣幹。",
    "entities": [
      {
        "text": "辟爲邑",
        "label": "LOC",
        "start": 10,
        "end": 13
      },
      {
        "text": "食貝丘縣",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000097",
    "sentence": "遭母喪，哀慕毀悴，殆不勝喪，至沉篤，頓昧伏枕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000098",
    "sentence": "又感風疾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000099",
    "sentence": "第五弟摶遇疾臨終，謂其兄弟曰：「大兄尫病如此，性至慈愛，摶之死日，必不得使大兄知之，哭泣聲必不可聞徹，致有感慟。」家人至於祖載，方始告之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000100",
    "sentence": "卬聞而悲痛，一慟便絶，年四十八。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000101",
    "sentence": "卬自在朝，篤慎固密，不説人短，不伐己長，言論清遠，有人倫鑒裁，朝野甚悲惜之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000102",
    "sentence": "贈衛將軍、青州刺史，諡曰文。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "青州",
        "label": "LOC",
        "start": 5,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000103",
    "sentence": "所著文章十四卷，行於世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000104",
    "sentence": "齊之效廟諸歌，多卬所制。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000105",
    "sentence": "子乂嗣，襲爵始平侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000106",
    "sentence": "王松年",
    "entities": [
      {
        "text": "王松年",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000107",
    "sentence": "王松年，少知名。",
    "entities": [
      {
        "text": "王松年",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000108",
    "sentence": "文襄臨幷州，辟爲主簿，累遷通直散騎常侍，副李緯使梁。",
    "entities": [
      {
        "text": "文襄臨幷州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000109",
    "sentence": "還，歷位尚書郎中。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000110",
    "sentence": "魏收撰《魏書》成，松年有謗言，文宣怒，禁止之，仍加杖罰。",
    "entities": [
      {
        "text": "《魏書》",
        "label": "TITLE",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000111",
    "sentence": "歲餘得免，除臨漳令，遷司馬、別駕、本州大中正。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "本州",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000112",
    "sentence": "孝昭擢拜給事黃門侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000113",
    "sentence": "帝每賜坐，與論政事，甚善之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000114",
    "sentence": "孝昭崩，松年馳驛至鄴都宣遺詔，發言涕泗，迄於宣罷，容色無改，辭吐諧韻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000115",
    "sentence": "宣訖，號慟自絶於地，百官莫不感慟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000116",
    "sentence": "還晉陽，兼侍中，護梓宮還鄴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000117",
    "sentence": "諸舊臣避形跡，無敢盡哀，唯松年哭甚流涕，朝士咸恐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000118",
    "sentence": "武成雖忿松年戀舊情切，亦雅重之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000119",
    "sentence": "以本官加散騎常侍，食高邑縣幹，參定律令，前後大事多委焉。",
    "entities": [
      {
        "text": "食高邑縣",
        "label": "LOC",
        "start": 9,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000120",
    "sentence": "兼御史中丞。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000121",
    "sentence": "發晉陽之鄴，在道遇疾卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000122",
    "sentence": "贈吏部尚書、幷州刺史，諡曰平。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "幷州",
        "label": "LOC",
        "start": 6,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000123",
    "sentence": "第三子卲，最知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000124",
    "sentence": "劉禕",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000125",
    "sentence": "劉禕，字彥英，彭城人。",
    "entities": [
      {
        "text": "彭城",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000126",
    "sentence": "父世明，魏兗州刺史。",
    "entities": [
      {
        "text": "魏兗州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000127",
    "sentence": "禕性弘裕，有威重，容止可觀，雖昵友密交，朝夕遊處，莫不加敬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000128",
    "sentence": "好學，善《三禮》，吉凶儀制，尤所留心。",
    "entities": [
      {
        "text": "《三禮》",
        "label": "TITLE",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000129",
    "sentence": "魏孝昌中，釋巾太學博士。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000130",
    "sentence": "累遷睢州刺史，邊人服其威信，甚得疆埸之和。",
    "entities": [
      {
        "text": "累遷睢州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000131",
    "sentence": "世宗輔政，降書褒獎，云：「以卿家世忠純，奕代冠冕，賢弟賢子，並與吾共事，懷抱相托，亦自依然。宜勗心力，以副所委，莫慮不富貴。」秩滿，逕歸鄉里侍父疾，竟不入朝。",
    "entities": [
      {
        "text": "逕歸鄉",
        "label": "LOC",
        "start": 66,
        "end": 69
      }
    ]
  },
  {
    "sentence_id": "HCH_004_035_000132",
    "sentence": "父喪，沉頓累年，非杖不起。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000133",
    "sentence": "世宗致辟，禕稱疾不動。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000134",
    "sentence": "五子，璇、玘、璞、瑗、瓚，並有志節，爲世所稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000135",
    "sentence": "校",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_035_000136",
    "sentence": "全文以中華書局、一九七二年十一月、第一版《北齊書》爲本校。",
    "entities": [
