      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000146",
    "sentence": "時度律、仲遠軍次陽平，尒朱兆會之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000147",
    "sentence": "神武用竇泰策，縱反間，度律、仲遠不戰而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000148",
    "sentence": "神武乃敗兆於廣阿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000149",
    "sentence": "十一月，攻鄴，相州刺史劉誕嬰城固守。",
    "entities": [
      {
        "text": "相州",
        "label": "LOC",
