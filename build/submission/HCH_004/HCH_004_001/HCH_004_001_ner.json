  },
  {
    "sentence_id": "HCH_004_001_000157",
    "sentence": "神武令封隆之守鄴，自出頓紫陌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000158",
    "sentence": "時馬不滿二千，步兵不至三萬，衆寡不敵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000159",
    "sentence": "乃於韓陵為圓陣，連牛驢以塞歸道，於是將士皆有死志，四面赴擊之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000160",
    "sentence": "尒朱兆責神武以背己，神武曰：「本戮力者，共輔王室，今帝何在？」兆曰：「永安枉害天柱，我報讐耳。」神武曰：「我昔日親聞天柱計，汝在戶前立，豈得言不反邪？且以君殺臣，何報之有？今日義絕矣。」乃合戰，大敗之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000161",
    "sentence": "尒朱兆對慕容紹宗叩心曰：「不用公言，以至於此！」將輕走。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000162",
    "sentence": "紹宗反旗鳴角，收聚散卒，成軍容而西上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000163",
    "sentence": "高季式以七騎追奔，度野馬崗，與兆遇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000164",
    "sentence": "高昂望之不見，哭曰：「喪吾弟矣！」夜久，季式還，血滿袖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000165",
    "sentence": "斛斯椿倍道先據河橋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000166",
    "sentence": "初，普泰元年十月，歲星、熒惑、鎮星、太白聚於觜，參色甚明。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000167",
    "sentence": "太史占云當有王者興。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000168",
    "sentence": "是時神武起於信都，至是而破兆等。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000169",
    "sentence": "四月，斛斯椿執天光、度律送洛陽。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000170",
    "sentence": "長孫承業遣都督賈顯智、張歡入洛陽，執世隆、彥伯斬之。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000171",
    "sentence": "兆奔幷州。",
    "entities": [
      {
        "text": "兆奔幷州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000172",
    "sentence": "仲遠奔梁州，遂死焉。",
    "entities": [
      {
        "text": "仲遠奔梁州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000173",
    "sentence": "時凶蠹旣除，朝廷慶悅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000174",
    "sentence": "初，未戰之前月，章武人張紹夜中忽被數騎將踰城，至一大將軍前，敕紹為軍導向鄴，云佐受命者除殘賊。",
    "entities": [
      {
        "text": "忽被數騎將踰城",
        "label": "LOC",
        "start": 15,
        "end": 22
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000175",
    "sentence": "紹迴視之，兵不測，整疾無聲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000176",
    "sentence": "將至鄴，乃放焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000177",
    "sentence": "及戰之日，尒朱氏軍人見陣外士馬四合，蓋神助也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000178",
    "sentence": "旣而神武至洛陽，廢節閔及中興主而立孝武。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000179",
    "sentence": "孝武旣卽位，授神武大丞相、天柱大將軍、太師、世襲定州刺史，增封並前十五萬戶。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 15,
        "end": 18
      },
      {
        "text": "世襲定州",
        "label": "LOC",
        "start": 22,
        "end": 26
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000180",
    "sentence": "神武辭天柱，減戶五萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000181",
    "sentence": "壬辰，還鄴，魏帝餞於乾脯山，執手而別。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000182",
    "sentence": "七月壬寅，神武帥師北伐尒朱兆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000183",
    "sentence": "封隆之言：「侍中斛斯椿、賀拔勝、賈顯智等往事尒朱，普皆反噬，今在京師，寵任，必構禍隙。」神武深以為然，乃歸天光、度律於京師，斬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000184",
    "sentence": "遂自滏口入。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000185",
    "sentence": "尒朱兆大掠晉陽，北保秀容。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000186",
    "sentence": "幷州平。",
    "entities": [
      {
        "text": "幷州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000187",
    "sentence": "神武以晉陽四塞，乃建大丞相府而定居焉。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000188",
    "sentence": "尒朱兆旣至秀容，分兵守險，出入寇抄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000189",
    "sentence": "神武揚聲討之，師出止者數四，兆意怠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000190",
    "sentence": "神武揣其歲首當宴會，遣竇泰以精騎馳之，一日一夜行三百里，神武以大軍繼之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000191",
    "sentence": "二年正月，竇泰奄至尒朱兆庭。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000192",
    "sentence": "軍人因宴休惰，忽見泰軍，驚走。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000193",
    "sentence": "追破之於赤洪嶺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000194",
    "sentence": "兆自縊，神武親臨厚葬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000195",
    "sentence": "慕容紹宗以尒朱榮妻子及餘衆自保烏突城，降，神武以義故，待之甚厚。",
    "entities": [
      {
        "text": "餘衆自保烏突城",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000196",
    "sentence": "神武之入洛也，尒朱仲遠部下都督橋甯、張子期自滑臺歸命，神武以其助亂，且數反覆，皆斬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000197",
    "sentence": "斛斯椿由是內不自安，乃與南陽王寶炬及武衛將軍元毗、魏光、王思政構神武於魏帝。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000198",
    "sentence": "舍人元士弼又奏神武受敕大不敬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000199",
    "sentence": "故魏帝心貳於賀拔岳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000200",
    "sentence": "初，孝明之時，洛下以兩拔相擊，謠言曰：「銅拔打鐵拔，元家世將末。」好事者以二拔謂拓拔、賀拔，言俱將衰敗之兆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000201",
    "sentence": "時司空高乾密啟神武，言魏帝之貳，神武封呈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000202",
    "sentence": "魏帝殺之，又遣東徐州刺史潘紹業密勑長樂太守龐蒼鷹令殺其弟昂。",
    "entities": [
      {
        "text": "又遣東徐州",
        "label": "LOC",
        "start": 5,
        "end": 10
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000203",
    "sentence": "昂先聞其兄死，以矟刺柱，伏壯士執紹業於路，得敕書於袍領，來奔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000204",
    "sentence": "神武抱其首，哭曰：「天子枉害司空！」遽使以白武幡勞其家屬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000205",
    "sentence": "時乾次弟慎在光州，為政嚴猛，又從部下取納，魏帝使代之。",
    "entities": [
      {
        "text": "乾次弟慎在光州",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000206",
    "sentence": "慎聞難，將奔梁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000207",
    "sentence": "其屬曰：「公家勳重，必不兄弟相及。」乃弊衣推鹿車歸渤海。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000208",
    "sentence": "逢使者，亦來奔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000209",
    "sentence": "於是魏帝與神武隙矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000210",
    "sentence": "阿至羅虜正光以前常稱藩，自魏朝多事，皆叛。",
    "entities": [
      {
        "text": "魏朝",
        "label": "ORG",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000211",
    "sentence": "神武遣使招納，便附款。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000212",
    "sentence": "先是，詔以寇賊平，罷行臺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000213",
    "sentence": "至是，以殊俗歸降，復授神武大行臺，隨機處分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000214",
    "sentence": "神武常賚其粟帛，議者以為徒費無益，神武不從，撫慰如初。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000215",
    "sentence": "其酋帥吐陳等感恩，皆從指麾，救曹泥，取万俟受洛干，大收其用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000216",
    "sentence": "河西費也頭虜紇豆陵伊利居河池，恃險擁衆，神武遣長史侯景屢招不從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000217",
    "sentence": "校",
    "entities": []
  },
