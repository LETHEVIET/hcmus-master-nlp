[
  {
    "sentence_id": "HCH_004_001_000001",
    "sentence": "神武上",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000002",
    "sentence": "齊高祖神武皇帝，姓高名歡，字賀六渾，渤海蓚人也。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000003",
    "sentence": "六世祖隱，晉玄菟太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000004",
    "sentence": "隱生慶，慶生泰，泰生湖，三世仕慕容氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000005",
    "sentence": "及慕容寶敗，國亂，湖率衆歸魏，為右將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000006",
    "sentence": "湖生四子，第三子謐，仕魏，位至侍御史，坐法徙居懷朔鎮。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "坐法徙居懷朔鎮",
        "label": "LOC",
        "start": 19,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000007",
    "sentence": "謐生皇考樹，性通率，不事家業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000008",
    "sentence": "住居白道南，數有赤光紫氣之異，鄰人以為怪，勸徙居以避之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000009",
    "sentence": "皇考曰：「安知非吉？」居之自若。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000010",
    "sentence": "及神武生而皇妣韓氏殂，養於同產姊婿鎮獄隊尉景家。",
    "entities": [
      {
        "text": "養於同產姊婿鎮",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000011",
    "sentence": "神武旣累世北邊，故習其俗，遂同鮮卑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000012",
    "sentence": "長而深沉有大度，輕財重士，為豪俠所宗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000013",
    "sentence": "目有精光，長頭高顴，齒白如玉，少有人傑表。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000014",
    "sentence": "家貧，及聘武明皇后，始有馬，得給鎮為隊主。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "得給鎮",
        "label": "LOC",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000015",
    "sentence": "鎮將遼西段長常奇神武貌，謂曰：「君有康濟才，終不徒然。」便以子孫為托。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000016",
    "sentence": "及貴，追贈長司空，擢其子寧用之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000017",
    "sentence": "神武自隊主轉為函使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000018",
    "sentence": "嘗乘驛過建興，雲霧晝晦，雷聲隨之，半日乃絕，若有神應者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000019",
    "sentence": "每行道路，往來無風塵之色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000020",
    "sentence": "又嘗夢履衆星而行，覺而內喜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000021",
    "sentence": "為函使六年，每至洛陽，給令史麻祥使。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 3,
        "end": 5
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 8,
        "end": 10
      },
      {
        "text": "令史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000022",
    "sentence": "詳嘗以肉啖神武，神武性不立食，坐而進之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000023",
    "sentence": "祥以為慢己，笞神武四十。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000024",
    "sentence": "及自洛陽還，傾產以結客。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000025",
    "sentence": "親故怪問之，答曰：「吾至洛陽，宿衛羽林相率焚領軍張彝宅，朝廷懼其亂而不問。為政若此，事可知也。財物豈可常守邪？」自是乃有澄清天下之志。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000026",
    "sentence": "與懷朔省事雲中司馬子如及秀容人劉貴、中山人賈顯智為奔走之友，懷朔戶曹史孫騰、外兵史侯景亦相友結。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000027",
    "sentence": "劉貴嘗得一白鷹，與神武及尉景、蔡儁、子如、賈顯智等獵於沃野。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000028",
    "sentence": "見一赤兔，每搏輒逸，遂至回澤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000029",
    "sentence": "澤中有茅屋，將奔入，有狗自屋中出，噬之，鷹兔俱死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000030",
    "sentence": "神武怒，以鳴鏑射之，狗斃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000031",
    "sentence": "屋中有二人出，持神武襟甚急。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000032",
    "sentence": "其母兩目盲，曳杖呵其二子曰：「何故觸大家！」出甕中酒，烹羊以飯客。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000033",
    "sentence": "因自言善暗相，遍捫諸人皆貴，而指麾俱由神武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000034",
    "sentence": "又曰：「子如歷位顯，智不善終。」飯竟出，行數里還，更訪之，則本無人居，乃向非人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000035",
    "sentence": "由是諸人益加敬異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000036",
    "sentence": "孝昌元年 ，柔玄鎮人杜洛周反於上谷，神武乃與同志從之。",
    "entities": [
      {
        "text": "孝昌元年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "柔玄鎮",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000037",
    "sentence": "醜其行事，私與尉景、段榮、蔡儁圖之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000038",
    "sentence": "不果而逃，為其騎所追。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000039",
    "sentence": "文襄及魏永熙后皆幼，武明後於牛上抱負之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000040",
    "sentence": "文襄屢落牛，神武彎弓將射之以決去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000041",
    "sentence": "后呼榮求救，賴榮遽下取之以免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000042",
    "sentence": "遂奔葛榮，又亡歸尒朱榮於秀容。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000043",
    "sentence": "先是，劉貴事榮，盛言神武美，至是始得見，以憔悴故，未之奇也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000044",
    "sentence": "貴乃為神武更衣，復求見焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000045",
    "sentence": "因隨榮之廄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000046",
    "sentence": "廄有惡馬，榮命翦之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000047",
    "sentence": "神武乃不加羈絆而翦，竟不蹄齧，已而起曰：「御惡人亦如此馬矣。」榮遂坐神武於床下，屏左右而訪時事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000048",
    "sentence": "神武曰：「聞公有馬十二谷，色別為羣，將此竟何用也？」榮曰：「但言爾意。」神武曰：「方今天子愚弱，太后淫亂，孽寵擅命，朝政不行。以明公雄武，乘時奮發，討鄭儼、徐紇而清帝側，霸業可舉鞭而成。此賀六渾之意也。」榮大悅，語自日中至夜半，乃出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000049",
    "sentence": "自是每參軍謀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000050",
    "sentence": "後從榮徙據幷州，抵揚州邑人龐蒼鷹，止團焦中。",
    "entities": [
      {
        "text": "後從榮徙據幷州",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "抵揚州邑",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000051",
    "sentence": "每從外歸，主人遙聞行響動地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000052",
    "sentence": "蒼鷹母數見團焦赤氣赫然屬天。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000053",
    "sentence": "又蒼鷹嘗夜欲入，有青衣人拔刀叱曰：「何故觸王！」言訖不見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000054",
    "sentence": "始以為異，密覘之，唯見赤蛇蟠床上，乃益驚異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000055",
    "sentence": "因殺牛分肉，厚以相奉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000056",
    "sentence": "蒼鷹母求以神武為義子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000057",
    "sentence": "及得志，以其宅為第，號為南宅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000058",
    "sentence": "雖門巷開廣，堂宇崇麗，其本所住團焦，以石堊塗之，留而不毀，至文宣時，遂為宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000059",
    "sentence": "旣而榮以神武為親信都督。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000060",
    "sentence": "于時魏明帝銜鄭儼、徐紇，逼靈太后，未敢制，私使榮舉兵內向。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000061",
    "sentence": "榮以神武為前鋒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000062",
    "sentence": "至上黨，明帝又私詔停之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000063",
    "sentence": "及帝暴崩，榮遂入洛，因將篡位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000064",
    "sentence": "神武諫，恐不聽，請鑄像卜之，鑄不成，乃止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000065",
    "sentence": "孝莊帝立，以定策勳，封銅鞮伯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000066",
    "sentence": "及尒朱榮擊葛榮，令神武喻下賊別稱王者七人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000067",
    "sentence": "後與行臺于暉破羊侃於泰山，尋與元天穆破邢杲于濟南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000068",
    "sentence": "累遷第三鎮人酋長，常在榮帳內。",
    "entities": [
      {
        "text": "累遷第三鎮",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000069",
    "sentence": "榮嘗問左右曰：「一日無我，誰可主軍？」皆稱尒朱兆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000070",
    "sentence": "曰：「此正可統三千騎以還，堪代我主衆者，唯賀六渾耳。」因誡兆曰：「爾非其匹，終當為其穿鼻。」乃以神武為晉州刺史。",
    "entities": [
      {
        "text": "乃以神武為晉州",
        "label": "LOC",
        "start": 46,
        "end": 53
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 53,
        "end": 55
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000071",
    "sentence": "於是大聚斂，因劉貴貨榮下要人，盡得其意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000072",
    "sentence": "時州庫角無故自鳴，神武異之，無幾而孝莊誅榮。",
    "entities": [
      {
        "text": "時州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000073",
    "sentence": "及尒朱兆自晉陽將舉兵赴洛，召神武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000074",
    "sentence": "神武使長史孫騰辭以絳蜀、汾胡欲反，不可委去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000075",
    "sentence": "兆恨焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000076",
    "sentence": "騰復命，神武曰：「兆舉兵犯上，此大賊也，吾不能久事之。」自是始有圖兆計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000077",
    "sentence": "及兆入洛，執莊帝以北，神武聞之，大驚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000078",
    "sentence": "又使孫騰偽賀兆，因密覘孝莊所在，將劫以舉義，不果。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000079",
    "sentence": "乃以書喻之，言不宜執天子以受惡名於海內。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000080",
    "sentence": "兆不納，殺帝，而與尒朱世隆等立長廣王曄，改元建明。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 23,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000081",
    "sentence": "封神武為平陽郡公。",
    "entities": [
      {
        "text": "封神武為平陽郡",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000082",
    "sentence": "及費也頭紇豆陵步藩入秀容，逼晉陽，兆徵神武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000083",
    "sentence": "神武將往，賀拔焉過兒請緩行以弊之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000084",
    "sentence": "神武乃往往逗遛，辭以河無橋不得渡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000085",
    "sentence": "步藩軍盛，兆敗走。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000086",
    "sentence": "初，孝莊之誅尒朱榮，知其黨必有逆謀，乃密敕步藩令襲其後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000087",
    "sentence": "步藩旣敗兆等，以兵勢日盛，兆又請救於神武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000088",
    "sentence": "神武內圖兆，復慮步藩後之難除，乃與兆悉力破之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000089",
    "sentence": "藩死，深德神武，誓為兄弟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000090",
    "sentence": "時世隆、度律、彥伯共執朝政，天光據關右，兆據幷州，仲遠據東郡，各擁兵為暴，天下苦之。",
    "entities": [
      {
        "text": "天光據關",
        "label": "LOC",
        "start": 14,
        "end": 18
      },
      {
        "text": "兆據幷州",
        "label": "LOC",
        "start": 20,
        "end": 24
      },
      {
        "text": "仲遠據東郡",
        "label": "LOC",
        "start": 25,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000091",
    "sentence": "葛榮衆流入幷、肆者二十餘萬，為契胡陵暴，皆不聊生，大小二十六反，誅夷者半，猶草竊不止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000092",
    "sentence": "兆患之，問計於神武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000093",
    "sentence": "神武曰：「六鎮反殘，不可盡殺，宜選王素腹心者私使統焉。若有犯者，直罪其帥，則所罪者寡。」兆曰：「善，誰可行也？」賀拔允時在坐，請神武。",
    "entities": [
      {
        "text": "六鎮",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000094",
    "sentence": "神武拳毆之，折其一齒，曰：「生平天柱時，奴輩伏處分如鷹犬，今日天下安置在王，而阿鞠泥敢誣下罔上，請殺之。」兆以神武為誠，遂以委焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000095",
    "sentence": "神武以兆醉，恐醒後或致疑貳，遂出，宣言受委統州鎮兵，可集汾東受令。",
    "entities": [
      {
        "text": "宣言受委統州鎮",
        "label": "LOC",
        "start": 17,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000096",
    "sentence": "乃建牙陽曲川，陳部分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000097",
    "sentence": "有款軍門者，絳巾袍，自稱梗楊驛子，願廁左右。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000098",
    "sentence": "訪之，則以力聞，常於幷州市搭殺人者，乃署為親信。",
    "entities": [
      {
        "text": "常於幷州",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000099",
    "sentence": "兵士素惡兆而樂神武，於是莫不皆至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000100",
    "sentence": "居無何，又使劉貴請兆，以幷、肆頻歲霜旱，降戶掘黃鼠而食之，皆面無穀色，徒汚人國土，請令就食山東，待溫飽而處分之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000101",
    "sentence": "兆從其議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000102",
    "sentence": "其長史慕容紹宗諫曰：「不可，今四方擾擾，人懷異望，況高公雄略，又握大兵，將不可為。」兆曰：「香火重誓，何所慮也。」紹宗曰：「親兄弟尚爾難信，何論香火！」時兆左右已受神武金，因譖紹宗與神武舊有隙，兆乃禁紹宗而催神武發。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000103",
    "sentence": "神武乃自晉陽出滏口。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000104",
    "sentence": "路逢尒朱榮妻北鄉長公主，自洛陽來，馬三百匹，盡奪易之。",
    "entities": [
      {
        "text": "逢尒朱榮妻北鄉",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000105",
    "sentence": "兆聞，乃釋紹宗而問焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000106",
    "sentence": "紹宗曰：「猶掌握中物也。」於是自追神武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000107",
    "sentence": "至襄垣，會漳水暴長，橋壞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000108",
    "sentence": "神武隔水拜曰：「所以借公主馬，非有他故，備山東盜耳。王受公主言，自來賜追，今渡河而死不辭，此衆便叛。」兆自陳無此意，因輕馬渡，與神武坐幕下，陳謝，遂授刀引頭，使神武斫己。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000109",
    "sentence": "神武大哭曰：「自天柱薨背，賀六渾更何所仰，願大家千萬歲，以申力用。今旁人構間至此，大家何忍復出此言！」兆投刀於地，遂刑白馬而盟，誓為兄弟，留宿夜飲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000110",
    "sentence": "尉景伏壯士欲執兆，神武齧臂止之曰：「今殺之，其黨必奔歸聚結。兵饑馬瘦，不可相支，若英雄崛起，則為害滋甚。不如且置之。兆雖勁捷，而凶狡無謀，不足圖也。」旦日，兆歸營，又召神武，神武將上馬詣之，孫騰牽衣，乃止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000111",
    "sentence": "兆隔水肆罵，馳還晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000112",
    "sentence": "兆心腹念賢領降戶家累別為營，神武偽與之善，觀其佩刀，因取之以殺其從者，從者盡散。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000113",
    "sentence": "於是士衆咸悅，倍願附從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000114",
    "sentence": "初，魏真君內學者奏言上黨有天子氣，云在壺關大王山。",
    "entities": [
      {
        "text": "云在壺關",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000115",
    "sentence": "太武帝於是南巡以厭當之，累石為三封，斬其北鳳凰山，以毀其形。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000116",
    "sentence": "後上黨人居晉陽者，號上黨坊，神武實居之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000117",
    "sentence": "及是行，舍大王山六旬而進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000118",
    "sentence": "將出滏口，倍加約束，纖毫之物，不聽侵犯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000119",
    "sentence": "將過麥地，神武輒步牽馬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000120",
    "sentence": "遠近聞之，皆稱高儀同將兵整肅，歸心焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000121",
    "sentence": "遂前行，屯鄴，求糧相州刺史劉誕，誕不供。",
    "entities": [
      {
        "text": "求糧相州",
        "label": "LOC",
        "start": 7,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000122",
    "sentence": "有軍營租米，神武自取之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000123",
    "sentence": "魏 普泰元年 二月，神武自軍次信都，高乾、封隆之開門以待，遂據冀州。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 4,
        "end": 6
      },
      {
        "text": "遂據冀州",
        "label": "LOC",
        "start": 29,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000124",
    "sentence": "是月，尒朱度律廢元曄而立節閔帝，欲羈縻神武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000125",
    "sentence": "三月，乃白節閔帝，封神武為渤海王，徵使入覲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000126",
    "sentence": "神武辭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000127",
    "sentence": "四月癸巳，又加授東道大行臺、第一鎮人酋長。",
    "entities": [
      {
        "text": "第一鎮",
        "label": "LOC",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000128",
    "sentence": "龐蒼鷹自太原來奔，神武以為行臺郎，尋以為安州刺史。",
    "entities": [
      {
        "text": "尋以為安州",
        "label": "LOC",
        "start": 17,
        "end": 22
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000129",
    "sentence": "神武自向山東，養士繕甲，禁侵掠，百姓歸心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000130",
    "sentence": "乃詐為書，言尒朱兆將以六鎮人配契胡為部曲，衆皆愁怨。",
    "entities": [
      {
        "text": "尒朱兆將以六鎮",
        "label": "LOC",
        "start": 6,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000131",
    "sentence": "又為幷州符，徵兵討步落稽。",
    "entities": [
      {
        "text": "又為幷州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000132",
    "sentence": "發萬人，將遣之，孫騰、尉景為請留五日，如此者再。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000133",
    "sentence": "神武親送之郊，雪涕執別，人皆號慟，哭聲動地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000134",
    "sentence": "神武乃喻之曰：「與爾俱失鄉客，義同一家，不意在上乃爾徵召。直向西已當死，後軍期又當死，配國人又當死，奈何！」衆曰：「唯有反耳！」神武曰：「反是急計，須推一人為主。」衆願奉神武。",
    "entities": [
      {
        "text": "與爾俱失鄉",
        "label": "LOC",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000135",
    "sentence": "神武曰：「爾鄉里難制，不見葛榮乎？雖百萬衆，無刑法，終自灰滅。今以吾為主，當與前異，不得欺漢兒，不得犯軍令，生死任吾則可，不爾不能為，取笑天下。」衆皆頓顙，死生唯命。",
    "entities": [
      {
        "text": "爾鄉",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_001_000136",
    "sentence": "神武曰若不得已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000137",
    "sentence": "明日，椎牛饗士，喻以討尒朱之意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000138",
    "sentence": "封隆之進曰：「千載一時，普天幸甚。」神武曰：「討賊，大順也；拯時，大業也。吾雖不武，以死繼之，何敢讓焉！」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000139",
    "sentence": "六月庚子，建義於信都，尚未顯背尒朱氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_001_000140",
    "sentence": "及李元忠與高乾平殷州，斬尒朱羽生首來謁，神武撫膺曰：「今日反決矣。」乃以元忠為殷州刺史。",
