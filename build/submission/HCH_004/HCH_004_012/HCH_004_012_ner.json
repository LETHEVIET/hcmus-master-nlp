        "end": 11
      },
      {
        "text": "貞爲靑州",
        "label": "LOC",
        "start": 12,
        "end": 16
      },
      {
        "text": "仁英爲冀州",
        "label": "LOC",
        "start": 17,
        "end": 22
      },
      {
        "text": "仁儉爲膠州",
        "label": "LOC",
        "start": 23,
        "end": 28
      },
      {
        "text": "仁直爲濟州",
        "label": "LOC",
        "start": 29,
        "end": 34
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 34,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000189",
    "sentence": "自廓已下，多與後主死於長安。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000190",
    "sentence": "仁英以淸狂，仁雅以喑疾，獲免，倶徙蜀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000191",
    "sentence": "隋開皇中，追仁英，詔與蕭琮、陳叔寶修其本宗祭禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000192",
    "sentence": "未幾而卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000193",
    "sentence": "後主五男",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000194",
    "sentence": "後主五男：穆皇后生幼主，諸姬生東平王恪，次善德，次買德，次質錢。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000195",
    "sentence": "胡太后以恪嗣琅邪王，尋夭折。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000196",
    "sentence": "齊滅，周武帝以任城已下大小三十王歸長安，皆有封爵。",
    "entities": [
      {
        "text": "周武帝以任城",
        "label": "LOC",
        "start": 3,
        "end": 9
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000197",
    "sentence": "其後不從戮者散配西土，皆死邊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000198",
    "sentence": "論",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000199",
    "sentence": "論曰：武成殘忍姦穢，事極人倫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000200",
    "sentence": "太原跡異猜嫌，情非釁逆，禍起昭信，遂及淫刑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000201",
    "sentence": "嗟乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000202",
    "sentence": "欲求長世，未之有也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000203",
    "sentence": "以孝昭德音，庶可慶流後嗣，百年之酷，蓋濟南之濫觴。",
    "entities": [
      {
        "text": "百年",
        "label": "TME",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000204",
    "sentence": "其云「莫效前人」之言，可爲傷嘆，各愛其子，豈其然乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000205",
    "sentence": "琅邪雖無師傅之資，而早聞氣尚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000206",
    "sentence": "士開淫亂，多歴歳年，一朝勦絶，慶集朝野，以之受斃，深可痛焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000207",
    "sentence": "然專戮之釁，未之或免，贈帝謚恭，矯枉過直，觀過知仁，不亦異於是乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000208",
    "sentence": "校",
    "entities": []
  },
