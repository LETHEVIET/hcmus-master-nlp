[
  {
    "sentence_id": "HCH_004_012_000001",
    "sentence": "文宣四王",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000002",
    "sentence": "文宣五男：李后生 廢帝 及太原王紹德，馮世婦生范陽王紹義，裴嬪生西河王紹仁，顏嬪生隴西王紹廉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000003",
    "sentence": "太原王紹德",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000004",
    "sentence": "太原王紹德，文宣第二子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000005",
    "sentence": "天保末，爲開府儀同三司。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000006",
    "sentence": "武成因怒李后，罵紹德曰：「你父打我時，竟不來救！」以刀環築殺之，親以土埋之遊豫園。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000007",
    "sentence": "武平元年 ，詔以范陽王子辨才爲後，襲太原王。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000008",
    "sentence": "范陽王紹義",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000009",
    "sentence": "范陽王紹義，文宣第三子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000010",
    "sentence": "初封廣陽，後封范陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000011",
    "sentence": "歴位侍中、淸都尹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000012",
    "sentence": "好與羣小同飲，擅置内參，打殺博士任方榮。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000013",
    "sentence": "武成嘗杖之二百，送付昭信后，后又杖一百。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000014",
    "sentence": "及後主奔鄴，以紹義爲尚書令、定州刺史。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "定州",
        "label": "LOC",
        "start": 14,
        "end": 16
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000015",
    "sentence": "周武帝克幷州，以封輔相爲北朔州總管。",
    "entities": [
      {
        "text": "周武帝克幷州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "封輔相爲北朔州",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000016",
    "sentence": "此地齊以重鎭，諸勇士多聚焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000017",
    "sentence": "前長史趙穆、司馬王當萬等謀執輔相，迎任城王於瀛州。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "迎任城王於瀛州",
        "label": "LOC",
        "start": 17,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000018",
    "sentence": "事不果，便迎紹義。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000019",
    "sentence": "紹義至馬邑。",
    "entities": [
      {
        "text": "紹義至馬邑",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000020",
    "sentence": "輔相及其屬韓阿各奴等數十人皆齊叛臣，自肆州以北城戍二百八十餘盡從輔相，及紹義至，皆反焉。",
    "entities": [
      {
        "text": "自肆州以北城",
        "label": "LOC",
        "start": 18,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000021",
    "sentence": "紹義與靈州刺史袁洪猛引兵南出，欲取幷州，至新興而肆州已爲周守。",
    "entities": [
      {
        "text": "紹義與靈州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "欲取幷州",
        "label": "LOC",
        "start": 15,
        "end": 19
      },
      {
        "text": "至新興而肆州",
        "label": "LOC",
        "start": 20,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000022",
    "sentence": "前隊二儀同以所部降周。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000023",
    "sentence": "周兵撃顯州，執刺史陸瓊，又攻陷諸城。",
    "entities": [
      {
        "text": "周兵撃顯州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "又攻陷諸城",
        "label": "LOC",
        "start": 12,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000024",
    "sentence": "紹義還保北朔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000025",
    "sentence": "周將宇文神舉軍逼馬邑，紹義遣杜明達拒之，兵大敗。",
    "entities": [
      {
        "text": "文神舉軍逼馬邑",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000026",
    "sentence": "紹義曰：「有死而已，不能降人。」遂奔突厥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000027",
    "sentence": "衆三千家，令之曰：「欲還者任意。」於是哭拜別者太半。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000028",
    "sentence": "突厥他缽可汗謂文宣爲英雄天子，以紹義重踝似之，甚見愛重，凡齊人在北者，悉隸紹義。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000029",
    "sentence": "髙寶寧在營州，表上尊號，紹義遂卽皇帝位，稱武平元年。",
    "entities": [
      {
        "text": "髙寶寧在營州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "元年",
        "label": "TME",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000030",
    "sentence": "以趙穆爲天水王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000031",
    "sentence": "他缽聞寶寧得平州，亦招諸部，各舉兵南向，云共立范陽王作齊帝，爲其報讐。",
    "entities": [
      {
        "text": "缽聞寶寧得平州",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000032",
    "sentence": "周武帝大集兵於雲陽，將親北伐，遇疾暴崩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000033",
    "sentence": "紹義聞之，以爲天贊己。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000034",
    "sentence": "盧昌斯據范陽，亦表迎紹義。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000035",
    "sentence": "俄而周將宇文神舉攻滅昌期。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000036",
    "sentence": "其日，紹義適至幽州，聞周總管出兵于外，欲乘虚取薊城，列天子旌旗，登燕昭王冢，乘髙望遠，部分兵衆。",
    "entities": [
      {
        "text": "紹義適至幽州",
        "label": "LOC",
        "start": 3,
        "end": 9
      },
      {
        "text": "欲乘虚取薊城",
        "label": "LOC",
        "start": 19,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000037",
    "sentence": "神舉遣大將軍宇文恩將四千人馳救幽州，半爲齊軍所殺。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 3,
        "end": 6
      },
      {
        "text": "四千人馳救幽州",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000038",
    "sentence": "紹義聞范陽城陷，素服舉哀，迴軍入突厥。",
    "entities": [
      {
        "text": "紹義聞范陽城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000039",
    "sentence": "周人購之於他缽，又使賀若誼往説之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000040",
    "sentence": "他缽猶不忍，遂偽與紹義獵於南境，使誼執之，流于蜀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000041",
    "sentence": "紹義妃渤海封孝琬女，自突厥逃歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000042",
    "sentence": "紹義在蜀，遺妃書云：「夷狄無信，送吾於此。」竟死蜀中。",
    "entities": [
      {
        "text": "蜀",
        "label": "ORG",
        "start": 24,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000043",
    "sentence": "西河王紹仁",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000044",
    "sentence": "西河王紹仁，文宣第四子也，天保末，爲開府儀同三司。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000045",
    "sentence": "尋薨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000046",
    "sentence": "隴西王紹廉",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000047",
    "sentence": "隴西王紹廉，文宣第五子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000048",
    "sentence": "初封長樂，後改焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000049",
    "sentence": "性粗暴，嘗拔刀逐紹義，紹義走入廄，閉門拒之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000050",
    "sentence": "紹義初爲淸都尹，未及理事，紹廉先往，喚囚悉出，率意決遣之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000051",
    "sentence": "能飲酒，一舉數升，終以此薨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000052",
    "sentence": "孝昭六王",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000053",
    "sentence": "孝昭七男：元后生樂陵王百年，桑氏生襄城王亮，出後 襄城景王 ，諸姬生汝南王彦理、始平王彦德、城陽王彦基、定陽王彦康、汝陽王彦忠。",
    "entities": [
      {
        "text": "百年",
