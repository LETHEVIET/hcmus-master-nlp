        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000170",
    "sentence": "北平王貞",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000171",
    "sentence": "北平王貞，字仁堅，武成第五子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000172",
    "sentence": "沈審寬恕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000173",
    "sentence": "帝常曰：「此兒得我鳳毛。」位司州牧、京畿大都督，兼尚書令、録尚書事。",
    "entities": [
      {
        "text": "位司州",
        "label": "LOC",
        "start": 13,
        "end": 16
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 20,
        "end": 22
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 25,
        "end": 27
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000174",
    "sentence": "帝行幸，總留臺事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000175",
    "sentence": "積年，後主以貞長大，漸忌之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000176",
    "sentence": "阿那肱承旨，令馮士幹劾繫貞於獄，奪其留後權。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000177",
    "sentence": "髙平王仁英",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000178",
    "sentence": "髙平王仁英，武成第六子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000179",
    "sentence": "舉止軒昂，精神無檢格。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000180",
    "sentence": "位定州刺史。",
    "entities": [
      {
        "text": "位定州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_012_000181",
    "sentence": "淮南王仁光",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000182",
    "sentence": "淮南王仁光，武成第七子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000183",
    "sentence": "性躁且暴，位淸都尹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000184",
    "sentence": "次西河王仁幾，生而無骨，不自支持；次樂平王仁邕；次潁川王仁儉；次安樂王仁雅，從小有喑疾；次丹陽王仁直；次東海王仁謙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000185",
    "sentence": "皆養於北宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000186",
    "sentence": "琅邪王死後，諸王守禁彌切。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000187",
    "sentence": "武平末年，仁邕已下始得出外，供給儉薄，取充而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_012_000188",
    "sentence": "尋後主窮蹙，以廓爲光州，貞爲靑州，仁英爲冀州，仁儉爲膠州，仁直爲濟州刺史。",
    "entities": [
      {
