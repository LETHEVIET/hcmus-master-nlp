  },
  {
    "sentence_id": "HCH_004_027_000082",
    "sentence": "孔雀少驍勇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000083",
    "sentence": "時宗人拔陵為亂，以孔雀為大都督、司徒、平南王。",
