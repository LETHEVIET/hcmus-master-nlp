[
  {
    "sentence_id": "HCH_004_027_000001",
    "sentence": "万俟普 子 洛 可朱渾元 劉豐 破六韓常 金祚 韋子粲",
    "entities": [
      {
        "text": "破六韓常",
        "label": "PER",
        "start": 16,
        "end": 20
      },
      {
        "text": "韋子粲",
        "label": "PER",
        "start": 24,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000002",
    "sentence": "万俟普",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000003",
    "sentence": "万俟普，字普撥，太平人，其先匈奴之別種也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000004",
    "sentence": "雄果有武力。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000005",
    "sentence": "正光中，破六韓拔陵構逆，授普太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000006",
    "sentence": "率部下降魏，授後將軍，第二領民酋長。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000007",
    "sentence": "高祖起義，普遠通誠款，高祖甚嘉之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000008",
    "sentence": "斛斯椿逼帝西出，授司空、秦州刺史，據覆靺城。",
    "entities": [
      {
        "text": "斛斯椿",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "秦州",
        "label": "LOC",
        "start": 12,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "據覆靺城",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000009",
    "sentence": "高祖平夏州，普乃率其部落來奔，高祖躬自迎接，授普河西公。",
    "entities": [
      {
        "text": "高祖平夏州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000010",
    "sentence": "累遷太尉、朔州刺史，卒。",
    "entities": [
      {
        "text": "朔州",
        "label": "LOC",
        "start": 5,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000011",
    "sentence": "子洛，字受洛干。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000012",
    "sentence": "豪壯有武藝，騎射過人，為鄉閭所伏。",
    "entities": [
      {
        "text": "為鄉",
        "label": "LOC",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000013",
    "sentence": "拔陵反，隨父歸順，除顯武將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000014",
    "sentence": "隨尒朱榮每有戰功，累遷汾州刺史、驃騎將軍。",
    "entities": [
      {
        "text": "累遷汾州",
        "label": "LOC",
        "start": 9,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000015",
    "sentence": "及起義信都，遠送誠款，高祖嘉其父子俱至，甚優其禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000016",
    "sentence": "除撫軍，兼靈州刺史。",
    "entities": [
      {
        "text": "兼靈州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000017",
    "sentence": "武帝入關，除左仆射。",
    "entities": [
      {
        "text": "武帝入關",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000018",
    "sentence": "天平中，隨父東歸，封建昌郡公，再遷領軍將軍。",
    "entities": [
      {
        "text": "封建昌郡",
        "label": "LOC",
        "start": 9,
        "end": 13
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000019",
    "sentence": "與諸將圍獨孤如願於金墉，及河陰之戰，並有功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000020",
    "sentence": "高祖以其父普尊老，特崇禮之，嘗親扶上馬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000021",
    "sentence": "洛免冠稽首曰：「願出死力以報深恩。」及此役也，諸軍北渡橋，洛以一軍不動。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000022",
    "sentence": "謂西人曰：「万俟受洛干在此，能來可來也！」西人畏而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000023",
    "sentence": "高祖以雄壯，名其所營地為回洛城。",
    "entities": [
      {
        "text": "所營地為回洛城",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000024",
    "sentence": "洛慷慨有氣節，勇銳冠時，當世推為名將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000025",
    "sentence": "興和初卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000026",
    "sentence": "可朱渾元",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000027",
    "sentence": "可朱渾元，字道元。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000028",
    "sentence": "自云遼東人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000029",
    "sentence": "世為渠帥，魏時擁衆內附，曾祖護野肱終於懷朔鎮將，遂家焉。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 5,
        "end": 6
      },
      {
        "text": "野肱終於懷朔鎮",
        "label": "LOC",
        "start": 15,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000030",
    "sentence": "元寬仁有武略，少與高祖相知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000031",
    "sentence": "北邊擾亂，遂將家屬赴定州，值鮮于修禮作亂，元擁衆屬焉。",
    "entities": [
      {
        "text": "遂將家屬赴定州",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000032",
    "sentence": "葛榮併並修禮，復以元為梁王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000033",
    "sentence": "遂奔尒朱榮，以為別將，隸天光征關中，以功為渭州刺史。",
    "entities": [
      {
        "text": "隸天光征關",
        "label": "LOC",
        "start": 11,
        "end": 16
      },
      {
        "text": "以功為渭州",
        "label": "LOC",
        "start": 18,
        "end": 23
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000034",
    "sentence": "侯莫陳悅之殺賀拔岳也，周文帝率岳所部還，共圖悅。",
    "entities": [
      {
        "text": "侯莫陳悅",
        "label": "PER",
        "start": 0,
        "end": 4
      },
      {
        "text": "賀拔岳",
        "label": "PER",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000035",
    "sentence": "元時助悅，悅走，元收其衆，入據秦州，為周攻圍，苦戰，結盟而罷。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 0,
        "end": 1
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000036",
    "sentence": "元既早被高祖知遇，兼其母兄在東，嘗有思歸之志，恒遣表疏，與高祖陰相往來。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000037",
    "sentence": "周文忌元智勇，知元懷貳，發兵攻之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000038",
    "sentence": "元乃率所部，發自渭州，西北渡烏蘭津。",
    "entities": [
      {
        "text": "發自渭州",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000039",
    "sentence": "周文頻遣兵邀之，元戰必摧之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000040",
    "sentence": "引軍歷河、源二州境，乃得東出。",
    "entities": [
      {
        "text": "源二州",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000041",
    "sentence": "靈州刺史曹埿女婿劉豐與元深相交結，元因說豐以高祖英武非常，克成大業，豐自此便有委質之心，遂資遣元。",
    "entities": [
      {
        "text": "靈州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000042",
    "sentence": "元從靈州東北入雲州。",
    "entities": [
      {
        "text": "元從靈州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "東北入雲州",
        "label": "LOC",
        "start": 4,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000043",
    "sentence": "高祖聞其來也，遣平陽守高嵩持金環一枚以賜元，並運資糧，遠遣候接。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000044",
    "sentence": "元至晉陽，引見執手，賜帛千匹並奴婢田宅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000045",
    "sentence": "兄弟四人先在幷州者，進官爵。",
    "entities": [
      {
        "text": "弟四人先在幷州",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000046",
    "sentence": "元所部督將，皆賞以爵邑。",
    "entities": [
      {
        "text": "皆賞以爵邑",
        "label": "LOC",
        "start": 6,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000047",
    "sentence": "封元縣公，除車騎大將軍。",
    "entities": [
      {
        "text": "封元縣",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000048",
    "sentence": "討西魏儀同金祚、皇甫智達於東雍，擒之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000049",
    "sentence": "遷幷州刺史。",
    "entities": [
      {
        "text": "遷幷州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000050",
    "sentence": "又與諸將征伐，頻有克捷降下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000051",
    "sentence": "天保初，封扶風王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000052",
    "sentence": "頻從顯祖討山胡、茹茹，累有戰功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000053",
    "sentence": "遷太師，薨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000054",
    "sentence": "贈假黃鉞、太宰、錄尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000055",
    "sentence": "元善於御衆，行軍用兵，務在持重，前後出征，未嘗負敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000056",
    "sentence": "及卒，朝廷深悼之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000057",
    "sentence": "皇建初，配享世宗廟庭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000058",
    "sentence": "劉豐",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000059",
    "sentence": "劉豐，字豐生，普樂人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000060",
    "sentence": "有雄姿壯氣，果毅絕人，有口辯，好說兵事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000061",
    "sentence": "破六韓拔陵之亂，豐以守城之功，除普樂太守。",
    "entities": [
      {
        "text": "豐以守城",
        "label": "LOC",
        "start": 8,
        "end": 12
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000062",
    "sentence": "魏永安初，除靈州鎮城大都督。",
    "entities": [
      {
        "text": "除靈州鎮城",
        "label": "LOC",
        "start": 5,
        "end": 10
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000063",
    "sentence": "周文授以衛大將軍，豐不受，乃遣攻圍，不克。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000064",
    "sentence": "豐遠慕高祖威德，乃率戶數萬來奔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000065",
    "sentence": "高祖上豐為平西將軍、南汾州刺史。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "南汾州",
        "label": "LOC",
        "start": 10,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000066",
    "sentence": "遂與諸將征討，平定寇亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000067",
    "sentence": "又從高祖破周文於河陰，豐功居多，高祖執手嗟賞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000068",
    "sentence": "入為左衛將軍，出除殷州。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "出除殷州",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000069",
    "sentence": "王思政據長社，世宗命豐與清河王岳攻之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000070",
    "sentence": "豐建水攻之策，遂遏洧水以灌之，水長，魚鱉皆遊焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000071",
    "sentence": "九月至四月，城將陷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000072",
    "sentence": "豐與行臺慕容紹宗見北有白氣同入船，忽有暴風從東北來，正晝昏暗，飛沙走礫，船纜忽絕，漂至城下。",
    "entities": [
      {
        "text": "慕容紹宗",
        "label": "PER",
        "start": 4,
        "end": 8
      },
      {
        "text": "漂至城",
        "label": "LOC",
        "start": 41,
        "end": 44
      }
    ]
  },
  {
    "sentence_id": "HCH_004_027_000073",
    "sentence": "豐遊水向土山，為浪所激，不時至，西人釣之，並為敵人所害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000074",
    "sentence": "豐壯勇善戰，為諸將所推。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000075",
    "sentence": "死之日，朝野駭惋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_027_000076",
    "sentence": "贈大司馬、司徒公、尚書令，諡曰忠。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
