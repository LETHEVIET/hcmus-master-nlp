[
  {
    "sentence_id": "HCH_004_037_000001",
    "sentence": "魏收",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000002",
    "sentence": "魏收，字伯起，小字佛助，鉅鹿下曲陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000003",
    "sentence": "曾祖緝，祖韶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000004",
    "sentence": "父子建，字敬忠，贈儀同、定州刺史。",
    "entities": [
      {
        "text": "定州",
        "label": "LOC",
        "start": 12,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_037_000005",
    "sentence": "收年十五，頗已屬文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000006",
    "sentence": "及隨父赴邊，好習騎射，欲以武藝自達。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000007",
    "sentence": "滎陽鄭伯調之曰：「魏郎弄戟多少？」收慚，遂折節讀書。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000008",
    "sentence": "夏月坐板床，隨樹陰諷誦，積年，板床為之銳減，而精力不輟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000009",
    "sentence": "以文華顯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000010",
    "sentence": "初除太學博士。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_037_000011",
    "sentence": "及尒朱榮於河陰濫害朝士，收亦在圍中，以日晏獲免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000012",
    "sentence": "吏部尚書李神儁重收才學，奏授司徒記室參軍。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_037_000013",
    "sentence": "永安三年 ，除北主客郎中。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_037_000014",
    "sentence": "節閔帝立，妙簡近侍，詔試收為《封禪書》，收下筆便就，不立稿草，文將千言，所改無幾。",
    "entities": [
      {
        "text": "《封禪書》",
        "label": "TITLE",
        "start": 14,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_037_000015",
    "sentence": "時黃門郎賈思同侍立，深奇之，白帝曰：「雖七步之才，無以過此。」遷散騎侍郎，尋勑典起居注，並修國史，兼中書侍郎，時年二十六。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 34,
        "end": 36
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 52,
        "end": 54
      }
    ]
  },
  {
    "sentence_id": "HCH_004_037_000016",
    "sentence": "孝武初，又詔收攝本職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000017",
    "sentence": "文誥填積，事咸稱旨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000018",
    "sentence": "黃門郎崔㥄從齊神武入朝，熏灼於世，收初不詣門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000019",
    "sentence": "㥄為帝登阼赦，云「朕託體孝文」，收嗤其率直。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000020",
    "sentence": "正員郎李慎以告之，㥄深憤忌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000021",
    "sentence": "時節閔帝殂，令收為詔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000022",
    "sentence": "㥄乃宣言：收普泰世出入幃幄，一日造詔，優為詞旨，然則義旗之士盡為逆人；又收父老，合解官歸侍，南臺將加彈劾，賴尚書辛雄為言於中尉綦儁，乃解。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 54,
        "end": 56
      }
    ]
  },
  {
    "sentence_id": "HCH_004_037_000023",
    "sentence": "收有賤生弟仲同，先未齒錄，因此怖懼，上籍，遣還鄉扶侍。",
    "entities": [
      {
        "text": "遣還鄉",
        "label": "LOC",
        "start": 21,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_037_000024",
    "sentence": "孝武嘗大發士卒，狩於嵩少之南旬有六日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000025",
    "sentence": "時天寒，朝野嗟怨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000026",
    "sentence": "帝與從官及諸妃主，奇伎異飾，多非禮度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000027",
    "sentence": "收欲言則懼，欲默不能已，乃上《南狩賦》以諷焉，時年二十七，雖富言淫麗，而終歸雅正。",
    "entities": [
      {
        "text": "《南狩賦》",
        "label": "TITLE",
        "start": 14,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_037_000028",
    "sentence": "帝手詔報焉，甚見褒美。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000029",
    "sentence": "鄭伯謂曰：「卿不遇老夫，猶應逐兔。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000030",
    "sentence": "初，神武固讓天柱大將軍，魏帝勑收為詔，令遂所請。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_037_000031",
    "sentence": "欲加相國，問品秩，收以實對，帝遂止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000032",
    "sentence": "收旣未測主相之意，以前事不安，求解，詔許焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000033",
    "sentence": "久之，除帝兄子廣平王贊開府從事中郎，收不敢辭，乃為《庭竹賦》以致己意。",
    "entities": [
      {
        "text": "《庭竹賦》",
        "label": "TITLE",
        "start": 25,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_004_037_000034",
    "sentence": "尋兼中書舍人，與濟陰溫子升、河間邢子才齊譽，世號三才。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000035",
    "sentence": "時孝武猜忌神武，內有間隙，收遂以疾固辭而免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000036",
    "sentence": "其舅崔孝芬怪而問之，收曰：「懼有晉陽之甲。」尋而神武南上，帝西入關。",
    "entities": [
      {
        "text": "崔孝芬",
        "label": "PER",
        "start": 2,
        "end": 5
      },
      {
        "text": "帝西入關",
        "label": "LOC",
        "start": 29,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_004_037_000037",
    "sentence": "收兼通直散騎常侍，副王昕使梁，昕風流文辯，收辭藻富逸，梁主及其群臣咸加敬異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000038",
    "sentence": "先是南北初和，李諧、盧元明首通使命，二人才器，並為鄰國所重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000039",
    "sentence": "至此，梁主稱曰：「盧、李命世，王、魏中興，未知後來復何如耳？」收在館，遂賣吳婢入館，其部下有賣婢者，收亦喚取，遍行奸穢，梁朝館司皆為之獲罪。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 17,
        "end": 18
      },
      {
        "text": "梁朝",
        "label": "ORG",
        "start": 60,
        "end": 62
      }
    ]
  },
  {
    "sentence_id": "HCH_004_037_000040",
    "sentence": "人稱其才而鄙其行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_037_000041",
    "sentence": "在途作《聘遊賦》，辭甚美盛。",
    "entities": [
      {
        "text": "《聘遊賦》",
        "label": "TITLE",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_037_000042",
    "sentence": "使還，尚書右僕射高隆之求南貨於昕、收，不能如志，遂諷御史中尉高仲密禁止昕、收於其臺，久之得釋。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
