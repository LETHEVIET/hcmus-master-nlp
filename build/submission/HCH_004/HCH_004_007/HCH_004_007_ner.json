    ]
  },
  {
    "sentence_id": "HCH_004_007_000005",
    "sentence": "帝時年八歲，冠服端嚴，神情閑遠，華戎歎異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000006",
