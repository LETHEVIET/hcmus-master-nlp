        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000059",
    "sentence": "秋八月辛丑，詔以三臺宮為大興聖寺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000060",
    "sentence": "冬十二月癸巳，陳人來聘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000061",
    "sentence": "己酉，周將楊忠帥突厥阿史那木汗等二十餘萬人自恒州分為三道，殺掠吏人。",
    "entities": [
      {
        "text": "十餘萬人自恒州",
        "label": "LOC",
        "start": 17,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000062",
    "sentence": "是時，大雨雪連月，南北千餘裡平地數尺，霜晝下，雨血於太原。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000063",
    "sentence": "戊午，帝至晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000064",
    "sentence": "己未，周軍逼幷州，又遣大將軍達奚武帥眾數萬至東雍及晉州，與突厥相應。",
    "entities": [
      {
        "text": "周軍逼幷州",
        "label": "LOC",
        "start": 3,
        "end": 8
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 11,
        "end": 14
      },
      {
        "text": "萬至東雍及晉州",
        "label": "LOC",
        "start": 20,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000065",
    "sentence": "是歲，室韋、庫莫奚、靺羯、契丹並遣使朝貢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000066",
    "sentence": "河清三年",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000067",
    "sentence": "三年春正月庚申朔，周軍至城下而陳，戰於城西。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "周軍至城",
        "label": "LOC",
        "start": 9,
        "end": 13
      },
      {
        "text": "戰於城",
        "label": "LOC",
        "start": 17,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000068",
    "sentence": "周軍及突厥大敗，人畜死者相枕，數百里不絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000069",
    "sentence": "詔平原王段韶追出塞而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000070",
    "sentence": "三月辛酉，以律令班下，大赦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000071",
    "sentence": "己巳，盜殺太師、彭城王浟。",
    "entities": [
      {
        "text": "彭城",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000072",
    "sentence": "庚辰，以司空斛律光為司徒，以侍中、武興王普為尚書左僕射。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000073",
    "sentence": "甲申，以尚書令、馮翊王潤為司空。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000074",
    "sentence": "夏四月辛卯，詔兼散騎常侍皇甫亮使於陳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000075",
    "sentence": "五月甲子，帝至自晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000076",
    "sentence": "壬午，以尚書令、趙郡王叡為錄尚書事，以前司徒婁叡為太尉。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "趙郡",
        "label": "LOC",
        "start": 8,
        "end": 10
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000077",
    "sentence": "甲申，乙太傅段韶為太師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000078",
    "sentence": "丁亥，以太尉、任城王湝為大將軍。",
    "entities": [
      {
        "text": "任城",
        "label": "LOC",
        "start": 7,
        "end": 9
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000079",
    "sentence": "壬辰，行幸晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000080",
    "sentence": "六月庚子，大雨晝夜不息，至甲辰乃止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000081",
    "sentence": "是月，晉陽訛言有鬼兵，百姓競擊銅鐵以捍之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000082",
    "sentence": "殺樂陵王百年。",
    "entities": [
      {
        "text": "百年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000083",
    "sentence": "歸宇文媼于周。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000084",
    "sentence": "秋九月乙丑，封皇子綽為南陽王，儼為東平王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000085",
    "sentence": "是月，歸閻媼于周。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000086",
    "sentence": "陳人來聘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000087",
    "sentence": "突厥寇幽州，入長城，虜掠而還。",
    "entities": [
      {
        "text": "突厥寇幽州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "入長城",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000088",
    "sentence": "閏月乙未，詔遣十二使巡行水潦州，免其租調。",
    "entities": [
      {
        "text": "二使巡行水潦州",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000089",
    "sentence": "乙巳，突厥寇幽州。",
    "entities": [
      {
        "text": "突厥寇幽州",
        "label": "LOC",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000090",
    "sentence": "周軍三道並出，使其將尉遲迥寇洛陽，楊檦入軹關，權景宣趣懸瓠。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 14,
        "end": 16
      },
      {
        "text": "楊檦入軹關",
        "label": "LOC",
        "start": 17,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000091",
    "sentence": "冬十一月甲午，迥等圍洛陽。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000092",
    "sentence": "戊戌，詔兼散騎常侍劉逖使於陳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000093",
    "sentence": "甲辰，太尉婁叡大破周軍於軹關，擒楊檦。",
    "entities": [
      {
        "text": "大破周軍於軹關",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000094",
    "sentence": "十二月乙卯，豫州刺史王士良以城降周將權景宣。",
    "entities": [
      {
        "text": "豫州",
        "label": "LOC",
        "start": 6,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000095",
    "sentence": "丁巳，帝自晉陽南討。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000096",
    "sentence": "己未，太宰、平陽王淹薨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000097",
    "sentence": "壬戌，太師段韶大破尉遲迥等，解洛陽圍。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000098",
    "sentence": "丁卯，帝至洛陽，免洛州經周軍處一年租賦，赦州城內死罪已下囚。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 5,
        "end": 7
      },
      {
        "text": "免洛州",
        "label": "LOC",
        "start": 8,
        "end": 11
      },
      {
        "text": "一年",
        "label": "TME",
        "start": 15,
        "end": 17
      },
      {
        "text": "赦州城",
        "label": "LOC",
        "start": 20,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000099",
    "sentence": "己巳，乙太師段韶為太宰，以司徒斛律光為太尉，幷州刺史蘭陵王長恭為尚書令。",
    "entities": [
      {
        "text": "幷州",
        "label": "LOC",
        "start": 22,
        "end": 24
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 24,
        "end": 26
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000100",
    "sentence": "壬申，帝至武牢，經滑臺，次於黎陽，所經減降罪人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000101",
    "sentence": "丙子，車駕至自洛陽。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000102",
    "sentence": "是歲，高麗、靺羯、新羅並遣使朝貢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000103",
    "sentence": "山東大水，饑死者不可勝計，詔發賑給，事竟不行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000104",
    "sentence": "河清四年",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000105",
    "sentence": "四年春正月癸卯，以大將軍、任城王湝為大司馬。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 9,
        "end": 12
      },
      {
        "text": "任城",
        "label": "LOC",
        "start": 13,
        "end": 15
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000106",
    "sentence": "辛未，幸晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000107",
    "sentence": "二月甲寅，詔以新羅國王金真興為使持節、東夷校尉、樂浪郡公、新羅王。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 21,
        "end": 23
      },
      {
        "text": "樂浪郡",
        "label": "LOC",
        "start": 24,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000108",
    "sentence": "壬申，以年穀不登，禁酤酒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000109",
    "sentence": "己卯，詔減百官食稟各有差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000110",
    "sentence": "三月戊子，詔給西兗、梁、滄、趙州，司州之東郡、陽平、清河、武都，冀州之長樂、渤海遭水潦之處貧下戶粟，各有差。",
    "entities": [
      {
        "text": "趙州",
        "label": "LOC",
        "start": 14,
        "end": 16
      },
      {
        "text": "司州之東郡",
        "label": "LOC",
        "start": 17,
        "end": 22
      },
      {
        "text": "冀州",
        "label": "LOC",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000111",
    "sentence": "家別鬥升而已，又多不付。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000112",
    "sentence": "是月，彗星見；有物隕於殿庭，如赤漆鼓帶小鈴；殿上石自起，兩兩相對。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000113",
    "sentence": "又有神見於後園萬壽堂前山穴中，其體壯大，不辯其面，兩齒絕白，長出於唇，帝直宿嬪御已下七百人咸見焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000114",
    "sentence": "帝又夢之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000115",
    "sentence": "夏四月戊午，大將軍、東安王婁叡坐事免。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000116",
    "sentence": "乙亥，陳人來聘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000117",
    "sentence": "太史奏天文有變，其占當有易王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000118",
    "sentence": "丙子，乃使太宰段韶兼太尉，持節奉皇帝璽綬傳位於皇太子，大赦，改元為 天統元年 ，百官進級降罪各有差。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 24,
        "end": 26
      },
      {
        "text": "元年",
        "label": "TME",
        "start": 36,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000119",
    "sentence": "又詔皇太子妃斛律氏為皇后。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000120",
    "sentence": "於是群公上尊號為太上皇帝，軍國大事咸以奏聞。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000121",
    "sentence": "始將傳政，使內參乘子尚乘驛送詔書於鄴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000122",
    "sentence": "子尚出晉陽城，見人騎隨後，忽失之，尚未至鄴而其言已布矣。",
    "entities": [
      {
        "text": "子尚出晉陽城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000123",
    "sentence": "天統四年 十二月辛未，太上皇帝崩於鄴宮乾壽堂，時年三十二，諡曰武成皇帝，廟號世祖。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000124",
    "sentence": "五年二月甲申，葬於永平陵。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_007_000125",
    "sentence": "【論】",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000126",
    "sentence": "論曰：武成風度高爽，經算弘長，文武之官，俱盡其力，有帝王之量矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000127",
    "sentence": "但愛狎庸豎，委以朝權，帷薄之間，淫侈過度，滅亡之兆，其在斯乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000128",
    "sentence": "玄象告變，傳位元子，名號雖殊，政猶己出，跡有虛飾，事非憲典，聰明臨下，何易可誣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_007_000129",
    "sentence": "又河南、河間、樂陵等諸王，或以時嫌，或以猜忌，皆無罪而殞，非所謂知命任天道之義也。",
    "entities": []
