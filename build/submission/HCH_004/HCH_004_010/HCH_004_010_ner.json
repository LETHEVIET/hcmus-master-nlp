      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000077",
    "sentence": "七年，轉司州牧，選從事皆取文才士明剖斷者，當時稱為美選。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "轉司州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000078",
    "sentence": "州舊案五百餘，浟未期悉斷盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000079",
    "sentence": "別駕羊脩等恐犯權戚，乃詣閤諮陳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000080",
    "sentence": "浟使告曰：「吾直道而行，何憚權戚，卿等當成人之美，反以權戚為言。」脩等慚悚而退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000081",
    "sentence": "後加特進，兼司空、太尉，州牧如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000082",
    "sentence": "太妃薨，解任，尋詔復本官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000083",
    "sentence": "俄拜司空，兼尚書令。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000084",
    "sentence": "濟南嗣位，除開府儀同三司、尚書令、領大宗正卿。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000085",
    "sentence": "皇建初，拜大司馬，兼尚書令，轉太保。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000086",
    "sentence": "武成入承大業，遷太師、錄尚書事。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000087",
    "sentence": "浟明練世務，果於斷決，事無大小，咸悉以情。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000088",
    "sentence": "趙郡李公統預高歸彥之逆，其母崔氏卽御史中丞崔昂從父子，兼右僕射魏收之內妹也。",
    "entities": [
      {
        "text": "趙郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000089",
    "sentence": "依令，年出六十，例免入官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000090",
    "sentence": "崔增年陳訴，所司以昂、收故，崔遂獲免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000091",
    "sentence": "浟摘發其事，昂等以罪除名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000092",
    "sentence": "自車駕巡幸，浟常留鄴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000093",
    "sentence": "河清三年三月，群盜田子禮等數十人謀劫浟為主，詐稱使者，徑向浟第，至內室，稱勑牽浟上馬，臨以白刃，欲引向南殿。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000094",
    "sentence": "浟大呼不從，遂遇害，時年三十二，朝野痛惜焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000095",
    "sentence": "初浟未被劫前，其妃鄭氏夢人斬浟頭持去，惡之，數日而浟見殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000096",
    "sentence": "贈假黃鉞、太師、太尉、錄尚書事，給轀輬車。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000097",
    "sentence": "子寶德嗣，位開府，兼尚書左僕射。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000098",
    "sentence": "上黨剛肅王",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000099",
    "sentence": "上黨剛肅王渙，字敬壽，神武第七子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000100",
    "sentence": "天姿雄傑，俶儻不群，雖在童幼，恒以將略自許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000101",
    "sentence": "神武壯而愛之，曰：「此兒似我。」及長，力能扛鼎，材武絕倫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000102",
    "sentence": "每謂左右曰：「人不可無學，但要不為博士耳。」故讀書頗知梗概，而不甚耽習。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000103",
    "sentence": "元象中，封平原郡公。",
    "entities": [
      {
        "text": "封平原郡",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000104",
    "sentence": "文襄之遇賊，渙年尚幼，在西學，聞宮中嘩，驚曰：「大兄必遭難矣！」彎弓而出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000105",
    "sentence": "武定末，除冀州刺史，在州有美政。",
    "entities": [
      {
        "text": "除冀州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "在州",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000106",
    "sentence": "天保初，封上党王，歷中書令、尚書左僕射。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000107",
    "sentence": "與常山王演等築伐惡諸城。",
    "entities": [
      {
        "text": "演等築伐惡諸城",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000108",
    "sentence": "遂聚鄴下輕薄，淩犯郡縣，為法司所糾。",
    "entities": [
      {
        "text": "淩犯郡縣",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000109",
    "sentence": "文宣戮其左右數人，渙亦被譴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000110",
    "sentence": "六年，率衆送梁王蕭明還江南，仍破東關，斬梁特進裴之橫等，威名甚盛。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "仍破東關",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000111",
    "sentence": "八年，錄尚書事。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000112",
    "sentence": "初，術士言亡高者黑衣，由是自神武后，每出行，不欲見沙門，為黑衣故也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000113",
    "sentence": "是時文宣幸晉陽，以所忌問左右曰：「何物最黑？」對曰：「莫過漆。」帝以渙第七子為當之，乃使庫真都督破六韓伯昇之鄴徵渙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000114",
    "sentence": "渙至紫陌橋，殺伯昇以逃，憑河而度，土人執以送帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000115",
    "sentence": "鐵籠盛之，與永安王浚同置地牢下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000116",
    "sentence": "歲餘，與浚同見殺，時年二十六。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000117",
    "sentence": "以其妃李氏配馮文洛，是帝家舊奴，積勞位至刺史，帝令文洛等殺渙，故以其妻妻焉。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000118",
    "sentence": "至 乾明元年 ，收二王餘骨葬之，贈司空，諡曰剛肅。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000119",
    "sentence": "有勑李氏還第。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000120",
    "sentence": "而文洛尚以故意，修飾詣李，李盛列左右，引文洛立於階下，數之曰：「遭難流離，以至大辱，志操寡薄，不能自盡，幸蒙恩詔，得反藩闈。汝是誰家孰奴，猶欲見侮！」於是杖之一百，流血灑地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000121",
    "sentence": "渙無嫡子，庶長子寶嚴以 河清二年 襲爵，位金紫光祿大夫、開府儀同三司。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 14,
        "end": 16
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000122",
    "sentence": "襄城景王",
    "entities": [
      {
        "text": "襄城",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000123",
    "sentence": "襄城景王淯，神武第八子也。",
    "entities": [
      {
        "text": "襄城",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000124",
    "sentence": "容貌甚美，弱年有器望。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000125",
    "sentence": "元象中，封章武郡公。",
    "entities": [
