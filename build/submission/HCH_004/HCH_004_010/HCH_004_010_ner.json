        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000150",
    "sentence": "及後主奔鄴，加湝大丞相。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000151",
    "sentence": "及安德王稱尊號於晉陽，使劉子昂修啟於湝：「至尊出奔，宗廟旣重，群公勸迫，權主號令，事甯終歸叔父。」湝曰：「我人臣，何容受此啟。」執子昂送鄴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000152",
    "sentence": "帝至濟州，禪位於湝，啟竟不達。",
    "entities": [
      {
        "text": "帝至濟州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000153",
    "sentence": "湝與廣甯王孝珩于冀州召募得四萬餘人，拒周軍。",
    "entities": [
      {
        "text": "甯王孝珩于冀州",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000154",
    "sentence": "周齊王憲來伐，先遣送書並赦詔，湝並沉諸井。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000155",
    "sentence": "戰敗，湝、孝珩俱被擒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000156",
    "sentence": "憲曰：「任城王何苦至此？」湝曰：「下官神武帝子，兄弟十五人，幸而獨存，逢宗社顛覆，今日得死，無愧墳陵。」憲壯之，歸其妻子。",
    "entities": [
      {
        "text": "任城",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000157",
    "sentence": "將至鄴城，湝馬上大哭，自投於地，流血滿面。",
    "entities": [
      {
        "text": "將至鄴城",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000158",
    "sentence": "至長安，尋與後主同死。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000159",
    "sentence": "妃盧氏，賜斛斯徵，蓬首垢面，長齋不言笑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000160",
    "sentence": "徵放之，乃為尼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000161",
    "sentence": "隋 開皇三年 ，表請文帝葬湝及五子於長安北原。",
    "entities": [
