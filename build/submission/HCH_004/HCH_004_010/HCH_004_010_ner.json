        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000126",
    "sentence": "天保初，封襄城郡王。",
    "entities": [
      {
        "text": "封襄城郡",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000127",
    "sentence": "二年春，薨。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000128",
    "sentence": "齊氏諸王選國臣府佐，多取富商群小、鷹犬少年，唯襄城、廣甯、蘭陵王等頗引文藝清識之士，當時以此稱之。",
    "entities": [
      {
