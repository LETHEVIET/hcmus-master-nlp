        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000054",
    "sentence": "博士韓毅教浟書，見浟筆跡未工，戲浟曰：「五郎書畫如此，忽為常侍開國，今日後宜更用心。」浟正色答曰：「昔甘羅幼為秦相，未聞能書。凡人唯論才具何如，豈必動誇筆跡。博士當今能者，何為不作三公？」時年蓋八歲矣。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "博士",
        "label": "TITLE",
        "start": 79,
        "end": 81
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000055",
    "sentence": "毅甚慚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000056",
    "sentence": "武定六年 ，出為滄州刺史，為政嚴察，部內肅然。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "出為滄州",
        "label": "LOC",
        "start": 6,
        "end": 10
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000057",
    "sentence": "守令參佐，下及胥吏，行遊往來，皆自賚糧食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000058",
    "sentence": "浟纖介知人間事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000059",
    "sentence": "有濕沃縣主簿張達嘗詣州，夜投人舍，食雞羹，浟察知之。",
    "entities": [
      {
        "text": "有濕沃縣",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "主簿張達嘗詣州",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000060",
    "sentence": "守令畢集，浟對衆曰：「食雞羹何不還價直也？」達卽伏罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000061",
    "sentence": "合境號為神明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000062",
    "sentence": "又有一人從幽州來，驢馱鹿脯。",
    "entities": [
      {
        "text": "又有一人從幽州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000063",
    "sentence": "至滄州界，腳痛行遲，偶會一人為伴，遂盜驢及脯去。",
    "entities": [
      {
        "text": "至滄州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000064",
    "sentence": "明旦，告州。",
    "entities": [
      {
        "text": "告州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000065",
    "sentence": "浟乃令左右及府僚吏分市鹿脯，不限其價。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000066",
    "sentence": "其主見脯識之，推獲盜者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000067",
    "sentence": "轉都督、定州刺史。",
    "entities": [
      {
        "text": "定州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000068",
    "sentence": "時有人被盜黑牛，背上有白毛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000069",
    "sentence": "長史韋道建謂中從事魏道勝曰：「使君在滄州日，擒姦如神，若捉得此賊，定神矣。」浟乃詐為上府市牛皮，倍酬價直，使牛主認之，因獲其盜。",
    "entities": [
      {
        "text": "使君在滄州",
        "label": "LOC",
        "start": 15,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000070",
    "sentence": "建等歎服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000071",
    "sentence": "又有老母姓王，孤獨，種菜三畝，數被偷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000072",
    "sentence": "浟乃令人密往書菜葉為字，明日市中看菜葉有字，獲賊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000073",
    "sentence": "爾後境內無盜，政化為當時第一。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000074",
    "sentence": "天保初，封彭城王。",
    "entities": [
      {
        "text": "封彭城",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000075",
    "sentence": "四年，徵為侍中，人吏送別悲號。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000076",
    "sentence": "有老公數百人相率具饌曰：「自殿下至來五載，人不識吏，吏不欺人，百姓有識已來，始逢今化。殿下唯飲此鄉水，未食此鄉食，聊獻疏薄。」浟重其意，為食一口。",
    "entities": [
      {
        "text": "殿下唯飲此鄉",
        "label": "LOC",
        "start": 43,
        "end": 49
      },
      {
        "text": "未食此鄉",
        "label": "LOC",
