      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000130",
    "sentence": "無子，詔以常山王演第二子亮嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000131",
    "sentence": "亮字彥道，性恭孝，美風儀，好文學。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000132",
    "sentence": "為徐州刺史，坐奪商人財物免官。",
    "entities": [
      {
        "text": "為徐州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000133",
    "sentence": "後主敗奔鄴，亮從焉，遷兼太尉、太傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000134",
    "sentence": "周師入鄴，亮於啟夏門拒守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000135",
    "sentence": "諸軍皆不戰而敗，周軍於諸城門皆入，亮軍方退走。",
    "entities": [
      {
        "text": "周軍於諸城",
        "label": "LOC",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000136",
    "sentence": "亮入太廟行馬內，慟哭拜辭，然後為周軍所執。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000137",
    "sentence": "入關，依例授儀同，分配遠邊，卒於龍州。",
    "entities": [
      {
        "text": "入關",
        "label": "LOC",
