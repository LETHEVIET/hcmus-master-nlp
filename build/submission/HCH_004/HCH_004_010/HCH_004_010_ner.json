    ]
  },
  {
    "sentence_id": "HCH_004_010_000138",
    "sentence": "任城王",
    "entities": [
      {
        "text": "任城",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000139",
    "sentence": "任城王湝，神武第十子也，少明慧。",
    "entities": [
      {
        "text": "任城",
        "label": "LOC",
        "start": 0,
