    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000163",
    "sentence": "高陽康穆王湜，神武第十一子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000164",
    "sentence": "天保元年 封。",
