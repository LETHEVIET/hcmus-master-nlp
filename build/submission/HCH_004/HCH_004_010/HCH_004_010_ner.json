        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000149",
    "sentence": "拜左丞相，轉瀛州刺史。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
