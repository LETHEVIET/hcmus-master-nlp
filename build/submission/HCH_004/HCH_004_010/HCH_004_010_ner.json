      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000173",
    "sentence": "子士義襲爵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000174",
    "sentence": "博陵文簡王",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_010_000175",
    "sentence": "博陵文簡王濟，神武第十二子也。",
    "entities": []
  },
