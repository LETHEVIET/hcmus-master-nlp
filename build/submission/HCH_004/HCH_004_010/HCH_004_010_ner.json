      }
    ]
  },
  {
    "sentence_id": "HCH_004_010_000129",
    "sentence": "乾明元年 二月，贈假黃鋮、太師、太尉、錄尚書事。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
