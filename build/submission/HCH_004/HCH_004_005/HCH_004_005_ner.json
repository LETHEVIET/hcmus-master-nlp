        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_005_000012",
    "sentence": "九年，文宣在晉陽，太子監國，集諸儒講《 孝經 》。",
