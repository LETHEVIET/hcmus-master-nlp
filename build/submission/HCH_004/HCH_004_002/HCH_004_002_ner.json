[
  {
    "sentence_id": "HCH_004_002_000001",
    "sentence": "神武下",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000002",
    "sentence": "天平元年 正月壬辰，神武西伐費也頭虜紇豆陵伊利於河西，滅之，遷其部於河東。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000003",
    "sentence": "二月，永寧寺九層浮圖災。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000004",
    "sentence": "旣而人有從東萊至，云及海上人咸見之於海中，俄而霧起乃滅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000005",
    "sentence": "說者以為天意若曰：永甯見災，魏不寧矣；飛入東海，渤海應矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000006",
    "sentence": "魏帝旣有異圖，時侍中封隆之與孫騰私言，隆之喪妻，魏帝欲妻以妹。",
    "entities": [
      {
        "text": "封隆之",
        "label": "PER",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000007",
    "sentence": "騰亦未之信，心害隆之，泄其言於斛斯椿。",
    "entities": [
      {
        "text": "斛斯椿",
        "label": "PER",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000008",
    "sentence": "椿以白魏帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000009",
    "sentence": "又孫騰帶仗入省，擅殺御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000010",
    "sentence": "並亡來奔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000011",
    "sentence": "稱魏帝撾舍人梁續於前，光祿少卿元子幹攘臂擊之，謂騰曰：「語爾高王，元家兒拳正如此。」領軍婁昭辭疾歸晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000012",
    "sentence": "魏帝於是以斛斯椿兼領軍，分置督將及河南、關西諸刺史。",
    "entities": [
      {
        "text": "斛斯椿",
        "label": "PER",
        "start": 5,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000013",
    "sentence": "華山王鷙在徐州，神武使邸珍奪其管籥。",
    "entities": [
      {
        "text": "華山王鷙在徐州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000014",
    "sentence": "建州刺史韓賢、濟州刺史蔡儁皆神武同義，魏帝忌之。",
    "entities": [
      {
        "text": "建州",
        "label": "LOC",
