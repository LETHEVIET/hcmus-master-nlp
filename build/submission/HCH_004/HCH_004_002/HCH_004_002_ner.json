      },
      {
        "text": "督竇泰入自潼關",
        "label": "LOC",
        "start": 36,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000118",
    "sentence": "四年正月癸丑，竇泰軍敗自殺。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000119",
    "sentence": "神武次蒲津，以冰薄不得赴救，乃班師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000120",
    "sentence": "高昂攻剋上洛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000121",
    "sentence": "二月乙酉，神武以幷、肆、汾、建、晉、東雍、南汾、泰、陝九州霜旱，人饑流散，請所在開倉賑給。",
    "entities": [
      {
        "text": "陝九州",
        "label": "LOC",
        "start": 26,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000122",
    "sentence": "六月壬申，神武如天池，獲瑞石，隱起成文曰「六王三川」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000123",
    "sentence": "十月壬辰，神武西討，自蒲津濟，衆二十萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000124",
    "sentence": "周文軍於沙苑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000125",
    "sentence": "神武以地阢阨少卻，西人鼓噪而進，軍大亂，棄器甲十有八萬，神武跨橐駝，候船以歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000126",
    "sentence": "元象元年 三月辛酉，神武固請解丞相，魏帝許之。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000127",
    "sentence": "四月庚寅，神武朝于鄴，壬辰，還晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000128",
    "sentence": "請開酒禁，並賑恤宿衛武官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000129",
    "sentence": "七月壬午，行台侯景、司徒高昂圍西魏將獨孤信於金墉，西魏帝及周文並來赴救。",
    "entities": [
      {
        "text": "獨孤信",
        "label": "PER",
        "start": 18,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000130",
    "sentence": "大都督厙狄干帥諸將前驅，神武總衆繼進。",
    "entities": [
      {
        "text": "大都",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000131",
    "sentence": "八月辛卯，戰於河陰，大破西魏軍，俘獲數萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000132",
    "sentence": "司徒高昂、大都督李猛、宋顯死之。",
    "entities": [
      {
        "text": "大都",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000133",
    "sentence": "西師之敗，獨孤信先入關，周文留其都督長孫子彥守金墉，遂燒營以遁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000134",
    "sentence": "神武遣兵追奔，至崤，不及而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000135",
    "sentence": "初，神武知西師來侵，自晉陽帥衆馳赴，至孟津，未濟，而軍有勝負。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000136",
    "sentence": "旣而神武渡河，子彥亦棄城走，神武遂毀金墉而還。",
    "entities": [
      {
        "text": "子彥亦棄城",
        "label": "LOC",
        "start": 7,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000137",
    "sentence": "十一月庚午，神武朝於京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000138",
    "sentence": "十二月壬辰，還晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000139",
    "sentence": "興和元年 七月丁丑，魏帝進神武為相國、錄尚書事，固讓乃止。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000140",
    "sentence": "十一月乙丑，神武以新宮成，朝於鄴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000141",
    "sentence": "魏帝與神武燕射，神武降階稱賀，又辭渤海王及都督中外諸軍事，詔不許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000142",
    "sentence": "十二月戊戌，神武還晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000143",
    "sentence": "二年十二月，阿至羅別部遣使請降。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000144",
    "sentence": "神武帥衆迎之，出武州塞，不見，大獵而還。",
    "entities": [
      {
        "text": "出武州",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000145",
    "sentence": "三年五月，神武巡北境，使使與蠕蠕通和。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000146",
    "sentence": "四年五月辛巳，神武朝鄴，請令百官每月面敷政事，明揚側陋，納諫屏邪，親理獄訟，褒黜勤怠；牧守有愆，節級相坐；椒掖之內，進御以序；後園鷹犬悉皆棄之。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000147",
    "sentence": "六月甲辰，神武還晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000148",
    "sentence": "九月，神武西征。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000149",
    "sentence": "十月己亥，圍西魏儀同三司王思政於玉壁城，欲以致敵，西師不敢出。",
    "entities": [
      {
        "text": "王思政於玉壁城",
        "label": "LOC",
        "start": 12,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000150",
    "sentence": "十一月癸未，神武以大雪士卒多死，乃班師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000151",
    "sentence": "武定元年 二月壬申，北豫州刺史高慎據武牢西叛。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "北豫州",
        "label": "LOC",
        "start": 10,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000152",
    "sentence": "三月壬辰，周文率衆援高慎，圍河橋南城。",
    "entities": [
      {
        "text": "圍河橋南城",
        "label": "LOC",
        "start": 13,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000153",
    "sentence": "戊申，神武大敗之於芒山，擒西魏督將已下四百餘人，俘斬六萬計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000154",
    "sentence": "是時軍士有盜殺驢者，軍令應死，神武弗殺，將至幷州決之。",
    "entities": [
      {
        "text": "將至幷州",
        "label": "LOC",
        "start": 20,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000155",
    "sentence": "明日復戰，奔西軍，告神武所在。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000156",
    "sentence": "西師盡銳來攻，衆潰，神武失馬，赫連陽順下馬以授神武，與蒼頭馮文洛扶上俱走，從者步騎六七人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000157",
    "sentence": "追騎至，親信都督尉興慶曰：「王去矣，興慶腰邊百箭，足殺百人。」神武勉之曰：「事濟，以爾為懷州，若死，則用爾子。」興慶曰：「兒小，願用兄。」許之。",
    "entities": [
      {
        "text": "以爾為懷州",
        "label": "LOC",
        "start": 41,
        "end": 46
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000158",
    "sentence": "興慶鬬，矢盡而死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000159",
    "sentence": "西魏太師賀拔勝以十三騎逐神武，河州刺史劉洪徽射中其二。",
    "entities": [
      {
        "text": "河州",
        "label": "LOC",
        "start": 15,
        "end": 17
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000160",
    "sentence": "勝矟將中神武，段孝先橫射勝馬殪，遂免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000161",
    "sentence": "豫、洛二州平。",
    "entities": [
      {
        "text": "洛二州",
        "label": "LOC",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000162",
    "sentence": "神武使劉豐追奔，拓地至弘農而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000163",
    "sentence": "七月，神武貽周文書，責以殺孝武之罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000164",
    "sentence": "八月辛未，魏帝詔神武為相國、錄尚書事、大行台，餘如故，固辭乃止。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000165",
    "sentence": "是月，神武命於肆州北山築城，西自馬陵戍，東至士隥，四十日罷。",
    "entities": [
      {
        "text": "神武命於肆州",
        "label": "LOC",
        "start": 3,
        "end": 9
      },
      {
        "text": "北山築城",
        "label": "LOC",
        "start": 9,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000166",
    "sentence": "十二月己卯，神武朝京師，庚辰，還晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000167",
    "sentence": "二年三月癸巳，神武巡行冀、定二州，因朝京師。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "定二州",
        "label": "LOC",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000168",
    "sentence": "以冬春亢旱，請蠲懸責，賑窮乏，宥死罪以下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000169",
    "sentence": "又請授老人板職各有差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000170",
    "sentence": "四月丙辰，神武還晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000171",
    "sentence": "十一月，神武討山胡，破平之，俘獲一萬餘戶口，分配諸州。",
    "entities": [
      {
        "text": "分配諸州",
        "label": "LOC",
        "start": 22,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000172",
    "sentence": "三年正月甲午，開府儀同三司尒朱文暢、開府司馬任胄、都督鄭仲禮、中府主簿李世林、前開府參軍房子遠等謀賊神武，因十五日夜打簇，懷刃而入，其黨薛季孝以告，並伏誅。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "司馬",
