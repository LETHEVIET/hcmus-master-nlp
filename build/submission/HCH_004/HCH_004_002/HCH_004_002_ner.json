    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000059",
    "sentence": "泰、貸文與顯智遇於長壽津，顯智陰約降，引軍退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000060",
    "sentence": "軍司元玄覺之，馳還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000061",
    "sentence": "請益師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000062",
    "sentence": "魏帝遣大都督侯幾紹赴之。",
