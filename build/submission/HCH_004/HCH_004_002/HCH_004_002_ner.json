      }
    ]
  },
  {
    "sentence_id": "HCH_004_002_000089",
    "sentence": "詔下三日，車駕便發，戶四十萬狼狽就道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_002_000090",
    "sentence": "神武留洛陽部分，事畢還晉陽。",
