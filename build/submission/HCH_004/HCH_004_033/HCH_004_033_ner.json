      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000049",
    "sentence": "建鄴陷，與從兄祗俱入東魏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000050",
    "sentence": "齊天保中，位金紫光祿大夫，卒。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000051",
    "sentence": "子慨，深沉有禮，樂善好學，攻草隸書。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000052",
    "sentence": "南士中稱為長者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000053",
    "sentence": "歷著作佐郎，待詔文林館，卒於司徒從事中郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000054",
    "sentence": "蕭放",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000055",
    "sentence": "蕭放，字希逸，隨父祗至鄴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000056",
    "sentence": "祗卒，放居喪以孝聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000057",
    "sentence": "所居廬室前有二慈鳥來集，各據一樹為巢，自午以前，馴庭飲啄，午後更不下樹，每臨時，舒翅悲鳴，全似哀泣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000058",
    "sentence": "家人伺之，未常有闕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000059",
    "sentence": "時以為至孝之感。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000060",
    "sentence": "服闋，襲爵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000061",
    "sentence": "武平中，待詔文林館。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000062",
    "sentence": "放性好文詠，頗善丹青，因此在宮中披覽書史及近世詩賦，監畫工作屏風等雜物見知，遂被眷待。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000063",
    "sentence": "累遷太子中庶子、散騎常侍。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000064",
    "sentence": "徐之才",
    "entities": [
      {
        "text": "徐之才",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000065",
    "sentence": "徐之才，丹陽人也。",
    "entities": [
      {
        "text": "徐之才",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000066",
    "sentence": "父雄，事南齊，位蘭陵太守，以醫術為江左所稱。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000067",
    "sentence": "之才幼而儁發，五歲誦《 孝經 》，八歲略通義旨。",
    "entities": [
      {
        "text": "《 孝經 》",
        "label": "TITLE",
        "start": 10,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000068",
    "sentence": "曾與從兄康造梁太子詹事汝南周舍宅聽《 老子 》。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "《 老子 》",
