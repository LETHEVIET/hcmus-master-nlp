      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000048",
    "sentence": "退在梁封湘潭侯，位青州刺史。",
    "entities": [
      {
        "text": "位青州",
        "label": "LOC",
        "start": 8,
