[
  {
    "sentence_id": "HCH_004_033_000001",
    "sentence": "蕭明　蕭祗　蕭退　蕭放　徐之才",
    "entities": [
      {
        "text": "徐之才",
        "label": "PER",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000002",
    "sentence": "蕭明",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000003",
    "sentence": "蕭明，蘭陵人，梁武帝長兄長沙王懿之子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000004",
    "sentence": "在其本朝，甚為梁武所親愛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000005",
    "sentence": "少歷顯職，封湞陽侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000006",
    "sentence": "太清中，以為豫州刺史。",
    "entities": [
      {
        "text": "清",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "以為豫州",
        "label": "LOC",
        "start": 4,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000007",
    "sentence": "梁主旣納侯景，詔明率水陸諸軍趨彭城，大圖進取。",
    "entities": [
      {
        "text": "水陸諸軍趨彭城",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000008",
    "sentence": "又命兗州刺史南康嗣王會理總馭群帥，指授方略。",
    "entities": [
      {
        "text": "又命兗州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000009",
    "sentence": "明渡淮未幾，官軍破之，盡俘其衆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000010",
    "sentence": "魏帝升門樓，親引見明及諸將帥，釋其禁，送於晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000011",
    "sentence": "世宗禮明甚重，謂之曰：「先王與梁主和好十有餘年，聞彼禮佛文，常雲奉為魏主，並及先王，此甚是梁主厚意。不謂一朝失信，致此紛擾。自出師薄伐，無戰不克，無城不陷，今自欲和，非是力屈。境上之事，知非梁主本心，當是侯景違命扇動耳。侯可遣使諮論，若猶存先王分義，重成通和者，吾不必違先王之旨，侯及諸人並卽放還。」於是使人以明書告梁主，梁主乃致書以慰世宗。",
    "entities": [
      {
        "text": "無城",
        "label": "LOC",
        "start": 73,
        "end": 75
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000012",
    "sentence": "天保六年 ，梁元為西魏所滅，顯祖詔立明為梁主，前所獲梁將湛海珍等皆聽從明歸，令上黨王渙率衆以送。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000013",
    "sentence": "是時梁太尉王僧辯、司空陳霸先在建鄴，推晉安王方智為丞相。",
    "entities": [
      {
        "text": "王僧辯",
        "label": "PER",
        "start": 5,
        "end": 8
      },
      {
        "text": "陳霸先",
        "label": "PER",
        "start": 11,
        "end": 14
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000014",
    "sentence": "顯祖賜僧辯、霸先璽書，僧辯未奉詔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000015",
    "sentence": "上黨王進軍，明又與僧辯書，往復再三，陳禍福，僧辯初不納。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000016",
    "sentence": "旣而上黨王破東關，斬裴之橫，江表危懼，僧辯乃啟上黨求納明，遣舟艦迎接。",
    "entities": [
      {
        "text": "而上黨王破東關",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "裴之橫",
        "label": "PER",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000017",
    "sentence": "王饗梁朝將士，及與明刑牲歃血，載書而盟。",
    "entities": [
      {
        "text": "梁朝",
        "label": "ORG",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000018",
    "sentence": "於是梁輿東度，齊師北反。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000019",
    "sentence": "侍中裴英起衛送明入建鄴，遂稱尊號，改 承聖四年 為 天成元年 ，大赦天下，宇文黑獺、賊詧等不在赦例。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 21,
        "end": 23
      },
      {
        "text": "天成元年",
        "label": "TME",
        "start": 26,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000020",
    "sentence": "以方智為太子，授王僧辯大司馬。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "王僧辯",
        "label": "PER",
        "start": 8,
        "end": 11
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000021",
    "sentence": "明上表遣第二息章馳到京都，拜謝宮闕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000022",
    "sentence": "冬，霸先襲殺僧辯，復立方智，以明為太傅、建安王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000023",
    "sentence": "霸先奉表朝廷，云僧辯陰謀篡逆，故誅之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000024",
    "sentence": "方智請稱臣，永為藩國，齊遣行臺司馬恭及梁人盟於歷陽。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000025",
    "sentence": "明年，詔徵明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000026",
    "sentence": "霸先猶稱藩，將遣使送明，會明疽發背死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000027",
    "sentence": "梁將王琳在江上與霸先相抗，顯祖遣兵納梁永嘉王蕭莊主梁祀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000028",
    "sentence": "九年二月，自湓城濟江，三月，卽帝位於郢州，年號天啟，王琳總其軍國，追諡明曰閔皇帝。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "自湓城",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "卽帝位於郢州",
        "label": "LOC",
        "start": 14,
        "end": 20
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 38,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000029",
    "sentence": "明年，莊為陳人所敗，遂入朝，封為侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000030",
    "sentence": "朝廷許以興復，竟不果。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000031",
    "sentence": "後主亡之日，莊在鄴飲氣而死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000032",
    "sentence": "蕭祗",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000033",
    "sentence": "蕭祗，字敬式，梁武弟南平王偉之子也。",
    "entities": [
      {
        "text": "王偉之",
        "label": "PER",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000034",
    "sentence": "少聰敏，美容儀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000035",
    "sentence": "在梁封定襄侯，位東揚州刺史。",
    "entities": [
      {
        "text": "位東揚州",
        "label": "LOC",
        "start": 7,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000036",
    "sentence": "於時江左承平，政寬人慢，祗獨莅以嚴切，梁武悅之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000037",
    "sentence": "遷北兗州刺史。",
    "entities": [
      {
        "text": "遷北兗州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000038",
    "sentence": "太清二年 ，侯景圍建鄴。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000039",
    "sentence": "祗聞臺城失守，遂來奔。",
    "entities": [
      {
        "text": "祗聞臺城",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000040",
    "sentence": "以 武定七年 至鄴，文襄令魏收、邢卲與相接對。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000041",
    "sentence": "歷位太子少傅，領平陽王師，封清河郡公。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "封清河郡",
        "label": "LOC",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000042",
    "sentence": "齊天保初，授右光祿大夫，領國子祭酒。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_033_000043",
    "sentence": "時梁元帝平侯景，復與齊通好，文宣欲放祗等還南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000044",
    "sentence": "俄而西魏剋江陵，遂留鄴都，卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_033_000045",
    "sentence": "贈中書監、車騎大將軍、揚州刺史。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 7,
        "end": 10
      },
      {
        "text": "揚州",
        "label": "LOC",
