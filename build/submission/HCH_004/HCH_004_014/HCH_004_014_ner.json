      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000009",
    "sentence": "無子，以兄子子瑗嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000010",
    "sentence": "天保初，改封平昌王，卒於魏尹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000011",
