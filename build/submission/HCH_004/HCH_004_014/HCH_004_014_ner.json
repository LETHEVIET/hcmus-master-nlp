        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000036",
    "sentence": "卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000037",
    "sentence": "上洛王",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000038",
    "sentence": "上洛王思宗，神武從子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000039",
    "sentence": "性寬和，頗有武幹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000040",
    "sentence": "天保初，封上洛郡王。",
    "entities": [
      {
        "text": "封上洛郡",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000041",
    "sentence": "歷位司空、太傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000042",
    "sentence": "薨於官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000043",
    "sentence": "子元海，累遷散騎常侍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000044",
    "sentence": "願處山林，脩行釋典。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000045",
    "sentence": "文宣許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000046",
    "sentence": "乃入林慮山，經二年，絕棄人事，志不能固，啟求歸。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000047",
    "sentence": "徵復本任，便縱酒肆情，廣納姬侍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000048",
    "sentence": "又除領軍，器小志大，頗以智謀自許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000049",
    "sentence": "皇建末，孝昭幸晉陽，武成居守，元海以散騎常侍留典機密。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000050",
    "sentence": "初孝昭之誅楊愔等，謂武成云：「事成，以爾為皇太弟。」及踐祚，乃使武成在鄴主兵，立子百年為皇太子，武成甚不平。",
    "entities": [
      {
        "text": "百年",
        "label": "TME",
        "start": 41,
        "end": 43
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 45,
        "end": 47
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000051",
    "sentence": "先是，恒留濟南於鄴，除領軍厙狄伏連為幽州刺史，以斛律豐樂為領軍，以分武成之權。",
    "entities": [
      {
        "text": "厙狄伏連為幽州",
        "label": "LOC",
        "start": 13,
        "end": 20
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000052",
    "sentence": "武成留伏連而不聽豐樂視事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000053",
    "sentence": "乃與河南王孝瑜偽獵，謀於野，暗乃歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000054",
    "sentence": "先是童謠云：「中興寺內白鳧翁，四方側聽聲雍雍，道人聞之夜打鐘。」時丞相府在北城中，卽舊中興寺也。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000055",
    "sentence": "鳧翁，謂雄雞，蓋指武成小字步落稽也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000056",
    "sentence": "道人，濟南王小名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000057",
    "sentence": "打鐘，言將被擊也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000058",
    "sentence": "旣而太史奏言北城有天子氣。",
    "entities": [
      {
        "text": "而太史奏言北城",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000059",
    "sentence": "昭帝以為濟南應之，乃使平秦王歸彥之鄴，迎濟南赴幷州。",
    "entities": [
      {
        "text": "迎濟南赴幷州",
        "label": "LOC",
        "start": 19,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000060",
    "sentence": "武成先咨元海，並問自安之計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000061",
    "sentence": "元海曰：「皇太后萬福，至尊孝性非常，殿下不須別慮。」武成曰：「豈我推誠之意耶？」元海乞還省一夜思之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000062",
    "sentence": "武成卽留元海後堂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000063",
    "sentence": "元海達旦不眠，唯繞床徐步。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000064",
    "sentence": "夜漏未曙，武成遽出，曰：「神算如何？」答云：「夜中得三策，恐不堪用耳。」因說梁孝王懼誅入關事，請乘數騎入晉陽，先見太后求哀，後見主上，請去兵權，以死為限，求不干朝政，必保太山之安。",
    "entities": [
      {
        "text": "梁孝王懼誅入關",
        "label": "LOC",
        "start": 38,
        "end": 45
      },
      {
        "text": "晉",
        "label": "ORG",
        "start": 52,
        "end": 53
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000065",
    "sentence": "此上策也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000066",
    "sentence": "若不然，當具表，云「『威權大盛，恐取謗衆口』，請青、齊二州刺史。沉靜自居，必不招物議。此中策也。」更問下策曰：「發言卽恐族誅。」因逼之，答曰：「濟南世嫡，主上假太后令而奪之。今集文武，示以此勑，執豐樂，斬歸彥，尊濟南，號令天下，以順討逆，此萬世一時也。」武成大悅，狐疑，竟未能用。",
    "entities": [
      {
        "text": "齊二州",
        "label": "LOC",
        "start": 26,
        "end": 29
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000067",
    "sentence": "乃使鄭道謙卜之，皆曰：「不利舉事，靜則吉。」又召曹魏祖，問之國事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000068",
    "sentence": "對曰：「當有大凶。」又時有林慮令姓潘，知占候，密謂武成曰：「宮車當晏駕，殿下為天下主。」武成拘之於內以候之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000069",
    "sentence": "又令巫覡卜之，多云不須舉兵，自有大慶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000070",
    "sentence": "武成乃奉詔，令數百騎送濟南於晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000071",
    "sentence": "及孝昭崩，武成卽位，除元海侍中、開府儀同三司、太子詹事。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000072",
    "sentence": "河清二年 ，元海為和士開所譖，被捶馬鞭六十。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000073",
    "sentence": "責云：「爾在鄴城，說我以弟反兄，幾許不義！鄴城兵馬抗幷州，幾許無智！不義無智，若為可使？」出為兗州刺史。",
    "entities": [
      {
        "text": "爾在鄴城",
        "label": "LOC",
        "start": 4,
        "end": 8
      },
      {
        "text": "鄴城兵馬抗幷州",
        "label": "LOC",
        "start": 21,
        "end": 28
      },
      {
        "text": "出為兗州",
        "label": "LOC",
        "start": 45,
        "end": 49
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 49,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000074",
    "sentence": "元海後妻，陸太姬甥也，故尋被追任使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000075",
    "sentence": "武平中，與祖珽共執朝政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000076",
    "sentence": "元海多以太姬密語告珽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000077",
    "sentence": "珽求領軍，元海不可，珽乃以其所告報太姬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000078",
    "sentence": "姬怒，出元海為鄭州刺史。",
    "entities": [
      {
        "text": "出元海為鄭州",
        "label": "LOC",
        "start": 3,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000079",
    "sentence": "鄴城將敗，徵為尚書令。",
    "entities": [
      {
        "text": "鄴城",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000080",
    "sentence": "周 建德七年 ，於鄴城謀逆，伏誅。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 4,
        "end": 6
      },
      {
        "text": "於鄴城",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000081",
    "sentence": "元海好亂樂禍，然詐仁慈，不飲灑啖肉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000082",
    "sentence": "文宣天保末年敬信內法，乃至宗廟不血食，皆元海所謀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000083",
    "sentence": "及為右僕射，又說後主禁屠宰，斷酤酒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000084",
    "sentence": "然本心非靖，故終致覆敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000085",
    "sentence": "思宗弟思好。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000086",
    "sentence": "思好本浩氏子也，思宗養以為弟，遇之甚薄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000087",
    "sentence": "少以騎射事文襄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000088",
    "sentence": "及文宣受命，為左衛大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000089",
    "sentence": "本名思孝， 天保五年 ，討蠕蠕，文宣悅其驍勇，謂曰：「爾擊賊如鶻入鴉群，宜思好事。」故改名焉。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000090",
    "sentence": "累遷尚書令、朔州道行臺、朔州刺史、開府、南安王，甚得邊朔人心。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "朔州",
        "label": "LOC",
        "start": 6,
        "end": 8
      },
      {
        "text": "朔州",
        "label": "LOC",
        "start": 12,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000091",
    "sentence": "後主時，斫骨光弁奉使至州，思好迎之甚謹，光弁倨敖，思好因心銜恨。",
    "entities": [
      {
        "text": "骨光弁奉使至州",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000092",
    "sentence": "武平五年 ，遂舉兵反。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000093",
    "sentence": "與幷州諸貴書曰：「主上少長深宮，未辨人之情偽，昵近兇狡，疏遠忠良。遂使刀鋸刑餘，貴溢軒階，商胡醜類，擅權帷幄，剝削生靈，劫掠朝市。闇於聽受，專行忍害。幽母深宮，無復人子之禮；二弟殘戮，頓絕孔懷之義。仍縱子立奪馬於東門，光弁擎鷹於西市，駮龍得儀同之號，逍遙受郡君之名，犬馬班位，榮冠軒冕。人不堪役，思長亂階。趙郡王叡實曰宗英，社稷惟寄，左丞相斛律明月，世為元輔，威著鄰國，無罪無辜，奄見誅殄。孤旣忝預皇枝，實蒙殊獎，今便擁率義兵，指除君側之害。幸悉此懷，無致疑惑。」行臺郎王行思之辭也。",
    "entities": [
      {
        "text": "與幷州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "逍遙受郡",
        "label": "LOC",
        "start": 125,
        "end": 129
      },
      {
        "text": "趙郡",
        "label": "LOC",
        "start": 153,
        "end": 155
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 168,
        "end": 170
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000094",
    "sentence": "思好至陽曲，自號大丞相，置百官，以行臺左丞王尚之為長史。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000095",
    "sentence": "武衛趙海在晉陽掌兵，時倉卒不暇奏，矯詔發兵拒之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000096",
    "sentence": "軍士皆曰：「南安王來，我輩唯須唱萬歲奉迎耳。」帝聞變，使唐邕、莫多婁敬顯、劉桃枝、中領軍厙狄士文馳之晉陽，帝勒兵續進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000097",
    "sentence": "思好軍敗，與行思投水而死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000098",
    "sentence": "其麾下二千人，桃枝圍之，且殺且招，終不降以至盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000099",
    "sentence": "時帝在道，叱奴世安自晉陽送露布於平都，遇斛斯孝卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000100",
    "sentence": "孝卿誘使食，因馳詣行宮，叫已了。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000101",
    "sentence": "帝大歡，左右呼萬歲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000102",
    "sentence": "良久，世安乃以狀自陳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000103",
    "sentence": "帝曰：「告示何物事，乃得坐食。」於是賞孝卿而免世安罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000104",
    "sentence": "暴思好屍七日，然後屠剝焚之，烹尚之於鄴市，令內參射其妃於宮內，仍火焚殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000105",
    "sentence": "思好反前五旬，有人告其謀反。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000106",
    "sentence": "韓長鸞女適思好子，故奏有人誣告諸貴，事相擾動，不殺無以息後，乃斬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000107",
    "sentence": "思好旣誅，死者弟伏闕下訴求贈兄，長鸞不為通也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000108",
    "sentence": "平秦王",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000109",
    "sentence": "平秦王歸彥，字仁英，神武族弟也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000110",
    "sentence": "父徽，魏末坐事當徙涼州，行至河、渭間，遇賊，以軍功得免流。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 3,
        "end": 4
      },
      {
        "text": "末坐事當徙涼州",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000111",
    "sentence": "因於河州積年。",
    "entities": [
      {
        "text": "因於河州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000112",
    "sentence": "以解胡言，為西域大使，得胡師子來獻，以功得河東守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000113",
    "sentence": "尋遂死焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000114",
    "sentence": "徽於神武舊恩甚篤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000115",
    "sentence": "及神武平京洛，迎徽喪與穆同營葬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000116",
    "sentence": "贈司徒，諡曰文宣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000117",
    "sentence": "初徽嘗過長安市，與婦人王氏私通而生歸彥，至是年已九歲。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000118",
    "sentence": "神武追見之，撫對悲喜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000119",
    "sentence": "稍遷徐州刺史。",
    "entities": [
      {
        "text": "稍遷徐州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000120",
    "sentence": "歸彥少質朴，後更改節，放縱好聲色，朝夕酣歌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000121",
    "sentence": "妻魏上黨王元天穆女也，貌不美而甚驕妒，數忿爭，密啟文宣求離，事寢不報。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000122",
    "sentence": "天保元年，封平秦王。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000123",
    "sentence": "嫡妃康及所生母王氏並為太妃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000124",
    "sentence": "善事二母，以孝聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000125",
    "sentence": "徵為兼侍郎，稍被親寵。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000126",
    "sentence": "以討侯景功，別封長樂郡公，除領軍大將軍。",
    "entities": [
      {
        "text": "別封長樂郡",
        "label": "LOC",
        "start": 6,
        "end": 11
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000127",
    "sentence": "領軍加大，自歸彥始也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000128",
    "sentence": "文宣誅高德正，金寶財貨悉以賜之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000129",
    "sentence": "幹明初，拜司徒，仍總知禁衛。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 1,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000130",
    "sentence": "初濟南自晉陽之鄴，楊愔宣勑，留從駕五千兵於西中，陰備非常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000131",
    "sentence": "至鄴數日，歸彥乃知之，由是陰怨楊、燕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000132",
    "sentence": "楊、燕等欲去二王，問計於歸彥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000133",
    "sentence": "歸彥詐喜，請共元海量之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000134",
    "sentence": "元海亦口許心違，馳告長廣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000135",
    "sentence": "長廣於是誅楊、燕等。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000136",
    "sentence": "孝昭將入雲龍門，都督成休寧列仗拒而不內，歸彥諭之，然後得入，進向柏閤、永巷亦如之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000137",
    "sentence": "孝昭踐祚，以此彌見優重，每入常在平原王段韶上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000138",
    "sentence": "以為司空，兼尚書令。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000139",
    "sentence": "齊制，宮內唯天子紗帽，臣下皆戎帽，特賜歸彥紗帽以寵之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000140",
    "sentence": "孝昭崩，歸彥從晉陽迎武成於鄴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000141",
    "sentence": "及武成卽位，進位太傅，領司徒，常聽將私部曲三人帶刀入仗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000142",
    "sentence": "從武成還都，諸貴戚等競要之，其所往處，一坐盡傾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000143",
    "sentence": "歸彥旣地居將相，志意盈滿，發言陵侮，旁若無人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000144",
    "sentence": "議者以威權震主，必為禍亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000145",
    "sentence": "上亦尋其前翻覆之跡，漸忌之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000146",
    "sentence": "高元海、畢義雲、高乾乾和等咸數言其短。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000147",
    "sentence": "上幸歸彥家，召魏收對御作詔草，欲加右丞相。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000148",
    "sentence": "收謂元海曰：「至尊以右丞相登位，今為歸彥威名太盛，故出之，豈可復加此號。」乃拜太宰、冀州刺史，卽乾和繕寫。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "冀州",
        "label": "LOC",
        "start": 42,
        "end": 44
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 44,
        "end": 46
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000149",
    "sentence": "晝日，仍勑門司不聽輒入內。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000150",
    "sentence": "時歸彥在家縱酒，經宿不知，至明欲參，至門知之，大驚而退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000151",
    "sentence": "及通名謝，勑令早發，別賜錢帛、鼓吹、醫藥，事事周備。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000152",
    "sentence": "又勑武職督將悉送至青陽宮，拜而退，莫敢共語。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000153",
    "sentence": "唯與趙郡王叡久語，時無聞者。",
    "entities": [
      {
        "text": "唯與趙郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000154",
    "sentence": "至州，不自安，謀逆，欲待受調訖，班賜軍士，望車駕如晉陽，乘虛入鄴。",
    "entities": [
      {
        "text": "至州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000155",
    "sentence": "為其郎中令呂思禮所告，詔平原王段韶襲之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000156",
    "sentence": "歸彥舊於南境置私驛，聞軍將逼，報之，便嬰城拒守。",
    "entities": [
      {
        "text": "便嬰城",
        "label": "LOC",
        "start": 18,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000157",
    "sentence": "先是，冀州長史宇文仲鸞、司馬李祖挹、別駕陳季璩、中從事房子弼、長樂郡守尉普興等疑歸彥有異，使連名密啟，歸彥追而獲之，遂收禁仲鸞等五人，仍並不從，皆殺之。",
    "entities": [
