    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000004",
    "sentence": "寬厚有長者風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000005",
    "sentence": "神武起兵於信都，以盛為中軍大都督，封廣平郡公。",
