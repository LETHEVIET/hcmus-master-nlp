  },
  {
    "sentence_id": "HCH_004_014_000012",
    "sentence": "陽州公永樂，神武從祖兄子也。",
    "entities": [
      {
        "text": "陽州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000013",
    "sentence": "太昌初，封陽州縣伯，進爵為公。",
    "entities": [
      {
        "text": "封陽州縣",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000014",
    "sentence": "累遷北豫州刺史。",
    "entities": [
      {
        "text": "累遷北豫州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "刺史",
