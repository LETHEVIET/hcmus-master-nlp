        "start": 5,
        "end": 7
      },
      {
        "text": "在州",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000033",
    "sentence": "襄樂王",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000034",
    "sentence": "襄樂王顯國，神武從祖弟也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000035",
    "sentence": "無才伎，直以宗室謹厚， 天保元年 ，封襄樂王，位右衛將軍。",
