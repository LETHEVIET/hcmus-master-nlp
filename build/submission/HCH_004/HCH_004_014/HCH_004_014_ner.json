        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000015",
    "sentence": "河陰之戰，司徒高昂失利退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000016",
    "sentence": "永樂守河陽南城，昂走趣城，西軍追者將至，永樂不開門，昂遂為西軍所擒。",
    "entities": [
      {
        "text": "永樂守河陽南城",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "昂走趣城",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000017",
    "sentence": "神武大怒，杖之二百。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000018",
    "sentence": "後罷豫州，家產不立。",
    "entities": [
      {
        "text": "後罷豫州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000019",
    "sentence": "神武問其故，對曰：「裴監為長史，辛公正為別駕，受王委寄，斗酒只雞不入。」神武乃以永樂為濟州，仍以監、公正為長史、別駕。",
    "entities": [
      {
        "text": "乃以永樂為濟州",
        "label": "LOC",
        "start": 38,
        "end": 45
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000020",
    "sentence": "謂永樂曰：「爾勿大貪，小小義取莫復畏。」永樂至州，監、公正諫不見聽，以狀啟神武。",
    "entities": [
      {
        "text": "永樂至州",
        "label": "LOC",
        "start": 20,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000021",
    "sentence": "神武封啟以示永樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000022",
    "sentence": "然後知二人清直，並擢用之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000023",
    "sentence": "永樂卒於州。",
    "entities": [
      {
        "text": "永樂卒於州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000024",
    "sentence": "贈太師、太尉、錄尚書事，諡曰武昭。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000025",
    "sentence": "無子，從兄思宗以第二子孝緒為後，襲爵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000026",
    "sentence": "天保初，改封脩城郡王。",
    "entities": [
      {
        "text": "改封脩城郡",
        "label": "LOC",
        "start": 4,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000027",
    "sentence": "永樂弟長弼，小名阿伽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000028",
    "sentence": "性粗武，出入城市，好毆擊行路，時人皆呼為阿伽郎君。",
    "entities": [
      {
        "text": "出入城",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000029",
    "sentence": "以宗室封廣武王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000030",
    "sentence": "時有天恩道人，至兇暴，橫行閭肆，後入長弼黨，專以鬬為事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000031",
    "sentence": "文宣並收掩付獄，天恩黨十餘人皆棄市，長弼鞭一百。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000032",
    "sentence": "尋為南營州刺史，在州無故自驚走，叛亡入突厥，竟不知死所。",
    "entities": [
      {
        "text": "尋為南營州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "刺史",
