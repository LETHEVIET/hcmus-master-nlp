      }
    ]
  },
  {
    "sentence_id": "HCH_004_014_000006",
    "sentence": "歷位司徒、太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_014_000007",
    "sentence": "天平三年 ，薨於位。",
    "entities": [
