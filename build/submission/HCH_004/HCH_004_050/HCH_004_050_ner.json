      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000128",
    "sentence": "韓鳳",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000129",
    "sentence": "韓鳳，字長鸞，昌黎人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000130",
    "sentence": "父永興，青州刺史。",
    "entities": [
