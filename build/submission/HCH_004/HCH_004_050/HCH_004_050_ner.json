[
  {
    "sentence_id": "HCH_004_050_000001",
    "sentence": "甚哉齊末之嬖幸也，蓋書契以降未之有焉。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 2,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000002",
    "sentence": "心利錐刀，居台鼎之任；智昏菽麥，當機衡之重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000003",
    "sentence": "刑殘閹宦、蒼頭盧兒，西域醜胡、龜茲雜伎，封王者接武，開府者比肩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000004",
    "sentence": "非直獨守弄臣，且復多干朝政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000005",
    "sentence": "賜予之費，帑藏以虛；杼軸之資，剝掠將盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000006",
    "sentence": "縱龜鼎之祚，卜世靈長，屬此淫昏，無不亡之理，齊運短促，固其宜哉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000007",
    "sentence": "高祖、世宗，情存庶政，文武任寄，多貞幹之臣，唯郭秀小人，有累明德。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000008",
    "sentence": "天保五年 之後，雖罔念作狂，所幸之徒，唯左右驅馳，內外褻狎，其朝廷之事一不與聞。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000009",
    "sentence": "大寧之後，姦佞浸繁，盛業鴻基，以之顛覆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000010",
    "sentence": "生民免夫被發左袵，非不幸也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000011",
    "sentence": "今緝諸凶族為《佞幸傳》云。",
    "entities": [
      {
        "text": "《佞幸傳》",
        "label": "TITLE",
        "start": 6,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000012",
    "sentence": "其宦者之徒，尤是亡齊之一物。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 9,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000013",
    "sentence": "醜聲穢跡，千端萬緒，其事闕而不書，仍略存姓名，附之此《傳》之末。",
    "entities": [
      {
        "text": "《傳》",
        "label": "TITLE",
        "start": 26,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000014",
    "sentence": "其帝家諸奴及胡人樂工，叨竊貴辛，今亦出焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000015",
    "sentence": "郭秀",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000016",
    "sentence": "郭秀，范陽涿人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000017",
    "sentence": "事高祖為行臺右丞，親寵日隆，多受賂遺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000018",
    "sentence": "秀遇疾，高祖親臨視之，問所欲官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000019",
    "sentence": "乃啟為七兵尚書，除書未至而卒。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000020",
    "sentence": "家無成人子弟，高祖自至其宅，親使錄知其家資粟帛多少，然後去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000021",
    "sentence": "命其子孝義與太原公已下同學讀書。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000022",
    "sentence": "初，秀忌楊愔，誑脅令其逃亡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000023",
    "sentence": "秀死後，愔還，高祖追忿秀，卽日斥孝義，終身不齒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000024",
    "sentence": "和士開",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000025",
    "sentence": "和士開，字彥通，清都臨漳人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000026",
    "sentence": "其先西域商胡，本姓素和氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000027",
    "sentence": "父安，恭敏善事人，稍遷中書舍人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000028",
    "sentence": "魏孝靜嘗夜中與朝賢講集，命安看斗柄所指，安答曰：「臣不識北斗。」高祖聞之，以為淳直。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000029",
    "sentence": "後為儀州刺史。",
    "entities": [
      {
        "text": "後為儀州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000030",
    "sentence": "士開幼而聰慧，選為國子學生，解悟捷疾，為同業所尚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000031",
    "sentence": "天保初，世祖封長廣王，辟士開府行參軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000032",
    "sentence": "世祖性好握槊，士開善於此戲，由是遂有斯舉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000033",
    "sentence": "加以傾巧便僻，又能彈胡琵琶，因此親狎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000034",
    "sentence": "嘗謂王曰：「殿下非天人也，是天帝也。」王曰：「卿非世人也，是世神也。」其深相愛如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000035",
    "sentence": "顯祖知其輕薄，不令王與小人相親善，責其戲狎過度，徙長城。",
    "entities": [
      {
        "text": "徙長城",
        "label": "LOC",
        "start": 24,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000036",
    "sentence": "後除京畿士曹參軍，長廣王請之也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000037",
    "sentence": "世祖踐祚，累除侍中，加開府。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000038",
    "sentence": "遭母劉氏憂，帝聞而悲惋，遣武衛將軍呂芬詣宅，晝夜扶侍，成服後方還。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000039",
    "sentence": "其日，帝又遣以犢車迎士開入內，帝見，親自握手，愴惻下泣，曉喻良久，然後遣還，幷諸弟四人並起復本官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000040",
    "sentence": "其見親重如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000041",
    "sentence": "除右僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000042",
    "sentence": "帝先患氣疾，因飲酒輒大發動，士開每諫不從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000043",
    "sentence": "屬帝氣疾發，又欲飲，士開淚下歔欷不能言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000044",
    "sentence": "帝曰：「卿此是不言之諫。」因不復飲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000045",
    "sentence": "言辭容止，極諸鄙褻，以夜繼晝，無復君臣之禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000046",
    "sentence": "至說世祖云：「自古帝王，盡為灰燼，堯、舜、桀、紂，竟復何異？陛下宜及少壯，恣意作樂，縱橫行之，卽是一日快活敵千年。國事分付大臣，何慮不辦，無為自勤苦也。」世祖大悅。",
    "entities": [
      {
        "text": "千年",
        "label": "TME",
        "start": 54,
        "end": 56
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000047",
    "sentence": "其年十二月，世祖寢疾於乾壽殿，士開入侍醫藥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000048",
    "sentence": "世祖謂士開有伊、霍之才，殷勤屬以後事，臨崩，握士開之手曰：「勿負我也。」仍絕於士開之手。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000049",
    "sentence": "後主以世祖顧托，深委仗之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000050",
    "sentence": "又先得幸於胡太后，是以彌見親密。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000051",
    "sentence": "趙郡王叡與婁定遠等謀出士開，引諸貴人共為計策。",
    "entities": [
      {
        "text": "趙郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000052",
    "sentence": "屬太后觴朝貴於前殿，叡面陳士開罪失，云：「士開先帝弄臣，城狐社鼠，受納貨賄，穢亂宮掖，臣等義無杜口，冒死以陳。」太后曰：「先帝在時，王等何不道？今日欲欺孤寡耶！但飲酒，勿多言。」叡詞色愈厲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000053",
    "sentence": "或曰：「不出士開，朝野不定。」叡等或投冠於地，或拂衣而起，言詞咆勃，無所不至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000054",
    "sentence": "明日，叡等共詣雲龍門，令文遙入奏之，太后不聽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000055",
    "sentence": "段韶呼胡長粲傳言，太后曰：「梓宮在殯，事大拚速，欲王等更思量。」趙郡王等遂並拜謝，更無餘言。",
    "entities": [
      {
        "text": "趙郡",
        "label": "LOC",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000056",
    "sentence": "太后及後主召見問士開，士開曰：「先帝群官之中，待臣最重，陛下諒暗始爾，大臣皆有覬覦心，若出臣，正是剪陛下羽翼。宜謂叡等云：『令士開為州，待過山陵，然後發遣。』叡等謂臣真出，必心喜之。」後主及太后然之，告叡等如士開旨，以士開為兗州刺史。",
    "entities": [
      {
        "text": "令士開為州",
        "label": "LOC",
        "start": 62,
        "end": 67
      },
      {
        "text": "以士開為兗州",
        "label": "LOC",
        "start": 108,
        "end": 114
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 114,
        "end": 116
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000057",
    "sentence": "山陵畢，叡等促士開就路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000058",
    "sentence": "士開載美女珠簾及條諸寶玩以詣定遠，謝曰：「諸貴欲殺士開，蒙王特賜性命，用作方伯。今欲奉別，謹具上二女子、一珠簾。」定遠喜，謂士開曰：「欲得還入不？」士開曰：「在內久，常不自安，令得出，實稱本意，不願更入，但乞王保護，長作大州刺史。今日遠出，願得一辭觀二宮。」定遠許之。",
    "entities": [
      {
        "text": "長作大州",
        "label": "LOC",
        "start": 108,
        "end": 112
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 112,
        "end": 114
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000059",
    "sentence": "士開由是得見太后及後主，進說曰：「先帝一旦登遐，臣愧不能自死。觀朝貴勢欲陛下為幹明。臣出之後，必有大變，復何面見先帝於地下。」因慟哭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000060",
    "sentence": "帝及太后皆泣，問計將安出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000061",
    "sentence": "士開曰：「臣已得入，復何所慮，正須數行詔書耳。」於是詔出定遠青州刺史，責趙郡王叡以不臣之罪，召入而殺之。",
    "entities": [
      {
        "text": "是詔出定遠青州",
        "label": "LOC",
        "start": 25,
        "end": 32
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 32,
        "end": 34
      },
      {
        "text": "責趙郡",
        "label": "LOC",
        "start": 35,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000062",
    "sentence": "復除士開侍中、右僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000063",
    "sentence": "定遠歸士開所遺，加以餘珍賂之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000064",
    "sentence": "武平元年 ，封淮陽王，除尚書令、錄尚書事，復本官悉得如故。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000065",
    "sentence": "世祖時，恒令士開與太后握槊，又出入臥內無復期限，遂與太后為亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000066",
    "sentence": "及世祖崩後，彌自放恣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000067",
    "sentence": "瑯邪王儼惡之，與領軍庫狄伏連、侍中馮子琮、禦史王子宜、武衛高舍洛等謀誅之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000068",
    "sentence": "伏連發京畿軍士，帖神武、千秋門外，並私約束，不聽士開入殿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000069",
    "sentence": "其年七月二十五日旦，士開依式早參，伏連前把士開手曰：「今有一大好事。」王子宜便授一函，云：「有勑令王向臺。」遣兵士防送，禁於治書侍御廳事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000070",
    "sentence": "儼遣都督馮永洛就臺斬之，時年四十八，簿錄其家口。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000071",
    "sentence": "後誅儼等。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000072",
    "sentence": "上哀悼，不視事數日，追憶不已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000073",
    "sentence": "詔起復其子道盛為常侍，又勑其弟士休入內省參典機密，詔贈士開假黃鉞、十州諸軍事、左丞相、太宰如故。",
    "entities": [
      {
        "text": "十州",
        "label": "LOC",
        "start": 33,
        "end": 35
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 40,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000074",
    "sentence": "士開稟性庸鄙，不闚書傳，發言吐論，惟以諂媚自資。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000075",
    "sentence": "河清、天統以後，威權轉盛，富商大賈朝夕填門，朝土不知廉恥者多相附會，甚者為其假子，與市道小人同在昆季行列。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000076",
    "sentence": "又有一人士，曾參士開，值疾，醫人云：「王傷寒極重，進藥無效，應服黃龍湯。」士開有難色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000077",
    "sentence": "是人云：「此物甚易與，王不須疑惑，請為王行先嘗之。」一舉便盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000078",
    "sentence": "士開深感此心，為之強服，遂得汗病愈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000079",
    "sentence": "其勢傾朝廷也如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000080",
    "sentence": "雖以左道事之者，不問賢愚，無不進擢；而以正理干忤者，亦頗能捨之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000081",
    "sentence": "士開見人將加刑戮，多所營救，旣得免罪，卽命諷喻，責其珍寶，謂之贖命物。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000082",
    "sentence": "雖有全濟，皆非直道云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000083",
    "sentence": "穆提婆",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000084",
    "sentence": "穆提婆，本姓駱，漢陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000085",
    "sentence": "父超，以謀叛伏誅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000086",
    "sentence": "提婆母陸令萱賞配入掖庭，後主繈褓之中，令其鞠養，謂之乾阿妳，遂大為胡后所昵愛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000087",
    "sentence": "令萱姦巧多機辯，取媚百端，宮掖之中，獨擅威福。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000088",
    "sentence": "天統初，奏引提婆入侍後主，朝夕左右，大被親狎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000089",
    "sentence": "嬉戲醜褻，無所不為。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000090",
    "sentence": "寵遇彌隆，官爵不知紀極，遂至錄尚書事，封城陽王。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "封城",
        "label": "LOC",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000091",
    "sentence": "令萱又佞媚，穆昭儀養之為母，是以提婆改姓穆氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000092",
    "sentence": "及穆后立，令萱號曰太姬，此卽齊朝皇后母氏之位號也，視第一品，班在長公主之上。",
    "entities": [
      {
        "text": "齊朝",
        "label": "ORG",
        "start": 14,
        "end": 16
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000093",
    "sentence": "自武平之後，令萱母子勢傾內外矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000094",
    "sentence": "庸劣之徒皆重跡屏氣焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000095",
    "sentence": "自外殺生予奪不可盡言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000096",
    "sentence": "晉州軍敗，後主還鄴，提婆奔周軍。",
    "entities": [
      {
        "text": "晉州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000097",
    "sentence": "令萱自殺，子孫大小皆棄市，籍沒其家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000098",
    "sentence": "高阿那肱",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000099",
    "sentence": "高阿那肱，善無人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000100",
    "sentence": "其父市貴，從高祖起義。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000101",
    "sentence": "那肱為庫典，從征討，以功勤擢為武衛將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000102",
    "sentence": "肱妙於騎射，便僻善事人，每宴射之次，大為世祖所愛重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000103",
    "sentence": "又諂悅和士開，尤相褻狎，士開每為之言，彌見親待。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000104",
    "sentence": "後主卽位，累遷幷省尚書左僕射，封淮陰王，又除幷省尚書令。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000105",
    "sentence": "肱才伎庸劣，不涉文史，識用尤在士開之下，而姦巧計數亦不逮士開。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000106",
    "sentence": "旣為世祖所幸，多令在東宮侍後主，所以大被寵遇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000107",
    "sentence": "士開死後，後主謂其識度足繼士開，遂致位宰輔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000108",
    "sentence": "武平四年 ，令其錄尚書事，又總知外兵及內省機密。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
