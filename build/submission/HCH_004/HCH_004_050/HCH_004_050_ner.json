      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000131",
    "sentence": "鳳少而聰察，有膂力，善騎射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000132",
    "sentence": "稍遷都督。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000133",
    "sentence": "後主居東宮，年幼稚，世祖簡都督二十人送令侍衛，鳳在其數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000134",
    "sentence": "後主親就衆中牽鳳手曰：「都督看兒來。」因此被識，數喚共戲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000135",
    "sentence": "後主卽位，累遷侍中、領軍，總知內省機密。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000136",
    "sentence": "祖珽曾與鳳於後主前論事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000137",
    "sentence": "語鳳云：「強弓長槊，無容相謝，軍國謀算，何由得爭。」鳳答曰：「各出意見，豈在文武優劣？」封昌黎郡王。",
    "entities": [
      {
        "text": "封昌黎郡",
        "label": "LOC",
        "start": 44,
        "end": 48
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000138",
    "sentence": "男寶仁尚公主，在晉陽賜第一區。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000139",
    "sentence": "其公主生男滿月，駕幸鳳宅，宴會盡日。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000140",
    "sentence": "軍國要密，無不經手，與高阿那肱、穆提婆共處衡軸，號曰三貴，損國害政，日月滋甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000141",
    "sentence": "壽陽陷沒，鳳與穆提婆聞告敗，握槊不輟，曰：「他家物，從他去。」後帝使於黎陽臨河築城戍，曰：「急時且守此作龜茲國子，更可憐人生如寄，唯當行樂，何因愁為？」君臣應和若此。",
    "entities": [
      {
        "text": "於黎陽臨河築城",
        "label": "LOC",
        "start": 34,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000142",
    "sentence": "其弟萬歲，及二子寶行、寶信並開府儀同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000143",
    "sentence": "寶信尚公主，駕復幸其宅，親戚咸蒙官賞。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000144",
    "sentence": "鳳母鮮于，段孝言之從母子姊也，為此偏相參附，奏遣監造晉陽宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000145",
    "sentence": "陳德信馳驛檢行，見孝言役官夫匠自營宅，卽語云：「僕射為至尊起臺殿未訖，何容先自營造？」鳳及穆提婆亦遣孝言分工匠為己造宅，德信還具奏聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000146",
    "sentence": "及幸晉陽，又以官馬與他人乘騎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000147",
    "sentence": "上因此發忿，與提婆並除名，亦不露其罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000148",
    "sentence": "仍毀其宅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000149",
    "sentence": "公主離婚。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000150",
    "sentence": "復被遣向鄴吏部門參。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000151",
    "sentence": "及後主晉陽走還，被勑入內，尋詔復爵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000152",
    "sentence": "從後主走度河，到青州，並為周軍所獲。",
    "entities": [
      {
        "text": "到青州",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000153",
    "sentence": "鳳於權要之中，尤嫉人士，崔季舒等冤酷，皆鳳所為。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000154",
    "sentence": "每朝士諮事，莫敢仰視，動致呵叱，輒詈云：「狗漢大不可耐，唯須殺却。」若見武職，雖廝養末品亦容下之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000155",
    "sentence": "仕隋，位終於隴州刺史。",
    "entities": [
      {
        "text": "位終於隴州",
        "label": "LOC",
        "start": 3,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000156",
    "sentence": "韓寶業等",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000157",
    "sentence": "韓寶業、盧勒叉、齊紹，並高祖舊左右，唯門閹驅使，不被恩遇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000158",
    "sentence": "歷天保、皇建之朝，亦不至寵幸，但漸有職任。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000159",
    "sentence": "寶業至長秋卿，勒叉等或為中常侍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000160",
    "sentence": "世祖時有曹文摽、鄧長顒輩，亦有至儀同食幹者，唯長顒武平中任參宰相，干預朝權。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000161",
    "sentence": "後寶業、勒叉、齊紹、子徵並封王，不過侵暴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000162",
    "sentence": "於後主之朝，有陳德信等數十人，並肆其姦佞，敗政虐人，古今未有。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000163",
    "sentence": "多授開府，罕止儀同，亦有加光祿大夫，金章紫綬者。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000164",
    "sentence": "多帶侍中、中常侍，此二職乃數十人，又皆封王、開府。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000165",
    "sentence": "恒出入門禁，往來園苑，趨侍左右，通宵累日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000166",
    "sentence": "承候顏色，競進諂諛，莫不發言動意，多會深旨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000167",
    "sentence": "一戲之賞，動逾巨萬，丘山之積，貪吝無厭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000168",
    "sentence": "猶以波斯狗為儀同、郡君，分其幹祿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000169",
    "sentence": "神獸門外有朝貴憩息之所，時人號為解卸廳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000170",
    "sentence": "諸閹或在內多日，暫放歸休，所乘之馬牽至神獸門階，然後升騎，飛鞭競走，數十為羣，馬塵必坌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000171",
    "sentence": "諸朝貴爰至唐、趙、韓、駱皆隱聽趨避，不敢為言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000172",
    "sentence": "高祖時有蒼頭陳山提、蓋豐樂、劉桃枝等數十人，俱驅馳便僻，頗蒙恩遇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000173",
    "sentence": "天保、大寧之朝，漸以貴盛，至武平時皆以開府、封王，其不及武平者則追贈王爵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000174",
    "sentence": "又有何海及子洪珍皆為王，尤為親要。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000175",
    "sentence": "洪珍侮弄權勢，鬻獄賣官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000176",
    "sentence": "又有史醜多之徒胡小兒等數十，咸能舞工歌，亦至儀同、開府封王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000177",
    "sentence": "諸宦者猶以宮掖驅馳，便煩左右，漸因昵狎，以至大官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000178",
    "sentence": "蒼頭始自家人，情寄深密，及於後主，則是先朝舊人，以勤舊之勞，致此叨竊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000179",
    "sentence": "至於胡小兒等眼鼻深險，一無可用，非理愛好，排突朝貴，尤為人士之所疾惡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000180",
    "sentence": "其以音樂至大官者：沈過兒官至開府儀同，王長通年十四五，便假節通州刺史。",
    "entities": [
      {
        "text": "便假節通州",
        "label": "LOC",
        "start": 27,
        "end": 32
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_004_050_000181",
    "sentence": "時又有開府薛榮宗，常自云能使鬼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000182",
    "sentence": "及周兵之逼，言於後主曰：「臣已發遣斛律明月將大兵在前去。」帝信之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000183",
    "sentence": "經古冢，榮宗謂舍人元行恭是誰冢，行恭戲之曰：「林宗冢。」復問林宗是誰，行恭曰：「郭元貞父。」榮宗前奏曰：「臣向見郭林宗從冢出，著大帽，吉莫靴，插馬鞭，問臣『我阿貞來不』。」是時羣妄多皆類此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000184",
    "sentence": "【贊】",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000185",
    "sentence": "贊曰：危亡之祚，昏亂之朝，小人道長，君子道消。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_050_000186",
    "sentence": "校",
    "entities": []
  },
