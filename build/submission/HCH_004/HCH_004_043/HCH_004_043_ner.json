      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000035",
    "sentence": "徵拜太府少卿，尋轉廷尉少卿，遷太尉長史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000036",
    "sentence": "肅宗卽位，兼散騎常侍、省方大使。",
    "entities": []
  },
