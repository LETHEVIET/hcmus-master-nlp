      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000086",
    "sentence": "遷大司農。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000087",
    "sentence": "會侯景背叛，王思政入據潁城，王師出討，惇常督漕，軍無乏絕。",
    "entities": [
      {
        "text": "王思政入據潁城",
        "label": "LOC",
        "start": 6,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000088",
    "sentence": "引洧水灌城，惇之策也。",
    "entities": [
      {
        "text": "引洧水灌城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000089",
    "sentence": "遷殿中尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000090",
    "sentence": "惇美鬚髯，下垂至帶，省中號為長鬛公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000091",
    "sentence": "顯祖嘗因酒酣，握惇鬚髯稱美，遂以刀截之，唯留一握。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000092",
    "sentence": "惇懼，因不復敢長，時人又號為齊鬚公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000093",
    "sentence": "世祖踐祚，領御史中丞，為膠州刺史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "為膠州",
        "label": "LOC",
        "start": 11,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000094",
    "sentence": "尋追為司農卿，又遷大理卿，再為度支尚書，歷太子少保、少師、光祿大夫、開府儀同三司、尚書右僕射、特進，賜爵萬年縣子，食下邳郡幹。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 17,
        "end": 19
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 21,
        "end": 23
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 31,
        "end": 33
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 41,
        "end": 43
      },
      {
        "text": "賜爵萬年縣",
        "label": "LOC",
        "start": 50,
        "end": 55
      },
      {
        "text": "食下邳郡",
        "label": "LOC",
        "start": 57,
        "end": 61
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000095",
    "sentence": "以年老致仕於家，三年卒。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000096",
    "sentence": "惇少純直，晚更浮動。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000097",
    "sentence": "齊朝體式，本州大中正以京官為之。",
    "entities": [
      {
        "text": "齊朝",
        "label": "ORG",
        "start": 0,
        "end": 2
      },
      {
        "text": "本州",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000098",
    "sentence": "同郡邢卲為中書監，德望甚高，惇與卲競中正，遂馮附宋欽道，出卲為刺史，朝議甚鄙薄之。",
    "entities": [
      {
        "text": "同郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "宋欽道",
        "label": "PER",
        "start": 24,
        "end": 27
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000099",
    "sentence": "雖久處朝行，歷官清顯，與邢卲、魏收、陽休之、崔劼、徐之才之徒比肩同列，諸人或談說經史，或吟詠詩賦，更相嘲戲，欣笑滿堂，惇不解劇談，又無學術，或竟坐杜口，或隱几而睡，深為勝流所輕。",
    "entities": [
      {
        "text": "徐之才",
        "label": "PER",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000100",
    "sentence": "子文紀，武平末度支郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000101",
    "sentence": "文紀弟文經，勤學方雅，身無擇行，口無戲言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000102",
    "sentence": "武平末，殿中侍御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000103",
    "sentence": "隋開皇初，侍御史，兼通直散騎常侍，聘陳使副，主爵侍郎。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000104",
    "sentence": "卒於相州長史。",
    "entities": [
      {
        "text": "卒於相州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000105",
    "sentence": "惇兄遜，字仲讓，有幹局，乾明中平原太守，卒贈信州刺史。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 13,
        "end": 14
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 17,
        "end": 19
      },
      {
        "text": "卒贈信州",
        "label": "LOC",
        "start": 20,
        "end": 24
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000106",
    "sentence": "遜子文高，司徒掾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000107",
    "sentence": "羊烈",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000108",
    "sentence": "羊烈，字信卿，太山鉅平人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000109",
    "sentence": "晉太仆卿琇之八世孫，魏梁州刺史祉之弟子。",
    "entities": [
      {
        "text": "魏梁州",
        "label": "LOC",
        "start": 10,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000110",
    "sentence": "父靈珍，魏兗州別駕。",
    "entities": [
      {
        "text": "魏兗州",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000111",
    "sentence": "烈少通敏，自修立，有成人之風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000112",
    "sentence": "好讀書，能言名理，以玄學知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000113",
    "sentence": "魏孝昌中，烈從兄侃為太守，據郡起兵外叛。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "據郡",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000114",
    "sentence": "烈潛知其謀，深懼家禍，與從兄廣平太守惇馳赴洛陽告難。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000115",
    "sentence": "朝廷將加厚賞，烈告人云：「譬如斬手全軀，所存者大爾，豈有幸從兄之敗以為己利乎？」卒無所受。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000116",
    "sentence": "弱冠，州辟主簿，又兼治中從事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000117",
    "sentence": "刺史方以吏事為意，以幹濟見知。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000118",
    "sentence": "釋巾太師咸陽王行參軍，遷秘書郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000119",
    "sentence": "顯祖初，為儀同三司開府倉曹參軍事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000120",
    "sentence": "天保初，授太子步兵校尉、輕車將軍，尋遷幷省比部郎中，除司徒屬，頻歷尚書祠部、左右民郎中，所在咸為稱職。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000121",
    "sentence": "九年，除陽平太守，治有能名。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000122",
    "sentence": "是時，頻有災蝗，犬牙不入陽平境，勑書褒美焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000123",
    "sentence": "皇建二年 ，遷光祿少卿，加龍驤將軍、兗州大中正，又進號平南將軍。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "兗州",
        "label": "LOC",
        "start": 18,
        "end": 20
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000124",
    "sentence": "天統中，除太中大夫，兼光祿少卿。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000125",
    "sentence": "武平初，除驃騎將軍、義州刺史，尋以老疾還鄉。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
