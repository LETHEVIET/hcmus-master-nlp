        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000003",
    "sentence": "李稚廉，趙郡高邑人也。",
    "entities": [
      {
        "text": "李稚廉",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "趙郡高邑",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000004",
    "sentence": "齊州刺史義深之弟。",
    "entities": [
      {
        "text": "齊州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000005",
    "sentence": "稚廉少而寡欲，為兒童時，初不從家人有所求請。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000006",
    "sentence": "家人嘗故以金寶授之，終不取，強付，輒擲之於地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000007",
    "sentence": "州牧以其蒙稚而廉，故名曰稚廉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000008",
    "sentence": "聰敏好學，年十五，頗尋覽五經章句。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000009",
    "sentence": "屬葛榮作亂，本郡紛擾，違難赴京。",
    "entities": [
      {
        "text": "本郡",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000010",
    "sentence": "永安中，釋褐奉朝請。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000011",
    "sentence": "普泰初，開府記室、龍驤將軍、廣州征南府錄事參軍，不行。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "廣州",
        "label": "LOC",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000012",
    "sentence": "尋轉開府諮議參軍事、前將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000013",
    "sentence": "天平中，高祖擢為泰州開府長史、平北將軍。",
    "entities": [
      {
        "text": "高祖擢為泰州",
        "label": "LOC",
        "start": 4,
        "end": 10
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000014",
    "sentence": "稚廉緝諧將士，軍民樂悅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000015",
    "sentence": "高祖頻幸河東，大相嗟賞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000016",
    "sentence": "轉為世宗驃騎府長史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000017",
    "sentence": "詔以濟州控帶川陸，接對梁使，尤須得人，世宗薦之，除濟州儀同長史。",
    "entities": [
      {
        "text": "詔以濟州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "除濟州",
        "label": "LOC",
        "start": 24,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000018",
    "sentence": "又遷瀛州長史。",
    "entities": [
      {
        "text": "又遷瀛州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000019",
    "sentence": "高祖行經冀州，總合河北六州文籍，商校戶口增損。",
    "entities": [
      {
        "text": "高祖行經冀州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "總合河北六州",
        "label": "LOC",
        "start": 7,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000020",
    "sentence": "高祖親自部分，多在馬上，徵責文簿，指景取備，事緒非一。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000021",
    "sentence": "稚廉每應機立成，恒先期會，莫不雅合深旨，為諸州準的。",
    "entities": [
      {
        "text": "為諸州",
        "label": "LOC",
        "start": 20,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000022",
    "sentence": "高祖顧謂司馬子如曰：「觀稚廉處分，快人意也。」因集文武數萬人，令郎中杜弼宣旨慰勞，仍詰諸州長史、守令等，諸人並謝罪，稚廉獨前拜恩，觀者咸歎美之。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "仍詰諸州",
        "label": "LOC",
        "start": 41,
        "end": 45
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000023",
    "sentence": "其日，賜以牛酒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000024",
    "sentence": "高祖還幷，以其事告世宗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000025",
    "sentence": "世宗喜而語人曰：「吾足知人矣。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000026",
    "sentence": "世宗嗣事，召詣晉陽，除霸府掾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000027",
    "sentence": "謂杜弼曰：「幷州王者之基，須好長史，各舉所知。」時互有所稱，皆不允。",
    "entities": [
      {
        "text": "幷州",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000028",
    "sentence": "衆人未答。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000029",
    "sentence": "世宗乃謂陳元康曰：「我教君好長史處，李稚廉卽其人也。」遂命為幷州長史。",
    "entities": [
      {
        "text": "李稚廉",
        "label": "PER",
        "start": 18,
        "end": 21
      },
      {
        "text": "遂命為幷州",
        "label": "LOC",
        "start": 27,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000030",
    "sentence": "常在世宗第內，與隴西辛術等六人號為館客，待以上賓之禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000031",
    "sentence": "天保初，除安南將軍、太原郡守。",
    "entities": [
