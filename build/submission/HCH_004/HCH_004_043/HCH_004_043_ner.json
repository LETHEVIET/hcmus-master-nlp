        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000065",
    "sentence": "更滿還朝，除左光祿大夫，又除殿中尚書。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000066",
    "sentence": "述久為法官，明解律令，議斷平允，深為時人所稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000067",
    "sentence": "而厚積財產，一無饋遺，雖至親密友貧病困篤，亦絕於拯濟，朝野物論甚鄙之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000068",
    "sentence": "外貌方整而不免請謁，迴避進趨，頗致嗤駭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000069",
    "sentence": "前妻河內司馬氏，一息，為娶隴西李士元女，大輸財娉。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000070",
    "sentence": "及將成禮，猶競懸違。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000071",
    "sentence": "述忽取供養像對士元打像作誓，士元笑曰：「封公何處常得應急像，須誓便用。」一息娶范陽盧莊之女。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000072",
    "sentence": "述又逕府訴云：「送驘乃嫌腳跛，評田則云鹹薄，銅器又嫌古廢。」皆為吝嗇所及，每致紛紜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000073",
    "sentence": "子元，武平末太子舍人。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000074",
    "sentence": "述弟詢，字景文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000075",
    "sentence": "魏員外郎，武定中永安公開府法曹，稍遷尚書起部郎中，轉三公郎，出為東平原郡太守，遷定州長史，又除河間郡守，入為尚書左丞，又為濟南太守。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "出為東平原郡",
        "label": "LOC",
        "start": 30,
        "end": 36
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 36,
        "end": 38
      },
      {
        "text": "遷定州",
        "label": "LOC",
        "start": 39,
        "end": 42
      },
      {
        "text": "又除河間郡",
        "label": "LOC",
        "start": 45,
        "end": 50
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 54,
        "end": 56
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 63,
        "end": 65
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000076",
    "sentence": "隋開皇中卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000077",
    "sentence": "詢闚涉經史，清素自持，歷官皆有幹局才具，治郡甚著聲績，民吏敬而愛之。",
    "entities": [
      {
        "text": "治郡",
        "label": "LOC",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000078",
    "sentence": "許惇",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000079",
    "sentence": "許惇，字季良，高陽新城人也。",
    "entities": [
      {
        "text": "高陽新城",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000080",
    "sentence": "父護，魏高陽、章武二郡太守。",
    "entities": [
      {
        "text": "章武二郡",
        "label": "LOC",
        "start": 7,
        "end": 11
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000081",
    "sentence": "惇清識敏速，達於從政，任司徒主簿，以能判斷見知，時人號為入鐵主簿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000082",
    "sentence": "稍遷陽平太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000083",
    "sentence": "當時遷都鄴，陽平卽是畿郡，軍國責辦，賦斂無準，又勳貴屬請，朝夕徵求，惇並御之以道，上下無怨，治為下天第一。",
    "entities": [
      {
        "text": "陽平卽是畿郡",
        "label": "LOC",
        "start": 6,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_043_000084",
    "sentence": "特加賞異，圖形於闕，詔頒天下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_043_000085",
    "sentence": "遷魏尹，出拜齊州刺史，轉梁州刺史，治並有聲。",
    "entities": [
      {
        "text": "出拜齊州",
        "label": "LOC",
        "start": 4,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
