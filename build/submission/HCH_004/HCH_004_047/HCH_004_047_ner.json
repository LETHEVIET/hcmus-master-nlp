    "entities": []
  },
  {
    "sentence_id": "HCH_004_047_000009",
    "sentence": "從高祖起義，拜為長史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_047_000010",
    "sentence": "性嚴暴，求取無厭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_047_000011",
    "sentence": "後兼尚書右僕射、大行臺，節度諸軍事。",
