[
  {
    "sentence_id": "HCH_004_048_000001",
    "sentence": "外戚",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000002",
    "sentence": "仁自兩漢以來，外戚之家罕有全者，其傾覆之跡，逆亂之機，皆詳諸前史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000003",
    "sentence": "齊氏后妃之族，多自保全，唯胡長仁以譖訴貽禍，斛律光以地勢被戮，俱非女謁盛衰之所致也。",
    "entities": [
      {
        "text": "齊氏",
        "label": "ORG",
        "start": 0,
        "end": 2
      },
      {
        "text": "斛律光",
        "label": "PER",
        "start": 22,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000004",
    "sentence": "今依前代史官，述《外戚》云爾。",
    "entities": [
      {
        "text": "《外戚》",
        "label": "TITLE",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000005",
    "sentence": "趙猛",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000006",
    "sentence": "趙猛，太安狄那人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000007",
    "sentence": "姊為文穆皇帝繼室，生趙郡王琛。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "生趙郡",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000008",
    "sentence": "猛性方直，頗有器幹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000009",
    "sentence": "高祖舉義，遷南營州刺史，卒。",
    "entities": [
      {
        "text": "遷南營州",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000010",
    "sentence": "婁叡",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000011",
    "sentence": "婁叡，字佛仁，武明皇後兄子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000012",
    "sentence": "父壯，魏南部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000013",
    "sentence": "叡少好弓馬，有武幹，為高祖帳內都督。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000014",
    "sentence": "從破尒朱於韓陵，累遷開府儀同、驃騎大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 17,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000015",
    "sentence": "叡無器幹，唯以外戚貴幸，而縱情財色，為時論所鄙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000016",
    "sentence": "皇建初，封東安王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000017",
    "sentence": "高歸彥反於冀州，詔叡往平之。",
    "entities": [
      {
        "text": "高歸彥反於冀州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000018",
    "sentence": "還，拜司徒公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000019",
    "sentence": "周兵寇東關，叡率軍赴援，頻戰有功，擒周將楊檦等。",
    "entities": [
      {
        "text": "周兵寇東關",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000020",
    "sentence": "進大司馬，出總偏師，赴懸瓠。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000021",
    "sentence": "叡在豫境，留停百餘日，侵削官私，專行非法，坐免官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000022",
    "sentence": "尋授太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000023",
    "sentence": "薨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000024",
    "sentence": "尒朱文暢",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000025",
    "sentence": "尒朱文暢，榮第四子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000026",
    "sentence": "初封昌樂王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000027",
    "sentence": "其姊魏孝莊皇後，及四胡敗滅，高祖納之，待其家甚厚，文暢由是拜肆州刺史。",
    "entities": [
      {
        "text": "文暢由是拜肆州",
        "label": "LOC",
        "start": 25,
        "end": 32
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000028",
    "sentence": "家富於財，招致賓客，既籍門地，窮極豪侈，與丞相司馬任胄、主簿李世林、都督鄭仲禮、房子遠等深相愛狎，外示杯酒之交，而潛謀逆亂。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 21,
        "end": 23
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000029",
    "sentence": "自魏氏舊俗，以正月十五日夜為打竹簇之戲，有能中者，即時賞帛。",
    "entities": [
      {
        "text": "魏氏",
        "label": "ORG",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000030",
    "sentence": "任胄令仲禮藏刀於袴中，因高祖臨觀，謀為竊發，事捷之後，共奉文暢為主。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000031",
    "sentence": "為任氏家客薛季孝告高祖，問皆具伏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000032",
    "sentence": "以其姊寵故，止坐文暢一房。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000033",
    "sentence": "弟文略，以兄文羅卒無後，襲梁郡王。",
    "entities": [
      {
        "text": "襲梁郡",
        "label": "LOC",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000034",
    "sentence": "以文暢事，當從坐，高祖特加寬貸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000035",
    "sentence": "文略聰明儁爽，多所通習。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000036",
    "sentence": "世宗嘗令章永興於馬上彈胡琵琶，奏十餘曲，試使文略寫之，遂得其八。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000037",
    "sentence": "世宗戲之曰：「聰明人多不老壽，梁郡其慎之。」文略對曰：「命之修短，皆在明公。」世宗愴然曰：「此不足慮也。」初，高祖遺令恕文略十死，恃此益橫，多所淩忽。",
    "entities": [
      {
        "text": "梁郡",
        "label": "LOC",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000038",
    "sentence": "平秦王有七百里馬，文略敵以好婢，賭而取之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000039",
    "sentence": "明日，平秦致請，文略殺馬及婢，以二銀器盛婢頭馬肉而遺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000040",
    "sentence": "平秦王訴之於文宣，系於京畿獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000041",
    "sentence": "文略彈琵琶，吹橫笛，謠詠，倦極便臥唱挽歌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000042",
    "sentence": "居數月，奪防者弓矢以射人曰：「不然，天子不憶我。」有司奏之，伏法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000043",
    "sentence": "文略嘗大遺魏收金，請為其父作佳傳，收論尒朱榮比韋、彭、伊、霍，蓋由是也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000044",
    "sentence": "鄭仲禮",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000045",
    "sentence": "鄭仲禮，滎陽開封人，魏鴻臚嚴庶子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000046",
    "sentence": "少輕險，有膂力，高祖嬖寵其姊，以親戚被昵，擢帳內都督。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000047",
    "sentence": "嘗執高祖弓刀，出入隨從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000048",
    "sentence": "任胄為好酒不憂公事，高祖責之，胄懼，謀為逆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000049",
    "sentence": "賴武明婁後為請，故仲禮死，不及其家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000050",
    "sentence": "李祖升",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000051",
    "sentence": "李祖升，趙國平棘人，顯祖李皇後之長兄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000052",
    "sentence": "父希宗，上黨守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000053",
    "sentence": "祖升儀容瑰麗，垂手過膝，睦姻好施，文學足以自通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000054",
    "sentence": "仕至齊州刺史，為徒兵所害。",
    "entities": [
      {
        "text": "仕至齊州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000055",
    "sentence": "弟祖勳，顯祖受禪，除秘書丞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000056",
    "sentence": "及女為濟南王妃，除侍中，封丹陽王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000057",
    "sentence": "濟南廢，為光州刺史。",
    "entities": [
      {
        "text": "為光州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000058",
    "sentence": "祖勳性貪慢，兼妻崔氏驕豪干政，時論鄙之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000059",
    "sentence": "以數坐贓免官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000060",
    "sentence": "無才幹，自少及長，居官皆因內寵，無可稱述，卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000061",
    "sentence": "元蠻",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000062",
    "sentence": "元蠻，魏太師江陽王繼子，肅宗元皇後之父也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000063",
    "sentence": "歷光祿卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000064",
    "sentence": "天保十年，大誅元氏，肅宗為蠻苦請，因是追原之，賜姓步六孤氏。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "元氏",
        "label": "ORG",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000065",
    "sentence": "尋病卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000066",
    "sentence": "胡長仁",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000067",
    "sentence": "胡長仁，字孝隆，安定臨涇人，武成皇後之兄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000068",
    "sentence": "父延之，魏中書令。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 4,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000069",
    "sentence": "長仁累遷右樸射及尚書令。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000070",
    "sentence": "世祖崩，預參朝政，封隴東王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000071",
    "sentence": "左丞鄒孝裕、郎中陸仁惠、盧元亮厚相結托。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000072",
    "sentence": "長仁每上省，孝裕必方駕而來。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000073",
    "sentence": "省務既繁，簿案堆積，令史欲諮都座者日有百數。",
    "entities": [
      {
        "text": "令史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000074",
    "sentence": "孝裕屏人私話，朝退亦相隨，仁惠、元亮又伺間而往，停斷公事，時人號為三佞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000075",
    "sentence": "長仁私遊密席，處處追尋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000076",
    "sentence": "孝裕勸其求進，和士開深疾之，於是奏除孝裕為章武郡守，元亮等皆出。",
    "entities": [
      {
        "text": "除孝裕為章武郡",
        "label": "LOC",
        "start": 17,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000077",
    "sentence": "孝裕又說長仁曰：「王陽臥疾，士開必來，因而殺之。入見太后，不過百日失官，便代其處。」士開知謀，徙孝裕為北營州建德郡守。",
    "entities": [
      {
        "text": "徙孝裕為北營州",
        "label": "LOC",
        "start": 47,
        "end": 54
      },
      {
        "text": "建德郡",
        "label": "LOC",
        "start": 54,
        "end": 57
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000078",
    "sentence": "後長仁倚親，驕豪無畏憚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000079",
    "sentence": "士開出為齊州刺史。",
    "entities": [
      {
        "text": "士開出為齊州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000080",
    "sentence": "長仁怨憤，謀令剌士開，事覺，遂賜死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000081",
    "sentence": "尋而後主納長仁女為后，重加贈謚，長仁弟等前後七人並賜王爵，合門貴盛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000082",
    "sentence": "從祖兄長粲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000083",
    "sentence": "父僧敬，即魏孝靜帝之舅，位至司空。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000084",
    "sentence": "長粲少而敏悟，以外戚起家給事中，遷黃門侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000085",
    "sentence": "後主踐祚，長粲被勑與黃門馮子琮出入禁中，專典敷奏。",
    "entities": [
      {
        "text": "馮子琮",
        "label": "PER",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000086",
    "sentence": "世祖崩，與領軍婁定遠、錄尚書趙彥深、和士開、高文遙、領軍綦連猛、高阿那肱、樸射唐邕同知朝政，時人號為八貴。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "趙彥深",
        "label": "PER",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_048_000087",
    "sentence": "於後定遠、文遙並出，唐邕專典外兵，綦連猛、高阿那肱別總武任，長粲常在左右，兼宣詔令，從幸晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000088",
    "sentence": "後主即位，富於春秋，庶事皆歸委長粲，長粲盡心毗奉，甚得名譽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000089",
    "sentence": "又為侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000090",
    "sentence": "長仁心欲入處機要之地，為執政不許，長仁疑長粲通謀，大以為恨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_048_000091",
    "sentence": "遂言於太后，發其陰私，請出為州，後主不得已從焉。",
