  },
  {
    "sentence_id": "HCH_004_025_000135",
    "sentence": "峻乃設奇伏大破之，獲其名王郁久閭豆拔提等數十人，送於京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000136",
