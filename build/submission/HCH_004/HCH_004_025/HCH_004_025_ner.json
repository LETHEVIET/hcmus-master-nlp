  },
  {
    "sentence_id": "HCH_004_025_000086",
    "sentence": "趙起",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000087",
    "sentence": "趙起，字興洛，廣平人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000088",
