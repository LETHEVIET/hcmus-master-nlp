[
  {
    "sentence_id": "HCH_004_025_000001",
    "sentence": "張纂",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000002",
    "sentence": "張纂，字徽纂，代郡平城人也。",
    "entities": [
      {
        "text": "代郡平城",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000003",
    "sentence": "父烈，桑幹太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000004",
    "sentence": "纂初事尒朱榮，又為尒朱兆都督長史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000005",
    "sentence": "為兆使於高祖，遂被顧識。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000006",
    "sentence": "高祖舉義山東，劉誕據相州拒守，時纂亦在其中。",
    "entities": [
      {
        "text": "劉誕據相州",
        "label": "LOC",
        "start": 7,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000007",
    "sentence": "高祖攻而拔之，以纂參丞相軍事。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000008",
    "sentence": "纂性便僻，左右出內，稍見親待，仍補行臺郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000009",
    "sentence": "高祖啟減國封，分賞文武，纂隨例封壽張伯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000010",
    "sentence": "魏武帝末，高祖赴洛，以趙郡公琛為行臺，守晉陽，以纂為右丞。",
    "entities": [
      {
        "text": "以趙郡",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000011",
    "sentence": "轉相府功曹參軍事，除右光祿大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000012",
    "sentence": "使於茹茹，以銜命稱旨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000013",
    "sentence": "歷中外、丞相二府從事中郎。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000014",
    "sentence": "邙山之役，大獲俘虜，高祖令纂部送京師，魏帝賜絹五百疋，封武安縣伯。",
    "entities": [
      {
        "text": "封武安縣",
        "label": "LOC",
        "start": 27,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000015",
    "sentence": "復為高祖行臺右丞，從征玉壁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000016",
    "sentence": "大軍將還山東，行達晉州，忽值寒雨，士卒饑凍，至有死者。",
    "entities": [
      {
        "text": "行達晉州",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000017",
    "sentence": "州以邊禁不聽入城。",
    "entities": [
      {
        "text": "以邊禁不聽入城",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000018",
    "sentence": "于時纂為別使，遇見，輒令開門內之，分寄民家，給其火食，多所全濟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000019",
    "sentence": "高祖聞而善之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000020",
    "sentence": "纂事高祖二十餘歲，傳通教令，甚見親賞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000021",
    "sentence": "世宗嗣位，侯景作亂潁川，招引西魏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000022",
    "sentence": "以纂為南道行臺，與諸將率討之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000023",
    "sentence": "還，除瀛州刺史。",
    "entities": [
      {
        "text": "除瀛州",
        "label": "LOC",
        "start": 2,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000024",
    "sentence": "會世宗入為太子少傅。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000025",
    "sentence": "後與平原王段孝先、行臺尚書辛術等攻圍東楚，仍拔廣陵、涇州數城，斬賊帥東方白額。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "涇州數城",
        "label": "LOC",
        "start": 26,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000026",
    "sentence": "授儀同三司，監築長城大使，領步騎數千鎮防北境。",
    "entities": [
      {
        "text": "監築長城",
        "label": "LOC",
        "start": 6,
        "end": 10
      },
      {
        "text": "領步騎數千鎮",
        "label": "LOC",
        "start": 13,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000027",
    "sentence": "還，遷護軍將軍，尋卒。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000028",
    "sentence": "張亮",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000029",
    "sentence": "張亮，字伯德，西河隰城人也。",
    "entities": [
      {
        "text": "西河隰城",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000030",
    "sentence": "少有幹用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000031",
    "sentence": "初事尒朱兆，拜平遠將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000032",
    "sentence": "以功封隰城縣伯，邑五百戶。",
    "entities": [
      {
        "text": "以功封隰城縣",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000033",
    "sentence": "高祖討兆於晉陽，兆奔秀容。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000034",
    "sentence": "兆左右皆密通誠款，唯亮獨無啟疏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000035",
    "sentence": "及兆敗，竄於窮山，令亮及倉頭陳山提斬己首以降，皆不忍，兆乃自縊於樹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000036",
    "sentence": "伯德伏屍而哭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000037",
    "sentence": "高祖嘉歎之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000038",
    "sentence": "授丞相府參軍事，漸見親待，委以書記之任。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000039",
    "sentence": "天平中，為世宗行臺郎中，典七兵事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000040",
    "sentence": "雖為臺郎，而常在高祖左右。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000041",
    "sentence": "遷行臺右丞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000042",
    "sentence": "高仲密之叛也，與大司馬斛律金守河陽。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000043",
    "sentence": "周文帝於上流放火船燒河橋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000044",
    "sentence": "亮乃備小艇百餘艘，皆載長鎖，鎖頭施釘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000045",
    "sentence": "火船將至，卽馳小艇，以釘釘之，引鎖向岸，火船不得及橋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000046",
    "sentence": "橋之獲全，亮之計也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000047",
    "sentence": "武定初，拜太中大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000048",
    "sentence": "薛琡嘗夢亮於山上持絲，以告亮，且占之曰：「山上絲，幽字也。君其為幽州乎？」數月，亮出為幽州刺史。",
    "entities": [
      {
        "text": "君其為幽州",
        "label": "LOC",
        "start": 29,
        "end": 34
      },
      {
        "text": "亮出為幽州",
        "label": "LOC",
        "start": 40,
        "end": 45
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 45,
        "end": 47
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000049",
    "sentence": "屬侯景叛，除平南將軍、梁州刺史。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "梁州",
        "label": "LOC",
        "start": 11,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000050",
    "sentence": "尋加都督揚、潁等十一州諸軍事，兼行臺殿中尚書，轉都督二豫、揚、潁等八州軍事、征西大將軍、豫州刺史、尚書右僕射、西南道行臺。",
    "entities": [
      {
        "text": "潁等十一州",
        "label": "LOC",
        "start": 6,
        "end": 11
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 20,
        "end": 22
      },
      {
        "text": "潁等八州",
        "label": "LOC",
        "start": 31,
        "end": 35
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 40,
        "end": 43
      },
      {
        "text": "豫州",
        "label": "LOC",
        "start": 44,
        "end": 46
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 46,
        "end": 48
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 49,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000051",
    "sentence": "攻梁江夏、潁陽等七城，皆下之。",
    "entities": [
      {
        "text": "潁陽等七城",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000052",
    "sentence": "亮性質直，勤力強濟，深為高祖、世宗所信，委以腹心之任。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000053",
    "sentence": "然少風格，好財利，久在左右，不能廉潔，及歷諸州，咸有黷貨之聞。",
    "entities": [
      {
        "text": "及歷諸州",
        "label": "LOC",
        "start": 19,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000054",
    "sentence": "武定末，征拜侍中、汾州大中正。",
    "entities": [
      {
        "text": "汾州",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000055",
    "sentence": "天保初，授光祿勳，加驃騎大將軍、儀同三司，別封安定縣男，轉中領軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 12,
        "end": 15
      },
      {
        "text": "別封安定縣",
        "label": "LOC",
        "start": 21,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000056",
    "sentence": "尋卒於位，贈司空公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000057",
    "sentence": "張耀",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000058",
    "sentence": "張耀，字靈光，上谷昌平人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000059",
    "sentence": "父鳳，晉州長史。",
    "entities": [
      {
        "text": "晉州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000060",
    "sentence": "耀少而貞謹，頗曉史職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000061",
    "sentence": "解褐給事中，轉司徒水曹行參軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000062",
    "sentence": "義旗建，高祖擢為中軍大都督韓軌府長史。",
    "entities": [
      {
        "text": "大都",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000063",
    "sentence": "及軌除瀛、冀二州刺史，又以耀為軌諮議參軍。",
    "entities": [
      {
        "text": "冀二州",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000064",
    "sentence": "後為御史所劾，州府僚佐及軌左右以贓罪掛網者百有餘人，唯耀清白獨免。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000065",
    "sentence": "徵為丞相府倉曹。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000066",
    "sentence": "顯祖嗣事，遷相府掾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000067",
    "sentence": "天保初，賜爵都亭鄉男，攝倉、庫二曹事。",
    "entities": [
      {
        "text": "賜爵都亭鄉",
        "label": "LOC",
        "start": 4,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000068",
    "sentence": "諸有賜給，常使耀典之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000069",
    "sentence": "轉秘書丞，遷尚書右丞。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000070",
    "sentence": "顯祖曾因近出，令耀居守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000071",
    "sentence": "帝夜還，耀不時開門，勒兵嚴備。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000072",
    "sentence": "帝駐蹕門外久之，催迫甚急。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000073",
    "sentence": "耀以夜深，真偽難辯，須火至面識，門乃可開，於是獨出見帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000074",
    "sentence": "帝笑曰：「卿欲學郅君章也？」乃使耀前開門，然後入，深嗟賞之，賜以錦采。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000075",
    "sentence": "出為南青州刺史，未之任。",
    "entities": [
      {
        "text": "出為南青州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_025_000076",
    "sentence": "肅宗輔政，累遷秘書監。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000077",
    "sentence": "耀歷事累世，奉職恪勤，咸見親待，未嘗有過。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000078",
    "sentence": "每得祿賜，散之宗族。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000079",
    "sentence": "性節儉率素，車服飲食，取給而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_025_000080",
    "sentence": "好讀《 春秋 》，月一遍，時人比之賈梁道。",
