[
  {
    "sentence_id": "HCH_004_009_000001",
    "sentence": "神武婁后",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000002",
    "sentence": "神武明皇后婁氏，諱昭君，贈司徒內干之女也。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000003",
    "sentence": "少明悟，強族多聘之，並不肯行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000004",
    "sentence": "及見神武於城上執役，驚曰：「此真吾夫也。」乃使婢通意，又數致私財，使以聘己，父母不得已而許焉。",
    "entities": [
      {
        "text": "及見神武於城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000005",
    "sentence": "神武既有澄清之志，傾產以結英豪，密謀秘策，后恒參預。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000006",
    "sentence": "及拜渤海王妃，閫闈之事悉決焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000007",
    "sentence": "后高明嚴斷，雅遵儉約，往來外舍，侍從不過十人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000008",
    "sentence": "性寬厚，不妒忌，神武姬侍，咸加恩待。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000009",
    "sentence": "神武嘗將西討出師，後夜孿生一男一女，左右以危急，請追告神武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000010",
    "sentence": "后弗聽曰：「王出統大兵，何得以我故輕離軍幕。死生命也，來復何為！」神武聞之，嗟歎良久。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000011",
    "sentence": "沙苑敗後，侯景屢言請精騎二萬，必能取之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000012",
    "sentence": "神武悅，以告于后。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000013",
    "sentence": "后曰：「若如其言，豈有還理，得獺失景，亦有何利。」乃止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000014",
    "sentence": "神武逼於茹茹，欲娶其女而未決。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000015",
    "sentence": "后曰：「國家大計，願不疑也。」及茹茹公主至，后避正室處之。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000016",
    "sentence": "神武愧而拜謝焉，曰：「彼將有覺，願絕勿顧。」慈愛諸子，不異己出，躬自紡績，人賜一袍一袴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000017",
    "sentence": "手縫戎服，以帥左右。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000018",
    "sentence": "弟昭，以功名自達，其餘親屬，未嘗為請爵位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000019",
    "sentence": "每言有材當用，義不以私亂公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000020",
    "sentence": "文襄嗣位，進為太妃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000021",
    "sentence": "文宣將受魏禪，后固執不許，帝所以中止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000022",
    "sentence": "天保初，尊為皇太后，宮曰宣訓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000023",
    "sentence": "濟南即位，尊為太皇太后。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000024",
    "sentence": "尚書令楊愔等受遺詔輔政，疏忌諸王。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000025",
    "sentence": "太皇太后密與孝昭及諸大將定策誅之，下令廢立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000026",
    "sentence": "孝昭即位，復為皇太后。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000027",
    "sentence": "孝昭帝崩，太后又下詔立武成帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000028",
    "sentence": "大寧二年春，太后寢疾，衣忽自舉，用巫媼言改姓石氏。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000029",
    "sentence": "四月辛丑，崩於北宮，時年六十二。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000030",
    "sentence": "五月甲申，合葬義平陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000031",
    "sentence": "太后凡孕六男二女，皆感夢：孕文襄則夢一斷龍；孕文宣則夢大龍，首尾屬天地，張口動目，勢狀驚人；孕孝昭則夢蠕龍於地；孕武成則夢龍浴於海；孕魏二后並夢月入懷；孕襄城、博陵二王夢鼠入衣下。",
    "entities": [
      {
        "text": "孕襄城",
        "label": "LOC",
        "start": 76,
        "end": 79
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000032",
    "sentence": "后未崩，有童謠曰「九龍母死不作孝」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000033",
    "sentence": "及后崩，武成不改服，緋袍如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000034",
    "sentence": "未幾，登三臺，置酒作樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000035",
    "sentence": "帝女進白袍，帝怒，投諸臺下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000036",
    "sentence": "和士開請止樂，帝大怒，撻之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000037",
    "sentence": "帝於昆季次實九，蓋其徵驗也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000038",
    "sentence": "文襄元后",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000039",
    "sentence": "文襄敬皇后元氏，魏孝靜帝之姊也。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "元氏",
        "label": "ORG",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000040",
    "sentence": "孝武帝時，封馮翊公主而歸於文襄。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000041",
    "sentence": "容德兼美，曲盡和敬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000042",
    "sentence": "初生河間王孝琬，時文襄為世子，三日而孝靜帝幸世子第，贈錦彩及布帛萬匹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000043",
    "sentence": "世子辭，求通受諸貴禮遺，於是十屋皆滿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000044",
    "sentence": "次生兩公主。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000045",
    "sentence": "文宣受禪，尊為文襄皇后，居靜德宮。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000046",
    "sentence": "及 天保六年 ，文宣漸致昏狂，乃移居于高陽之宅，而取其府庫，曰：「吾兄昔奸我婦，我今須報。」乃淫於后。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000047",
    "sentence": "其高氏女婦無親疏，皆使左右亂交之於前。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000048",
    "sentence": "以葛為絙，令魏安德主騎上，使人推引之，又命胡人苦辱之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000049",
    "sentence": "帝又自呈露，以示群下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000050",
    "sentence": "武平中，后崩，祔葬義平陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000051",
    "sentence": "文宣李后",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000052",
    "sentence": "文宣皇后李氏，諱祖娥，趙郡李希宗女也。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "趙郡",
        "label": "LOC",
        "start": 11,
        "end": 13
      },
      {
        "text": "李希宗",
        "label": "PER",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000053",
    "sentence": "容德甚美。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000054",
    "sentence": "初為太原公夫人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000055",
    "sentence": "及帝將建中宮，高隆之、高德正言漢婦人不可為天下母，宜更擇美配。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000056",
    "sentence": "楊愔固請依漢、魏故事，不改元妃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000057",
    "sentence": "而德正猶固請廢后而立段昭儀，欲以結勳貴之援，帝竟不從而立后焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000058",
    "sentence": "帝好捶撻嬪御，乃至有殺戮者，唯後后蒙禮敬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000059",
    "sentence": "天保十年 ，改為可賀敦皇后。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000060",
    "sentence": "孝昭即位，降居昭信宮，號昭信皇后。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000061",
    "sentence": "武成踐祚，逼后淫亂，云：「若不許，我當殺爾兒。」后懼，從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000062",
    "sentence": "後有娠，太原王紹德至閣，不得見，慍曰：「兒豈不知耶，姊姊腹大，故不見兒。」後聞之，大慚，由是生女不舉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000063",
    "sentence": "帝橫刀詬曰：「爾殺我女，我何不殺爾兒！」對后前築殺紹德。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000064",
    "sentence": "后大哭，帝愈怒，裸后亂撾撻之，號天不已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000065",
    "sentence": "盛以絹囊，流血淋漉，投諸渠水，良久乃蘇，犢車載送妙勝尼寺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000066",
    "sentence": "后性愛佛法，因此為尼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000067",
    "sentence": "齊亡入關。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000068",
    "sentence": "隋時得還趙郡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000069",
    "sentence": "孝昭元后",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000070",
    "sentence": "孝昭皇后元氏，開府元蠻女也。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "元氏",
        "label": "ORG",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000071",
    "sentence": "初為常山王妃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000072",
    "sentence": "天保末，賜姓步六孤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000073",
    "sentence": "孝昭即位，立為皇后。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000074",
    "sentence": "帝崩，梓宮之鄴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000075",
    "sentence": "始渡汾橋，武成聞后有奇藥，追索之不得，使閹人就車頓辱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000076",
    "sentence": "降居順成宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000077",
    "sentence": "武成既殺樂陵王，元被閟隔，不得與家相知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000078",
    "sentence": "宮闈內忽有飛語，帝令檢推，得后父兄書信，元蠻由是坐免官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000079",
    "sentence": "後以齊亡入周氏宮中。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 2,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000080",
    "sentence": "隋文帝作相，放還山東。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000081",
    "sentence": "武成胡后",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000082",
    "sentence": "武成皇后胡氏，安定胡延之女。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000083",
    "sentence": "其母范陽盧道約女，初懷孕，有胡僧詣門曰：「此宅瓠蘆中有月」，既而生后。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000084",
    "sentence": "天保初，選為長廣王妃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000085",
    "sentence": "產後主日，號鳴於產帳上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000086",
    "sentence": "武成崩，尊為皇太后，陸媼及和士開密謀殺趙郡王叡，出婁定遠、高文遙為刺史。",
    "entities": [
      {
        "text": "士開密謀殺趙郡",
        "label": "LOC",
        "start": 14,
        "end": 21
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000087",
    "sentence": "和、陸諂事太后，無所不至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000088",
    "sentence": "初武成時，後與諸閹人褻狎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000089",
    "sentence": "武成寵倖和士開，每與后握槊，因此與后姦通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000090",
    "sentence": "自武成崩後，數出詣佛寺，又與沙門曇獻通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000091",
    "sentence": "布金錢於獻席下，又挂寶裝胡床於獻屋壁，武成平生之所御也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000092",
    "sentence": "乃置百僧於內殿，托以聽講，日夜與曇獻寢處。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000093",
    "sentence": "以獻為昭玄統。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000094",
    "sentence": "僧徒遙指太后以弄曇獻，乃至謂之為太上者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000095",
    "sentence": "帝聞太后不謹而未之信，後朝太后，見二少尼，悅而召之，乃男子也，於是曇獻事亦發，皆伏法，並殺元、山、王三郡君，皆太后之所昵也。",
    "entities": [
      {
        "text": "王三郡",
        "label": "LOC",
        "start": 49,
        "end": 52
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000096",
    "sentence": "帝自晉陽奉太后還鄴，至紫陌，卒遇大風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000097",
    "sentence": "舍人魏僧伽明風角，奏言即時當有暴逆事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000098",
    "sentence": "帝詐云鄴中有急，彎弓緾槊，馳入南城，令鄧長顒幽太后北宮，仍有敕內外諸親一不得與太后相見。",
    "entities": [
      {
        "text": "馳入南城",
        "label": "LOC",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000099",
    "sentence": "久之，帝復迎太后。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000100",
    "sentence": "太后初聞使者至，大驚，慮有不測。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000101",
    "sentence": "每太后設食，帝亦不敢嘗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000102",
    "sentence": "周使元偉來聘，作《述行賦》，敘鄭莊公克段而遷姜氏，文雖不工，當時深以為愧。",
    "entities": [
      {
        "text": "《述行賦》",
        "label": "TITLE",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000103",
    "sentence": "齊亡入周，恣行姦穢。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "周",
        "label": "ORG",
        "start": 3,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000104",
    "sentence": "隋開皇中殂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000105",
    "sentence": "後主斛律后",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000106",
    "sentence": "後主皇后斛律氏，左丞相光之女也。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000107",
    "sentence": "初為皇太子妃。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000108",
    "sentence": "後主受禪，立為皇后。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000109",
    "sentence": "武平三年 正月生女，帝欲悅光，詐稱生男，為之大赦。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000110",
    "sentence": "光誅，后廢在別宮，後令為尼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000111",
    "sentence": "齊滅，嫁為開府元仁妻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000112",
    "sentence": "後主胡后",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000113",
    "sentence": "後主皇后胡氏，隴東王長仁女也。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000114",
    "sentence": "胡太后失母儀之道，深以為愧，欲求悅後主，故飾后於宮中，令帝見之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000115",
    "sentence": "帝果悅，立為弘德夫人，進左昭儀，大被寵愛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000116",
    "sentence": "斛律后廢，陸媼欲以穆夫人代之，太后不許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000117",
    "sentence": "祖孝徵請立胡昭儀，遂登為皇后。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000118",
    "sentence": "陸媼既非勸立，又意在穆夫人，其後於太后前作色而言曰：「何物親侄女，作如此語言！」太后問有何言，曰：「不可道。」固問之，乃曰：「語大家云，太后行多非法，不可以訓。」太后大怒，喚後出，立剃其髮，送令還家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000119",
    "sentence": "帝思之，每致物以通意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000120",
    "sentence": "後與斛律廢后俱召入內，數日而鄴不守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000121",
    "sentence": "後亦改嫁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000122",
    "sentence": "後主穆后",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000123",
    "sentence": "後主皇后穆氏，名邪利，本斛律後從婢也。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000124",
    "sentence": "母名輕霄，本穆子倫婢也，轉入侍中宋欽道家，姦私而生后，莫知氏族，或云后即欽道女子也。",
    "entities": [
      {
        "text": "宋欽道",
        "label": "PER",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000125",
    "sentence": "小字黃花，後字舍利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000126",
    "sentence": "欽道婦妬，黥輕霄面為「宋 」字。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000127",
    "sentence": "欽道伏誅，黃花因此入宮，有幸於後主，宮內稱為舍利太監。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000128",
    "sentence": "女侍中陸太姬知其寵，養以為女，薦為弘德夫人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000129",
    "sentence": "武平元年 六月，生皇子恒。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000130",
    "sentence": "於時後主未有儲嗣，陸陰結待，以監撫之任不可無主，時皇后斛律氏，丞相光之女也，慮其懷恨，先令母養之，立為皇太子。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 25,
        "end": 27
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 31,
        "end": 33
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 52,
        "end": 54
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000131",
    "sentence": "陸以國姓之重，穆、陸相對，又奏賜姓穆氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000132",
    "sentence": "胡庶人之廢也，陸有助焉，胡遂立為皇后，大赦。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000133",
    "sentence": "初，有折衝將軍元正烈於鄴城東水中得璽以獻，文曰「天王后璽」，蓋石氏所作。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000134",
    "sentence": "詔書頒告，以為穆后之瑞焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000135",
    "sentence": "武成時，為胡后造真珠裙袴，所費不可稱計，被火所燒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000136",
    "sentence": "後主既立穆皇后，復為營之。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000137",
    "sentence": "屬周武遭太后喪，詔侍中薛孤、康買等為弔使，又遣商胡齎錦彩三萬疋與使同往，欲市真珠為皇后造七寶車，周人不與交易，然而竟造焉。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 41,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000138",
    "sentence": "先是童謠曰：「黃華勢欲落，清觴滿杯酌。」言黃花不久也，後主自立穆后以後，昏飲無度，故云清觴滿杯酌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000139",
    "sentence": "陸息駱提婆詔改姓為穆，陸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000140",
    "sentence": "太姬，皆以皇后故也。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000141",
    "sentence": "后既以陸為母，提婆為家，更不采輕霄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000142",
    "sentence": "輕霄後自療面，欲求見，太后、陸媼使禁掌之，竟不得見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000143",
    "sentence": "論",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000144",
    "sentence": "論曰：神武肇興齊業，武明追蹤周亂。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 7,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_009_000145",
    "sentence": "溫公之敗邦家，馮妃比跡褒後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000146",
    "sentence": "然則汙隆之義，蓋有系焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000147",
    "sentence": "其餘作孽為眚，外平內蠹，鑒之近代，于齊為甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_009_000148",
    "sentence": "校",
    "entities": []
  },
  {
