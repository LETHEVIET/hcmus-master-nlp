[
  {
    "sentence_id": "HCH_004_040_000001",
    "sentence": "尉瑾　馮子琮　赫連子悅　唐邕　白建",
    "entities": [
      {
        "text": "馮子琮",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000002",
    "sentence": "尉瑾",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000003",
    "sentence": "尉瑾，字安仁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000004",
    "sentence": "父慶賓，為魏肆州刺史。",
    "entities": [
      {
        "text": "為魏肆州",
        "label": "LOC",
        "start": 4,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000005",
    "sentence": "瑾少而敏悟，好學慕善。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000006",
    "sentence": "稍遷直後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000007",
    "sentence": "司馬子如執政，瑾取其外生皮氏女，由此擢拜中書舍人。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000008",
    "sentence": "旣是子如姻戚，數往參詣，因與先達名輩微相款狎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000009",
    "sentence": "世宗入朝，因命瑾在鄴北宮共高德正典機密。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000010",
    "sentence": "肅宗輔政，累遷吏部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000011",
    "sentence": "世祖踐祚，趙彥深本子如賓僚，元文遙、和士開並帝鄉故舊，共相薦達，任遇彌重。",
    "entities": [
      {
        "text": "趙彥深",
        "label": "PER",
        "start": 5,
        "end": 8
      },
      {
        "text": "和士開並帝鄉",
        "label": "LOC",
        "start": 18,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000012",
    "sentence": "又吏部銓衡所歸，事多秘密，由是朝之幾事，頗亦預聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000013",
    "sentence": "尋兼右僕射，攝選，未幾即真。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000014",
    "sentence": "病卒，世祖方在三臺飲酒，文遙奏聞，遂命徹樂罷飲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000015",
    "sentence": "瑾外雖通顯，內闕風訓，閨門穢雜，為世所鄙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000016",
    "sentence": "然亦能折節下士，意在引接名流，但不別之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000017",
    "sentence": "及官高任重，便大躁急，省內郎中將論事者逆即瞋詈，不可諮承。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000018",
    "sentence": "旣居大選，彌自驕狠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000019",
    "sentence": "子德載嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000020",
    "sentence": "馮子琮",
    "entities": [
      {
        "text": "馮子琮",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000021",
    "sentence": "馮子琮，信都人，北燕主馮跋之後也。",
    "entities": [
      {
        "text": "馮子琮",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000022",
    "sentence": "父靈紹，度支郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000023",
    "sentence": "子琮性聰敏，涉獵書傳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000024",
    "sentence": "為。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000025",
    "sentence": "肅宗除領軍府法曹，典機密，攝庫部。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000026",
    "sentence": "肅宗曾閱簿領，試令口陳，子琮闇對，無有遺失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000027",
    "sentence": "子琮妻，胡皇后妹也。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000028",
    "sentence": "遷殿中郎，加東宮管記。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000029",
    "sentence": "又奉別詔，令共胡長粲輔遵太子，轉庶子。",
    "entities": [
      {
        "text": "胡長粲",
        "label": "PER",
        "start": 7,
        "end": 10
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000030",
    "sentence": "天統元年 ，世祖禪位後主。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000031",
    "sentence": "世祖御正殿，謂子琮曰：「少君左右宜得正人，以卿心存正直，今以後事相委。」除給事黃門侍郎，領主衣都統。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 41,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000032",
    "sentence": "世祖在晉陽，旣居舊殿，少帝未有別所，詔子琮監造大明宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000033",
    "sentence": "宮成，世祖親自巡幸，怪其不甚宏麗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000034",
    "sentence": "子琮對曰：「至尊幼年，纂承大業，欲令敦行節儉，以示萬邦。兼此北連天闕，不宜過復崇峻。」世祖稱善。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000035",
    "sentence": "及世祖崩，僕射和士開先恒侍疾，秘喪三日不發。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000036",
    "sentence": "子琮問士開不發喪之意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000037",
    "sentence": "士開引神武、文襄初崩並秘喪不舉，至尊年少，恐王公有貳心，意欲普追集涼風堂，然後與詳議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000038",
    "sentence": "時太尉錄尚書事趙郡王叡先恒居內，預帷幄之謀，子琮素知士開忌叡及領軍臨淮王婁定遠，恐其矯遺詔出叡外任，奪定遠禁衛之權，因答云：「大行，神武之子，今上又是先皇傳位，群臣富貴者皆是至尊父子之恩，但令在內貴臣一無改易，王公已下必無異望。世異事殊，不得與霸朝相比。且公出宮門已經數日，升遐之事，行路皆傳，久而不舉，恐有他變。」於是乃發喪。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000039",
    "sentence": "元文遙以子琮太后妹夫，恐其獎成太后干政，說趙郡王及士開出之，拜鄭州刺史，即令之任。",
    "entities": [
      {
        "text": "說趙郡",
        "label": "LOC",
        "start": 20,
        "end": 23
      },
      {
        "text": "拜鄭州",
        "label": "LOC",
        "start": 30,
        "end": 33
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000040",
    "sentence": "子琮除州，非後主本意，中旨殷勤，特給後部鼓吹，加兵五十人，並聽將物度關。",
    "entities": [
      {
        "text": "子琮除州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "並聽將物度關",
        "label": "LOC",
        "start": 29,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000041",
    "sentence": "至州未幾，太后為齊安王納子琮長女為妃，子琮因請假赴鄴，遂授吏部尚書。",
    "entities": [
      {
        "text": "至州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000042",
    "sentence": "其妻恃親放縱，請謁公行，賄貨填積。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000043",
    "sentence": "守宰除授，先定錢帛多少，然後奏聞，其所通致，事無不允，子琮亦不禁制。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000044",
    "sentence": "俄遷尚書右僕射，仍攝選。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000045",
    "sentence": "和士開居要日久，子琮舊所附托，卑辭曲躬，事事諮稟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000046",
    "sentence": "士開弟休與盧氏婚，子琮檢校趨走，與士開府僚不異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000047",
    "sentence": "是時內官除授多由士開奏擬，子琮旣恃內戚，兼帶選曹，自擅權寵，頗生間隙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000048",
    "sentence": "瑯邪王儼殺士開，子琮與其事，就內省絞殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000049",
    "sentence": "子琮微有識鑒，及位望轉隆，宿心頓改。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000050",
    "sentence": "擢引非類，以為深交；縱其子弟，官位不依倫次；又專營婚媾，歷選上門，例以官爵許之，旬日便驗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000051",
    "sentence": "子慈正。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000052",
    "sentence": "赫連子悅",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000053",
    "sentence": "赫連子悅，字士欣，勃勃之後也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000054",
    "sentence": "魏永安初，以軍功為濟州別駕。",
    "entities": [
      {
        "text": "以軍功為濟州",
        "label": "LOC",
        "start": 5,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000055",
    "sentence": "及高祖起義，侯景為刺史，景本尒朱心腹，子悅勸景起義，景從之。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000056",
    "sentence": "除林慮守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000057",
    "sentence": "世宗往晉陽，路由是郡，因問所不便。",
    "entities": [
      {
        "text": "路由是郡",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000058",
    "sentence": "悅答云：「臨水、武安二縣去郡遙遠，山嶺重疊，車步艱難，若東屬魏郡，則地平路近。」世宗笑曰：「卿徒知便民，不覺損幹。」子悅答云：「所言因民疾苦，不敢以私潤負心。」世宗云：「卿能如此，甚善甚善。」仍勑依事施行。",
    "entities": [
      {
        "text": "武安二縣去郡",
        "label": "LOC",
        "start": 8,
        "end": 14
      },
      {
        "text": "若東屬魏郡",
        "label": "LOC",
        "start": 27,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000059",
    "sentence": "在郡滿，更徵為臨漳令。",
    "entities": [
      {
        "text": "在郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000060",
    "sentence": "後除鄭州刺史，于時新經河清大水，民多逃散，子悅親加恤隱，戶口益增，治為天下之最。",
    "entities": [
      {
        "text": "後除鄭州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000061",
    "sentence": "入為都官尚書，鄭州民八百餘請立碑頌德，有詔許焉。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "鄭州",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000062",
    "sentence": "後以本官兼吏部。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000063",
    "sentence": "子悅在官，唯以清勤自守，旣無學術，又闕風儀，人倫清鑒，去之彌遠，一旦居銓衡之首，大招物議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000064",
    "sentence": "由是除太常卿，卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000065",
    "sentence": "唐邕",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000066",
    "sentence": "唐邕，字道和，太原晉陽人，其先自晉昌徙焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000067",
    "sentence": "父靈芝，魏壽陽令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000068",
    "sentence": "邕少明敏，有治世才具。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000069",
    "sentence": "太昌初，或薦於高祖，命其直外兵曹，典執文帳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000070",
    "sentence": "邕善書計，強記默識，以幹濟見知，擢為世宗大將軍府參軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 20,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000071",
    "sentence": "及世宗崩，事出倉卒，顯祖部分將士，鎮壓四方，夜中召邕支配，造次便了，顯祖甚重之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000072",
    "sentence": "顯祖頻年出塞，邕必陪從，專掌兵機。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000073",
    "sentence": "識悟閑明，承受敏速，自督將以還，軍吏以上，勞效由緒，無不諳練，每有顧問，占對如響。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000074",
    "sentence": "或於御前簡閱，雖三五千人，邕多不執文簿，暗唱官位姓名，未常謬誤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000075",
    "sentence": "七年，於羊汾堤講武，令邕總為諸軍節度。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000076",
    "sentence": "事畢，仍監宴射之禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000077",
    "sentence": "是日，顯祖親執邕手，引至太后前，坐於丞相斛律金之上，啟太后云：「唐邕強幹，一人當千。」仍別賜錦彩錢帛。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "斛律金",
        "label": "PER",
        "start": 20,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000078",
    "sentence": "邕非唯強濟明辨，然亦善揣上意，進取多途，是以恩寵日隆，委任彌重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000079",
    "sentence": "顯祖又嘗對邕白太后云：「唐邕分明強記，每有軍機大事，手作文書，口且處分，耳又聽受，實是異人。」一日之中，六度賜物。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000080",
    "sentence": "又嘗解所服青鼠皮裘賜邕，云：「朕意在車馬衣裘與卿共弊。」十年，從幸晉陽，除兼給事黃門侍郎，領中書舍人。",
