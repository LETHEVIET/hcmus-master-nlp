      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000109",
    "sentence": "少子君德，以邕降周伏法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000110",
    "sentence": "齊朝因高祖作相，丞相府外兵曹、騎兵曹分掌兵馬。",
    "entities": [
      {
        "text": "齊朝",
        "label": "ORG",
