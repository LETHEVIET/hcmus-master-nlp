      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000116",
    "sentence": "天保十年 ，兼中書舍人。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000117",
    "sentence": "肅宗輔政，除大丞相騎兵參軍。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000118",
    "sentence": "河清三年 ，突厥入境，代、忻二牧悉是細馬，合數萬匹，在五臺山北栢谷中避賊。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000119",
    "sentence": "賊退後，勑建就彼檢校，續使人詣建間領馬，送定州付民養飼。",
    "entities": [
      {
        "text": "送定州",
        "label": "LOC",
        "start": 20,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000120",
    "sentence": "建以馬久不得食，瘦弱，遠送恐多死損，遂違勑以便宜從事，隨近散付軍人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000121",
    "sentence": "啟知，勑許焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000122",
    "sentence": "戎乘無損，建有力焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000123",
    "sentence": "武平末，歷特進、侍中、中書令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000124",
    "sentence": "建雖無他才，勤於在公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000125",
    "sentence": "屬王業始基，戎寄為重，建與唐邕俱以典執兵馬致位卿相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000126",
    "sentence": "晉陽，國之下都，每年臨幸，徵詔差科，責成州郡。",
    "entities": [
      {
        "text": "責成州郡",
        "label": "LOC",
        "start": 18,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000127",
    "sentence": "本藩僚佐爰及守宰，諮承陳請，趨走無暇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000128",
    "sentence": "諸子幼稚，俱為州郡主簿，新君選補，必先召辟。",
    "entities": [
      {
        "text": "俱為州郡",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000129",
    "sentence": "男婚女嫁，皆得勝流。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000130",
    "sentence": "當世以為榮寵之極。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000131",
