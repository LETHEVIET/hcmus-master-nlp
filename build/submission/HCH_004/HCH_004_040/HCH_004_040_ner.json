        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000097",
    "sentence": "卒於鳳州刺史。",
    "entities": [
      {
        "text": "卒於鳳州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
