        "start": 65,
        "end": 67
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000090",
    "sentence": "屬周師來寇，丞相高阿那肱率兵赴援，邕配割不甚從允，因此有隙。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_040_000091",
    "sentence": "肱譖之，遣侍中斛律孝卿宣旨責讓，留身禁止，尋釋之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000092",
    "sentence": "車駕將幸晉陽，勑孝卿總知騎兵度支，事多自決，不相詢稟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000093",
    "sentence": "邕自恃從霸朝以來常典樞要，歷事六帝，恩遇甚重，一旦為孝卿所輕，負氣鬱怏，形於辭色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000094",
    "sentence": "帝平陽敗後，狼狽還鄴都。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000095",
    "sentence": "邕懼那肱譖之，恨斛律孝卿輕己，遂留晉陽，與莫多婁敬顯等崇樹安德王為帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_040_000096",
    "sentence": "信宿城陷，邕遂降周，依例授儀同大將軍。",
    "entities": [
      {
        "text": "信宿城",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
