[
  {
    "sentence_id": "HCH_004_036_000001",
    "sentence": "邢卲",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000002",
    "sentence": "邢卲，字子才，河間鄚人，魏太常貞之後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000003",
    "sentence": "父虬，魏光祿卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000004",
    "sentence": "卲小字吉，少時有避，遂不行名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000005",
    "sentence": "年五歲，魏吏部郎清河崔亮見而奇之，曰：「「此子後當大成，位望通顯。」十歲便能屬文，雅有才思，聰明強記，日誦萬餘言。族兄巒，有人倫鑒，謂子弟曰：「宗室中有此兒，非常人也。」少在洛陽，會天下無事，與時名勝專以山水遊宴為娛，不暇勤業。嘗因霖雨，乃讀《漢書》，五日，略能遍記之。後因飲謔倦，方廣尋經史，五行俱下，一覽便記，無所遺忘。文章典麗，既贍且速。年未二十，名動衣冠。嘗與右北平陽固、河東裴伯茂、從兄罘、河南陸道暉等至北海王昕舍宿飲，相與賦詩，凡數十首，皆在主人奴處。旦日奴行，諸人求詩不得，卲皆為誦之。諸人有不認詩者，奴還得本，不誤一字。諸人方之王粲。吏部尚書隴西李神儁大相欽重，引為忘年之交。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 87,
        "end": 89
      },
      {
        "text": "《漢書》",
        "label": "TITLE",
        "start": 121,
        "end": 125
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 277,
        "end": 279
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000006",
    "sentence": "釋巾為魏宣武挽郎，除奉朝請，遷著作佐郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000007",
    "sentence": "深為領軍元叉所禮，叉新除尚書令，神儁與陳郡袁翻在席，叉令卲作謝表，須臾便成，以示諸賓。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "神儁與陳郡",
        "label": "LOC",
        "start": 16,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000008",
    "sentence": "神儁曰：「邢卲此表，足使袁公變色。」孝昌初，與黃門侍郎李琰之對典朝儀。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000009",
    "sentence": "自孝明之後，文雅大盛，卲雕蟲之美，獨步當時，每一文初出，京師為之紙貴，讀誦俄遍遠近。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000010",
    "sentence": "于時袁翻與范陽祖瑩位望通顯，文筆之美，見稱先達，以卲藻思華贍，深共嫉之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000011",
    "sentence": "每洛中貴人拜職，多憑卲為謝表。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000012",
    "sentence": "嘗有一貴勝初受官，大集賓食，翻與卲俱在坐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000013",
    "sentence": "翻意主人托其為讓表，遂命卲作之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000014",
    "sentence": "翻甚不悅，每告人云：「邢家小兒當客作章表，自買黃紙，寫而送之。」卲恐為翻所害，乃辭以疾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000015",
    "sentence": "屬尚書令元羅出鎮青州，啟為府司馬。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 1,
        "end": 3
      },
      {
        "text": "青州",
        "label": "LOC",
        "start": 8,
        "end": 10
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000016",
    "sentence": "遂在青土，終日酣賞，盡山泉之致。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000017",
    "sentence": "永安初，累遷中書侍郎，所作詔誥，文體宏麗。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000018",
    "sentence": "及尒朱榮入洛，京師擾亂，卲與弘農楊愔避地嵩高山。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000019",
    "sentence": "普泰中，兼給事黃門侍郎，尋為散騎常侍。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000020",
    "sentence": "太昌初，勑令恒直內省，給御食，令覆按尚書門下事，凡除大官，先問其可否，然後施行。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000021",
    "sentence": "除衛將軍、國子祭酒。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000022",
    "sentence": "以親老還鄉，詔所在特給兵力五人，並令歲一入朝，以備顧問。",
    "entities": [
      {
        "text": "以親老還鄉",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000023",
    "sentence": "丁母憂，哀毀過禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000024",
    "sentence": "後楊愔與魏收及卲請置學及修立明堂，奏曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000025",
    "sentence": "世室明堂，顯於周、夏；一黌兩學，盛自虞、殷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000026",
    "sentence": "所以宗配上帝，以著莫大之嚴；宣布下土，以彰則天之軌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000027",
    "sentence": "養黃發以詢哲言，育青衿而敷教典，用能享國長久，風徽萬祀者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000028",
    "sentence": "爰暨亡秦，改革其道，坑儒滅學，以蔽黔黎。",
    "entities": [
      {
        "text": "秦",
        "label": "ORG",
        "start": 3,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000029",
    "sentence": "故九服分崩，祚終二代。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000030",
    "sentence": "炎漢勃興，更修儒術。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000031",
    "sentence": "故西京有六學之義，東都有三本之盛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000032",
    "sentence": "逮自魏、晉，撥亂相因，兵革之中，學校不絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000033",
    "sentence": "仰惟高祖孝文皇帝稟聖自天，道鏡今古，列校序於鄉黨，敦詩書於郡國。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "列校序於鄉",
        "label": "LOC",
        "start": 18,
        "end": 23
      },
      {
        "text": "敦詩書於郡",
        "label": "LOC",
        "start": 25,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000034",
    "sentence": "但經始事殷，戎軒屢駕，未遑多就，弓劍弗追。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000035",
    "sentence": "世宗統歷，聿遵先緒，永平之中，大興板築。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000036",
    "sentence": "續以水旱，戎馬生郊，雖逮為山，還停一簣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000037",
    "sentence": "而明堂禮樂之本，乃鬱荊棘之林；膠序德義之基，空盈牧豎之跡；城隍嚴固之重，闕磚石之功；墉構顯望之要，少樓榭之飾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000038",
    "sentence": "加以風雨稍侵，漸致虧墜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000039",
    "sentence": "非所謂追隆堂構，儀刑萬國者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000040",
    "sentence": "伏聞朝議以高祖大造區夏，道侔姬文，提記明堂，式配上帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000041",
    "sentence": "今若基址不修，乃同丘畎，即使高皇神享，闕於國陽，宗事之典，有聲無實。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000042",
    "sentence": "此臣子所以匪寧，億兆所以佇望也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000043",
    "sentence": "臣又聞官方授能，所以任事，事既任矣，酬之以祿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000044",
    "sentence": "如此則上無曠官之譏，下絕尸素之謗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000045",
    "sentence": "今國子雖有學官之名，無教授之實，何異兔絲燕麥，南箕北斗哉？",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000046",
    "sentence": "昔劉向有言，王者宜興辟雍、陳禮樂以風天下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000047",
    "sentence": "夫禮樂所以養人，刑法所以殺人，而有司勤勤，請定刑法，至於禮樂，則曰未敢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000048",
    "sentence": "是敢於殺人，不敢於養人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000049",
    "sentence": "臣以為當今四海清平，九服寧宴，經國要重，理應先榮，脫復稽延，則劉向之言徵矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000050",
    "sentence": "但事不兩興，須有進退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000051",
    "sentence": "以臣愚量，宜罷尚方雕靡之作，頗省永寧土木之功，並減瑤光材瓦之力，兼分石窟鐫琢之勞，及諸事役非世急者，三時農隙，修此數條。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000052",
    "sentence": "使辟雍之禮，蔚爾而復興；諷誦之音，煥然而更作，美榭高墉嚴壯於外，槐宮棘寺顯麗於中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000053",
    "sentence": "更明古今，重遵鄉飲，敦進郡學，精課經業，如此則元、凱可得之於上序，遊、夏可致之於下國，豈不休歟！",
    "entities": [
      {
        "text": "重遵鄉",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "敦進郡",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000054",
    "sentence": "靈太後令曰：「配饗大禮，為國之本，此以戎馬在郊，未遑修繕。今四表晏寧，當勅有司，別議經始。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000055",
    "sentence": "累遷太常卿、中書監，攝國子祭酒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000056",
    "sentence": "是時朝臣多守一職，帶領二官甚少，卲頓居三職，並是文學之首，當世榮之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000057",
    "sentence": "文宣幸晉陽，路中頻有甘露之瑞，朝臣皆作《甘露頌》，尚書符令卲為之序。",
    "entities": [
      {
        "text": "《甘露頌》",
        "label": "TITLE",
        "start": 19,
        "end": 24
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000058",
    "sentence": "及文宣皇帝崩，凶禮多見訊訪，勑撰哀策。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000059",
    "sentence": "後授特進，卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000060",
    "sentence": "卲率情簡素，內行修謹，兄弟親姻之間，稱為雍睦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000061",
    "sentence": "博覽墳籍，無不通曉，晚年尤以《五經》章句為意，窮其指要。",
    "entities": [
      {
        "text": "《五經》",
        "label": "TITLE",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000062",
    "sentence": "吉兇禮儀，公私諮稟，質疑去惑，為世指南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000063",
    "sentence": "每公卿會議，事關典故，卲援筆立成，證引該洽。",
    "entities": [
      {
        "text": "事關",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000064",
    "sentence": "帝命朝章，敢定俄頃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000065",
    "sentence": "詞致宏遠，獨步當時。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000066",
    "sentence": "與濟陰溫子升為文士之冠，世論謂之溫、邢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000067",
    "sentence": "鉅鹿魏收，雖天才艷發，而年事在二人之後，故子升死後，方稱邢、魏焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000068",
    "sentence": "雖望實兼重，不以才位傲物。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000069",
    "sentence": "脫略簡易，不修威儀，車服器用，充事而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000070",
    "sentence": "有齋不居，坐臥恒在一小屋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000071",
    "sentence": "果餌之屬，或置之梁上，賓至，下而共噉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000072",
    "sentence": "天姿質素，特安異同，士無賢愚，皆能顧接，對客或解衣覓蝨，且與劇談。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000073",
    "sentence": "有書甚多，而不甚讐校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000074",
    "sentence": "見人校書，常笑曰：「何愚之甚，天下書至死讀不可遍，焉能復校此。且誤書思之，更是一適。」妻弟李季節，才學之士，謂子才曰：「世間人多不聰明，思誤書何由能得。」子才曰：「若思不能得，便不勞讀書。」與婦甚疏，未嘗內宿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000075",
    "sentence": "自云嘗晝入內閤，為狗所吠，言畢便撫掌大笑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000076",
    "sentence": "性好談賞，不能閑獨，公事歸休，恒須賓客自伴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000077",
    "sentence": "事寡嫂甚謹，養孤子恕，慈受特深。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000078",
    "sentence": "在兗州，有都信云恕疾，便憂之，廢寢食，顏色貶損。",
    "entities": [
      {
        "text": "在兗州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_036_000079",
    "sentence": "及卒，人士為之傷心，痛悼雖甚，竟不再哭，賓客弔慰，抆淚而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000080",
    "sentence": "其高情達識，開遣滯累，東門吳以還，所未有也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000081",
    "sentence": "有集三十卷，見行於世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000082",
    "sentence": "子大寶，有文情。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000083",
    "sentence": "孽子大德、大道，略不識字焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000084",
    "sentence": "論曰：子才少有盛名，鼓動京洛，文宗學府，獨秀當年，舉必任真，情無飾智，疏通簡易，罕見其人，足為一代之模楷也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000085",
    "sentence": "及明崔甗之謗言，執侯景之奸使，昔人稱孟軻為勇，于文簡公見之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000086",
    "sentence": "唯嘗短崔暹，頗為累德。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000087",
    "sentence": "阮籍未嘗品藻人物，斯亦良有以焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_036_000088",
    "sentence": "校",
    "entities": []
  },
