      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000062",
    "sentence": "辛術謂曰：「公旣萬里歸誠，主上虛心相待，何為作此術？」法和手持香爐，步從路車，至於館。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000063",
    "sentence": "明日引見，給通幰油絡網車，伏身百人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000064",
    "sentence": "詣闕通名，不稱官爵，不稱臣，但云荊山居士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000065",
    "sentence": "文宣宴法和及其徒屬於昭陽殿，賜法和錢百萬、物千段、甲第一區、田一百頃、奴婢二百人，生資什物稱是，宋莅千段，其餘儀同、刺史以下各有差。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 58,
        "end": 60
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000066",
    "sentence": "法和所得奴婢，盡免之，曰：「各隨緣去。」錢帛散施，一日便盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000067",
    "sentence": "以官所賜宅營佛寺，自居一房，與凡人無異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000068",
    "sentence": "三年間再為太尉，世猶謂之居士。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000069",
    "sentence": "無疾而告弟子死期，至時，燒香禮佛，坐繩床而終。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000070",
    "sentence": "浴訖將斂，屍小，縮止三尺許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000071",
    "sentence": "文宣令開棺視之，空棺而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000072",
    "sentence": "法和書其所居壁而塗之，及剝落，有文曰：「十年天子為尚可，百日天子急如火，周年天子遞代坐。」又曰：「一母生三天，兩天共五年。」說者以為婁太后生三天子，自孝昭卽位，至武成傳位後主，共五年焉。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 20,
        "end": 22
      },
      {
        "text": "五年",
        "label": "TME",
        "start": 58,
        "end": 60
      },
      {
        "text": "五年",
        "label": "TME",
        "start": 89,
        "end": 91
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000073",
    "sentence": "法和在荊郢，有少姬，年可二十餘，自稱越姥，身披法服，不嫁，恒隨法和東西。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000074",
    "sentence": "或與其私通十有餘年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000075",
    "sentence": "今者賜棄，別更他淫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000076",
    "sentence": "有司考驗並實。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000077",
    "sentence": "越姥因爾改適，生子數人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000078",
    "sentence": "王琳",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000079",
    "sentence": "王琳，字子珩，會稽山陰人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000080",
    "sentence": "父顯嗣，梁湘東王國常侍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000081",
    "sentence": "琳本兵家，元帝居藩，琳姊妹並入後庭見幸，琳由此未弱冠得在左右。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000082",
    "sentence": "少好武，遂為將帥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000083",
    "sentence": "太清二年 ，侯景渡江，遣琳獻米萬石。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000084",
    "sentence": "未至，都城陷，乃中江沉米，輕舸還荊州。",
    "entities": [
      {
        "text": "都城",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "輕舸還荊州",
        "label": "LOC",
        "start": 13,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000085",
    "sentence": "稍遷岳陽內史，以軍功封建寧縣侯。",
    "entities": [
      {
        "text": "以軍功封建寧縣",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000086",
    "sentence": "侯景遣將宋子仙據郢州，琳攻剋之，擒子仙。",
    "entities": [
      {
        "text": "將宋子仙據郢州",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000087",
    "sentence": "又隨王僧辯破景。",
    "entities": [
      {
        "text": "王僧辯",
        "label": "PER",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000088",
    "sentence": "後拜湘州刺史。",
    "entities": [
      {
        "text": "後拜湘州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000089",
    "sentence": "琳果勁絕人，又能傾身下士，所得賞物，不以入家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000090",
    "sentence": "麾下萬人，多是江淮羣盜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000091",
    "sentence": "平景之勛，與杜龕俱為第一，恃寵縱暴於建業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000092",
    "sentence": "王僧辯禁之不可，懼將為亂，啟請誅之。",
    "entities": [
      {
        "text": "王僧辯",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000093",
    "sentence": "琳亦疑禍，令長史陸納率部曲前赴湘州，身徑上江陵。",
    "entities": [
      {
        "text": "率部曲前赴湘州",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000094",
    "sentence": "將行，謂納等曰：「吾若不返，子將安之？」咸曰：「請死相報。」泣而別。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000095",
    "sentence": "及至，帝以下吏，而廷尉卿黃羅漢、太府卿張載宣喻琳軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000096",
    "sentence": "陸納等及軍人並哭對使者，莫肯受命，乃報黃羅漢，殺張載。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000097",
    "sentence": "載性深刻，為帝所信，荊州疾之如仇，故納等因人之欲，抽腸系馬腳，使繞而走，腸盡氣絕，又臠割備五刑而斬之。",
    "entities": [
      {
        "text": "荊州",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000098",
    "sentence": "梁元遣王僧辯討納，納等敗走長沙。",
    "entities": [
      {
        "text": "王僧辯",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000099",
    "sentence": "是時湘州未平，武陵王兵又甚盛，江陵公私恐懼，人有異圖。",
    "entities": [
      {
        "text": "是時湘州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000100",
    "sentence": "納啟申琳罪，請復本位，永為奴婢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000101",
    "sentence": "梁元乃鎖琳送長沙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000102",
    "sentence": "時納兵出方戰，會琳至，僧辯升諸樓車以示之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000103",
    "sentence": "納等投戈俱拜，舉軍皆哭，曰：「乞王郎入城，卽出。」及放琳入，納等乃降，湘州平。",
    "entities": [
      {
        "text": "乞王郎入城",
        "label": "LOC",
        "start": 15,
        "end": 20
      },
      {
        "text": "湘州",
        "label": "LOC",
        "start": 35,
        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000104",
    "sentence": "仍復本位，使琳拒蕭紀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000105",
    "sentence": "紀平，授衡州刺史。",
    "entities": [
      {
        "text": "授衡州",
        "label": "LOC",
        "start": 3,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000106",
    "sentence": "梁元性多忌，以琳所部甚衆，又得衆心，故出之嶺外，又受都督、廣州刺史。",
    "entities": [
      {
        "text": "廣州",
        "label": "LOC",
        "start": 29,
        "end": 31
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000107",
    "sentence": "其友主書李膺，帝所任遇，琳告之曰：「琳蒙拔擢，常欲畢命以報國恩。今天下未平，遷琳嶺外，如有萬一不虞，安得琳力？忖官正疑琳耳。琳分望有限，可得與官爭為帝乎？何不以琳為雍州刺史，使鎮武寧，琳自放兵作田，為國禦捍。若警急，動靜相知。孰若遠棄嶺南，相去萬里，一日有變，將欲如何？琳非願長坐荊南，正以國計如此耳。」膺然其言，不敢啟，故遂率其衆鎮嶺南。",
    "entities": [
      {
        "text": "何不以琳為雍州",
        "label": "LOC",
        "start": 77,
        "end": 84
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 84,
        "end": 86
      },
      {
        "text": "使鎮",
        "label": "LOC",
        "start": 87,
        "end": 89
      },
      {
        "text": "故遂率其衆鎮",
        "label": "LOC",
        "start": 161,
        "end": 167
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000108",
    "sentence": "梁元為魏圍逼，乃徵琳赴援，除湘州刺史。",
    "entities": [
      {
        "text": "除湘州",
        "label": "LOC",
        "start": 13,
        "end": 16
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000109",
    "sentence": "琳師次長沙，知魏平江陵，已立梁王察，乃為梁元舉哀，三軍縞素。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000110",
    "sentence": "遣別將侯平率舟師攻梁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000111",
    "sentence": "琳屯兵長沙，傳檄諸方，為進趨之計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000112",
    "sentence": "時長沙藩王蕭韶及上遊諸將推琳主盟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000113",
    "sentence": "侯平雖不能渡江，頻破梁軍，又以琳兵威不接，翻更不受指麾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000114",
    "sentence": "琳遣將討之，不克，又師老兵疲不能進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000115",
    "sentence": "乃遣使奉表詣齊，並獻馴象；又使獻款於魏，求其妻子；亦稱臣於梁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000116",
    "sentence": "陳霸先旣殺王僧辯，推立敬帝，以侍中司空徵。",
    "entities": [
      {
        "text": "陳霸先",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "王僧辯",
        "label": "PER",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000117",
    "sentence": "琳不從命，乃大營樓艦，將圖義舉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000118",
    "sentence": "琳將帥各乘一艦，每行，戰艦以千數，以「野豬」為名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000119",
    "sentence": "陳武帝遣將侯安都、周文育等誅琳，仍受梁禪。",
    "entities": [
      {
        "text": "侯安都",
        "label": "PER",
        "start": 5,
        "end": 8
      },
      {
        "text": "周文育",
        "label": "PER",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000120",
    "sentence": "安都嘆曰：「我其敗乎，師無名矣。」逆戰於沌口，琳乘平肩輿，執鉞而麾之，禽安都、文育，其餘無所漏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000121",
    "sentence": "唯以周鐵虎一人背恩，斬之。",
    "entities": [
      {
        "text": "周鐵虎",
        "label": "PER",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000122",
    "sentence": "鎖安都、文育置琳所坐艦中，令一閹豎監守之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000123",
    "sentence": "琳乃移湘州軍府就郢城，帶甲十萬，練兵於白水浦。",
    "entities": [
      {
        "text": "琳乃移湘州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "軍府就郢城",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000124",
    "sentence": "琳巡軍而言曰：「可以為勤王之師矣，溫太真何人哉！」江南渠帥熊曇朗、周迪懷貳，琳遣李孝欽、樊猛與余孝頃同討之。",
    "entities": [
      {
        "text": "余孝頃",
        "label": "PER",
        "start": 47,
        "end": 50
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000125",
    "sentence": "三將軍敗，並為敵所囚。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000126",
    "sentence": "安都、文育等盡逃還建業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000127",
    "sentence": "初，魏剋江陵之時，永嘉王莊年甫七歲，逃匿人家，後琳迎還湘中，衛送東下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000128",
    "sentence": "及敬帝立，出質於齊，請納莊為梁主。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000129",
    "sentence": "文宣遣兵援送，仍遣兼中書令李騊駼冊拜琳為梁丞相、都督中外諸軍、錄尚書事。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 21,
        "end": 23
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000130",
    "sentence": "舍人羊愨、遊詮之等齎璽書江表宣勞，自琳以下皆有頒賜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000131",
    "sentence": "琳乃遣兄子叔寶率所部十州刺史子弟赴鄴，奉莊纂梁祚於郢州。",
    "entities": [
      {
        "text": "叔寶率所部十州",
        "label": "LOC",
        "start": 5,
        "end": 12
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "莊纂梁祚於郢州",
        "label": "LOC",
        "start": 20,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000132",
    "sentence": "莊授琳侍中、使持節、大將軍、中書監，改封安城郡公，其餘並依齊朝前命。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 10,
        "end": 13
      },
      {
        "text": "改封安城郡",
        "label": "LOC",
        "start": 18,
        "end": 23
      },
      {
        "text": "齊朝",
        "label": "ORG",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000133",
    "sentence": "及陳霸先卽位，琳乃輔莊次於濡須口。",
    "entities": [
      {
        "text": "陳霸先",
        "label": "PER",
        "start": 1,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000134",
    "sentence": "齊遣揚州道行臺慕容儼率衆臨江，為其聲援。",
    "entities": [
      {
        "text": "齊遣揚州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "慕容儼",
        "label": "PER",
        "start": 7,
