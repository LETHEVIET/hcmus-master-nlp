      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000135",
    "sentence": "陳遣安州刺史吳明徹江中夜上，將襲湓城。",
    "entities": [
      {
        "text": "陳遣安州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "吳明徹",
        "label": "PER",
        "start": 6,
        "end": 9
      },
      {
        "text": "將襲湓城",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000136",
    "sentence": "琳遣巴陵太守任忠大敗之，明徹僅以身免。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000137",
    "sentence": "琳兵因東下，陳遣司空侯安都等拒之。",
    "entities": [
      {
        "text": "侯安都",
        "label": "PER",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000138",
    "sentence": "侯瑱等以琳軍方盛，引軍入蕪湖避之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000139",
    "sentence": "時西南風忽至，琳謂得天道，將直取揚州。",
    "entities": [
      {
        "text": "將直取揚州",
        "label": "LOC",
        "start": 13,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000140",
    "sentence": "侯瑱等徐出蕪湖，躡其後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000141",
    "sentence": "比及兵交，西南風翻為瑱用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000142",
    "sentence": "琳兵放火燧以擲船者，皆反燒其船。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000143",
    "sentence": "琳船艦潰亂，兵士投水死十二三，其餘皆棄船上岸，為陳軍所殺殆盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000144",
    "sentence": "初琳命左長史袁泌、禦史中丞劉仲威同典兵侍衛莊，及軍敗，泌遂降陳，仲威以莊投歷陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000145",
    "sentence": "琳尋與莊同降鄴都。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000146",
    "sentence": "孝昭帝遣琳出合肥，鳩集義故，更圖進取。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000147",
    "sentence": "琳乃繕艦，分遣招募，淮南傖楚，皆願戮力。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000148",
    "sentence": "陳合州刺史裴景暉，琳兄珉之婿也，請以私屬導引齊師。",
    "entities": [
      {
        "text": "陳合州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000149",
    "sentence": "孝昭委琳與行臺左丞盧潛率兵應赴，沉吟不決。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000150",
    "sentence": "景暉懼事泄，挺身歸齊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000151",
    "sentence": "孝昭賜琳璽書，令鎮壽陽，其部下將帥悉聽以行，乃除琳驃騎大將軍、開府儀同三司、揚州刺史，封會稽郡公，又增兵仗，兼給鐃吹。",
    "entities": [
      {
        "text": "令鎮",
        "label": "LOC",
        "start": 7,
        "end": 9
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 27,
        "end": 30
      },
      {
        "text": "揚州",
        "label": "LOC",
        "start": 38,
        "end": 40
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 40,
        "end": 42
      },
      {
        "text": "封會稽郡",
        "label": "LOC",
        "start": 43,
        "end": 47
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000152",
    "sentence": "琳水陸戒嚴，將觀釁而動。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000153",
    "sentence": "屬陳氏結好於齊，使琳更聽後圖。",
    "entities": [
      {
        "text": "陳氏",
        "label": "ORG",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000154",
    "sentence": "琳在壽陽，與行臺尚書盧潛不協，更相是非，被召還鄴，武成弘而不問。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000155",
    "sentence": "除滄州刺史，後以琳為特進、侍中。",
    "entities": [
      {
        "text": "除滄州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000156",
    "sentence": "所居屋脊無故剝破，出赤蛆數升，落地化為血，蠕蠕而動。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000157",
    "sentence": "又有龍出於門外之地，雲霧起，晝晦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000158",
    "sentence": "會陳將吳明徹來寇，帝勑領軍將軍尉破胡等出援秦州，令琳共為經略。",
    "entities": [
      {
        "text": "吳明徹",
        "label": "PER",
        "start": 3,
        "end": 6
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "破胡等出援秦州",
        "label": "LOC",
        "start": 16,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000159",
    "sentence": "琳謂所親曰：「今太歲在東南，歲星居鬥牛分，太白已高，皆利為客，我將有喪。」又謂破胡曰：「吳兵甚銳，宜長策制之，慎勿輕鬬。」破胡不從，遂戰，軍大敗，琳單馬突圍，僅而獲免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000160",
    "sentence": "還至彭城，帝令便赴壽陽，並許召募。",
    "entities": [
      {
        "text": "還至彭城",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000161",
    "sentence": "又進封琳巴陵郡王。",
    "entities": [
      {
        "text": "又進封琳巴陵郡",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000162",
    "sentence": "陳將吳明徹進兵圍之，堰淝水灌城，而皮景和等屯於淮西，竟不赴救。",
    "entities": [
      {
        "text": "吳明徹",
        "label": "PER",
        "start": 2,
        "end": 5
      },
      {
        "text": "堰淝水灌城",
        "label": "LOC",
        "start": 10,
        "end": 15
      },
      {
        "text": "皮景和",
        "label": "PER",
        "start": 17,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000163",
    "sentence": "明徹晝夜攻擊，城內水氣轉侵，人皆患腫，死病相枕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000164",
    "sentence": "從七月至十月，城陷被執，百姓泣而從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000165",
    "sentence": "吳明徹恐其為變，殺之城東北二十里，時年四十八，哭者聲如雷。",
    "entities": [
      {
        "text": "吳明徹",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "殺之城",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000166",
    "sentence": "有一叟以酒脯來酹，盡哀，收其血，懷之而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000167",
    "sentence": "傳首建康，懸之於市。",
    "entities": [
      {
        "text": "建康",
        "label": "LOC",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000168",
    "sentence": "琳故吏梁驃騎府倉曹參軍朱瑒致書陳尚書僕射徐陵求琳首曰：",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000169",
    "sentence": "竊以朝市遷貿，傳骨梗之風，歷運推移，表忠貞之跡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000170",
    "sentence": "故典午將滅，徐廣為晉家遺老；當塗已謝，馬孚稱魏室忠臣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000171",
    "sentence": "用能播美於前書，垂名於後世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000172",
    "sentence": "梁故建寧公琳，洛濱餘胄，沂州舊族，立功代邸，效績中朝，當離亂之辰，總方伯之任。",
    "entities": [
      {
        "text": "沂州",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000173",
    "sentence": "爾乃輕躬殉主，以身許國，實追蹤於往彥，信踵武於前修。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000174",
    "sentence": "而天厭梁德，上思匡繼，徒蘊包胥之念，終遘萇弘之眚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000175",
    "sentence": "洎王業光啟，鼎祚有歸，於是遠跡山東，寄命河北。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000176",
    "sentence": "雖輕旅臣之歎，猶懷客卿之禮，感茲知己，忘此捐軀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000177",
    "sentence": "至使身沒九泉，頭行萬里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000178",
    "sentence": "誠復馬革裹死，遂其生平之志；原野暴骸，會彼人臣之節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000179",
    "sentence": "然身首異處，有足悲者；封樹靡卜，良可愴焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000180",
    "sentence": "瑒早簉末席，降薛君之吐握，荷魏公之知遇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000181",
    "sentence": "是用霑巾雨袂，痛可識之顏；回腸疾首，切猶生之面。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000182",
    "sentence": "伏惟聖恩博厚，明詔爰發，赦王經之哭，許田橫之葬，瑒雖芻賤，竊亦有心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000183",
    "sentence": "琳經蒞壽陽，頗存遺愛；曾遊江右，非無餘德。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000184",
    "sentence": "比肩東閤之吏，繼踵西園之賓，願歸彼境，還修窀穸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000185",
    "sentence": "庶孤墳旣築，或飛銜土之燕；豐碑式樹，時留墮淚之人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000186",
    "sentence": "近故舊王綰等已有論牒，仰蒙制議，不遂所陳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000187",
    "sentence": "昔廉公告逝，卽淝川而建塋域；孫叔云亡，仍芍陂而植楸槚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000188",
    "sentence": "由此言之，抑有其例。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000189",
    "sentence": "不使壽春城下，唯傳報葛之人；滄洲島上，獨有悲田之客。",
    "entities": [
      {
        "text": "不使壽春城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000190",
    "sentence": "昧死陳祈，伏待刑憲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000191",
    "sentence": "陵嘉其志節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000192",
    "sentence": "又明徹亦數夢琳求首，並為啟陳主而許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000193",
    "sentence": "仍與開府儀同主簿劉韶慧等持其首還於淮南，權瘞八公山側，義故會葬者數千人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000194",
    "sentence": "瑒等乃間道北歸，別議迎接。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000195",
    "sentence": "尋有揚州人茅知勝等五人密送葬柩達於鄴。",
    "entities": [
      {
        "text": "尋有揚州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000196",
    "sentence": "贈十五州諸軍事、揚州刺史、侍中、特進、開府、錄尚書事，諡曰忠武王，葬給轀輬車。",
    "entities": [
      {
        "text": "贈十五州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "揚州",
        "label": "LOC",
        "start": 8,
        "end": 10
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000197",
    "sentence": "琳體貌閑雅，立髮委地，喜怒不形於色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000198",
    "sentence": "雖無學業，而強記內敏，軍府佐吏千數，皆識其姓名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000199",
    "sentence": "刑罰不濫，輕財愛士，得將卒之心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000200",
    "sentence": "少任將帥，屢經喪亂，雅有忠義之節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000201",
    "sentence": "雖本圖不遂，鄴人亦以此重之，待遇甚厚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000202",
    "sentence": "及敗，為陳軍所執，吳明徹欲全之，而其下將領多琳故吏，爭來致請，並相資給，明徹由此忌之，故及於難。",
    "entities": [
      {
        "text": "吳明徹",
        "label": "PER",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000203",
    "sentence": "當時田夫野老，知與不知，莫不為之歔欷流泣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000204",
    "sentence": "觀其誠信感物，雖李將軍之恂恂善誘，殆無以加焉。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000205",
    "sentence": "琳十七子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000206",
    "sentence": "長子敬，在齊襲王爵，武平末，通直常侍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000207",
    "sentence": "第九子衍，隋開皇中開府儀同三司，大業初，卒於渝州刺史。",
    "entities": [
      {
        "text": "卒於渝州",
        "label": "LOC",
        "start": 20,
        "end": 24
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000208",
    "sentence": "[ 1 ]",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000209",
    "sentence": "注",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000210",
    "sentence": "↑ 全文以中華書局、一九七二年十一月、第一版《北齊書》為本校。",
    "entities": [
      {
