      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000002",
    "sentence": "陸法和，不知何許人也。",
    "entities": [
      {
        "text": "陸法和",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000003",
    "sentence": "隱於江陵百里洲，衣食居處，一與苦行沙門同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000004",
    "sentence": "耆老自幼見之，容色常不定，人莫能測也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000005",
    "sentence": "或謂自出嵩高，遍遊遐邇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000006",
    "sentence": "旣入荊州汶陽郡高安縣之紫石山，無故捨所居山。",
    "entities": [
      {
        "text": "旣入荊州汶陽郡",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "高安縣",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000007",
    "sentence": "俄有蠻賊文道期之亂，時人以為預見萌兆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000008",
    "sentence": "及侯景始告降於梁，法和謂南郡朱元英曰：「貧道共檀越擊侯景去。」元英曰：「侯景為國立效，師云擊之，何也？」法和曰：「正自如此。」及景渡江，法和時在青谿山，元英往問曰：「景今圍城，其事云何？」法和曰：「凡人取果，宜待熟時，不撩自落。檀越但待侯景熟，何勞問也。」固問之，乃曰：「亦克亦不克。」",
    "entities": [
      {
        "text": "法和謂南郡",
        "label": "LOC",
        "start": 9,
        "end": 14
      },
      {
        "text": "景今圍城",
        "label": "LOC",
        "start": 83,
        "end": 87
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000009",
    "sentence": "景遣將任約擊梁湘東王於江陵，法和乃詣湘東乞征約，召諸蠻弟子八百人在江津，二日便發。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000010",
    "sentence": "湘東遣胡僧佑領千餘人與同行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000011",
    "sentence": "法和登艦大笑曰：「無量兵馬。」江陵多神祠，人俗恒所祈禱，自法和軍出，無復一騐，人以為神皆從行故也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000012",
    "sentence": "至赤沙湖，與約相對，法和乘輕船，不介胄，沿流而下，去約軍一里乃還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000013",
    "sentence": "謂將士曰：「聊觀彼龍睡不動，吾軍之龍甚自踴躍，卽攻之。若得待明日，當不損客主一人而破賊，然有惡處。」遂縱火舫於前，而逆風不便，法和執白羽麾風，風勢卽返。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000014",
    "sentence": "約衆皆見梁兵步於水上，於是大潰，皆投水而死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000015",
    "sentence": "約逃竄不知所之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000016",
    "sentence": "法和曰：「明日午時當得。」及期而未得，人問之，法和曰：「吾前於此洲水幹時建一剎，語檀越等，此雖為剎，實是賊標，今何不向標下求賊也？」如其言，果於水中見約抱剎仰頭，裁出鼻，遂擒之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000017",
    "sentence": "約言求就師目前死，法和曰：「檀越有相，必不兵死，且於王有緣，決無他慮，王於後當得檀越力耳。」湘東果釋用為郡守。",
    "entities": [
      {
        "text": "湘東果釋用為郡",
        "label": "LOC",
        "start": 46,
        "end": 53
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000018",
    "sentence": "及魏圍江陵，約以兵赴救，力戰焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000019",
    "sentence": "法和旣平約，往進見王僧辯於巴陵，謂曰：「貧道已斷侯景一臂，其更何能為，檀越宜卽遂取。」乃請還，謂湘東王曰：「侯景自然平矣，無足可慮。蜀賊將至，法和請守巫峽待之。」乃總諸軍而往，親運石以填江。",
    "entities": [
      {
        "text": "王僧辯",
        "label": "PER",
        "start": 9,
        "end": 12
      },
      {
        "text": "蜀",
        "label": "ORG",
        "start": 66,
        "end": 67
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000020",
    "sentence": "三日，水遂分流，橫之以鐵鎖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000021",
    "sentence": "武陵王紀果遣蜀兵來渡，峽口勢蹙，進退不可。",
    "entities": [
      {
        "text": "武陵王紀",
        "label": "PER",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000022",
    "sentence": "王琳與法和經略，一戰而殄之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000023",
    "sentence": "軍次白帝，謂人曰：「諸葛孔明可謂名將，吾自見之。此城旁有其埋弩箭鏃一斛許。」因插表令掘之，如其言。",
    "entities": [
      {
        "text": "此城",
        "label": "LOC",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000024",
    "sentence": "又嘗至襄陽城北大樹下，畫地方二尺，令弟子掘之，得一龜，長尺半，以杖叩之曰：「汝欲出不能得，已數百歲，不逢我者，豈見天日乎？」為授三歸，龜乃入草。",
    "entities": [
      {
        "text": "又嘗至襄陽城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000025",
    "sentence": "初，八疊山多惡疾人，法和為采藥療之，不過三服皆差，卽求為弟子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000026",
    "sentence": "山中毒蟲猛獸，法和授其禁戒，不復噬螫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000027",
    "sentence": "所泊江湖，必於峰側結表，云「此處放生。」漁者皆無所得，才有少獲，輒有大風雷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000028",
    "sentence": "船人懼而放之，風雨乃定。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000029",
    "sentence": "晚雖將兵，猶禁諸軍漁捕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000030",
    "sentence": "有竊違者，中夜猛獸必來欲噬之，或亡其船纜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000031",
    "sentence": "有小弟子戲截蛇頭，來詣法和。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000032",
    "sentence": "法和曰：「汝何意殺蛇？」因指以示之，弟子乃見蛇頭齚褲襠而不落。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000033",
    "sentence": "法和使懺悔，為蛇作功德。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000034",
    "sentence": "又有人以牛試刀，一下而頭斷，來詣法和。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000035",
    "sentence": "法和曰：「有一斷頭牛，就卿徵命殊急，若不為作功德，一月內報至。」其人弗信，少日果死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000036",
    "sentence": "法和又為人置宅圖墓，以避禍求福。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000037",
    "sentence": "嘗謂人曰：「勿繫馬於碓。」其人行過鄉曲，門側有碓，因繫馬於其柱。",
    "entities": [
      {
        "text": "其人行過鄉",
        "label": "LOC",
        "start": 13,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000038",
    "sentence": "入門中，意法和戒，走出將解之，馬已斃矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000039",
    "sentence": "梁元帝以法和為都督、郢州刺史，封江乘縣公。",
    "entities": [
      {
        "text": "郢州",
        "label": "LOC",
        "start": 10,
        "end": 12
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "封江乘縣",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000040",
    "sentence": "法和不稱臣，其啟文朱印名上，自稱司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000041",
    "sentence": "梁元帝謂其僕射王褒曰：「我未嘗有意用陸為三公，而自稱何也？」褒曰：「彼旣以道術自命，容是先知。」梁元帝以法和功業稍重，遂就加司徒，都督、刺史如故。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 68,
        "end": 70
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000042",
    "sentence": "部曲數千人，通呼為弟子，唯以道術為化，不以法獄加人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000043",
    "sentence": "又列肆之內，不立市丞牧佐之法，無人領受，但以空檻籥在道間，上開一孔受錢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000044",
    "sentence": "賈客店人隨貨多少，計其估限，自委檻中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000045",
    "sentence": "行掌之司，夕方開取，條其孔目，輸之於庫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000046",
    "sentence": "又法和平常言若不出口，時有所論，則雄辯無敵，然猶帶蠻音。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000047",
    "sentence": "善為攻戰具。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000048",
    "sentence": "在江夏，大聚兵艦，欲襲襄陽而入武關。",
    "entities": [
      {
        "text": "襲襄陽而入武關",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000049",
    "sentence": "梁元帝使止之，法和曰：「法和是求佛之人，尚不希釋梵天王坐處，豈規王位？但於空王佛所與主上有香火因緣，見主人應有報至，故求援耳。今旣被疑，是業定不可改也。」於是設供食，具大槌薄餅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000050",
    "sentence": "及魏舉兵，法和自郢入漢口，將赴江陵。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 10,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000051",
    "sentence": "梁元帝使人逆之曰：「此自能破賊，但鎮郢州，不須動也。」法和乃還州，堊其城門，著粗白布衫、布袴、邪巾，大繩束腰，坐葦席，終日乃脫之。",
    "entities": [
      {
        "text": "但鎮郢州",
        "label": "LOC",
        "start": 16,
        "end": 20
      },
      {
        "text": "法和乃還州",
        "label": "LOC",
        "start": 27,
        "end": 32
      },
      {
        "text": "堊其城",
        "label": "LOC",
        "start": 33,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000052",
    "sentence": "及聞梁元帝敗滅，復取前凶服著之，哭泣受弔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_032_000053",
    "sentence": "梁人入魏，果見槌餅焉。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 3,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000054",
    "sentence": "法和始於百里洲造壽王寺，旣架佛殿，更截梁柱，曰：「後四十許年佛法當遭雷電，此寺幽僻，可以免難。」及魏平荊州，宮室焚燼，總管欲發取壽王佛殿，嫌其材短，乃停。",
    "entities": [
      {
        "text": "及魏平荊州",
        "label": "LOC",
        "start": 48,
        "end": 53
      }
    ]
  },
  {
    "sentence_id": "HCH_004_032_000055",
    "sentence": "後周氏滅佛法，此寺隔在陳境，故不及難。",
    "entities": [
