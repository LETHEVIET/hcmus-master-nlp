[
  {
    "sentence_id": "HCH_004_034_000001",
    "sentence": "楊愔",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000002",
    "sentence": "楊愔，字遵彥，小名秦王，弘農華陰人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000003",
    "sentence": "父津，魏時累為司空侍中。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 3,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000004",
    "sentence": "愔兒童時，口若不能言，而風度深敏，出入門閭，未嘗戲弄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000005",
    "sentence": "六歲學史書，十一受《詩》《易》，好《左氏春秋》。",
    "entities": [
      {
        "text": "《詩》",
        "label": "TITLE",
        "start": 9,
        "end": 12
      },
      {
        "text": "《易》",
        "label": "TITLE",
        "start": 12,
        "end": 15
      },
      {
        "text": "《左氏春秋》",
        "label": "TITLE",
        "start": 17,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000006",
    "sentence": "幼喪母，曾詣舅源子恭，子恭與之飲，問讀何書，曰：「誦《詩》。」子恭曰：「誦至《渭陽》未邪？」愔便號泣感噎，子恭亦對之歔欷，遂為之罷酒。",
    "entities": [
      {
        "text": "源子恭",
        "label": "PER",
        "start": 7,
        "end": 10
      },
      {
        "text": "《詩》",
        "label": "TITLE",
        "start": 26,
        "end": 29
      },
      {
        "text": "《渭陽》",
        "label": "TITLE",
        "start": 38,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000007",
    "sentence": "子恭後謂津曰：「常謂秦王不甚察慧，從今已後，更欲刮目視之。」愔一門四世同居，家甚隆盛，昆季就學者三十餘人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000008",
    "sentence": "學庭前有柰樹，實落地，群兒咸爭之，愔頹然獨坐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000009",
    "sentence": "其季父暐適入學館，見之大用嗟異，顧謂賓客曰：「此兒恬裕，有我家風。」宅內有茂竹，遂為愔於林邊別葺一室，命獨處其中，常以銅盤具盛饌以飯之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000010",
    "sentence": "因以督厲諸子曰：「汝輩但如遵彥謹慎，自得竹林別室、銅盤重肉之食。」愔從父兄黃門侍郎昱特相器重，曾謂人曰：「此兒駒齒未落，已是我家龍文。更十歲後，當求之千里外。」昱嘗與十餘人賦詩，愔一覽便誦，無所遺失。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 39,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000011",
    "sentence": "及長，能清言，美音制，風神俊悟，容止可觀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000012",
    "sentence": "人士見之，莫不敬異，有識者多以遠大許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000013",
    "sentence": "正光中，隨父之幷州。",
    "entities": [
      {
        "text": "隨父之幷州",
        "label": "LOC",
        "start": 4,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000014",
    "sentence": "性旣恬默，又好山水，遂入晉陽西縣甕山讀書。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000015",
    "sentence": "孝昌初，津為定州刺史，愔亦隨父之職。",
    "entities": [
      {
        "text": "津為定州",
        "label": "LOC",
        "start": 4,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000016",
    "sentence": "以軍功除羽林監，賜爵魏昌男，不拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000017",
    "sentence": "及中山為杜洛周陷，全家被囚縶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000018",
    "sentence": "未幾，洛周滅，又沒葛榮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000019",
    "sentence": "榮欲以女妻之，又逼以偽職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000020",
    "sentence": "愔乃託疾，密含牛血數合，於衆中吐之，仍佯喑不語。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000021",
    "sentence": "榮以為信然，乃止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000022",
    "sentence": "永安初，還洛，拜通直散騎侍郎，時年十八。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000023",
    "sentence": "元顥入洛，時愔從父兄侃為北中郎將，鎮河梁。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000024",
    "sentence": "愔適至侃處，便屬乘輿失守，夜至河。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000025",
    "sentence": "侃雖奉迎車駕北渡，而潛欲南奔，愔固諫止之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000026",
    "sentence": "遂相與扈從達建州。",
    "entities": [
      {
        "text": "相與扈從達建州",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000027",
    "sentence": "除通直散騎常侍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000028",
    "sentence": "愔以世故未夷，志在潛退，乃謝病，與友人中直侍郎河間邢卲隱於嵩山。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000029",
    "sentence": "及莊帝誅尒朱榮，其從兄侃參贊帷幄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000030",
    "sentence": "朝廷以其父津為幷州刺史、北道大行臺，愔隨之任。",
    "entities": [
      {
        "text": "以其父津為幷州",
        "label": "LOC",
        "start": 2,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000031",
    "sentence": "有邯鄲人楊寬者，求義從出藩，愔請津納之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000032",
    "sentence": "俄而孝莊幽崩，愔時適欲還都，行達邯鄲，過楊寬家，為寬所執。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000033",
    "sentence": "至相州，見刺史劉誕，以愔名家盛德，甚相哀念，付長史慕容白澤禁止焉。",
    "entities": [
      {
        "text": "至相州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000034",
    "sentence": "遣隊主鞏榮貴防禁送都。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000035",
    "sentence": "至安陽亭，愔謂榮貴曰：「僕家世忠臣，輸誠魏室，家亡國破，一至於此。雖曰囚虜，復何面目見君父之讐仇！得自縊於一繩，傳首而去，君之惠也。」榮貴深相憐感，遂與俱逃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000036",
    "sentence": "愔乃投高昂兄弟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000037",
    "sentence": "旣潛竄累載，屬神武至信都，遂投刺轅門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000038",
    "sentence": "便蒙引見，贊揚興運，陳訴家禍，言辭哀壯，涕泗橫集，神武為之改容。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000039",
    "sentence": "即署行臺郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000040",
    "sentence": "大軍南攻鄴，歷楊寬村，寬於馬前叩頭請罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000041",
    "sentence": "愔謂曰：「人不識恩義，蓋亦常理，我不恨卿，無遐驚怖。」時鄴未下，神武命愔作祭天文，燎畢而城陷。",
    "entities": [
      {
        "text": "燎畢而城",
        "label": "LOC",
        "start": 41,
        "end": 45
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000042",
    "sentence": "由是轉大行臺右丞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000043",
    "sentence": "于時霸圖草創，軍國務廣，文檄教令，皆自愔及崔㥄出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000044",
    "sentence": "遭離家難，以喪禮自居，所食唯鹽米而已，哀毀骨立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000045",
    "sentence": "神武愍之，恒相開慰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000046",
    "sentence": "及韓陵之戰，愔每陣先登，朋僚咸共怪嘆曰：「楊氏儒生，今遂為武士，仁者必勇，定非虛論。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000047",
    "sentence": "頃之，表請解職還葬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000048",
    "sentence": "一門之內，贈太師、太傅、丞相、大將軍者二人，太尉、錄尚書及中書令者三人，僕射、尚書者五人，刺史、太守者二十餘人。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 15,
        "end": 18
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 26,
        "end": 28
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 39,
        "end": 41
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 45,
        "end": 47
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 48,
        "end": 50
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000049",
    "sentence": "追榮之盛，古今未之有也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000050",
    "sentence": "及喪柩進發，吉凶儀衛亙二十餘里，會葬者將萬人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000051",
    "sentence": "是日隆冬盛寒，風雪嚴厚，愔跣步號哭，見者無不哀之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000052",
    "sentence": "尋徵赴晉陽，仍居本職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000053",
    "sentence": "愔從兄幼卿為岐州刺史，以直言忤旨見誅。",
    "entities": [
      {
        "text": "從兄幼卿為岐州",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000054",
    "sentence": "愔聞之悲懼，因哀感發疾，後取急就雁門溫湯療疾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000055",
    "sentence": "郭秀素害其能，因致書恐之曰：「高王欲送卿於帝所。」仍勸其逃亡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000056",
    "sentence": "愔遂棄衣冠於水濱若自沉者，變易名姓，自稱劉士安，入嵩山，與沙門曇謨徵等居成削迹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000057",
    "sentence": "又潛之光州，因東入田橫島，以講誦為業。",
    "entities": [
      {
        "text": "又潛之光州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000058",
    "sentence": "海隅之士，謂之劉先生。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000059",
    "sentence": "太守王元景陰佑之。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000060",
    "sentence": "神武知愔存，遣愔從兄寶猗賫書慰喻，仍遣光州刺史奚思業令搜訪，以禮發遣。",
    "entities": [
      {
        "text": "仍遣光州",
        "label": "LOC",
        "start": 17,
        "end": 21
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000061",
    "sentence": "神武見之悅，除太原公開府司馬，轉長史，復授大行臺右丞，封華陰縣侯，遷給事黃門侍郎，妻以庶女。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "封華陰縣",
        "label": "LOC",
        "start": 27,
        "end": 31
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 38,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000062",
    "sentence": "又兼散騎常侍，為聘梁使主。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000063",
    "sentence": "至碻磝戍，州內有愔家舊佛寺，入精廬禮拜，見太傅容像，悲感慟哭，嘔血數升，遂發病不成行，輿疾還鄴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000064",
    "sentence": "久之，以本官兼尚書吏部郎中。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000065",
    "sentence": "武定末，以望實之美，超拜吏部尚書，加侍中、衛將軍，侍學典選如故。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000066",
    "sentence": "天保初，以本官領太子少傅，別封陽夏縣男。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "別封陽夏縣",
        "label": "LOC",
        "start": 13,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000067",
    "sentence": "又詔監太史，遷尚書右僕射。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000068",
    "sentence": "尚太原長公主，即魏孝靜後也。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000069",
    "sentence": "會有雉集其舍，又拜開府儀同三司、尚書左僕射，改封華山郡公。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "改封華山郡",
        "label": "LOC",
        "start": 22,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000070",
    "sentence": "九年，徙尚書令，又拜特進、驃騎大將軍。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000071",
    "sentence": "十年，封開封王。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000072",
    "sentence": "文宣之崩，百僚莫有下淚，愔悲不自勝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000073",
    "sentence": "濟南嗣業，任遇益隆，朝章國命，一人而已，推誠體道，時無異議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000074",
    "sentence": "乾明元年二月，為孝昭帝所誅，時年五十。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000075",
    "sentence": "天統末，追贈司空。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000076",
    "sentence": "愔貴公子，早著聲譽，風表鑒裁，為朝野所稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000077",
    "sentence": "家門遇禍，唯有二弟一妹及兄孫女數人，撫養孤幼，慈旨溫顏，咸出人表。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000078",
    "sentence": "重義輕財，前後賜與，多散之親族，羣從弟侄十數人，並待而舉火。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000079",
    "sentence": "頻遭迍厄，冒履艱危，一飧之惠，酬答必重，性命之讐，捨而不問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000080",
    "sentence": "典選二十餘年，獎擢人倫，以為己任，然取士多以言貌，時致謗言，以為愔之用人，似貧士市瓜，取其大者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000081",
    "sentence": "愔聞，不屑焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000082",
    "sentence": "其聰記強識，半面不忘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000083",
    "sentence": "每有所召問，或單稱姓，或單稱名，無有誤者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000084",
    "sentence": "後有選人魯漫漢，自言猥賤，獨不見識。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000085",
    "sentence": "愔曰：「卿前在元子思坊，騎禿尾草驢，經見我不下，以方麴曲鄣面，我何不識卿？」漫漢驚服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000086",
    "sentence": "又調之曰：「名以定體，漫漢果自不虛。」又令吏唱人名，誤以盧士深為士琛，士琛自言，愔曰：「盧郎玉潤，所以從玉。」自尚公主後，衣紫羅袍，金縷大帶。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 57,
        "end": 59
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000087",
    "sentence": "遇李庶，頗以為恥，謂曰：「我此衣服，都是內裁，旣見子將，不能無愧。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000088",
    "sentence": "及居端揆，權綜機衡，千端萬緒，神無滯用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000089",
    "sentence": "自天保五年已後，一人喪德，維持匡救，實有賴焉。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000090",
    "sentence": "每天子臨軒，公卿拜授，施號發令，宣揚詔冊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000091",
    "sentence": "愔辭氣溫辯，神儀秀發，百僚觀聽，莫不悚動。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000092",
    "sentence": "自居大位，門絕私交。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000093",
    "sentence": "輕貨財，重仁義，前後賞賜，積累巨萬，散之九族，架篋之中，唯有書數千卷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000094",
    "sentence": "太保、平原王隆之與愔鄰宅，愔嘗見其門外有富胡數人，謂左右曰：「我門前幸無此物。」性周密畏慎，恒若不足，每聞後命，愀然變色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000095",
    "sentence": "文宣大漸，以常山、長廣二王位地親逼，深以後事為念。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000096",
    "sentence": "愔與尚書左僕射平秦王歸彥、侍中燕子獻、黃門侍郎鄭子默受遺詔輔政，並以二王威望先重，咸有猜忌之心。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000097",
    "sentence": "初在晉陽，以大行在殯，天子諒暗，議令常山王在東館，欲奏之事，皆先諮決。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000098",
    "sentence": "二旬而止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000099",
    "sentence": "仍欲以常山王隨梓宮之鄴，留長廣王鎮晉陽。",
    "entities": [
      {
        "text": "留長廣王鎮",
        "label": "LOC",
        "start": 12,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000100",
    "sentence": "執政復生疑貳，兩王又俱從至于鄴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000101",
    "sentence": "子獻立計，欲處太皇太后於北宮，政歸皇太后。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000102",
    "sentence": "又自天保八年已來，爵賞多濫，至是，愔先自表解其開府封王，諸叨竊恩榮者皆從黜免。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000103",
    "sentence": "由是嬖寵失職之徒，盡歸心二叔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000104",
    "sentence": "高歸彥初雖同德，後尋反動，以疏忌之跡盡告兩王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000105",
    "sentence": "可朱渾天和又每云：「若不誅二王，少主無自安之理。」宋欽道面奏帝，稱二叔威權旣重，宜速去之。",
    "entities": [
      {
        "text": "宋欽道",
        "label": "PER",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000106",
    "sentence": "帝不許曰：「可與令公共詳其事。」愔等議出二王為刺史。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000107",
    "sentence": "以帝仁慈，恐不可所奏，乃通啟皇太后，具述安危。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000108",
    "sentence": "有宮人李昌儀者，北豫州刺史高仲密之妻，坐仲密事入宮，太后以昌儀宗情，甚相昵愛。",
    "entities": [
      {
        "text": "北豫州",
        "label": "LOC",
        "start": 8,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000109",
    "sentence": "太後以啟示之，昌儀密啟太皇太后。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000110",
    "sentence": "愔等又議不可令二王俱出，乃奏以長廣王為大司馬、幷州刺史，常山王為太師、錄尚書事。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 20,
        "end": 22
      },
      {
        "text": "幷州",
        "label": "LOC",
        "start": 23,
        "end": 25
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 25,
        "end": 27
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 36,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000111",
    "sentence": "及二王拜職，於尚書省大會百僚，愔等並將同赴。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000112",
    "sentence": "子默止之，云：「事不可量，不可輕脫。」愔云：「吾等至誠體國，豈有常山拜職，有不赴之理，何為忽有此慮？」長廣旦伏家僮數十人於錄尚書後室，仍與席上勳貴數人相知。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 62,
        "end": 64
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000113",
    "sentence": "並與諸勳胄約，行酒至愔等，我各勸雙杯，彼必致辭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000114",
    "sentence": "我一曰「捉酒」，二曰「捉酒，」三曰「何不捉，」爾輩即捉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000115",
    "sentence": "及宴如之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000116",
    "sentence": "愔大言曰：「諸王構逆，欲殺忠良邪？尊天子，削諸侯，赤心奉國，未應及此。」常山王欲緩之，長廣王曰：「不可。」於是愔及天和、欽道皆被拳杖亂毆擊，頭面血流，各十人持之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000117",
    "sentence": "使薛孤延、康買執子默於尚藥局。",
    "entities": [
      {
        "text": "薛孤延",
        "label": "PER",
        "start": 1,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000118",
    "sentence": "子默曰：「不用智者言，以至於此，豈非命也！」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000119",
    "sentence": "二叔率高歸彥、賀拔仁、斛律金擁愔等唐突入雲龍門。",
    "entities": [
      {
        "text": "斛律金",
        "label": "PER",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000120",
    "sentence": "見都督叱利騷，招之不進，使騎殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000121",
    "sentence": "開府成休寧拒門，歸彥喻之，乃得入。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000122",
    "sentence": "送愔等於御前。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000123",
    "sentence": "長廣王及歸彥在朱華門外。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000124",
    "sentence": "太皇太后臨昭陽殿，太后及帝側立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000125",
    "sentence": "常山王以磚叩頭，進而言曰：「臣與陛下骨肉相連。楊遵彥等欲擅朝權，威福自己，王公以還，皆重足屏氣。共相唇齒，以成亂階，若不早圖，必為宗社之害。臣與湛等為國事重，賀拔仁、斛律金等惜獻皇帝基業，共執遵彥等領入宮，未敢刑戮，專輒之失，罪合萬死。」帝時默然，領軍劉桃枝之徒陛衛，叩刀仰視，帝不睨之，太皇太后令卻仗，不肯。",
    "entities": [
      {
        "text": "斛律金",
        "label": "PER",
        "start": 83,
        "end": 86
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 89,
        "end": 91
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000126",
    "sentence": "又厲聲曰：「奴輩即今頭落。」乃卻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000127",
    "sentence": "因問楊郎何在，賀拔仁曰：「一目已出。」太皇太后愴然曰：「楊郎何所能，留使不好耶！」乃讓帝曰：「此等懷逆，欲殺我二兒，次及我，爾何縱之？」帝猶不能言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000128",
    "sentence": "太皇太后怒且悲，王公皆泣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000129",
    "sentence": "太皇太后曰：「豈可使我母子受漢老嫗斟酌。」太后拜謝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000130",
    "sentence": "常山王叩頭不止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000131",
    "sentence": "太皇太后謂帝：「何不安尉爾叔？」帝乃曰：「天子亦不敢與叔惜，豈敢惜此漢輩？但願乞兒性命，兒自下殿去，此等任叔父處分。」遂皆斬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000132",
    "sentence": "長廣王以子默昔讒己作詔書，故先拔其舌，截其手。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000133",
    "sentence": "太皇太后臨愔喪，哭曰：「楊郎忠而獲罪。」以御金為之一眼，親內之，曰：「以表我意。」常山王亦悔殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000134",
    "sentence": "先是童謠曰：「白羊頭尾禿，羖䍽頭生角。」又曰：「羊羊喫野草，不吃野草遠我道，不遠打爾腦。」又曰：「阿麼姑禍也，道人姑夫死也。」羊為愔也，「角」文為用刀，「道人」謂廢帝小名，太原公主嘗作尼，故曰「阿麼姑」，愔子獻、天和皆帝姑夫云。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 88,
        "end": 90
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000135",
    "sentence": "於是乃以天子之命下詔罪之，罪止一身，家口不問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000136",
    "sentence": "尋復簿錄五家，王晞固諫，乃各沒一房，孩幼兄弟皆除名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000137",
    "sentence": "遵彥死，仍以中書令趙彥深代總機務。",
    "entities": [
      {
        "text": "趙彥深",
        "label": "PER",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000138",
    "sentence": "鴻臚少卿陽休之私謂人曰：「將涉千里，殺騏驥而策蹇驢，可悲之甚。」愔所著詩賦表奏書訟甚多，誅後散失，門生鳩集所得者萬餘言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000139",
    "sentence": "燕子獻",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000140",
    "sentence": "燕子獻，字季則，廣漢下洛人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000141",
    "sentence": "少時相者謂之曰：「使役在胡代，富貴在齊趙。」其後，遇宇文氏稱霸關中，用為典簽，將命使於茹茹。",
    "entities": [
      {
        "text": "遇宇文氏稱霸關",
        "label": "LOC",
        "start": 25,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000142",
    "sentence": "子獻欲驗相者之言，來歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000143",
    "sentence": "高祖見之大悅，尚淮陽公主，甚被待遇。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000144",
    "sentence": "顯祖時，官至侍中、開府。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000145",
    "sentence": "濟南即位之後，委任彌重，除右僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000146",
    "sentence": "子獻素多力，頭又少發，當狼狽之際，排衆走出省門，斛律光逐而擒之。",
    "entities": [
      {
        "text": "斛律光",
        "label": "PER",
        "start": 24,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000147",
    "sentence": "子獻嘆曰：「丈夫為計遲，遂至於此矣。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000148",
    "sentence": "可朱渾天和",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000149",
    "sentence": "可朱渾天和，道元之季弟也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000150",
    "sentence": "以道無勳重，尚東平公主。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000151",
    "sentence": "累遷領軍大將軍、開府。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000152",
    "sentence": "濟南王即位，加特進，改博陵公，與楊愔同被殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000153",
    "sentence": "宋欽道",
    "entities": [
      {
        "text": "宋欽道",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000154",
    "sentence": "宋欽道，廣平人，魏吏部尚書弁孫也。",
    "entities": [
      {
        "text": "宋欽道",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000155",
    "sentence": "初為大將軍主簿，典書記。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000156",
    "sentence": "後為黃門侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000157",
    "sentence": "又令在東宮教太子習事。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000158",
    "sentence": "時鄭子默以文學見知，亦備親寵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000159",
    "sentence": "欽道本文法吏，不甚諳識古今，凡有疑事，必詢於子默。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000160",
    "sentence": "二人幸於兩宮，雖諸王貴臣莫不敬憚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000161",
    "sentence": "欽道又遷秘書監。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000162",
    "sentence": "與楊愔同誅，贈吏部尚書、趙州刺史。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "趙州",
        "label": "LOC",
        "start": 12,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000163",
    "sentence": "鄭頤",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000164",
    "sentence": "鄭頤，字子默，彭城人。",
    "entities": [
      {
        "text": "彭城",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000165",
    "sentence": "高祖據，魏彭城守，自滎陽徙焉。",
    "entities": [
      {
        "text": "魏彭城",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000166",
    "sentence": "頤聰敏，頗涉文義。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000167",
    "sentence": "初為太原公東閣祭酒，與宋欽道特相友愛，欽道每師事之。",
    "entities": [
      {
        "text": "宋欽道",
        "label": "PER",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000168",
    "sentence": "楊愔始輕宋、鄭，不為之禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000169",
    "sentence": "俄而自結人主，與參顧命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000170",
    "sentence": "欽道復舊與濟南款狎，共相引致，無所不言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000171",
    "sentence": "乾明初，拜散騎常侍。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 1,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000172",
    "sentence": "二人權勢之重，與愔相埒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000173",
    "sentence": "愔見害之時，邢子才流涕曰：「楊令君雖其人，死日恨不得一佳伴。」頤後與愔同詔追贈殿中尚書、廣州刺史。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 41,
        "end": 43
      },
      {
        "text": "廣州",
        "label": "LOC",
        "start": 44,
        "end": 46
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 46,
        "end": 48
      }
    ]
  },
  {
    "sentence_id": "HCH_004_034_000174",
    "sentence": "頤弟抗，字子信，頗有文學。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000175",
    "sentence": "武平末，兼左右郎中，待詔文林館。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000176",
    "sentence": "【史論】",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000177",
    "sentence": "論曰：愔雅道風流，早同標緻，公望人物所推。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000178",
    "sentence": "夫處亂虐之世，當機衡之重，朝有善政，是也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000179",
    "sentence": "及寄天下之命，托六尺之孤，旬朔未幾，身亡君辱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000180",
    "sentence": "進不能送往事居，觀幾衛主；退不能保身全名，辭寵招福。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000181",
    "sentence": "朝廷之釁，既已仗義斷恩；猜忌之塗，無容推心受亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000182",
    "sentence": "是知變通之術，非所長也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_034_000183",
    "sentence": "校",
    "entities": []
  },
  {
