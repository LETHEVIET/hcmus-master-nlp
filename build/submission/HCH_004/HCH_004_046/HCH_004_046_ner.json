        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000114",
    "sentence": "瓊所部人連接村居，無相染累。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000115",
    "sentence": "鄰邑於此伏其德。",
