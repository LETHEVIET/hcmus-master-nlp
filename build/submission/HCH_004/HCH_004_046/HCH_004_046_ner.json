  },
  {
    "sentence_id": "HCH_004_046_000158",
    "sentence": "父翼宗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000159",
    "sentence": "豹體貌魁岸，美音儀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000160",
    "sentence": "釋褐開府參軍，兼行臺郎中，隨慕容紹宗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000161",
    "sentence": "紹宗自云有水厄，遂於戰艦中浴，並自投於水，冀以厭當之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000162",
    "sentence": "豹曰：「夫命也在天，豈人理所能延促？公若實有災眚，恐非禳所能解；若其實無，何禳之有。」紹宗笑曰：「不能免俗，聊復爾耳。」未幾而紹宗遇溺，時論以為知微。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000163",
    "sentence": "遷樂陵太守，鎮以凝重，哀矜貧弱。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000164",
    "sentence": "豹階庭簡靜，圄囹空虛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000165",
    "sentence": "郡治瀕海，水味多鹹苦，豹命鑿一井，遂得甘泉，遐邇以為政化所致。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000166",
    "sentence": "豹罷歸後，井味復鹹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000167",
    "sentence": "齊滅，還鄉園自養，頻徵，辭疾。",
