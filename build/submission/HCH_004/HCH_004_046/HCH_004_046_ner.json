[
  {
    "sentence_id": "HCH_004_046_000001",
    "sentence": "序",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000002",
    "sentence": "先王疆理天下，司牧黎元，刑法以禁其奸，禮教以防其欲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000003",
    "sentence": "故分職命官，共理天下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000004",
    "sentence": "《書》云：「知人則哲，能官人安人則惠。」睿哲之君，必致清明之臣，昏亂之朝，多有貪殘之吏。",
    "entities": [
      {
        "text": "《書》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000005",
    "sentence": "高祖撥亂反正，恤隱為懷，故守令之徒，才多稱職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000006",
    "sentence": "仍以戰功諸將，出牧外藩，不識治體，無聞政術。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000007",
    "sentence": "非唯暗於前言往行，乃至始學依判付曹，聚斂無厭，淫虐不已，雖或直繩，終無悛革。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000008",
    "sentence": "於戲！",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000009",
    "sentence": "此朝廷之大失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000010",
    "sentence": "大寧以後，風雅俱缺，賣官鬻獄，上下相蒙，降及末年，黷貨滋甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000011",
    "sentence": "齊氏循良，如辛術之徒非一，多以官爵通顯，別有列傳。",
    "entities": [
      {
        "text": "齊氏",
        "label": "ORG",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000012",
    "sentence": "如房仲幹之屬，在武平之末能，卓爾不群，斯固彌可嘉也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000013",
    "sentence": "今掇張華原等列於《循吏》云。",
    "entities": [
      {
        "text": "《循吏》",
        "label": "TITLE",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000014",
    "sentence": "張華原",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000015",
    "sentence": "張華原，字國滿，代郡人也。",
    "entities": [
      {
        "text": "代郡",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000016",
    "sentence": "少明敏，有器度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000017",
    "sentence": "高祖開驃騎府，引為法曹參軍，遷大丞相府屬，仍侍左右。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000018",
    "sentence": "從於信都，深為高祖所親待。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000019",
    "sentence": "高祖每號令三軍，常令宣諭意旨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000020",
    "sentence": "周文帝始據雍州也，高祖猶欲以逆順曉之，使華原入關說焉。",
    "entities": [
      {
        "text": "周文帝始據雍州",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "使華原入關",
        "label": "LOC",
        "start": 19,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000021",
    "sentence": "周文密有拘留之意，謂華原曰：「若能屈驥足於此，當共享富貴，不爾，命懸今日。」華原曰：「渤海王命世誕生，殆天所縱，以明公蕞爾關右，便自隔絕，故使華原銜喻公旨。明公不以此日改圖，轉禍為福，乃欲賜脅，有死而已。」周文嘉其亮正，乃使東還。",
    "entities": [
      {
        "text": "以明公蕞爾關",
        "label": "LOC",
        "start": 56,
        "end": 62
      },
      {
        "text": "明",
        "label": "ORG",
        "start": 78,
        "end": 79
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000022",
    "sentence": "高祖以華原久而不返，每嘆惜之，及聞其來，喜見於色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000023",
    "sentence": "累遷為兗州刺史，人懷感附，寇盜寢息。",
    "entities": [
      {
        "text": "累遷為兗州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000024",
    "sentence": "州獄先有囚千餘人，華原皆決遣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000025",
    "sentence": "至年暮，唯有重罪者數十人，華原亦遣歸家申賀，依期至獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000026",
    "sentence": "先是州境數有猛獸為暴，自華原臨州，忽有六駁食之，咸以化感所致。",
    "entities": [
      {
        "text": "先是州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "自華原臨州",
        "label": "LOC",
        "start": 11,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000027",
    "sentence": "後卒官，州人大小莫不號慕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000028",
    "sentence": "宋世良",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000029",
    "sentence": "宋世良，字元友，廣平人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000030",
    "sentence": "年十五便有膽氣，應募從軍北討，屢有戰功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000031",
    "sentence": "尋為殿中侍御史，詣河北括戶，大獲浮惰。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000032",
    "sentence": "還見汲郡城旁多骸骨，移書州郡，令悉收瘞。",
    "entities": [
      {
        "text": "還見汲郡城",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "移書州郡",
        "label": "LOC",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000033",
    "sentence": "其夜，甘雨霶沱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000034",
    "sentence": "還，孝莊勞之曰：「知卿所括得丁倍於本帳，若官人皆如此用心，便是更出一天下也。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000035",
    "sentence": "出除清河太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000036",
    "sentence": "世良才識閑明，尤善治術，在郡未幾，聲問甚高。",
    "entities": [
      {
        "text": "在郡",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000037",
    "sentence": "郡東南有曲堤，成公一姓阻而居之，群盜多萃於此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000038",
    "sentence": "人為之語曰：「寧度東吳會稽，不歷成公曲堤。」世良施八條之制，盜奔他境。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000039",
    "sentence": "民又謠曰：「曲堤雖險賊何益，但有宋公自屏跡。」後齊天保中大赦，郡先無一囚，羣吏拜詔而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000040",
    "sentence": "獄內穞生，桃樹、蓬蒿亦滿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000041",
    "sentence": "每日衙門虛寂，無復訴訟者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000042",
    "sentence": "其冬，醴泉出於界內。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000043",
    "sentence": "及代至，傾城祖道。",
    "entities": [
      {
        "text": "傾城",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000044",
    "sentence": "有老人丁金剛泣而前，謝曰：「己年九十，記三十五政，君非唯善治，清亦徹底。今失賢君，民何濟矣。」莫不攀援涕泣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000045",
    "sentence": "除東郡太守，卒官。",
    "entities": [
      {
        "text": "除東郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000046",
    "sentence": "世良強學，好屬文，撰《字略》五篇、《宋氏別錄》十卷。",
    "entities": [
      {
        "text": "《字略》",
        "label": "TITLE",
        "start": 10,
        "end": 14
      },
      {
        "text": "《宋氏別錄》",
        "label": "TITLE",
        "start": 17,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000047",
    "sentence": "與弟世軌俱有孝友之譽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000048",
    "sentence": "世軌，幼自嚴整，好法律，稍遷廷尉卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000049",
    "sentence": "洛州民聚結欲劫河橋，吏捕案之，連諸元徒黨千七百人。",
    "entities": [
      {
        "text": "洛州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000050",
    "sentence": "崔暹為廷尉，以之為反，數年不斷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000051",
    "sentence": "及世軌為少卿，判其事為劫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000052",
    "sentence": "於是殺魁首，餘從坐悉舍焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000053",
    "sentence": "時大理正蘇珍之亦以平幹知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000054",
    "sentence": "寺中為之語曰：「決定嫌疑蘇珍之，視表見裏宋世軌。」時人以為寺中二絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000055",
    "sentence": "南臺囚到廷尉，世軌多雪之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000056",
    "sentence": "仍移攝御史，將問其濫狀，中尉畢義雲不送，移往復不止。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000057",
    "sentence": "世軌遂上書，極言義雲酷擅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000058",
    "sentence": "顯祖引見二人，親勑世軌曰：「我知臺欺寺久，卿能執理與之抗衡，但守此心，勿慮不富貴。」勑義雲曰：「卿比所為誠合死，以志在疾惡，故且一恕。」仍顧謂朝臣曰：「此二人並我骨鯁臣也。」及疾卒，廷尉、御史諸繫囚聞世軌死，皆哭曰：「宋廷尉死，我等豈有生路！」",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 94,
        "end": 96
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000059",
    "sentence": "世良從子孝王，學涉，亦好緝綴文藻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000060",
    "sentence": "形貌短陋，而好臧否人物，時論甚疾之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000061",
    "sentence": "為段孝言開府參軍，又薦為北平王文學。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000062",
    "sentence": "求入文林館不遂，因非毀朝士，撰《別錄》二十卷，會平齊，改為《關東風俗傳》，更廣見聞，勒成三十卷以上之。",
    "entities": [
      {
        "text": "《別錄》",
        "label": "TITLE",
        "start": 15,
        "end": 19
      },
      {
        "text": "《關東風俗傳》",
        "label": "TITLE",
        "start": 29,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000063",
    "sentence": "言多妄謬，篇第冗雜，無著述體。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000064",
    "sentence": "郎基",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000065",
    "sentence": "郎基，字世業，中山人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000066",
    "sentence": "身長八尺，美鬚髯，泛涉墳典，尤長吏事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000067",
    "sentence": "起家奉朝請，累遷海西鎮將。",
    "entities": [
      {
        "text": "累遷海西鎮",
        "label": "LOC",
        "start": 6,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000068",
    "sentence": "梁吳明徹率衆攻圍海西，基獎勵兵民，固守百餘日，軍糧且罄，戎仗亦盡，乃至削木為箭，剪紙為羽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000069",
    "sentence": "圍解還朝，僕射楊愔迎勞之曰：「卿本文吏，遂有武略。削木剪紙，皆無故事，班、墨之思，何以相過。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000070",
    "sentence": "後帶潁川郡，積年留滯，數日之中，剖判咸盡，而臺報下，並允基所陳。",
    "entities": [
      {
        "text": "後帶潁川郡",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000071",
    "sentence": "條綱旣疏，獄訟清息，官民遐邇，皆相慶悅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000072",
    "sentence": "基性清慎，無所營求，曾語人云：「任官之所，木枕亦不須作，況重於此事。」唯頗令寫書。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000073",
    "sentence": "潘子義曾遺之書曰：「在官寫書，亦是風流罪過。」基答書曰：「觀過知仁，斯亦可矣。」後卒官，柩將還，遠近將送，莫不攀轅悲哭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000074",
    "sentence": "孟業",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000075",
    "sentence": "孟業，字敬業，鉅鹿安國人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000076",
    "sentence": "家本寒微，少為州吏。",
    "entities": [
      {
        "text": "少為州",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000077",
    "sentence": "性廉謹，同僚諸人侵盜官絹，分三十疋與之，拒而不受。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000078",
    "sentence": "魏彭城王韶拜定州，除典籖。",
    "entities": [
      {
        "text": "魏彭城",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "王韶拜定州",
        "label": "LOC",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000079",
    "sentence": "長史劉仁之謂業曰：「我處其外，君居其內，同心戮力，庶有濟乎。」未幾仁之徵入為中書令，臨路啟韶云：「殿下左右可信任者唯有孟業，願專任之。餘人不可信也。」又與業別，執手曰：「今我出都，君便失援，恐君在後，不自保全。唯正與直，願君自勉。」業唯有一馬，因瘦而死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000080",
    "sentence": "韶以業家貧，令州府官人同食馬肉，欲令厚償，業固辭不敢。",
    "entities": [
      {
        "text": "令州",
