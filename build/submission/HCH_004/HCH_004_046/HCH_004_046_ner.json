        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_046_000168",
    "sentence": "終於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000169",
    "sentence": "路去病",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000170",
    "sentence": "路去病，陽平人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000171",
    "sentence": "風神疏朗，儀表瓌異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000172",
    "sentence": "釋褐開府參軍。",
    "entities": []
  },
