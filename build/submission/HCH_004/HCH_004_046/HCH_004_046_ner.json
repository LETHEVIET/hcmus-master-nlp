    "sentence": "房豹",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000156",
    "sentence": "房豹，字仲幹，清河人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_046_000157",
    "sentence": "祖法壽，《 魏書 》有傳。",
