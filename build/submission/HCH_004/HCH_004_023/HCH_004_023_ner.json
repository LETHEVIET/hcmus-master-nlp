        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000002",
    "sentence": "魏蘭根，鉅鹿下曲陽人也。",
    "entities": [
      {
        "text": "魏蘭根",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000003",
    "sentence": "父伯成，魏中山太守。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 4,
        "end": 5
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000004",
    "sentence": "蘭根身長八尺，儀貌奇偉，泛覽群書，誦《 左氏傳 》《 周易 》，機警有識悟。",
    "entities": [
      {
        "text": "《 左氏傳 》",
        "label": "TITLE",
        "start": 18,
        "end": 25
      },
      {
        "text": "《 周易 》",
        "label": "TITLE",
        "start": 25,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000005",
    "sentence": "起家北海王國侍郎，歷定州長流參軍。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "歷定州",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000006",
    "sentence": "丁母憂，居喪有孝稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000007",
    "sentence": "將葬常山郡境，先有董卓祠，祠有柏樹。",
    "entities": [
      {
        "text": "將葬常山郡",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000008",
    "sentence": "蘭根以卓兇逆無道，不應遺祠至今，乃伐柏以為槨材。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000009",
    "sentence": "人或勸之不伐，蘭根盡取之，了無疑懼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000010",
    "sentence": "遭父喪，廬於墓側，負土成墳，憂毀殆於滅性。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000011",
    "sentence": "後為司空、司徒二府記室參軍，轉夏州平北府長史，入為司徒掾，出除本郡太守，並有當官之能。",
    "entities": [
      {
        "text": "轉夏州",
        "label": "LOC",
        "start": 14,
        "end": 17
      },
      {
        "text": "出除本郡",
        "label": "LOC",
        "start": 29,
        "end": 33
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000012",
    "sentence": "正光末，尚書令李崇為本郡都督，率眾討茹茹，以蘭根為長史。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000013",
    "sentence": "因說崇曰：「緣邊諸鎮，控攝長遠。昔時初置，地廣人稀，或徵發中原強宗子弟，或國之肺腑，寄以爪牙。中年以來，有司乖實，號曰府戶，役同廝養，官婚班齒，致失清流。而本宗舊類，各各榮顯，顧瞻彼此，理當憤怨。更張琴瑟，今也其時，靜境寧邊，事之大者。宜改鎮立州，分置郡縣，凡是府戶，悉免為民，入仕次敘，一準其舊，文武兼用，威恩並施。此計若行，國家庶無北顧之慮矣。」崇以秦聞，事寢不報。",
    "entities": [
      {
        "text": "緣邊諸鎮",
        "label": "LOC",
        "start": 6,
        "end": 10
      },
      {
        "text": "宜改鎮立州",
        "label": "LOC",
        "start": 118,
        "end": 123
      },
      {
        "text": "分置郡縣",
        "label": "LOC",
        "start": 124,
        "end": 128
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000014",
    "sentence": "軍還，除冠軍將軍，轉司徒右長史，假節，行豫州事。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "行豫州",
        "label": "LOC",
        "start": 19,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000015",
    "sentence": "孝昌初，轉岐州刺史。",
    "entities": [
      {
        "text": "轉岐州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000016",
    "sentence": "從行臺蕭寶寅討破宛川，俘其民人為奴婢，以美女十人賞蘭根。",
    "entities": [
      {
        "text": "蕭寶寅",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000017",
    "sentence": "蘭根辭曰：「此縣界於強虜，皇威未接，無所適從，故成背叛。今當寒者衣之，饑者食之，奈何將充僕隸乎？」盡以歸其父兄。",
    "entities": [
      {
        "text": "此縣",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000018",
    "sentence": "部內麥多五穗，鄰州田鼠為災，犬牙不入岐境。",
    "entities": [
      {
        "text": "鄰州",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000019",
    "sentence": "屬秦隴反叛，蕭寶寅敗於涇州，高平虜賊逼岐州，州城民逼囚蘭根降賊。",
    "entities": [
      {
        "text": "高平虜賊逼岐州",
        "label": "LOC",
        "start": 14,
        "end": 21
      },
      {
        "text": "州城",
        "label": "LOC",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000020",
    "sentence": "寶寅至雍州，收輯散亡，兵威復振，城民復斬賊刺史侯莫陳仲和，推蘭根復任。",
    "entities": [
      {
        "text": "寶寅至雍州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000021",
    "sentence": "朝廷以蘭根得西土人心，加持節、假平西將軍、都督涇岐東秦南岐四州軍事，兼四州行臺尚書。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "岐東秦南岐四州",
        "label": "LOC",
        "start": 24,
        "end": 31
      },
      {
        "text": "兼四州",
        "label": "LOC",
        "start": 34,
        "end": 37
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 39,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000022",
    "sentence": "尋入拜光祿大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000023",
    "sentence": "孝昌末，河北流人南渡，以蘭根兼尚書，使齊、濟、二兗四州安撫，並置郡縣。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "二兗四州",
        "label": "LOC",
        "start": 23,
        "end": 27
      },
      {
        "text": "並置郡縣",
        "label": "LOC",
        "start": 30,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000024",
    "sentence": "河間邢杲反於青、兗之間，杲，蘭根之甥也，復詔蘭根銜命慰勞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000025",
    "sentence": "杲不下，仍隨元天穆討之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000026",
    "sentence": "還，除太府卿，辭不拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000027",
    "sentence": "轉安東將軍、中書令。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000028",
    "sentence": "莊帝之將誅尒朱榮也，蘭根聞其計，遂密告尒朱世隆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000029",
    "sentence": "榮死，蘭根恐莊帝知之，憂懼不知所出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000030",
    "sentence": "時應詔王道習見信於莊帝，蘭根乃托附之，求得在外立功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000031",
    "sentence": "道習為啟聞，乃以蘭根為河北行臺，於定州率募鄉曲，欲防井陘。",
    "entities": [
      {
        "text": "於定州率募鄉",
        "label": "LOC",
        "start": 16,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000032",
    "sentence": "時尒朱榮將侯深自范陽趣中山，蘭根與戰，大敗，走依渤海高乾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000033",
    "sentence": "屬乾兄弟舉義，因在其中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000034",
    "sentence": "高祖至，以蘭根宿望，深禮遇之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000035",
    "sentence": "中興初，加車騎大將軍、尚書右僕射。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 7,
        "end": 10
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000036",
    "sentence": "及高祖將入洛陽，遣蘭根先至京師。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000037",
    "sentence": "時廢立未決，令蘭根觀察魏前廢帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000038",
    "sentence": "帝神采高明，蘭根恐於後難測，遂與高幹兄弟及黃門崔㥄同心固請於高祖，言廢帝本是胡賊所推，今若仍立，於理不允。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000039",
    "sentence": "高祖不得已，遂立武帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000040",
    "sentence": "廢帝素有德業，而為蘭根等構毀，深為時論所非。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000041",
    "sentence": "太昌初，除儀同三司，尋加開府，封鉅鹿縣侯，邑七百戶。",
    "entities": [
      {
        "text": "封鉅鹿縣",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000042",
    "sentence": "啟授兄子同達。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000043",
    "sentence": "蘭根既預義勳，位居端揆，至是始敘復岐州勳，封永興縣侯，邑千戶。",
    "entities": [
      {
        "text": "至是始敘復岐州",
        "label": "LOC",
        "start": 12,
        "end": 19
      },
      {
        "text": "封永興縣",
        "label": "LOC",
        "start": 21,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000044",
    "sentence": "高乾之死，蘭根懼，去宅，避於寺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000045",
    "sentence": "武帝大加譴責，蘭根憂怖，乃移病解僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000046",
    "sentence": "天平初，以病篤上表求還鄉里。",
    "entities": [
      {
        "text": "病篤上表求還鄉",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000047",
    "sentence": "魏帝遣舍人石長宣就家勞問，猶以開府儀同，門施行馬，歸於本鄉。",
    "entities": [
      {
        "text": "歸於本鄉",
        "label": "LOC",
        "start": 25,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000048",
    "sentence": "二年卒，時年六十一。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000049",
    "sentence": "贈冀定殷三州軍事、定州刺史、司徒公、侍中，諡曰文宣。",
    "entities": [
      {
        "text": "贈冀定殷三州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "定州",
        "label": "LOC",
        "start": 9,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000050",
    "sentence": "蘭根雖以功名自立，然善附會，出處之際，多以計數為先，是以不為清論所許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000051",
    "sentence": "長子相如，秘書郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000052",
    "sentence": "以建義勳，尋加將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000053",
    "sentence": "襲父爵，遷安東將軍、殷州別駕，入為侍御史。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "殷州",
        "label": "LOC",
        "start": 10,
        "end": 12
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000054",
    "sentence": "武定三年 卒。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000055",
    "sentence": "次子敬仲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000056",
    "sentence": "肅宗時，佐命功臣配享，而不及蘭根。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000057",
    "sentence": "敬仲表訴，帝以詔命既行，難於追改，擢敬仲為祠部郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000058",
    "sentence": "卒於章武太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000059",
    "sentence": "蘭根族弟明朗，頗涉經史，粗有文性。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000060",
    "sentence": "累遷大司馬府法曹參軍，兼尚書金部郎中。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000061",
    "sentence": "元顥入洛陽，明朗為南道行臺郎中，為顥所擒。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000062",
    "sentence": "後棄顥逃還，除龍驤將軍、中散大夫，賜爵鉅鹿侯。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000063",
    "sentence": "永安末，蘭根為河北行臺，引明朗為左丞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000064",
    "sentence": "及蘭根中山之敗，俱歸高祖。",
    "entities": []
  },
  {
