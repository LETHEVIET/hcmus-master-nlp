      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000080",
    "sentence": "愷從子彥卿，魏大司農季景之子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000081",
    "sentence": "武平中，兼通直散騎常侍，聘陳使副。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000082",
    "sentence": "彥卿弟澹，學識有詞藻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000083",
    "sentence": "武平初，殿中御史，遷中書舍人，待詔文林館。",
