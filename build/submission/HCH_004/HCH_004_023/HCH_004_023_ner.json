        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000196",
    "sentence": "法峻以 武平六年 從駕在晉陽，嘗語中書侍郎李德林云：「此日看高相王以下文武官人相表，俱盡其事，口不忍言。唯弟一人，更應富貴，當在他國，不在本朝，吾亦不及見也。」其精妙如此。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 6,
        "end": 8
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 19,
        "end": 21
      },
      {
        "text": "李德林",
        "label": "PER",
        "start": 21,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000197",
    "sentence": "㥄族子肇師，魏尚書僕射亮之孫也。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000198",
    "sentence": "父士太，諫議大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000199",
    "sentence": "肇師少時疏放，長遂變節，更成謹厚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000200",
    "sentence": "涉獵經史，頗有文思。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000201",
    "sentence": "襲父爵樂陵男。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000202",
    "sentence": "釋褐開府東閤祭酒，轉司空外兵參軍，遷大司馬府記室參軍。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000203",
    "sentence": "天平初，轉通直侍郎，為尉勞青州使。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "為尉勞青州",
        "label": "LOC",
        "start": 10,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000204",
    "sentence": "至齊州界，為土賊崔迦葉等所虜，欲逼與同事。",
    "entities": [
      {
        "text": "至齊州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000205",
    "sentence": "肇師執節不動，諭以禍福，賊遂捨之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000206",
    "sentence": "乃巡慰青部而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000207",
    "sentence": "元象中，數以中舍人接梁使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000208",
    "sentence": "武定中，復兼中正員郎，送梁使徐州。",
    "entities": [
      {
        "text": "送梁使徐州",
        "label": "LOC",
        "start": 11,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000209",
    "sentence": "還，勑修起居注。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000210",
    "sentence": "尋兼通直散騎常侍，聘梁副使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000211",
    "sentence": "轉中書舍人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000212",
    "sentence": "天保初，參定禪代禮儀，封襄城縣男，仍兼中書侍郎。",
    "entities": [
      {
        "text": "封襄城縣",
        "label": "LOC",
        "start": 11,
        "end": 15
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000213",
    "sentence": "二年卒，時年四十九。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000214",
    "sentence": "【史論】",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000215",
    "sentence": "史臣曰：蘭根早有名行，為時論所稱；長孺才望之美，見重當世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000216",
    "sentence": "並功參霸迹，位遇通顯，與李元忠、盧文偉蓋義旗之人物歟？",
    "entities": [
      {
        "text": "李元忠",
        "label": "PER",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_023_000217",
    "sentence": "魏之要幸附會，崔以門地驕很，雖有周公之美，猶以為累德，況未足喻其高下也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000218",
    "sentence": "瞻詞韻溫雅，風神秀發，亦一時之領袖焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000219",
    "sentence": "贊曰：崔、魏才望，見重霸初。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000220",
    "sentence": "名教之跡，其猶病諸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000221",
    "sentence": "彥通尚志，家風有餘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_023_000222",
