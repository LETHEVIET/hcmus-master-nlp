[
  {
    "sentence_id": "HCH_004_026_000001",
    "sentence": "薛琡",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000002",
    "sentence": "薛琡，字曇珍，河南人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000003",
    "sentence": "其先代人，本姓叱干氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000004",
    "sentence": "父彪子，魏徐州刺史。",
    "entities": [
      {
        "text": "魏徐州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000005",
    "sentence": "琡形貌魁偉，少以幹用稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000006",
    "sentence": "為典客令，每引客見，儀望甚美。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000007",
    "sentence": "魏帝召而謂之曰：「卿風度峻整，姿貌秀異，後當升進，何以處官？」琡曰：「宗廟之禮，不敢不敬，朝廷之事，不敢不忠，自此以外，非庸臣所及。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000008",
    "sentence": "正光中，行洛陽令，部內肅然。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000009",
    "sentence": "有犯法者，未加拷掠，直以辭理窮覈，多得其情。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000010",
    "sentence": "於是豪猾畏威，事務簡靜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000011",
    "sentence": "時以久旱，京師見囚悉召集華林，理問寃滯，洛陽繫獄，唯有三人。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000012",
    "sentence": "魏孝明嘉之，賜縑百疋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000013",
    "sentence": "遷吏部，尚書崔亮奏立停年之格，不簡人才，專問勞舊。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000014",
    "sentence": "琡上書，言：「黎元之命，繫於長吏，若得其人，則蘇息有地，任非其器，為患更深。若使選曹唯取年勞，不簡賢否，便義均行雁，次若貫魚，執簿呼名，一吏足矣，數人而用，何謂銓衡？請不依此。」書奏不報。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000015",
    "sentence": "後因引見，復進諫曰：「共治天下，本屬百官。是以漢朝常令三公大臣舉賢良方正、有道直言之士，以為長吏，監撫黎元。自晉末以來，此風遂替。今四方初定，務在養民。臣請依漢氏更立四科，令三公貴臣各薦時賢，以補郡縣，明立條格，防其阿黨之端。」詔下公卿議之，事亦寢。",
    "entities": [
      {
        "text": "晉",
        "label": "ORG",
        "start": 55,
        "end": 56
      },
      {
        "text": "漢氏",
        "label": "ORG",
        "start": 79,
        "end": 81
      },
      {
        "text": "以補郡縣",
        "label": "LOC",
        "start": 96,
        "end": 100
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000016",
    "sentence": "元天穆討邢杲也，以琡為行臺尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000017",
    "sentence": "時元顥已據酇城。",
    "entities": [
      {
        "text": "時元顥已據酇城",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000018",
    "sentence": "天穆集文武議其所先。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000019",
    "sentence": "議者咸以杲衆甚盛，宜先經略。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000020",
    "sentence": "琡以為邢杲聚衆無名，雖強猶賊；元顥皇室昵親，來稱義舉，此恐難測。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000021",
    "sentence": "杲鼠盜狗竊，非有遠志，宜先討顥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000022",
    "sentence": "天穆以群情所欲，遂先討杲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000023",
    "sentence": "杲降軍還，顥遂入洛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000024",
    "sentence": "天穆謂琡曰：「不用君言，乃至於此。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000025",
    "sentence": "天平初，高祖引為丞相長史。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000026",
    "sentence": "琡宿有能名，深被禮遇，軍國之事，多所聞知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000027",
    "sentence": "琡亦推誠盡節，屢進忠讜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000028",
    "sentence": "高祖大舉西伐，將度蒲津。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000029",
    "sentence": "琡諫曰：「西賊連年饑饉，無可食啖，故冒死來入陜州，欲取倉粟。今高司徒已圍陜城，粟不得出。但置兵諸道，勿與野戰，比及來年麥秋，人民盡應餓死，寶炬、黑獺，自然歸降。願王無渡河也。」侯景亦曰：「今者之舉，兵衆極大，萬一不捷，卒難收斂。不如分為二軍，相繼而進，前軍若勝，後軍合力，前軍若敗，後軍承之。」高祖皆不納，遂有沙苑之敗。",
    "entities": [
      {
        "text": "故冒死來入陜州",
        "label": "LOC",
        "start": 17,
        "end": 24
      },
      {
        "text": "高司徒已圍陜城",
        "label": "LOC",
        "start": 31,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000030",
    "sentence": "累遷尚書僕射，卒。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000031",
    "sentence": "臨終勑其子斂以時服，逾月便葬，不聽干求贈官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000032",
    "sentence": "自制喪車，不加雕飾，但用麻為流蘇，繩用網絡而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000033",
    "sentence": "明器等物並不令置。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000034",
    "sentence": "琡久在省闥，閑明簿領，當官剖斷，敏速如流。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000035",
    "sentence": "然天性險忌，情義不篤，外似方格，內實浮動。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000036",
    "sentence": "受納貨賄，曲法舞文，深情刻薄，多所傷害，士民畏惡之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000037",
    "sentence": "魏東平王元匡妾張氏淫逸放恣，琡初與姦通，後納以為婦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000038",
    "sentence": "惑其讒言，逐前妻于氏，不認其子，家內怨忿，競相告列，深為世所譏鄙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000039",
    "sentence": "贈青州刺史。",
    "entities": [
      {
        "text": "贈青州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000040",
    "sentence": "敬顯儁",
    "entities": [
      {
        "text": "敬顯儁",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000041",
    "sentence": "敬顯儁，字孝英，平陽人。",
    "entities": [
      {
        "text": "敬顯儁",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000042",
    "sentence": "少英俠有節操，交結豪傑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000043",
    "sentence": "為羽林監。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000044",
    "sentence": "高祖臨晉州，儁因使謁見，與語說之，乃啟為別駕。",
    "entities": [
      {
        "text": "高祖臨晉州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000045",
    "sentence": "及義舉，以儁為行臺倉部郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000046",
    "sentence": "從攻鄴，令儁督造土山。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000047",
    "sentence": "城拔，又從平西胡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000048",
    "sentence": "轉都官尚書，與諸將征討，累有功。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000049",
    "sentence": "又從高祖平寇難，破周文帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000050",
    "sentence": "敗侯景，平壽春，定淮南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000051",
    "sentence": "又略地三江口，多築城戍。",
    "entities": [
      {
        "text": "多築城",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000052",
    "sentence": "累除兗州刺史，卒。",
    "entities": [
      {
        "text": "累除兗州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000053",
    "sentence": "平鑒",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000054",
    "sentence": "平鑒，字明達，燕郡薊人。",
    "entities": [
      {
        "text": "燕郡",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000055",
    "sentence": "父勝，安州刺史。",
    "entities": [
      {
        "text": "安州",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000056",
    "sentence": "鑒少聰敏，頗有志力。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000057",
    "sentence": "受學於徐遵明，不為章句，雖崇儒業，而有豪俠氣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000058",
    "sentence": "孝昌末，盜賊蜂起，見天下將亂，乃之洛陽，與慕容儼騎馬為友。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 17,
        "end": 19
      },
      {
        "text": "慕容儼",
        "label": "PER",
        "start": 21,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000059",
    "sentence": "鑒性巧，夜則胡畫，以供衣食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000060",
    "sentence": "謂其宗親曰：「運有污隆，亂極則治。幷州戎馬之地，尒朱王命世之雄，杖義建旗，奉辭問罪，勞忠竭力，今也其時。」遂相率奔尒朱榮於晉陽，因陳靜亂安民之策。",
    "entities": [
      {
        "text": "幷州",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000061",
    "sentence": "榮大奇之，即署參軍前鋒，從平鞏、密，每陣先登。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000062",
    "sentence": "除撫軍、襄州刺史。",
    "entities": [
      {
        "text": "襄州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000063",
    "sentence": "高祖起義信都，鑒自歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000064",
    "sentence": "高祖謂鑒曰：「日者皇綱中弛，公已早竭忠誠。今尒朱披猖，又能去逆從善。搖落之時，方識松筠。」即啟授征西。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000065",
    "sentence": "懷州刺史。",
    "entities": [
      {
        "text": "懷州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000066",
    "sentence": "鑒奏請於州西故軹道築城以防遏西寇，朝廷從之。",
    "entities": [
      {
        "text": "鑒奏請於州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "西故軹道築城",
        "label": "LOC",
        "start": 5,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000067",
    "sentence": "尋而西魏來攻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000068",
    "sentence": "是時新築之城，糧仗未集，舊來乏水，衆情大懼。",
    "entities": [
      {
        "text": "是時新築之城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000069",
    "sentence": "南門內有一井，隨汲即竭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000070",
    "sentence": "鑒乃具衣冠俯井而祝，至旦有井泉湧溢，合城取之。",
    "entities": [
      {
        "text": "合城",
        "label": "LOC",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_026_000071",
    "sentence": "魏師敗還，以功進位開府儀同三司。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000072",
    "sentence": "時和士開以佞幸勢傾朝列，令人求鑒愛妾劉氏，鑒即送之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_026_000073",
    "sentence": "仍謂人曰：「老公失阿劉，與死何異。要自為身作計，不得不然。」由是除齊州刺史。",
    "entities": [
      {
        "text": "由是除齊州",
