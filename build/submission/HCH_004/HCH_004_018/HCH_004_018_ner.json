        "start": 82,
        "end": 84
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000006",
    "sentence": "騰少而質直，明解吏事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000007",
    "sentence": "魏正光中，北方擾亂，騰間關危險，得達秀容。",
    "entities": [
      {
        "text": "騰間關",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000008",
    "sentence": "屬尒朱榮建義，騰隋榮入洛，例除冗從僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000009",
    "sentence": "尋為高祖都督府長史，從高祖東征邢杲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000010",
    "sentence": "師次齊城，有撫宜鎮軍人謀逆，將害督帥。",
    "entities": [
      {
        "text": "師次齊城",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "有撫宜鎮",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000011",
    "sentence": "騰知之，密啟高祖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000012",
    "sentence": "俄頃事發，高祖以有備，擒破之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000013",
    "sentence": "高祖之為晉州，騰為長史，加後將軍，封石安縣伯。",
    "entities": [
      {
        "text": "高祖之為晉州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "封石安縣",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000014",
    "sentence": "高祖自晉陽出滏口，行至襄垣，尒朱兆率衆追。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000015",
    "sentence": "高祖與兆宴飲於水湄，誓為兄弟，各還本營。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000016",
    "sentence": "明旦，兆復招高祖，高祖欲安其意，將赴之，臨上馬，騰牽衣止之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000017",
    "sentence": "兆乃隔水肆罵，馳還晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000018",
    "sentence": "高祖遂東。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000019",
    "sentence": "及起義信都，騰以誠款，常預謀策。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000020",
    "sentence": "騰以朝廷隔絕，號令無所歸，不權有所立，則衆將沮散，苦請於高祖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000021",
    "sentence": "高祖從之，遂立中興主。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000022",
    "sentence": "除侍中，尋加使持節、六州流民大都督、北道大行臺。",
    "entities": [
      {
        "text": "六州",
        "label": "LOC",
        "start": 10,
        "end": 12
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000023",
    "sentence": "高祖進軍於鄴，初留段榮守信都，尋遣榮鎮中山，仍令騰居守。",
    "entities": [
      {
        "text": "尋遣榮鎮",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000024",
    "sentence": "及平鄴，授相州刺史，改封咸陽郡公，增邑通前一千三百戶，入為侍中。",
    "entities": [
      {
        "text": "授相州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "改封咸陽郡",
        "label": "LOC",
        "start": 10,
        "end": 15
      },
      {
        "text": "增邑",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000025",
    "sentence": "時魏京兆王愉女平原公主寡居，騰欲尚之，公主不許。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000026",
    "sentence": "侍中封隆之無婦，公主欲之，騰妬隆之，遂相間構。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000027",
    "sentence": "高祖啟免騰官，請除外任，俄而復之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000028",
    "sentence": "騰以高祖腹心，入居門下，與斛斯椿同掌機密。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000029",
    "sentence": "椿既生異端，觸塗乖謬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000030",
    "sentence": "騰深見猜忌，慮禍及己，遂潛將十餘騎馳赴晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000031",
    "sentence": "高祖入討斛斯椿，留騰行幷州事，又使騰為冀相殷定滄瀛幽安八州行臺僕射、行冀州事，復行相州事。",
    "entities": [
      {
        "text": "留騰行幷州",
        "label": "LOC",
        "start": 8,
        "end": 13
      },
      {
        "text": "定滄瀛幽安八州",
        "label": "LOC",
        "start": 22,
        "end": 29
      },
      {
        "text": "行冀州",
        "label": "LOC",
        "start": 34,
        "end": 37
      },
      {
        "text": "復行相州",
        "label": "LOC",
        "start": 39,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000032",
    "sentence": "天平初，入為尚書左僕射，內外之事，騰咸知之，兼司空、尚書令。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000033",
    "sentence": "時西魏遣將寇南兗，詔騰為南道行臺，率諸將討之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000034",
    "sentence": "騰性尫怯，無威略，失利而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000035",
    "sentence": "又除司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000036",
    "sentence": "初北境亂離，亡一女，及貴，遠加推訪，終不得，疑其為人婢賤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000037",
    "sentence": "及為司徒，奴婢訴良者，不研虛實，率皆免之，願免千人，冀得其女。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000038",
    "sentence": "時高祖入朝，左右有言之者，高祖大怒，解其司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000039",
    "sentence": "武定中，使於青州，括浮逃戶口，遷太保。",
    "entities": [
      {
        "text": "使於青州",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000040",
    "sentence": "初，博陵崔孝芬取貧家子賈氏以為養女，孝芬死，其妻元更適鄭伯猷，攜賈於鄭氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000041",
    "sentence": "賈有姿色，騰納之，始以為妾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000042",
    "sentence": "其妻袁氏死，騰以賈有子，正以為妻，詔封丹陽郡君，復請以袁氏爵迴授其女。",
    "entities": [
      {
        "text": "詔封丹陽郡",
        "label": "LOC",
        "start": 17,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000043",
    "sentence": "違禮肆情，多此類也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000044",
    "sentence": "騰早依附高祖，契闊艱危，勤力恭謹，深見信待。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000045",
    "sentence": "及高祖置之魏朝，寄以心腹，遂志氣驕盈，與奪由己，求納財賄，不知紀極。",
    "entities": [
      {
        "text": "魏朝",
        "label": "ORG",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000046",
    "sentence": "生官死贈，非貨不行，餚藏銀器，盜為家物，親狎小人，專為聚斂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000047",
    "sentence": "在鄴與高岳、高隆之、司馬子如號為四貴，非法專恣，騰為甚焉。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000048",
    "sentence": "高祖屢加譴讓，終不悛改，朝野深非笑之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000049",
    "sentence": "武定六年 四月薨，時年六十八。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000050",
    "sentence": "贈使持節、都督冀定等五州諸軍事、冀州刺史、太師、開府、錄尚書事，諡曰文。",
    "entities": [
      {
        "text": "都督冀定等五州",
        "label": "LOC",
        "start": 5,
        "end": 12
      },
      {
        "text": "冀州",
        "label": "LOC",
        "start": 16,
        "end": 18
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000051",
    "sentence": "天保初，以騰佐命，詔祭告其墓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000052",
    "sentence": "皇建中，配享高祖廟庭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000053",
    "sentence": "子鳳珍嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000054",
    "sentence": "鳳珍庸暗，武平中，卒於開府儀同三司。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000055",
    "sentence": "高隆之",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000056",
    "sentence": "高隆之，字延興，本姓徐氏，云出自高平金鄉。",
    "entities": [
      {
        "text": "云出自高平金鄉",
        "label": "LOC",
        "start": 13,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000057",
    "sentence": "父幹，魏白水郡守，為姑婿高氏所養，因從其姓。",
    "entities": [
      {
        "text": "魏白水郡",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000058",
    "sentence": "隆之貴，魏朝贈司徒公、雍州刺史。",
    "entities": [
      {
        "text": "魏朝",
        "label": "ORG",
        "start": 4,
        "end": 6
      },
      {
        "text": "雍州",
        "label": "LOC",
        "start": 11,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000059",
    "sentence": "隆之後有參議之功，高祖命為從弟，仍云渤海蓚人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000060",
    "sentence": "隆之身長八尺，美鬚髯，深沈有志氣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000061",
    "sentence": "魏汝南王悅為司州牧，以為戶曹從事。",
    "entities": [
      {
        "text": "汝南王悅為司州",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000062",
    "sentence": "建義初，釋褐員外散騎常侍，與行臺于暉出討羊侃於太山，暉引隆之為行臺郎中，又除給事中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000063",
    "sentence": "與高祖深自結托。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000064",
    "sentence": "高祖之臨晉州，引為治中，行平陽郡事。",
    "entities": [
      {
        "text": "高祖之臨晉州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "行平陽郡",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000065",
    "sentence": "從高祖起義山東，以為大行臺右丞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000066",
    "sentence": "魏中興初，除御史中尉，領尚食典御。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000067",
    "sentence": "從高祖平鄴，行相州事。",
    "entities": [
      {
        "text": "行相州",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000068",
    "sentence": "從破四胡於韓陵，太昌初，除驃騎大將軍、儀同三司。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000069",
    "sentence": "西魏文帝曾與隆之因酒忿競，文帝坐以黜免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000070",
    "sentence": "高祖責隆之不能協和，乃啟出為北道行臺，轉幷州刺史，封平原郡公，邑一千七百戶。",
    "entities": [
      {
        "text": "轉幷州",
        "label": "LOC",
        "start": 19,
        "end": 22
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 22,
        "end": 24
      },
      {
        "text": "封平原郡",
        "label": "LOC",
        "start": 25,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000071",
    "sentence": "隆之請減戶七百，並求降己四階讓兄騰，並加優詔許之，仍以騰為滄州刺史。",
    "entities": [
      {
        "text": "仍以騰為滄州",
        "label": "LOC",
        "start": 25,
        "end": 31
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000072",
    "sentence": "高祖之討斛斯椿，以隆之為大行臺尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000073",
    "sentence": "及大司馬、清河王亶承制，拜隆之侍中、尚書右僕射，領御史中尉。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000074",
    "sentence": "廣費人工，大營寺塔，為高祖所責。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000075",
    "sentence": "天平初，丁母艱解任，尋詔起為幷州刺史，入為尚書右僕射。",
    "entities": [
      {
        "text": "尋詔起為幷州",
        "label": "LOC",
        "start": 10,
        "end": 16
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000076",
    "sentence": "時初給民田，貴勢皆占良美，貧弱咸受瘠薄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000077",
    "sentence": "隆之啟高祖，悉更反易，乃得均平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000078",
    "sentence": "又領營構大將軍，京邑制造，莫不由之。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 4,
        "end": 7
      },
      {
        "text": "京邑",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000079",
    "sentence": "增築南城，周迴二十五里。",
    "entities": [
      {
        "text": "增築南城",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000080",
    "sentence": "以漳水近於帝城，起長堤以防泛溢之患。",
    "entities": [
      {
        "text": "以漳水近於帝城",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000081",
    "sentence": "又鑿渠引漳水周流城郭，造治水碾磑，並有利於時。",
    "entities": [
      {
        "text": "渠引漳水周流城",
        "label": "LOC",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000082",
    "sentence": "魏自孝昌已後，天下多難，刺史太守皆為當部都督，雖無兵事，皆立佐僚，所在頗為煩擾。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000083",
    "sentence": "隆之表請自非實在邊要，見有兵馬者，悉皆斷之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000084",
    "sentence": "又朝貴多假常侍以取貂蟬之飾，隆之自表解侍中，並陳諸假侍中服用者，請亦罷之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000085",
    "sentence": "詔皆如表。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000086",
    "sentence": "自軍國多事，冒名竊官者不可勝數，隆之奏請檢括，獲五萬餘人，而群小喧囂，隆之懼而止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000087",
    "sentence": "詔監起居事，進位司徒公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000088",
    "sentence": "武定中，為河北括戶大使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000089",
    "sentence": "追還，授領軍將軍、錄尚書事，尋兼侍中。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000090",
    "sentence": "續出行青州事。",
    "entities": [
      {
        "text": "續出行青州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000091",
    "sentence": "追還，拜太子太師、兼尚書左僕射、吏部尚書，遷太保。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000092",
    "sentence": "時世宗作宰，風俗肅清，隆之時有受納，世宗於尚書省大加責辱。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000093",
    "sentence": "齊受禪，進爵為王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000094",
    "sentence": "尋以本官錄尚書事，領大宗正卿，監國史。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000095",
    "sentence": "隆之性小巧，至於公家羽儀、百戲、服制時有改易，不循典故，時論非之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000096",
    "sentence": "於射堋上立三像人為壯勇之勢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000097",
    "sentence": "顯祖曾至東山，因射，謂隆之曰：「射堋上可作猛獸，以存古義，何為置人？終日射人，朕所不取。」隆之無以對。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000098",
    "sentence": "初，世宗委任兼右僕射崔暹、黃門郎崔季舒等，及世宗崩，隆之啟顯祖並欲害之，不許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000099",
    "sentence": "顯祖以隆之舊齒，委以政事，季舒等仍以前隙，乃譖云：「隆之每見訴訟者，輒加哀矜之意，以示非己能裁。」顯祖以其受任既重，知有冤狀，便宜申滌，何得委過要名，非大臣義。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000100",
    "sentence": "天保五年，禁止尚書省。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000101",
    "sentence": "隆之曾與元昶宴飲，酒酣，語昶曰：「與王交遊，當生死不相背。」人有密言之者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000102",
    "sentence": "又帝未登庸之日，隆之意常侮帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000103",
    "sentence": "帝將受魏禪，大臣咸言未可，隆之又在其中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000104",
    "sentence": "帝深銜之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000105",
    "sentence": "因此，遂大發怒，令壯士築百餘下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000106",
    "sentence": "放出，渴將飲水，人止之，隆之曰：「今日何在！」遂飲之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000107",
    "sentence": "因從駕，死於路中，年六十一。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000108",
    "sentence": "贈冀定瀛滄幽五州諸軍事、大將軍、太尉、太保、冀州刺史、陽夏王。",
    "entities": [
      {
        "text": "冀定瀛滄幽五州",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 12,
        "end": 15
      },
      {
        "text": "冀州",
        "label": "LOC",
        "start": 22,
        "end": 24
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000109",
    "sentence": "竟不得諡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000110",
    "sentence": "隆之雖不涉學，而欽尚文雅，縉紳名流，必存禮接。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000111",
    "sentence": "寡姊為尼，事之如母，訓督諸子，必先文義。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000112",
    "sentence": "世甚以此稱之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000113",
    "sentence": "顯祖末年，既多猜害，追忿隆之，誅其子德樞等十餘人，並投漳水。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000114",
    "sentence": "又發隆之冢，出其屍，葬已積年，其貌不改，斬截骸骨，亦棄於漳流，遂絕嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000115",
    "sentence": "幹明中，詔其兄子子遠為隆之後，襲爵陽夏王，還其財產。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 1,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000116",
    "sentence": "初，隆之見信高祖，性多陰毒，睚眥之忿，無不報焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000117",
    "sentence": "儀同三司崔孝芬以結婚姻不果，太府卿任集同知營構，頗相乖異，瀛州刺史元晏請托不遂，前後構成其罪，並誅害之。",
    "entities": [
      {
        "text": "瀛州",
        "label": "LOC",
        "start": 29,
        "end": 31
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000118",
    "sentence": "終至家門殄滅，論者謂有報應焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000119",
    "sentence": "司馬子如",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000120",
    "sentence": "司馬子如，字遵業，河內溫人也。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000121",
    "sentence": "八世祖模，晉司空、南陽王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000122",
    "sentence": "模世子保，晉亂出奔涼州，因家焉。",
    "entities": [
      {
        "text": "晉亂出奔涼州",
        "label": "LOC",
        "start": 5,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000123",
    "sentence": "魏平姑臧，徙居於雲中，其自序云爾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000124",
    "sentence": "父興龍，魏魯陽太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000125",
    "sentence": "子如少機警，有口辯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000126",
    "sentence": "好交遊豪傑，與高祖相結托，分義甚深。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000127",
    "sentence": "孝昌中，北州淪陷，子如攜家口南奔肆州，為尒朱榮所禮遇，假以中軍。",
    "entities": [
      {
        "text": "北州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "攜家口南奔肆州",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000128",
    "sentence": "榮之向洛也，以子如為司馬、持節、假平南將軍，監前軍。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000129",
    "sentence": "次高都，榮以建興險阻，往來沖要，有後顧之憂，以子如行建興太守、當郡都督。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 28,
        "end": 30
      },
      {
        "text": "當郡",
        "label": "LOC",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000130",
    "sentence": "永安初，封平遙縣子，邑三百戶，仍為大行臺郎中。",
    "entities": [
      {
        "text": "封平遙縣",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000131",
    "sentence": "榮以子如明辯，能說時事，數遣奉使詣闕，多稱旨，孝莊亦接待焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000132",
    "sentence": "葛榮之亂，相州孤危，榮遣子如間行入鄴，助加防守。",
    "entities": [
      {
        "text": "相州",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000133",
    "sentence": "葛榮平，進爵為侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000134",
    "sentence": "元顥入洛，人情離阻，以子如曾守鄴城，頗有恩信，乃令行相州事。",
    "entities": [
      {
        "text": "以子如曾守鄴城",
        "label": "LOC",
        "start": 10,
        "end": 17
      },
      {
        "text": "乃令行相州",
        "label": "LOC",
        "start": 23,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000135",
    "sentence": "顥平，徵為金紫光祿大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000136",
    "sentence": "尒朱榮之誅，子如知有變，自宮內突出，至榮宅，棄家隨榮妻子與尒朱世隆等走出京城。",
    "entities": [
      {
        "text": "世隆等走出京城",
        "label": "LOC",
        "start": 31,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000137",
    "sentence": "世隆便欲還北，子如曰：「事貴應機，兵不厭詐，天下恟恟，唯強是視，於此際會，不可以弱示人。若必走北，即恐變故隨起，不如分兵守河橋，迴軍向京，出其不意，或可離潰。假不如心，猶足示有餘力，使天下觀聽，懼我威強。」於是世隆還逼京城。",
    "entities": [
      {
        "text": "是世隆還逼京城",
        "label": "LOC",
        "start": 104,
        "end": 111
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000138",
    "sentence": "魏長廣王立，兼尚書右僕射。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000139",
    "sentence": "前廢帝以為侍中、驃騎大將軍、儀同三司，進爵陽平郡公，邑一千七百戶。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 10,
        "end": 13
      },
      {
        "text": "進爵陽平郡",
        "label": "LOC",
        "start": 19,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000140",
    "sentence": "固讓儀同不受。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000141",
    "sentence": "高祖起義信都，世隆等知子如與高祖有舊，疑慮，出為南岐州刺史。",
    "entities": [
      {
        "text": "出為南岐州",
        "label": "LOC",
        "start": 22,
        "end": 27
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000142",
    "sentence": "子如憤恨，泣涕自陳，而不獲免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000143",
    "sentence": "高祖入洛，子如遣使啟賀，仍敘平生舊恩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000144",
    "sentence": "尋追赴京，以為大行臺尚書，朝夕左右，參知軍國。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000145",
    "sentence": "天平初，除左僕射，與侍中高岳、侍中孫騰、右僕射高隆之等共知朝政，甚見信重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000146",
    "sentence": "高祖鎮晉陽，子如時往謁見，待之甚厚，並坐同食，從旦達暮，及其當還，高祖及武明後俱有賚遺，率以為常。",
    "entities": [
      {
        "text": "高祖鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000147",
    "sentence": "子如性既豪爽，兼恃舊恩，簿領之務，與奪任情，公然受納，無所顧憚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000148",
    "sentence": "興和中，以為北道行臺，巡檢諸州，守令已下，委其黜陟。",
    "entities": [
      {
        "text": "巡檢諸州",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000149",
    "sentence": "子如至定州，斬深澤縣令；至冀州，斬東光縣令。",
    "entities": [
      {
        "text": "子如至定州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "至冀州",
        "label": "LOC",
        "start": 12,
        "end": 15
      },
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000150",
    "sentence": "皆稽留時漏，致之極刑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000151",
    "sentence": "若言有進退，少不合意，便令武士頓曳，白刃臨項。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000152",
    "sentence": "士庶惶懼，不知所為。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000153",
    "sentence": "轉尚書令。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000154",
    "sentence": "子如義旗之始，身不參預，直以高祖故舊，遂當委重，意氣甚高，聚斂不息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000155",
    "sentence": "時世宗入輔朝政，內稍嫌之，尋以贓賄為御史中尉崔暹所劾，禁止於尚書省。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000156",
    "sentence": "詔免其大罪，削官爵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000157",
    "sentence": "未幾，起行冀州事。",
    "entities": [
      {
        "text": "起行冀州",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000158",
    "sentence": "子如能自厲改，甚有聲譽，發摘姦偽，僚吏畏伏之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000159",
    "sentence": "轉行幷州事。",
    "entities": [
      {
        "text": "轉行幷州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000160",
    "sentence": "詔復官爵，別封野王縣男，邑二百戶。",
    "entities": [
      {
        "text": "別封野王縣",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000161",
    "sentence": "齊受禪，以有翼贊之功，別封須昌縣公，尋除司空。",
    "entities": [
      {
        "text": "別封須昌縣",
        "label": "LOC",
        "start": 11,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000162",
    "sentence": "子如性滑稽，不治檢裁，言戲穢褻，識者非之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000163",
    "sentence": "而事姊有禮，撫諸兄子慈篤，當時名士並加欽愛，世以此稱之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000164",
    "sentence": "然素無鯁正，不能平心處物。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000165",
    "sentence": "世宗時，中尉崔暹、黃門郎崔季舒俱被任用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000166",
    "sentence": "世宗崩，暹等赴晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000167",
    "sentence": "子如乃啟顯祖，言其罪惡，仍勸誅之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000168",
    "sentence": "其後子如以馬度關，為有司所奏。",
    "entities": [
      {
        "text": "後子如以馬度關",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000169",
    "sentence": "顯祖引子如數讓之曰：「崔暹、季舒事朕先世，有何大罪，卿令我殺之？」因此免官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000170",
    "sentence": "久之，猶以先帝之舊，拜太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000171",
    "sentence": "尋以疾薨，時年六十四。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000172",
    "sentence": "贈使持節、都督冀定瀛滄懷五州諸軍事、太師、太尉、懷州刺史，贈物一千段，諡曰文明。",
    "entities": [
      {
        "text": "冀定瀛滄懷五州",
        "label": "LOC",
        "start": 7,
        "end": 14
      },
      {
        "text": "懷州",
        "label": "LOC",
        "start": 24,
        "end": 26
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000173",
    "sentence": "子消難嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000174",
    "sentence": "尚高祖女，以主婿、貴公子，頻歷中書、黃門郎、光祿少卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000175",
    "sentence": "出為北豫州刺史，鎮武牢。",
    "entities": [
      {
        "text": "出為北豫州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000176",
    "sentence": "消難博涉史傳，有風神，然不能廉潔，在州為御史所劾。",
    "entities": [
      {
        "text": "在州",
        "label": "LOC",
        "start": 17,
        "end": 19
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000177",
    "sentence": "又於公主情好不睦，公主譖訴之，懼罪，遂招延鄰敵，走關西。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "走關",
        "label": "LOC",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000178",
    "sentence": "子如兄纂，先卒，子如貴，贈岳州刺史。",
    "entities": [
      {
        "text": "贈岳州",
        "label": "LOC",
        "start": 12,
        "end": 15
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000179",
    "sentence": "纂長子世雲，輕險無行，累遷衛將軍、潁州刺史。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "潁州",
        "label": "LOC",
        "start": 17,
        "end": 19
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000180",
    "sentence": "世雲本無勳業，直以子如故，頻歷州郡。",
    "entities": [
      {
        "text": "頻歷州郡",
        "label": "LOC",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000181",
    "sentence": "恃叔之勢，所在聚斂，仍肆姦穢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000182",
    "sentence": "將見推治，內懷驚懼，侯景反，遂舉州從之。",
    "entities": [
      {
        "text": "遂舉州",
        "label": "LOC",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000183",
    "sentence": "時世雲母弟在鄴，便傾心附景，無復顧望。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000184",
    "sentence": "諸將圍景於潁川，世雲臨城遙對諸將，言甚不遜。",
    "entities": [
      {
        "text": "世雲臨城",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000185",
    "sentence": "世宗猶以子如恩舊，免其諸弟死罪，徙於北邊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000186",
    "sentence": "侯景於渦陽敗後，世雲復有異志，為景所殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000187",
    "sentence": "世雲弟膺之，字仲慶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000188",
    "sentence": "少好學，美風儀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000189",
    "sentence": "天平中，子如貴盛，膺之自尚書郎歷中書、黃門郎。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000190",
    "sentence": "子如別封須昌縣公，回授膺之。",
    "entities": [
      {
        "text": "子如別封須昌縣",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000191",
    "sentence": "膺之家富於財，厚自封殖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000192",
    "sentence": "王元景、邢子才之流以夙素重之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000193",
    "sentence": "以其疏簡傲物，竟天保世，淪滯不齒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000194",
    "sentence": "幹明中，王曦白肅宗，除衛尉少卿。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 1,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000195",
    "sentence": "河清末，光祿大夫。",
    "entities": [
      {
        "text": "清",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000196",
    "sentence": "患泄利，積年不起，至武平中，猶不堪朝謁，就家拜儀同三司。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000197",
    "sentence": "好讀《 太玄經 》，註揚雄《 蜀都賦 》。",
    "entities": [
      {
        "text": "《 太玄經 》",
        "label": "TITLE",
        "start": 2,
        "end": 9
      },
      {
        "text": "《 蜀都賦 》",
        "label": "TITLE",
        "start": 13,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000198",
    "sentence": "每云：「我欲與揚子雲周旋。」齊亡歲，以利疾終，時年七十一。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 14,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000199",
    "sentence": "膺之弟子瑞，天保中為定州長史，遷吏部郎中。",
    "entities": [
      {
        "text": "天保中為定州",
        "label": "LOC",
        "start": 6,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000200",
    "sentence": "舉清勤平約。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000201",
    "sentence": "遷司徒左長史，兼廷尉卿，以平直稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000202",
    "sentence": "幹明初，領御史中丞，正色舉察，為朝廷所許。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000203",
    "sentence": "以疾去職，就拜祠部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000204",
    "sentence": "卒，贈瀛州刺史，諡曰文節。",
    "entities": [
      {
        "text": "贈瀛州",
        "label": "LOC",
        "start": 2,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000205",
    "sentence": "子瑞弟幼之，清貞有素行，少歷顯位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000206",
    "sentence": "隋開皇中，卒於眉州刺史。",
    "entities": [
      {
        "text": "卒於眉州",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000207",
    "sentence": "子瑞妻，令萱之妹，及令萱得寵於後主，重贈子瑞懷州剌史，諸子亦並居顯職。",
    "entities": [
      {
        "text": "重贈子瑞懷州",
        "label": "LOC",
        "start": 18,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000208",
    "sentence": "同遊，武平末給事黃門侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000209",
    "sentence": "同回，太府卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000210",
    "sentence": "同憲，通直常侍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000211",
    "sentence": "然同遊終為嘉吏，隋開皇中尚書民部侍郎，卒於遂州刺史。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "卒於遂州",
        "label": "LOC",
        "start": 19,
        "end": 23
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000212",
    "sentence": "【史論】",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000213",
    "sentence": "史臣曰：高祖以晉陽戎馬之地，霸圖攸屬，治兵訓旅，遙制朝權，京臺機務，委寄深遠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000214",
    "sentence": "孫騰等俱不能清貞守道，以治亂為懷，厚斂貨財，填彼溪壑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000215",
    "sentence": "昔蕭何之鎮關中，荀彧之居許下，不亦異於是乎！",
    "entities": [
      {
        "text": "昔蕭何之鎮關",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_018_000216",
    "sentence": "賴世宗入輔，責以驕縱，厚遇崔暹，奮其霜簡，不然則君子屬厭，豈易間焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000217",
    "sentence": "孫騰牽裾之誠，有足稱美。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000218",
    "sentence": "隆之勞其志力，經始鄴京，又並是潛德僚寀，早申任遇，崇其名器，未失朝序。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000219",
    "sentence": "子如徒以少相親重，情深昵狎，義非草昧，恩結寵私，勳德莫聞，坐致臺輔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000220",
    "sentence": "猶子之愛，訓以義方，膺之風素可重，幼之清簡自立，有足稱也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000221",
    "sentence": "贊曰：閎、散胥附，蕭、曹扶翼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000222",
    "sentence": "齊運勃興，孫、高陳力。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000223",
    "sentence": "黷貨無厭，多慚袞職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_018_000224",
    "sentence": "司馬滑稽，巧言令色。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
