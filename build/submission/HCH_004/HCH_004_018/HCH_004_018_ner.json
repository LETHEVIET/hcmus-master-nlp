      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 45,
        "end": 47
      },
      {
        "text": "冀定滄瀛殷五州",
        "label": "LOC",
        "start": 61,
        "end": 68
      },
      {
        "text": "尚書",
        "label": "TITLE",
