  },
  {
    "sentence_id": "HCH_004_029_000069",
    "sentence": "渾族子 公緒",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000070",
    "sentence": "公緒，字穆叔，渾族兄籍之子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000071",
    "sentence": "性聰敏，博通經傳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000072",
    "sentence": "魏末冀州司馬，屬疾去官。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000073",
    "sentence": "後以侍御史徵，不至，卒。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000074",
    "sentence": "公緒沉冥樂道，不關世務，故誓心不仕。",
    "entities": [
      {
