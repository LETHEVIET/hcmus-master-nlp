  {
    "sentence_id": "HCH_004_029_000078",
    "sentence": "李璵",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000079",
    "sentence": "李璵，字道璠，隴西成紀人，涼武昭王暠之五世孫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000080",
    "sentence": "父韶，並有重名於魏代。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 8,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000081",
    "sentence": "璵溫雅有識量。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000082",
    "sentence": "釋褐太尉行參軍，累遷司徒右長史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000083",
    "sentence": "及遷都於鄴，留於後，監掌府藏，及撤運宮廟材木，以明幹見稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000084",
    "sentence": "累遷驃騎大將軍、東徐州刺史。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 4,
        "end": 7
      },
      {
        "text": "東徐州",
        "label": "LOC",
        "start": 8,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000085",
    "sentence": "解州還，遂稱老疾，不求仕。",
    "entities": [
      {
        "text": "解州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000086",
    "sentence": "齊受禪，進璵兼前將軍，導從於圓丘行禮。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000087",
    "sentence": "璵意不願策名兩朝，雖以宿舊被徵，過事卽絕朝請。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000088",
    "sentence": "天保四年卒。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000089",
    "sentence": "子詮、韞、誦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000090",
    "sentence": "韞無行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000091",
    "sentence": "誦以女妻穆提婆子懷廆，超遷臨漳令、儀同三司。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000092",
    "sentence": "韞與陸令萱女弟私通，令萱奏授太子舍人。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000093",
    "sentence": "璵弟 瑾",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000094",
    "sentence": "弟瑾，字道瑜，名在《魏書》。",
    "entities": [
      {
        "text": "《魏書》",
        "label": "TITLE",
        "start": 9,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000095",
    "sentence": "才識之美，見稱當代。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000096",
    "sentence": "瑾六子，彥之、倩之、壽之、禮之、行之、凝之，並有器望。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000097",
    "sentence": "行之與兄弟深相友愛，又風素夷簡，為士友所稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000098",
    "sentence": "范陽盧思道是其舅子，嘗贈詩云：「水衡稱逸人，潘楊有世親，形骸預冠蓋，心思出風塵。」時人以為實錄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000099",
    "sentence": "璵從弟 曉",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000100",
    "sentence": "璵從弟曉，字仁略。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000101",
    "sentence": "魏太尉虔子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000102",
    "sentence": "學涉有思理。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000103",
    "sentence": "釋褐員外侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000104",
    "sentence": "尒朱榮之害朝士，將行，曉衣冠為鼠所噬，遂不成行，得免河陰之難。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000105",
    "sentence": "及遷都鄴，曉便寓居清河，託從母兄崔㥄宅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000106",
    "sentence": "給良田三十頃，曉遂築室安居，訓勗子侄，無復宦情。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000107",
    "sentence": "武定末，以世道方泰，乃入都從仕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000108",
    "sentence": "除頓丘守，卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000109",
    "sentence": "鄭述祖",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000110",
    "sentence": "鄭述祖，字恭文，滎陽開封人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000111",
    "sentence": "祖羲，魏中書令。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 3,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000112",
    "sentence": "父道昭，魏秘書監。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000113",
    "sentence": "述祖少聰敏，好屬文，有風檢，為先達所稱譽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000114",
    "sentence": "釋褐司空行參軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000115",
    "sentence": "天保初，累遷太子少師、儀同三司、兗州刺史。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "兗州",
        "label": "LOC",
        "start": 16,
        "end": 18
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000116",
    "sentence": "時穆子容為巡省使，嘆曰：「古人有言：『聞伯夷之風，貪夫廉，懦夫有立。』今於鄭兗州見之矣。」",
    "entities": [
      {
        "text": "今於鄭兗州",
        "label": "LOC",
        "start": 35,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000117",
    "sentence": "初，述祖父為光州，於城南小山起齋亭，刻石為記。",
    "entities": [
      {
        "text": "述祖父為光州",
        "label": "LOC",
        "start": 2,
        "end": 8
      },
      {
        "text": "於城",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000118",
    "sentence": "述祖時年九歲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000119",
    "sentence": "及為刺史，往尋舊跡，得一破石，有銘云：「中嶽先生鄭道昭之白雲堂。」述祖對之嗚咽，悲動群僚。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000120",
    "sentence": "有人入市盜布，其父怒曰：「何忍欺人君！」執之以歸首，述祖特原之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000121",
    "sentence": "自是之後，境內無盜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000122",
    "sentence": "人歌之曰：「大鄭公，小鄭公，相去五十載，風教猶尚同。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000123",
    "sentence": "述祖能鼓琴，自造《龍吟十弄》，云嘗夢人彈琴，寤而寫得。",
    "entities": [
      {
        "text": "《龍吟十弄》",
        "label": "TITLE",
        "start": 8,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000124",
    "sentence": "當時以為絕妙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000125",
    "sentence": "所在好為山池，松竹交植。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000126",
    "sentence": "盛饌以待賓客，將迎不倦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000127",
    "sentence": "未貴時，在鄉單馬出行，忽有騎者數百，見述祖皆下馬，曰「公在此」，行列而拜。",
    "entities": [
      {
        "text": "在鄉",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000128",
    "sentence": "述祖顧問從人，皆不見，心甚異之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000129",
    "sentence": "未幾備徵，終歷顯位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000130",
    "sentence": "及病篤，乃自言之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000131",
    "sentence": "且曰：「吾今老矣，一生富貴足矣，以清白之名遺子孫，死無所恨。」遂卒於州。",
    "entities": [
      {
        "text": "遂卒於州",
        "label": "LOC",
        "start": 31,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000132",
    "sentence": "述祖女為趙郡王叡妃。",
    "entities": [
      {
        "text": "述祖女為趙郡",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000133",
    "sentence": "述祖常坐受王拜，命坐，王乃坐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000134",
    "sentence": "妃薨後，王更娶鄭道蔭女。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000135",
    "sentence": "王坐受道蔭拜，王命坐，乃敢坐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000136",
    "sentence": "王謂道蔭曰：「鄭尚書風德如此，又貴重宿舊，君不得譬之。」",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000137",
    "sentence": "述祖子 元德",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000138",
    "sentence": "子元德，多藝術，官至瑯邪守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000139",
    "sentence": "述祖從子 元禮",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000140",
    "sentence": "元德從父弟元禮，字文規。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000141",
    "sentence": "少好學，愛文藻，有名望。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000142",
    "sentence": "世宗引為館客，歷太子舍人。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_029_000143",
    "sentence": "崔昂妻，卽元禮之姊也，魏收又昂之妹夫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_029_000144",
    "sentence": "昂嘗持元禮數篇詩示盧思道，乃謂思道云：「看元禮比來詩詠，亦當不減魏收？」答云：「未覺元禮賢於魏收，但知妹夫疏於婦弟。」元禮入周，卒於始州別駕。",
