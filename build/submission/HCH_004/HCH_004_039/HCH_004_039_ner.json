    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000104",
    "sentence": "又奏造胡桃油，復爲割藏免官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000105",
    "sentence": "文宣毎見之，常呼爲賊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000106",
    "sentence": "文宣崩，普選勞舊，除爲寧武太守。",
