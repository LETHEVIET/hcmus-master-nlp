[
  {
    "sentence_id": "HCH_004_039_000001",
    "sentence": "崔季舒",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000002",
    "sentence": "崔季舒，字叔正，博陵安平人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000003",
    "sentence": "父瑜之，魏鴻臚卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000004",
    "sentence": "季舒少孤，性明敏，渉獵經史，長於尺牘，有當世才具。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000005",
    "sentence": "年十七，爲州主簿，爲大將軍趙郡公琛所器重，言之於神武。",
    "entities": [
      {
        "text": "爲州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000006",
    "sentence": "神武親簡丞郎，補季舒大行臺都官郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000007",
    "sentence": "文襄輔政，轉大將軍中兵參軍，甚見親寵。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000008",
    "sentence": "以魏帝左右，須置腹心，擢拜中書侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000009",
    "sentence": "文襄爲中書監，移門下機事總歸中書，又季舒善音樂，故内伎亦通隸焉，内伎屬中書。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000010",
    "sentence": "自季舒始也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000011",
    "sentence": "文襄毎進書魏帝，有所諫請，或文辭繁雜，季舒輒修飾通之，得申勸戒而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000012",
    "sentence": "靜帝報答霸朝，恒與季舒論之，云：「崔中書是我妳母。」轉黃門侍郎，領主衣都統。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000013",
    "sentence": "雖迹在魏朝，而心歸霸府，密謀大計，皆得預聞。",
    "entities": [
      {
        "text": "魏朝",
        "label": "ORG",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000014",
    "sentence": "於是賓客輻湊，傾心接禮，甚得名譽，勢傾崔暹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000015",
    "sentence": "暹嘗於朝堂屛人拜之曰：「暹若得僕射，皆叔父之恩。」其權重如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000016",
    "sentence": "時勳貴多不法，文襄無所縱捨，外議以季舒及崔暹等所爲，甚被怨疾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000017",
    "sentence": "及文襄遇難，文宣將赴晉陽，黃門郎陽休之勸季舒從行，曰：「一日不朝，其間容刀。」季舒性愛聲色，心在閑放，遂不請行，欲恣其行樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000018",
    "sentence": "司馬子如縁宿憾，及尚食典御陳山提等共列其過狀，由是季舒及暹各鞭二百，徙北邊。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000019",
    "sentence": "天保初，文宣知其無罪，追爲將作大匠，再遷侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000020",
    "sentence": "俄兼尚書左僕射、儀同三司，大被恩遇。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000021",
    "sentence": "乾明初，楊愔以文宣遺旨，停其僕射。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 1,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000022",
    "sentence": "遭母喪解任，起復，除光祿勳，兼中兵尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000023",
    "sentence": "出爲齊州刺史，坐遣人渡淮互市，亦有贓賄事，爲御史所劾，會赦不問。",
    "entities": [
      {
        "text": "出爲齊州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000024",
    "sentence": "武成居藩，曾病，文宣令季舒療病，備盡心力。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000025",
    "sentence": "大寧初，追還，引入慰勉，累拜度支尚書、開府儀同三司。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000026",
    "sentence": "營昭陽殿，敕令監造。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000027",
    "sentence": "以判事式爲胡長仁密言其短，出爲西兗州刺史。",
    "entities": [
      {
        "text": "出爲西兗州",
        "label": "LOC",
        "start": 13,
        "end": 18
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000028",
    "sentence": "爲進典籖於吏部，被責免官，又以詣廣寧王宅，決馬鞭數十。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000029",
    "sentence": "及武成崩，不得預於哭泣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000030",
    "sentence": "久之，除膠州刺史，遷侍中、開府，食新安、河陰二郡幹。",
    "entities": [
      {
        "text": "除膠州",
        "label": "LOC",
        "start": 3,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "河陰二郡",
        "label": "LOC",
        "start": 20,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000031",
    "sentence": "加左光祿大夫，待詔文林館，監撰《御覽》。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "《御覽》",
        "label": "TITLE",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000032",
    "sentence": "加特進、監國史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000033",
    "sentence": "季舒素好圖籍，暮年轉更精勤，兼推薦人士，獎勸文學，時議翕然，遠近稱美。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000034",
    "sentence": "祖珽受委，奏季舒總監内作。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000035",
    "sentence": "珽被出，韓長鸞以爲珽黨，亦欲出之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000036",
    "sentence": "屬車駕將適晉陽，季舒與張雕議：以爲壽春被圍，大軍出拒，信使往還，須稟節度；兼道路小人，或相驚恐，云大駕向幷，畏避南寇；若不啓諫，必動人情。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000037",
    "sentence": "遂與從駕文官連名進諫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000038",
    "sentence": "時貴臣趙彦深、唐邕、段孝言等初亦同心，臨時疑貳，季舒與爭未決。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000039",
    "sentence": "長鸞遂奏云：「漢兒文官連名總署，聲云諫止向幷，其實未必不反，宜加誅戮。」帝卽召已署表官人集含章殿，以季舒、張雕、劉逖、封孝琰、裴澤、郭遵等爲首，並斬之殿庭，長鸞令棄其屍於漳水。",
    "entities": [
      {
        "text": "封孝琰",
        "label": "PER",
        "start": 59,
        "end": 62
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000040",
    "sentence": "自外同署，將加鞭撻，趙彦深執諫獲免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000041",
    "sentence": "季舒等家屬男女徙北邊，妻女子婦配奚官，小男下蠶室，沒入貲産。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000042",
    "sentence": "季舒大好醫術，天保中，於徙所無事，更鋭意研精，遂爲名手，多所全濟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000043",
    "sentence": "雖位望轉髙，未曾懈怠，縱貧賤廝養，亦爲之療。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000044",
    "sentence": "庶子長君，尚書右外兵郎中。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000045",
    "sentence": "次鏡玄，著作佐郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000046",
    "sentence": "並流於遠惡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000047",
    "sentence": "未幾，季舒等六人妻以年老放出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000048",
    "sentence": "後南安王思好更稱朝廷罪惡，以季舒等見害爲詞，悉召六人兄弟子姪隨軍趣晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000049",
    "sentence": "事敗，長君等並從戮，六人妻又追入官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000050",
    "sentence": "周武帝滅齊，詔斛律光與季舒等六人同被優贈，季舒贈開府儀同大將軍、定州刺史云。",
    "entities": [
      {
        "text": "斛律光",
        "label": "PER",
        "start": 7,
        "end": 10
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 28,
        "end": 31
      },
      {
        "text": "定州",
        "label": "LOC",
        "start": 32,
        "end": 34
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 34,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000051",
    "sentence": "祖珽",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000052",
    "sentence": "祖珽，字孝征，范陽狄遒人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000053",
    "sentence": "父瑩，魏護軍將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000054",
    "sentence": "珽神情機警，詞藻遒逸，少馳令譽，爲世所推。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000055",
    "sentence": "起家秘書郎，對策髙第，爲尚書儀曹郎中，典儀注。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000056",
    "sentence": "嘗爲冀州刺史万俟受洛制《淸德頌》，其文典麗，由是神武聞之。",
    "entities": [
      {
        "text": "嘗爲冀州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "《淸德頌》",
        "label": "TITLE",
        "start": 11,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000057",
    "sentence": "時文宣爲幷州刺史，署珽開府倉曹參軍。",
    "entities": [
      {
        "text": "時文宣爲幷州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000058",
    "sentence": "神武口授珽三十六事，出而疎之，一無遺失，大爲僚類所賞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000059",
    "sentence": "時神武送魏蘭陵公主出塞嫁蠕蠕，魏收賦《出塞》及《公主遠嫁詩》二首，珽皆和之，大爲時人傳詠。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "《出塞》",
        "label": "TITLE",
        "start": 18,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000060",
    "sentence": "珽性疎率，不能廉愼守道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000061",
    "sentence": "倉曹雖云州局，乃受山東課輸，由此大有受納，豐於財産。",
    "entities": [
      {
        "text": "倉曹雖云州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000062",
    "sentence": "又自解彈琵琶，能爲新曲，招城市年少歌舞爲娯，遊集諸倡家。",
    "entities": [
      {
        "text": "招城",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000063",
    "sentence": "與陳元康、穆子容、任胄、元士亮等爲聲色之遊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000064",
    "sentence": "諸人嘗就珽宿，出山東大文綾幷連珠孔雀羅等百餘疋，令諸嫗擲樗蒲賭之，以爲戲樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000065",
    "sentence": "參軍元景獻，故尚書令元世雋子也，其妻司馬慶雲女，是魏孝靜帝姑博陵長公主所生。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000066",
    "sentence": "珽忽迎景獻妻赴席，與諸人遞寢，亦以貨物所致。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000067",
    "sentence": "其豪縱淫逸如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000068",
    "sentence": "常云：「丈夫一生不負身。」已文宣罷州，珽例應隨府，規爲倉局之間，致請於陳元康，元康爲白，由是還任倉曹。",
    "entities": [
      {
        "text": "已文宣罷州",
        "label": "LOC",
        "start": 13,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000069",
    "sentence": "珽又委體附參軍事攝典簽陸子先，並爲畫計，請糧之際，令子先宣教，出倉粟十車，爲僚官捉送。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000070",
    "sentence": "神武親問之，珽自言不受署，歸罪子先，神武信而釋之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000071",
    "sentence": "珽出而言曰：「此丞相天縁明鑒，然實孝徴所爲。」性不羈放縱，曾至膠州刺史司馬世雲家飲酒，遂藏銅疊二面。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "曾至膠州",
        "label": "LOC",
        "start": 29,
        "end": 33
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 33,
        "end": 35
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 35,
        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000072",
    "sentence": "廚人請搜諸客，果於珽懷中得之，見者以爲深恥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000073",
    "sentence": "所乘老馬，常稱騮駒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000074",
    "sentence": "又與寡婦王氏姦通，毎人前相聞往復。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000075",
    "sentence": "裴讓之與珽早狎，於衆中嘲珽曰：「卿那得如此詭異，老馬十歳，猶號騮駒；一妻耳順，尚稱娘子。」于時喧然傳之。",
    "entities": [
      {
        "text": "裴讓之",
