      }
    ]
  },
  {
    "sentence_id": "HCH_004_039_000096",
    "sentence": "薄晩，就家掩之，縛珽送廷尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000097",
    "sentence": "據犯枉法處絞刑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000098",
    "sentence": "文宣以珽伏事先世，諷所司命特寬其罰，遂奏免死除名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_039_000099",
    "sentence": "天保元年，復被召從駕，依除免例，參於晉陽。",
