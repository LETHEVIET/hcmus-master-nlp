[
  {
    "sentence_id": "HCH_004_011_000001",
    "sentence": "文襄六男：文敬元皇后生河間王孝琬，宋氏生河南王孝瑜，王氏生廣寧王孝珩，蘭陵王長恭不得母氏姓，陳氏生安德王延宗，燕氏生漁陽王紹信。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "宋氏",
