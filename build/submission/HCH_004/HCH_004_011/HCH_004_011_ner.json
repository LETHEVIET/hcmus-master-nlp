        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000032",
    "sentence": "孝珩愛賞人物，學涉經史，好綴文，有伎藝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000033",
    "sentence": "嘗於廳事壁自畫一蒼鷹，見者皆以為真，又作朝士圖，亦當時之妙絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000034",
    "sentence": "後主自晉州敗奔鄴，詔王公議於含光殿。",
    "entities": [
      {
        "text": "後主自晉州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000035",
    "sentence": "孝珩以大敵既深，事藉機變。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000036",
    "sentence": "宜使任城王領幽州道兵入土門，揚聲趣并州；獨孤永業領洛州兵趣潼關，揚聲趣長安；臣請領京畿兵出滏口，鼓行逆戰。",
    "entities": [
      {
        "text": "宜使任城",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "王領幽州",
        "label": "LOC",
        "start": 4,
        "end": 8
      },
      {
        "text": "揚聲趣并州",
        "label": "LOC",
        "start": 14,
        "end": 19
      },
      {
        "text": "獨孤永業領洛州",
        "label": "LOC",
        "start": 20,
        "end": 27
      },
      {
        "text": "兵趣潼關",
        "label": "LOC",
        "start": 27,
        "end": 31
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 35,
        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000037",
    "sentence": "敵聞南北有兵，自然潰散。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000038",
    "sentence": "又請出宮人珍寶賜將士，帝不能用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000039",
    "sentence": "承光即位，以孝珩為太宰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000040",
    "sentence": "與呼延族、莫多婁敬顯、尉相願同謀，期正月五日 [ 2 ] ，孝珩於千秋門斬高阿那肱，相願在內以禁兵應之，族與敬顯自遊豫園勒兵出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000041",
    "sentence": "既而阿那肱從別宅取便路入宮，事不果。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000042",
    "sentence": "乃求出拒西軍，謂阿那肱、韓長鸞、陳德信等云：「朝廷不賜遣擊賊，豈不畏孝珩反耶？孝珩破宇文邕，遂至長安，反時何與國家事。以今日之急，猶作如此猜疑。」高、韓恐其變，出孝珩為滄州刺史。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 48,
        "end": 50
      },
      {
        "text": "出孝珩為滄州",
        "label": "LOC",
        "start": 80,
        "end": 86
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 86,
        "end": 88
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000043",
    "sentence": "至州，以五千人會任城王於信都，共為匡復計。",
    "entities": [
      {
        "text": "至州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "以五千人會任城",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000044",
    "sentence": "周齊王憲來伐，兵弱不能敵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000045",
    "sentence": "怒曰：「由高阿那肱小人，吾道窮矣！」齊叛臣乞扶令和以矟刺孝珩墜馬，奴白澤以身扞之，孝珩猶傷數處，遂見虜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000046",
    "sentence": "齊王憲問孝珩齊亡所由，孝珩自陳國難，辭淚俱下，俯仰有節。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 6,
        "end": 7
      },
      {
        "text": "陳國",
        "label": "ORG",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000047",
    "sentence": "憲為之改容，親為洗創傅藥，禮遇甚厚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000048",
    "sentence": "孝珩獨歎曰：「李穆叔言齊氏二十八年，今果然矣。自神武皇帝以外，吾諸父兄弟無一人得至四十者，命也。嗣君無獨見之明，宰相非柱石之寄，恨不得握兵符，受廟算，展我心力耳。」至長安，依例授開府、縣侯。",
    "entities": [
      {
        "text": "齊氏",
        "label": "ORG",
        "start": 11,
        "end": 13
      },
      {
        "text": "二十八年",
        "label": "TME",
