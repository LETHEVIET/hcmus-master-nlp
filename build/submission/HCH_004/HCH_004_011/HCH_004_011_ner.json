        "end": 19
      },
      {
        "text": "陳氏",
        "label": "ORG",
        "start": 46,
        "end": 48
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000002",
    "sentence": "河南康献王",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000003",
    "sentence": "河南康献王孝瑜，字正德，文襄長子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000004",
    "sentence": "初封河南郡公，齊受禪，進爵為王。",
    "entities": [
      {
        "text": "初封河南郡",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000005",
    "sentence": "歷位中書令、司州牧。",
    "entities": [
      {
        "text": "司州",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000006",
    "sentence": "初，孝瑜養於神武宮中，與武成同年相愛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000007",
    "sentence": "將誅楊愔等，孝瑜預其謀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000008",
    "sentence": "及武成即位，禮遇特隆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000009",
    "sentence": "帝在晉陽，手勑之曰：「吾飲汾清二盃，勸汝於鄴酌兩盃。」其親愛如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000010",
    "sentence": "孝瑜容貌魁偉，精彩雄毅，謙慎寬厚，兼愛文學，讀書敏速，十行俱下，覆缱不失一道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000011",
    "sentence": "初，文襄於鄴東起山池遊觀，時俗眩之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000012",
    "sentence": "孝瑜遂於第作水堂、龍舟，植幡矟於舟上，數集諸弟宴射為樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000013",
    "sentence": "武成幸其第，見而悅之，故盛興後園之玩，於是貴賤慕矅，處處營造。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000014",
    "sentence": "武成常使和士開與胡后對坐握槊，孝瑜諫曰：「皇后天下之母，不可與臣下接手。」帝深納之。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000015",
    "sentence": "後又言趙郡王父死非命，不可親。",
    "entities": [
      {
        "text": "後又言趙郡",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000016",
    "sentence": "由是叡及士開皆側目。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000017",
    "sentence": "士開密告其奢僭，叡又言山東唯聞河南王，不聞有陛下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000018",
    "sentence": "帝由是忌之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000019",
    "sentence": "尒朱御女名摩女，本事太后，孝瑜先與之通，後因太子婚夜，孝瑜竊與之言。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000020",
    "sentence": "武成大怒，頓飲其酒三十七盃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000021",
    "sentence": "體至肥大，腰帶十圍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000022",
    "sentence": "使婁子彥載以出，酖之於車。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000023",
    "sentence": "至西華門，煩熱躁悶，投水而絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000024",
    "sentence": "贈太尉、錄尚書事。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000025",
    "sentence": "子弘節嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000026",
    "sentence": "孝瑜母，魏吏部尚書宋弁孫也，本魏潁川王斌之妃，為文襄所納，生孝瑜，孝瑜還第，為太妃。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000027",
    "sentence": "孝瑜妃，盧正山女，武成胡后之內姊也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000028",
    "sentence": "孝瑜薨後，宋太妃為盧妃所譖訴，武成殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000029",
    "sentence": "廣寧王",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000030",
    "sentence": "廣寧王孝珩，文襄第二子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000031",
    "sentence": "歷位司州牧、尚書令、司空、司徒、錄尚書、大將軍、大司馬。",
    "entities": [
      {
