        "label": "LOC",
        "start": 83,
        "end": 85
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000049",
    "sentence": "後周武帝在雲陽，宴齊君臣，自彈胡琵琶，命孝珩吹笛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000050",
    "sentence": "辭曰：「亡國之音，不足聽也。」固命之，舉笛裁至口，淚下嗚咽，武帝乃止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000051",
    "sentence": "其年十月，疾甚，啟歸葬山東，從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000052",
    "sentence": "尋卒，令還葬鄴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000053",
    "sentence": "河間王",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000054",
    "sentence": "河間王孝琬，文襄第三子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000055",
    "sentence": "天保元年 封。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000056",
    "sentence": "天統中，累遷尚書令。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000057",
    "sentence": "初，突厥與周師入太原，武成將避之而東。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000058",
    "sentence": "孝琬叩馬諫，請委趙郡王部分之，必整齊，帝從其言。",
    "entities": [
      {
        "text": "請委趙郡",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_011_000059",
    "sentence": "孝琬免冑將出，帝使追還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_011_000060",
    "sentence": "周軍退，拜并州刺史。",
    "entities": [
      {
        "text": "拜并州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
