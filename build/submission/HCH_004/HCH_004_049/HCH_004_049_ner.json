  {
    "sentence_id": "HCH_004_049_000033",
    "sentence": "信都芳，河間人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_049_000034",
    "sentence": "少明算術，為州裏所稱。",
    "entities": [
