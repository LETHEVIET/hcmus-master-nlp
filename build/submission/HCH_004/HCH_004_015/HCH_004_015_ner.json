[
  {
    "sentence_id": "HCH_004_015_000001",
    "sentence": "竇泰",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000002",
    "sentence": "竇泰，字世寧，大安捍殊人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000003",
    "sentence": "本出清河觀津，曾祖羅，魏統萬鎮將，因居北邊。",
    "entities": [
      {
        "text": "魏統萬鎮",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000004",
    "sentence": "父樂，魏末破六韓拔陵為亂，與鎮將楊鈞固守，遇害。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 3,
        "end": 4
      },
      {
        "text": "與鎮",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000005",
    "sentence": "泰貴，追贈司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000006",
    "sentence": "初，泰母夢風雷暴起，若有雨狀，出庭觀之，見電光奪目，駛雨霑灑，寤而驚汗，遂有娠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000007",
    "sentence": "期而不產，大懼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000008",
    "sentence": "有巫曰：「渡河湔裙，產子必易。」便向水所。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000009",
    "sentence": "忽見一人，曰：「當生貴子，可徙而南。」泰母從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000010",
    "sentence": "俄而生泰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000011",
    "sentence": "及長，善騎射，有勇略。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000012",
    "sentence": "泰父兄戰歿於鎮，泰身負骸骨歸尒朱榮。",
    "entities": [
      {
        "text": "泰父兄戰歿於鎮",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000013",
    "sentence": "以從討邢杲功，賜爵廣阿子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000014",
    "sentence": "神武之為晉州，請泰為鎮城都督，參謀軍事。",
    "entities": [
      {
        "text": "神武之為晉州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "請泰為鎮城",
        "label": "LOC",
        "start": 7,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000015",
    "sentence": "累遷侍中、京畿大都督，尋領御史中尉。",
    "entities": [
      {
        "text": "大都",
        "label": "LOC",
        "start": 7,
        "end": 9
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000016",
    "sentence": "泰以勳戚居臺，雖無多糾舉，而百僚畏懼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000017",
    "sentence": "天平三年，神武西討，令泰自潼關入。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "令泰自潼關",
        "label": "LOC",
        "start": 10,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000018",
    "sentence": "四年，泰至小關，為周文帝所襲，衆盡沒，泰自殺。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "泰至小關",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000019",
    "sentence": "初，泰將發鄴，鄴有惠化尼謠云：「竇行臺，去不回。」未行之前，夜三更，忽有朱衣冠幘數千人入臺，云「收竇中尉」，宿直兵吏皆驚，其人入數屋，俄頃而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000020",
    "sentence": "旦視關鍵不異，方知非人。",
    "entities": [
      {
        "text": "旦視關",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000021",
    "sentence": "皆知其必敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000022",
    "sentence": "贈大司馬、太尉、錄尚書事，諡曰武貞。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000023",
    "sentence": "泰妻，武明婁后妹也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000024",
    "sentence": "泰雖以親見待，而功名自建。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000025",
    "sentence": "齊受禪，祭告其墓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000026",
    "sentence": "皇建初，配享神武廟庭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000027",
    "sentence": "子孝敬嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000028",
    "sentence": "位儀同三司。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000029",
    "sentence": "尉景",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000030",
    "sentence": "尉景，字士真，善無人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000031",
    "sentence": "秦、漢置尉候官，其先有居此職者，因以氏焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000032",
    "sentence": "景性溫厚，頗有俠氣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000033",
    "sentence": "魏孝昌中，北鎮反，景與神武入杜洛周軍中，仍共歸尒朱榮。",
    "entities": [
      {
        "text": "北鎮",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000034",
    "sentence": "以軍功封博野縣伯。",
    "entities": [
      {
        "text": "以軍功封博野縣",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000035",
    "sentence": "後從神武起兵信都。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000036",
    "sentence": "韓陵之戰，唯景所統失利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000037",
    "sentence": "神武入洛，留景鎮鄴。",
    "entities": [
      {
        "text": "留景鎮",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000038",
    "sentence": "尋進封為公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000039",
    "sentence": "景妻常山君，神武之姊也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000040",
    "sentence": "以勳戚，每有軍事，與厙狄干常被委重，而不能忘懷財利，神武每嫌責之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000041",
    "sentence": "轉冀州刺史，又大納賄，發夫獵，死者三百人。",
    "entities": [
      {
        "text": "轉冀州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000042",
    "sentence": "厙狄干與景在神武坐，請作御史中尉。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000043",
    "sentence": "神武曰：「何意下求卑官？」干曰：「欲捉尉景。」神武大笑，令優者石董桶戲之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000044",
    "sentence": "董桶剝景衣，曰：「公剝百姓，董桶何為不剝公！」神武誡景曰：「可以無貪也。」景曰：「與爾計生活孰多，我止人上取，爾割天子調。」神武笑不答。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000045",
    "sentence": "改長樂郡公。",
    "entities": [
      {
        "text": "改長樂郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000046",
    "sentence": "歷位太保、太傅，坐匿亡人見禁止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000047",
    "sentence": "使崔暹謂文襄曰：「語阿惠兒，富貴欲殺我耶！」神武聞之泣，詣闕曰：「臣非尉景，無以至今日。」三請，帝乃許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000048",
    "sentence": "於是黜為驃騎大將軍、開府儀同三司。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000049",
    "sentence": "神武造之，景恚臥不動，叫曰：「殺我時趣耶！」常山君謂神武曰：「老人去死近，何忍煎迫至此。」又曰：「我為爾汲水胝生。」因出其掌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000050",
    "sentence": "神武撫景，為之屈膝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000051",
    "sentence": "先是，景有果下馬，文襄求之，景不與，曰：「土相扶為墻，人相扶為王，一馬亦不得畜而索也。」神武對景及常山君責文襄而杖之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000052",
    "sentence": "常山君泣救之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000053",
    "sentence": "景曰：「小兒慣去，放使作心腹，何須干啼濕哭不聽打耶！」尋授青州刺史，操行頗改，百姓安之。",
    "entities": [
      {
        "text": "尋授青州",
        "label": "LOC",
        "start": 27,
        "end": 31
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000054",
    "sentence": "徵授大司馬。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000055",
    "sentence": "遇疾，薨於州。",
    "entities": [
      {
        "text": "薨於州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000056",
    "sentence": "贈太師、尚書令。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000057",
    "sentence": "齊受禪，以景元勳，詔祭告其墓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000058",
    "sentence": "皇建初，配享神武廟庭，追封長樂王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000059",
    "sentence": "子粲，少歷顯職，性粗武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000060",
    "sentence": "天保初，封厙狄干等為王，粲以父不預王爵，大恚恨，十餘日閉門不朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000061",
    "sentence": "帝怪，遣使就宅問之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000062",
    "sentence": "隔門謂使者曰：「天子不封粲父為王，粲不如死。」使云：「須開門受勑。」粲遂彎弓隔門射使者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000063",
    "sentence": "使者以狀聞之，文宣使段韶諭旨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000064",
    "sentence": "粲見韶，唯撫膺大哭，不答一言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000065",
    "sentence": "文宣親詣其宅慰之，方復朝請。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000066",
    "sentence": "尋追封景長樂王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000067",
    "sentence": "粲襲爵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000068",
    "sentence": "位司徒、太傅，薨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000069",
    "sentence": "子世辯嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000070",
    "sentence": "周師將入鄴，令辯出千餘騎覘候，出滏口，登高阜西望，遙見群烏飛起，謂是西軍旗幟，即馳還，比至紫陌橋，不敢回顧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000071",
    "sentence": "隋開皇中，卒於浙州刺史。",
    "entities": [
      {
        "text": "卒於浙州",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000072",
    "sentence": "婁昭",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000073",
    "sentence": "婁昭，字菩薩，代郡平城人也，武明皇後之母弟也。",
    "entities": [
      {
        "text": "代郡平城",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000074",
    "sentence": "祖父提，雄傑有識度，家僮千數，牛馬以谷量。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000075",
    "sentence": "性好周給，士多歸附之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000076",
    "sentence": "魏太武時，以功封真定侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000077",
    "sentence": "父內干，有武力，未仕而卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000078",
    "sentence": "昭貴，魏朝贈司徒。",
    "entities": [
      {
        "text": "魏朝",
        "label": "ORG",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000079",
    "sentence": "齊受禪，追封太原王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000080",
    "sentence": "昭方雅正直，有大度深謀，腰帶八尺，弓馬冠世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000081",
    "sentence": "神武少親重之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000082",
    "sentence": "昭亦早識人，恒曲盡禮敬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000083",
    "sentence": "數隨神武獵，每致請不宜乘危歷階。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000084",
    "sentence": "神武將出信都，昭贊成大策，卽以為中軍大都督。",
    "entities": [
      {
        "text": "大都",
        "label": "LOC",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000085",
    "sentence": "從破尒朱兆於廣阿，封安喜縣伯，改濟北公，又徙濮陽郡公，授領軍將軍。",
    "entities": [
      {
        "text": "封安喜縣",
        "label": "LOC",
        "start": 9,
        "end": 13
      },
      {
        "text": "又徙濮陽郡",
        "label": "LOC",
        "start": 20,
        "end": 25
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000086",
    "sentence": "魏孝武將貳於神武，昭以疾辭還晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000087",
    "sentence": "從神武入洛，兗州刺史樊子鵠反，以昭為東道大都督討之。",
    "entities": [
      {
        "text": "兗州",
        "label": "LOC",
        "start": 6,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000088",
    "sentence": "子鵠既死，諸將勸昭盡捕誅其黨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000089",
    "sentence": "昭曰：「此州無狀，橫被殘賊，其君是怨，其人何罪。」遂皆捨焉。",
    "entities": [
      {
        "text": "此州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000090",
    "sentence": "後轉大司馬，仍領軍。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000091",
    "sentence": "遷司徒，出為定州刺史。",
    "entities": [
      {
        "text": "出為定州",
        "label": "LOC",
        "start": 4,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000092",
    "sentence": "昭好酒，晚得偏風，雖愈，猶不能處劇務，在州事委僚屬，昭舉其大綱而已。",
    "entities": [
      {
        "text": "在州",
        "label": "LOC",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000093",
    "sentence": "薨於州。",
    "entities": [
      {
        "text": "薨於州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000094",
    "sentence": "贈假黃鉞、太師、太尉，諡曰武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000095",
    "sentence": "齊受禪，詔祭告其墓，封太原王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000096",
    "sentence": "皇建初，配享神武廟庭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000097",
    "sentence": "長子仲達嗣，改封濮陽王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000098",
    "sentence": "次子定遠，少歷顯職，外戚中偏為武成愛狎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000099",
    "sentence": "別封臨淮郡王。",
    "entities": [
      {
        "text": "別封臨淮郡",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000100",
    "sentence": "武成大漸，與趙郡王等同受顧命，位司空。",
    "entities": [
      {
        "text": "與趙郡",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000101",
    "sentence": "趙郡王之奏黜和士開，定遠與其謀，遂納士開賄賂，成趙郡之禍，其貪鄙如此。",
    "entities": [
      {
        "text": "趙郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "成趙郡",
        "label": "LOC",
        "start": 23,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000102",
    "sentence": "尋除瀛州刺史。",
    "entities": [
      {
        "text": "尋除瀛州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000103",
    "sentence": "初，定遠弟季略，穆提婆求其伎妾，定遠不許。",
    "entities": [
      {
        "text": "穆提婆",
        "label": "PER",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000104",
    "sentence": "因高思好作亂，提婆令臨淮國郎中令告定遠陰與思好通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000105",
    "sentence": "後主令開府段暢率三千騎掩之，令侍御史趙秀通至州，以贓貨事劾定遠。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000106",
    "sentence": "定遠疑有變，遂縊而死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000107",
    "sentence": "兄子　叡",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000108",
    "sentence": "昭兄子叡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000109",
    "sentence": "叡字佛仁，父拔，魏南部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000110",
    "sentence": "叡幼孤，被叔父昭所養。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000111",
    "sentence": "為神武帳內都督，封掖縣子，累遷光州刺史。",
    "entities": [
      {
        "text": "封掖縣",
        "label": "LOC",
        "start": 8,
        "end": 11
      },
      {
        "text": "累遷光州",
        "label": "LOC",
        "start": 13,
        "end": 17
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000112",
    "sentence": "在任貪縱，深為文襄所責。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000113",
    "sentence": "後改封九門縣公。",
    "entities": [
      {
        "text": "後改封九門縣",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000114",
    "sentence": "齊受禪，得除領軍將軍，別封安定侯。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000115",
    "sentence": "叡無他器干，以外戚貴幸，縱情財色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000116",
    "sentence": "為瀛州刺史，聚斂無厭。",
    "entities": [
      {
        "text": "為瀛州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000117",
    "sentence": "皇建初，封東安王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000118",
    "sentence": "大寧元年，進位司空。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000119",
    "sentence": "平高歸彥於冀州，還拜司徒。",
    "entities": [
      {
        "text": "平高歸彥於冀州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000120",
    "sentence": "河清三年，濫殺人，為尚書左丞宋仲羨彈奏，經赦乃免。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "宋仲羨",
        "label": "PER",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000121",
    "sentence": "尋為太尉，以軍功進大司馬。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000122",
    "sentence": "武成至河陽，仍遣總偏師赴懸瓠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000123",
    "sentence": "叡在豫境留停百餘日，專行非法，詔免官，以王還第。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000124",
    "sentence": "尋除太尉，薨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000125",
    "sentence": "贈大司馬。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000126",
    "sentence": "子子彥嗣，位開府儀同三司。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000127",
    "sentence": "厙狄干",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000128",
    "sentence": "厙狄干，善無人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000129",
    "sentence": "曾祖越豆眷，魏道武時以功割善無之西臘汙山地方百里以處之，後率部北遷，因家朔方。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000130",
    "sentence": "干梗直少言，有武藝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000131",
    "sentence": "魏正光初，除掃逆黨，授將軍，宿衛於內。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000132",
    "sentence": "以家在寒鄉，不宜毒暑，冬得入京師，夏歸鄉里。",
    "entities": [
      {
        "text": "以家在寒鄉",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "夏歸鄉",
        "label": "LOC",
        "start": 17,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000133",
    "sentence": "孝昌元年，北邊擾亂，奔雲中，為刺史費穆送於尒朱榮。",
    "entities": [
      {
        "text": "孝昌元年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000134",
    "sentence": "以軍主隨榮入洛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000135",
    "sentence": "後從神武起兵，破四胡於韓陵，封廣平縣公，尋進郡公。",
    "entities": [
      {
        "text": "封廣平縣",
        "label": "LOC",
        "start": 14,
        "end": 18
      },
      {
        "text": "尋進郡",
        "label": "LOC",
        "start": 20,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000136",
    "sentence": "河陰之役，諸將大捷，唯干兵退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000137",
    "sentence": "神武以其舊功，竟不責黜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000138",
    "sentence": "尋轉太保、太傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000139",
    "sentence": "及高仲密以武牢叛，神武討之，以干為大都督前驅。",
    "entities": [
      {
        "text": "大都",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000140",
    "sentence": "干上道不過家，見侯景不遑食，景使騎追饋之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000141",
    "sentence": "時文帝自將兵至洛陽，軍容甚盛。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000142",
    "sentence": "諸將未欲南度，干決計濟河。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000143",
    "sentence": "神武大兵繼至，遂大破之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000144",
    "sentence": "還為定州刺史。",
    "entities": [
      {
        "text": "還為定州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000145",
    "sentence": "不閑吏事，事多擾煩，然清約自居，不為吏人所患。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000146",
    "sentence": "遷太師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000147",
    "sentence": "天保初，以天平元勳佐命，封章武郡王，轉太宰。",
    "entities": [
      {
        "text": "封章武郡",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000148",
    "sentence": "干尚神武妹樂陵長公主，以親地見待。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000149",
    "sentence": "自預勤王，常總大衆，威望之重，為諸將所伏，而最為嚴猛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000150",
    "sentence": "會詣京師，魏譙王元孝友於公門言戲過度，諸公無能面折者，干正色責之，孝友大慚，時人稱之。",
    "entities": [
      {
        "text": "元孝友",
        "label": "PER",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000151",
    "sentence": "薨，贈假黃鉞，太宰，給轀輬車，諡曰景烈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000152",
    "sentence": "干不知書，署名為「干」字，逆上畫之，時人謂之穿錐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000153",
    "sentence": "又有武將王周者，署名先為「吉」而後成其外，二人至子孫始並知書。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000154",
    "sentence": "干，皇建初配享神武廟庭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000155",
    "sentence": "子敬伏，位儀同三司，卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000156",
    "sentence": "子士文嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000157",
    "sentence": "子　士文",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000158",
    "sentence": "士文性孤真，雖鄰里至親，莫與通狎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000159",
    "sentence": "在齊，襲封章武郡王，位領軍將軍。",
    "entities": [
      {
        "text": "襲封章武郡",
        "label": "LOC",
        "start": 3,
        "end": 8
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000160",
    "sentence": "周武帝平齊，山東衣冠多來迎，唯士文閉門自守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000161",
    "sentence": "帝奇之，授開府儀同三司，隨州刺史。",
    "entities": [
      {
        "text": "隨州",
        "label": "LOC",
        "start": 12,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000162",
    "sentence": "隋文受禪，加上開府，封湖陂縣子。",
    "entities": [
      {
        "text": "封湖陂縣",
        "label": "LOC",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000163",
    "sentence": "尋拜貝州刺史。",
    "entities": [
      {
        "text": "尋拜貝州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000164",
    "sentence": "性清苦，不受公料，家無餘財。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000165",
    "sentence": "其子嘗啖官廚餅，士文枷之於獄累日，杖之二百，步送還京，僮隸無敢出門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000166",
    "sentence": "所買鹽菜，必於外境。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000167",
    "sentence": "凡有出入，皆封署其門，親故絕跡，慶吊不通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000168",
    "sentence": "法令嚴肅，吏人貼服，道不拾遺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000169",
    "sentence": "凡有細過，必深文陷害之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000170",
    "sentence": "嘗入朝，遇上賜公卿入左藏，任取多少。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000171",
    "sentence": "人皆極重，士文獨口銜絹一匹，兩手各持一匹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000172",
    "sentence": "上問其故，士文曰：「臣口手俱足，餘無所須。」上異之，別齎遺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000173",
    "sentence": "士文至州，發摘姦吏，尺布鬥粟之贓，無所寬貸，得千人奏之，悉配防嶺南。",
    "entities": [
      {
        "text": "士文至州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000174",
    "sentence": "親戚相送，哭聲遍於州境。",
    "entities": [
      {
        "text": "哭聲遍於州",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000175",
    "sentence": "至嶺南，遇瘴厲死者十八九，於是父母妻子唯哭士文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000176",
    "sentence": "士文聞之，令人捕搦，捶楚盈前，而哭者彌甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000177",
    "sentence": "司馬京兆韋焜、清河令河東趙達二人並苛刻，唯長史有惠政，時人語曰：「刺史羅剎政，司馬蝮蛇瞋，長史含笑判，清河生吃人。」上聞，嘆曰：「士文暴過猛獸。」竟坐免。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 33,
        "end": 35
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 39,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000178",
    "sentence": "未幾為雍州長史，謂人曰：「我向法深，不能窺候要貴，無乃必死此官。」及下車，執法嚴正，不避貴戚，賓客莫敢至門。",
    "entities": [
      {
        "text": "未幾為雍州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000179",
    "sentence": "人多怨望。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000180",
    "sentence": "士文從妹為齊氏嬪，有色，齊滅後，賜薛公長孫覽。",
    "entities": [
      {
        "text": "齊氏",
        "label": "ORG",
        "start": 5,
        "end": 7
      },
      {
        "text": "長孫覽",
        "label": "PER",
        "start": 19,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000181",
    "sentence": "覽妻鄭氏妬，譖之文獻后，后令覽離絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000182",
    "sentence": "士文恥之，不與相見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000183",
    "sentence": "後應州刺史唐君明居母憂，娉以為妻，由是君明、士文並為御史所劾。",
    "entities": [
      {
        "text": "後應州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000184",
    "sentence": "士文性剛，在獄數日，憤恚而死，家無餘財，有三子，朝夕不繼，親賓無贍之者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000185",
    "sentence": "韓軌",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000186",
    "sentence": "韓軌，字百年，太安狄那人也。",
    "entities": [
      {
        "text": "百年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000187",
    "sentence": "少有志操，性深沈，喜怒不形於色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000188",
    "sentence": "神武鎮晉州，引為鎮城都督。",
    "entities": [
      {
        "text": "神武鎮晉州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "引為鎮城",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000189",
    "sentence": "及起兵於信都，軌贊成大策。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000190",
    "sentence": "從破尒朱兆於廣阿，又從韓陵陣，封平昌縣侯。",
    "entities": [
      {
        "text": "封平昌縣",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000191",
    "sentence": "仍督中軍，從破尒朱兆於赤谼嶺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000192",
    "sentence": "再遷泰州刺史。",
    "entities": [
      {
        "text": "再遷泰州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000193",
    "sentence": "甚得邊和。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000194",
    "sentence": "神武巡泰州，欲以軌還，仍賜城人戶別絹布兩匹。",
    "entities": [
      {
        "text": "神武巡泰州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "仍賜城",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000195",
    "sentence": "州人田昭等七千戶皆辭不受，唯乞留軌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000196",
    "sentence": "神武嘉嘆，乃留焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000197",
    "sentence": "頻以軍功，進封安德郡公。",
    "entities": [
      {
        "text": "進封安德郡",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000198",
    "sentence": "遷瀛州刺史，在州聚斂，為御史糾劾，削除官爵。",
    "entities": [
      {
        "text": "遷瀛州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "在州",
        "label": "LOC",
        "start": 6,
        "end": 8
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000199",
    "sentence": "未幾，復其安德郡公。",
    "entities": [
      {
        "text": "復其安德郡",
        "label": "LOC",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000200",
    "sentence": "歷位中書令、司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000201",
    "sentence": "齊受禪，封安德郡王。",
    "entities": [
      {
        "text": "封安德郡",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000202",
    "sentence": "軌妹為神武所納，生上黨王渙，復以勳庸，歷登臺鉉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000203",
    "sentence": "常以謙恭自處，不以富貴驕人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000204",
    "sentence": "後拜大司馬，從文宣征蠕蠕，在軍暴疾薨。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000205",
    "sentence": "贈假黃鉞，太宰、太師，諡曰肅武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000206",
    "sentence": "皇建初，配饗文襄廟庭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000207",
    "sentence": "子晉明嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000208",
    "sentence": "天統中，改封東萊王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000209",
    "sentence": "晉明有俠氣，諸勳貴子孫中最留心學問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000210",
    "sentence": "好酒誕縱，招引賓客，一席之費，動至萬錢，猶恨儉率。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000211",
    "sentence": "朝庭處之貴要之地，必以疾辭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000212",
    "sentence": "告人云：「廢人飲美酒、封名勝，安能作刀筆吏返披故紙乎？」武平末，除尚書左僕射，百餘日便謝病解官。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000213",
    "sentence": "潘樂",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000214",
    "sentence": "潘樂，字相貴，廣寧石門人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000215",
    "sentence": "本廣宗大族，魏世分鎮北邊，因家焉。",
    "entities": [
      {
        "text": "魏世分鎮",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000216",
    "sentence": "父永，有技藝，襲爵廣宗男。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000217",
    "sentence": "樂初生，有一雀止其母左肩，占者咸言富貴之徵，因名相貴，後始為字。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000218",
    "sentence": "及長，寬厚有膽略。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000219",
    "sentence": "初歸葛榮，授京兆王，時年十九。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000220",
    "sentence": "榮敗，隨尒朱榮，為別將討元顥，以功封敷城縣男。",
    "entities": [
      {
        "text": "以功封敷城縣",
        "label": "LOC",
        "start": 15,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000221",
    "sentence": "齊神武出牧晉州，引樂為鎮城都將。",
    "entities": [
      {
        "text": "齊神武出牧晉州",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "引樂為鎮城",
        "label": "LOC",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000222",
    "sentence": "從破尒朱兆於廣阿，進爵廣宗縣伯。",
    "entities": [
      {
        "text": "進爵廣宗縣",
        "label": "LOC",
        "start": 9,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000223",
    "sentence": "累以軍功拜東雍州刺史。",
    "entities": [
      {
        "text": "以軍功拜東雍州",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000224",
    "sentence": "神武嘗議欲廢州，樂以東雍地帶山河，境連胡、蜀，形勝之會，不可棄也，遂如故。",
    "entities": [
      {
        "text": "神武嘗議欲廢州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000225",
    "sentence": "後破周師於河陰，議欲追之，令追者在西，不願者東，唯樂與劉豐居西。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000226",
    "sentence": "神武善之，以衆議不同而止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000227",
    "sentence": "改封金門郡公。",
    "entities": [
      {
        "text": "改封金門郡",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000228",
    "sentence": "文宣嗣事，鎮河陽，破西將楊檦等。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000229",
    "sentence": "時帝以懷州刺史平鑒等所築城深入敵境，欲棄之，樂以軹關要害，必須防固，乃更修理，增置兵將，而還鎮河陽，拜司空。",
    "entities": [
      {
        "text": "時帝以懷州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "樂以軹關",
        "label": "LOC",
        "start": 22,
        "end": 26
      },
      {
        "text": "而還鎮",
        "label": "LOC",
        "start": 44,
        "end": 47
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000230",
    "sentence": "齊受禪，樂進璽綬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000231",
    "sentence": "進封河東郡王，遷司徒。",
    "entities": [
      {
        "text": "進封河東郡",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000232",
    "sentence": "周文東至崤、陜，遣其行臺侯莫陳崇自齊子嶺趣軹關，儀同楊檦從鼓鐘道出建州，陷孤公戍。",
    "entities": [
      {
        "text": "侯莫陳崇",
        "label": "PER",
        "start": 12,
        "end": 16
      },
      {
        "text": "自齊子嶺趣軹關",
        "label": "LOC",
        "start": 16,
        "end": 23
      },
      {
        "text": "從鼓鐘道出建州",
        "label": "LOC",
        "start": 28,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000233",
    "sentence": "詔樂總大衆禦之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000234",
    "sentence": "樂晝夜兼行，至長子，遣儀同韓永興從建州西趣崇，崇遂遁。",
    "entities": [
      {
        "text": "同韓永興從建州",
        "label": "LOC",
        "start": 12,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000235",
    "sentence": "又為南道大都督，討侯景。",
    "entities": [
      {
        "text": "大都",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000236",
    "sentence": "樂發石鱉，南度百餘里，至梁涇州。",
    "entities": [
      {
        "text": "至梁涇州",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000237",
    "sentence": "涇州舊在石梁，侯景改為懷州，樂獲其地，仍立涇州，又克安州。",
    "entities": [
      {
        "text": "涇州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "侯景改為懷州",
        "label": "LOC",
        "start": 7,
        "end": 13
      },
      {
        "text": "仍立涇州",
        "label": "LOC",
        "start": 19,
        "end": 23
      },
      {
        "text": "又克安州",
        "label": "LOC",
        "start": 24,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000238",
    "sentence": "除瀛州刺史，仍略淮、漢。",
    "entities": [
      {
        "text": "除瀛州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000239",
    "sentence": "天保六年，薨於懸瓠。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000240",
    "sentence": "贈假黃鉞，太師、大司馬、尚書令。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_015_000241",
    "sentence": "子子晃嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000242",
    "sentence": "諸將子弟，率多驕縱，子晃沈密謹愨，以清凈自居。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_015_000243",
    "sentence": "尚公主，拜駙馬都尉。",
