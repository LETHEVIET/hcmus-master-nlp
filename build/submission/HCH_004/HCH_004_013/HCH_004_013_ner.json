        "label": "LOC",
        "start": 18,
        "end": 20
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000010",
    "sentence": "琛推誠撫納，拔用人士，甚有聲譽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000011",
    "sentence": "及斛斯椿等釁結。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000012",
    "sentence": "高祖將謀內討，以晉陽根本，召琛留掌後事，以為幷、肆、汾大行臺僕射，領六州九酋長大都督，其相府政事琛悉決之。",
    "entities": [
      {
        "text": "領六州",
        "label": "LOC",
        "start": 33,
        "end": 36
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 39,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000013",
    "sentence": "天平中，除御史中尉，正色糾彈，無所回避，遠近肅然。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000014",
    "sentence": "尋亂高祖後庭，高祖責罰之，因杖而斃，時年二十三。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000015",
    "sentence": "贈使持節、侍中、都督冀定滄瀛幽殷幷肆雲朔十州諸軍事、驃騎大將軍、冀州刺史、太尉、尚書令，諡曰貞平。",
    "entities": [
      {
        "text": "殷幷肆雲朔十州",
        "label": "LOC",
        "start": 15,
        "end": 22
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 28,
        "end": 31
      },
      {
        "text": "冀州",
        "label": "LOC",
        "start": 32,
        "end": 34
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 34,
        "end": 36
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 40,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000016",
    "sentence": "天統三年 ，又贈假黃鉞、左丞相、太師、錄尚書事、冀州刺史，進爵為王，配饗高祖廟庭。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 20,
        "end": 22
      },
      {
        "text": "冀州",
        "label": "LOC",
        "start": 24,
        "end": 26
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000017",
    "sentence": "子叡嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000018",
    "sentence": "子 叡",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000019",
    "sentence": "叡小名須拔，生三旬而孤，聰慧夙成，特為高祖所愛，養於宮中，令遊娘母之，恩同諸子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000020",
    "sentence": "魏興和中，襲爵南趙郡公。",
    "entities": [
      {
        "text": "襲爵南趙郡",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000021",
    "sentence": "至四歲，未嘗識母，其母則魏華陽公主也。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000022",
    "sentence": "有鄭氏者，叡母之從母姊妹之女，戲語叡曰：「汝是我姨兒，何因倒親遊氏。」叡因問訪，遂精神不怡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000023",
    "sentence": "高祖甚以為怪，疑其感疾，欲命醫看之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000024",
    "sentence": "叡對曰：「兒無患苦，但聞有所生，欲得暫見。」高祖驚曰：「誰向汝道耶？」叡具陳本末。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000025",
    "sentence": "高祖命元夫人令就宮與叡相見，叡前跪拜，因抱頭大哭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000026",
    "sentence": "高祖甚以悲傷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000027",
    "sentence": "語平秦王曰：「此兒天生至孝，我兒子無有及者。」遂為休務一日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000028",
    "sentence": "叡初讀《 孝經 》，至「資於事父」，輒流涕歔欷。",
    "entities": [
      {
        "text": "《 孝經 》",
        "label": "TITLE",
        "start": 3,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000029",
    "sentence": "十歲喪母，高祖親送叡至領軍府，為叡發喪，與聲殞絕，哀感左右，三日水漿不入口。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000030",
    "sentence": "高祖與武明婁皇后殷勤敦譬，方漸順旨。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000031",
    "sentence": "居喪盡禮，持佛像長齋，至于骨立，杖而後起。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000032",
    "sentence": "高祖令常山王共臥起，日夜說喻之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000033",
    "sentence": "並敕左右不聽進水，雖絕清漱，午後輒不肯食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000034",
    "sentence": "由是高祖食必喚叡同案。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000035",
    "sentence": "其見湣惜如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000036",
    "sentence": "高祖崩，哭泣嘔血。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000037",
    "sentence": "及壯，將為婚娶，而貌有戚容。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000038",
    "sentence": "世宗謂之曰：「我為爾娶鄭述祖女，門閥甚高，汝何所嫌而精神不樂？」叡對曰：「自痛孤遺，常深膝下之慕，方從婚冠，彌用感切。」言未卒，嗚咽不自勝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000039",
    "sentence": "世宗為之憫默。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000040",
    "sentence": "勵己勤學，常夜久方罷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000041",
    "sentence": "武定末，除太子庶子。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000042",
    "sentence": "顯祖受禪，進封爵為趙郡王，邑一千二百戶，遷散騎常侍。",
    "entities": [
      {
        "text": "進封爵為趙郡",
        "label": "LOC",
        "start": 5,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000043",
    "sentence": "叡身長七尺，容儀甚偉，閑習吏職，有知人之鑒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000044",
    "sentence": "二年，出為定州刺史，加撫軍將軍、六州大都督，時年十七。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "出為定州",
        "label": "LOC",
        "start": 3,
