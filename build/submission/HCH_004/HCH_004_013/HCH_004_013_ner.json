  {
    "sentence_id": "HCH_004_013_000070",
    "sentence": "時隆冬盛寒，叡跣步號哭，面皆破裂，嘔血數升。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000071",
