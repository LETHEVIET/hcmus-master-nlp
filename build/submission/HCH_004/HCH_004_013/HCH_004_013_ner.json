  {
    "sentence_id": "HCH_004_013_000123",
    "sentence": "時岳遇患，高祖令還幷治療，疾瘳，復令赴職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000124",
    "sentence": "及高祖崩，侯景叛，世宗徵岳還幷，共圖取景之計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000125",
    "sentence": "而武帝乘間遣其貞陽侯明率衆於寒山，擁泗水灌彭城，與景為掎角聲援。",
    "entities": [
      {
        "text": "擁泗水灌彭城",
        "label": "LOC",
        "start": 17,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000126",
    "sentence": "岳總帥諸軍南討，與行臺慕容紹宗等擊明，大破之，臨陣擒明及其大將胡貴孫，自餘俘馘數萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000127",
    "sentence": "景乃擁衆於渦陽，與左衛將軍劉豐等相持。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000128",
    "sentence": "岳回軍追討，又破之，景單騎逃竄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000129",
    "sentence": "六年，以功除侍中、太尉，餘如故，別封新昌縣子。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "別封新昌縣",
        "label": "LOC",
        "start": 16,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000130",
    "sentence": "又拜使持節、河南總管、大都督，統慕容紹宗、劉豐等討王思政於長社。",
    "entities": [
      {
        "text": "大都",
        "label": "LOC",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000131",
    "sentence": "思政嬰城自守，岳等引洧水灌城。",
    "entities": [
      {
        "text": "思政嬰城",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "岳等引洧水灌城",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000132",
    "sentence": "紹宗、劉豐為思政所獲，關西出兵援思政，岳內外防禦，甚有謀算。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000133",
    "sentence": "城不沒者三板。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000134",
    "sentence": "會世宗親臨，數日城下，獲思政等。",
    "entities": [
      {
        "text": "數日城",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000135",
    "sentence": "以功別封真定縣男，世宗以為己功，故賞典弗弘也。",
    "entities": [
      {
        "text": "以功別封真定縣",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000136",
    "sentence": "世宗崩，顯祖出撫晉陽，令岳以本官兼尚書左僕射，留鎮京師。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 17,
        "end": 19
      },
      {
        "text": "留鎮",
        "label": "LOC",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000137",
    "sentence": "天保初，進封清河郡王，尋除使持節、驃騎大將軍、開府儀同三司、宗師、司州牧。",
    "entities": [
      {
        "text": "進封清河郡",
        "label": "LOC",
        "start": 4,
        "end": 9
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 19,
        "end": 22
      },
      {
        "text": "司州",
        "label": "LOC",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000138",
    "sentence": "五年，加太保。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000139",
    "sentence": "梁蕭繹為周軍所逼，遣使告急，且請援。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000140",
    "sentence": "冬，詔岳為西南道大行臺，統司徒潘相樂等救江陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000141",
    "sentence": "六年正月，師次義陽，遇荊州陷，因略地南至郢州，獲梁州刺史司徒陸法和，仍剋郢州。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "遇荊州",
        "label": "LOC",
        "start": 10,
        "end": 13
      },
      {
        "text": "因略地南至郢州",
        "label": "LOC",
        "start": 15,
        "end": 22
      },
      {
        "text": "獲梁州",
        "label": "LOC",
        "start": 23,
        "end": 26
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 26,
        "end": 28
      },
      {
        "text": "仍剋郢州",
        "label": "LOC",
        "start": 34,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000142",
    "sentence": "岳先送法和於京師，遣儀同慕容儼據郢城。",
    "entities": [
      {
        "text": "同慕容儼據郢城",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000143",
    "sentence": "朝廷知江陵陷，詔岳旋師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000144",
    "sentence": "岳自討寒山、長社及出隨、陸，並有功績，威名彌重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000145",
    "sentence": "而性華侈，尤悅酒色，歌姬舞女，陳鼎擊鐘，諸王皆不及也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000146",
    "sentence": "初，高歸彥少孤，高祖令岳撫養，輕其年幼，情禮甚薄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000147",
    "sentence": "歸彥內銜之而未嘗出口。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000148",
    "sentence": "及歸彥為領軍，大被寵遇，岳謂其德己，更倚賴之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000149",
    "sentence": "歸彥密構其短。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000150",
    "sentence": "岳於城南起宅，聽事後開巷。",
    "entities": [
      {
        "text": "岳於城",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000151",
    "sentence": "歸彥奏帝曰：「清河造宅，僭擬帝宮，制為永巷，但唯無闕耳。」顯祖聞而惡之，漸以疏岳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000152",
    "sentence": "仍屬顯祖召鄴下婦人薛氏入宮，而岳先嘗喚之至宅，由其姊也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000153",
    "sentence": "帝懸薛氏姊而鋸殺之，讓岳以為姦民女。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000154",
    "sentence": "岳曰：「臣本欲取之，嫌其輕薄不用，非姦也。」帝益怒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000155",
    "sentence": "六年十一月，使高歸彥就宅切責之。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000156",
    "sentence": "岳憂悸不知所為，數日而薨，故時論紛然，以為賜鴆也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000157",
    "sentence": "朝野嘆惜之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000158",
    "sentence": "時年四十四。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000159",
    "sentence": "詔大鴻臚監護喪事，贈使持節、都督冀定滄瀛趙幽濟七州諸軍、太宰、太傅、定州刺史，假黃鉞，給轀輬車，赗物二千段，諡曰昭武。",
    "entities": [
      {
        "text": "滄瀛趙幽濟七州",
        "label": "LOC",
        "start": 18,
        "end": 25
      },
      {
        "text": "定州",
        "label": "LOC",
        "start": 34,
        "end": 36
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 36,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000160",
    "sentence": "初，岳與高祖經綸天下，家有私兵，並畜戎器，儲甲千餘領。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000161",
    "sentence": "世宗之末，岳以四海無事，表求納之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000162",
    "sentence": "世宗敦至親之重，推心相任，云 ：「叔屬居肺腑，職在維城，所有之甲，本資國用，叔何疑而納之。」文宣之世，亦頻請納，又固不許。",
    "entities": [
      {
        "text": "職在維城",
        "label": "LOC",
        "start": 23,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000163",
    "sentence": "及將薨，遺表謝恩，並請上甲于武庫，至此葬畢，方許納焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000164",
    "sentence": "皇建中，配享世宗廟庭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000165",
    "sentence": "後歸彥反，世祖知其前譖，曰：「清河忠烈，盡力皇家，而歸彥毀之，間吾骨肉。」籍沒歸彥，以良賤百口賜岳家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000166",
    "sentence": "後又思岳之功，重贈太師、太保，餘如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000167",
    "sentence": "子勱嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000168",
    "sentence": "子 勱",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000169",
    "sentence": "勱，字敬德，夙智早成，為顯祖所愛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000170",
    "sentence": "年七歲，遣侍皇太子。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000171",
    "sentence": "後除青州刺史，拜日，顯祖戒之曰：「叔父前牧青州，甚有遺惠，故遣汝慰彼黎庶，宜好用心，無墜聲績。」勱流涕對曰：「臣以蒙幼，濫叨拔擢，雖竭庸短，懼忝先政。」帝曰：「汝既能有此言，吾不慮也。」尋追授武衛將軍、領軍、祠部尚書、開府儀同三司。",
    "entities": [
      {
        "text": "後除青州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "叔父前牧青州",
        "label": "LOC",
        "start": 17,
        "end": 23
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 98,
        "end": 100
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 106,
        "end": 108
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000172",
    "sentence": "以清河地在畿內，改封樂安王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000173",
    "sentence": "轉侍中、尚書右僕射，出為朔州行臺僕射。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "出為朔州",
        "label": "LOC",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000174",
    "sentence": "後主晉州敗，太后從土門道還京師，敕勱統領兵馬，侍衛太后。",
    "entities": [
      {
        "text": "後主晉州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000175",
    "sentence": "時佞幸閽寺，猶行暴虐，民間雞豬，悉放鷹犬搏噬取之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000176",
    "sentence": "勱收儀同三司茍子溢徇軍，欲行大戮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000177",
    "sentence": "太后有令，然後釋之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000178",
    "sentence": "劉文殊竊謂勱曰：「子溢之徒，言成禍福，何容如此，豈不慮後生毀謗耶？」勱攘袂語文殊曰：「自獻武皇帝以來，撫養士卒，委政親賢，用武行師，未有折衂。今西寇已次幷州，達官多悉委叛，正坐此輩專政弄權，所以內外離心，衣冠解體。若得今日斬此卒，明日及誅，亦無所恨。王國家姻婭，須同疾惡，返為此言，豈所望乎！」太后還至鄴，周軍續至，人皆恟懼，無有鬭心，朝士出降，晝夜相屬。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 46,
        "end": 48
      },
      {
        "text": "今西寇已次幷州",
        "label": "LOC",
        "start": 71,
        "end": 78
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000179",
    "sentence": "勱因奏後主曰：「今所翻叛，多是貴人，至於卒伍，猶未離貳。請追五品已上家屬，置之三臺，因協之曰：『若戰不捷，即退焚臺。』此曹顧惜妻子，必當死戰。且王師頻北，賊徒輕我，今背城一決，理必破之，此亦計之上者。」後主卒不能用。",
    "entities": [
      {
        "text": "今背城",
        "label": "LOC",
        "start": 82,
        "end": 85
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000180",
    "sentence": "齊亡入周，依例授開府。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "周",
        "label": "ORG",
        "start": 3,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000181",
    "sentence": "隋朝歷楊、楚、光、洮四州刺史。",
    "entities": [
      {
        "text": "洮四州",
        "label": "LOC",
        "start": 9,
        "end": 12
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000182",
    "sentence": "開皇中卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000183",
    "sentence": "【評贊】",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000184",
    "sentence": "史臣曰：《 易 》稱：「天地盈虛，與時消息，況於人乎！」蓋以通塞有期，汚隆適道。",
    "entities": [
      {
        "text": "《 易 》",
        "label": "TITLE",
        "start": 4,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000185",
    "sentence": "舉世思治，則顯仁以應之；小人道長，則儉德以避之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000186",
    "sentence": "至若負博陸之圖，處藩屏之地，而欲迷邦違難，其可得乎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000187",
    "sentence": "趙郡以跗萼之親，當顧命之重，高揖則宗社易危，去惡則人神俱泰。",
    "entities": [
      {
        "text": "趙郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000188",
    "sentence": "是用安夫一德，同此貞心，踐畏途而不疑，履危機而莫懼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000189",
    "sentence": "以斯忠義，取斃尹凶慝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000190",
    "sentence": "豈道光四海，不遇周成之明；將朝去三仁，終見殷墟之禍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000191",
    "sentence": "不然則邦國殄瘁，何影響之速乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000192",
    "sentence": "清河屬經綸之會，自致青雲，出將入相，翊成鴻業，雖漢朝劉賈，魏室曹洪，俱未足論其高下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000193",
    "sentence": "天保不辰，易生悔咎，固不可掩其風烈，適以彰顯祖之失德云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000194",
    "sentence": "贊曰：趙郡英偉，風範凝正。",
