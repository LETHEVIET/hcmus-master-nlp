        "end": 18
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000045",
    "sentence": "叡留心庶事，糾摘姦非，勸課農桑，接禮民儁，所部大治，稱為良牧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000046",
    "sentence": "三年，加儀同三司。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000047",
    "sentence": "六年，詔叡領山東兵數萬監築長城。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "兵數萬監築長城",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000048",
    "sentence": "于時盛夏六月，叡在途中，屏除蓋扇，親與軍人同其勞苦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000049",
    "sentence": "而定州先有冰室，每歲藏冰，長史宋欽道以叡冒犯暑熱，遂遣輿冰，倍道追送。",
    "entities": [
      {
        "text": "而定州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000050",
    "sentence": "正值日中停車，炎赫尤甚，人皆不堪，而送冰者至，咸謂得冰一時之要。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000051",
    "sentence": "叡乃對之嘆息云 ：「三軍之人，皆飲溫水，吾以何義，獨進寒冰，非追名古將，實情所不忍。」遂至消液，竟不一嘗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000052",
    "sentence": "兵人感悅，遐邇稱嘆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000053",
    "sentence": "先是，役徒罷作，任其自返。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000054",
    "sentence": "丁壯之輩，各自先歸；羸弱之徒，棄在山北，加以饑病，多致僵殞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000055",
    "sentence": "叡於是親帥所部，與之俱還，配合州鄉，部分營伍，督帥監領，強弱相持，遇善水草，即為停頓，分有餘，贍不足，屯以全者十三四焉。",
    "entities": [
      {
        "text": "配合州鄉",
        "label": "LOC",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000056",
    "sentence": "七年，詔以本官都督滄、瀛、幽、安、平、東燕六州諸軍事、滄州刺史。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "東燕六州",
        "label": "LOC",
        "start": 19,
        "end": 23
      },
      {
        "text": "滄州",
        "label": "LOC",
        "start": 27,
        "end": 29
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000057",
    "sentence": "八年，徵叡赴鄴，仍除北朔州刺史，都督北燕、北蔚、北恒三州，及庫推以西黃河以東長城諸鎮諸軍事。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "仍除北朔州",
        "label": "LOC",
        "start": 8,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "北恒三州",
        "label": "LOC",
        "start": 24,
        "end": 28
      },
      {
        "text": "西黃河以東長城",
        "label": "LOC",
        "start": 33,
        "end": 40
      },
      {
        "text": "諸鎮",
        "label": "LOC",
        "start": 40,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000058",
    "sentence": "叡慰撫新遷，量置烽戍，內防外禦，備有條法，大為兵民所安。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_013_000059",
    "sentence": "有無水之處，禱而掘井，鍬鍤裁下，泉源湧出，至今號曰趙郡王泉。",
    "entities": [
      {
        "text": "至今號曰趙郡",
        "label": "LOC",
        "start": 21,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000060",
    "sentence": "九年，車駕幸樓煩，叡朝於行宮，仍從還晉陽。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000061",
    "sentence": "時濟南以太子監國，因立大都督府，與尚書省分理衆事，仍開府置佐。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 11,
        "end": 13
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000062",
    "sentence": "顯祖特崇其選，乃除叡侍中、攝大都督府長史。",
    "entities": [
      {
        "text": "大都",
        "label": "LOC",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_013_000063",
    "sentence": "叡後因侍宴，顯祖從容顧謂常山王演等曰：「由來亦有如此長史不？吾用此長史何如？」演對曰：「陛下垂心庶政，優賢禮物，須拔進居蟬珥之榮，退當委要之職，自昔以來，實未聞如此銓授。」帝曰：「吾於此亦自謂得宜。」十年，轉儀同三司、侍中、將軍、長史，王如故。",
    "entities": [
      {
        "text": "十年",
