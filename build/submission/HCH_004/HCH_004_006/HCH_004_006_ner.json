      },
      {
        "text": "趙郡",
        "label": "LOC",
        "start": 88,
        "end": 90
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000090",
    "sentence": "大寧元年閏十二月癸卯，梓宮還鄴，上諡曰孝昭皇帝。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "皇帝",
