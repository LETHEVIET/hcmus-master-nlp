  },
  {
    "sentence_id": "HCH_004_006_000081",
    "sentence": "十二月丙午，車駕至晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000082",
    "sentence": "皇建二年",
