[
  {
    "sentence_id": "HCH_004_006_000001",
    "sentence": "孝昭帝",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000002",
    "sentence": "孝昭皇帝演，字延安，神武皇帝第六子，文宣皇帝之母弟也。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000003",
    "sentence": "幼而英特，早有大成之量，武明皇太后早所愛重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000004",
    "sentence": "魏 元象元年 ，封常山郡公。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 4,
        "end": 6
      },
      {
        "text": "封常山郡",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000005",
    "sentence": "及文襄執政，遣中書侍郎李同軌就霸府為諸弟師。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000006",
    "sentence": "帝所覽文籍，源其指歸而不好辭彩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000007",
    "sentence": "每歎云：「雖盟津之師，左驂震而不衄。」以為能。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000008",
    "sentence": "遂篤志讀《 漢書 》，至《李陵傳》，恒壯其所為焉。",
    "entities": [
      {
        "text": "《 漢書 》",
        "label": "TITLE",
        "start": 4,
        "end": 10
      },
      {
        "text": "《李陵傳》",
        "label": "TITLE",
        "start": 12,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000009",
    "sentence": "聰敏過人，所與遊處，一知其家諱，終身未嘗誤犯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000010",
    "sentence": "同軌病卒，又命開府長流參軍刁柔代之，性嚴褊，不適誘訓之宜，中被遣出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000011",
    "sentence": "帝送出閤，慘然斂容，淚數行下，左右莫不歔欷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000012",
    "sentence": "其敬業重舊也如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000013",
    "sentence": "天保初，進爵為王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000014",
    "sentence": "五年，除幷省尚書令。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000015",
    "sentence": "帝善斷割，長於文理，省內畏服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000016",
    "sentence": "七年，從文宣還鄴。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000017",
    "sentence": "文宣以尚書奏事，多有異同，令帝與朝臣先論定得失，然後敷奏。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000018",
    "sentence": "帝長於政術，剖斷咸盡其理，文宣歎重之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000019",
    "sentence": "八年，轉司空、錄尚書事。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000020",
    "sentence": "九年，除大司馬，仍錄尚書。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000021",
    "sentence": "時文宣溺於遊宴，帝憂憤表於神色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000022",
    "sentence": "文宣覺之，謂帝曰：「但令汝在，我何為不縱樂？」帝唯啼泣拜伏，竟無所言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000023",
    "sentence": "文宣亦大悲，抵杯於地曰：「汝以此嫌我，自今敢進酒者，斬之！」因取所御杯盡皆壞棄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000024",
    "sentence": "後益沉湎，或入諸貴賤家角力批拉，不限貴賤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000025",
    "sentence": "唯常山王至，內外肅然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000026",
    "sentence": "帝又密撰事條，將諫，其友王晞以為不可。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000027",
    "sentence": "帝不從，因間極言，遂逢大怒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000028",
    "sentence": "順成后本魏朝宗室，文宣欲帝離之，陰為帝廣求淑媛，望移其寵。",
    "entities": [
      {
        "text": "魏朝",
        "label": "ORG",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000029",
    "sentence": "帝雖承旨有納，而情義彌重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000030",
    "sentence": "帝性頗嚴，尚書郎中剖斷有失，輒加捶楚，令史姦慝，便即考竟。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "令史",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000031",
    "sentence": "文宣乃立帝於前，以刀環擬脅召被帝罰者，臨以白刃，求帝之短，咸無所陳，方見解釋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000032",
    "sentence": "自是不許笞箠郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000033",
    "sentence": "後賜帝魏時宮人，醒而忘之，謂帝擅取，遂以刀環亂築，因此致困。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 3,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000034",
    "sentence": "皇太后日夜啼泣，文宣不知所為。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000035",
    "sentence": "先是禁友王晞，乃捨之，令侍帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000036",
    "sentence": "帝月餘漸瘳，不敢復諫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000037",
    "sentence": "及文宣崩，帝居禁中護喪事，幼主即位，乃即朝班。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000038",
    "sentence": "除太傅、錄尚書，朝政皆決於帝。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000039",
    "sentence": "月餘，乃居藩邸，自是詔勑多不關帝。",
    "entities": [
      {
        "text": "自是詔勑多不關",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000040",
    "sentence": "客或言於帝曰：「鷙烏舍巢，必有探卵之患，今日之地，何宜屢出。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000041",
    "sentence": "乾明元年",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000042",
    "sentence": "乾明元年 ，從廢帝赴鄴，居於領軍府。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000043",
    "sentence": "時楊愔、燕子獻、可朱渾天和、宋欽道、鄭子默等以帝威望旣重，內懼權逼，請以帝為太師、司州牧、錄尚書事；長廣王湛為大司馬、錄幷省尚書事，解京畿大都督。",
    "entities": [
      {
        "text": "宋欽道",
        "label": "PER",
        "start": 14,
        "end": 17
      },
      {
        "text": "司州",
        "label": "LOC",
        "start": 41,
        "end": 43
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 46,
        "end": 48
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 56,
        "end": 58
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 62,
        "end": 64
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 69,
        "end": 71
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000044",
    "sentence": "帝時以尊親而見猜斥，乃與長廣王期獵，謀之於野。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000045",
    "sentence": "三月甲戌，帝初上省，旦發領軍府，大風暴起，壞所御車幔，帝甚惡之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000046",
    "sentence": "及至省，朝士咸集。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000047",
    "sentence": "坐定，酒數行，執尚書令楊愔、右僕射燕子獻、領軍可朱渾天和、侍中宋欽道等於坐。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "宋欽道",
        "label": "PER",
        "start": 31,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000048",
    "sentence": "帝戎服與平原王段韶、平秦王高歸彥、領軍劉洪徽入自雲龍門，於中書省前遇散騎常侍鄭子默，又執之，同斬於御府之內。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000049",
    "sentence": "帝至東閤門，都督成休甯抽刃呵帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000050",
    "sentence": "帝令高歸彥喻之，休甯厲聲大呼不從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000051",
    "sentence": "歸彥旣為領軍，素為兵士所服，悉皆弛仗，休寧歎息而罷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000052",
    "sentence": "帝入至昭陽殿，幼主、太皇太后、皇太后並出臨御坐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000053",
    "sentence": "帝奏愔等罪，求伏專擅之辜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000054",
    "sentence": "時庭中及兩廊下衛士二千餘人皆被甲待詔，武衛娥永樂武力絕綸，又被文宣重遇，撫刃思效。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000055",
    "sentence": "廢帝性吃訥，兼倉卒不知所言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000056",
    "sentence": "太皇太后又為皇后誓，言帝無異志，唯去逼而已。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000057",
    "sentence": "高歸彥勑勞衛士解嚴，永樂乃內刀而泣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000058",
    "sentence": "帝乃令歸彥引侍衛之士向華林園，以京畿軍入守門閤，斬娥永樂於園。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000059",
    "sentence": "詔以帝為大丞相、都督中外諸軍、錄尚書事，相府佐史進位一等。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000060",
    "sentence": "帝尋如晉陽，有詔軍國大政咸諮決焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000061",
    "sentence": "帝旣當大位，知無不為，擇其令典，考綜名實，廢帝恭己以聽政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000062",
    "sentence": "太皇太后尋下令廢少主，命帝統大業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000063",
    "sentence": "皇建元年",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000064",
    "sentence": "皇建元年 八月壬午，皇帝即位於晉陽宣德殿，大赦，改乾明元年為皇建。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "元年",
        "label": "TME",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000065",
    "sentence": "詔奉太皇太后還稱皇太后，皇太后稱文宣皇后，宮曰昭信。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000066",
    "sentence": "乙酉，詔自太祖創業已來，諸有佐命功臣子孫絕滅，國統不傳者，有司搜訪近親，以名聞，當量為立後；諸郡國老人各授版職，賜黃帽鳩杖。",
    "entities": [
      {
        "text": "諸郡",
        "label": "LOC",
        "start": 46,
        "end": 48
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000067",
    "sentence": "又詔謇正之士並聽進見陳事；軍人戰亡死王事者，以時申聞，當加榮贈；督將、朝士名望素高，位歷通顯，天保以來未蒙追贈者，亦皆錄奏；又以廷尉、中丞，執法所在，繩違按罪，不得舞文弄法；其官奴婢年六十已上免為庶人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000068",
    "sentence": "戊子，乙太傅、長廣王湛為右丞相，以太尉、平陽王淹為太傅，以尚書令、彭城王浟為大司馬。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 29,
        "end": 31
      },
      {
        "text": "彭城",
        "label": "LOC",
        "start": 33,
        "end": 35
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 39,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000069",
    "sentence": "壬辰，詔分遣大使巡省四方，觀察風俗，問人疾苦，考求得失，搜訪賢良。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000070",
    "sentence": "甲午，詔曰：「昔武王克殷，先封兩代，漢、魏、二晉，無廢茲典。及元氏統歷，不率舊章。朕纂承大業，思弘古典，但二王三恪，舊說不同，可議定是非，列名條奏。其禮義體式亦仰議之。」又詔國子寺可備立官屬，依舊置生，請習經典，歲時考試。",
    "entities": [
      {
        "text": "元氏",
        "label": "ORG",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000071",
    "sentence": "其文襄帝所運石經，宜即施列於學館。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000072",
    "sentence": "外州大學亦仰典司勤加督課。",
    "entities": [
      {
        "text": "外州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000073",
    "sentence": "丙申，詔九州勳人有重封者，聽分授子弟，以廣骨肉之恩。",
