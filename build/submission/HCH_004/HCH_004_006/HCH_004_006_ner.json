      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000087",
    "sentence": "冬十月丙子，以尚書令、彭城王浟為太保，長樂王尉粲為太尉。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
