        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000091",
    "sentence": "庚午，葬於文靖陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000092",
    "sentence": "帝聰敏有識度，深沉能斷，不可窺測。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000093",
    "sentence": "身長八尺，腰帶十圍，儀望風表，迥然獨秀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000094",
    "sentence": "自居臺省，留心政術，閑明簿領，吏所不逮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000095",
    "sentence": "及正位宸居，彌所剋勵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000096",
    "sentence": "輕徭薄賦，勤恤人隱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000097",
    "sentence": "內無私寵，外收人物，雖后父位亦特進無別。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000098",
    "sentence": "日昃臨朝，務知人之善惡，每訪問左右，冀獲直言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000099",
    "sentence": "曾問舍人裴澤在外議論得失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000100",
    "sentence": "澤率爾對曰：「陛下聰明至公，自可遠侔古昔，而有識之士，咸言傷細，帝王之度，頗為未弘。」帝笑曰：「誠如卿言。朕初臨萬機，慮不周悉，故致爾耳。此事安可久行，恐後又嫌疏漏。」澤因被寵遇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000101",
    "sentence": "其樂聞過也如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000102",
    "sentence": "趙郡王叡與厙狄顯安侍坐，帝曰：「須拔我同堂弟，顯安我親姑子，今序家人禮，除君臣之敬，可言我之不逮。」顯安曰：「陛下多妄言。」曰：「若何？」對曰：「陛下昔見文宣以馬鞭撻人，常以為非，而今行之，非妄言耶？」帝握其手謝之。",
    "entities": [
      {
        "text": "趙郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000103",
    "sentence": "又使直言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000104",
    "sentence": "對曰：「陛下太細，天子乃更似吏。」帝曰：「朕甚知之，然無法來久，將整之以至無為耳。」又問王晞，晞答如顯安，皆從容受納。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000105",
    "sentence": "性至孝，太后不豫，出居南宮，帝行不正履，容色貶悴，衣不解帶，殆將四旬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000106",
    "sentence": "殿去南宮五百餘步，雞鳴而去，辰時方還，來去徒行，不乘輿輦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000107",
    "sentence": "太后所苦小增，便即寢伏閤外，食飲藥物盡皆躬親。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000108",
    "sentence": "太后常心痛不自堪忍，帝立侍帷前，以爪掐手心，血流出袖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000109",
    "sentence": "友愛諸弟，無君臣之隔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000110",
    "sentence": "雄斷有謀，于時國富兵強，將雪神武遺恨，意在頓駕平陽，為進取之策。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000111",
    "sentence": "遠圖不遂，惜哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000112",
    "sentence": "初，帝與濟南約不相害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000113",
    "sentence": "及輿駕在晉陽，武成鎮鄴，望氣者云鄴城有天子氣。",
    "entities": [
      {
        "text": "武成鎮",
        "label": "LOC",
        "start": 7,
        "end": 10
      },
      {
        "text": "望氣者云鄴城",
        "label": "LOC",
        "start": 12,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000114",
    "sentence": "帝常恐濟南復興，乃密行鳩毒，濟南不從，乃扼而殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000115",
    "sentence": "後頗愧悔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000116",
    "sentence": "初苦內熱，頻進湯散。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000117",
    "sentence": "時有尚書令史姓趙，於鄴見文宣從楊愔、燕子獻等西行，言相與復讐。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "令史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000118",
    "sentence": "帝在晉陽宮，與毛夫人亦見焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000119",
    "sentence": "遂漸危篤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000120",
    "sentence": "備禳厭之事，或煮油四灑，或持炬燒逐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000121",
    "sentence": "諸厲方出殿梁，騎棟上，歌呼自若，了無懼容。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000122",
    "sentence": "時有天狗下，乃於其所講武以厭之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000123",
    "sentence": "有兔驚馬，帝墜而絕肋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000124",
    "sentence": "太后視疾，問濟南所在者三，帝不對。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000125",
    "sentence": "太后怒曰：「殺之耶？不用吾言，死其宜矣！」臨終之際，唯扶服床枕，叩頭求哀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000126",
    "sentence": "遣使詔追長廣王入纂大統，手書云：「宜將吾妻子置一好處，勿學前人也。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000127",
    "sentence": "【論】",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000128",
    "sentence": "論曰：孝昭早居臺閤，故事通明，人吏之間，無所不委。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000129",
    "sentence": "文宣崩後，大革前弊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000130",
    "sentence": "及臨尊極，留心更深，時人服其明而識其細也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000131",
    "sentence": "情好稽古，率由禮度，將封先代之胤，且敦學校之風，徵召英賢，文武畢集。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_006_000132",
    "sentence": "于時周氏朝政移於宰臣，主將相猜，不無危殆。",
    "entities": [
      {
        "text": "周氏",
        "label": "ORG",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000133",
    "sentence": "乃眷關右，實懷兼併之志，經謀宏遠，實當代之明主，而降年不永，其故何哉？",
    "entities": [
      {
        "text": "乃眷關",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_004_006_000134",
    "sentence": "豈幽顯之間，實有報復，將齊之基宇止在於斯，帝欲大之，天不許也？",
    "entities": []
  },
