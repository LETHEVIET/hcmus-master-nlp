        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_028_000056",
    "sentence": "諡曰文侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000057",
    "sentence": "元弼",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000058",
    "sentence": "元弼，字輔宗，魏司空暉之子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000059",
    "sentence": "性剛正，有文學。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000060",
    "sentence": "位中散大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_028_000061",
    "sentence": "以世嫡應襲先爵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000062",
    "sentence": "為季父尚書僕射麗因于氏親寵，遂奪弼王爵，橫授同母兄子誕，於是弼絕棄人事，托疾還私第。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_004_028_000063",
    "sentence": "宣武中為侍中，弼上表固讓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000064",
    "sentence": "入嵩山，以穴為室，布衣蔬食，卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000065",
    "sentence": "建元元年 ，子暉業訴復王爵。",
