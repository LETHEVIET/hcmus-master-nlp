        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_004_028_000039",
    "sentence": "二年冬，被詔入晉陽宮，出與元暉業同被害。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
