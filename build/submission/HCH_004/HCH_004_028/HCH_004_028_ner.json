        "start": 7,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_004_028_000040",
    "sentence": "元暉業",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000041",
    "sentence": "元暉業，字紹遠，魏景穆皇帝之玄孫。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_028_000042",
    "sentence": "少險薄，多與寇盜交通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000043",
    "sentence": "長乃變節，涉子史，亦頗屬文，而慷慨有志節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000044",
    "sentence": "歷位司空、太尉，加特進，領中書監，錄尚書事。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_004_028_000045",
    "sentence": "文襄嘗問之曰：「此何所披覽？」對曰：「數尋伊、霍之傳，不讀曹、馬之書。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000046",
    "sentence": "暉業以時運漸謝，不復圖全，唯事飲啖，一日一羊，三日一犢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000047",
    "sentence": "又嘗賦詩云：「昔居王道泰，濟濟富群英；今逢世路阻，狐兔鬱縱橫。」齊初，降封美陽縣公，開府儀同三司、特進。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 32,
        "end": 33
      },
      {
        "text": "降封美陽縣",
        "label": "LOC",
        "start": 35,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_004_028_000048",
    "sentence": "暉業之在晉陽也，無所交通，居常閑暇，乃撰魏藩王家世，號為《辯宗錄》，四十卷，行於世。",
    "entities": [
      {
        "text": "《辯宗錄》",
        "label": "TITLE",
        "start": 28,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_004_028_000049",
    "sentence": "位望隆重，又以性氣不倫，每被忌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000050",
    "sentence": "天保二年 ，從駕至晉陽，於宮門外罵元韶曰：「爾不及一老嫗，背負璽與人，何不打碎之。我出此言，卽知死也，然爾亦詎得幾時！」文宣聞而殺之，亦斬臨淮公孝友。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_028_000051",
    "sentence": "孝友臨刑，驚惶失措，暉業神色自若。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000052",
    "sentence": "仍鑿冰沉其屍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000053",
    "sentence": "暉業弟昭業，頗有學問，位諫議大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_028_000054",
    "sentence": "莊帝幸洛南，昭業立於閶闔門外叩馬諫，帝避之而過，後勞勉之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_028_000055",
    "sentence": "位給事黃門侍郎、衛將軍，右光祿大夫，卒。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 5,
