        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000163",
    "sentence": "韶第三子德舉，武平末，儀同三司。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000164",
    "sentence": "周 建德七年 ，在鄴城與高元海謀逆，誅。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 4,
        "end": 6
      },
      {
        "text": "在鄴城",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000165",
    "sentence": "韶第四子德衡，武平末，開府儀同三司，隆化時，濟州刺史。",
    "entities": [
      {
        "text": "濟州",
        "label": "LOC",
        "start": 22,
        "end": 24
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000166",
    "sentence": "入周，授儀同大將軍。",
    "entities": [
      {
        "text": "周",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000167",
    "sentence": "韶第七子德堪，武平中，儀同三司。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000168",
    "sentence": "隋大業初，汴州刺史，卒於汝南郡守。",
    "entities": [
      {
        "text": "汴州",
        "label": "LOC",
        "start": 5,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "卒於汝南郡",
        "label": "LOC",
        "start": 10,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000169",
    "sentence": "韶弟孝言",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000170",
    "sentence": "榮第二子孝言，少警發有風儀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000171",
    "sentence": "魏武定末，起家司徒參軍事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000172",
    "sentence": "齊受禪，其兄韶以別封霸城縣侯授之。",
    "entities": [
      {
        "text": "兄韶以別封霸城",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000173",
    "sentence": "累遷儀同三司、度支尚書、清都尹。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000174",
    "sentence": "孝言本以勳戚緒餘，致位通顯，至此便驕奢放逸，無所畏憚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000175",
    "sentence": "曾夜行，過其賓客宋孝王家宿，喚坊民防援，不時應赴，遂拷殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000176",
    "sentence": "又與諸淫婦密遊，為其夫覺，復恃官勢，拷掠而殞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000177",
    "sentence": "時苑內須果木，科民間及僧寺備輸，悉分向其私宅種植。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000178",
    "sentence": "又殿內及園中須石，差車牛從漳河運載，復分車迴取。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000179",
    "sentence": "事悉聞徹，出為海州刺史。",
    "entities": [
      {
        "text": "出為海州",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000180",
    "sentence": "尋以其兄故，徵拜都官尚書，食陽城郡幹，仍加開府。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "食陽城郡",
        "label": "LOC",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000181",
    "sentence": "遷太常卿，除齊州刺史，以贓賄為御史所劾。",
    "entities": [
      {
        "text": "除齊州",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000182",
    "sentence": "屬世祖崩，遇赦免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000183",
    "sentence": "拜太常卿，轉食河南郡幹，遷吏部尚書。",
    "entities": [
      {
        "text": "轉食河南郡",
        "label": "LOC",
        "start": 5,
        "end": 10
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000184",
    "sentence": "祖珽執政，將廢趙彥深，引孝言為助。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000185",
    "sentence": "除兼侍中，入內省，典機密，尋即正，仍吏部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000186",
    "sentence": "孝言既無深鑒，又待物不平，抽擢之徒，非賄則舊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000187",
    "sentence": "有將作丞崔成，忽於衆中抗言曰：「尚書天下尚書，豈獨段家尚書也！」孝言無辭以答，惟厲色遣下而已。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 20,
        "end": 22
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000188",
    "sentence": "尋除中書監，加特進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000189",
    "sentence": "又托韓長鸞，共構祖珽之短。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000190",
    "sentence": "及祖出後，孝言除尚書右僕射，仍掌選舉，恣情用捨，請謁大行。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000191",
    "sentence": "勑濬京城北隍，孝言監作，儀同三司崔士順、將作大匠元士將、太府少卿酈孝裕、尚書左民郎中薛叔昭、司州治中崔龍子、清都尹丞李道隆、鄴縣令尉長卿、臨漳令崔象、成安令高子徹等並在孝言部下。",
    "entities": [
      {
        "text": "勑濬京城",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "尚書",
