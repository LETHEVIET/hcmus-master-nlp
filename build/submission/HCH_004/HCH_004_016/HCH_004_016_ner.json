        "label": "LOC",
        "start": 46,
        "end": 48
      },
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 63,
        "end": 65
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000192",
    "sentence": "典作日，別置酒高會，諸人膝行跪伏，稱觴上壽，或自陳屈滯，更請轉官，孝言意色揚揚，以為己任，皆隨事報答，許有另授。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000193",
    "sentence": "富商大賈多被銓擢，緃令所進用人士，咸是粗險放縱之流。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000194",
    "sentence": "尋遷尚書左僕射，特進、侍中如故。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000195",
    "sentence": "孝言富貴豪侈，尤好女色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000196",
    "sentence": "後娶婁定遠妾董氏，大耽愛之，為此內外不和，更相糾列，坐爭免官，徙光州。",
    "entities": [
      {
        "text": "徙光州",
        "label": "LOC",
        "start": 31,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000197",
    "sentence": "隆化敗後，有勑追還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000198",
    "sentence": "孝言雖黷貨無厭，恣情酒色，然舉止風流，招致名士，美景良辰，未嘗虛棄，賦詩奏伎，畢盡歡洽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000199",
    "sentence": "雖草萊之士，粗閑文藝，多引入賓館，與同興賞，其貧躓者亦時有乞遺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000200",
    "sentence": "世論復以此多之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000201",
    "sentence": "齊亡入周，授開府儀同大將軍，後加上開府。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "周",
        "label": "ORG",
        "start": 3,
        "end": 4
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000202",
    "sentence": "【史論】",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000203",
    "sentence": "史臣曰：段榮以姻戚之重，遇時來之會，功伐之地，亦足稱焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000204",
    "sentence": "韶光輔七君，克隆門業，每出當閫外，或任以留臺，以猜忌之朝，終其眉壽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000205",
    "sentence": "屬亭候多警，為有齊上將，豈其然乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000206",
    "sentence": "當以志謝矜功，名不逾實，不以威權御物，不以智數要時，欲求覆餗，其可得也？",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000207",
    "sentence": "語曰「率性之謂道」，此其效歟？",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000208",
    "sentence": "贊曰：榮發其原，韶大其門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_004_016_000209",
    "sentence": "位因功顯，望以德尊。",
    "entities": []
  },
  {
