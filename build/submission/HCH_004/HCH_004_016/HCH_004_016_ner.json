        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_004_016_000162",
    "sentence": "入周，拜大將軍，郡公，坐事死。",
    "entities": [
      {
        "text": "周",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "大將軍",
