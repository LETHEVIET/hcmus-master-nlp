      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000025",
    "sentence": "今趙琰、李棠、柳檜、杜叔毗、陵彥師、李德饒入別傳及其家傳，其餘並從此編緝，以備《孝行傳》云。",
    "entities": [
      {
        "text": "《孝行傳》",
        "label": "TITLE",
        "start": 39,
        "end": 44
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000026",
    "sentence": "孝行",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000027",
    "sentence": "長孫慮，代人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000028",
    "sentence": "母因飲酒，其父真呵叱之，誤以杖擊，便即致死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000029",
    "sentence": "真為縣囚執，處以重坐。",
    "entities": [
      {
        "text": "真為縣",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000030",
    "sentence": "慮列辭尚書云：「父母忿爭，本無餘惡，直以謬誤，一朝橫禍。今母喪未殯，父命旦夕，慮兄弟五人並沖幼。慮身居長，今年十五，有一女弟，向始四歲。更相鞠養，不能保全，父若就刑，交墜溝壑。乞以身代老父命，使嬰弱眾孤，得蒙存立。」尚書奏云：「慮于父為孝子，于弟為仁兄，尋情究狀，特可矜感。」孝文帝詔特恕其父死罪，以從遠流。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 108,
        "end": 110
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000031",
    "sentence": "乞伏保，高車部人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000032",
    "sentence": "父居，獻文時為散騎常侍，領牧曹尚書，賜爵甯國侯。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000033",
    "sentence": "以忠謹慎密，常在左右，出內詔命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000034",
    "sentence": "賜宮人河南宗氏，亡後，賜以宮人申氏，宋太子左率申坦兄女也。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000035",
    "sentence": "歲餘，居卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000036",
    "sentence": "申撫養伏保，性嚴肅，捶罵切至，而伏保奉事孝謹，初無恨色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000037",
    "sentence": "襲父侯爵，例降為伯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000038",
    "sentence": "稍遷左中郎將。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000039",
    "sentence": "每請祿賜，在外公私尺丈所用，無不白知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000040",
    "sentence": "出為鄯善鎮將。",
    "entities": [
      {
        "text": "出為鄯善鎮",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000041",
    "sentence": "申年逾八十，伏保手制馬車，親自扶接，申欣然隨之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000042",
    "sentence": "申亡，伏保解官，奉喪還洛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000043",
    "sentence": "復為長兼南中郎將，卒。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000044",
    "sentence": "孫益德，樂安人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000045",
    "sentence": "其母為人所害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000046",
    "sentence": "益德童幼，為母復仇，還家哭於殯，以待縣官。",
    "entities": [
      {
        "text": "以待縣",
        "label": "LOC",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000047",
    "sentence": "孝文、文明太后以其幼而孝決，又不逃罪，特免之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000048",
    "sentence": "董洛生，代人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000049",
    "sentence": "居父喪過禮，詔遣秘書中散溫紹伯奉璽書慰之，令自抑割，以全孝道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000050",
    "sentence": "又詔其宗親，使相喻獎，勿令有滅性之譏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000051",
    "sentence": "楊引，鄉郡襄垣人也。",
    "entities": [
      {
        "text": "鄉郡",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000052",
    "sentence": "三歲喪父，為叔所養。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000053",
    "sentence": "母年九十二終，引年七十五，哀毀過禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000054",
    "sentence": "三年服畢，恨不識父，追服斬衰，食粥粗服，誓終身命。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000055",
    "sentence": "經十三年，哀慕不改，為郡縣鄉閭三百餘人上狀稱美。",
    "entities": [
      {
        "text": "十三年",
        "label": "TME",
        "start": 1,
        "end": 4
      },
      {
        "text": "為郡縣鄉",
        "label": "LOC",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000056",
    "sentence": "有司奏宜旌賞，復其一門，樹其純孝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000057",
    "sentence": "詔別敕集書標揚引至行，又可假以散員之名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000058",
    "sentence": "閻元明，河東安邑人也。",
    "entities": [
      {
        "text": "河東安邑",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000059",
    "sentence": "少而至孝，行著鄉閭。",
    "entities": [
      {
        "text": "行著鄉",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000060",
    "sentence": "太和五年，除北隨郡太守。",
    "entities": [
      {
        "text": "太和五年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "除北隨郡",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000061",
    "sentence": "元明以違離親養，興言悲慕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000062",
    "sentence": "母亦慈念，泣淚喪明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000063",
    "sentence": "悲號上訴，許歸奉養。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000064",
    "sentence": "一見其母，母目便開。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000065",
    "sentence": "刺史呂壽恩列狀上聞，詔下州郡，表為孝門，復其租調兵役，令終母年。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "詔下州郡",
        "label": "LOC",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000066",
    "sentence": "母亡服終，心喪積載，每忌日，悲動傍鄰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000067",
    "sentence": "昆弟雍和，尊卑諧穆，安貧樂道，白首同歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000068",
    "sentence": "又猗氏縣人令狐仕，兄弟四人，早喪父，泣慕十載，奉養其母，孝著鄉邑。",
    "entities": [
      {
        "text": "又猗氏縣",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "孝著鄉邑",
        "label": "LOC",
        "start": 28,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000069",
    "sentence": "而力田積粟，博施不已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000070",
    "sentence": "又河東郡人楊風等七百五十人，列稱樂戶皇甫奴兄弟，雖沉屈兵伍，而操尚彌高，奉養繼親，甚著恭孝之稱。",
    "entities": [
      {
        "text": "又河東郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000071",
    "sentence": "又東郡小黃縣人董吐渾、兄養，事親至孝，三世同居，閨門有禮。",
    "entities": [
      {
        "text": "又東郡小黃縣",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000072",
    "sentence": "景明初，畿內大使王凝奏請標異，詔從之。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 1,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000073",
    "sentence": "吳悉達，河東聞喜人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000074",
    "sentence": "兄弟三人，年並幼小，父母為人所殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000075",
    "sentence": "四時號慕，悲感鄉鄰。",
    "entities": [
      {
        "text": "悲感鄉",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000076",
    "sentence": "及長報仇，避地永安。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000077",
    "sentence": "昆弟同居四十餘載，閨門和睦，讓逸競勞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000078",
    "sentence": "雖於儉年，糊饘不繼，賓客經過，必傾所有。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000079",
    "sentence": "每守宰殯喪，私辦車牛，送終葬所。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000080",
    "sentence": "鄰人孤貧窘困者，莫不解衣輟糧，以相賑恤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000081",
    "sentence": "鄉閭五百餘人詣州稱頌焉。",
    "entities": [
      {
        "text": "閭五百餘人詣州",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000082",
    "sentence": "刺史以悉達兄弟行著鄉里，板贈悉達父勃海太守。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "悉達兄弟行著鄉",
        "label": "LOC",
        "start": 3,
        "end": 10
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000083",
    "sentence": "悉達後欲改葬，亡失墳墓，推尋弗獲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000084",
    "sentence": "號哭之聲，晝夜不止，叫訴神祇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000085",
    "sentence": "忽于悉達足下地陷，得父銘記，因遷葬曾祖已下三世九喪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000086",
    "sentence": "傾盡資業，不假於人，哀感毀悴，有過初喪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000087",
    "sentence": "有司奏聞，標閭復役，以彰孝義。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000088",
    "sentence": "時有齊州人崔承宗，其父于宋世仕漢中，母喪因殯彼。",
    "entities": [
      {
        "text": "時有齊州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "漢",
        "label": "ORG",
        "start": 15,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000089",
    "sentence": "後青、徐歸魏，遂為隔絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000090",
    "sentence": "承宗性至孝，萬里投險，偷路負喪還京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000091",
    "sentence": "黃門侍郎孫惠蔚聞之，曰：「吾於斯人，見廉範之情矣。」於是吊贈盡禮，如舊相識。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000092",
    "sentence": "王續生，滎陽京縣人也。",
    "entities": [
      {
        "text": "滎陽京縣",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000093",
    "sentence": "遭繼母憂，居喪，杖而後起。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000094",
    "sentence": "乃終禮制，鬢髮盡落。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000095",
    "sentence": "有司奏聞，宣武詔標旌門閭，甄其徭役。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000096",
    "sentence": "李顯達，潁川陽翟人也。",
    "entities": [
      {
        "text": "李顯達",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000097",
    "sentence": "父喪，水漿不入口七日，鬢髮墮落，形體枯悴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000098",
    "sentence": "六年廬於墓側，哭不絕聲，殆於滅性。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000099",
    "sentence": "州牧高陽王雍以狀奏，靈太后詔表其門閭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000100",
    "sentence": "倉跋，滎陽京縣人也。",
    "entities": [
      {
        "text": "滎陽京縣",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000101",
    "sentence": "喪母，水漿不入口五日，吐血數升，居憂毀瘠，見稱州裏。",
    "entities": [
      {
        "text": "見稱州",
        "label": "LOC",
        "start": 21,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000102",
    "sentence": "有司奏聞，孝武帝詔標門閭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000103",
    "sentence": "張升，滎陽京縣人也。",
    "entities": [
      {
        "text": "滎陽京縣",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000104",
    "sentence": "喪父，飲水絕鹽，哀毀過度，形骸枯悴，骨立而已，發落殆盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000105",
    "sentence": "聲聞鄉里，盜賊不侵其閭。",
    "entities": [
      {
        "text": "聲聞鄉",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000106",
    "sentence": "州表以聞，標其門閭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000107",
    "sentence": "王崇，字乾邕，陽夏雍人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000108",
    "sentence": "兄弟並以孝稱，身勤稼穡，以養二親。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000109",
    "sentence": "仕梁州鎮南府主簿。",
    "entities": [
      {
        "text": "仕梁州鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000110",
    "sentence": "母亡，杖而後起，鬢髮墮落。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000111",
    "sentence": "未及葬，權殯宅西。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000112",
    "sentence": "崇廬於殯所，晝夜哭泣，鳩鴿群至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000113",
    "sentence": "有一小鳥，素質黑眸，形大於雀，棲於崇廬，朝夕不去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000114",
    "sentence": "母喪闋，復丁父憂，哀毀過禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000115",
    "sentence": "是年夏，風雹，所經處，禽獸暴死，草木摧折。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000116",
    "sentence": "至崇田畔，風雹便止，禾麥十頃，竟無損落。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000117",
    "sentence": "及過崇地，風雹如初。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000118",
    "sentence": "咸稱至行所感。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000119",
    "sentence": "崇雖除服，仍居墓側。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000120",
    "sentence": "於其室前，生草一根，莖葉甚茂，人莫能識。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000121",
    "sentence": "至冬中，復有鳥巢崇屋，乳養三子，毛羽成長，馴而不驚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000122",
    "sentence": "守令聞之，親自臨視。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000123",
    "sentence": "州以聞奏，標其門閭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000124",
    "sentence": "郭文恭，太原平遙人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000125",
    "sentence": "仕為太平縣令。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000126",
    "sentence": "年逾七十，父母喪亡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000127",
    "sentence": "文恭孝慕罔極，乃居祖父墓次，晨夕拜跪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000128",
    "sentence": "跣足負土，培祖父二墓，寒暑竭力，積年不已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000129",
    "sentence": "見者莫不哀歎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000130",
    "sentence": "尚書聞奏，標其門閭。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000131",
    "sentence": "荊可，河東猗氏人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000132",
    "sentence": "性質樸，容止有異於人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000133",
    "sentence": "能苦身勤力，供養其母，隨時甘旨，終無匱乏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000134",
    "sentence": "母喪，水漿不入口三日，悲號擗踴，絕而後蘇者數四。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000135",
    "sentence": "葬母之後，遂廬於墓側，晝夜悲哭，負土成墳，蓬發不櫛，菜食飲水而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000136",
    "sentence": "然可家舊墓，塋域極大，榛蕪至深，去家十餘里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000137",
    "sentence": "而可獨宿其中，與禽獸雜處，哀感遠近，邑裏稱之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000138",
    "sentence": "大統中，可鄉人以可孝行足以勸勵風俗，乃上言焉。",
    "entities": [
      {
        "text": "可鄉",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000139",
    "sentence": "周文令州縣表異之。",
    "entities": [
      {
        "text": "周文令州縣",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000140",
    "sentence": "及服終之後，猶若居喪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000141",
    "sentence": "大塚宰、晉公護聞可孝行，特引見焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000142",
    "sentence": "與可言論，時有會於護意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000143",
    "sentence": "而護亦至孝，其母閻氏，沒於敵境，不測存亡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000144",
    "sentence": "每見可，自傷久乖膝下，而重可至性。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000145",
    "sentence": "可卒後，護猶思其純孝，收可妻子于京城，恆給其衣食。",
    "entities": [
      {
        "text": "收可妻子于京城",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000146",
    "sentence": "秦族，上郡洛川人也。",
    "entities": [
      {
        "text": "上郡",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000147",
    "sentence": "祖白、父雚，並有至性，聞於閭里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000148",
    "sentence": "魏太和中，板白潁州刺史。",
    "entities": [
      {
        "text": "板白潁州",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000149",
    "sentence": "大統中，板雚酈城郡守。",
    "entities": [
      {
        "text": "板雚酈城郡",
        "label": "LOC",
        "start": 4,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000150",
    "sentence": "族性至孝，事親竭力。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000151",
    "sentence": "及父喪，哀毀過禮，每一慟哭，酸感行路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000152",
    "sentence": "既以母在，恆抑割哀情，以慰其母意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000153",
    "sentence": "四時珍羞，未嘗匱乏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000154",
    "sentence": "與弟榮先，復相友愛，閨門之中，怡怡如也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000155",
    "sentence": "尋而其母又沒，哭泣無時，唯飲水食菜而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000156",
    "sentence": "終喪之後，猶蔬食，不入房室二十許年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000157",
    "sentence": "鄉里咸歎異之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000158",
    "sentence": "其邑人王元達等七十餘人上其狀，有詔表其門閭。",
    "entities": [
      {
        "text": "其邑",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000159",
    "sentence": "榮先亦至孝，遭父喪，哀慕不已，遂以毀卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000160",
    "sentence": "邑裏化其孝行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000161",
    "sentence": "周文嘉之，乃下詔褒美其行，贈滄州刺史，以旌厥異。",
    "entities": [
      {
        "text": "贈滄州",
        "label": "LOC",
        "start": 13,
        "end": 16
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000162",
    "sentence": "皇甫遐，字永賢，河東汾陰人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000163",
    "sentence": "累世寒微，而鄉里稱其和睦。",
    "entities": [
      {
        "text": "而鄉",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000164",
    "sentence": "遐性純至，少喪父，事母以孝聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000165",
    "sentence": "後遭母喪，乃廬於墓側，負土為墳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000166",
    "sentence": "復于墓南作一禪窟，陰雨則穿窟，晴霽則營墓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000167",
    "sentence": "曉夕勤力，未嘗暫停。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000168",
    "sentence": "積以歲年，墳高數丈，周回五十餘步，禪窟重台兩匝，總成十有二室，中間行道，可容百人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000169",
    "sentence": "遐食粥枕塊，櫛風沐雨，形容枯悴，家人不識。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000170",
    "sentence": "當其營墓之初，乃有鴟鳥各一，徘徊悲鳴，不離墓側，若助遐者，經月餘日乃去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000171",
    "sentence": "遠近聞其至孝，競以米麵遺之，遐皆受而不食，悉以營佛齋焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000172",
    "sentence": "郡縣表上其狀，有詔旌異之。",
    "entities": [
      {
        "text": "郡縣",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000173",
    "sentence": "張元，字孝始，河北芮城人也。",
    "entities": [
      {
        "text": "河北芮城",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000174",
    "sentence": "祖成，假平陽郡守。",
    "entities": [
      {
        "text": "假平陽郡",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000175",
    "sentence": "父延俊，仕州郡，累為功曹主簿。",
    "entities": [
      {
        "text": "仕州郡",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000176",
    "sentence": "並以純至為鄉里所推。",
    "entities": [
      {
        "text": "並以純至為鄉",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000177",
    "sentence": "元性謙謹，有孝行，微涉經史，然精釋典。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000178",
    "sentence": "年六歲，其祖以其夏中熱，欲將元就井浴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000179",
    "sentence": "元固不肯從，謂其貪戲，乃以杖擊其頭曰：「汝何為不肯浴？」元對曰：「衣以蓋形，為覆其褻。元不能褻露其體于白日之下。」祖異而舍之。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 43,
        "end": 44
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000180",
    "sentence": "南鄰有二杏樹，杏熟多落元園中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000181",
    "sentence": "諸小兒競取而食之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000182",
    "sentence": "元所得者，送還其主。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000183",
    "sentence": "樹陌有狗子為人所棄者，元即收而養之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000184",
    "sentence": "其叔父怒曰：「何用此為！」將欲更棄之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000185",
    "sentence": "元對曰：「有生之類，莫不重其性命。若天生天殺，自然之理。今為人所棄而死，非其道也。若見而不收養，無仁心也。是以收而養之。」叔父感其言，遂許焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000186",
    "sentence": "未幾，乃有狗母銜一死兔置元前而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000187",
    "sentence": "及元年十六，其祖喪明三年。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 1,
        "end": 3
      },
      {
        "text": "三年",
        "label": "TME",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000188",
    "sentence": "元恆憂泣，晝夜讀佛經，禮拜以祈福祐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000189",
    "sentence": "後讀《藥師經》，見「盲者得視」之言。",
    "entities": [
      {
        "text": "《藥師經》",
        "label": "TITLE",
        "start": 2,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000190",
    "sentence": "遂請七僧，然七燈，七日七夜轉《藥師經》行道。",
    "entities": [
      {
        "text": "《藥師經》",
        "label": "TITLE",
        "start": 14,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000191",
    "sentence": "每言：「天人師乎！元為孫不孝，使祖喪明。今以燈光普施法界，願祖目見明，元求代暗。」如此經七日，其夜夢見一老翁，以金鑱療其祖目，於夢中喜躍，遂即驚覺。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 9,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000192",
    "sentence": "乃遍告家人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000193",
    "sentence": "三日，祖目果明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000194",
    "sentence": "其後，祖臥疾再周，元恆隨祖所食多少，衣冠不解，旦夕扶侍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000195",
    "sentence": "及祖沒，號踴絕而後蘇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000196",
    "sentence": "隨其父，水漿不入口三日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000197",
    "sentence": "鄉里咸歎異之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000198",
    "sentence": "縣博士楊軌等二百餘人上其狀，有詔表其門閭。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000199",
    "sentence": "王頒，字景彥，太原祁人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000200",
    "sentence": "父僧辯，《南史》有傳。",
    "entities": [
      {
        "text": "《南史》",
        "label": "TITLE",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000201",
    "sentence": "頒少俶儻，有文武幹局。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000202",
    "sentence": "僧辯平侯景，留頒荊州。",
    "entities": [
      {
        "text": "留頒荊州",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000203",
    "sentence": "遇梁元帝為周師所陷，頒因入關。",
    "entities": [
      {
        "text": "頒因入關",
        "label": "LOC",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000204",
    "sentence": "聞其父為陳武帝所殺，號慟而絕，食頃乃蘇，哭不絕聲，毀瘠骨立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000205",
    "sentence": "至服闋，常布衣蔬食，藉槁而臥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000206",
    "sentence": "周明帝嘉之，召授左侍上士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000207",
    "sentence": "累遷漢中太守，尋拜儀同三司。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 2,
        "end": 3
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000208",
    "sentence": "隋開皇初，以平蠻功，加開府，封蛇丘縣公。",
    "entities": [
      {
        "text": "封蛇丘縣",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000209",
    "sentence": "獻取陳之策，上覽而異之，召見，言畢歔欷，上為之改容。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000210",
    "sentence": "及大舉伐陳，頒自請行。",
    "entities": [
      {
        "text": "陳",
        "label": "ORG",
        "start": 4,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000211",
    "sentence": "率兵數百人，從韓擒虎先鋒夜濟，力戰被傷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000212",
    "sentence": "恐不堪復鬥，悲感嗚咽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000213",
    "sentence": "夜中睡，夢有人授藥，比寤而瘡不痛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000214",
    "sentence": "時人以為孝感。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000215",
    "sentence": "及陳滅，頒密召父在時士卒，得千餘人，對之涕泣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000216",
    "sentence": "其間壯士或問曰：「郎君仇恥已雪，而悲哀不止者，將不為霸先早死，不得手刃之邪？請發其丘隴，鬥櫬焚骨，亦可申孝心矣。」頒頓桑陳謝，額盡流血，答曰：「其為墳塋甚大，恐一宵發掘，不及其屍，更至明朝，事乃彰露。」諸人請具鍬鍤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000217",
    "sentence": "於是夜發其陵，剖棺，見陳武帝須皆不落，其本皆出自骨中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000218",
    "sentence": "頒遂焚骨取灰，投水飲之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000219",
    "sentence": "既而自縛歸罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000220",
    "sentence": "晉王表其狀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000221",
    "sentence": "文帝曰：「朕以義平陳。王頒所為，亦孝義之道，何忍罪之？」舍而不問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000222",
    "sentence": "有司錄其戰功，將加柱國，賜物五千段。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000223",
    "sentence": "頒固辭曰：「臣緣國威靈，得雪怨恥，本心徇私，非是為國。所加官賞，終不敢當。」帝從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000224",
    "sentence": "拜代州刺史，甚有惠政。",
    "entities": [
      {
        "text": "拜代州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000225",
    "sentence": "卒于齊州刺史。",
    "entities": [
      {
        "text": "卒于齊州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000226",
    "sentence": "弟頍，字景文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000227",
    "sentence": "年數歲而江陵亡，同諸兄入關。",
    "entities": [
      {
        "text": "同諸兄入關",
        "label": "LOC",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000228",
    "sentence": "少好遊俠，年二十，尚不知書，為其兄顒所責怒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000229",
    "sentence": "於是感激，始讀《孝經》、《論語》，晝夜不倦，遂讀《左傳》、《禮》、《易》、《詩》、《書》，乃歎曰：「書無不可讀者。」勤學累載，遂遍通《五經》，究其旨趣，大為儒者所稱。",
    "entities": [
      {
        "text": "《孝經》",
        "label": "TITLE",
        "start": 7,
        "end": 11
      },
      {
        "text": "《論語》",
        "label": "TITLE",
        "start": 12,
        "end": 16
      },
      {
        "text": "《左傳》",
        "label": "TITLE",
        "start": 24,
        "end": 28
      },
      {
        "text": "《禮》",
        "label": "TITLE",
        "start": 29,
        "end": 32
      },
      {
        "text": "《易》",
        "label": "TITLE",
        "start": 33,
        "end": 36
      },
      {
        "text": "《詩》",
        "label": "TITLE",
        "start": 37,
        "end": 40
      },
      {
        "text": "《書》",
        "label": "TITLE",
        "start": 41,
        "end": 44
      },
      {
        "text": "《五經》",
        "label": "TITLE",
        "start": 66,
        "end": 70
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000230",
    "sentence": "解綴文，善談話。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000231",
    "sentence": "年三十，周武帝引為露門學士，每有議決，多頍所為。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000232",
    "sentence": "性識甄明，精力不倦，好讀諸子，遍記異書，以博物稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000233",
    "sentence": "又曉兵法，益有從橫之志，每歎不逢時，常以將相自許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000234",
    "sentence": "開皇五年，授著作佐郎，尋令于國子講授。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000235",
    "sentence": "會帝親臨釋奠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000236",
    "sentence": "國子祭酒元善講《孝經》，頍與相論難，詞義鋒起，善往往見屈。",
    "entities": [
      {
        "text": "《孝經》",
        "label": "TITLE",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000237",
    "sentence": "帝大奇之，超授國子博士。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000238",
    "sentence": "後坐事解職，配防嶺南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000239",
    "sentence": "數載，授漢王諒府諮議參軍，王甚禮之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000240",
    "sentence": "時諒見房陵及秦、蜀二王相次廢黜，潛有異志。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000241",
    "sentence": "頍陰勸諒繕甲兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000242",
    "sentence": "及文帝崩，諒遂舉兵反，多頍之計也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000243",
    "sentence": "頍後數進奇策，諒不能用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000244",
    "sentence": "楊素至蒿澤，將戰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000245",
    "sentence": "頍謂其子曰：「氣候殊不佳，兵必敗。汝可隨從我。」既而兵敗，頍將歸突厥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000246",
    "sentence": "至山中，徑路斷絕，知必不免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000247",
    "sentence": "謂其子曰：「吾之計謀，不減楊素，但為言不見從，遂至於此。不能坐受禽執，以成豎子之名也。吾死後，汝慎勿過親故！」於是自殺，瘞之石窟中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000248",
    "sentence": "其子數日不得食，遂過其故人，竟為所禽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000249",
    "sentence": "楊素求頍屍得之，斬首，梟於太原。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000250",
    "sentence": "所撰《五經大義》三十卷，有集二十卷，並因兵亂，無復存焉。",
    "entities": [
      {
        "text": "《五經大義》",
        "label": "TITLE",
        "start": 2,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000251",
    "sentence": "楊慶，字伯悅，河間人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000252",
    "sentence": "祖玄、父剛，並以至孝知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000253",
    "sentence": "慶美容止，性辯慧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000254",
    "sentence": "年十六，齊國子博士徐遵明見而異之。",
    "entities": [
      {
        "text": "齊國",
        "label": "ORG",
        "start": 4,
        "end": 6
      },
      {
        "text": "博士",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000255",
    "sentence": "及長，頗涉書記。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000256",
    "sentence": "年二十五，郡察孝廉，以侍養不赴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000257",
    "sentence": "母有疾，不解襟帶者七旬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000258",
    "sentence": "及居母憂，哀毀骨立，負土成墳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000259",
    "sentence": "齊文宣表其門閭，賜帛及綿粟各有差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000260",
    "sentence": "隋文帝受禪，屢加褒賞，擢授儀同三司，板平陽太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000261",
    "sentence": "卒於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000262",
    "sentence": "田翼，不知何許人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000263",
    "sentence": "養母以孝聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000264",
    "sentence": "其後母臥疾歲餘，翼親易燥濕，母食則食，母不食則不食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000265",
    "sentence": "隋開皇中，母患暴痢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000266",
    "sentence": "翼謂中毒藥，遂親嘗穢惡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000267",
    "sentence": "母終，翼一慟而絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000268",
    "sentence": "妻亦不勝哀而死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000269",
    "sentence": "鄉人厚共葬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000270",
    "sentence": "紐因，字孝政，河東安邑人也。",
    "entities": [
      {
        "text": "河東安邑",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000271",
    "sentence": "性至孝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000272",
    "sentence": "周武成中，父母喪，廬於墓側，負土成墳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000273",
    "sentence": "廬前生麻一株，高丈許，圍之合拱，枝葉鬱茂，冬夏恆青。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000274",
    "sentence": "有鳥棲上，因舉聲哭，鳥即悲鳴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000275",
    "sentence": "時人異之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000276",
    "sentence": "周武帝表其閭，擢授甘棠令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000277",
    "sentence": "隋開皇初卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000278",
    "sentence": "子士雄，少質直孝友。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000279",
    "sentence": "喪父，復廬於墓側，負土成墳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000280",
    "sentence": "其庭前有一槐樹，先甚鬱茂，及士雄居喪，樹遂枯死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000281",
    "sentence": "服闋還宅，死槐復榮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000282",
    "sentence": "隋文帝聞之，歎其父子至孝，下詔褒揚，號其居為累德里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000283",
    "sentence": "劉仕俊，彭城人也。",
    "entities": [
      {
        "text": "彭城",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000284",
    "sentence": "性至孝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000285",
    "sentence": "丁母喪，絕而復蘇者數矣，勺飲不入口者七日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000286",
    "sentence": "廬於墓側，負土成墳，列植松柏，虎狼馴擾，為之取食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000287",
    "sentence": "隋文帝受禪，表其門閭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000288",
    "sentence": "翟普林，楚丘人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000289",
    "sentence": "事親以孝聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000290",
    "sentence": "州郡辟皆不就，躬耕色養。",
    "entities": [
      {
        "text": "州郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000291",
    "sentence": "鄉閭謂為楚丘先生。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000292",
    "sentence": "後父母疾，親易澡濕，不解衣者七旬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000293",
    "sentence": "大業初，父母俱終，哀毀殆將滅性。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000294",
    "sentence": "廬於墓側，負土成墳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000295",
    "sentence": "盛冬不衣繒絮，唯著單縗而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000296",
    "sentence": "家有鳥犬，隨其在墓，若普林哀臨，犬亦悲號，見者嗟異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000297",
    "sentence": "有二鵲巢其廬前柏樹，入廬馴狎，無所驚懼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000298",
    "sentence": "司隸巡察，奏其孝感，擢授孝陽令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000299",
    "sentence": "華秋，汲郡臨河人也。",
    "entities": [
      {
        "text": "汲郡",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000300",
    "sentence": "幼喪父，事母以孝聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000301",
    "sentence": "家貧，傭賃為養。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000302",
    "sentence": "其母患疾，秋容貌毀悴，鬢須盡改。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000303",
    "sentence": "母終，遂絕櫛沐，發盡禿落。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000304",
    "sentence": "廬於墓側，負土成墳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000305",
    "sentence": "有人欲助之者，秋輒拜而止之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000306",
    "sentence": "隋大業初，調狐皮，郡縣大獵。",
    "entities": [
      {
        "text": "郡縣",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000307",
    "sentence": "有一兔，逐之，奔入秋廬中，匿秋膝下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000308",
    "sentence": "獵人至廬所，異而免之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000309",
    "sentence": "自爾，此兔常宿廬中，馴其左右。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000310",
    "sentence": "郡縣嘉其孝感，具以狀聞。",
    "entities": [
      {
        "text": "郡縣",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000311",
    "sentence": "降使勞問，而表其門閭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000312",
    "sentence": "後群盜起，常往來廬之左右，咸相誡曰：「勿犯孝子鄉。」賴秋全者甚眾。",
    "entities": [
      {
        "text": "勿犯孝子鄉",
        "label": "LOC",
        "start": 19,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000313",
    "sentence": "徐孝肅，汲郡人也。",
    "entities": [
      {
        "text": "汲郡",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000314",
    "sentence": "宗族數十家，多以豪侈相尚，唯孝肅儉約。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000315",
    "sentence": "事親以孝聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000316",
    "sentence": "雖在幼小，宗黨間每有爭訟，皆至孝肅所平論，短者無不引咎而退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000317",
    "sentence": "孝肅早孤，不識父。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000318",
    "sentence": "及長，問其母父狀，因畫工圖其形，構廟置之而定省焉，朔望享祭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000319",
    "sentence": "養母至孝，數十年家人未見其忿恚色。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_003_084_000320",
    "sentence": "母老疾，孝肅視易燥濕，憂悴數年，見者莫不悲悼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000321",
    "sentence": "母終，孝肅茹蔬飲水，盛冬單縗，毀瘠骨立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000322",
    "sentence": "祖父母、父母墓，皆負土成墳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000323",
    "sentence": "廬于墓所四十餘載，被髮徒跣，遂以終身。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000324",
    "sentence": "其弟德備終，子處默，又廬於墓側。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000325",
    "sentence": "弈世稱孝焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000326",
    "sentence": "【論】",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000327",
    "sentence": "論曰：塞天地而橫四海者，唯孝而已矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000328",
    "sentence": "然則孝始愛敬之方，終極哀思之道，厥亦多緒，其心一焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000329",
    "sentence": "若上智稟自然之質，中庸有企及之義，及其成名，其美一也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000330",
    "sentence": "長孫慮等或出公卿之緒，藉禮教之資；或出茆笪之下，非獎勸所得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000331",
    "sentence": "並因心乘理，不逾禮教，感通所致，貫之神明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000332",
    "sentence": "乃有負土成墳，致毀滅性，雖乖先王之典制，亦觀過而知仁矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_084_000333",
    "sentence": "本唐朝作品在全世界都属于 公有领域 ，因为作者逝世已经遠遠超过100年。",
    "entities": [
      {
        "text": "100年",
        "label": "TME",
        "start": 31,
        "end": 35
      }
    ]
  }
]
