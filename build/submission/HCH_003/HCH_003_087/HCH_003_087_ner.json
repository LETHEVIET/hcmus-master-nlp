[
  {
    "sentence_id": "HCH_003_087_000001",
    "sentence": "酷吏",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000002",
    "sentence": "于洛侯 胡泥 李洪之 子 神 張赦提 趙霸 崔暹 邸珍 田式 燕榮 元弘嗣 王文同",
    "entities": [
      {
        "text": "于洛侯",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "李洪之",
        "label": "PER",
        "start": 7,
        "end": 10
      },
      {
        "text": "張赦提",
        "label": "PER",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000003",
    "sentence": "夫為國之體有四焉：一曰仁義，二曰禮制，三曰法令，四曰刑罰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000004",
    "sentence": "仁義、禮制，教之本也；法令、刑罰，教之末也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000005",
    "sentence": "無本不立，無末不成。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000006",
    "sentence": "然教化遠而刑罰近，可以助化而不可以專行，可以立威而不可以繁用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000007",
    "sentence": "老子曰：「其政察察，其人缺缺。」又曰：「法令滋章，盜賊多有。」然則，令之煩苛，吏之嚴酷，不可致化，百世可知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000008",
    "sentence": "考覽前載，有時而用之矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000009",
    "sentence": "昔秦任獄吏，赭衣滿道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000010",
    "sentence": "漢革其風，矯枉過正，禁綱疏闊，遂漏吞舟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000011",
    "sentence": "故大奸巨猾，犯義悖禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000012",
    "sentence": "郅都、甯成之倫，猛氣奮發，摧拉凶邪，一切以救時弊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000013",
    "sentence": "雖乖教義，或有所取焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000014",
    "sentence": "于洛侯之徒，前書編之《酷吏》。",
    "entities": [
      {
        "text": "于洛侯",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "《酷吏》",
        "label": "TITLE",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000015",
    "sentence": "或因餘緒，或以微功，遭遇時來，忝竊高位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000016",
    "sentence": "肆其褊性，多行無禮，君子小人，咸罹其毒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000017",
    "sentence": "凡所蒞職，莫不懍然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000018",
    "sentence": "居其下者，視之如蛇虺；過其境者，逃之如寇仇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000019",
    "sentence": "與人之恩，心非好善；加人之罪，事非疾惡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000020",
    "sentence": "其所笞辱，多在無辜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000021",
    "sentence": "察其所為，豺狼之不若也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000022",
    "sentence": "其禁奸除猾，殆與郅、寧之倫異乎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000023",
    "sentence": "君子賤之，故編於《酷吏》。",
    "entities": [
      {
        "text": "《酷吏》",
        "label": "TITLE",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000024",
    "sentence": "魏 有于洛侯、胡泥、李洪之、高遵、張赦提、羊祉、崔暹、酈道元、穀楷。",
    "entities": [
      {
        "text": "于洛侯",
        "label": "PER",
        "start": 3,
        "end": 6
      },
      {
        "text": "李洪之",
        "label": "PER",
        "start": 10,
        "end": 13
      },
      {
        "text": "張赦提",
        "label": "PER",
        "start": 17,
        "end": 20
      },
      {
        "text": "酈道元",
        "label": "PER",
        "start": 27,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000025",
    "sentence": "齊 有邸珍、宋游道、盧斐、畢義云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000026",
    "sentence": "《 周書 》不立此篇。",
    "entities": [
      {
        "text": "《 周書 》",
        "label": "TITLE",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000027",
    "sentence": "《 隋書 》有庫狄士文、田式、燕榮、趙仲卿、崔弘度、元弘嗣、王文同。",
    "entities": [
      {
        "text": "《 隋書 》",
        "label": "TITLE",
        "start": 0,
        "end": 6
      },
      {
        "text": "趙仲卿",
        "label": "PER",
        "start": 18,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000028",
    "sentence": "今檢高遵、羊祉、酈道元、谷楷、宋游道、盧斐、畢義雲、庫狄士文、趙仲卿、崔弘度各從其家傳，其餘並列於此云。",
    "entities": [
      {
        "text": "酈道元",
        "label": "PER",
        "start": 8,
        "end": 11
      },
      {
        "text": "畢義雲",
        "label": "PER",
        "start": 22,
        "end": 25
      },
      {
        "text": "趙仲卿",
        "label": "PER",
        "start": 31,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000029",
    "sentence": "于洛侯",
    "entities": [
      {
        "text": "于洛侯",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000030",
    "sentence": "于洛侯，代人也。",
    "entities": [
      {
        "text": "于洛侯",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000031",
    "sentence": "為秦州刺史，貪酷安忍。",
    "entities": [
      {
        "text": "為秦州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000032",
    "sentence": "部人富熾奪人呂勝脛纏一具，洛侯輒鞭富熾一百，截其右腕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000033",
    "sentence": "百姓王隴客刺殺人王羌奴、王愈二人，依律罪死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000034",
    "sentence": "而洛侯生拔隴客舌，刺其本，並刺胸腹二十餘瘡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000035",
    "sentence": "隴客不堪苦痛，隨刀戰動。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000036",
    "sentence": "乃立四柱，磔其手足。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000037",
    "sentence": "命將絕，始斬其首，支解四體，分懸道路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000038",
    "sentence": "見者無不傷楚歎愕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000039",
    "sentence": "百姓王元壽等一時反叛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000040",
    "sentence": "有司糾劾，孝文詔使者於州常刑人處，宣告兵人，然後斬洛侯以謝百姓。",
    "entities": [
      {
        "text": "孝文詔使者於州",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000041",
    "sentence": "胡泥",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000042",
    "sentence": "胡泥，代人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000043",
    "sentence": "曆官至司衛監，賜爵永成侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000044",
    "sentence": "泥率勒禁中，不憚豪貴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000045",
    "sentence": "殿中尚書叔孫侯頭應內直而闕於一時，泥以法繩之。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000046",
    "sentence": "侯頭恃寵，遂與口諍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000047",
    "sentence": "孝文聞而嘉焉，賜泥衣服一襲，出為幽州刺史，假范陽。",
    "entities": [
      {
        "text": "出為幽州",
        "label": "LOC",
        "start": 14,
        "end": 18
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000048",
    "sentence": "以北平陽尼碩學，遂表薦之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000049",
    "sentence": "轉為定州刺史。",
    "entities": [
      {
        "text": "轉為定州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000050",
    "sentence": "以暴虐，刑罰酷濫，受納貨賄，徽還戮之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000051",
    "sentence": "將就法，孝文臨太華殿引見，遣侍臣宣詔責之，遂就家賜盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000052",
    "sentence": "李洪之",
    "entities": [
      {
        "text": "李洪之",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000053",
    "sentence": "李洪之，本名文通，恆農人也。",
    "entities": [
      {
        "text": "李洪之",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000054",
    "sentence": "少為沙門，晚乃還俗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000055",
    "sentence": "真君中，為狄道護軍，賜爵安陽男。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000056",
    "sentence": "會永昌王仁隨太武南征，得元後姊妹二人，洪之潛相餉遺，結為兄弟，遂便如親。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000057",
    "sentence": "頗得元後在南兄弟名字，乃改名洪之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000058",
    "sentence": "及仁坐事誅，元後入宮，得幸於文成，生獻文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000059",
    "sentence": "元後臨崩，太后問其親，因言洪之為兄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000060",
    "sentence": "與相訣經日，具條列南方諸兄珍之等，手以付洪之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000061",
    "sentence": "遂號為獻文親舅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000062",
    "sentence": "太安中，珍之等兄弟至都，與洪之相見，敘元後平生故事，計長幼為昆季。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000063",
    "sentence": "以外戚為河內太守，進爵任城侯，威儀一同刺史。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "進爵任城",
        "label": "LOC",
        "start": 9,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000064",
    "sentence": "河內北連上党，南接武牢，地險人悍，數為劫害，長吏不能禁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000065",
    "sentence": "洪之至郡，嚴設科防，募斬賊者，便加重賞，勤勸務本，盜賊止息。",
    "entities": [
      {
        "text": "洪之至郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000066",
    "sentence": "誅鋤奸黨，過為酷虐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000067",
    "sentence": "後為懷州刺史，封漢郡公，徵拜內都大官。",
    "entities": [
      {
        "text": "後為懷州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "封漢郡",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000068",
    "sentence": "河西羌胡領部落反叛，獻文親征，命洪之與侍中、東郡王陸定總統諸軍。",
    "entities": [
      {
        "text": "東郡",
        "label": "LOC",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000069",
    "sentence": "輿駕至并州，詔洪之為河西都將，討山胡。",
    "entities": [
      {
        "text": "輿駕至并州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000070",
    "sentence": "皆保險距戰，洪之築壘於石樓南白雞原以對之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000071",
    "sentence": "時諸將悉欲進攻，洪之乃開以大信，聽其復業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000072",
    "sentence": "胡人遂降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000073",
    "sentence": "獻文嘉之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000074",
    "sentence": "遷拜尚書、外都大官。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000075",
    "sentence": "後為使持節、安南將軍、秦、益二州刺史。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "益二州",
        "label": "LOC",
        "start": 13,
        "end": 16
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000076",
    "sentence": "至任，設禁奸之制。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000077",
    "sentence": "有帶刃行者，罪與劫同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000078",
    "sentence": "輕重品格，各有條章。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000079",
    "sentence": "於是大饗州中豪傑長老，示之法制。",
    "entities": [
      {
        "text": "於是大饗州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000080",
    "sentence": "乃夜密遣騎分部覆諸要路，有犯禁者，輒捉送州，宣告斬決。",
    "entities": [
      {
        "text": "輒捉送州",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000081",
    "sentence": "其中枉見殺害者，至有百數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000082",
    "sentence": "赤葩渴郎羌深居山谷，雖相羈縻，王人罕到。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000083",
    "sentence": "洪之芟山為道，廣十餘步，示以軍行之勢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000084",
    "sentence": "乃興軍臨其境，山人驚駭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000085",
    "sentence": "洪之將數十騎至其里閭，撫其妻子，問所疾苦，因資遺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000086",
    "sentence": "眾羌喜悅，求編課調，所入十倍於常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000087",
    "sentence": "洪之善禦戎夷，頗有威惠，而刻害之聲，聞於朝野。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000088",
    "sentence": "初，洪之微時妻張氏，亦聰強婦人，自貧賤至富貴，多所補益，有男女幾十人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000089",
    "sentence": "洪之後得劉芳從姊，重之，疏張氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000090",
    "sentence": "亦多所產育。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000091",
    "sentence": "為兩宅別居，偏厚劉室，由是二妻妒競，兩宅母子，往來如仇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000092",
    "sentence": "及蒞西州，以劉自隨。",
    "entities": [
      {
        "text": "及蒞西州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000093",
    "sentence": "洪之素非廉清，每有受納。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000094",
    "sentence": "時孝文始建祿制，法禁嚴峻，遂鎖洪之赴京，親臨太華，庭集群臣數之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000095",
    "sentence": "以其大臣，聽在家自裁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000096",
    "sentence": "洪之志性慷慨，多所堪忍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000097",
    "sentence": "疹病炙療，艾炷圍將二寸，首足十餘處，一時俱下，言笑自若，接賓不輟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000098",
    "sentence": "及臨盡，沐浴衣幍，防卒扶持，出入遍巡家庭，如是再三，泣歎良久，乃臥而引藥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000099",
    "sentence": "始洪之托為元後兄，公私自同外戚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000100",
    "sentence": "至此罪後，孝文乃稍對百官辯其誣假。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000101",
    "sentence": "而諸李猶善相視，恩紀如親。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000102",
    "sentence": "洪之始見元後，計年為兄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000103",
    "sentence": "及珍之等至，洪之以元後素定長幼，其呼拜坐，皆如家人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000104",
    "sentence": "暮年，數延攜之宴飲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000105",
    "sentence": "醉酣之後，時或言及本末，洪之則起而加敬，笑語自若。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000106",
    "sentence": "富貴赫奕，舅戚之家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000107",
    "sentence": "遂棄宗，專附珍之等。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000108",
    "sentence": "後頗存振本屬，而猶不顯然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000109",
    "sentence": "劉氏四子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000110",
    "sentence": "子 神",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000111",
    "sentence": "長子神，少有膽略，以氣尚為名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000112",
    "sentence": "以軍功封長樂縣男，累遷平東將軍、太中大夫。",
    "entities": [
      {
        "text": "以軍功封長樂縣",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000113",
    "sentence": "孝昌中，行相州事，尋正加撫軍。",
    "entities": [
      {
        "text": "行相州",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000114",
    "sentence": "葛榮盡銳攻之，久不能克。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000115",
    "sentence": "會葛榮見禽，以功進爵為公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000116",
    "sentence": "元顥入洛，莊帝北巡，以神為侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000117",
    "sentence": "又除殿中尚書，仍行相州事。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "仍行相州",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000118",
    "sentence": "車駕還宮，改封安康郡公。",
    "entities": [
      {
        "text": "改封安康郡",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000119",
    "sentence": "普泰元年，進驃騎大將軍、儀同三司、相州大中正。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 8,
        "end": 11
      },
      {
        "text": "相州",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000120",
    "sentence": "薨，贈司徒公，冀州刺史。",
    "entities": [
      {
        "text": "冀州",
        "label": "LOC",
        "start": 7,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000121",
    "sentence": "子士<素勺>。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000122",
    "sentence": "齊受禪，例降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000123",
    "sentence": "張赦提",
    "entities": [
      {
        "text": "張赦提",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000124",
    "sentence": "張赦提，中山安喜人也。",
    "entities": [
      {
        "text": "張赦提",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000125",
    "sentence": "性雄武，有規畫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000126",
    "sentence": "初為武卉中郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000127",
    "sentence": "時京畿盜魁，首稱豹子、彪子，並善弓馬，於靈丘、應門間聚為劫害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000128",
    "sentence": "至乃斬人首，射其口，刺人臍，引腸繞樹而共射之，以為戲笑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000129",
    "sentence": "其暴酷如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000130",
    "sentence": "軍騎掩捕，久弗能獲，行者患焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000131",
    "sentence": "赦提為逐賊軍將，未幾而獲彪子、豹子及其黨與，盡送京師，斬於闕下，自是清靜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000132",
    "sentence": "其靈丘羅思祖，宗門豪溢，家處隘險，多止亡命，與之為劫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000133",
    "sentence": "獻文怒之，孥戮其家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000134",
    "sentence": "而思祖家黨，相率寇盜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000135",
    "sentence": "赦提募求捕逐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000136",
    "sentence": "以赦提為遊徼軍將，前後擒獲，殺之略盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000137",
    "sentence": "因此，濫有屠害，尤為忍酷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000138",
    "sentence": "既資前稱，又藉此功，除幽州刺史，假安喜侯。",
    "entities": [
      {
        "text": "除幽州",
        "label": "LOC",
        "start": 10,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000139",
    "sentence": "赦提克己厲約，遂有清稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000140",
    "sentence": "後頗縱妻段氏，多有受納。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000141",
    "sentence": "命僧尼因事通請，貪虐流聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000142",
    "sentence": "中散李真香出使幽州，採訪牧守政績。",
    "entities": [
      {
        "text": "李真香出使幽州",
        "label": "LOC",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000143",
    "sentence": "真香驗案其罪，赦提懼死欲逃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000144",
    "sentence": "其妻姑為太尉、東陽王丕妻，恃丕親貴，自許詣丕申訴求助，謂赦提曰：「當為訴理，幸得申雪，願寬憂，不為異計。」赦提以此，差自解慰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000145",
    "sentence": "段乃陳列：真香昔嘗因假而過幽州，知赦提有好牛，從索不果。",
    "entities": [
      {
        "text": "嘗因假而過幽州",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000146",
    "sentence": "令台使止挾前事，故威逼部下，拷楚過極，橫以無辜，證成誣罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000147",
    "sentence": "執事恐有不盡，使駕部令趙秦州重往究訊，事狀如前，處赦提大辟。",
    "entities": [
      {
        "text": "使駕部令趙秦州",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000148",
    "sentence": "孝文詔賜死於第。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000149",
    "sentence": "將就盡，命妻而責之曰：「貪濁穢吾者卿也，又安吾而不得免禍，九泉之下，當為仇仇矣。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000150",
    "sentence": "趙霸",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000151",
    "sentence": "又有華山太守趙霸，酷暴非理。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000152",
    "sentence": "大使崔光奏霸云：「不遵憲度，威虐任情，至乃手擊吏人，僚屬奔走，不可以君人字下，納之軌物。輒禁止在州。」詔免所居官。",
    "entities": [
      {
        "text": "輒禁止在州",
        "label": "LOC",
        "start": 44,
        "end": 49
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000153",
    "sentence": "崔暹",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000154",
    "sentence": "崔暹，字元欽，本雲清河東武城人也，世家於滎陽、潁川之間。",
    "entities": [
      {
        "text": "本雲清河東武城",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000155",
    "sentence": "性猛酷，少仁恕，奸猾好利，能事勢家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000156",
    "sentence": "初以秀才累遷南袞州刺史，盜用官瓦，贓汙狼籍，為御史中尉李平所糾，免官。",
    "entities": [
      {
        "text": "秀才累遷南袞州",
        "label": "LOC",
        "start": 2,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000157",
    "sentence": "後行豫州事，尋即真。",
    "entities": [
      {
        "text": "後行豫州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000158",
    "sentence": "遣子析戶，分隸三縣，廣占田宅，藏匿官奴，障吝陂葦，侵盜公私，為御史中尉王顯所彈，免官。",
    "entities": [
      {
        "text": "分隸三縣",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000159",
    "sentence": "後累遷瀛州刺史。",
    "entities": [
      {
        "text": "後累遷瀛州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000160",
    "sentence": "貪暴安忍，人庶患之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000161",
    "sentence": "嘗出獵州北，單騎至人村，有汲水婦人，暹令飲馬，因問曰：「崔瀛州何如？」婦人不知是暹，答曰：「百姓何罪！得如此癩兒刺史。」暹默然而去。",
    "entities": [
      {
        "text": "嘗出獵州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "崔瀛州",
        "label": "LOC",
        "start": 28,
        "end": 31
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 56,
        "end": 58
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000162",
    "sentence": "以不稱職，被解還京。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000163",
    "sentence": "武川鎮反，詔暹為都督，李崇討之。",
    "entities": [
      {
        "text": "武川鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000164",
    "sentence": "違崇節度，為賊所敗，單騎潛還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000165",
    "sentence": "禁於廷尉，以女妓園田貨元叉獲免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000166",
    "sentence": "建義初，遇害於河陰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000167",
    "sentence": "贈司徒公、冀州刺史，追封武津縣公。",
    "entities": [
      {
        "text": "冀州",
        "label": "LOC",
        "start": 5,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "追封武津縣",
        "label": "LOC",
        "start": 10,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000168",
    "sentence": "子瓚，字祖珍，位兼尚書左丞，卒。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000169",
    "sentence": "瓚妻，莊帝姊也，後封襄城長公主，故特贈瓚冀州刺史。",
    "entities": [
      {
        "text": "後封襄城",
        "label": "LOC",
        "start": 8,
        "end": 12
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "故特贈瓚冀州",
        "label": "LOC",
        "start": 16,
        "end": 22
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000170",
    "sentence": "子茂，字祖昂，襲祖爵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000171",
    "sentence": "邸珍",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000172",
    "sentence": "邸珍，字安寶，本中山上曲陽人也，魏太和中，徙居武州鎮。",
    "entities": [
      {
        "text": "徙居武州鎮",
        "label": "LOC",
        "start": 21,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000173",
    "sentence": "孝昌中，六鎮兵起，珍遂從杜洛周賊。",
    "entities": [
      {
        "text": "六鎮",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000174",
    "sentence": "洛周為葛榮所吞，珍入榮軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000175",
    "sentence": "榮為爾硃榮所破，珍與其餘黨，俱徙并州。",
    "entities": [
      {
        "text": "俱徙并州",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000176",
    "sentence": "從齊神武出山東。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000177",
    "sentence": "神武起義信都，拜珍長史，封上曲縣侯，除殷州刺史。",
    "entities": [
      {
        "text": "封上曲縣",
        "label": "LOC",
        "start": 12,
        "end": 16
      },
      {
        "text": "除殷州",
        "label": "LOC",
        "start": 18,
        "end": 21
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000178",
    "sentence": "珍求取無厭，大為州人所疾苦。",
    "entities": [
      {
        "text": "大為州",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000179",
    "sentence": "後兼尚書右僕射、大行台，節度諸軍事，擊梁州將成景攜等，解東行圍，回軍彭城。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "擊梁州",
        "label": "LOC",
        "start": 18,
        "end": 21
      },
      {
        "text": "回軍彭城",
        "label": "LOC",
        "start": 32,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000180",
    "sentence": "珍禦下殘酷，士眾離心，至於土人豪族，遇之無禮，遂為州人所害。",
    "entities": [
      {
        "text": "遂為州",
        "label": "LOC",
        "start": 23,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000181",
    "sentence": "後贈定州刺史、司空公。",
    "entities": [
      {
        "text": "後贈定州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000182",
    "sentence": "田式",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000183",
    "sentence": "田式，字顯標，馮翊下邽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000184",
    "sentence": "祖安興、父長樂，仕魏，俱為本郡太守。",
    "entities": [
      {
        "text": "俱為本郡",
        "label": "LOC",
        "start": 11,
        "end": 15
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000185",
    "sentence": "式性剛果，多武藝，拳勇絕人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000186",
    "sentence": "仕周，位渭南太守，政尚嚴猛，吏人重足而立，無敢違法。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000187",
    "sentence": "遷本郡太守，親故屏跡，請托不行。",
    "entities": [
      {
        "text": "遷本郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000188",
    "sentence": "周武帝聞而善之，進位儀同三司，賜爵信都縣公，擢拜延州刺史。",
    "entities": [
      {
        "text": "賜爵信都縣",
        "label": "LOC",
        "start": 15,
        "end": 20
      },
      {
        "text": "擢拜延州",
        "label": "LOC",
        "start": 22,
        "end": 26
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000189",
    "sentence": "從平齊，以功授上開府，徙為建州刺史，改封梁泉縣公。",
    "entities": [
      {
        "text": "徙為建州",
        "label": "LOC",
        "start": 11,
        "end": 15
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "改封梁泉縣",
        "label": "LOC",
        "start": 18,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000190",
    "sentence": "後從韋孝寬討尉遲迥，以功拜大將軍，進爵武山郡公。",
    "entities": [
      {
        "text": "韋孝寬",
        "label": "PER",
        "start": 2,
        "end": 5
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 13,
        "end": 16
      },
      {
        "text": "進爵武山郡",
        "label": "LOC",
        "start": 17,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000191",
    "sentence": "及隋文帝受禪，拜襄州總管。",
    "entities": [
      {
        "text": "拜襄州",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000192",
    "sentence": "專以立威為務，每視事於外，必盛氣以待之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000193",
    "sentence": "其下官屬，股栗無敢仰視。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000194",
    "sentence": "有犯禁者，雖至親昵，無所容貸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000195",
    "sentence": "其女婿京兆杜甯自長安省之，式誡寧無出外。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000196",
    "sentence": "寧久之不得還，竊上北樓，以暢羈思。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000197",
    "sentence": "式知之，杖寧五十。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000198",
    "sentence": "其所愛奴，嘗詣式白事，有蟲上其衣衿，揮袖拂去之，式以為慢己，立棒殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000199",
    "sentence": "或僚吏奸贓，部內劫盜者，無問輕重，悉禁地阱中，寢處糞穢，令受苦毒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000200",
    "sentence": "自非身死，終不得出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000201",
    "sentence": "每赦書到州，式未暇省讀，先召獄卒殺重囚，然後宣示百姓。",
    "entities": [
      {
        "text": "每赦書到州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000202",
    "sentence": "其刻暴如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000203",
    "sentence": "由是為上所譴，除名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000204",
    "sentence": "式慚恚不食，妻子至其所輒怒，唯侍僮二人，給使左右。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000205",
    "sentence": "從家中索椒，欲自殺，家人不與。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000206",
    "sentence": "陰遣侍僮詣市買毒藥，妻子又奪棄之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000207",
    "sentence": "式恚臥，其子信時為儀同，至式前流涕曰：「大人既是朝廷重臣，又無大過，比見公卿放辱者多矣，旋復外用，大人何能久乎？乃至於此！」式欻起抽刀斫信，信避之，刃中於門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000208",
    "sentence": "上知之，以式為罪己之深，復其官爵，尋拜廣州總管，卒官。",
    "entities": [
      {
        "text": "尋拜廣州",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000209",
    "sentence": "燕榮",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000210",
    "sentence": "燕榮，字貴公，華陰弘農人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000211",
    "sentence": "父侃，周大將軍榮性剛嚴，有武藝。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000212",
    "sentence": "仕周，為內侍上士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000213",
    "sentence": "從武帝伐齊，以功授開府儀同三司，封高邑縣公。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 4,
        "end": 5
      },
      {
        "text": "封高邑縣",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000214",
    "sentence": "隋文帝受禪，進位大將軍，進封落叢郡公，拜晉州刺史。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 8,
        "end": 11
      },
      {
        "text": "進封落叢郡",
        "label": "LOC",
        "start": 12,
        "end": 17
      },
      {
        "text": "拜晉州",
        "label": "LOC",
        "start": 19,
        "end": 22
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000215",
    "sentence": "尋從河間王弘擊突厥，以功拜上柱國，遷青州總管。",
    "entities": [
      {
        "text": "遷青州",
        "label": "LOC",
        "start": 17,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000216",
    "sentence": "在州，選絕有力者為伍伯。",
    "entities": [
      {
        "text": "在州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000217",
    "sentence": "吏人過之者，必加詰問，輒楚撻之，創多見骨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000218",
    "sentence": "奸盜屏跡，境內肅然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000219",
    "sentence": "他州縣人經其界者，畏若寇仇，不敢休息。",
    "entities": [
      {
        "text": "他州縣",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000220",
    "sentence": "後因入朝覲，特加恩遇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000221",
    "sentence": "榮以母老，請每歲入朝，上許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000222",
    "sentence": "伐陳之役，以為行軍總管，率水軍自東萊傍海入太湖，取吳郡。",
    "entities": [
      {
        "text": "陳",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "取吳郡",
        "label": "LOC",
        "start": 24,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000223",
    "sentence": "既破丹陽，吳人共立蕭瓛，為宇文述所敗，退保包山。",
    "entities": [
      {
        "text": "宇文述",
        "label": "PER",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000224",
    "sentence": "榮率精甲躡之，瓛敗走，為榮所執。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000225",
    "sentence": "事平，檢校揚州總管。",
    "entities": [
      {
        "text": "檢校揚州",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000226",
    "sentence": "尋徵為武候將軍，後除幽州總管。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "後除幽州",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000227",
    "sentence": "榮性嚴酷，有威容，長吏見者，莫不惶懼自失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000228",
    "sentence": "范陽盧氏，世為著姓，榮皆署為吏卒，以屈辱之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000229",
    "sentence": "鞭笞左右，動至千數，流血盈前，飲啖自若。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000230",
    "sentence": "嘗按部，道次見叢荊，堪為笞箠，命取之，輒以試人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000231",
    "sentence": "人或自陳無咎，榮曰：'後有罪，當免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000232",
    "sentence": "」及後犯細過，將撾之，人曰：「前日被杖，許有罪宥之。」榮曰：「無過尚爾，況有過邪！」榜捶如舊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000233",
    "sentence": "榮每巡省管內，聞人吏妻有美色，輒舍其室而淫之，貪暴放縱日甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000234",
    "sentence": "時元弘嗣除幽州長史，懼辱，固辭。",
    "entities": [
      {
        "text": "時元弘嗣除幽州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000235",
    "sentence": "上知之，敕榮曰：「弘嗣杖十已上罪，皆奏聞。」榮忿曰：「豎子何敢弄我！」及遣弘嗣監納倉粟，颺得一糠一秕，罰之，每笞不滿十，然一日中或至三數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000236",
    "sentence": "如是歷年，怨隙日構。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000237",
    "sentence": "榮遂收付獄，禁絕其糧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000238",
    "sentence": "弘嗣饑，抽衣絮雜水咽之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000239",
    "sentence": "其妻詣闕稱冤，上遣考功侍郎劉士龍馳驛鞫問，奏榮毒虐，又贓穢狼籍，遂征還京，賜死。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000240",
    "sentence": "先是，榮家寢室無故有蛆數斛從地墳出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000241",
    "sentence": "未幾，榮死於蛆出之處。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000242",
    "sentence": "有子詢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000243",
    "sentence": "元弘嗣",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000244",
    "sentence": "元弘嗣，河南洛陽人也。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000245",
    "sentence": "祖剛，魏漁陽王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000246",
    "sentence": "父經，周漁陽郡公。",
    "entities": [
      {
        "text": "周漁陽郡",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000247",
    "sentence": "弘嗣少襲爵，十八為左親衛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000248",
    "sentence": "開皇元年，從晉王平陳，以功授上儀同。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000249",
    "sentence": "後除觀州長史，以嚴峻任事，州人多怨之。",
    "entities": [
      {
        "text": "後除觀州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000250",
    "sentence": "轉幽州。",
    "entities": [
      {
        "text": "轉幽州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000251",
    "sentence": "時總管燕榮肆虐於弘嗣，每笞辱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000252",
    "sentence": "弘嗣心不伏，遂被禁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000253",
    "sentence": "及榮誅，弘嗣為政，酷又甚之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000254",
    "sentence": "每鞫囚，多以酢灌鼻，或椓弋其下竅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000255",
    "sentence": "無敢隱情，奸偽屏息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000256",
    "sentence": "仁壽末，授木工監，修營東都。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000257",
    "sentence": "大業初，煬帝潛有遼東意，遣弘嗣於東萊海口監造船。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000258",
    "sentence": "諸州役丁苦其捶楚，官人當作，晝夜立水中，略不敢息，自腰已下無不蛆生，死者十三四。",
    "entities": [
      {
        "text": "諸州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000259",
    "sentence": "尋遷黃門侍郎，轉殿中少監。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000260",
    "sentence": "遼東之役，進位金紫光祿大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000261",
    "sentence": "後奴賊寇隴西，詔弘嗣擊之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000262",
    "sentence": "及玄感反，弘嗣屯兵安定。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000263",
    "sentence": "或告之謀應玄感，代王侑遣執送行在所。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000264",
    "sentence": "以無反釋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000265",
    "sentence": "帝疑之，除名徙日南，道死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000266",
    "sentence": "有子仁觀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000267",
    "sentence": "王文同",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000268",
    "sentence": "王文同，京兆頻陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000269",
    "sentence": "性明辯，有幹用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000270",
    "sentence": "開皇中，以軍功拜儀同，授桂州司馬。",
    "entities": [
      {
        "text": "授桂州",
        "label": "LOC",
        "start": 11,
        "end": 14
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000271",
    "sentence": "煬帝嗣位，為光祿少卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000272",
    "sentence": "以忤旨，出為恆山郡贊務。",
    "entities": [
      {
        "text": "出為恆山郡",
        "label": "LOC",
        "start": 4,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000273",
    "sentence": "有一人豪猾，每持長吏長短，前後守令咸憚之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000274",
    "sentence": "文同下車，聞其名而數之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000275",
    "sentence": "因令剡木為大橛，埋之於庭，出尺餘，四面各埋小橛，令其人踣心於木橛上，縛四支於小橛，以棒打其背，應時潰爛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000276",
    "sentence": "郡中大駭，吏人懾氣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000277",
    "sentence": "及帝征遼東，令文同巡察河北諸郡，文同見沙門齋戒菜食者，以為妖妄，皆收系之。",
    "entities": [
      {
        "text": "同巡察河北諸郡",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000278",
    "sentence": "北至河間，召郡官人。",
    "entities": [
      {
        "text": "召郡",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000279",
    "sentence": "小有遲違者，輒覆面於地而捶殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000280",
    "sentence": "求沙門相聚講論及長老共為佛會者數百人，文同以為聚結惑眾，盡斬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000281",
    "sentence": "又悉裸僧尼，驗有淫狀非童男女者數千人，復將殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000282",
    "sentence": "郡中士女，號哭於路，諸郡驚駭，各奏其事。",
    "entities": [
      {
        "text": "諸郡",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000283",
    "sentence": "帝聞大怒，遣使者違奚善意馳鎖之，斬於河間，以謝百姓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000284",
    "sentence": "仇人剖其棺，臠其肉啖之，斯須咸盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000285",
    "sentence": "【論】",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000286",
    "sentence": "論曰：士之立名，其途不一，或以循良進，或以嚴酷顯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000287",
    "sentence": "故寬猛相資，德刑互設。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000288",
    "sentence": "然不嚴而化，君子所先。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000289",
    "sentence": "于洛侯等為惡不同，同歸於酷，肆其毒螫，多行殘忍。",
    "entities": [
      {
        "text": "于洛侯",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_087_000290",
    "sentence": "賤人肌膚，同諸木石；輕人性命，甚於芻狗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000291",
    "sentence": "長惡不悛，鮮有不及。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000292",
    "sentence": "故或身嬰罪戮，或憂恚俱殞，異術皆斃，各其宜焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000293",
    "sentence": "凡百君子，以為有天道矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_087_000294",
    "sentence": "本唐朝作品在全世界都属于 公有领域 ，因为作者逝世已经遠遠超过100年。",
    "entities": [
      {
        "text": "100年",
        "label": "TME",
        "start": 31,
        "end": 35
      }
    ]
  }
]
