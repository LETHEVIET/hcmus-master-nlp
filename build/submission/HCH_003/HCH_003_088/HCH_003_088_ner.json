        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000092",
    "sentence": "蘭根申表薦修，明帝詔付雍州刺史蕭寶夤訪實以聞。",
    "entities": [
      {
        "text": "明帝詔付雍州",
        "label": "LOC",
        "start": 7,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "蕭寶夤",
        "label": "PER",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000093",
    "sentence": "會寶夤作逆，事不行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000094",
    "sentence": "崔廓",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000095",
    "sentence": "崔廓，字士玄，博陵安平人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000096",
    "sentence": "父子元，齊燕州司馬。",
    "entities": [
      {
        "text": "齊燕州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000097",
    "sentence": "廓少孤貧，母賤，由是不為邦族所齒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000098",
    "sentence": "初為裏佐，屢逢屈辱，於是感激，逃入山中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000099",
    "sentence": "遂博覽書籍，多所通涉，山東學者皆宗之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000100",
    "sentence": "既還鄉，不應辟命。",
    "entities": [
      {
        "text": "既還鄉",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000101",
    "sentence": "與趙郡李士謙為忘言友，時稱崔、李。",
    "entities": [
      {
        "text": "與趙郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000102",
    "sentence": "士謙死，廓哭之慟，為之作傳，輸之秘府。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000103",
    "sentence": "士謙妻盧氏寡居，每家事，輒令人諮廓取定。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000104",
    "sentence": "廓嘗著論言刑名之理，其義甚精，文多不載。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000105",
    "sentence": "隋大業中，終於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000106",
    "sentence": "子 賾",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000107",
    "sentence": "子賾，字祖浚，七歲能屬文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000108",
    "sentence": "容貌短小，有口辯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000109",
    "sentence": "開皇初，秦孝王薦之，射策高第。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000110",
    "sentence": "詔與諸儒定樂，授校書郎，轉協律郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000111",
    "sentence": "太常卿蘇威雅重之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000112",
    "sentence": "母憂去職，性至孝，水漿不入口者五日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000113",
    "sentence": "後徵為河南、豫章二王侍讀，每更日來往二王之第。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000114",
    "sentence": "及河南為晉王，轉記室參軍，自此去豫章。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000115",
    "sentence": "王重之不已，遺賾書曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000116",
    "sentence": "賾答曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000117",
    "sentence": "豫章得書，齎米五十石，並衣服、錢帛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000118",
    "sentence": "時晉邸文翰，多成其手。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000119",
    "sentence": "王入東宮，除太子齋帥，俄兼舍人。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000120",
    "sentence": "及元德太子薨，以疾歸於家。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000121",
    "sentence": "後征起居舍人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000122",
    "sentence": "大業四年，從駕汾陽宮，次河陽鎮。",
    "entities": [
      {
        "text": "大業四年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "次河陽鎮",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000123",
    "sentence": "藍田令王曇于藍田山得一玉人，長三四寸，著大領衣，冠幘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000124",
    "sentence": "奏之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000125",
    "sentence": "詔問群臣，莫有識者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000126",
    "sentence": "賾答曰：「謹案：漢文帝已前，未有冠幘，即是文帝以來所制也。臣見魏大司農盧元明撰《嵩高山廟記》云：『有神人，以玉為形，像長數寸，或出或隱，出則令世延長。』伏惟陛下，應天順人，定鼎嵩、雒，嶽神自見，臣敢稱慶。」因再拜，百官畢賀。",
    "entities": [
      {
        "text": "《嵩高山廟記》",
        "label": "TITLE",
        "start": 39,
        "end": 46
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000127",
    "sentence": "天子大悅，賜縑二百匹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000128",
    "sentence": "從駕往太山，詔問賾曰：「何處有羊腸阪？」賾答曰：「臣案《漢書·地理志》，上党壺關縣有羊腸阪。」帝曰：「不是。」又答曰：「臣案皇甫士安撰《地書》，云太原北九十里，有羊腸阪。」帝曰：「是也。」因謂牛弘曰：「崔祖浚所謂問一知二。」",
    "entities": [
      {
        "text": "《漢書·地理志》",
        "label": "TITLE",
        "start": 27,
        "end": 35
      },
      {
        "text": "上党壺關縣",
        "label": "LOC",
        "start": 36,
        "end": 41
      },
      {
        "text": "《地書》",
        "label": "TITLE",
        "start": 67,
        "end": 71
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000129",
    "sentence": "五年，受詔與諸儒撰《區宇圖志》二百五十卷，奏之。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "《區宇圖志》",
        "label": "TITLE",
        "start": 9,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000130",
    "sentence": "帝不善之，更令虞世基、許善心演為六百卷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000131",
    "sentence": "以父憂去職，尋起令視事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000132",
    "sentence": "遼東之役，授鷹揚長史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000133",
    "sentence": "置遼東郡縣名，皆賾之議也。",
    "entities": [
      {
        "text": "置遼東郡縣",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000134",
    "sentence": "奉詔作《東征記》。",
    "entities": [
      {
        "text": "《東征記》",
        "label": "TITLE",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000135",
    "sentence": "九年，除越王長史。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000136",
    "sentence": "于時山東盜賊蜂起，帝令撫慰高陽、襄國，歸首者八百餘人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000137",
    "sentence": "十二年，從駕江都。",
    "entities": [
      {
        "text": "十二年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000138",
    "sentence": "宇文化及之弑帝也，引為著作郎，稱疾不起。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000139",
    "sentence": "在路發疾，卒于彭城，年六十九。",
    "entities": [
      {
        "text": "卒于彭城",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000140",
    "sentence": "賾與河南元善、河東柳䛒、太原王劭、吳興姚察、琅琊諸葛潁、信都劉焯、河間劉炫相善，每因休假，清談竟日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000141",
    "sentence": "所著詞、賦、碑、志十餘萬言，撰《洽聞志》七卷，《八代四科志》三十卷。",
    "entities": [
      {
        "text": "《洽聞志》",
        "label": "TITLE",
        "start": 15,
        "end": 20
      },
      {
        "text": "《八代四科志》",
        "label": "TITLE",
        "start": 23,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000142",
    "sentence": "未及施行，江都傾覆，咸為煨燼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000143",
    "sentence": "徐則",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000144",
    "sentence": "徐則，東海郯人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000145",
    "sentence": "幼沈靜，寡嗜欲，受業于周弘正，善三玄，精於論議，聲擅都邑。",
    "entities": [
      {
        "text": "聲擅都邑",
        "label": "LOC",
        "start": 24,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000146",
    "sentence": "則歎曰：「名者實之賓，吾其為賓乎！」遂懷棲隱之操，杖策入縉雲山。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000147",
    "sentence": "後學者數百人苦請教授，則謝而遣之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000148",
    "sentence": "不娶妻，常服巾褐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000149",
    "sentence": "陳太建中，應召來憩於至真觀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000150",
    "sentence": "期月，又辭入天台山。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000151",
    "sentence": "因絕粒養性，所資唯松水而已，雖隆冬冱寒，不服綿絮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000152",
    "sentence": "太傅徐陵為之刊山立頌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000153",
    "sentence": "初在縉雲山，太極真人徐君降之曰：「汝年出八十，當為王者師，然後得道也。」晉王廣鎮揚州，聞其名，手書召之曰：「夫道得眾妙，法體自然，包涵二儀，混成萬物，人能弘道，道不虛行。先生履德養空，宗玄齊物，深曉義理，頗味法門。悅性沖玄，恬神虛白，餐松餌術，棲息煙霞。望赤城而待風雲，遊玉堂而駕龍鳳。雖復藏名台嶽，猶且騰實江、淮。藉甚嘉猷，有勞寤寐。欽承素道，久積虛襟，側席幽人，夢想岩穴。霜風已冷，海氣將寒，偃息茂林，道體休悆。昔商山四皓，輕舉漢庭；淮南八公，來儀籓邸。古今雖異，山谷不殊。市朝之隱，前賢已說。導凡述聖。非先生而誰？故遣使人，往彼延請，想無勞東帛，賁然來思，不待蒲輪，去彼空穀。希能屈己，佇望披云。」則謂門人曰：「吾今年八十一，王來召我，徐君之旨，信而不征。」於是遂詣揚州。",
    "entities": [
      {
        "text": "晉王廣鎮揚州",
        "label": "LOC",
        "start": 36,
        "end": 42
      },
      {
        "text": "望赤城",
        "label": "LOC",
        "start": 127,
        "end": 130
      },
      {
        "text": "於是遂詣揚州",
        "label": "LOC",
        "start": 332,
        "end": 338
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000154",
    "sentence": "晉王將請受道法，則辭以時日不便。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000155",
    "sentence": "其後夕中，命待者取香火，如平常朝禮之儀，至於五更而死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000156",
    "sentence": "支體柔弱如生，停留數旬，顏色不變。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000157",
    "sentence": "晉王下書曰：「天台真隱東海徐先生，虛確居宗，沖玄成德，齊物處外，檢行安身。草褐蒲衣，餐松餌朮，棲隱靈岳，五十餘年。卓矣仙才，飄然騰氣，千尋萬頃，莫測其涯。寡人欽承道風，久餐德素，頻遣使乎，遠此延屈，冀得虔受上法，式建良緣。至止甫爾，未淹旬日，厭塵羽化，反真靈府。身體柔軟，顏色不變，經方所謂屍解地仙者哉。誠復師禮未申，而心許有在，雖忘怛化，猶愴於懷。喪事所資，隨須供給。霓裳羽蓋，既且騰雲；空槨餘衣，詎藉墳壟？但杖舄在爾，可同俗法。宜遣使人，送還天台定葬。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000158",
    "sentence": "是時，自江都至天台，在道多見則徒步，云得放還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000159",
    "sentence": "至其舊居，取經書道法，分遣弟子，仍令淨掃一房，曰：「若有客至，宜延之於此。」然後跨石梁而去，不知所之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000160",
    "sentence": "須臾屍柩至，知其靈化，時年八十二。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000161",
    "sentence": "晉王聞而益異之，賵物千段，遣畫工圖其狀，令柳{巧言}為之贊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000162",
    "sentence": "時有建安宋玉泉、會稽孔道茂、丹陽王遠知等，亦行辟穀道，以松水自給，皆為煬帝所重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000163",
    "sentence": "張文詡",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000164",
    "sentence": "張文詡，河東人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000165",
    "sentence": "父琚，開皇中，為洹水令，以清正聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000166",
    "sentence": "文詡博覽群書，特精《三禮》。",
    "entities": [
      {
        "text": "《三禮》",
        "label": "TITLE",
        "start": 9,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000167",
    "sentence": "隋文帝方引天下名儒碩學之士，文詡時游太學，博士房暉遠等莫不推伏之。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000168",
    "sentence": "書侍御史皇甫誕，一時朝彥，恆執弟子之禮，以所乘馬就學邀屈。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000169",
    "sentence": "文詡遂每牽馬步進，意在不因人自致也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000170",
    "sentence": "右僕射蘇威聞而召之，與語大悅，勸令從官，文詡固辭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000171",
    "sentence": "仁壽末，學廢，文詡策杖而歸，灌園為業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000172",
    "sentence": "州郡頻舉，皆不應命。",
    "entities": [
      {
        "text": "州郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000173",
    "sentence": "事母以孝聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000174",
    "sentence": "每以德化人，鄉黨頗移風俗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000175",
    "sentence": "嘗有人夜中竊刈其麥者，見而避之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000176",
    "sentence": "盜因感悟，棄麥而謝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000177",
    "sentence": "文詡慰諭之，自誓不言，固令持去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000178",
    "sentence": "經數年，盜者向鄉人說之，始為遠近所悉。",
    "entities": [
      {
        "text": "盜者向鄉",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000179",
    "sentence": "鄰家築牆，心有不直，文詡因毀舊堵以應之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000180",
    "sentence": "文詡常有腰疾，會醫者自言善禁，文詡令禁之，遂為刀所傷，至於頓伏床枕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000181",
    "sentence": "醫者叩頭請罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000182",
    "sentence": "文詡遽遣之，因為隱，謂妻子曰：「吾昨風眩，落坑所致。」其掩人短，皆此類也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000183",
    "sentence": "州縣以其貧素，將加賑恤，輒辭不受。",
    "entities": [
      {
        "text": "州縣",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000184",
    "sentence": "嘗閒居無事，從容歎曰：「老冉冉而將至，恐修名之不立！」以如意擊几自樂，皆有處所，時人方之閔子騫、原憲焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000185",
    "sentence": "終於家，鄉人為立碑頌，號曰張先生。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000186",
    "sentence": "【論】",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000187",
    "sentence": "論曰：古之所謂隱逸者，非伏其身而不見也，非閉其言而不出也，非藏其智而不發也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000188",
    "sentence": "蓋以恬淡為心，不皦不昧，安時處順，與物無私者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000189",
    "sentence": "眭誇忘懷纓冕，畢志丘園，或隱不違親，貞不絕俗；或不教而勸，虛往實歸，非有自然純德，其孰能至此？",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000190",
    "sentence": "然文詡見傷無慍，徐則志在沈冥，不可親疏，莫能貴賤，皆可謂抱樸之士矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000191",
    "sentence": "崔廓感於屈辱，遂以肥遁見稱；祖浚文籍之美，足以克隆堂構。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000192",
    "sentence": "父子雖動靜殊方，其于成名一也，美哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000193",
    "sentence": "本唐朝作品在全世界都属于 公有领域 ，因为作者逝世已经遠遠超过100年。",
    "entities": [
      {
        "text": "100年",
        "label": "TME",
        "start": 31,
        "end": 35
      }
    ]
  }
]
