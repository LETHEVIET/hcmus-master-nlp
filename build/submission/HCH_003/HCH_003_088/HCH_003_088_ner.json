[
  {
    "sentence_id": "HCH_003_088_000001",
    "sentence": "隱逸",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000002",
    "sentence": "眭誇 馮亮 鄭修 崔廓 子 賾 徐則 張文詡",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000003",
    "sentence": "蓋兼濟獨善，顯晦之殊，其事不同，由來久矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000004",
    "sentence": "昔夷、齊獲全于周武，華矞不容于太公，何哉？",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000005",
    "sentence": "求其心者，許以激貪之用；督其跡者，矯以教義之風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000006",
    "sentence": "而肥遁不歸，代有其人矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000007",
    "sentence": "故《 易 》稱「遁世無悶」，「不事王侯」。",
    "entities": [
      {
        "text": "《 易 》",
        "label": "TITLE",
        "start": 1,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000008",
    "sentence": "《 詩 》云「皎皎白駒，在彼空谷」。",
    "entities": [
      {
        "text": "《 詩 》",
        "label": "TITLE",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000009",
    "sentence": "《禮》云「儒有上不臣天子，下不事諸侯」。",
    "entities": [
      {
        "text": "《禮》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000010",
    "sentence": "《語》曰「舉逸民，天下之人歸心焉」。",
    "entities": [
      {
        "text": "《語》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000011",
    "sentence": "雖出處殊途，語默異用，各言其志，皆君子之道也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000012",
    "sentence": "洪崖兆其始，箕山扇其風，七人作乎周年，四皓光乎漢日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000013",
    "sentence": "魏、晉以降，其流逾廣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000014",
    "sentence": "其大者則輕天下，細萬物；其小者則安苦節，甘賤貧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000015",
    "sentence": "或與世同塵，隨波瀾以俱逝；或違時矯俗，望江湖而獨往。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000016",
    "sentence": "狎玩魚鳥，左右琴書，拾遺粒而織落毛，飲石泉而庇松柏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000017",
    "sentence": "放情宇宙之外，自足懷抱之中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000018",
    "sentence": "然皆欣欣於獨善，鮮汲汲於兼濟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000019",
    "sentence": "夷情得喪，忘懷累有。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000020",
    "sentence": "比夫邁德弘道，匡俗庇人，可得而小，不可得而忽也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000021",
    "sentence": "而受命哲王，守文令主，莫不束帛交馳，蒲輪結轍，奔走岩穀，唯恐不逮者，何哉？",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000022",
    "sentence": "以其道雖未弘，志不可奪，縱無舟楫之功，終有堅貞之操，足以立懦夫之志，息貪競之風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000023",
    "sentence": "與苟得之徒，不可同年共日，所謂無用以為用，無為而無不為也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000024",
    "sentence": "自叔世澆浮，淳風殆盡，錐刀之末，競入成群。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000025",
    "sentence": "而能冥心物表，介然離俗，望古獨適，求友千齡，亦異人矣！",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000026",
    "sentence": "何必御霞乘雲而追日月，窮極天地，始為超遠哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000027",
    "sentence": "案《 魏書 》列眭誇、馮亮、李謐、鄭脩為《 逸士傳 》。",
    "entities": [
      {
        "text": "《 魏書 》",
        "label": "TITLE",
        "start": 1,
        "end": 7
      },
      {
        "text": "《 逸士傳 》",
        "label": "TITLE",
        "start": 20,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000028",
    "sentence": "《 隋書 》列李士謙、崔廓、廓子賾、徐則、張文詡為《 隱逸傳 》。",
    "entities": [
      {
        "text": "《 隋書 》",
        "label": "TITLE",
        "start": 0,
        "end": 6
      },
      {
        "text": "《 隱逸傳 》",
        "label": "TITLE",
        "start": 25,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000029",
    "sentence": "今以李謐、士謙附其家傳，其餘並編附篇，以備《隱逸傳》云。",
    "entities": [
      {
        "text": "《隱逸傳》",
        "label": "TITLE",
        "start": 21,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000030",
    "sentence": "眭誇",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000031",
    "sentence": "眭誇，一名旭，趙郡高邑人也。",
    "entities": [
      {
        "text": "趙郡高邑",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000032",
    "sentence": "祖邁，晉東海王越軍謀掾，後沒石勒，為徐州刺史。",
    "entities": [
      {
        "text": "為徐州",
        "label": "LOC",
        "start": 17,
        "end": 20
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000033",
    "sentence": "父邃，字懷道，慕容寶中書令。",
    "entities": [
      {
        "text": "慕容寶",
        "label": "PER",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000034",
    "sentence": "誇少有大度，不拘小節，耽好書傳，未曾以世務經心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000035",
    "sentence": "好飲酒，浩然物表。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000036",
    "sentence": "年三十，遭父喪，須鬢致白，每一悲哭，聞者為之流涕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000037",
    "sentence": "高尚不仕，寄情丘壑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000038",
    "sentence": "同郡李順願與之交，誇拒而不許。",
    "entities": [
      {
        "text": "同郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000039",
    "sentence": "邦國少長莫不憚之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000040",
    "sentence": "少與崔浩為莫逆之交。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000041",
    "sentence": "浩為司徒，奏徵為中郎，辭疾不赴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000042",
    "sentence": "州郡逼遣，不得已，入京都，與浩相見。",
    "entities": [
      {
        "text": "州郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000043",
    "sentence": "經留數日，唯飲酒談敘平生，不及世利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000044",
    "sentence": "浩每欲論屈之，竟不能發言，其見敬憚如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000045",
    "sentence": "浩後遂投詔書於誇懷，亦不開口。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000046",
    "sentence": "誇曰：「桃簡，卿已為司徒，何足以此勞國士也？吾便將別。」桃簡，浩小名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000047",
    "sentence": "浩慮誇即還，時乘一騾，更無兼騎，乃以誇騾內之廄中，冀相維縶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000048",
    "sentence": "誇遂托鄉人輸租者，謬為御車，乃得出關。",
    "entities": [
      {
        "text": "誇遂托鄉",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "乃得出關",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000049",
    "sentence": "浩知而歎曰：「眭誇獨行士，本不應以小職辱之，又使其人杖策復路，吾當何辭以謝也！」時朝法甚峻，誇既私還，將有私歸之咎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000050",
    "sentence": "浩仍相左右，始得無坐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000051",
    "sentence": "經年，送誇本騾，兼遺以所乘馬，為書謝之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000052",
    "sentence": "誇更不受其騾馬，亦不復書。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000053",
    "sentence": "及浩沒，為之素服，受鄉人弔唁，經一時乃止。",
    "entities": [
      {
        "text": "受鄉",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000054",
    "sentence": "歎曰：「崔公既死，誰能更容眭誇！」婦父巨鹿魏攀，當時名達之士，未嘗備婿之禮，情同朋好。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000055",
    "sentence": "或人謂誇曰：「吾聞有大才者必居貴仕，子何獨在桑榆乎？」遂著《知命論》以釋之。",
    "entities": [
      {
        "text": "《知命論》",
        "label": "TITLE",
        "start": 29,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000056",
    "sentence": "及卒，葬日赴會者如市。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000057",
    "sentence": "無子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000058",
    "sentence": "馮亮",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000059",
    "sentence": "馮亮，字靈通，南陽人，梁平北將軍蔡道恭之甥也。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "蔡道恭",
        "label": "PER",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000060",
    "sentence": "少博覽諸書，又篤好佛理。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000061",
    "sentence": "隨道恭至義陽，會中山王英平義陽，獲焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000062",
    "sentence": "英素聞其名，以禮待接。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000063",
    "sentence": "亮性清靜，後隱居嵩山，感英之德，以時展覲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000064",
    "sentence": "英亡，亮奔赴，盡其哀慟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000065",
    "sentence": "宣武嘗召以為羽林監，領中書舍人，將令侍講《十地》諸經，固辭不許。",
    "entities": [
      {
        "text": "《十地》",
        "label": "TITLE",
        "start": 20,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000066",
    "sentence": "又欲使衣幘入見，苦求以幅巾就朝，遂不強逼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000067",
    "sentence": "還山數年，與僧禮誦為業，蔬食飲水，有終焉之志。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000068",
    "sentence": "會逆人王敞事發，連山中沙門法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000069",
    "sentence": "而亮被執赴尚書省，十餘日，詔特免雪。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000070",
    "sentence": "亮不敢還山，遂寓居景明寺，敕給衣食及其從者數人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000071",
    "sentence": "後思其舊居，復還山室。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000072",
    "sentence": "亮既雅愛山水，又兼工思，結架岩林，甚得棲遊之適。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000073",
    "sentence": "頗以此聞，宣武給其工力，令與沙門統僧暹、河南尹甄深等同視嵩山形勝之處，遂造閒居佛寺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000074",
    "sentence": "林泉既奇，營制又美，曲盡山居之妙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000075",
    "sentence": "亮時出京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000076",
    "sentence": "延昌二年冬，因遇篤疾，宣武敕以馬輿送令還山，居嵩高道場寺，數日卒。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000077",
    "sentence": "詔贈帛二百匹，以供凶事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000078",
    "sentence": "遺誡兄子綜，殮以衣蒨，左手持板，右手執《孝經》一卷，置屍磐石上，去人數里外，積十餘日，乃焚於山，灰燼處，起佛塔經藏。",
    "entities": [
      {
        "text": "《孝經》",
        "label": "TITLE",
        "start": 19,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000079",
    "sentence": "初、亮以盛冬喪，連日驟雪，窮山荒澗，鳥獸饑窘，僵屍山野，無所防護。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000080",
    "sentence": "時有壽春道人惠需，每旦往看其屍，拂去塵霰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000081",
    "sentence": "禽蟲之跡，交橫左右，而初無侵毀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000082",
    "sentence": "衣服如本，唯風蒨巾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000083",
    "sentence": "又以亮識舊南方法師信大栗十枚，言期之將來十地果報，開亮手，以置把中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000084",
    "sentence": "經宿，乃為蟲鳥盜食，皮殼在地，而亦不傷肌體。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000085",
    "sentence": "焚燎之日，有素霧蓊鬱，回繞其傍，自地屬天，彌朝不絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000086",
    "sentence": "山中道俗營助者百餘人，莫不異焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000087",
    "sentence": "鄭修",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000088",
    "sentence": "鄭修，北海人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000089",
    "sentence": "少隱于岐南凡穀中，依岩結宇，不交世俗，雅好經史，專意玄門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_003_088_000090",
    "sentence": "前後州將，每徵不至。",
    "entities": [
      {
        "text": "前後州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_003_088_000091",
    "sentence": "岐州刺史魏蘭根頻遣致命，修不得已，暫出見蘭根，尋還山舍。",
