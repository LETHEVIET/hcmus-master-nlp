[
  {
    "sentence_id": "HCH_007_054_000001",
    "sentence": "王鎔",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000002",
    "sentence": "王鎔，其先回鶻部人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000003",
    "sentence": "遠祖沒諾幹，唐至德中，事鎮州節度使王武俊為騎將。",
    "entities": [
      {
        "text": "事鎮州",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000004",
    "sentence": "武俊嘉其勇幹，畜為假子，號王五哥，其後子孫以王為氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000005",
    "sentence": "四代祖廷湊，事鎮帥王承宗為牙將。",
    "entities": [
      {
        "text": "事鎮",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000006",
    "sentence": "長慶初，承宗卒，穆宗命田宏正為成德軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000007",
    "sentence": "既而鎮人殺宏正，推廷湊為留後，朝廷不能制，因以旄鉞授之。",
    "entities": [
      {
        "text": "既而鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000008",
    "sentence": "廷湊卒，子元逵尚文宗女壽安公主。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000009",
    "sentence": "元逵卒，子紹鼎立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000010",
    "sentence": "紹鼎卒，子景崇立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000011",
    "sentence": "皆世襲鎮州節度使，並前史有傳。",
    "entities": [
      {
        "text": "皆世襲鎮州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000012",
    "sentence": "景崇位至太尉、中書令，封常山王， 中和二年 卒。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000013",
    "sentence": "鎔即景崇之子也，年十歲，三軍推襲父位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000014",
    "sentence": "大順中，武皇將李存孝既平邢、洺，因獻謀於武皇，欲兼並鎮、定，乃連年出師以擾鎮之屬邑。",
    "entities": [
      {
        "text": "欲兼並鎮",
        "label": "LOC",
        "start": 23,
        "end": 27
      },
      {
        "text": "連年出師以擾鎮",
        "label": "LOC",
        "start": 31,
        "end": 38
      },
      {
        "text": "之屬邑",
        "label": "LOC",
        "start": 38,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000015",
    "sentence": "鎔苦之，遣使求救於幽州。",
    "entities": [
      {
        "text": "遣使求救於幽州",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000016",
    "sentence": "〈 （《 舊唐書 》云：時天子蒙塵，九州鼎沸，河東節度使李克用虎視山東，方謀吞據。鎔以重賂結納，請以修和好。晉軍討孟方立於邢州，鎔常奉以芻糧。及方立平，晉將李存孝侵鎔於南部，鎔求援於幽州。） 〉 自是燕帥李匡威頻歲出軍，以為鎔援。",
    "entities": [
      {
        "text": "《 舊唐書 》",
        "label": "TITLE",
        "start": 3,
        "end": 10
      },
      {
        "text": "九州",
        "label": "LOC",
        "start": 18,
        "end": 20
      },
      {
        "text": "晉",
        "label": "ORG",
        "start": 54,
        "end": 55
      },
      {
        "text": "討孟方立於邢州",
        "label": "LOC",
        "start": 56,
        "end": 63
      },
      {
        "text": "鎔求援於幽州",
        "label": "LOC",
        "start": 87,
        "end": 93
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000017",
    "sentence": "時匡威兵勢方盛，以鎔衝弱，將有窺圖之志。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000018",
    "sentence": "景福二年 春，匡威率精騎數萬，再來赴援，會匡威弟匡儔奪據兄位，匡威退無歸路，鎔乃延入府第，館於寶壽佛寺。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000019",
    "sentence": "鎔以匡威因己而失國，又感其援助之力，事之如父。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000020",
    "sentence": "五月，鎔謁匡威於其館，匡威陰遣部下伏甲劫鎔，抱持之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000021",
    "sentence": "鎔曰：「公戒部人勿造次。吾國為晉人所侵，垂將覆滅，賴公濟援之力，幸而獲存。今日之事，本所甘心。」即並轡歸府舍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000022",
    "sentence": "鎔軍拒之，竟殺匡威。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000023",
    "sentence": "鎔本疏瘦，時年始十七，當與匡威並轡之時，電雨驟作，屋瓦皆飛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000024",
    "sentence": "有一人於缺垣中望見鎔，鎔就之，遽挾於馬上，肩之而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000025",
    "sentence": "翌日，鎔但覺項痛頭偏，蓋因為有力者所挾，不勝其苦故也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000026",
    "sentence": "既而訪之，則曰墨君和，乃鼓刀之士也，遂厚賞之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000027",
    "sentence": "〈 （《 太平廣記 》引《劉氏耳目記》云：真定墨君和，幼名三旺。眉目棱岸，肌膚若鐵，年十五六。趙王鎔初即位，曾見之，悅而問曰：「此中何得昆侖兒也？」問其姓，與形質相應，即呼為墨昆侖，因以皂衣賜之。是時，常山縣邑屢為并州中軍所侵掠，趙之將卒疲於戰敵。告急於燕王，李匡威率師五萬來救之。並人攻陷數城。燕王聞之，躬領五萬騎徑與晉師戰於元氏，晉師敗績。趙王感燕王之德，椎牛灑酒，大犒於稾城，輦金二十萬以謝之。燕王歸國，比及境上，為其弟匡儔所拒，趙人以其有德於我，遂營東圃以居之。燕王自以失國，又見趙王之幼，乃圖之。遂伏甲俟趙王，旦至，即使擒之。趙王請曰：「某承先代基構，主此山河，每被鄰寇侵漁，困於守備，賴大王武略，累挫戎鋒，獲保宗祧，實資恩力。顧惟幼懦，夙有卑誠，望不匆匆，可伸交讓。願與大王同歸衙署，即軍府必不拒違。」燕王以為然，遂與趙王並轡而進。俄有大風並黑雲起於城上，大雨雷電，至東角門內，有勇夫袒臂旁來，拳毆燕之介士，即挾負趙王逾垣而走，遂得歸公府。問其姓名，君和恐其難記，但言曰：「硯中之物。」王心志之。左右軍士既見主免難，遂逐燕王。燕王退走於東圃，趙人圍而殺之。趙王既免燕王之難，召墨生以千金賞之，兼賜上第一區，良田萬畝，仍恕其十死，奏授光祿大夫。） 〉",
