    ]
  },
  {
    "sentence_id": "HCH_007_054_000082",
    "sentence": "王都，本姓劉，小字雲郎，中山陘邑人也。",
    "entities": [
      {
        "text": "中山陘邑",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000083",
    "sentence": "初，有妖人李應之得於村落間，養為己子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000084",
    "sentence": "及處直有疾，應之以左道醫之，不久病間，處直神之，待為羽人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000085",
    "sentence": "始假幕職，出入無間，漸署為行軍司馬，軍府之事，鹹取決焉。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000086",
    "sentence": "處直時未有子，應之以都遺於處直曰：「此子生而有異。」因是都得為處直之子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000087",
    "sentence": "其後應之閱白丁於管內，別置新軍，起第於博陵坊，麵開一門，動皆鬼道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000088",
    "sentence": "處直信重日隆，將校相慮，變在朝夕，謀先事為禍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000089",
    "sentence": "會燕師假道，伏甲於外城，以備為不虞，昧旦入郭，諸校因引軍以圍其第，應之死於亂兵，鹹雲不見其屍，眾不解甲。",
    "entities": [
      {
        "text": "伏甲於外城",
        "label": "LOC",
        "start": 6,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000090",
    "sentence": "乃逼牙帳請殺都，處直堅靳之，久乃得免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000091",
    "sentence": "翌日賞勞，籍其兵於臥內，自隊長已上記於別簿，漸以他事孥戮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000092",
    "sentence": "迨二十年，別簿之記，略無孑遺。",
    "entities": [
      {
        "text": "二十年",
        "label": "TME",
        "start": 1,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000093",
    "sentence": "都既成長，總其兵柄，奸詐巧佞，生而知之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000094",
    "sentence": "處直愛養，漸有付托之意，時處直諸子尚幼，乃以都為節度副大使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000095",
    "sentence": "王鬱者，亦處直之孽子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000096",
    "sentence": "〈 （案：以下有闕文。） 〉",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000097",
    "sentence": "天祐十八年十二月，莊宗親征鎮州，敗契丹於沙河。",
    "entities": [
      {
        "text": "十八年",
        "label": "TME",
        "start": 2,
        "end": 5
      },
      {
        "text": "莊宗親征鎮州",
        "label": "LOC",
        "start": 9,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000098",
    "sentence": "明年正月，乘勝追敵，過定州，都馬前奉迎，莊宗幸其府第曲宴。",
    "entities": [
      {
        "text": "過定州",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000099",
    "sentence": "都有愛女，十餘歲，莊宗與之論婚，許為皇子繼岌妻之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000100",
    "sentence": "自是恩寵特異，奏請無不從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000101",
    "sentence": "同光三年 ，莊宗幸鄴都，都來朝覲，留宴旬日，錫賚钜萬，遷太尉、侍中。",
    "entities": [
      {
        "text": "同光三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000102",
    "sentence": "時周元豹見之曰：「形若鯉魚，難免刀機。」 及明宗嗣位，加中書令，然以其奪據父位，深心惡之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000103",
    "sentence": "初，同光中，祁、易二州刺史，都奏部下將校為之，不進戶口，租賦自贍本軍，天成初仍舊。",
    "entities": [
      {
        "text": "易二州",
        "label": "LOC",
        "start": 8,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000104",
    "sentence": "既而安重誨用事，稍以朝政厘之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000105",
    "sentence": "時契丹犯塞，諸軍多屯幽、易間，大將往來，都陰為之備，屢廢迎送，漸成猜間。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000106",
    "sentence": "和昭訓為都籌畫曰：「主上新有四海，其勢易離，可圖自安之計。」會朱守殷據汴州反，鎮州節度使王建立與安重誨不協，心懷怨嫉。",
    "entities": [
      {
        "text": "會朱守殷據汴州",
        "label": "LOC",
        "start": 30,
        "end": 37
      },
      {
        "text": "鎮州",
        "label": "LOC",
        "start": 39,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000107",
    "sentence": "都陰知之，乃遣人說建立謀叛，建立偽許之，密以狀聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000108",
    "sentence": "都又與青、徐、岐、潞、梓五帥蠟書以離聞之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000109",
    "sentence": "三年四月，製削都在身官爵，遣宋州節度使王晏球率師討之。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "遣宋州",
        "label": "LOC",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000110",
    "sentence": "都急與王鬱謀，引契丹為援。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000111",
    "sentence": "洎王師攻城，契丹將托諾率騎萬人來援，都與契丹合兵大戰於嘉山，為王師所敗，唯餒諾以二千騎奔入定州。",
    "entities": [
      {
        "text": "洎王師攻城",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "二千騎奔入定州",
        "label": "LOC",
        "start": 40,
        "end": 47
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000112",
    "sentence": "都仗之守城，呼為諾王，屈身瀝懇，冀其盡力。",
    "entities": [
      {
        "text": "都仗之守城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000113",
    "sentence": "孤壘周年，亦甚有備，諸校或思歸向，以其訪察嚴密，殺人相繼，人無宿謀，故數構不就。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000114",
    "sentence": "都好聚圖書，自常山始破，梁國初平，令人廣將金帛收市，以得為務，不責貴賤，書至三萬卷，名畫樂器各數百，皆四方之精妙者，萃於其府。",
    "entities": [
      {
        "text": "梁國",
        "label": "ORG",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000115",
    "sentence": "四年三月，晏球拔定州，時都校馬讓能降於曲陽門，都巷戰而敗，奔馬歸於府第，縱火焚之，府庫妻孥，一夕俱燼，惟擒托餒並其男四人、弟一人獻於行在。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "晏球拔定州",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000116",
    "sentence": "李繼陶者，莊宗初略地河朔，俘而得之，收養於宮中，故名曰得得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000117",
    "sentence": "天成初，安重誨知其本末，付段佪養之為兒；佪知其不稱，許其就便。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_054_000118",
    "sentence": "王都素蓄異志，潛取以歸，呼為莊宗太子。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_054_000119",
    "sentence": "及都叛，遂僭其服裝，時俾乘墉，欲惑軍士，人咸知其偽，競詬辱之。",
    "entities": []
  },
