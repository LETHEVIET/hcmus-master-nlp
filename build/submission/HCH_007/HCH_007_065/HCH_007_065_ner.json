        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_065_000121",
    "sentence": "累歲移鎮忠武，改京兆尹、西京留守。",
    "entities": [
      {
        "text": "累歲移鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_065_000122",
    "sentence": "楊彥溫據河中作亂，自通率師討平之，授河中節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_065_000123",
    "sentence": "尋自鄜州入為右龍武統軍。",
    "entities": [
      {
        "text": "尋自鄜州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_065_000124",
