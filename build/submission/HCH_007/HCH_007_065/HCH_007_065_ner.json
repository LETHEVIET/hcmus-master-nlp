        "label": "LOC",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_065_000116",
    "sentence": "後因從獵，射中走鹿，轉指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_065_000117",
    "sentence": "佐周德威攻燕軍於涿州，擒燕將郭在鈞。",
    "entities": [
