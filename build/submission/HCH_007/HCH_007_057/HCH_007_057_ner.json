        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_057_000015",
    "sentence": "自是崇韜專典機務，艱難戰伐，靡所不從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_057_000016",
