      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000065",
    "sentence": "即日肩輿歸洛，居於福善裏，修篁嘉木，圖書琴酒，以自適焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000066",
