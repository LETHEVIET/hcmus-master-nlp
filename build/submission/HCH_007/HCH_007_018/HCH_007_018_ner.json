      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000064",
    "sentence": "以風恙拜章乞骸，改刑部尚書致仕。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 11,
