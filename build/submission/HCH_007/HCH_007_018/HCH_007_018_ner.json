[
  {
    "sentence_id": "HCH_007_018_000001",
    "sentence": "張文蔚",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000002",
    "sentence": "張文蔚，字右華，河間人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000003",
    "sentence": "父裼，唐僖宗朝，累為顯官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000004",
    "sentence": "文蔚幼礪文行，求知取友，藹然有佳士之稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000005",
    "sentence": "唐乾符初，登進士第，時丞相裴坦兼判鹽鐵，解褐署巡官。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000006",
    "sentence": "未幾，以畿尉直館。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000007",
    "sentence": "丁家艱，以孝聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000008",
    "sentence": "中和歲，僖宗在蜀，大寇未滅，急於軍費，移鹽鐵於揚州，命李都就判之，奏為轉運巡官。",
    "entities": [
      {
        "text": "移鹽鐵於揚州",
        "label": "LOC",
        "start": 19,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000009",
    "sentence": "駕還長安，除監察御史，遷左補闕侍御史、起居舍人、司勳吏部員外郎，拜司勳郎中、知制誥，歲滿授中書舍人。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 2,
        "end": 4
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000010",
    "sentence": "丁母憂，退居東畿，哀毀過禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000011",
    "sentence": "服闋，復拜中書舍人，俄召入翰林，為承旨學士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000012",
    "sentence": "屬昭宗初還京闕，皇綱浸微，文蔚所發詔令，靡失厥中，論者多之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000013",
    "sentence": "轉戶部侍郎，仍依前充職，尋出為禮部侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000014",
    "sentence": "天祐元年夏，拜中書侍郎、平章事，兼判戶部。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000015",
    "sentence": "時柳璨在相位，擅權縱暴，傾陷賢俊，宰相裴樞等五家及三省而下三十餘人，鹹抱冤就死；縉紳以目，不敢竊語其是非，餘怒所注，亦不啻十許輩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000016",
    "sentence": "文蔚殫其力解之，乃止，士人賴焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000017",
    "sentence": "璨敗死，文蔚兼度支鹽鐵使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000018",
    "sentence": "天祐四年，天子以土運將革，天命有歸，四月，命文蔚與楊涉等總率百僚，奉禪位詔至大梁。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000019",
    "sentence": "太祖受命，文蔚等不易其位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000020",
    "sentence": "開平二年春，暴卒於位，詔贈右僕射。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000021",
    "sentence": "文蔚沈邃重厚，有大臣之風，居家孝且悌，雖位至清顯，與仲季相雜，在太夫人膝下，一不異布素。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000022",
    "sentence": "弟濟美，早得心恙， 〈 （《北夢瑣言》云：張裼尚書有五子：文蔚、彝憲、濟美、仁龜，皆有名第，至宰輔丞郎。內一子，忘其名，少年聞壁魚食神仙字，身有五色，吞之可得仙，因欲試之，遂致心疾。是得急者別自一人非濟美也。） 〉 文蔚撫視殆三十年，士君子稱之。",
    "entities": [
      {
        "text": "《北夢瑣言》",
        "label": "TITLE",
        "start": 13,
        "end": 19
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 23,
        "end": 25
      },
      {
        "text": "三十年",
        "label": "TME",
        "start": 113,
        "end": 116
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000023",
    "sentence": "子鑄，周顯德中，位至秘書監。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000024",
    "sentence": "薛貽矩",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000025",
    "sentence": "薛貽矩，字熙用，河東聞喜人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000026",
    "sentence": "祖存，父廷望，咸有令名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000027",
    "sentence": "貽矩風儀秀聳，其與遊者皆一時英妙，藉甚於文場間。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000028",
    "sentence": "唐乾符中，登進士第，曆度支巡官、集賢校理、拾遺、殿中、起居舍人，召拜翰林學士，加禮部員外郎、知制誥，轉司勳郎中，其職如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000029",
    "sentence": "乾寧中，天子幸石門，貽矩以私屬相失，不及於行在，罷之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000030",
    "sentence": "旋除中書舍人，再踐內署。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000031",
    "sentence": "曆戶部兵部侍郎、學士承旨。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000032",
    "sentence": "及昭宗自鳳翔還京，大翦閹寺，貽矩尚為韓全誨等作畫讚，悉記於內侍省屋壁間，坐是謫官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000033",
    "sentence": "天祐初，除吏部侍郎，不至。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000034",
    "sentence": "太祖素重之，嘗言之於朝，即日拜吏部尚書，俄遷御史大夫。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 17,
        "end": 19
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 22,
        "end": 24
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000035",
    "sentence": "四年春，唐帝命貽矩持詔赴大梁，議禪代之事。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000036",
    "sentence": "貽矩至，盛稱太祖功德，請就北面之禮，太祖雖謙抑不納，待之甚厚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000037",
    "sentence": "受禪之歲夏五月，拜中書侍郎、平章事，兼判戶部。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000038",
    "sentence": "明年夏，進拜門下侍郎、監修國史，判度支，又遷宏文館大學士，充鹽鐵轉運使，累官自僕射至守司空。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000039",
    "sentence": "在任綿五載，然亦無顯赫事跡可紀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000040",
    "sentence": "扈從貝州還，染時癘，旬日卒於東京。",
    "entities": [
      {
        "text": "扈從貝州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000041",
    "sentence": "詔贈侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000042",
    "sentence": "張策",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000043",
    "sentence": "張策，字少逸，敦煌人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000044",
    "sentence": "父同，仕唐，官至容管經略使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000045",
    "sentence": "策少聰警好學，尤樂章句。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000046",
    "sentence": "居洛陽敦化裏，嘗浚甘泉井，得古鼎，耳有篆字曰：「魏黃初元年春二月，匠吉千」，且又製作奇巧，同甚寶之。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 1,
        "end": 3
      },
      {
        "text": "元年",
        "label": "TME",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000047",
    "sentence": "策時在父旁，徐言曰：「建安二十五年，曹公薨，改年為延康，其年十月，文帝受漢禪，始號黃初，則是黃初元年無二月明矣。鼎文何謬歟！」同大驚，亟遣啟書室，取《魏志》展讀，一不失所啟，宗族奇之，時年十三。",
    "entities": [
      {
        "text": "建安二十五年",
        "label": "TME",
        "start": 11,
        "end": 17
      },
      {
        "text": "元年",
