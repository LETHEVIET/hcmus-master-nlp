  },
  {
    "sentence_id": "HCH_007_018_000109",
    "sentence": "乾寧中，改光祿少卿充職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000110",
    "sentence": "天復中，授檢校禮部尚書，遙領蘇州刺史。",
