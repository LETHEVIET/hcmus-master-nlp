    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000067",
    "sentence": "所著《典議》三卷、詞製歌詩二十卷、箋表三十卷，存於其家。",
