        "start": 48,
        "end": 50
      },
      {
        "text": "《魏志》",
        "label": "TITLE",
        "start": 74,
        "end": 78
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000048",
    "sentence": "然而妙通因果，酷奉空教，未弱冠，落發為僧，居雍之慈恩精廬，頗有高致。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000049",
    "sentence": "唐廣明末，大盜犯闕，策遂返初服，奉父母逃難，君子多之。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 2,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000050",
    "sentence": "及丁家艱，以孝聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000051",
    "sentence": "服滿，自屏郊藪，一無幹進意，若是者十餘載，方出為廣文博士，改秘書郎。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000052",
    "sentence": "王行瑜帥邠州，辟為觀察支使，帶水曹員外郎，賜緋。",
    "entities": [
      {
        "text": "王行瑜帥邠州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000053",
    "sentence": "及行瑜反，太原節度使李克用奉詔討伐，行瑜敗死，邠州平。",
    "entities": [
      {
        "text": "邠州",
        "label": "LOC",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000054",
    "sentence": "策與婢肩輿其親，南出邠境，屬邊寨積雪，為行者所哀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000055",
    "sentence": "太祖聞而嘉之，奏為鄭滑支使，尋以內憂去職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000056",
    "sentence": "製闋，除國子博士，遷膳部員外郎。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000057",
    "sentence": "不一歲，華帥韓建辟為判官，及建領許州，又為掌記。",
    "entities": [
      {
        "text": "及建領許州",
        "label": "LOC",
        "start": 13,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000058",
    "sentence": "天復中，策奉其主書幣來聘，太祖見而喜曰：「張夫子且至矣。」 即奏為掌記，兼賜金紫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000059",
    "sentence": "天祐初，表其才，拜職方郎中，兼史館修撰，俄召入為翰林學士，轉兵部郎中，知制誥，依前修史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000060",
    "sentence": "未幾，遷中書舍人，職如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_018_000061",
    "sentence": "太祖受禪，改工部侍郎，加承旨。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_018_000062",
    "sentence": "其年冬，轉禮部侍郎。",
    "entities": [
      {
        "text": "侍郎",
