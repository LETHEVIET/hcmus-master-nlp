        "start": 22,
        "end": 27
      },
      {
        "text": "允權據西城",
        "label": "LOC",
        "start": 28,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000148",
    "sentence": "會漢高祖建義於太原，遣使安撫，密乃棄其城奔於太原，隨漢祖歸汴，久居於闕下。",
    "entities": [
      {
        "text": "密乃棄其城",
        "label": "LOC",
        "start": 15,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000149",
    "sentence": "廣順初，授太子太師致仕。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000150",
    "sentence": "顯德元年春卒，時年七十五。",
    "entities": [
      {
        "text": "顯德元年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000151",
    "sentence": "長子銳，仕皇朝為內職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000152",
    "sentence": "次子廣，歷諸衛大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000153",
    "sentence": "李懷忠",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000154",
    "sentence": "李懷忠，字光孝，太原晉陽人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000155",
    "sentence": "父海，本府軍校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000156",
    "sentence": "懷忠形質魁壯，初事唐莊宗，隸於保衛軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000157",
    "sentence": "夾城之役，懷忠率先登城，以功補本軍副兵馬使。",
    "entities": [
      {
        "text": "夾城",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "懷忠率先登城",
        "label": "LOC",
        "start": 5,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000158",
    "sentence": "莊宗平定山東，累遷保衛軍使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000159",
    "sentence": "天成中，歷陜府、許州、滄州都指揮使，遙領辰州刺史。",
    "entities": [
      {
        "text": "許州",
        "label": "LOC",
