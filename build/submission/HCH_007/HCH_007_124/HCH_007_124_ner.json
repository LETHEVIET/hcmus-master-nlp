      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "遷復州",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000197",
    "sentence": "國初，加檢校太保，尋受代歸闕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000198",
    "sentence": "屬太祖親征兗海，以延遇為先鋒都校，兗州平，授齊州防禦使。",
    "entities": [
      {
        "text": "兗州",
        "label": "LOC",
        "start": 17,
        "end": 19
      },
      {
        "text": "授齊州",
        "label": "LOC",
        "start": 21,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000199",
    "sentence": "歲餘，改兗州防禦使。",
    "entities": [
      {
        "text": "改兗州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000200",
    "sentence": "在兗二年，為政有聞，人甚安之，州民數百詣闕，乞立德政碑以頌其美。",
    "entities": [
      {
        "text": "二年",
