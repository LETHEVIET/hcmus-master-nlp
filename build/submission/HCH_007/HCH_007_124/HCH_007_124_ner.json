        "start": 57,
        "end": 59
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000174",
    "sentence": "領代州日，兼蕃漢馬步都部署。",
    "entities": [
      {
        "text": "領代州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000175",
    "sentence": "漢高祖鎮並門，表為副留守、檢校太保。",
    "entities": [
