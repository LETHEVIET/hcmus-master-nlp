[
  {
    "sentence_id": "HCH_007_124_000001",
    "sentence": "王殷",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000002",
    "sentence": "王殷，瀛州人。",
    "entities": [
      {
        "text": "瀛州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000003",
    "sentence": "曾祖昌裔，本州別駕。",
    "entities": [
      {
        "text": "本州",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000004",
    "sentence": "祖光，滄州教練使，因家焉。",
    "entities": [
      {
        "text": "滄州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000005",
    "sentence": "唐末，幽、滄大亂，殷父鹹珪避地南遷，因投於魏軍。",
    "entities": [
      {
        "text": "唐",
        "label": "ORG",
        "start": 0,
        "end": 1
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000006",
    "sentence": "殷自言生於魏州之開元寺，既長從軍，漸為偏將。",
    "entities": [
      {
        "text": "殷自言生於魏州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000007",
    "sentence": "唐同光末，為華州馬步軍副指揮使，因家於華下。",
    "entities": [
      {
        "text": "為華州",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000008",
    "sentence": "天成中，移授靈武都指揮使，久之代還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000009",
    "sentence": "清泰中，張令昭據鄴叛，殷從範延光討之，首冒矢石，率先登城，以功授祁州刺史，尋改原州。",
    "entities": [
      {
        "text": "率先登城",
        "label": "LOC",
        "start": 24,
        "end": 28
      },
      {
        "text": "以功授祁州",
        "label": "LOC",
        "start": 29,
        "end": 34
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 34,
        "end": 36
      },
      {
        "text": "尋改原州",
        "label": "LOC",
        "start": 37,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000010",
    "sentence": "殷性謙謹好禮，事母以孝聞，每與人結交，過從皆先稟於母，母命不從，殷必不往，雖在軍旅，交遊不雜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000011",
    "sentence": "及為刺史，政事小有不佳，母察之，立殷於庭，詰責而杖之。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000012",
    "sentence": "〈 （《歐陽史》：殷為刺史，政事有小失，母責之，殷即取杖授婢仆，自笞於母前。） 〉 晉天福中，丁內艱，尋有詔起復，授憲州刺史，殷上章辭曰：「臣為末將，出處無損益於國家。臣本燕人，值鄉國離亂，少罹偏罰，因母鞠養訓導，方得成人，不忍遽釋苴麻，遠離廬墓，伏願許臣終母喪紀。」晉高祖嘉而許之。",
    "entities": [
      {
        "text": "《歐陽史》",
        "label": "TITLE",
        "start": 3,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "授憲州",
        "label": "LOC",
        "start": 57,
        "end": 60
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 60,
        "end": 62
      },
      {
        "text": "值鄉",
        "label": "LOC",
        "start": 89,
        "end": 91
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000013",
    "sentence": "晉少帝嗣位，會殷服闋，召典禁軍，累遷奉國右廂都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000014",
    "sentence": "漢祖受命，從討杜重威於鄴下，殷與劉詞皆率先力戰，矢中於首，久之，出折鏃於口中，以是漢祖嘉之。",
    "entities": [
      {
        "text": "杜重威",
        "label": "PER",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000015",
    "sentence": "乾祐末，遷侍衛步軍都指揮使，領夔州節度使，會契丹寇邊，遣殷領兵屯澶州。",
    "entities": [
      {
        "text": "領夔州",
        "label": "LOC",
        "start": 14,
        "end": 17
      },
      {
        "text": "遣殷領兵屯澶州",
        "label": "LOC",
        "start": 27,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000016",
    "sentence": "及李業等作亂，漢隱帝密詔澶帥李洪義遣圖殷，洪義懼不克，反以變告殷，殷與洪義同遣人至鄴，請太祖赴內難。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000017",
    "sentence": "殷從平京師，授侍衛親軍都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000018",
    "sentence": "太祖即位，授天雄軍節度使，加同平章事，典軍如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000019",
    "sentence": "殷赴鎮，以侍衛司局從，凡河北征鎮有戍兵處，鹹稟殷節制。",
    "entities": [
      {
        "text": "殷赴鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "凡河北征鎮",
        "label": "LOC",
        "start": 11,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000020",
    "sentence": "又於民間多方聚斂，太祖聞而惡之，因使宣諭曰：「朕離鄴時，帑廩所儲不少，卿與國家同體，隨要取給，何患無財。」二年夏，太祖征兗還，殷迎謁於路，宴賜而去。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 53,
        "end": 55
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000021",
    "sentence": "及王峻得罪，太祖遣其子飛龍使承誨往鄴，令口諭峻之過惡，以慰其心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000022",
    "sentence": "三年秋，以永壽節上表請覲，太祖雖允其請，且慮殷之不誠，尋遣使止之。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000023",
    "sentence": "何福進在鎮州，素惡殷之太橫，福進入朝，摭其陰事以奏之，太祖遂疑之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000024",
    "sentence": "是年冬，以郊禋有日，殷自鎮入覲，太祖令依舊內外巡警。",
    "entities": [
      {
        "text": "殷自鎮",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000025",
    "sentence": "殷出入部從不下數百人，又以儀形魁偉，觀者無不聳然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000026",
    "sentence": "一日，遽入奏曰：「郊禮在近，兵民大集，臣城外防警，請量給甲仗，以備非常。」太祖難之。",
    "entities": [
      {
        "text": "臣城",
        "label": "LOC",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000027",
    "sentence": "時中外以太祖嬰疾，步履稍難，多不視朝，俯逼郊禋，殷有震主之勢，頗憂之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000028",
    "sentence": "太祖乃力疾坐於滋德殿，殷入起居，即命執之，尋降制流竄，及出都城，遽殺之，眾情乃安。",
    "entities": [
      {
        "text": "及出都城",
        "label": "LOC",
        "start": 27,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000029",
    "sentence": "是歲春末，鄴城寺鐘懸絕而落，又火光出幡竿之上。",
    "entities": [
      {
        "text": "鄴城",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000030",
    "sentence": "殷之入覲也，都人餞於離亭，上馬失鐙，翻墮於地，人訝其不祥，果及於禍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000031",
    "sentence": "太祖尋令澶帥鄭仁誨赴鄴，殷次子為衙內指揮使，不出候謁，仁誨誅之，遷其家屬於登州。",
    "entities": [
      {
        "text": "遷其家屬於登州",
        "label": "LOC",
        "start": 32,
        "end": 39
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000032",
    "sentence": "何福進",
    "entities": [
      {
        "text": "何福進",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000033",
    "sentence": "何福進，字善長，太原人。",
    "entities": [
      {
        "text": "何福進",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000034",
    "sentence": "父神劍，累贈左驍衛大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000035",
    "sentence": "福進少從軍，以驍勇聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000036",
    "sentence": "唐同光末，郭從謙以兵圍莊宗於大內，福進時為宿衛軍校，獨出死力拒戰於內，後明宗知而嘉之，擢為捧聖軍校，出為磁州刺史，充北面行營先鋒都校。",
    "entities": [
      {
        "text": "出為磁州",
        "label": "LOC",
        "start": 50,
        "end": 54
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 54,
        "end": 56
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000037",
    "sentence": "清泰中，自彰聖都虞候率本軍從範延光平鄴，以功歷鄭、隴二州防禦使。",
    "entities": [
      {
        "text": "隴二州",
        "label": "LOC",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000038",
    "sentence": "開運中，由潁州團練使入拜左驍衛大將軍。",
    "entities": [
      {
        "text": "由潁州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000039",
    "sentence": "屬契丹陷中原，令中朝文武臣僚凡數十人隨帳北歸，時福進預其行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000040",
    "sentence": "行次鎮州，聞北主已斃，其黨尚據鎮陽，遂與李筠、白再榮之儔合謀力戰，盡逐契丹，據有鎮陽。",
    "entities": [
      {
        "text": "行次鎮州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
