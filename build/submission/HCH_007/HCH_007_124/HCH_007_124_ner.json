        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000160",
    "sentence": "清泰初，以河西蕃部寇鈔，命懷忠屯方渠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000161",
    "sentence": "晉祖受命，以懷忠故人，召典禁兵，三遷護聖左右廂都指揮使，遙領壽州節度使、檢校太保。",
    "entities": [
      {
        "text": "遙領壽州",
        "label": "LOC",
        "start": 28,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000162",
    "sentence": "未幾，為同州節度使、檢校太傅。",
    "entities": [
      {
        "text": "為同州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000163",
    "sentence": "少帝嗣位，入為右羽林統軍，改左武衛上將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000164",
    "sentence": "廣順中，以太子太傅致仕。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000165",
    "sentence": "三年夏卒，年六十六。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000166",
    "sentence": "詔贈太子太師。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000167",
