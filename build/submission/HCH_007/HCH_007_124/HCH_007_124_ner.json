    "entities": [
      {
        "text": "白文珂",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000168",
    "sentence": "白文珂，字德溫，太原人也。",
    "entities": [
      {
        "text": "白文珂",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000169",
    "sentence": "曾祖辯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000170",
    "sentence": "父君成，遼州刺史。",
    "entities": [
