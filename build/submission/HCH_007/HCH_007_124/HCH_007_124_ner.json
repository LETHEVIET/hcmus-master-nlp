      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000187",
    "sentence": "白延遇",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000188",
    "sentence": "白延遇，字希望，太原人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000189",
    "sentence": "幼畜於晉之公宮，年十三，從晉祖伐蜀，以趫悍見稱。",
    "entities": [
      {
        "text": "蜀",
        "label": "ORG",
        "start": 16,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000190",
    "sentence": "晉有天下，歷典禁軍，累遷至檢校司空。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000191",
    "sentence": "天福中，晉祖在鄴，安重榮叛於鎮州，帥眾數萬詣闕而來，晉祖命杜重威統諸將以禦之。",
    "entities": [
      {
        "text": "杜重威",
        "label": "PER",
        "start": 29,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000192",
    "sentence": "時延遇不預其行，乃泣告晉祖，願以身先，許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000193",
    "sentence": "及陣於宗城，延遇率其屬先犯之，斬級數十，戰既酣，而劍亦折，諸將由是推伏。",
    "entities": [
      {
        "text": "及陣於宗城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000194",
    "sentence": "晉祖聞之，即命中使以寶劍良馬賜之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000195",
    "sentence": "常山平，以功授檢校司徒，充馬軍左廂都校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000196",
    "sentence": "後出為汾州刺史，遷復州防禦使。",
    "entities": [
      {
        "text": "後出為汾州",
        "label": "LOC",
        "start": 0,
