      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000185",
    "sentence": "輟視朝一日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000186",
    "sentence": "子廷誨，仕皇朝，歷諸衛將軍卒。",
    "entities": [
      {
        "text": "將軍",
