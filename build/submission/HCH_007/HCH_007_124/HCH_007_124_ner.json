      },
      {
        "text": "楊光遠",
        "label": "PER",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000056",
    "sentence": "後從馬全節伐安陸，敗淮賊萬餘眾，晉祖嘉之，授奉國都校，累加檢校司空。",
    "entities": [
      {
        "text": "馬全節",
        "label": "PER",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000057",
    "sentence": "又從杜重威敗安重榮於宗城。",
    "entities": [
      {
        "text": "杜重威",
        "label": "PER",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000058",
    "sentence": "及圍鎮陽，詞自登雲梯，身先士伍，以功加檢校司徒、沁州刺史。",
    "entities": [
      {
        "text": "及圍鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
