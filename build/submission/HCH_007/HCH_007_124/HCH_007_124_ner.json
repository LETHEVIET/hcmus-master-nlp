  },
  {
    "sentence_id": "HCH_007_124_000129",
    "sentence": "屬契丹來寇，時令溫奉詔入朝，契丹遂陷貝州，其家屬因沒於契丹。",
    "entities": [
      {
        "text": "契丹遂陷貝州",
        "label": "LOC",
        "start": 14,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000130",
    "sentence": "晉少帝憫之，授武勝軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000131",
    "sentence": "未幾，移鎮延州，又遷靈武。",
    "entities": [
      {
        "text": "移鎮延州",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000132",
    "sentence": "漢有天下，復為永清軍節度使，尋改安州。",
    "entities": [
      {
        "text": "尋改安州",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000133",
    "sentence": "國初，加檢校太尉、同平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000134",
    "sentence": "世宗嗣位，遷鎮安軍節度使，罷鎮歸闕。",
    "entities": [
      {
        "text": "遷鎮",
        "label": "LOC",
        "start": 5,
        "end": 7
      },
      {
        "text": "罷鎮",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000135",
    "sentence": "顯德三年夏，以疾卒，時年六十有二，詔贈侍中。",
    "entities": [
      {
        "text": "顯德三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000136",
    "sentence": "周密",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000137",
    "sentence": "周密，字德峰，應州神武川人也。",
    "entities": [
      {
        "text": "應州",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000138",
    "sentence": "初事後唐武皇為軍職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000139",
    "sentence": "莊宗之平常山，明宗之襲汶陽，密皆從征有功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000140",
    "sentence": "莊宗平梁，授鎮州馬軍都指揮使。",
    "entities": [
      {
        "text": "授鎮州",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000141",
    "sentence": "明宗即位，累遷河東馬步軍副都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000142",
    "sentence": "晉天福初，除冀州刺史，累官至檢校司徒，入為右羽林統軍、檢校太保。",
    "entities": [
      {
        "text": "除冀州",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000143",
    "sentence": "四年秋，授保大軍節度使、檢校太傅。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000144",
    "sentence": "屬部民作亂，密討平之，尋移鎮晉州，加檢校太尉。",
    "entities": [
      {
        "text": "尋移鎮晉州",
        "label": "LOC",
        "start": 11,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000145",
    "sentence": "開運中，入拜右龍武統軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000146",
    "sentence": "三年秋，出鎮延州。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "出鎮延州",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000147",
    "sentence": "其年冬，契丹陷中原，延州軍亂，立高允權為帥，時密據東城，允權據西城，相拒久之。",
    "entities": [
      {
        "text": "延州",
        "label": "LOC",
        "start": 10,
        "end": 12
      },
      {
        "text": "時密據東城",
