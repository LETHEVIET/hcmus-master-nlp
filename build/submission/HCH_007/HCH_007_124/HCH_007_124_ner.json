      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000179",
    "sentence": "會河中李守貞叛，詔充河中府行營都部署。",
    "entities": [
      {
        "text": "李守貞",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000180",
    "sentence": "時文珂已老，朝議恐非守貞之敵，乃命太祖西征。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000181",
    "sentence": "河中平，文珂授西京留守、河南尹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000182",
    "sentence": "太祖踐阼，加兼中書令，頃之，以太子太師致仕。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_124_000183",
    "sentence": "世宗即位，封晉國公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000184",
    "sentence": "顯德元年，卒於西京，年七十九。",
    "entities": [
      {
        "text": "顯德元年",
        "label": "TME",
        "start": 0,
