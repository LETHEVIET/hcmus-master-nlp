  {
    "sentence_id": "HCH_007_124_000120",
    "sentence": "贈中書令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000121",
    "sentence": "王令溫",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_124_000122",
