  {
    "sentence_id": "HCH_007_00_000168",
    "sentence": "此外以伧父之见，改尔雅之词，据习俗所安，谓前文有误。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000169",
    "sentence": "与夫“戎王”尽作“契丹”，“编发”俱为避易。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000170",
    "sentence": "武断害理，未易更仆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000171",
    "sentence": "窃以为五季征文，欧史既不如薛史之真，是新、旧两行，自必以旧书为正。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000172",
    "sentence": "奈何搜集于残阙之余，仍见厄于校刊之谬，岂非恨事！",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000173",
    "sentence": "用特举所藏武英殿原抄正本，购机影印，务在纤悉不差，俨然法物，并将粘签及批校各条，汇印附后，俾读是书者得见文勤之所谓真面目焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000174",
    "sentence": "嘉业堂刊本旧五代史跋",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000175",
    "sentence": "旧五代史一百五十卷，目录二卷，宋薛居正等撰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000176",
    "sentence": "原书久佚，乾隆四十年诏开四库馆，从永乐大典中辑录，间有残阙，复取他书所引补之，此为邵学士晋涵原辑本。",
    "entities": [
      {
        "text": "乾隆四十年",
        "label": "TME",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_00_000177",
    "sentence": "晋涵字二云，余姚人，乾隆辛卯二甲进士，归经部铨选。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000178",
    "sentence": "以大学士刘文正荐奉，特旨改庶吉士，充四库馆纂修，旋授职编修，历官至翰林院侍读学士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000179",
    "sentence": "阳湖洪穉存太史尝称其史学本于刘蕺山、黄梨洲两先生。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000180",
    "sentence": "此书乃其一手所勘定也，逐条之下注明采取书名、卷数，后来诸家所辑已佚诸经传注悉用其例。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000181",
    "sentence": "四十九年武英殿刊板尽删去之，彭文勤公屡争于总裁，不见听，薛氏真面目遂不可识。",
    "entities": [
      {
        "text": "四十九年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_00_000182",
    "sentence": "余于甬东卢氏报经楼得其原辑本，亟以千金购归付梓，行格悉遵殿本，俾得两本对勘，学士纂辑之勤不遂湮没，殆有默相之者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000183",
    "sentence": "司马迁史记实继春秋而作，谦不敢自居，曰：“余所谓述故事，整齐其世传，非所谓作。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000184",
    "sentence": "”今观薛史比次旧闻，学士从散佚之余，傍搜博采，整比使之归条理，以复原书之旧，仍每条注明所采书名、卷数，亦述者所有事也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000185",
    "sentence": "若删之，则读者无所征信矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000186",
    "sentence": "兹得学士原辑本刻之，以广其博。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000187",
    "sentence": "彭文勤公所屡争而不得者，一旦竟复旧观，不独读者之幸，亦抑此书之幸也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000188",
    "sentence": "乙丑仲春，吴兴刘承干谨跋。",
    "entities": []
  }
]
