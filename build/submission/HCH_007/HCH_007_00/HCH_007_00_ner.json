  {
    "sentence_id": "HCH_007_00_000016",
    "sentence": "敬请刊诸秘殿，颁在学官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000017",
    "sentence": "搜散佚于七百余年，广体裁于二十三史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000018",
    "sentence": "著名山之录，允宜传播于人间；储乙夜之观，冀禀折衷于睿鉴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_00_000019",
    "sentence": "惟惭疏陋，伏候指挥，谨奏。",
