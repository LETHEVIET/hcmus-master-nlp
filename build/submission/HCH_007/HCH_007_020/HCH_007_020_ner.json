      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000098",
    "sentence": "乾寧二年三月，楊行密復攻濠州，張遂遣嗣勳求援於太祖。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000099",
    "sentence": "俄而郡陷，嗣勳無所歸，即署為元從押牙、副典客，頗稱任使。",
    "entities": [
      {
        "text": "俄而郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000100",
    "sentence": "光化元年三月，太祖令往光州說刺史劉存背淮賊以向國，又從李彥威復黃州及武昌縣，獲刺史瞿章。",
    "entities": [
