      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000050",
    "sentence": "昭宗還京，改常州刺史，賜號迎鑾毅勇功臣。",
    "entities": [
      {
        "text": "改常州",
        "label": "LOC",
