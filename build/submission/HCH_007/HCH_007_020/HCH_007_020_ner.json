        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000139",
    "sentence": "子仁願，晉天福中，仕至大理。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000140",
    "sentence": "寇彥卿",
