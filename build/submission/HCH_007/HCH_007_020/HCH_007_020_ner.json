      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000043",
    "sentence": "光化三年六月，太祖北伐鎮、定，至常山，而王镕危懾，送款於太祖，命捍入壁門傳諭。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
