      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000102",
    "sentence": "會淮賊急攻光州，存與嗣勳率兵大戰，敗而走之。",
    "entities": [
      {
        "text": "會淮賊急攻光州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000103",
    "sentence": "又遣使於蜀，及歸，得其助軍貲實甚多。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000104",
    "sentence": "天復中，太祖迎昭宗於岐下，軍至華之西，使嗣勳入見，韓建即時同出迎謁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000105",
    "sentence": "及羅紹威將殺牙軍，遣使告於太祖，求為外援。",
    "entities": [
