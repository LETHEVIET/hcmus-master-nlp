      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000016",
    "sentence": "開平初，追贈司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000017",
    "sentence": "司馬鄴",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000018",
    "sentence": "司馬鄴，字表仁，其先河內溫人也。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000019",
    "sentence": "祖德璋，仕唐為杞王傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000020",
    "sentence": "父諲，左武衛大將軍。",
