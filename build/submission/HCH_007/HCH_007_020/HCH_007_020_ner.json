      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000121",
    "sentence": "光化二年夏四月，幽、滄侵淩魏郡，復以存敬為都指揮使。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
