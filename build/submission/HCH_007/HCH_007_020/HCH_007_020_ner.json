    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000002",
    "sentence": "謝瞳，字子明，福州人。",
    "entities": [
      {
        "text": "福州",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000003",
    "sentence": "唐咸通末舉進士，因留長安，三歲不中第。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000004",
    "sentence": "廣明初，黃巢陷長安，遂投跡於太祖，洎居門下，未嘗一日不在左右。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000005",
    "sentence": "及太祖據同州，遂署右職。",
    "entities": [
      {
        "text": "及太祖據同州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000006",
    "sentence": "其年秋，太祖與河中交戰，再不利，連上章請兵於巢，偽右軍都尉孟楷抑而不進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000007",
    "sentence": "瞳揣太祖有擇福意，乃進說曰：「黃家以數十萬之師，值唐朝久安，人不習戰，因利乘便，遂下兩京。然始竊偽號，任用已失其所。今將軍勇冠三軍，力戰於外，而孟楷專務壅蔽，奏章不達，下為庸才所製，無獨斷之明，破亡之兆必矣。況土德未厭，外兵四集，漕運波注，日以收復為名，惟將軍察之。」太祖曰：「我意素決，爾又如是，復何疑哉！」翌日，遂定策，戮偽監軍使，悉眾歸順於河中。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 59,
        "end": 61
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 128,
        "end": 130
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000008",
    "sentence": "王重榮表瞳為檢校屯田員外郎，賜緋，令奉表於蜀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000009",
    "sentence": "唐僖宗大悅，召入顧問，錫賚甚厚，以功授朝散大夫、太子率更令，賜紫，為陵州刺史。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 21,
        "end": 23
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 24,
        "end": 26
      },
      {
        "text": "為陵州",
        "label": "LOC",
        "start": 33,
        "end": 36
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 36,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000010",
    "sentence": "治郡一歲，改檢校右散騎常侍、通州刺史。",
    "entities": [
      {
        "text": "治郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
