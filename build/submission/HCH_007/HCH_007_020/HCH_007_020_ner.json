        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000141",
    "sentence": "寇彥卿，字俊臣，大梁人也。",
    "entities": [
      {
        "text": "寇彥卿",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000142",
    "sentence": "祖琯，父裔，皆宣武軍牙校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000143",
    "sentence": "太祖鎮汴，以彥卿將家子，擢在左右。",
    "entities": [
      {
