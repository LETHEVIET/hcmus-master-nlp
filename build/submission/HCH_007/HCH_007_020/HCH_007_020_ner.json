        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000011",
    "sentence": "在任四考，頗有政績。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000012",
    "sentence": "秋罷，詣蜀行在，太祖遣人迎之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000013",
    "sentence": "龍紀二年，至東京，勞徠彌厚，賜第墅各一區，錢千緡，表為亳州團練使兼太清宮副使，加檢校工部尚書。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "表為亳州",
        "label": "LOC",
        "start": 25,
        "end": 29
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 44,
        "end": 46
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000014",
    "sentence": "是年冬，太祖征淮南，過郡，因求侍府幕，表為宣義軍節度副使，充兩使留後。",
    "entities": [
      {
        "text": "過郡",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000015",
    "sentence": "瞳在滑十三年，部內增戶約五萬，益兵數千人，累遷至大中大夫、檢校右僕射，卒於滑。",
    "entities": [
      {
        "text": "十三年",
