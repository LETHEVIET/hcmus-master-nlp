        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000069",
    "sentence": "時州境荒饉，大寇繼至，黃巢數十萬眾寨於州南，敬蕘極力抗禦，逾旬而退。",
    "entities": [
      {
        "text": "時州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "數十萬眾寨於州",
        "label": "LOC",
        "start": 13,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000070",
    "sentence": "俄又宗權之眾，淩暴益甚，合圍攻壁，皆力屈而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000071",
    "sentence": "蔡賊復遣將刁君務以萬眾來逼，敬蕘列陣當之，身先馳突，殺敵甚多，由是竟全郡壘，遠近歸附。",
    "entities": [
      {
        "text": "由是竟全郡",
        "label": "LOC",
        "start": 31,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000072",
    "sentence": "及淮人不恭，太祖屢以軍南渡，路由州境，敬蕘悉心供億，太祖甚嘉之。",
    "entities": [
      {
        "text": "路由州",
        "label": "LOC",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000073",
    "sentence": "乾寧二年，署為沿淮上下都指揮使。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000074",
    "sentence": "四年冬，龐師古敗於清口，敗軍逃歸者甚眾，路出於潁。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000075",
    "sentence": "時雨雪連旬，軍士凍餒，敬蕘自淮燎薪，相屬於道，郡中設糜糗餅餌以待之，全活者甚眾，由是表知武寧軍節度、徐宿觀察留後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000076",
    "sentence": "數月，真拜武寧軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000077",
    "sentence": "天復二年，入為右龍武統軍。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000078",
    "sentence": "天祐三年，轉左衛上將軍。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000079",
    "sentence": "開平元年八月，以疾致仕，尋卒於其第。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000080",
    "sentence": "敬蕘魁傑沈勇，多力善戰，所用槍矢，皆以純鐵鍛就，槍重三十餘斤，摧鋒突陣，率以此勝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000081",
    "sentence": "雖非太祖舊臣，而遠輸懇款，保境合兵，以輔興王之運，有足稱者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000082",
    "sentence": "高劭",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000083",
    "sentence": "高劭，字子將，淮南節度使駢之從子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000084",
    "sentence": "父泰，黔中觀察使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000085",
    "sentence": "唐僖宗避敵在蜀，駢鎮淮南為都統，兼諸道鹽鐵使，兵賦在己，朝廷優假之，以故劭幸而早官，年十四遙領華州刺史。",
    "entities": [
      {
        "text": "駢鎮",
        "label": "LOC",
        "start": 8,
        "end": 10
      },
      {
        "text": "年十四遙領華州",
        "label": "LOC",
        "start": 42,
        "end": 49
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 49,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000086",
    "sentence": "光啟中，以駢命遏晉公王鐸於鄭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000087",
    "sentence": "俄而州陷於蔡，劭為賊所得，使人守之，戒四門曰：「無出高大夫。」劭伺守者稍惰，佯為乞食者，過危垣，取殍者衣，坌身易服，得他兒抱之行，出東郊門。",
    "entities": [
      {
        "text": "俄而州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000088",
    "sentence": "人以為丐者，不之止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000089",
    "sentence": "及稍遠，棄所抱兒，疾趨至中牟，遂達於汴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000090",
    "sentence": "太祖以客禮遇之，尋表為亳州團練副使，知州事。",
    "entities": [
      {
        "text": "尋表為亳州",
        "label": "LOC",
        "start": 8,
        "end": 13
      },
      {
        "text": "知州",
        "label": "LOC",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000091",
    "sentence": "又數年，辟為宣武軍節度判官，在幕下頗以氣直自許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000092",
    "sentence": "後監鄭州事，復權知徐州留後。",
    "entities": [
      {
        "text": "後監鄭州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "復權知徐州",
        "label": "LOC",
        "start": 6,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000093",
    "sentence": "唐昭宗之鳳翔，太祖迎奉未出，劭有疑謀，遂令赴華州，詣丞相府以議其事；行至高陵，為盜所害。",
    "entities": [
      {
        "text": "遂令赴華州",
        "label": "LOC",
        "start": 19,
        "end": 24
      },
      {
