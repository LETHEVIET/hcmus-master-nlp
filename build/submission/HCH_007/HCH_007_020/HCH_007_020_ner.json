        "text": "刺史",
        "label": "TITLE",
        "start": 39,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000101",
    "sentence": "俄復使光州，持幣馬以賜劉存。",
    "entities": [
      {
        "text": "俄復使光州",
        "label": "LOC",
        "start": 0,
