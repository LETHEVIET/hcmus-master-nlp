      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000067",
    "sentence": "唐乾符初，敬蕘為本州都知兵馬使。",
    "entities": [
      {
        "text": "敬蕘為本州",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000068",
    "sentence": "中和初，寇難益熾，郡守庸怯，不能自固，敬蕘遂代之監郡，俄真拜刺史，加檢校右散騎常侍。",
    "entities": [
      {
        "text": "敬蕘遂代之監郡",
        "label": "LOC",
