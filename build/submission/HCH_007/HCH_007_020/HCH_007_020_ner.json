        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000025",
    "sentence": "及大軍在岐下，遣奏事於昭宗，再入復出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000026",
    "sentence": "又使於金州，說其帥馮行襲，俾堅攀附。",
    "entities": [
      {
        "text": "又使於金州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000027",
    "sentence": "後曆宣武、天平等軍從事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000028",
    "sentence": "開平元年，拜右武衛上將軍。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000029",
    "sentence": "三年，使於兩浙。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000030",
    "sentence": "時淮路不通，乘駔者迂回萬里，陸行則出荊、襄、潭、桂入嶺，自番禺泛海至閩中，達於杭、越。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000031",
    "sentence": "復命則備舟楫，出東海，至於登、萊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000032",
    "sentence": "而揚州諸步多賊船，過者不敢循岸，必高帆遠引海中，謂之「入陽」，以故多損敗。",
    "entities": [
      {
        "text": "而揚州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000033",
    "sentence": "鄴在海逾年，漂至躭羅國，一行俱溺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000034",
    "sentence": "後詔贈司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000035",
    "sentence": "劉捍",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000036",
    "sentence": "劉捍，開封人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000037",
    "sentence": "父行仙，宣武軍大將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000038",
    "sentence": "捍少為牙職，太祖初鎮夷門，以捍聰敏，擢副典客。",
    "entities": [
      {
        "text": "太祖初鎮",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000039",
    "sentence": "唐中和四年夏，太祖以朱珍為淄州刺史，令收兵於淄、青間，命捍監其兵，路逢大敵，皆破之。",
    "entities": [
      {
        "text": "唐",
        "label": "ORG",
