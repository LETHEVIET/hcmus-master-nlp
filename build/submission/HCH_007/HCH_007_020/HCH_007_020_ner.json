      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000094",
    "sentence": "馬嗣勳",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000095",
    "sentence": "馬嗣勳，濠州鍾離縣人，世為軍吏。",
