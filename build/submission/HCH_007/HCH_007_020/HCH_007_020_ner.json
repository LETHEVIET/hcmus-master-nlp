      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000144",
    "sentence": "弱冠，選為通讚官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000145",
    "sentence": "太祖為元帥，補元帥府押牙，充四鎮通讚官行首兼右長直都指揮使，累奏授檢校司徒，領洺州刺史。",
