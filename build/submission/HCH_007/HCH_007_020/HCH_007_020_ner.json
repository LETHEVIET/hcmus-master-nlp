        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000051",
    "sentence": "四月，太祖伐王師範於青州，改左右長直都指揮使。",
    "entities": [
      {
        "text": "伐王師範於青州",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000052",
    "sentence": "天祐三年正月，授宋州刺史。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "授宋州",
        "label": "LOC",
