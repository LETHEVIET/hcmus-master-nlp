      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000132",
    "sentence": "進圍河中，王珂請降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000133",
    "sentence": "太祖嘉之，乃以存敬為護國軍留後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000134",
    "sentence": "未幾，檢校司空，尋移宋州刺史。",
    "entities": [
