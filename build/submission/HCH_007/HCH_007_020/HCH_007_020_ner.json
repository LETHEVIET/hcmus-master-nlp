      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000044",
    "sentence": "時兩軍未整，守門者戈戟千匝，捍馳騎而入，竟達其命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000045",
    "sentence": "又移師以攻中山，至懷德驛，大破定人五萬眾，王處直乞降，捍復單馬入州，安撫而回。",
    "entities": [
      {
        "text": "捍復單馬入州",
        "label": "LOC",
        "start": 27,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000046",
    "sentence": "太祖迎昭宗於岐下，以捍為親軍指揮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000047",
    "sentence": "天復三年正月，宋文通令客將郭啟奇使於太祖，命捍復命。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_020_000048",
    "sentence": "昭宗聞其至，即召見，詢東兵之事，仍以錦服、銀鞍勒馬賜之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_020_000049",
    "sentence": "翌日，授光祿大夫、檢校司空、登州刺史。",
