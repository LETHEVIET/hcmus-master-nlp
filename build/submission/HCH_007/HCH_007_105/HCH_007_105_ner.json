      }
    ]
  },
  {
    "sentence_id": "HCH_007_105_000008",
    "sentence": "高祖發哀於太平宮，哭之大慟，以至於不豫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_105_000009",
    "sentence": "是月，追封魏王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_105_000010",
    "sentence": "歸葬於太原。",
