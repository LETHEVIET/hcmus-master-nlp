        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000139",
    "sentence": "乾化二年春，太祖親伐鎮、定，駐於相州，因閱馬，怒其馬瘦，與魏博軍校何令稠、陳令勳同斬於纛下。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "太祖親伐鎮",
        "label": "LOC",
        "start": 6,
        "end": 11
      },
      {
        "text": "駐於相州",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000140",
    "sentence": "黃文靖",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000141",
    "sentence": "黃文靖，金鄉人。",
    "entities": [
      {
        "text": "金鄉",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000142",
    "sentence": "少附於黃巢黨中，巢敗，歸於太祖，累署牙職，繼遷諸軍指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000143",
    "sentence": "從太祖南平巢、蔡，北定兗、鄆，皆有功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000144",
    "sentence": "唐大順中，佐葛從周送朱崇節入潞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000145",
    "sentence": "會晉軍十餘萬近逼垣寨，文靖慮孤軍難守，乃與葛從周啟出師，文靖為殿，命矢刃皆外向，持重而還，晉人不敢逼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000146",
    "sentence": "其年冬，與康懷英渡淮，入壽春之境，下安豐、霍丘，至光州而還。",
    "entities": [
      {
        "text": "至光州",
        "label": "LOC",
        "start": 24,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000147",
    "sentence": "光化初，晉將李嗣昭、周德威寇於山東，文靖佐葛從周統大軍禦之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000148",
    "sentence": "至沙河，敗晉軍五千餘騎，遂逐之，越張公橋乃止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000149",
    "sentence": "後旬日，復與晉人戰於邢州之北，擒蕃將賁金鐵、慕容藤、李存建等百餘人，奪馬數千匹。",
    "entities": [
      {
        "text": "與晉人戰於邢州",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000150",
    "sentence": "尋以功表授檢校左僕射、耀州刺史。",
    "entities": [
      {
        "text": "耀州",
        "label": "LOC",
        "start": 11,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000151",
    "sentence": "天祐二年春，命佐楊師厚深入淮甸，越壽春，侵廬江，軍至大獨山，遇淮夷，殺五千餘眾，振旅而還。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000152",
    "sentence": "改蔡州刺史，加檢校司空，又遷潁州刺史。",
    "entities": [
      {
        "text": "改蔡州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "又遷潁州",
        "label": "LOC",
        "start": 12,
        "end": 16
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000153",
    "sentence": "太祖受禪，復為蔡州刺史，入為左神武統軍，又改左龍驤使。",
    "entities": [
      {
        "text": "復為蔡州",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000154",
    "sentence": "乾化元年，從太祖北征，因閱馬得罪，命斬之。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000155",
    "sentence": "文靖驍果善戰，諸將皆惜之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000156",
    "sentence": "胡規",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000157",
    "sentence": "胡規，兗州人。",
    "entities": [
      {
        "text": "兗州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000158",
    "sentence": "初事朱瑾為中軍都校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000159",
    "sentence": "兗州平，署為宣武軍都虞候。",
    "entities": [
      {
        "text": "兗州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000160",
    "sentence": "佐葛從周伐鎮、定，從張存敬收晉、絳，皆有功，署為河中都虞候，榷鹽務。",
    "entities": [
      {
        "text": "佐葛從周伐鎮",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000161",
    "sentence": "天復中，太祖迎駕至岐下，以規權知洽州。",
    "entities": [
      {
        "text": "以規權知洽州",
        "label": "LOC",
        "start": 12,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000162",
    "sentence": "昭宗還長安，詔授皇城使。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "詔授皇城",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000163",
    "sentence": "及東遷，以為御營使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000164",
    "sentence": "駕至洛，授內園莊宅使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000165",
    "sentence": "天祐三年，佐李周彝討相州，獨當州之一面，頗以功聞，軍還，權知耀州事。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "佐李周彝討相州",
        "label": "LOC",
        "start": 5,
        "end": 12
      },
      {
        "text": "獨當州",
        "label": "LOC",
        "start": 13,
        "end": 16
      },
      {
        "text": "權知耀州",
        "label": "LOC",
        "start": 28,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000166",
    "sentence": "明年，討滄州，為諸軍壕寨使。",
    "entities": [
      {
        "text": "討滄州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000167",
    "sentence": "太祖受禪，除右羽林統軍，尋佐劉鄩統兵收潼關，擒劉知浣獻之，乃以為右龍虎統軍兼侍衛指揮使。",
    "entities": [
      {
        "text": "劉鄩統兵收潼關",
        "label": "LOC",
        "start": 14,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000168",
    "sentence": "乾化元年，詔修洛河堤堰，軍士因之斬伐百姓園林太甚，河南尹張宗奭奏之，規得罪，賜死。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000169",
    "sentence": "李讜",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000170",
    "sentence": "李讜，河中臨晉人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000171",
    "sentence": "少時遊秦、雍間，為人勇悍多力，甚有氣誼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000172",
    "sentence": "唐廣明初，黃巢陷長安，讜遂得仕於其間。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 2,
        "end": 3
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000173",
    "sentence": "巢以讜為內樞密使，蓋讜曾委質於宦者，出入於宮禁間，巢以此用焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000174",
    "sentence": "其後巢軍既敗，讜乃束身歸於太祖，署為左德勝騎軍都將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000175",
    "sentence": "從太祖討蔡賊，頗立軍功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000176",
    "sentence": "及東伐兗、鄆，以所部士伍俘獲甚眾，改元從騎將，表授檢校右僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000177",
    "sentence": "郴王友裕領兵攻澤州，時太祖駐大軍於盟津，乃令讜將兵越太行，授以籌謀。",
    "entities": [
      {
        "text": "友裕領兵攻澤州",
        "label": "LOC",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000178",
    "sentence": "讜頗違節度，久而無功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000179",
    "sentence": "太祖遣追還，廷責其罪，戮之於河橋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000180",
    "sentence": "李重胤",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000181",
    "sentence": "李重胤，宋州下邑人。",
    "entities": [
      {
        "text": "宋州下邑",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000182",
    "sentence": "狀貌雄武，初在黃巢黨中，推為剛鷙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000183",
    "sentence": "唐中和四年五月，同尚讓、李讜等率眾至繁台，與太祖之軍相拒。",
    "entities": [
      {
        "text": "唐",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "四年",
        "label": "TME",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000184",
    "sentence": "及巢寇漸衰，乃率眾來降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000185",
    "sentence": "太祖素識之，拔用不次，署為先鋒步軍都頭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000186",
    "sentence": "與胡真援河陽，逼懷州。",
    "entities": [
      {
        "text": "逼懷州",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000187",
    "sentence": "重胤以部下兵突之，射中蕃將安休休。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000188",
    "sentence": "又令與李讜率騎軍至陝，應接郭言，回次澠池，破賊帥黃花子之眾，改滑州夾馬指揮使。",
    "entities": [
      {
        "text": "改滑州",
        "label": "LOC",
        "start": 30,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000189",
    "sentence": "蔡賊圍汴，重胤以步兵攻下三寨，擄獲甚多。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000190",
    "sentence": "太祖大舉伐宗權，俾重胤以滑兵為先鋒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000191",
    "sentence": "及東討徐州，下豐、蕭二邑，轉右廂馬步軍指揮使。",
    "entities": [
      {
        "text": "及東討徐州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "蕭二邑",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000192",
    "sentence": "大順元年秋，從郴王友裕收澤州，與晉軍戰於馬牢川，王師敗績，回守河陽。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "郴王友裕收澤州",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000193",
    "sentence": "太祖謂諸將曰：「李讜、重胤違我節度，不能立功，頗辜任使。」於是與李讜並戮於河橋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000194",
    "sentence": "範居實",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000195",
    "sentence": "範居實，絳州翼城人。",
    "entities": [
      {
        "text": "絳州翼城",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000196",
    "sentence": "事太祖，初為隊將，從討巢、蔡有功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000197",
    "sentence": "又從朱珍收滑州，改左廂都虞候。",
    "entities": [
      {
        "text": "又從朱珍收滑州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000198",
    "sentence": "預破兗、鄆功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000199",
    "sentence": "遷感義都頭、鄭州馬軍指揮使。",
    "entities": [
      {
        "text": "鄭州",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000200",
    "sentence": "幽州劉仁恭舉眾南下，寇魏郡北，居實與葛從周、張存敬率兵救魏，大破幽、滄之眾於內黃。",
    "entities": [
      {
        "text": "幽州",
        "label": "LOC",
