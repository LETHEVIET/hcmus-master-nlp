[
  {
    "sentence_id": "HCH_007_019_000001",
    "sentence": "氏叔琮",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000002",
    "sentence": "氏叔琮，尉氏人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000003",
    "sentence": "唐中和末，應募為騎軍，初隸於龐師古，為伍長。",
    "entities": [
      {
        "text": "唐",
        "label": "ORG",
        "start": 0,
        "end": 1
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000004",
    "sentence": "叔琮壯勇沈毅，膽力過人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000005",
    "sentence": "太祖討巢、蔡於陳、許間，叔琮奮擊，首出諸校，太祖壯之，自行伍間擢為後院馬軍都將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000006",
    "sentence": "時東伐徐、鄆，多曆年所，叔琮身當矢石，奮不顧命，觀者許焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000007",
    "sentence": "累遷為指揮使，尋奏授宿州刺史、檢校右僕射。",
    "entities": [
      {
        "text": "尋奏授宿州",
        "label": "LOC",
        "start": 7,
        "end": 12
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000008",
    "sentence": "太祖伐襄陽，叔琮失利，降為陽翟鎮遏使；尋又捍禦晉軍於洹水有功，遷曹州刺史。",
    "entities": [
      {
        "text": "降為陽翟鎮",
        "label": "LOC",
        "start": 11,
        "end": 16
      },
      {
        "text": "遷曹州",
        "label": "LOC",
        "start": 31,
        "end": 34
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 34,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000009",
    "sentence": "天復元年春，領大軍攻拔澤、潞，叔琮遂引兵北掠太原。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000010",
    "sentence": "師還，除晉州節度使。",
    "entities": [
      {
        "text": "除晉州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000011",
    "sentence": "明年，太祖屯軍於岐下，晉軍潛襲絳州，前軍不利。",
    "entities": [
      {
        "text": "晉軍潛襲絳州",
        "label": "LOC",
        "start": 11,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000012",
    "sentence": "晉軍恃勝攻臨汾，叔琮嚴設備禦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000013",
    "sentence": "乃於軍中選壯士二人，深目虯須，貌如沙陀者，令就襄陵縣牧馬於道間。",
    "entities": [
      {
        "text": "令就襄陵縣",
        "label": "LOC",
        "start": 21,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000014",
    "sentence": "蕃寇見之不疑，二人因雜其行間，俄而伺隙各擒一人而來。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000015",
    "sentence": "晉軍大驚，且疑有伏兵，遂退據蒲縣。",
    "entities": [
      {
        "text": "遂退據蒲縣",
        "label": "LOC",
        "start": 11,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000016",
    "sentence": "時太祖遣朱友寧將兵數萬赴應，悉委叔琮節制。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000017",
    "sentence": "既至，諸將皆欲休軍，叔琮曰：「若然，則賊必遁矣，遁則何功焉！」因夜出，潛師截其歸路，遇晉軍遊騎數百，盡殺之；遂攻其壘，拔之，斬獲萬餘眾，奪馬三百匹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000018",
    "sentence": "太祖聞之，喜謂左右曰：「殺蕃賊，破太原，非氏老不可！」叔琮乃長驅收汾州，與晉人轉戰，直抵並壘。",
    "entities": [
      {
        "text": "琮乃長驅收汾州",
        "label": "LOC",
        "start": 28,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000019",
    "sentence": "軍回，以其功奏加檢校司空。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000020",
    "sentence": "自後累年，晉軍不敢侵軼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000021",
    "sentence": "叔琮養士愛民，甚有能政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000022",
    "sentence": "天復三年，為鄜州留後，尋真領保大軍節度使、檢校司徒。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "為鄜州",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000023",
    "sentence": "及昭宗東遷，征為右龍虎統軍，以衛洛陽。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000024",
    "sentence": "天祐元年八月，與朱友恭同受太祖密旨，弑昭宗於大內。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000025",
    "sentence": "既而責以軍政不理，貶白州司戶。",
    "entities": [
      {
        "text": "貶白州",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000026",
    "sentence": "尋賜自盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000027",
    "sentence": "叔琮將死，呼曰：「賣我性命，欲塞天下之謗，其如神理何！」乾化二年，詔許歸葬。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000028",
    "sentence": "朱友恭",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000029",
    "sentence": "朱友恭，壽春人，本姓李，名彥威。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000030",
    "sentence": "瑽角事太祖，性穎利，善體太祖意，太祖憐之，因畜為己子，賜姓，初名克讓，後改之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000031",
    "sentence": "時初建左長劍都，以友恭董之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000032",
    "sentence": "從太祖四征，稍立軍功，累遷諸軍都指揮使、檢校左僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000033",
    "sentence": "乾寧中，授汝州刺史，加檢校司空。",
    "entities": [
      {
        "text": "授汝州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000034",
    "sentence": "光化初，淮夷侵鄂渚，武昌帥杜洪來乞師，太祖遣友恭將兵萬餘，濟江應援，引兵至龍沙、九江而還，軍聲大振。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000035",
    "sentence": "時淮寇據黃州，友恭攻陷其壁，獲賊將瞿章，俘斬萬計。",
    "entities": [
      {
        "text": "時淮寇據黃州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000036",
    "sentence": "途經安陸，因襲殺刺史武瑜，盡收其眾，以功為潁州刺史，加檢校司徒。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "以功為潁州",
        "label": "LOC",
        "start": 18,
        "end": 23
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000037",
    "sentence": "天復中，為武寧軍留後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000038",
    "sentence": "天祐初，昭宗東遷洛邑，征拜左龍虎統軍，以衛宮闕。",
    "entities": [
      {
        "text": "昭宗東遷洛邑",
        "label": "LOC",
        "start": 4,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000039",
    "sentence": "尋與氏叔琮同受太祖密旨，弑昭宗於洛陽宮。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000040",
    "sentence": "既而太祖自河中至，責以慢於軍政，貶崖州司戶，復其本姓名，與氏叔琮同日賜死。",
    "entities": [
      {
        "text": "貶崖州",
        "label": "LOC",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000041",
    "sentence": "王重師",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000042",
    "sentence": "王重師，潁州長社人也。",
    "entities": [
      {
        "text": "潁州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000043",
    "sentence": "材力兼人，沈嘿大度，臨事有權變，劍槊之妙，冠絕於一時。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000044",
    "sentence": "唐中和末，蔡寇陷許昌，重師脫身而來，太祖異其狀貌，乃隸於拔山都。",
    "entities": [
      {
        "text": "唐",
        "label": "ORG",
        "start": 0,
        "end": 1
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000045",
    "sentence": "每於軍前效用，頗出儕類。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000046",
    "sentence": "文德中，令董左右長劍軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000047",
    "sentence": "太祖伐上蔡，重師力戰有功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000048",
    "sentence": "及討兗、鄆，擢為指揮使，奏授檢校右僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000049",
    "sentence": "重師枕戈擐甲五六年，於齊、魯間凡經百餘戰，由是威震敵人。",
    "entities": [
      {
        "text": "五六年",
        "label": "TME",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000050",
    "sentence": "尋授檢校司空，為潁州刺史。",
    "entities": [
      {
        "text": "為潁州",
        "label": "LOC",
        "start": 7,
        "end": 10
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000051",
    "sentence": "乾寧中，太祖攻濮州，縱兵壞其墉，濮人因屯火塞其壞壘，煙焰亙空，人莫敢越。",
    "entities": [
      {
        "text": "太祖攻濮州",
        "label": "LOC",
        "start": 4,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000052",
    "sentence": "重師方苦金瘡，臥於軍次，諸將或勉之，乃躍起，命壯士悉取軍中氈罽投水中，擲於火上，重師然後率精銳，持短兵突入，諸軍踵之，濮州乃陷。",
    "entities": [
      {
        "text": "濮州",
        "label": "LOC",
        "start": 59,
        "end": 61
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000053",
    "sentence": "重師為劍槊所傷，身被八九創，丁壯荷之還營，且將斃矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000054",
    "sentence": "太祖驚惜尤甚，曰：「雖得濮壘，而失重師，奈何！」亟命以奇藥療之，彌月始愈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000055",
    "sentence": "尋知平盧軍留後，加檢校司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000056",
    "sentence": "其後北伐幽、滄、鎮、定，屢與晉軍接戰，頗得士心，故多勝捷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000057",
    "sentence": "天祐中，授雍州節度使，加同平章事。",
    "entities": [
      {
        "text": "授雍州",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000058",
    "sentence": "數年治戎恤民，頗有威惠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000059",
    "sentence": "開平中，為劉捍所構，太祖深疑之，然未有以發其事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000060",
    "sentence": "無何，擅遣裨將張君練縱兵深入邠、鳳，君練敗北。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000061",
    "sentence": "太祖聞之，怒其專擅，因追而斬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000062",
    "sentence": "〈 （《通鑒》云劉捍至長安，王重師不為禮，捍譖之帝，曰：「重師潛與邠、岐通。」甲申，貶溪州刺史，尋賜自盡，夷其族。） 〉",
    "entities": [
      {
        "text": "《通鑒》",
        "label": "TITLE",
        "start": 3,
        "end": 7
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 11,
        "end": 13
      },
      {
        "text": "貶溪州",
        "label": "LOC",
        "start": 42,
        "end": 45
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 45,
        "end": 47
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000063",
    "sentence": "朱珍",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000064",
    "sentence": "朱珍，徐州豐縣雍鳳里人也。",
    "entities": [
      {
        "text": "徐州豐縣",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000065",
    "sentence": "太祖初起兵，珍與龐師古、許唐、李暉、丁會、氏叔琮、鄧季筠、王武等八十餘人，以中涓從，摧堅陷陣，所向蕩決。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000066",
    "sentence": "及太祖鎮汴，兼領招討使，署珍為宣武右職，以總腹心。",
    "entities": [
      {
        "text": "及太祖鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000067",
    "sentence": "於是簡練軍伍，裁制綱紀，平巢破蔡，多珍之力也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000068",
    "sentence": "始尚讓以驍騎五千人至繁臺，珍與龐師古、齊奉國等擊退之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000069",
    "sentence": "及黃巢敗，珍與並帥李克用追至冤句而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000070",
    "sentence": "尋從太祖以汴、宋、亳之師入西華，破王夏寨，勇冠軍鋒，以功加秩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000071",
    "sentence": "光啟元年，署諸軍都指揮使，始為上將。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000072",
    "sentence": "於是軍焦夷，敗蔡師鐵林三千人，盡俘其將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000073",
    "sentence": "復西至汝、鄭，南過陳、潁，繚宋、亳、滑、濮間，與蔡賊交戰，鏖伏襲殺，不知其數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000074",
    "sentence": "會滑州節度使安師儒戎政不治，太祖命珍與李唐賓率步騎以經略之。",
    "entities": [
      {
        "text": "會滑州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000075",
    "sentence": "始入境，遇大雪，令軍士無得休息，一夕馳至壁下，百梯並升，遂乘其墉，滑州平。",
    "entities": [
      {
        "text": "滑州",
        "label": "LOC",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000076",
    "sentence": "時太祖方謀齊師，乃遣珍往淄州募兵，行次任縣，東面都統齊克讓伏兵於孫師陂以邀珍，珍大破之。",
    "entities": [
      {
        "text": "乃遣珍往淄州",
        "label": "LOC",
        "start": 8,
        "end": 14
      },
      {
        "text": "行次任縣",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000077",
    "sentence": "進軍至牙山，都虞候張仁遇白珍曰：「軍有不齊者，當先斬本都將，後以狀聞，願許之。」珍怒其專，乃斬仁遇以徇軍，由是諸將咸懼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000078",
    "sentence": "兵至乾封，與淄人戰於白草口，敗之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000079",
    "sentence": "青人以步騎二萬，列三寨於金嶺驛，珍與戰，連破之，殲其師，盡獲軍器戎馬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000080",
    "sentence": "是夕，攻博昌，大獲兵眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000081",
    "sentence": "其後破盧瑭、張至及朱瑄、朱瑾之眾，平定曹、濮，未嘗不在戰中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000082",
    "sentence": "梁山之役，始與李唐賓不協。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000083",
    "sentence": "珍在軍嘗私迎其室於汴，而不先請，太祖疑之，密令唐賓察之，二將不相下，因而交諍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000084",
    "sentence": "唐賓夜斬關還汴以訴，珍亦棄軍單騎而至，太祖兩惜之，故不罪，俾還於師。",
    "entities": [
      {
        "text": "唐賓夜斬關",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000085",
    "sentence": "復以踏白騎士入陳、亳間，以邀蔡人，遂南至斤溝，破淮西石璠之師二萬，擄璠以獻。",
    "entities": [
      {
        "text": "陳",
        "label": "ORG",
        "start": 7,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000086",
    "sentence": "珍旋師自亳北趣靜戎，濟舟於滑，破黎陽、臨河、李固三鎮。",
    "entities": [
      {
        "text": "李固三鎮",
        "label": "LOC",
        "start": 22,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000087",
    "sentence": "軍於內黃，敗樂從訓萬餘人，分命聶金、範居實略澶州，與魏師遇於臨黃；魏軍有豹子軍二千人，戮之無噍類，威振河朔。",
    "entities": [
      {
        "text": "範居實略澶州",
        "label": "LOC",
        "start": 18,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000088",
    "sentence": "復攻淮西，至蔡，夾河而寨，敗賊將蕭皓之眾，皆擁於河溺死之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000089",
    "sentence": "進軍蔡州，營其西南，既破羊馬垣，遇雨班師。",
    "entities": [
      {
        "text": "進軍蔡州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000090",
    "sentence": "珍以兵援劉讚，赴楚州，至襄山南，遇徐戎扼其路，珍乃攻豐，下之。",
    "entities": [
      {
        "text": "赴楚州",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000091",
    "sentence": "時溥乃以全師會戰於豐南吳康裏，珍乃收豐，破其三萬餘眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000092",
    "sentence": "及蔡賊平，珍比諸將功居多。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000093",
    "sentence": "龍紀初，與諸將屯於蕭縣，以禦時溥，珍慮太祖自至，令諸軍葺馬廄以候巡撫，李唐賓之裨將嚴郊獨慢焉，軍候範權恃珍以督之。",
    "entities": [
      {
        "text": "與諸將屯於蕭縣",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000094",
    "sentence": "唐賓素與珍不協，果怒，乃見以訴其事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000095",
    "sentence": "珍亦怒曰：「唐賓無禮！」遂拔劍斬之，珍命騎列狀陳其事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000096",
    "sentence": "太祖初聞唐賓之死，驚駭，與敬翔謀，詐令有司收捕唐賓妻子下獄，以安珍心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000097",
    "sentence": "太祖遂徑往蕭縣，距蕭一舍，珍率將校迎謁，梁祖令武士執之，責其專殺，命丁會行戮。",
    "entities": [
      {
        "text": "太祖遂徑往蕭縣",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000098",
    "sentence": "都將霍存等數十人叩頭以救，太祖怒，以坐床擲之，乃退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000099",
    "sentence": "李思安",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000100",
    "sentence": "李思安，陳留張亭里人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000101",
    "sentence": "初事汴將楊彥洪為騎士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000102",
    "sentence": "好拳勇，未弱冠，長七尺，超然有乘時自奮之意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000103",
    "sentence": "唐中和三年，太祖鎮汴，嘗大閱戎旅，睹其材，甚偉之，因錫名思安，字貞臣。",
    "entities": [
      {
        "text": "唐",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "三年",
        "label": "TME",
        "start": 3,
        "end": 5
      },
      {
        "text": "太祖鎮",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000104",
    "sentence": "思安善飛槊，所向披靡，每從太祖征伐，常馳馬出敵陣之後，測其厚薄而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000105",
    "sentence": "或敵人有恃猛自炫者，多命取之，必鷹揚飆卷，擒馘於萬眾之中，出入自若，如蹈無人之地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000106",
    "sentence": "太祖甚惜之，命副王虔裕為踏白將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000107",
    "sentence": "時巢、蔡合從，太祖每遣偵邏，必率先獨往。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000108",
    "sentence": "巢敗走，思安領所部百餘人追賊，殺戮掩奪，眾莫敢當。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000109",
    "sentence": "尋領軍襲蔡寇於鄭，都將李唐賓馬躓而墜，思安援槊刺追者，唐賓復其騎而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000110",
    "sentence": "又嘗與蔡人鬥，當陣生擒賊將柳行實。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000111",
    "sentence": "其後渡長淮，下天長、高郵二邑，又拒孫儒，迫濠州，皆有奇績。",
    "entities": [
      {
        "text": "高郵二邑",
        "label": "LOC",
        "start": 10,
        "end": 14
      },
      {
        "text": "迫濠州",
        "label": "LOC",
        "start": 20,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000112",
    "sentence": "累遷為諸軍都指揮使，奏官至檢校左僕射，尋拜亳州刺史。",
    "entities": [
      {
        "text": "尋拜亳州",
        "label": "LOC",
        "start": 19,
        "end": 23
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000113",
    "sentence": "練兵禦寇，邊境肅然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000114",
    "sentence": "思安為性勇悍，每統戎臨敵，不大勝，必大敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000115",
    "sentence": "開平元年春，率兵伐幽州，營於桑乾河，擄獲甚眾，燕人大懼。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "率兵伐幽州",
        "label": "LOC",
        "start": 6,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000116",
    "sentence": "及軍回，率諸軍伐潞，累月不克，師人多逸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000117",
    "sentence": "太祖怒甚，詔疏其罪，盡奪其官爵，委本郡以民戶係焉。",
    "entities": [
      {
        "text": "委本郡",
        "label": "LOC",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000118",
    "sentence": "逾歲起之，復令領兵，亦無巨績可紀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000119",
    "sentence": "太祖嘗因命將授鉞，謂左右曰：「李思安當敵果敢，無出其右者，然每遇藩方擇材，吾將用之，則敗聞必至，如是者二三矣，則知飛將數奇，前史豈虛言哉！」乾化元年秋，又以為相州刺史。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 72,
        "end": 74
      },
      {
        "text": "又以為相州",
        "label": "LOC",
        "start": 76,
        "end": 81
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 81,
        "end": 83
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000120",
    "sentence": "思安自謂當擁旄仗鉞，及是殊不快意，但日循晏安，無意為政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000121",
    "sentence": "及太祖北征，以候騎之誤，落然無所具，而復壁壘荒圮，帑廩空竭，太祖怒，貶柳州司戶，尋賜死於相州。",
    "entities": [
      {
        "text": "貶柳州",
        "label": "LOC",
        "start": 34,
        "end": 37
      },
      {
        "text": "尋賜死於相州",
        "label": "LOC",
        "start": 40,
        "end": 46
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000122",
    "sentence": "〈 （《通鑒》：開化元年丙午，至相州，刺史李思安不意帝猝至，落然無具，坐削官爵。二年正月丁卯，帝至獲嘉，追思李思安去歲供饋有闕，貶柳州司戶，尋長流思安於崖州，賜死。） 〉",
    "entities": [
      {
        "text": "《通鑒》",
        "label": "TITLE",
