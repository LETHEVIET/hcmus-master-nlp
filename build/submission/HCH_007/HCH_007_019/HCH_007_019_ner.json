        "end": 12
      },
      {
        "text": "至相州",
        "label": "LOC",
        "start": 15,
        "end": 18
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 19,
        "end": 21
      },
      {
        "text": "二年",
        "label": "TME",
        "start": 40,
        "end": 42
      },
      {
        "text": "貶柳州",
        "label": "LOC",
        "start": 64,
        "end": 67
      },
      {
        "text": "長流思安於崖州",
        "label": "LOC",
        "start": 71,
        "end": 78
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000123",
    "sentence": "鄧季筠",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000124",
    "sentence": "鄧季筠，宋州下邑人也。",
    "entities": [
      {
        "text": "宋州下邑",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000125",
    "sentence": "少入黃巢軍，隸於太祖麾下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000126",
    "sentence": "及太祖鎮汴，首署為牙將，主騎軍。",
    "entities": [
      {
        "text": "及太祖鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000127",
    "sentence": "伐鄆之役，生擒排陣將劉矯以獻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000128",
    "sentence": "唐大順初，唐帝命丞相張浚伐太原，太祖奉詔出師，西至高平，與晉人接戰，軍既不利，季筠為晉人所擒。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000129",
    "sentence": "克用見之甚喜，釋縛，待以賓禮，俄典戎事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000130",
    "sentence": "季筠在並門凡四稔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000131",
    "sentence": "景福二年，晉軍攻邢台，季筠領偏師預其役，將及邢，邢人陣於郊，兩軍酣戰之際，季筠出陣，飛馬來歸；太祖大加獎歎，賞賚甚厚。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000132",
    "sentence": "時初置廳子都，最為親軍，命季筠主之，旋改統親騎，又遷將中軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000133",
    "sentence": "天祐三年，奏授登州刺史，下車稱理。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "奏授登州",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000134",
    "sentence": "登州舊無羅城，及季筠至郡，率丁壯以築之，民甚安之，因相與立碑以頌其績。",
    "entities": [
      {
        "text": "登州舊無羅城",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "及季筠至郡",
        "label": "LOC",
        "start": 7,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000135",
    "sentence": "太祖受禪，改鄭州刺史，尋主兵於河中，為都指揮使。",
    "entities": [
      {
        "text": "改鄭州",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000136",
    "sentence": "時並人寇平陽，季筠接戰於洪洞，大克，拜華州防禦使。",
    "entities": [
      {
        "text": "拜華州",
        "label": "LOC",
        "start": 18,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000137",
    "sentence": "又繼領龍驤等諸軍騎士，累官至檢校司空。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000138",
    "sentence": "柏鄉之役，季筠臨陣前卻，太祖亦未之罪。",
    "entities": [
      {
        "text": "柏鄉",
