        "end": 2
      },
      {
        "text": "寇魏郡",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000201",
    "sentence": "太祖迎昭宗於岐下，以居實為河中馬軍都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_019_000202",
    "sentence": "及昭宗還京，賜迎鑾毅勇功臣，遙領錦州刺史，又遷左龍驤馬軍都指揮使。",
    "entities": [
      {
        "text": "遙領錦州",
        "label": "LOC",
        "start": 14,
        "end": 18
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000203",
    "sentence": "從征淮南回，改登州刺史，轉左神勇軍使。",
    "entities": [
      {
        "text": "改登州",
        "label": "LOC",
        "start": 6,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_019_000204",
    "sentence": "開平元年，用軍於潞州，命居實統軍以解澤州之圍。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
