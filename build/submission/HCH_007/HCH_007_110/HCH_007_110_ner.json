  {
    "sentence_id": "HCH_007_110_000117",
    "sentence": "是日旭旦，日邊有紫氣來，當帝之馬首。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000118",
    "sentence": "十九日，下令諸軍進發。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000119",
