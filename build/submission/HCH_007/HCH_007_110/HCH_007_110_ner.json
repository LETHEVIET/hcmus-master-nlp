    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000120",
    "sentence": "軍士登墻越屋而入，請帝為天子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000121",
    "sentence": "亂軍山積，登階匝陛，扶抱擁迫，或有裂黃旗以被帝體，以代赭袍，山呼震地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000122",
    "sentence": "帝在萬眾之中，聲氣沮喪，悶絕數四，左右親衛，星散竄匿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000123",
    "sentence": "帝即登城樓，稍得安息，諸軍遂擁帝南行。",
    "entities": [
      {
        "text": "帝即登城",
        "label": "LOC",
