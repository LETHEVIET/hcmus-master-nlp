        "end": 281
      },
      {
        "text": "行次近鎮",
        "label": "LOC",
        "start": 322,
        "end": 326
      },
      {
        "text": "將登澶州",
        "label": "LOC",
        "start": 339,
        "end": 343
      }
    ]
  },
  {
    "sentence_id": "HCH_007_110_000129",
    "sentence": "時文武百官、內外將帥、藩臣郡守等，相繼上表勸進。",
    "entities": [
      {
        "text": "藩臣郡",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_110_000130",
    "sentence": "三十日夜，御營西北隅步軍將校因醉揚言：「昨澶州馬軍扶策，今步軍亦欲扶策。」尋令虞候詰其姓名，昧旦擒而斬之。",
    "entities": [
      {
        "text": "昨澶州",
        "label": "LOC",
        "start": 20,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_110_000131",
    "sentence": "其一軍仍納甲仗，遣中使監送就糧所。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000132",
    "sentence": "廣順元年春正月丁卯，漢太后誥曰：「邃古以來，受命相繼，是不一姓，傳諸百王，莫不人心順之則興，天命去之則廢，昭然事跡，著在典書。予否運所丁，遭家不造，奸邪構亂，朋黨橫行，大臣冤枉以被誅，少主倉卒而及禍，人自作孽，天道寧論。監國威，深念漢恩，切安劉氏，既平亂略，復正頹綱，思固護於基扃，擇繼嗣於宗室。而獄訟盡歸於西伯，謳謠不在於丹朱，六師竭推戴之誠，萬國仰欽明之德，鼎革斯契，圖箓有歸，予作佳賓，固以為幸。今奉符寶授監國，可即皇帝位。於戲！天祿在躬，神器自至，允集天命，永綏兆民，敬之哉！」是日，帝自臯門入大內，禦崇元殿，即皇帝位。",
    "entities": [
      {
        "text": "廣順元年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 211,
        "end": 213
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 260,
        "end": 262
      }
    ]
  },
  {
    "sentence_id": "HCH_007_110_000133",
    "sentence": "制曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000134",
    "sentence": "自古受命之君，興邦建統，莫不上符天意，下順人心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000135",
    "sentence": "是以夏德既衰，爰啟有商之祚；炎風不競，肇開皇魏之基。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000136",
    "sentence": "朕早事前朝，久居重位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000137",
    "sentence": "受遺輔政，敢忘伊、霍之忠；仗鉞臨戎，復委韓、彭之任。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000138",
    "sentence": "匪躬盡瘁，焦思勞心，討叛渙於河、潼，張聲援於岐、雍，竟平大憝，粗立微勞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000139",
    "sentence": "才旋騑於關西，尋統兵於河朔，訓齊師旅，固護邊陲，只將身許國家，不以賊遺君父。",
    "entities": [
      {
        "text": "才旋騑於關",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_110_000140",
    "sentence": "外憂少息，內患俄生，群小連謀，大臣遇害，棟梁既壞，社稷將傾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000141",
    "sentence": "朕方在藩維，以遭讒構。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000142",
    "sentence": "逃一生於萬死，徑赴闕庭；梟四罪於九衢，幸安區宇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000143",
    "sentence": "將延漢祚，擇立劉宗，征命已行，軍情忽變。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000144",
    "sentence": "朕以眾庶所迫，逃避無由，扶擁至京，尊戴為主。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000145",
    "sentence": "重以中外勸進，方嶽推崇，黽勉雖順於群心，臨御實慚於涼德。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000146",
    "sentence": "改元建號，祗率於舊章；革故鼎新，宜覃於霈澤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000147",
    "sentence": "朕本姬室之遠裔，虢叔之後昆，積慶累功，格天光表，盛德既延於百世，大命復集於眇躬，今建國宜以大周為號，可改漢乾祐四年為廣順元年。",
    "entities": [
      {
        "text": "乾祐四年",
        "label": "TME",
        "start": 53,
        "end": 57
      },
      {
        "text": "廣順元年",
        "label": "TME",
        "start": 58,
        "end": 62
      }
    ]
  },
  {
    "sentence_id": "HCH_007_110_000148",
    "sentence": "自正月五日昧爽已前，應天下罪人，常赦所不原者，咸赦除之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000149",
    "sentence": "故樞密使楊邠、侍衛都指揮使史宏肇、三司使王章等，以勞定國，盡節致君，千載逢時，一旦同命，悲感行路，憤結重泉，雖尋雪於沈冤，宜更伸於渥澤，並可加等追贈，備禮歸葬，葬事官給，仍訪子孫敘用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000150",
    "sentence": "其餘同遭枉害者，亦與追贈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000151",
    "sentence": "馬步諸軍將士等，戮力葉誠，輸忠效義，先則平持內難，後乃推戴朕躬，言念勛勞，所宜旌賞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000152",
    "sentence": "其原屬將士等，各與等第，超加恩命，仍賜功臣名號，已帶功臣者別與改賜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000153",
    "sentence": "應左降官，未量移者與量移，已量移者與復資，已復資者量加敘錄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000154",
    "sentence": "亡官失爵之人，宜與齒用，配流徒役人，並許放還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000155",
    "sentence": "諸處有犯罪逃亡之人，及山林草寇等，一切不問，如赦到後一月不歸本業者，復罪如初。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000156",
    "sentence": "內外前任、見任文武官僚致仕官，各與加恩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000157",
    "sentence": "應在朝文武臣僚、內諸司使、諸道行軍副使、藩方馬步都指揮使，如父母在，未有恩澤者即與恩澤，已有者更與恩澤；如亡沒，未曾追封贈者亦與封贈，已封贈者更與封贈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000158",
    "sentence": "應天下州縣，所欠乾祐元年、二年已前夏秋殘稅及沿征物色，並三年夏稅諸色殘欠，並與除放。",
    "entities": [
      {
        "text": "應天下州縣",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "乾祐元年",
        "label": "TME",
        "start": 8,
        "end": 12
      },
      {
        "text": "二年",
        "label": "TME",
        "start": 13,
        "end": 15
      },
      {
        "text": "三年",
        "label": "TME",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_007_110_000159",
    "sentence": "澶州已來，官路兩邊共二十里內，並乾祐三年殘稅欠稅，並與除放。",
    "entities": [
      {
        "text": "澶州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "乾祐三年",
        "label": "TME",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_110_000160",
    "sentence": "應河北沿邊州縣，自去年九月後來，曾經契丹蹂踐處，其人戶應欠乾祐三年終已前積年殘欠諸色稅物，並與除放。",
    "entities": [
      {
        "text": "應河北沿邊州縣",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "乾祐三年",
        "label": "TME",
        "start": 29,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_007_110_000161",
    "sentence": "應系三司主持錢穀敗闕場院官取乾祐元年終已前征納外，灼然無抵當者，委三司分析聞奏。",
    "entities": [
      {
        "text": "乾祐元年",
        "label": "TME",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_110_000162",
    "sentence": "天下倉場、庫務，宜令節度使專切鈐轄，掌納官吏一依省條指揮，不得別納鬥餘、秤耗，舊來所進羨余物色，今後一切停罷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000163",
    "sentence": "應乘輿服禦之物，不得過為華飾，宮闈器用，務從樸素，大官常膳，一切減損。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000164",
    "sentence": "諸道所有進奉，以助軍國之費，其珍巧纖華及奇禽異獸鷹犬之類，不得輒有獻貢，諸無用之物、不急之務，並宜停罷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000165",
    "sentence": "帝王之道，德化為先，崇飾虛名，朕所不取，茍致治之未洽，雖多端以奚為！",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000166",
    "sentence": "今後諸道所有祥瑞，不得輒有奏獻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000167",
    "sentence": "古者用刑，本期止辟，今茲作法，義切禁非。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000168",
    "sentence": "蓋承弊之時，非猛則奸兇難制；及知勸之後，在寬則典憲得宜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000169",
    "sentence": "相時而行，庶臻中道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000170",
    "sentence": "今後應犯竊盜賊贓及和奸者，並依晉天福元年已前條制施行。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_110_000171",
    "sentence": "應諸犯罪人等，除反逆罪外，其罪並不得籍沒家產、誅及骨肉，一依格令處分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000172",
    "sentence": "天下諸侯，皆有親戚，自可慎擇委任，必當克效參裨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000173",
    "sentence": "朝廷選差，理或未當，宜矯前失，庶葉通規。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000174",
    "sentence": "其先於在京諸司差軍將充諸州郡元從都押衙、孔目官、內知客等，並可停廢，仍勒卻還舊處職役。",
    "entities": [
      {
        "text": "司差軍將充諸州",
        "label": "LOC",
        "start": 6,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_110_000175",
    "sentence": "近代帝王陵寢，合禁樵采。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000176",
    "sentence": "唐莊宗、明宗、晉高祖，各置守陵十戶，以近陵人戶充。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000177",
    "sentence": "漢高祖皇帝陵署職員及守宮人，時日薦饗，並守陵人戶等，一切如故。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_110_000178",
    "sentence": "仍以晉、漢之胄為二王後，委中書門下處分雲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000179",
    "sentence": "司天上言：「今國家建號，以木德代水，準經法國以姓墓為臘，請以未日為臘。」從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000180",
    "sentence": "時議者曰：「昔武王勝殷，歲集於房，國家受命，金、木集於房。文王厄羑裏，而卦遇明夷，帝脫於鄴，大衍之數，復得明夷，則周為國號，符於文、武矣。」先是，丁未年夏六月，土、金、木、火四星聚於張，占者雲，當有帝王興於周者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000181",
    "sentence": "故漢祖建國，由平陽、陜服趨洛陽以應之，及隱帝將嗣位，封周王以符其事。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_110_000182",
    "sentence": "而帝以姬虢之胄，復繼宗周，而天下之契炳然矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000183",
