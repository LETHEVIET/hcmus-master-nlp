  {
    "sentence_id": "HCH_007_110_000022",
    "sentence": "天成初，明宗幸浚郊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_110_000023",
    "sentence": "時朱守殷嬰城拒命，帝從晉高祖一軍率先登城。",
