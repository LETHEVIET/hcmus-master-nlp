        "start": 1,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_030_000008",
    "sentence": "甲戌，帝攻之，中都素無城守，師既雲合，梁眾自潰。",
    "entities": [
      {
        "text": "中都素無城",
        "label": "LOC",
        "start": 7,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_030_000009",
    "sentence": "是日，擒梁將王彥章及都監張漢傑、趙廷隱、劉嗣彬、李知節、康文通、王山興等將吏二百餘人，斬馘二萬，奪馬千匹。",
    "entities": [
