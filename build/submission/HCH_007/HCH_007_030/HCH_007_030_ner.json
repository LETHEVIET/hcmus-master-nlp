        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_030_000006",
    "sentence": "是夜三鼓，渡汶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_030_000007",
    "sentence": "時王彥章守中都。",
    "entities": [
