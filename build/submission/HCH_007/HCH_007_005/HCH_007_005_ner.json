    ]
  },
  {
    "sentence_id": "HCH_007_005_000009",
    "sentence": "九月丁酉，拔其城，斬叛兵千人，執李洪、楊虔等送洛陽，斬之。",
    "entities": [
      {
        "text": "拔其城",
