      }
    ]
  },
  {
    "sentence_id": "HCH_007_075_000108",
    "sentence": "〈 （《遼史》：初圍晉安，分遣精兵守其要害，以絕援兵之路。趙延壽等皆逗留不進。） 〉",
    "entities": [
      {
