        "text": "刺史",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000076",
    "sentence": "二年，授右監門上將軍，尋改華州防禦使。",
    "entities": [
      {
        "text": "二年",
