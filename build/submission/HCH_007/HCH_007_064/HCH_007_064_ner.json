        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000143",
    "sentence": "天成末，以史敬鎔代之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000144",
    "sentence": "玘還京師，卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000145",
    "sentence": "贈侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000146",
    "sentence": "有子師道，仕皇朝，為右讚善大夫。",
