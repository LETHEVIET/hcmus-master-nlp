        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000077",
    "sentence": "三年，自左天武使復授右羽林統軍。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000078",
    "sentence": "郢王友珪篡位，授洺州團練使。",
    "entities": [
      {
        "text": "授洺州",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000079",
    "sentence": "貞明中，為邢州留後，遷本州節度使。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 1,
