      },
      {
        "text": "復令還鎮",
        "label": "LOC",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000102",
    "sentence": "明年，授左龍武統軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000103",
    "sentence": "莊宗嘗幸漢賓之第，漢賓妻進酒上食，奏家樂以娛之，自是漢賓頗蒙寵待。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000104",
    "sentence": "同光四年正月，冀王朱友謙入朝，明宗居洛陽，以友謙故人，置酒於第。",
    "entities": [
      {
        "text": "同光四年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000105",
    "sentence": "莊宗諸弟在席，友謙坐在永王存霸之上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000106",
    "sentence": "酒酣，漢賓以大觴奉友謙曰：「公雖名位高，坐於皇弟之上，非宜也。仆與公俱在梁朝，以宗盟相厚，自公入朝，三發單函候問，略無報復，忽餘卑位，不亦甚乎！」元行欽恐其紛然，為解之方止。",
    "entities": [
      {
        "text": "梁朝",
        "label": "ORG",
        "start": 36,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000107",
    "sentence": "不數日，友謙赤族。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000108",
    "sentence": "趙在禮據魏州，元行欽率軍進討，詔漢賓權知河南府事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000109",
    "sentence": "明宗以漢賓為右衛上將軍，樞密使安重誨方當委重，漢賓密令結托，得為婚家。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000110",
    "sentence": "天成末，為潞州節度使，移鎮晉州。",
    "entities": [
      {
        "text": "為潞州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "移鎮晉州",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000111",
    "sentence": "重誨既誅，漢賓復為上將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000112",
    "sentence": "明年秋，漢賓告老，授太子少保致仕。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000113",
    "sentence": "清泰二年六月卒，時年六十四。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000114",
    "sentence": "漢賓少勇健，及晚歲飲啖過人，其狀貌偉如也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000115",
    "sentence": "凡所履曆，不聞逾法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000116",
    "sentence": "梁時，嘗領軍屯魏州莘縣，適值連帥去郡，諸軍咸以利見誘，請自為留後，漢賓則斬其言者，拒而不從，聞者賞焉。",
    "entities": [
      {
        "text": "梁",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "嘗領軍屯魏州",
        "label": "LOC",
        "start": 3,
        "end": 9
      },
      {
        "text": "莘縣",
        "label": "LOC",
        "start": 9,
        "end": 11
      },
      {
        "text": "適值連帥去郡",
        "label": "LOC",
        "start": 12,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000117",
    "sentence": "在曹日，飛蝗去境，父老歌之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000118",
    "sentence": "臨平陽遇旱，親齋潔禱龍子祠，逾日雨足，四封大稔，咸以為善政之所致也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000119",
    "sentence": "及致仕，東還亳郡，見鄉舊親戚淪沒者，有塋兆未辦，則給以棺斂；有婚嫁未畢，則助以資幣，受其惠者數百家，郡人義之。",
    "entities": [
      {
        "text": "東還亳郡",
        "label": "LOC",
        "start": 4,
        "end": 8
      },
      {
        "text": "見鄉",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000120",
    "sentence": "尋還洛陽，有第在懷仁裏，北限洛水，南枕通衢，層屋連甍，修木交幹，笙歌羅綺，日以自娛，養彼太和，保其餘齒，此乃近朝知止之良將也。",
    "entities": [
      {
        "text": "洛陽",
