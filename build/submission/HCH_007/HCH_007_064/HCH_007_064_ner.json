        "label": "LOC",
        "start": 46,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000084",
    "sentence": "城中危急，符存審晝夜乘城以拒之。",
    "entities": [
      {
        "text": "符存審晝夜乘城",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000085",
    "sentence": "莊宗自薊五日馳至魏州，思遠聞之解去。",
    "entities": [
      {
        "text": "薊五日馳至魏州",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000086",
    "sentence": "及明宗襲下鄆州，思遠罷軍權，降授宣化軍留後。",
    "entities": [
      {
        "text": "及明宗襲下鄆州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000087",
    "sentence": "其年，莊宗入汴，思遠自鄧州入朝，復令歸鎮。",
    "entities": [
      {
        "text": "思遠自鄧州",
        "label": "LOC",
