        "end": 9
      },
      {
        "text": "授徐州",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000020",
    "sentence": "契丹犯塞，莊宗以明宗為北面招討使，命彥威為副。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000021",
    "sentence": "彥威善言論，頗能接奉，明宗尤重之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000022",
    "sentence": "趙太叛於邢州，奉詔討平之。",
    "entities": [
      {
        "text": "趙太叛於邢州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000023",
    "sentence": "時趙在禮據魏州，與明宗會兵於鄴下，大軍夕亂，明宗為其所逼，彥威從入魏州。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000024",
    "sentence": "皇甫暉等尤忌彥威，欲殺之，彥威機辯開說，竟免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000025",
    "sentence": "及出，彥威部下兵士獨全，衛護明宗至魏縣。",
    "entities": [
      {
        "text": "衛護明宗至魏縣",
        "label": "LOC",
        "start": 12,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000026",
    "sentence": "時明宗欲北趨常山，彥威與安重誨懇請赴闕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000027",
    "sentence": "從至洛陽，彥威首率卿相勸進於至德宮。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000028",
    "sentence": "旬日之間，內外機事，皆決於彥威。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000029",
    "sentence": "擅收段凝、溫韜下獄，將置於法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000030",
    "sentence": "安重誨曰：「溫、段罪惡，負於梁室，眾所知矣。今主上克平內艱，冀安萬國，豈為公報仇耶！」至天成初，除鄆州節度使。",
    "entities": [
      {
        "text": "除鄆州",
        "label": "LOC",
        "start": 48,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000031",
    "sentence": "值青州王公儼拒命，改平盧軍節度，至鎮，擒公儼，斬之。",
    "entities": [
