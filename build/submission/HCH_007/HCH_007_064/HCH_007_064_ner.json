      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000154",
    "sentence": "會萬進納款於梁，知裕先奔於汴，梁主厚待之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000155",
    "sentence": "特置歸化軍，以知裕為指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000156",
    "sentence": "凡軍士自河朔歸梁者，皆隸於部下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000157",
    "sentence": "梁與莊宗交戰於河，摧堅挫銳，惟恃歸化一軍，然歲將一紀，位不及郡守。",
    "entities": [
      {
        "text": "位不及郡",
        "label": "LOC",
        "start": 27,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000158",
    "sentence": "同光初，莊宗入汴，知裕隨段凝軍解甲封丘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000159",
    "sentence": "明宗時為總管，受降於郊外，見知裕甚喜，遙相謂曰：「周歸化今為吾人，何樂如之！」因令諸子以兄事之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000160",
    "sentence": "莊宗撫憐尤異，而諸校心妒之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000161",
    "sentence": "有壯士唐從益者，因獵射之，知裕遁而獲免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000162",
    "sentence": "莊宗遂誅從益，出知裕為房州刺史。",
    "entities": [
      {
        "text": "出知裕為房州",
        "label": "LOC",
        "start": 7,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000163",
    "sentence": "魏王繼岌伐蜀，召為前鋒騎將。",
    "entities": [
      {
        "text": "蜀",
        "label": "ORG",
        "start": 5,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000164",
    "sentence": "明宗即位，移刺絳州，改淄州刺史、宿州團練使。",
    "entities": [
      {
        "text": "移刺絳州",
