      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000138",
    "sentence": "莊宗至汴，玘來朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000139",
    "sentence": "玘在晉州八年，日與上黨、太原之師交鬥於境上。",
    "entities": [
      {
