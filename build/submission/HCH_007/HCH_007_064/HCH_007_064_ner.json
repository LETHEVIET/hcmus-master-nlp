      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000122",
    "sentence": "子四人，長曰崇勳，官至左武衛將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 14,
