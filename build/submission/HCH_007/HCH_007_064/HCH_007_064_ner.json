      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000080",
    "sentence": "屬燕將張萬進殺滄州留後劉繼威，以城歸梁，末帝命思遠鎮之。",
    "entities": [
      {
        "text": "將張萬進殺滄州",
