        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000071",
    "sentence": "贈太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000072",
    "sentence": "子徹，位至懷州刺史。",
    "entities": [
      {
        "text": "位至懷州",
        "label": "LOC",
        "start": 3,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000073",
    "sentence": "戴思遠，本梁之故將也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000074",
    "sentence": "初事梁祖，以武幹知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000075",
    "sentence": "開平元年，自右羽林統軍加檢校司徒，出為晉州刺史。",
