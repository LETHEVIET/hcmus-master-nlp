[
  {
    "sentence_id": "HCH_007_064_000001",
    "sentence": "霍彥威，字子重，洺州曲周人也。",
    "entities": [
      {
        "text": "洺州",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000002",
    "sentence": "梁將霍存得之於村落間，年十四，從征討。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000003",
    "sentence": "存憐其爽邁，養為己子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000004",
    "sentence": "存，梁史有傳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000005",
    "sentence": "彥威未弱冠，為梁祖所知，擢在左右，漸升戎秩，亟立戰功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000006",
    "sentence": "嘗中流矢，眇其一目。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000007",
    "sentence": "開平二年，自開封府押衙、右親從指揮使、檢校司空授右龍驤軍使。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000008",
    "sentence": "三年，自右監門衛將軍授左天武軍使，遷右監門上將軍。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
