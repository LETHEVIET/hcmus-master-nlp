        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000090",
    "sentence": "清泰二年八月，卒於家。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000091",
    "sentence": "朱漢賓，字績臣，亳州譙縣人也。",
    "entities": [
      {
        "text": "亳州譙縣",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000092",
    "sentence": "父元禮，始為郡將。",
    "entities": [
      {
        "text": "始為郡",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000093",
    "sentence": "梁太祖聞其名，擢為軍校，從龐師古渡淮，戰沒於淮南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000094",
    "sentence": "漢賓少有膂力，形神壯偉，膽氣過人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000095",
    "sentence": "梁祖以其父死王事，選置帳下，編入屬籍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000096",
    "sentence": "梁祖之攻兗、鄆也，朱瑾募驍勇數百人，黥雙雁於其頰，立為「雁子都」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000097",
    "sentence": "梁祖聞之，亦選數百人，別為一軍，號為「落雁都」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000098",
    "sentence": "署漢賓為軍使，當時目為「朱落雁」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000099",
    "sentence": "後與諸將破蔡賊有功，天復中，授右羽林統軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000100",
    "sentence": "入梁，曆天威軍使、左羽林統軍，出為磁州刺史、滑宋二州留後、亳曹二州刺史、安州節度使。",
    "entities": [
      {
