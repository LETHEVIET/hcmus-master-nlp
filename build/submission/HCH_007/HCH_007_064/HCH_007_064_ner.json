      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000010",
    "sentence": "乾化末，邠州留後李保衡背李茂貞以城歸梁，梁以彥威為邠州節度使。",
    "entities": [
      {
        "text": "邠州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "衡背李茂貞以城",
        "label": "LOC",
        "start": 10,
        "end": 17
      },
      {
        "text": "梁以彥威為邠州",
        "label": "LOC",
        "start": 20,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000011",
    "sentence": "其年五月，茂貞遣將劉知俊率大軍攻之，彥威固守逾年，竟不能下；或得其俘，悉令放之，秦人懷其惠，遂無侵擾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000012",
    "sentence": "轉滑州節度使。",
    "entities": [
      {
        "text": "轉滑州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000013",
    "sentence": "移鎮鄆州，兼北面行營招討，總大軍於河上。",
    "entities": [
      {
        "text": "移鎮鄆州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000014",
    "sentence": "師徒屢敗，降授陝州留後。",
    "entities": [
      {
        "text": "降授陝州",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000015",
    "sentence": "莊宗入汴，彥威自陝馳至請罪，詔釋之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000016",
    "sentence": "一日，莊宗於崇元殿宴諸將，彥威與段凝、袁象先等預會。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000017",
    "sentence": "酒酣，莊宗舉酒屬明宗曰：「 此席宴客，皆吾前歲之勁敵也，一旦與吾同宴，蓋卿前鋒之效也。」彥威等伏陛謝罪，莊宗曰：「與卿話舊，無足畏也。」 因賜禦衣、器幣，盡歡而罷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000018",
    "sentence": "尋放歸藩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000019",
    "sentence": "明年，從明宗平潞州，授徐州節度使。",
    "entities": [
      {
        "text": "從明宗平潞州",
        "label": "LOC",
