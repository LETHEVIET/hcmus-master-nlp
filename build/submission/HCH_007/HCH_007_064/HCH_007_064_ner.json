      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000165",
    "sentence": "知裕老於軍旅，勤於稼穡，凡為郡勸課，皆有政聲，朝廷喜之，遷安州留後。",
    "entities": [
      {
        "text": "凡為郡",
        "label": "LOC",
        "start": 12,
        "end": 15
      },
      {
        "text": "遷安州",
