        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000063",
    "sentence": "惕隱以餘眾北走幽州，趙德鈞令牙將武從諫以騎邀擊。",
    "entities": [
      {
        "text": "以餘眾北走幽州",
        "label": "LOC",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000064",
    "sentence": "德鈞分扼諸要路，旬日之內，盡獲惕隱已下酋長七百餘人，契丹遂弱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000065",
    "sentence": "晏球圍城既久，帝遣使督攻城，晏球曰：「賊壘堅峻，但食三州租稅，撫恤黎民，愛養軍士彼自當魚潰。」帝然其言。",
    "entities": [
      {
        "text": "晏球圍城",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "帝遣使督攻城",
        "label": "LOC",
        "start": 7,
        "end": 13
      },
      {
        "text": "但食三州",
        "label": "LOC",
        "start": 24,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000066",
    "sentence": "晏球能與將士同其甘苦，所得祿賜私財，盡以饗士，日具飲饌，與將校筵宴，待軍士有禮，軍中無不敬伏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000067",
    "sentence": "其年冬，平賊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_064_000068",
    "sentence": "自初戰至於城拔，不戮一士，上下歡心，物議以為有將帥之略，以功授天平軍節度使。",
    "entities": [
      {
        "text": "自初戰至於城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000069",
    "sentence": "未幾，移鎮青州，就加兼中書令。",
    "entities": [
      {
        "text": "移鎮青州",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_064_000070",
    "sentence": "長興三年，卒於鎮，時年六十。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
