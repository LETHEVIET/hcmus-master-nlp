    "entities": []
  },
  {
    "sentence_id": "HCH_007_121_000024",
    "sentence": "時以妃喪在賊境，未及遷窆，世宗乃詔有司於嵩陵之側，預營一冢以虛之，俟賊平即議襄事。",
    "entities": []
  },
