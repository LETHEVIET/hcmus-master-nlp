  {
    "sentence_id": "HCH_007_108_000104",
    "sentence": "李鏻",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000105",
    "sentence": "李鏻，唐宗屬也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000106",
    "sentence": "父洎，韶州刺史。",
