      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000122",
    "sentence": "嘗權典選部，銓綜失序，物論非之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000123",
    "sentence": "晉天福中，守太子少保。",
    "entities": [
