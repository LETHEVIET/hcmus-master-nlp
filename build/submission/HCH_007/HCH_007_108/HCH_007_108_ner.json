        "start": 81,
        "end": 83
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000121",
    "sentence": "得代歸闕，復為戶部尚書，尋轉兵部尚書，有頃兼判太常卿事。",
    "entities": [
      {
        "text": "尚書",
