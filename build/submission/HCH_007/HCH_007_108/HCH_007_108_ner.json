      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000125",
    "sentence": "高祖至闕，授守司徒，數月而卒，年八十八。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000126",
    "sentence": "詔贈太傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000127",
    "sentence": "龍敏",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000128",
    "sentence": "龍敏，字欲訥，幽州永清人。",
