      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000048",
    "sentence": "蘇逢吉",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000049",
    "sentence": "蘇逢吉，長安人。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000050",
    "sentence": "父悅，逢吉母早喪，而悅鰥居，旁無侍者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000051",
    "sentence": "性嗜酒，雖所飲不多，然漱醪終日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000052",
    "sentence": "他人供膳，皆不稱旨，俟逢吉庖炙，方肯下箸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000053",
    "sentence": "悅初仕蜀，官升朝列，逢吉初學為文，嘗代父染翰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000054",
    "sentence": "悅嘗為高祖從事，甚見禮遇，因從容薦逢吉曰：「老夫耄矣，才器無取。男逢吉粗學援毫，性復恭恪，如公不以㹠犬之微，願令事左右。」高祖召見，以神精爽惠，甚憐之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000055",
    "sentence": "有頃，擢為賓佐，凡有謀議，立侍其側。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000056",
    "sentence": "高祖素嚴毅，及鎮太原，位望崇重，從事稀得謁見，惟逢吉日侍左右。",
    "entities": [
      {
        "text": "及鎮",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000057",
    "sentence": "兩使文簿，堆案盈幾，左右不敢輒通，逢吉置於懷袖，俟其悅色則諮之，多見其可。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000058",
    "sentence": "高祖建號於太原，逢吉自節度判官拜同平章事、集賢殿大學士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000059",
    "sentence": "車駕至汴，朝廷百司庶務，逢吉以為己任，參決處置，並出胸臆，雖有當有否，而事無留滯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000060",
    "sentence": "會翰林學士李濤從容侍帝，言及霸府二相，官秩未崇，逢吉旋加吏部尚書，未幾，轉左僕射，監修國史。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000061",
    "sentence": "從征杜重威於鄴下，數乘醉抵辱周太祖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000062",
    "sentence": "及高祖大漸，與楊邠、史宏肇等臥內同受顧命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000063",
    "sentence": "李濤與逢吉論甥舅之契，相得甚歡，濤之入相，逢吉甚有力焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000064",
    "sentence": "會濤上章，請出兩樞密為方鎮，帝怒，罷濤相，勒歸私第，時論疑濤承逢吉之風旨。",
    "entities": [
      {
        "text": "出兩樞密為方鎮",
        "label": "LOC",
        "start": 6,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000065",
    "sentence": "先是，高祖踐阼之後，逢吉與蘇禹珪俱在中書，有所除拜，多違舊制，用舍升降，率意任情，至有自白丁而升宦路、由流外而除令錄者，不可勝數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000066",
    "sentence": "物論紛然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000067",
    "sentence": "高祖方倚信二相，莫敢言者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000068",
    "sentence": "逢吉尤貪財貨，無所顧避，求進之士，稍有物力者，即遣人微露風旨，許以美秩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000069",
    "sentence": "及楊邠為相，稍奪二蘇之權，自是盡斂手而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000070",
    "sentence": "邠每懲二蘇之失，艱於除拜，至於諸司補吏，與門胄出身，一切停罷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000071",
    "sentence": "時論以邠之蔽，固亦由逢吉、禹珪本不能至公於物之所致也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000072",
    "sentence": "初，高祖至汴，以故相馮道、李崧為契丹所俘，佇於真定，乃以崧第賜逢吉，道第賜禹珪，崧於西洛有別業，亦為逢吉所有。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000073",
    "sentence": "及真定逐契丹，崧、道歸朝，崧弟嶼以逢吉占據其第，時出怨言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000074",
    "sentence": "未幾，崧以西京宅券獻於逢吉，不悅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000075",
    "sentence": "會崧有仆夫欲誣告謀反，逢吉誘致其狀，即告史宏肇，令逮捕其家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000076",
    "sentence": "逢吉遣直省吏召崧至第，即令監至侍衛獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000077",
    "sentence": "翌日，所司以獄辭上，其李嶼款招云：「與兄崧、弟鳷，與家僮二十人商議，比至山陵發引之時，同放火謀亂，其告是實。」蓋自誣之辭也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000078",
    "sentence": "逢吉仍以筆添註「二十人」字為「五十人」，封下有司，盡誅崧家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000079",
    "sentence": "時人冤之，歸咎於逢吉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000080",
    "sentence": "逢吉深文好殺，從高祖在太原時，嘗因事，高祖命逢吉靜獄，以祈福祐，逢吉盡殺禁囚以報。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000081",
    "sentence": "及執朝政，尤愛刑戮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000082",
    "sentence": "朝廷患諸處盜賊，遣使捕逐，逢吉自草詔意云：「應有賊盜，其本家及四鄰同保人，並仰所在全族處斬。」或謂逢吉曰：「為盜者族誅，猶非王法，鄰保同罪，不亦甚乎？」逢吉堅以為是，竟去「全族」二字。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000083",
    "sentence": "時有鄆州捕賊使臣張令柔盡殺平陰縣十七村民，良由此也。",
    "entities": [
      {
        "text": "時有鄆州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "令柔盡殺平陰縣",
        "label": "LOC",
        "start": 9,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000084",
    "sentence": "逢吉性侈靡，好鮮衣美食，中書供膳，鄙而不食，私庖供饌，務盡甘珍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000085",
    "sentence": "嘗於私第大張酒樂以召權貴，所費千餘緡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000086",
    "sentence": "其妻武氏卒，葬送甚盛，班行官及外州節制，有與逢吉相款洽者，皆令賫送綾羅絹帛，以備縞素。",
    "entities": [
      {
        "text": "班行官及外州",
        "label": "LOC",
        "start": 11,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000087",
    "sentence": "失禮違度，一至如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000088",
    "sentence": "又性不拘名教，繼母死不行服，妻死未周，其子並授官秩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000089",
    "sentence": "有庶兄自外至，不白逢吉，便見諸子，逢吉怒，且懼他日淩弱其子息，乃密白高祖，誣以他事杖殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000090",
    "sentence": "乾祐二年秋，加守司空。",
    "entities": [
      {
        "text": "乾祐二年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000091",
    "sentence": "周太祖之將鎮鄴也，逢吉奏請落樞密使，隱帝曰：「有前例否？」逢吉奏曰：「樞密之任，方鎮帶之非便。」史宏肇曰：「兼帶樞密，所冀諸軍稟畏。」竟從宏肇之議。",
    "entities": [
      {
        "text": "周太祖之將鎮",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "方鎮",
        "label": "LOC",
        "start": 40,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000092",
    "sentence": "宏肇怨逢吉之異己，逢吉曰：「此國家之事也，且以內制外則順，以外制內豈得便耶！」事雖不從，物議多之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000093",
    "sentence": "居無何，王章張飲，會逢吉與史宏肇有謔言，大為宏肇所詬，逢吉不校，幾至毆擊，逢吉馳馬而歸，自是將相失歡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000094",
    "sentence": "逢吉欲希外任，以紓宏肇之怒，既而中輟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000095",
    "sentence": "人問其故，逢吉曰：「茍領一方鎮，只消得史公一處分。則為齏粉矣。」李業輩惡宏肇、楊邠等，逢吉知之，每見業等，即微以言激怒之。",
    "entities": [
      {
        "text": "茍領一方鎮",
        "label": "LOC",
        "start": 10,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000096",
    "sentence": "及宏肇等被害，逢吉不預其謀，聞變驚駭，即受宣徽，權知樞密院事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000097",
    "sentence": "尋令草制正授，制入，聞鄴兵至澶州乃止。",
    "entities": [
      {
        "text": "聞鄴兵至澶州",
        "label": "LOC",
        "start": 10,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000098",
    "sentence": "事急，逢吉謂人曰：「蕭墻之變，太覺匆遽，主上若有一言見問，必不至是矣。」數夕宿於金祥殿之東，謂天官正王處訥曰：「夜來就枕未瞑，已見李崧在傍，生人與死人相接，無吉事也。」及周太祖自鄴至汴，官軍敗於劉子陂，是夕逢吉宿於七里郊，與同舍痛飲，醉將自刎，左右止之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000099",
    "sentence": "至曙，與隱帝同抵民舍，遂自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000100",
    "sentence": "周太祖定京城，與聶文進等同梟於北市，釋其家族。",
    "entities": [
      {
        "text": "周太祖定京城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000101",
    "sentence": "其梟首之處，適當李崧冤死之地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000102",
    "sentence": "廣順初，詔就西京賜其子莊宅各一區。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000103",
    "sentence": "〈 （《五代史補》：高祖在河東幕府，闕書記，朝廷除前進士丘廷敏為之，以高祖有異志，恐為所累，辭疾不赴，遂改蘇逢吉。未幾，契丹南侵，高祖仗順而起，兵不血刃而天下定，逢吉以佐命功，自掌書記拜中書侍郎、平章事。逾年，廷敏始選授鳳翔麟遊縣令。過堂之日，逢吉戲之，且撫所坐椅子曰：「合是長官坐，何故讓與鄙夫耶？」廷敏遂漸悚而退。） 〉",
