        "start": 34,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000109",
    "sentence": "鏻少舉進士，累舉不第。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000110",
    "sentence": "客遊河朔，稱清海軍掌書記，謁定州王處直，不見禮。",
    "entities": [
      {
        "text": "謁定州",
        "label": "LOC",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000111",
    "sentence": "鏻即脫綠被緋，入常山謁要人李宏規，以宗姓請兄事之，由是得進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000112",
    "sentence": "趙王镕辟為從事，镕卒，復為王德明賓客。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000113",
    "sentence": "德明使鏻聘於唐莊宗，鏻密疏德明之罪，且言可圖之狀，莊宗嘉之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000114",
    "sentence": "及常山平，以鏻為霸府支使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000115",
    "sentence": "嘗從容請於莊宗曰：「鏻有四子，請誅之。」莊宗問其故，對曰：「此輩生於常山，稟勃亂之氣，不可留也。」莊宗笑而止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000116",
    "sentence": "同光初，授宗正卿，俄兼工部侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_108_000117",
    "sentence": "常山有唐啟運陵，鏻受富民李守恭賂，署為陵臺令，守恭暴橫，為長吏所訴，按之以聞，鏻左授司農少卿，削金紫，未幾，出為河府副使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_108_000118",
    "sentence": "明宗即位，歷兵部、戶部侍郎，工部、戶部尚書。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
