      }
    ]
  },
  {
    "sentence_id": "HCH_007_063_000053",
    "sentence": "會趙在禮據魏州，都軍進討無功。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 5,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_063_000054",
    "sentence": "時明宗已為群小間諜，端居私第。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_063_000055",
    "sentence": "全義以臥疾聞變，憂懼不食，薨於洛陽私第，時年七十五。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_063_000056",
    "sentence": "天成初，冊贈太師，諡曰忠肅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_063_000057",
    "sentence": "全義曆守太師、太傅、太尉、中書令，封王，邑萬三千戶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_063_000058",
    "sentence": "凡領方鎮洛、鄆、陝、滑、宋，三蒞河陽，再領許州，內外官曆二十九任，尹正河、洛，凡四十年，位極人臣，善保終吉者，蓋一人而已。",
    "entities": [
      {
        "text": "凡領方鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "再領許州",
        "label": "LOC",
        "start": 19,
        "end": 23
      },
      {
        "text": "四十年",
        "label": "TME",
        "start": 40,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_007_063_000059",
    "sentence": "全義樸厚大度，敦本務實，起戰士而忘功名，尊儒業而樂善道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_063_000060",
    "sentence": "家非士族，而獎愛衣冠，開幕府辟士，必求望實，屬邑補奏，不任吏人。",
    "entities": [
      {
        "text": "屬邑",
        "label": "LOC",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_063_000061",
    "sentence": "位極王公，不衣羅綺，心奉釋、老，而不溺左道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_063_000062",
    "sentence": "如是數者，人以為難。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_063_000063",
    "sentence": "自莊宗至洛陽，趨向者皆由徑以希恩寵，全義不改素履，盡誠而已。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_063_000064",
    "sentence": "言事者以梁祖為我世讎，宜斫棺燔柩，全義獨上章申理，議者嘉之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_063_000065",
    "sentence": "劉皇后嘗從莊宗幸其第，奏云：「妾孩幼遇亂，失父母，欲拜全義為義父。」許之。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_063_000066",
    "sentence": "全義稽首奏曰：「皇后萬國之母儀，古今未有此事，臣無地自處。」莊宗敦逼再三，不獲已，乃受劉後之拜。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_063_000067",
    "sentence": "既非所願，君子不以為非。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_063_000068",
    "sentence": "然全義少長軍中，立性樸滯，凡百姓有詞訟，以先訴者為得理，以是人多枉濫，為時所非。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_063_000069",
    "sentence": "又嘗怒河南縣令羅貫，因憑劉後譖於莊宗，俾貫非罪而死，露屍於府門，冤枉之聲，聞於遠近，斯亦良玉之微瑕也。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
