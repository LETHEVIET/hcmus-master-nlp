  },
  {
    "sentence_id": "HCH_007_071_000105",
    "sentence": "格有文章，明吏事，時頗稱之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000106",
    "sentence": "許寂，字閑閑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000107",
