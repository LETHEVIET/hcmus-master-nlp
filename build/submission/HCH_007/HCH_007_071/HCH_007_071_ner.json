[
  {
    "sentence_id": "HCH_007_071_000001",
    "sentence": "馬郁，其先范陽人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000002",
    "sentence": "郁少警悟，有俊才智數，言辯縱橫，下筆成文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000003",
    "sentence": "乾寧末，為幽州府刀筆小吏。",
    "entities": [
      {
        "text": "為幽州",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000004",
    "sentence": "李匡威為王鎔所殺，鎔書報其弟匡儔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000005",
    "sentence": "匡儔遣使於鎔，問謀亂本末，幕客為書，多不如旨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000006",
    "sentence": "郁時直記室，即起草，為之條列事狀，雲可疑者十，詞理俊贍，以此知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000007",
    "sentence": "嘗聘王鎔於鎮州，官妓有轉轉者，美麗善歌舞，因宴席，郁累挑之。",
    "entities": [
      {
        "text": "嘗聘王鎔於鎮州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000008",
    "sentence": "幕客張澤亦以文章名，謂郁曰：「子能座上成賦，可以此妓奉酬。」郁抽筆操紙，即時成賦，擁妓而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000009",
    "sentence": "郁在武皇幕，累官至檢校司空、秘書監。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000010",
    "sentence": "武皇與莊宗禮遇俱厚，給賜優異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000011",
    "sentence": "監軍張承業，本朝舊人，權貴任事，人士脅肩低首候之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000012",
    "sentence": "郁以滑稽侮狎，其往如歸，有時直造臥內。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000013",
    "sentence": "每賓僚宴集，承業出珍果陳列於前，食之必盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000014",
    "sentence": "承業私戒主膳者曰：「他日馬監至，唯以乾藕子置前而已。」郁至，窺其不可啖；異日，靴中出一鐵楇，碎而食之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000015",
    "sentence": "承業大笑曰：「為公設異饌，勿敗餘食案。」其俊率如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000016",
    "sentence": "郁在莊宗幕，寄寓他土，年老思鄉，每對莊宗欷歔，言家在范陽，乞骸歸國，以葬舊山。",
    "entities": [
      {
        "text": "年老思鄉",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000017",
    "sentence": "莊宗謂之曰：「自卿去國已來，同舍孰在？守光尚不能容父，能容卿乎！孤不惜卿行，但卿不得死爾。」郁既無歸路，衷懷嗚咽，竟卒於太原。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000018",
    "sentence": "司空頲，貝州人。",
    "entities": [
      {
        "text": "貝州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000019",
    "sentence": "唐僖宗時，舉進士不中，屬天子播遷，三輔大亂，乃還鄉里。",
    "entities": [
      {
        "text": "乃還鄉",
        "label": "LOC",
        "start": 22,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000020",
    "sentence": "羅紹威為節度副大使，頲以所業幹之，幕客公乘億為延譽，羅宏信署為府參軍，辟館驛巡官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000021",
    "sentence": "張彥之亂，命判官王正言草奏，正言素不能文，不能下筆，彥怒詬曰：「鈍漢乃辱我！」推之下榻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000022",
    "sentence": "問孰可草奏者，有言頲，羅王時書記，乃馳騎召之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000023",
    "sentence": "頲揮筆成文，詆斥梁君臣，彥甚喜，為判官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000024",
    "sentence": "及張彥復脅賀德倫降於唐，德倫遣頲先奉狀太原。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000025",
    "sentence": "〈 （《北夢瑣言》載其狀詞云：屈原哀郢，本非怨望之人；樂毅歸燕，且異傾邪之行。） 〉 莊宗仍以頲為判官，後以頲權軍府事。",
    "entities": [
      {
        "text": "《北夢瑣言》",
        "label": "TITLE",
        "start": 3,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000026",
    "sentence": "頲有侄在梁，遣家奴以書召之，都虞候張裕擒其家奴，以謂通於梁，遂見殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000027",
    "sentence": "〈 （《通鑒》：晉王責頲曰：「自吾得魏博，庶事悉以委公，公何得見欺如是，獨不可先相示耶！」揖令歸第，是日族誅於軍門。） 〉",
    "entities": [
      {
        "text": "《通鑒》",
        "label": "TITLE",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000028",
    "sentence": "曹廷隱，魏州人也，為本州典謁虞候。",
    "entities": [
      {
        "text": "魏州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "為本州",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000029",
    "sentence": "賀德倫使西迎莊宗於晉陽，莊宗既得鄴城，擢為馬步都虞候，以其稱職，自是遷拜日隆。",
    "entities": [
      {
        "text": "莊宗既得鄴城",
        "label": "LOC",
        "start": 12,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000030",
    "sentence": "天成初，除齊州防禦使。",
    "entities": [
      {
        "text": "除齊州",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000031",
    "sentence": "下車嚴整，頗有清白之譽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000032",
    "sentence": "時有孔目吏範弼者，為人剛愎，視廷隱蔑如也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000033",
    "sentence": "弼監軍廩，鬻空乏以取貲；又私貨官鹽，廷隱按之，遂奏其事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000034",
    "sentence": "弼家人訴於執政，並下御史府劾之。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000035",
    "sentence": "弼雖伏法，廷隱以所奏不實，並流永州，續敕賜自盡，時人冤之。",
    "entities": [
      {
        "text": "並流永州",
        "label": "LOC",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000036",
    "sentence": "蕭希甫，宋州人也。",
    "entities": [
      {
        "text": "宋州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000037",
    "sentence": "少舉進士，為梁開封尹袁象先書記。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000038",
    "sentence": "象先為青州節度使，以希甫為巡官，希甫不樂。",
    "entities": [
      {
        "text": "象先為青州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000039",
    "sentence": "乃棄其母妻，變姓名，亡之鎮州，自稱青州掌書記，進謁王鎔。",
    "entities": [
      {
        "text": "亡之鎮州",
        "label": "LOC",
        "start": 10,
        "end": 14
      },
      {
        "text": "自稱青州",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000040",
    "sentence": "鎔以希甫為參軍，尤不樂，居歲餘，又亡之易州，削髮為僧，居百丈山。",
    "entities": [
      {
        "text": "又亡之易州",
        "label": "LOC",
        "start": 16,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000041",
    "sentence": "莊宗將建國，置百官，李紹宏薦為魏州推官。",
    "entities": [
      {
        "text": "李紹宏薦為魏州",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000042",
    "sentence": "同光初，有詔定內宴儀，問希甫樞密使得坐否，希甫以為不可。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000043",
    "sentence": "樞密使張居翰聞之怒，謂希甫曰：「老夫曆事三朝天子，見內宴數百，子本田舍兒，安知宮禁事！」希甫不能對。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000044",
    "sentence": "初，莊宗欲以希甫知制誥，宰相豆盧革等附居翰，共排斥之，以為駕部郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000045",
    "sentence": "希甫失誌，尤怏怏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000046",
    "sentence": "莊宗滅梁室，遣希甫宣慰青、齊，希甫始知其母已死，妻袁氏亦改嫁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000047",
    "sentence": "希甫乃發哀服喪，居於魏州。",
    "entities": [
      {
        "text": "居於魏州",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000048",
    "sentence": "人有引漢李陵書以譏之曰：「老母終堂，生妻去室。」天成初，欲召為諫議，豆盧革、韋說沮之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000049",
    "sentence": "明宗卒以希甫為諫議大夫，復為匭函使。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000050",
    "sentence": "其後革、說為安重誨所惡，希甫希旨，誣奏革縱田客殺人，而說與鄰人爭井，井有寶貨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000051",
    "sentence": "有司推勘井中，惟破釜而已，革、說卒皆貶死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000052",
    "sentence": "希甫拜左散騎常侍，躁進尤甚，引告變人李筠夜扣內門，通變書云：「修堤兵士，欲取郊天日舉火為叛。」安重誨不信之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000053",
    "sentence": "斬告變者，軍人訴屈，請希甫啖之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000054",
    "sentence": "既而詔曰：「左散騎常侍、集賢殿學士判院事蕭希甫，身處班行，職非警察，輒引凶狂之輩，上陳誣骫之詞，逼近郊禋，扇搖軍眾。李筠既當誅戮，希甫寧免謫遷，可貶嵐州司戶參軍，仍馳驛發遣。」長興中，卒於貶所。",
    "entities": [
      {
        "text": "可貶嵐州",
        "label": "LOC",
        "start": 72,
        "end": 76
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000055",
    "sentence": "子士明，仕周，終於邑宰。",
    "entities": [
      {
        "text": "終於邑",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000056",
    "sentence": "藥縱之，太原人，少為儒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000057",
    "sentence": "明宗刺代州，署為軍事衙推。",
    "entities": [
      {
        "text": "明宗刺代州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000058",
    "sentence": "從明宗鎮邢州，為掌書記，曆天平、宣武兩鎮節度副使。",
    "entities": [
      {
        "text": "從明宗鎮邢州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "宣武兩鎮",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000059",
    "sentence": "明宗鎮常山，被病不從。",
    "entities": [
      {
        "text": "明宗鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000060",
    "sentence": "及即位，縱之見於洛邑，安重誨怒其觀望，久無所授。",
    "entities": [
      {
        "text": "縱之見於洛邑",
        "label": "LOC",
        "start": 4,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000061",
    "sentence": "明宗曰：「德勝用兵時，縱之饑寒相伴，不離我左右。今有天下，何人不富貴，何為獨棄縱之！」浹旬，授磁州刺史。",
    "entities": [
      {
        "text": "授磁州",
        "label": "LOC",
        "start": 46,
        "end": 49
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 49,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000062",
    "sentence": "歲餘，自戶部侍郎遷吏部侍郎，銓總之法，惘然莫知。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000063",
    "sentence": "長興初，為曹州刺史。",
    "entities": [
      {
        "text": "為曹州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000064",
    "sentence": "清泰元年九月，以疾受代而卒。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000065",
    "sentence": "賈馥，故鎮州節度使王鎔判官也。",
    "entities": [
      {
        "text": "故鎮州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000066",
    "sentence": "家聚書三千卷，手自刊校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000067",
    "sentence": "張文禮殺王鎔，時莊宗未即尊位，文禮遣馥至鄴都勸進，因留鄴下，棲遲郵舍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000068",
    "sentence": "莊宗即位，授鴻臚少卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_071_000069",
    "sentence": "後以鴻臚卿致仕，復歸鎮州，結茅於別墅，自課兒孫耕牧為事。",
    "entities": [
      {
        "text": "復歸鎮州",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_071_000070",
    "sentence": "馥初累為鎮、冀屬邑令，所蒞有能政，性恬澹，與物無競，乃鎮州士人之秀者也。",
    "entities": [
      {
        "text": "馥初累為鎮",
        "label": "LOC",
