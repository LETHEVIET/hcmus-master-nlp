      }
    ]
  },
  {
    "sentence_id": "HCH_007_106_000009",
    "sentence": "周稟性寬惠，人庶便之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_106_000010",
    "sentence": "開運末，杜重威降於契丹，引契丹主臨城諭之。",
