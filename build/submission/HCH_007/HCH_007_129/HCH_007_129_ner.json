      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000215",
    "sentence": "穎性卞急峻刻，不容人之小過，雖左右親信，亦皆怨之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000216",
    "sentence": "部曲曹澄有處女，穎逼而娶之，澄遂與不逞之徒數人，同謀害穎，中夜挾刃入於寢門，執穎而殺之，遂奔於金陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000217",
    "sentence": "世宗征淮南，以永德之故，遣江南李景，令執澄等送行在。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000218",
    "sentence": "及至，世宗以澄等賜永德，俾甘心而戮之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000219",
    "sentence": "劉仁贍",
    "entities": [
      {
        "text": "劉仁贍",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000220",
    "sentence": "劉仁贍，略通儒術，好兵書，在澤國甚有聲望。",
    "entities": [
      {
        "text": "劉仁贍",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000221",
    "sentence": "吳主知之，累遷為偽右監門衛將軍，歷黃、袁二州刺史，所至稱治。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "袁二州",
