        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000134",
    "sentence": "孫漢英，太原人也。",
    "entities": [
      {
        "text": "孫漢英",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000135",
    "sentence": "父重進，事唐武皇、莊宗為大將，賜姓，名存進，《唐書》有傳。",
    "entities": [
      {
        "text": "《唐書》",
        "label": "TITLE",
        "start": 22,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000136",
    "sentence": "漢英少事戎伍，稍至都將，嘗為東面馬步軍都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000137",
    "sentence": "清泰初，興元節度使張虔釗失律於岐下，遂以其地西臣於蜀，漢英兄漢韶，時為洋州節度使，因茲阻隔，亦送款於蜀，由是漢英與弟漢筠久之不調。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 5,
        "end": 6
      },
      {
        "text": "張虔釗",
        "label": "PER",
        "start": 9,
        "end": 12
      },
      {
        "text": "時為洋州",
        "label": "LOC",
        "start": 33,
        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000138",
    "sentence": "漢乾祐中，太祖西征蒲、雍，以漢英戚裏之分，奏於軍中指使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000139",
    "sentence": "蒲、雍平，班師，隱帝以漢英為絳州刺史、檢校司徒。",
    "entities": [
      {
