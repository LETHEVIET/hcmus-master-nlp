        "start": 6,
        "end": 8
      },
      {
        "text": "安從進",
        "label": "PER",
        "start": 8,
        "end": 11
      },
      {
        "text": "騎千餘屯於葉縣",
        "label": "LOC",
        "start": 25,
        "end": 32
      },
      {
        "text": "皇城",
        "label": "LOC",
        "start": 46,
        "end": 48
      },
      {
        "text": "至湖陽縣",
        "label": "LOC",
        "start": 65,
        "end": 69
      },
      {
        "text": "以功授亳州",
        "label": "LOC",
        "start": 87,
        "end": 92
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000111",
    "sentence": "襄陽平，遷安州防禦使。",
    "entities": [
      {
        "text": "遷安州",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000112",
    "sentence": "歷河陽、邢州兵馬留後。",
    "entities": [
      {
        "text": "邢州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000113",
    "sentence": "漢初，入為右衛大將軍。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000114",
    "sentence": "年逾七十，神氣不衰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000115",
    "sentence": "建崇始自代北事武皇，至是四十餘年，前後所掌兵，麾下部曲多至節鉞，零落殆盡，惟建崇雖位不及藩屏，而康強自適，以至期耄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000116",
    "sentence": "太祖即位，授左監門衛上將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000117",
    "sentence": "廣順三年春卒。",
    "entities": [
      {
        "text": "廣順三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000118",
    "sentence": "贈黔南節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000119",
    "sentence": "王重裔",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000120",
    "sentence": "王重裔，陳州宛丘人。",
    "entities": [
      {
        "text": "陳州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000121",
    "sentence": "父達，歷安、均、洺三州刺史，因家於洺。",
    "entities": [
      {
        "text": "洺三州",
        "label": "LOC",
        "start": 8,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000122",
    "sentence": "重裔幼沈厚有勇，善騎射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000123",
    "sentence": "年未及冠，事莊宗為廳直，管契丹直。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000124",
    "sentence": "從安汴、洛，累為禁軍指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000125",
    "sentence": "晉天福中，鎮州安重榮謀叛，稱兵指闕，朝廷命杜重威率師拒之，賊陣於宗城東，晉遣齊軍擊之，再合不動。",
    "entities": [
      {
        "text": "鎮州",
        "label": "LOC",
        "start": 5,
        "end": 7
      },
      {
        "text": "安重榮",
        "label": "PER",
        "start": 7,
        "end": 10
      },
      {
        "text": "杜重威",
        "label": "PER",
        "start": 21,
        "end": 24
      },
      {
        "text": "賊陣於宗城",
        "label": "LOC",
        "start": 29,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000126",
    "sentence": "杜重威懼，謀欲抽退，重裔曰：「兵家忌退，但請公分麾下兵擊其兩翼，重裔為公陷陣，當其中軍，彼必狼狽矣。」重威從之，重榮即時退蹙，遂敗。",
    "entities": [
      {
        "text": "杜重威",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000127",
    "sentence": "以功遷護聖右廂都指揮使，領費州刺史。",
    "entities": [
      {
        "text": "領費州",
        "label": "LOC",
        "start": 12,
        "end": 15
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000128",
    "sentence": "漢初，仍典禁軍，從征鄴都平，遷深州刺史。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "遷深州",
        "label": "LOC",
        "start": 14,
        "end": 17
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000129",
    "sentence": "淮夷以李守貞故，數侵邊地，以重裔為亳州防禦使，又令於徐州巡檢，兼知軍州，就加檢校太傅。",
    "entities": [
      {
        "text": "李守貞",
        "label": "PER",
        "start": 3,
        "end": 6
      },
      {
        "text": "以重裔為亳州",
        "label": "LOC",
        "start": 13,
        "end": 19
      },
      {
        "text": "又令於徐州",
        "label": "LOC",
        "start": 23,
        "end": 28
      },
      {
        "text": "兼知軍州",
        "label": "LOC",
        "start": 31,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000130",
    "sentence": "太祖踐阼，加爵邑，改功臣。",
    "entities": [
      {
        "text": "加爵邑",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000131",
    "sentence": "廣順元年夏，以疾卒，年五十有三。",
    "entities": [
      {
        "text": "廣順元年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000132",
    "sentence": "贈武信軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000133",
    "sentence": "孫漢英",
    "entities": [
