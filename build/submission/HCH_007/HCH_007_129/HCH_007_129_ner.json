[
  {
    "sentence_id": "HCH_007_129_000001",
    "sentence": "常思",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000002",
    "sentence": "常思，字克恭，太原人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000003",
    "sentence": "父仁嶽，河東牙將，累贈太子太師。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000004",
    "sentence": "唐莊宗之為晉王也，廣募勝兵，時思以趫悍應募，累從戎役，後為長直都校，歷捧聖軍使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000005",
    "sentence": "晉初，遷六軍都虞候。",
    "entities": [
      {
        "text": "晉",
        "label": "ORG",
        "start": 0,
        "end": 1
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000006",
    "sentence": "漢高祖出鎮並門，奏以思從行，尋表為河東牢城都指揮使，以勤幹見稱。",
    "entities": [
      {
        "text": "漢高祖出鎮",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "尋表為河東牢城",
        "label": "LOC",
        "start": 14,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000007",
    "sentence": "漢國初建，授檢校太保，遙領鄧州。",
    "entities": [
      {
        "text": "遙領鄧州",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000008",
    "sentence": "漢有天下，遷檢校太尉、昭義軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000009",
    "sentence": "乾佑初，李守貞叛於河中，太祖征之，朝廷命思帥部兵以副焉。",
    "entities": [
      {
        "text": "李守貞",
        "label": "PER",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000010",
    "sentence": "既而禦眾無能，勒歸舊藩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000011",
    "sentence": "思在上黨凡五年，無令譽可稱，唯以聚斂為務，性又鄙吝，未嘗與賓佐有酒肴之會。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000012",
    "sentence": "嘗有從事欲求謁見者，思覽刺而怒曰：「彼必是來獵酒也。」命典客者飲而遣之，其鄙吝也如是。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000013",
    "sentence": "太祖受命，就加平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000014",
    "sentence": "初，太祖微時，以季父待思，及即位，遣其妻入覲，太祖拜之如家人之禮，仍呼曰叔母，其恩顧如是。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000015",
    "sentence": "廣順二年秋，思來朝，加兼侍中，移鎮宋州。",
    "entities": [
      {
        "text": "廣順二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "移鎮宋州",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000016",
    "sentence": "三年夏，詔赴闕，改授平盧軍節度使。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000017",
    "sentence": "思將赴鎮，奏太祖云：「臣在宋州出鎮，得絲十餘萬兩，謹以上進，請行征督。」太祖頷之，尋詔本州折券以諭其民。",
    "entities": [
      {
        "text": "思將赴鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "臣在宋州出鎮",
        "label": "LOC",
        "start": 11,
        "end": 17
      },
      {
        "text": "尋詔本州",
        "label": "LOC",
        "start": 41,
        "end": 45
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000018",
    "sentence": "及到鎮，未幾，染風痹之疾，上表請尋醫，既而舁疾歸洛。",
    "entities": [
      {
        "text": "及到鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000019",
    "sentence": "顯德元年春卒，年六十有九。",
    "entities": [
      {
        "text": "顯德元年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000020",
    "sentence": "贈中書令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000021",
    "sentence": "翟光鄴",
    "entities": [
      {
        "text": "翟光鄴",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000022",
    "sentence": "翟光鄴，字化基，濮州鄄城人。",
    "entities": [
      {
        "text": "翟光鄴",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "濮州鄄城",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000023",
    "sentence": "父景珂，倜儻有膽氣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000024",
    "sentence": "梁貞明初，唐莊宗始駐軍於河上，景珂率聚邑人守永定驛，固守逾年，後為北軍所攻，景珂戰歿，眾潰。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 2,
        "end": 3
      },
      {
        "text": "景珂率聚邑",
        "label": "LOC",
        "start": 15,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000025",
    "sentence": "光鄴時年十歲，為明宗軍所俘，以其穎悟，俾侍左右，字之曰永定。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000026",
    "sentence": "既冠，沈毅有謀，蒞事寡過。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000027",
    "sentence": "明宗即位，時深委遇，累遷至皇城使、檢校司空。",
    "entities": [
      {
        "text": "累遷至皇城",
        "label": "LOC",
        "start": 10,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000028",
    "sentence": "長興中，樞密使安重誨得罪，時光鄴與中官孟小僧頗有力焉。",
    "entities": [
      {
        "text": "安重誨",
        "label": "PER",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000029",
    "sentence": "居無何，出為耀州團練使。",
    "entities": [
      {
        "text": "出為耀州",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000030",
    "sentence": "清泰初，入為左監門衛大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000031",
    "sentence": "晉天福中，歷棣沂二州刺史、西京副留守。",
    "entities": [
      {
        "text": "歷棣沂二州",
        "label": "LOC",
        "start": 5,
        "end": 10
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000032",
    "sentence": "開運初，授宣徽使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000033",
    "sentence": "楊光遠叛滅，青州平，除為防禦使，朝廷以兵亂之後，人物雕弊，故命光鄴理之。",
    "entities": [
      {
        "text": "楊光遠",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "青州",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000034",
    "sentence": "光鄴好聚書，重儒者，虛齋論議，惟求理道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000035",
    "sentence": "時郡民喪亡十之六七，而招懷撫諭，視之如傷，故期月之間，流亡載輯。",
    "entities": [
      {
        "text": "時郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000036",
    "sentence": "契丹入汴，偽命權知曹州。",
    "entities": [
      {
        "text": "偽命權知曹州",
        "label": "LOC",
        "start": 5,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000037",
    "sentence": "李從益假號，以光鄴明宗舊臣，署為樞密使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000038",
    "sentence": "漢祖至汴，改左領衛大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000039",
    "sentence": "乾祐初，遷右金吾衛大將軍，充街使、檢校太保。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000040",
    "sentence": "太祖踐阼，復授宣徽使、左千牛衛上將軍、檢校太傅。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000041",
    "sentence": "數月，兼樞密副使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000042",
    "sentence": "會永興李洪信入朝，代知軍府事。",
    "entities": [
      {
        "text": "李洪信",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000043",
    "sentence": "廣順二年十月，卒於長安，時年四十六。",
    "entities": [
      {
        "text": "廣順二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000044",
    "sentence": "光鄴有器度，慎密敦厚，出於天然，喜慍不形於色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000045",
    "sentence": "事繼母以孝聞，兄弟皆雍睦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000046",
    "sentence": "雖食祿日久，家無餘財，任金吾日，假官屋數間以蔽風雨，親族累重，糲食才給，人不堪其憂，光鄴處之晏如也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000047",
    "sentence": "賓朋至，則貰酒延之，談說終日，略無厭倦，士大夫多之。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000048",
    "sentence": "及權知京兆，以寬靜為治，前政有煩苛之事，一切停罷，百姓便之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000049",
    "sentence": "及病甚，召親隨於臥內，戒之曰：「氣絕之後，以屍歸洛，不得於此停留，慮煩軍府。」言訖而終。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000050",
    "sentence": "京兆吏如喪所親，或有以漿酒遙奠者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000051",
    "sentence": "樞密使王峻素重光鄴，且欲厚恤其家，為之上請，故自終及葬，所賜賻赗幾數千計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000052",
    "sentence": "詔贈太子少師。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000053",
    "sentence": "光鄴膚革肥皙，善於攝養，故司天監趙延乂有袁、許之術，嘗謂人曰：「翟君外厚而內薄，雖貴而無壽。」果如其言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000054",
    "sentence": "曹英",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000055",
    "sentence": "曹英，字德秀，舊名犯今上御名，故改焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000056",
    "sentence": "本常山鎮定人也。",
    "entities": [
      {
        "text": "本常山鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000057",
    "sentence": "父全武，事趙王王镕為列校，英因得隸於镕之帳下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000058",
    "sentence": "及張文禮之亂，唐莊宗奄有其地，乃錄镕之左右，署為散指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000059",
    "sentence": "明宗即位，英侍於仗下，問其祖考，英以實對，明宗曰：「乃朕之舊也。」擢為本班行首，每加顧遇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000060",
    "sentence": "晉天福中，遷弩手軍使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000061",
    "sentence": "平張從賓於汜水，以功授本軍都校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000062",
    "sentence": "漢初，改奉國軍主，加檢校司徒，兼康州刺史。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "兼康州",
        "label": "LOC",
        "start": 15,
        "end": 18
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000063",
    "sentence": "乾祐初，李守貞據河中叛，授行營步軍都校。",
    "entities": [
      {
        "text": "李守貞",
        "label": "PER",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000064",
    "sentence": "河中平，遷本軍廂主，領岳州防禦使。",
    "entities": [
      {
        "text": "領岳州",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000065",
    "sentence": "隨太祖在魏，為北面行營步軍都校，從平內難。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000066",
    "sentence": "國初，以翊戴功授昭武節度使、檢校太傅、侍衛步軍都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000067",
    "sentence": "二年春，總兵討慕容彥超於兗州，梯沖塹壘，頗有力焉。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000068",
    "sentence": "夏五月，太祖親征，因並兵攻陷其城，及凱旋，領彰信軍節度使，典軍如故。",
    "entities": [
      {
        "text": "因並兵攻陷其城",
        "label": "LOC",
        "start": 9,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000069",
    "sentence": "世宗嗣位，加同平章事，授成德軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000070",
    "sentence": "車駕自太原回，加兼侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000071",
    "sentence": "顯德元年冬，卒於鎮，時年四十九。",
    "entities": [
      {
        "text": "顯德元年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "卒於鎮",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000072",
    "sentence": "制贈中書令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000073",
    "sentence": "英性沈厚，謙恭有禮，雖衽席之際，接對賓客，亦未嘗造次。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000074",
    "sentence": "及卒，搢紳之士亦皆惜之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000075",
    "sentence": "李彥頵",
    "entities": [
