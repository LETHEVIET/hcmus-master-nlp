      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000140",
    "sentence": "廣順元年冬，卒於都。",
    "entities": [
      {
        "text": "廣順元年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000141",
    "sentence": "許遷",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000142",
    "sentence": "許遷，鄆州人也。",
    "entities": [
      {
        "text": "鄆州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000143",
    "sentence": "初為本州牙將，性剛褊。",
    "entities": [
      {
        "text": "初為本州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000144",
    "sentence": "漢乾祐初，為左屯衛將軍，與少府監馬從斌同監造漢祖山陵法物，節財省用，減數萬計。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000145",
    "sentence": "改左監門大將軍，又加檢校司空。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000146",
    "sentence": "漢末，權知隰州。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "權知隰州",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000147",
    "sentence": "太祖踐阼，劉崇遣子鈞率兵寇平陽，路由於隰，賊眾攻城，城中兵少，遷感激指諭，士鬥兼倍，賊眾傷夷，尋自退去。",
    "entities": [
      {
        "text": "賊眾攻城",
        "label": "LOC",
        "start": 21,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000148",
    "sentence": "太祖降詔撫諭，正授隰州刺史。",
    "entities": [
      {
        "text": "正授隰州",
        "label": "LOC",
        "start": 7,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000149",
    "sentence": "遷切於除盜，嫉惡過當，或釘磔賊人，令部下臠割。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000150",
    "sentence": "誤斷不合死罪人，其家詣闕致訟，詔下開封府獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000151",
    "sentence": "時陳觀為知府，素與遷不協，深劾其事，欲追遷對訟，太祖以事狀可原，但罷郡而已。",
    "entities": [
      {
        "text": "但罷郡",
        "label": "LOC",
        "start": 32,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000152",
    "sentence": "遷既奉朝請，因大詬陳觀，謂王峻曰：「相公執政，所與參議，宜求賢德。如陳觀者，為儒無家行，為官多任情，茍知其微，屠沽兒恥與為侶，況明公乎！」峻無以沮之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000153",
    "sentence": "既而嬰疾，請告歸汶上而卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000154",
    "sentence": "趙鳳",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000155",
    "sentence": "趙鳳，冀州棗強縣人，幼讀書，舉童子。",
    "entities": [
      {
        "text": "冀州棗強縣",
        "label": "LOC",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000156",
    "sentence": "既長，兇豪多力，以殺人暴掠為事，吏不能禁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000157",
    "sentence": "安重榮鎮常山，招集叛亡，鳳乃應募，既而犯法當死，即破械逾獄，遁而獲免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000158",
    "sentence": "天福中，趙延壽為契丹鄉導，歲侵深、冀，鳳往依焉。",
    "entities": [
      {
        "text": "趙延壽為契丹鄉",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000159",
    "sentence": "〈 （《宋史·荊罕儒傳》：罕儒少無賴，與趙鳳、張輦為群盜，晉天福中，相率詣范陽，委贄燕王趙延壽，得掌兵權。） 〉 契丹主素聞其桀黠，署為羽林軍使，累遷羽林都指揮使，常令將兵在邊，貝、冀之民，日罹其患。",
    "entities": [
      {
        "text": "《宋史·荊罕儒傳》",
        "label": "TITLE",
        "start": 3,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000160",
    "sentence": "晉末，契丹入洛，鳳從至東京，授宿州防禦使。",
    "entities": [
      {
        "text": "晉",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "授宿州",
        "label": "LOC",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000161",
    "sentence": "漢祖即位，受代歸闕，尋授河陽行軍司馬。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000162",
    "sentence": "乾祐初，入為龍武將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000163",
    "sentence": "丁父憂，起復授右千牛衛大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000164",
    "sentence": "漢末，都城變起，兵集之夜，無不剽之室，唯鳳里閭，兵不敢犯，人皆服其膽勇。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "都城",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000165",
    "sentence": "廣順初，用為宋、亳、宿三州巡檢使。",
    "entities": [
      {
        "text": "宿三州",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000166",
    "sentence": "鳳出於伏莽，尤知盜之隱伏，乃誘致盜魁於麾下，厚待之，每桴鼓之發，無不擒捕，眾以為能，然平民因捕盜而破家者多矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000167",
    "sentence": "鳳善事人，或使臣經由，靡不傾財厚奉，故得延譽而掩其醜跡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000168",
    "sentence": "太祖聞其幹事，用為單州刺史，既剛忿不仁，得位逾熾，刑獄之間，尤為不道。",
    "entities": [
      {
        "text": "用為單州",
        "label": "LOC",
        "start": 7,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000169",
    "sentence": "嘗抑奪人之妻女，又以進奉南郊為名，率斂部民財貨，為人所訟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000170",
    "sentence": "廣順三年十二月，詔削奪鳳在身官爵，尋令賜死。",
    "entities": [
      {
        "text": "廣順三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000171",
    "sentence": "齊藏珍",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000172",
    "sentence": "齊藏珍，少歷內職，累遷諸衛將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000173",
    "sentence": "前後監押兵師在外，頗稱幹事，然險诐無行，殘忍辯給，無不畏其利口。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000174",
    "sentence": "廣順中，奉命滑州界巡護河堤，以弛慢致河決，除名，配沙門島。",
    "entities": [
      {
        "text": "奉命滑州",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000175",
    "sentence": "世宗在西班時，與藏珍同列，每聆其談論，或剖判世務，似有可采。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000176",
    "sentence": "及即位，自流所征還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000177",
    "sentence": "秦、鳳之役，令監偏師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000178",
    "sentence": "及淮上用兵，復委監護，與軍校何超領兵降下光州。",
    "entities": [
      {
        "text": "超領兵降下光州",
        "label": "LOC",
        "start": 15,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000179",
    "sentence": "藏珍欺隱官物甚多，超以為不可，藏珍曰：「沙門島已有屋數間，不妨再去矣。」其不畏法也如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000180",
    "sentence": "世宗既破紫金山寨，追吳寇室渦口，因與藏珍言及克捷之狀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000181",
    "sentence": "對曰：「陛下神武之功，近代無比，於文德則未光。」世宗頷之，又問以揚州之事，對曰：「揚州地實卑濕，食物例多腥腐。臣去歲在彼，人以鱔魚饋臣者，視其盤中虬屈，一如蛇虺之狀，假使鸛雀有知，亦應不食，豈況於人哉！」其敷奏大率多此類，聞者無不悚然。",
    "entities": [
      {
        "text": "又問以揚州",
        "label": "LOC",
        "start": 29,
        "end": 34
      },
      {
        "text": "揚州",
        "label": "LOC",
        "start": 41,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000182",
    "sentence": "一日，又奏云：「唐景思已為刺史，臣猶未蒙聖澤。」世宗俯而從之，時濠梁未下，即命為濠州行州刺史。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "即命為濠州行州",
        "label": "LOC",
        "start": 37,
        "end": 44
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 44,
        "end": 46
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000183",
    "sentence": "及張永德與李重進有間言，藏珍嘗遊說重進，洎壽陽兵回，諸將中有以藏珍之言上奏者。",
    "entities": [
      {
        "text": "李重進",
        "label": "PER",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000184",
    "sentence": "世宗怒，急召赴闕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000185",
    "sentence": "四年夏，以其冒稱檢校官罪，按其事而斃之，蓋不欲暴其惡跡也。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000186",
    "sentence": "王環",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000187",
    "sentence": "王環，本真定人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000188",
    "sentence": "唐天成初，孟知祥鎮西川，環往事之，及知祥建號，環累典軍衛，孟昶嗣位，環兼領左、右衛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000189",
    "sentence": "顯德二年秋，王師西伐，時環為鳳州節度使。",
    "entities": [
      {
        "text": "顯德二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "時環為鳳州",
        "label": "LOC",
        "start": 11,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000190",
    "sentence": "初，偏師傅其城下，為環所敗，裨將胡立為環所擒。",
    "entities": [
      {
        "text": "偏師傅其城",
        "label": "LOC",
        "start": 2,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000191",
    "sentence": "是冬，王師大集，急攻其城，蜀之援兵相次敗走。",
    "entities": [
      {
        "text": "急攻其城",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000192",
    "sentence": "環聞之，守備愈堅，王師攻擊數月方克。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000193",
    "sentence": "城陷，環就擒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000194",
    "sentence": "及到闕，世宗以忠於所事，釋其罪，授若驍衛大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 20,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000195",
    "sentence": "四年冬，世宗南征，環隨駕至泗州，遇疾而卒。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "環隨駕至泗州",
        "label": "LOC",
        "start": 9,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000196",
    "sentence": "張彥超",
    "entities": [
      {
        "text": "張彥超",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000197",
    "sentence": "張彥超，本沙陀部人也。",
    "entities": [
      {
        "text": "張彥超",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000198",
    "sentence": "素有郤克之疾，時號為「跛子」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000199",
    "sentence": "初，以騎射事唐莊宗為馬直軍使，莊宗入汴，授神武指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000200",
    "sentence": "明宗嘗以為養子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000201",
    "sentence": "天成中，擢授蔚州刺史。",
    "entities": [
      {
        "text": "擢授蔚州",
        "label": "LOC",
        "start": 4,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000202",
    "sentence": "素與晉高祖不協，屬其總戎於太原，遂舉其城投於契丹，即以為雲州節度使。",
    "entities": [
      {
        "text": "遂舉其城",
        "label": "LOC",
        "start": 16,
        "end": 20
      },
      {
        "text": "即以為雲州",
        "label": "LOC",
        "start": 25,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000203",
    "sentence": "契丹之南侵也，彥超率部眾，頗為鎮、魏之患。",
    "entities": [
      {
        "text": "頗為鎮",
        "label": "LOC",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000204",
    "sentence": "及契丹入汴，遷侍衛馬軍都校，尋授晉昌軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000205",
    "sentence": "漢高祖入洛，彥超飛表輸誠，移授保大軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000206",
    "sentence": "乾祐初，奉詔歸闕，止奉朝請而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000207",
    "sentence": "太祖自鄴入平內難，隱帝令彥超董騎軍為拒，劉子陂兵亂，彥超先謁見太祖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000208",
    "sentence": "廣順中，授神武統軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000209",
    "sentence": "顯德三年冬，以疾終於第。",
    "entities": [
      {
        "text": "顯德三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000210",
    "sentence": "制贈太子太師。",
    "entities": [
      {
