      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000076",
    "sentence": "李彥頵，字德循，太原人也。",
    "entities": [
      {
        "text": "李彥頵",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000077",
    "sentence": "本以商賈為業，太祖鎮鄴，置之左右，及即位，歷綾錦副使、搉易使。",
    "entities": [
      {
        "text": "太祖鎮",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000078",
    "sentence": "世宗嗣位，以彥頵有舊，超授內客省使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000079",
    "sentence": "未幾，知相州軍府事，尋改延州兵馬留後。",
    "entities": [
      {
        "text": "知相州",
        "label": "LOC",
        "start": 3,
        "end": 6
      },
      {
        "text": "尋改延州",
        "label": "LOC",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000080",
    "sentence": "到鎮，頗以殖貨為意，窺圖剩利，侵漁蕃漢部人，群情大擾。",
    "entities": [
      {
        "text": "到鎮",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000081",
    "sentence": "會世宗南征，蕃部結聚，圍迫州城，彥頵閉壁自守，求援於鄰道，賴救兵至，乃解。",
    "entities": [
      {
        "text": "圍迫州城",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000082",
    "sentence": "世宗不悅，征赴京師，然猶委曲庇護，竟不之責。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000083",
    "sentence": "尋為西京水南巡檢使，居無何，命權知泗州軍州事，改滄州兩使留後。",
    "entities": [
      {
        "text": "命權知泗州軍州",
        "label": "LOC",
        "start": 14,
        "end": 21
      },
      {
        "text": "改滄州",
        "label": "LOC",
        "start": 23,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000084",
    "sentence": "彥頵到任，處置乖方，大為物情所鄙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000085",
    "sentence": "顯德六年秋，受代歸闕，遇疾而卒，時年五十有二。",
    "entities": [
      {
        "text": "顯德六年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000086",
    "sentence": "李暉",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000087",
    "sentence": "李暉，字順光，瀛州束城人。",
    "entities": [
      {
        "text": "瀛州束城",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000088",
    "sentence": "弱冠應募於龍驤軍，漢祖領河東，暉請從，因得署為河東牙將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000089",
    "sentence": "漢有天下，授檢校司徒、大內皇城使。",
    "entities": [
      {
        "text": "大內皇城",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000090",
    "sentence": "未幾，遷宣徽南院使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000091",
    "sentence": "乾祐初，拜河陽節度使、檢校太傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000092",
    "sentence": "太祖登極，加同平章事，尋移鎮滄州。",
    "entities": [
      {
        "text": "尋移鎮滄州",
        "label": "LOC",
        "start": 11,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000093",
    "sentence": "顯德元年，就加兼侍中。",
    "entities": [
      {
        "text": "顯德元年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000094",
    "sentence": "二年秋，以世宗誕慶節來朝，改邠州節度使。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "改邠州",
        "label": "LOC",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000095",
    "sentence": "五年，移鎮鳳翔。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "移鎮",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000096",
    "sentence": "歲餘，卒於鎮。",
    "entities": [
      {
        "text": "卒於鎮",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000097",
    "sentence": "優詔贈中書令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000098",
    "sentence": "暉之儀貌不及於常人，而位極將相，年登耳順，袁、許之術，夫何恃哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000099",
    "sentence": "然性貪鄙，而好小惠以邀虛譽，故在河陽及滄州日，民皆詣闕請立碑以頌其美，識者亦未之許也。",
    "entities": [
      {
        "text": "故在河陽及滄州",
        "label": "LOC",
        "start": 14,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000100",
    "sentence": "李建崇",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000101",
    "sentence": "李建崇，潞州人。",
    "entities": [
      {
        "text": "潞州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000102",
    "sentence": "少從軍，善騎射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000103",
    "sentence": "初事唐武皇，為鐵林都將，轉突騎、飛騎二軍使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000104",
    "sentence": "從莊宗攻常山，阿保機來援，莊宗率親軍千騎，遇於滿城，兵少，為契丹所圍。",
    "entities": [
      {
        "text": "遇於滿城",
        "label": "LOC",
        "start": 21,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000105",
    "sentence": "時建崇為親將，與契丹格鬥，自午至申，會李嗣昭騎至，契丹乃解去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000106",
    "sentence": "同光中，自龍武捧聖都指揮使，出歷襄、秦、徐、雍都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000107",
    "sentence": "建崇性純厚，處身任遇，不能巧宦，以致久滯偏裨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000108",
    "sentence": "明宗嘗掌牙兵，與建崇共事，及即位，甚湣之，連授磁、沁二郡。",
    "entities": [
      {
        "text": "沁二郡",
        "label": "LOC",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000109",
    "sentence": "入晉為申州刺史。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000110",
    "sentence": "天福七年冬，襄州安從進構逆，率眾寇南陽，時建崇領步騎千餘屯於葉縣，開封尹鄭王遣宣徽使張從恩、皇城使焦繼勛率在京諸軍，會建崇軍拒賊，至湖陽縣之花山，遇從進軍，建崇接戰，大敗之，以功授亳州團練使。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "襄州",
