        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000222",
    "sentence": "洎李景僭襲偽位，俾掌親軍，遷鄂州節度使。",
    "entities": [
      {
        "text": "遷鄂州",
        "label": "LOC",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000223",
    "sentence": "居數年，復以兵柄任之，改壽州節度使。",
    "entities": [
      {
        "text": "改壽州",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000224",
    "sentence": "及王師渡淮，而仁贍固守甚堅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000225",
    "sentence": "洎世宗駐蹕於其壘北，數道齊攻，填塹陷壁，晝夜不息，如是者累月。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000226",
    "sentence": "世宗臨城以諭之，而仁贍但遜詞以謝。",
    "entities": [
      {
        "text": "世宗臨城",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000227",
    "sentence": "及車駕還京，命李重進總兵守之，復乘間陷我南寨。",
    "entities": [
      {
        "text": "李重進",
        "label": "PER",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000228",
    "sentence": "自是圍之愈急，城中饑死者甚眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000229",
    "sentence": "三年冬，淮寇復來救援，列寨於紫金山，夾道相屬，累然數十里，垂及壽壁，而重進兵幾不能支，世宗患之，遂復議親征。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000230",
    "sentence": "車駕至壽春，命今上率師破紫金山之眾，擒其應援使陳承昭以獻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000231",
    "sentence": "仁贍聞援兵既敗，計無所出，但扼腕浩嘆而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000232",
    "sentence": "會世宗以紫金山之捷，飛詔以諭之，時仁贍臥疾已亟，因翻然納款，而城內諸軍萬計，皆屏息以聽其命。",
    "entities": [
      {
        "text": "而城",
        "label": "LOC",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000233",
    "sentence": "及見於行在，世宗撫之甚厚，賜與加等，復令入城養病，尋授天平軍節度使、兼中書令。",
    "entities": [
      {
        "text": "復令入城",
        "label": "LOC",
        "start": 18,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000234",
    "sentence": "制出之日，薨於其家，年五十八。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000235",
    "sentence": "世宗聞之，遣使吊祭，命內臣監護喪事，追封彭城郡王。",
    "entities": [
      {
        "text": "追封彭城郡",
        "label": "LOC",
        "start": 18,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000236",
    "sentence": "後以其子崇讃為懷州刺史。",
    "entities": [
      {
        "text": "其子崇讃為懷州",
        "label": "LOC",
        "start": 2,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000237",
    "sentence": "仁贍輕財重士，法令嚴肅，重圍之中，其子崇諫犯軍禁，即令斬之，故能以一城之眾，連年拒守。",
    "entities": [
      {
        "text": "故能以一城",
        "label": "LOC",
        "start": 30,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000238",
    "sentence": "逮其來降，而其下未敢竊議者，保其後嗣，抑有由焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_129_000239",
    "sentence": "崇贊仕周，累為郡守。",
    "entities": [
      {
        "text": "累為郡",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_129_000240",
    "sentence": "幼子崇諒，後自江南歸於本朝，亦位至省郎。",
    "entities": []
  },
