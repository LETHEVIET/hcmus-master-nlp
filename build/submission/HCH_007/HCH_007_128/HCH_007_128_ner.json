      }
    ]
  },
  {
    "sentence_id": "HCH_007_128_000143",
    "sentence": "羽之使閩也，正使陸崇卒於道，羽載其喪還，歸其橐裝，時人義之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000144",
    "sentence": "段希堯",
    "entities": []
  },
