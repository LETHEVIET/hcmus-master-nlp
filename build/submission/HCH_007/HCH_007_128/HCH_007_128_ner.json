[
  {
    "sentence_id": "HCH_007_128_000001",
    "sentence": "王朴",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000002",
    "sentence": "王朴，字文伯，東平人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000003",
    "sentence": "父序，以朴貴，贈左諫議大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_128_000004",
    "sentence": "朴幼警慧，好學善屬文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000005",
    "sentence": "漢乾祐中，擢進士第，解褐授校書郎，依樞密使楊邠，館於邠第。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000006",
    "sentence": "是時漢室浸亂，大臣交惡，朴度其必危，因乞告東歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000007",
    "sentence": "未幾，李業輩作亂，害邠等三族，凡遊其門下者，多被其禍，而朴獨免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000008",
    "sentence": "國初，世宗鎮澶淵，朝廷以朴為記室。",
    "entities": [
      {
        "text": "世宗鎮",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_128_000009",
    "sentence": "及世宗為開封尹，拜右拾遺，充開封府推官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000010",
    "sentence": "世宗嗣位，授比部郎中，賜紫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000011",
    "sentence": "二年夏，世宗命朝廷文學之士二十餘人，各撰策論一首，以試其才。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_128_000012",
    "sentence": "時朴獻《平邊策》，云：",
    "entities": [
      {
        "text": "《平邊策》",
        "label": "TITLE",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_128_000013",
    "sentence": "唐失道而失吳、蜀，晉失道而失幽、并，觀所以失之由，知所以平之術。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000014",
    "sentence": "當失之時，莫不君暗政亂，兵驕民困，近者奸於內，遠者叛於外，小不制而至於大，大不制而至於僭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000015",
    "sentence": "天下離心，人不用命，吳、蜀乘其亂而竊其號，幽、并乘其間而據其地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000016",
    "sentence": "平之之術，在乎反唐、晉之失而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000017",
    "sentence": "必先進賢退不肖以清其時，用能去不能以審其材，恩信號令以結其心，賞功罰罪以盡其力，恭儉節用以豐其財，徭役以時以阜其民。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000018",
    "sentence": "俟其倉廩實、器用備、人可用而舉之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000019",
    "sentence": "彼方之民，知我政化大行、上下同心、力強財足、人和將和、有必取之勢，則知彼情狀者願為之間諜，知彼山川者願為之先導。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000020",
    "sentence": "彼民與此民之心同，是與天意同，與天意同則無不成之功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000021",
    "sentence": "攻取之道，從易者始，當今吳國，東至海，南至江，可撓之地二千里。",
    "entities": [
      {
        "text": "吳國",
        "label": "ORG",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_128_000022",
    "sentence": "從少備處先撓之，備東則撓西，備西則撓東，必奔走以救其弊，奔走之間，可以知彼之虛實、眾之強弱，攻虛擊弱，則所向無前矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000023",
    "sentence": "勿大舉但以輕兵撓之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000024",
    "sentence": "彼人怯，知我師入其地，必大發以來應，數大發則必民困而國竭，一不大發則我獲其利，彼竭我利，則江北諸州，乃國家之所有也。",
    "entities": [
      {
        "text": "則江北諸州",
        "label": "LOC",
        "start": 44,
        "end": 49
      }
    ]
  },
  {
    "sentence_id": "HCH_007_128_000025",
    "sentence": "既得江北，則用彼之民，揚我之兵，江之南亦不難而平之也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000026",
    "sentence": "如此，則用力少而收功多。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000027",
    "sentence": "得吳，則桂、廣皆為內臣，岷、蜀可飛書而召之，如不至，則四面並進，席卷而蜀平矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000028",
    "sentence": "吳、蜀平，幽可望風而至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000029",
    "sentence": "惟並必死之寇，不可以恩信誘，必須以強兵攻之，但亦不足以為邊患，可為後圖，候其便則一削以平之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000030",
    "sentence": "方今兵力精練，器用具備，群下知法，諸將用命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000031",
    "sentence": "一稔之後，可以平邊，此歲夏秋，便可於沿邊貯納。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000032",
    "sentence": "臣書生也，不足以講大事，至於不達大體，不合機變，望陛下寬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000033",
    "sentence": "世宗覽之，愈重其器識。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000034",
    "sentence": "未幾，遷左諫議大夫，知開封府事。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_128_000035",
    "sentence": "初，世宗以英武自任，喜言天下事，常憤廣明之後，中土日蹙，值累朝多事，尚未克復，慨然有包舉天下之志。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000036",
    "sentence": "而居常計事者多不喻其旨，唯朴神氣勁峻，性剛決有斷，凡所謀畫，動愜世宗之意，由是急於登用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000037",
    "sentence": "尋拜左散騎常侍，充端明殿學士，知府如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000038",
    "sentence": "是時，初廣京城，朴奉命經度，凡通衢委巷，廣袤之間，靡不由其心匠。",
    "entities": [
      {
        "text": "初廣京城",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_128_000039",
    "sentence": "及世宗南征，以朴為東京副留守，車駕還京，改戶部侍郎兼樞密副使。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_128_000040",
    "sentence": "未幾，遷樞密使、檢校太保。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000041",
    "sentence": "頃之，丁內艱，尋起復授本官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_128_000042",
    "sentence": "四年冬，世宗再幸淮甸，兼東京留守，京邑庶務，悉以便宜制之，比及入蹕，都下肅如也。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "京邑",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
