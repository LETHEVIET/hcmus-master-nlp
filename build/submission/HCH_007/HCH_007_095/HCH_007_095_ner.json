[
  {
    "sentence_id": "HCH_007_095_000001",
    "sentence": "皇甫遇，常山人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000002",
    "sentence": "父武，流寓太原，嘗為遮塞軍使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000003",
    "sentence": "遇少好勇，及壯，虬髯，善騎射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000004",
    "sentence": "唐明宗在藩時，隸於麾下，累從戰有功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000005",
    "sentence": "明宗即位，遷龍武都指揮使，遙領嚴州刺史，出討東川，為行營左軍都指揮使。",
    "entities": [
      {
        "text": "遙領嚴州",
        "label": "LOC",
        "start": 13,
        "end": 17
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000006",
    "sentence": "應順、清泰中，累歷團練防禦使，尋遷鄧州節度使。",
    "entities": [
      {
        "text": "尋遷鄧州",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000007",
    "sentence": "所至苛暴，以誅斂為務，其幕客多私去，以避其累。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000008",
    "sentence": "高祖入洛，移領中山，俄聞與鎮州安重榮為婚家，乃移鎮上黨，又改平陽，咸以憸人執事，政事隳紊。",
    "entities": [
      {
        "text": "俄聞與鎮州",
        "label": "LOC",
        "start": 10,
        "end": 15
      },
      {
        "text": "乃移鎮",
        "label": "LOC",
        "start": 22,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000009",
    "sentence": "及鎮河陽，部內創別業，開畎水泉，以通溉灌，所經墳墓悉毀之，部民以朝廷方姑息郡帥，莫之敢訴。",
    "entities": [
      {
        "text": "及鎮",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "以朝廷方姑息郡",
        "label": "LOC",
        "start": 31,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000010",
    "sentence": "少帝即位，罷歸闕下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000011",
    "sentence": "二年，契丹南寇，從至澶州，戰於鄆州北津，契丹眾大敗，溺死者數千人，以功拜滑州節度使。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "從至澶州",
        "label": "LOC",
        "start": 8,
        "end": 12
      },
      {
        "text": "戰於鄆州",
        "label": "LOC",
        "start": 13,
        "end": 17
      },
      {
        "text": "以功拜滑州",
        "label": "LOC",
        "start": 33,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000012",
    "sentence": "三年，契丹率眾屯邯鄲，遇與安審琦、慕容彥超等禦之。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000013",
    "sentence": "遇將渡漳河，契丹前鋒大至，遇引退，轉鬥二十里至鄴南榆林店。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000014",
    "sentence": "遇謂審琦等曰：「彼眾我寡，走無生路，不如血戰。」遂自辰及未，戰百餘合，所傷甚眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000015",
    "sentence": "遇所乘馬中鏑而斃，遇有紀綱杜知敏以馬授遇，遇得馬復戰，久之稍解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000016",
    "sentence": "杜知敏已為所獲，遇謂彥超曰：「知敏蒼黃之中，以馬授我，義也，安可使陷於賊中！」遂與彥超躍馬取知敏而還，敵騎壯之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000017",
    "sentence": "俄而生軍復合，遇不能解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000018",
    "sentence": "時審琦已至安陽河，謂首將張從恩曰：「皇甫遇等未至，必為敵騎所圍，若不急救，則成擒矣。」從恩曰：「敵甚盛，無以枝梧，將軍獨往何益？」審琦曰：「成敗命也。設若不濟，則與之俱死。假令失此二將，將何面目以見天子！」遂率鐵騎北渡赴之。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 57,
        "end": 59
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000019",
    "sentence": "契丹見塵起，謂救軍並至，乃引去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000020",
    "sentence": "遇與彥超中數創得還，時諸軍嘆曰：「此三人皆猛將也！」遇累官至檢校太師、同中書門下平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000021",
    "sentence": "四年，契丹復至，從杜重威營滹水，重威送款於契丹，遇不預其議，及降，心不平之。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000022",
    "sentence": "時契丹欲遣遇先入汴，遇辭之，因私謂人曰：「我身荷國恩，位兼將相，既不能死於軍陣，何顏以見舊主！更受命圖之，所不忍也。」明日，行至趙郡，泊其縣舍，顧從者曰：「我已信宿不食，疾甚矣，主辱臣死，無復南行。」因絕吭而殞，遠近聞而義之。",
    "entities": [
      {
        "text": "行至趙郡",
        "label": "LOC",
        "start": 62,
        "end": 66
      },
      {
        "text": "泊其縣",
        "label": "LOC",
        "start": 67,
        "end": 70
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000023",
    "sentence": "漢高祖登極，詔贈中書令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000024",
    "sentence": "周廣順三年正月，遇妻宋國夫人霍氏上言，請度為尼，周太祖許之，仍賜紫衣，號貞範大師，法名惠圓，又賜夏臘十。",
    "entities": [
      {
        "text": "廣順三年",
        "label": "TME",
        "start": 1,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000025",
    "sentence": "王清，字去瑕，洺州曲周人也。",
    "entities": [
      {
        "text": "洺州",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000026",
    "sentence": "父度，世為農。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000027",
    "sentence": "清少以勇力端厚稱於鄉里。",
    "entities": [
      {
        "text": "勇力端厚稱於鄉",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000028",
    "sentence": "後唐明宗領行臺，置步直軍，清預其募，漸升為小校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000029",
    "sentence": "同光初，從戰於河上有功，賜忠烈功臣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000030",
    "sentence": "明宗即位，自天成至清泰末，歷嚴衛、寧衛指揮使，加檢校右散騎常侍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000031",
    "sentence": "天福元年，高祖建義入洛，加檢校刑部尚書，改賜扈蹕忠孝功臣。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000032",
    "sentence": "三年，從楊光遠平範延光於鄴，改奉國軍都虞候。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000033",
    "sentence": "六年，襄州安從進叛，從高行周討之，逾年不下。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "襄州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000034",
    "sentence": "一日，清請先登，諸軍繼其後，會有內應者，遂拔其城。",
    "entities": [
      {
        "text": "遂拔其城",
        "label": "LOC",
        "start": 20,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000035",
    "sentence": "清以中重創，有詔褒慰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000036",
    "sentence": "七年，改賜推忠保運功臣，加金紫光祿大夫，領溪州刺史。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 17,
        "end": 19
      },
      {
        "text": "領溪州",
        "label": "LOC",
        "start": 20,
        "end": 23
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000037",
    "sentence": "八年，詔遣以所部兵屯於鄴。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000038",
    "sentence": "九年春，契丹南牧，圍其城，清與張從恩守之，少帝飛蠟詔勉諭，錫之第宅。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "圍其城",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000039",
    "sentence": "契丹退，以幹城功，繼遷軍額。",
    "entities": [
      {
        "text": "以幹城",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000040",
    "sentence": "開運二年春三月，從杜重威北征，解陽城之圍，加檢校司徒。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "解陽城",
        "label": "LOC",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000041",
    "sentence": "是歲秋七月，詔遣與皇甫遇援糧入易州。",
    "entities": [
      {
        "text": "甫遇援糧入易州",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000042",
    "sentence": "十一月，從杜重威收瀛州，聞契丹大至，重威率諸軍沿滹水而西，將保常山，及至中渡橋，契丹已屯於北岸。",
    "entities": [
      {
        "text": "從杜重威收瀛州",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000043",
    "sentence": "自其月二十七日至十二月五日，軍不能解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000044",
    "sentence": "時契丹至，留騎之精者以禦我，分其弱者，自故靈都城緣其山足，涉滹沱之淺處，引眾而南，至趙郡，凡百餘里，斷我飛免，且扼歸路。",
    "entities": [
      {
        "text": "自故靈都城",
        "label": "LOC",
        "start": 19,
        "end": 24
      },
      {
        "text": "至趙郡",
        "label": "LOC",
        "start": 41,
        "end": 44
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000045",
    "sentence": "清知勢蹙，謂重威曰：「軍去常山五里，守株於此，營孤食盡，將若之何！請以步兵二千為前鋒，奪橋開路，公可率諸軍繼之，期入常山，必濟矣。」重威可之，遣宋彥筠俱行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000046",
    "sentence": "清一擊獲其橋，契丹為之小卻，重威猶豫不進，密已貳於國矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000047",
    "sentence": "彥筠退走，清列陣北岸，嚴戒部曲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000048",
    "sentence": "日暮，酣戰不息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000049",
    "sentence": "契丹以生軍繼至，我軍無寸刃以益之，清與其下歿焉，時年五十三。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000050",
    "sentence": "〈 （《通鑒》：清謂其眾曰：「上將握兵，坐觀吾輩困急而不救，此必有異志。吾輩當以死報國耳！」眾感其言，莫有退者，至幕，戰不息。契丹以新兵繼之，清及眾士盡死，由是諸軍皆奪氣。） 〉 契丹尋於所戰之地，築一京觀。",
    "entities": [
      {
        "text": "《通鑒》",
        "label": "TITLE",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000051",
    "sentence": "及漢高祖即位，使人平之，贈清太傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000052",
    "sentence": "是歲，清子守鈞於本邑義化別業，招魂以葬之也。",
    "entities": [
      {
        "text": "清子守鈞於本邑",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000053",
    "sentence": "梁漢璋，字國寶，應州人也。",
    "entities": [
      {
        "text": "應州",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000054",
    "sentence": "少以勇力事唐明宗，歷突騎、奉德指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000055",
    "sentence": "高祖即位之二年，遙領欽州刺史。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 5,
        "end": 7
      },
      {
        "text": "遙領欽州",
