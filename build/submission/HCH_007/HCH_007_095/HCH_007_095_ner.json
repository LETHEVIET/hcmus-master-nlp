      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000162",
    "sentence": "初事後唐明宗，漸升為軍校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000163",
    "sentence": "天福中，為奉國指揮使，歷數郡刺史。",
