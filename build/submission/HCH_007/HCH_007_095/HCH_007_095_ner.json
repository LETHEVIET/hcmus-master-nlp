        "start": 54,
        "end": 56
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000160",
    "sentence": "福赟終不自明，以至見殺，人甚冤之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000161",
    "sentence": "郭璘，邢州人也。",
