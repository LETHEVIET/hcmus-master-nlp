      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000164",
    "sentence": "開運中，移領易州，契丹攻其郡，璘率厲士眾，同其甘苦，敵不能克。",
    "entities": [
      {
        "text": "移領易州",
        "label": "LOC",
        "start": 4,
        "end": 8
      },
      {
        "text": "契丹攻其郡",
