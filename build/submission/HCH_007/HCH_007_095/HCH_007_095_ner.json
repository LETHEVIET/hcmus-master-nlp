      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000127",
    "sentence": "契丹大怒，攻之，半歲不能下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000128",
    "sentence": "高祖致書於契丹，乃解圍而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_095_000129",
    "sentence": "召巒歸闕，授徐州節度使，再遷右諫議大夫，為復州防禦使，數年罷歸。",
    "entities": [
