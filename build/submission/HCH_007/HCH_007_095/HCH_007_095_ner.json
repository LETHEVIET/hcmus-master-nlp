      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000056",
    "sentence": "三年，加檢校司空，改護聖都指揮使。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000057",
