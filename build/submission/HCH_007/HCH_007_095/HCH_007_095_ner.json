        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_095_000150",
    "sentence": "高祖建義，割新州屬契丹。",
    "entities": [
      {
        "text": "割新州",
        "label": "LOC",
