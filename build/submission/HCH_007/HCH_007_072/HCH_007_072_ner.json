  },
  {
    "sentence_id": "HCH_007_072_000071",
    "sentence": "馬紹宏",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000072",
    "sentence": "馬紹宏，閹官也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000073",
    "sentence": "初與孟知祥同為中門使，及周德威薨，莊宗兼領幽州，令紹宏權知州事。",
    "entities": [
      {
        "text": "莊宗兼領幽州",
        "label": "LOC",
        "start": 17,
