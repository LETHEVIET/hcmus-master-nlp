[
  {
    "sentence_id": "HCH_007_072_000001",
    "sentence": "張承業",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000002",
    "sentence": "張承業，字繼元，本姓康，同州人。",
    "entities": [
      {
        "text": "同州",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_072_000003",
    "sentence": "咸通中，內常侍張泰畜為假子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000004",
    "sentence": "光啟中，主郃陽軍事，賜紫，入為內供奉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000005",
    "sentence": "武皇之討王行瑜，承業累奉使渭北，因留監武皇軍事，賊平，改酒坊使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000006",
    "sentence": "三年，昭宗將幸太原，以承業與武皇善，用除為河東監軍，密令迎駕。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_072_000007",
    "sentence": "既而昭宗幸華州，就加左監門衛將軍。",
    "entities": [
      {
        "text": "既而昭宗幸華州",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_072_000008",
    "sentence": "駕在鳳翔，承業屢請出師晉、絳，以為岐人掎角。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000009",
    "sentence": "崔魏公之誅宦官也，武皇偽戮罪人首級以奉詔，匿承業於斛律寺，昭宗遇弑，乃復請為監軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000010",
    "sentence": "夾城之役，遣承業求援於鳳翔。",
    "entities": [
      {
        "text": "夾城",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_072_000011",
    "sentence": "時河中阻絕，自離石渡河，春冰方泮，淩澌奔蹙，艤舟不得渡，因禱河神。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000012",
    "sentence": "是夜，夢神人謂曰：「子但渡，流冰無患。」既寤，津吏報曰：「河冰合矣。」淩晨，躡冰而濟，旋踵冰解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000013",
    "sentence": "使還，武皇病篤，啟手之夕，召承業屬之曰：「吾兒孤弱，群臣縱橫，後事公善籌之。」承業奉遺顧，爰立嗣王，平內難，策略居多。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000014",
    "sentence": "既終易月之制，即請出師救潞，破賊夾城。",
    "entities": [
      {
        "text": "破賊夾城",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_072_000015",
    "sentence": "莊宗深感其意，兄事之，親幸承業私第，升堂拜母，賜遺優厚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000016",
    "sentence": "時莊宗初行墨製，凡除拜之命，皆成於盧汝弼之手。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000017",
    "sentence": "汝弼既自為戶部侍郎，乃請與承業改官及開國邑，承業拒而不受。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "業改官及開國邑",
        "label": "LOC",
        "start": 14,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_072_000018",
    "sentence": "其後，但稱本朝舊官而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000019",
    "sentence": "天祐中，幽州劉守光敗，其府掾馮道歸太原，承業辟為本院巡官。",
    "entities": [
      {
        "text": "幽州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_072_000020",
    "sentence": "承業重其文章履行，甚見待遇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000021",
    "sentence": "時有周元豹者，善人倫鑒，與道不合，謂承業曰：「馮生無前程，公不可過用。」管書記盧質聞之曰：「我曾見杜黃裳司空寫真圖，道之狀貌酷類焉，將來必副大用，元豹之言，不足信也。」承業薦為霸府從事焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000022",
    "sentence": "柏鄉之役，王師既逼汴營，周德威慮其奔衝，堅請退舍。",
    "entities": [
      {
        "text": "柏鄉",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_072_000023",
    "sentence": "莊宗怒其懦，不聽，垂帳而寢，諸將不敢言事，咸詣監軍請白。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000024",
    "sentence": "承業遽至牙門，褰帳而入，撫莊宗曰：「此非王安寢時，周德威老將，洞識兵勢，姑務萬全，言不可忽。」 莊宗蹶然而興曰：「予方思之。」其夕，收軍保鄗邑。",
    "entities": [
      {
        "text": "收軍保鄗邑",
        "label": "LOC",
        "start": 66,
        "end": 71
      }
    ]
  },
  {
    "sentence_id": "HCH_007_072_000025",
    "sentence": "德威討劉守光，令承業往視賊勢，因請莊宗自行，果成大捷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000026",
    "sentence": "承業感武皇厚遇，自莊宗在魏州垂十年，太原軍國政事，一委承業；而積聚庾帑，收兵市馬，招懷流散，勸課農桑，成是霸基者，承業之忠力也。",
    "entities": [
      {
        "text": "自莊宗在魏州",
        "label": "LOC",
        "start": 8,
        "end": 14
      },
      {
        "text": "十年",
        "label": "TME",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_072_000027",
    "sentence": "時貞簡太后，韓德妃、伊淑妃、諸宅王之貴，洎王之介弟在晉陽宮，或不以其道幹於承業，悉不聽，逾法禁者必懲，由是貴戚斂手，民俗丕變。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000028",
    "sentence": "或有中傷承業於莊宗者，言專弄威柄，廣納賂遺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000029",
    "sentence": "莊宗歲時還晉陽宮省太后，須錢蒱博、給伶官，嘗置酒於泉府，莊宗酣飲，命興聖宮使李繼岌為承業起舞，既竟，承業出寶帶幣馬奉之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000030",
    "sentence": "莊宗指錢積謂承業曰：「和哥無錢使，七哥與此一積，寶馬非殊惠也。」承業謝曰：「郎君哥勞，承業自出己俸錢。此錢是大王庫物，準擬支贍三軍，不敢以公物為私禮也。」莊宗不悅，使酒侵承業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000031",
    "sentence": "承業曰：「臣老敕使。非為子孫之謀，惜錢為大王基業，王若自要散施，何妨老夫，不過財盡兵散，一事無成。」 〈 （案：《 通鑒 》作王自取用之，何問仆為！） 〉 莊宗怒，顧元行欽曰：「取劍來！」承業引莊宗衣，泣而言曰：「仆荷先王遺顧，誓為本朝誅汴賊，為王惜庫物，斬承業首，死亦無愧於先王，今日請死！」閻寶解承業手，令退。",
    "entities": [
      {
        "text": "《 通鑒 》",
        "label": "TITLE",
        "start": 56,
        "end": 62
      }
    ]
  },
  {
    "sentence_id": "HCH_007_072_000032",
    "sentence": "承業詬寶曰：「黨朱溫逆賊，未嘗有一言效忠，而敢依阿諂附。」揮拳踣之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000033",
    "sentence": "太后聞莊宗酒失，急召入。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000034",
    "sentence": "莊宗性至孝，聞太后召，叩頭謝阿業曰：「吾杯酒之間，忤於七哥，太后必怪吾。七哥為痛飲兩卮分謗，可乎？」莊宗連飲四鍾，勸承業，竟不飲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000035",
    "sentence": "莊宗歸宮，太后使人謂承業曰：「小兒忤特進，已笞矣，可歸第。」翌日，太后與莊宗俱幸其第，慰勞之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000036",
    "sentence": "自是私謁幾絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000037",
    "sentence": "十四年，承制授開府儀同三司、左衛上將軍、燕國公，固辭不受。",
    "entities": [
