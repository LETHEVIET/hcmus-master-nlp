        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_072_000069",
    "sentence": "居翰性和而靜，諳悉舊事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_072_000070",
    "sentence": "在潞州累年，每春課人育蔬種樹，敦本惠農，有仁者之心焉。",
    "entities": [
      {
        "text": "在潞州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
