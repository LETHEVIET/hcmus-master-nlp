      }
    ]
  },
  {
    "sentence_id": "HCH_007_028_000183",
    "sentence": "秋七月辛未，帝遣李存審領軍與嗣源會於易州，步騎凡七萬。",
    "entities": [
      {
        "text": "與嗣源會於易州",
        "label": "LOC",
        "start": 13,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_028_000184",
    "sentence": "於是三將同謀，銜枚束甲，尋澗穀而行，直抵幽州。",
    "entities": [
      {
        "text": "直抵幽州",
        "label": "LOC",
        "start": 18,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_028_000185",
    "sentence": "八月甲午，自易州北循山而行，李嗣源率三千騎為前鋒。",
    "entities": [
      {
        "text": "自易州",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_028_000186",
    "sentence": "庚子，循大房嶺而東，距幽州六十里。",
    "entities": [
      {
        "text": "距幽州",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_028_000187",
    "sentence": "契丹萬騎遽至，存審、嗣源極力以拒之，契丹大敗，委棄毳幕、氈廬、弓矢、羊馬不可勝紀，進軍追討，俘斬萬計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_028_000188",
    "sentence": "辛丑，大軍入幽州，德威見諸將，握手流涕。",
    "entities": [
      {
        "text": "大軍入幽州",
        "label": "LOC",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_028_000189",
    "sentence": "翌日，獻捷於鄴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_028_000190",
    "sentence": "九月，班師，帝授存審檢校太傅，嗣源檢校太保，閻寶加同平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_028_000191",
    "sentence": "十月，帝自魏州還晉陽。",
    "entities": [
      {
        "text": "帝自魏州",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_028_000192",
    "sentence": "十一月，復至魏州。",
    "entities": [
      {
        "text": "復至魏州",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_028_000193",
    "sentence": "十二月，帝觀兵於河上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_028_000194",
    "sentence": "時梁人據楊劉城，列柵相望，帝率軍履河冰而渡，盡平諸柵，進攻楊劉城。",
    "entities": [
      {
        "text": "時梁人據楊劉城",
        "label": "LOC",
        "start": 0,
