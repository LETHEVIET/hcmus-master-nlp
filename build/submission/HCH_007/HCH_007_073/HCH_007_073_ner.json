  },
  {
    "sentence_id": "HCH_007_073_000003",
    "sentence": "璋性凶悖，有膽略，從征河上，屢有戰功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000004",
    "sentence": "梁平，授滄州節度使。",
    "entities": [
      {
        "text": "授滄州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000005",
    "sentence": "王師討蜀，以璋為行營右廂馬軍都指揮使；蜀平，璋功居多。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000006",
    "sentence": "明年，蕭牆禍起，繼岌自西川至渭南，部下散亡，其川貨妓樂，為璋所掠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000007",
    "sentence": "明宗嗣位，錄平蜀功，授邠州節度使。",
    "entities": [
      {
        "text": "授邠州",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000008",
    "sentence": "璋既家富於財，有蜀之妓樂，驕僭自大，動多不法，招致部下，繕理兵仗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000009",
    "sentence": "朝廷移授昭義節度使，璋謀欲不奉詔，判官邊蔚密言規責，乃僶勉承命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000010",
    "sentence": "洎至潞州，狂妄不悛，每擁川妓於山亭院，服赭黃，縱酒，令為王衍在蜀之戲。",
    "entities": [
      {
        "text": "洎至潞州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000011",
    "sentence": "事聞於朝，征為金吾上將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000012",
    "sentence": "其年秋，東川節度使董璋上言：「毛璋男廷贇齎父書往西川，慮有陰事。」因追廷贇及同行人趙延祚，與璋俱下御史台獄。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 49,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000013",
    "sentence": "廷贇乃璋之假侄，稱有叔在蜀，欲往省之，亦無私書，詔停任，令歸私第。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000014",
    "sentence": "初，延祚在獄，多言璋陰事，璋許重賂，以塞其口。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000015",
    "sentence": "及免，延祚征其賂，璋拒而不與，以至延祚詣台訴璋翻覆，復下御史台訊鞫。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000016",
    "sentence": "中丞呂夢奇以璋前蒙昭雪，今延祚以責賂之故，復加織羅，故稍佑璋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000017",
    "sentence": "及款狀上聞，或云夢奇受璋賂，所以獄不盡情，執之，移於軍巡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000018",
    "sentence": "璋具狀曾許延祚賂未與，又云曾借馬與夢奇，別無行賂之事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000019",
    "sentence": "朝廷懲其宿惡，長流儒州，賜死於路。",
    "entities": [
      {
        "text": "長流儒州",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000020",
    "sentence": "聶嶼，鄴中人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000021",
    "sentence": "少為僧，漸學吟詠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000022",
    "sentence": "鄭玨之再主禮闈也，與鄉人趙都俱赴鄉薦，都納賄於玨，人報翌日登第，嶼聞不捷，詬來人以嚇之，玨懼，俾俱成名。",
    "entities": [
      {
        "text": "與鄉",
        "label": "LOC",
        "start": 9,
        "end": 11
      },
      {
        "text": "人趙都俱赴鄉",
        "label": "LOC",
        "start": 11,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000023",
    "sentence": "漸為拾遺，依郭崇韜為鎮州書記。",
    "entities": [
      {
        "text": "依郭崇韜為鎮州",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000024",
    "sentence": "明宗時，為起居舍人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000025",
    "sentence": "雙眸若懸，性氣乖僻，人多忌之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000026",
    "sentence": "天成初，除鄴都留守判官，與趙敬怡、呂夢奇不足。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000027",
    "sentence": "又改河東節度，及至，常鄙其土風，薄其人士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000028",
    "sentence": "或達於重誨，會敬怡入為樞密使，與夢奇同構殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000029",
    "sentence": "嶼早依郭崇韜門庭，致身朱紫，名登兩史，浙江使回，生涯巨萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000030",
    "sentence": "嶼內河東節判時，郭氏次子之婦，孀居於家，嶼喪偶未久，復忍而納幣，人皆罪之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000031",
    "sentence": "明宗在藩邸時，素聞其醜聲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000032",
    "sentence": "天成中，與溫韜等同詔賜死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000033",
    "sentence": "溫韜，華原人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000034",
    "sentence": "少為盜，據華原，事李茂貞，名彥韜，後降於梁，更名昭圖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000035",
    "sentence": "為耀州節度，唐諸陵在境者悉發之，取所藏金寶：而昭陵最固，悉藏前世圖書，鍾、王紙墨，筆跡如新。",
    "entities": [
      {
        "text": "為耀州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000036",
    "sentence": "〈 （案：以下有闕文。） 〉 移許州節度使，累官至檢校太尉、平章事。",
    "entities": [
      {
        "text": "移許州",
        "label": "LOC",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000037",
    "sentence": "韜素善趙岩，每依附之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000038",
    "sentence": "莊宗入汴，岩恃韜與己素厚，遂奔許州。",
    "entities": [
      {
        "text": "遂奔許州",
        "label": "LOC",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000039",
    "sentence": "韜延之於第，斬首傳送闕下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000040",
    "sentence": "同光初，韜來朝，郭崇韜曰：「此劫陵賊，罪不可赦。」韜納賂劉後，賜姓，名紹衝，遽遣還鎮。",
    "entities": [
      {
        "text": "遽遣還鎮",
        "label": "LOC",
        "start": 38,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000041",
    "sentence": "明宗即位，流於德州，俄賜死。",
    "entities": [
      {
        "text": "流於德州",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000042",
    "sentence": "長子延浚，清泰中為泥水關使；次延招，為父牙帳都校；次延袤，鄧州指揮使；鹹聚居許下。",
    "entities": [
      {
        "text": "清泰中為泥水關",
        "label": "LOC",
        "start": 5,
        "end": 12
      },
      {
        "text": "鄧州",
        "label": "LOC",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000043",
    "sentence": "晉天福初，聞張從賓作亂於河陽，鹹往依之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000044",
    "sentence": "從賓慮其難製，悉斬於帳下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000045",
    "sentence": "段凝，開封人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000046",
    "sentence": "本名明遠，少穎悟，多智數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000047",
    "sentence": "初為澠池簿，脫荷衣以事梁祖，梁祖漸器之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000048",
    "sentence": "開平三年十月，自東頭供奉官授右威衛大將軍，充左軍巡使兼水北巡檢使。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 17,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000049",
    "sentence": "凝妹為梁祖美人，故稍委心腹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000050",
    "sentence": "四年五月，授懷州刺史。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "授懷州",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000051",
    "sentence": "乾化元年十二月，梁祖北征回，過郡，凝貢獻加等，梁祖大悅。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "過郡",
        "label": "LOC",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000052",
    "sentence": "梁祖復北，凝迎奉進貢，有加於前。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000053",
    "sentence": "梁祖次相州，刺史李思安迎奉疏怠，梁祖怒，貶思安。",
    "entities": [
      {
        "text": "梁祖次相州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000054",
    "sentence": "製云：「懷州刺史段明遠，少年治郡，庶事惟公，兩度隻奉行鑾，數程宿食本界，動無遺闕，舉必周豐，蓋能罄竭於家財，務在顯酬夫明獎。觀明遠之忠勤若此，見思安之悖慢何如！」其見賞如此。",
    "entities": [
      {
        "text": "懷州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "少年治郡",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000055",
    "sentence": "其後，遷鄭州刺史，監大軍於河上。",
    "entities": [
      {
        "text": "遷鄭州",
        "label": "LOC",
        "start": 3,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000056",
    "sentence": "梁末帝以戴思遠為北面招討使。",
    "entities": [
      {
        "text": "梁",
        "label": "ORG",
        "start": 0,
        "end": 1
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000057",
    "sentence": "行師不利，用王彥章代之，受任之翌日，取德勝之南城，軍聲大振。",
    "entities": [
      {
        "text": "取德勝之南城",
        "label": "LOC",
        "start": 18,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000058",
    "sentence": "張漢倫等推功於凝，凝掎摭彥章之失以間之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000059",
    "sentence": "〈 （《通鑒》：彥章棄鄒家口，復趨楊劉。遊奕將李紹興敗梁遊兵於清邱縣南，段凝以為唐兵已自上流渡，驚駭失色，麵數彥章，尤其深入。） 〉 梁末帝怒，罷彥章兵權。",
    "entities": [
      {
        "text": "《通鑒》",
        "label": "TITLE",
        "start": 3,
        "end": 7
      },
      {
        "text": "梁遊兵於清邱縣",
        "label": "LOC",
        "start": 27,
        "end": 34
      },
      {
        "text": "梁",
        "label": "ORG",
        "start": 67,
        "end": 68
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000060",
    "sentence": "凝納賂於趙、張二族，求為招討使，敬翔、李振極言不可，竟不能止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000061",
    "sentence": "凝以眾五萬營於高陵津，裨將康延孝叛歸莊宗，延孝具陳梁軍虛實，莊宗遂決長驅之計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000062",
    "sentence": "未幾，莊宗入汴，凝自滑率兵而南，前鋒杜晏球至封丘，解甲聽命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_073_000063",
    "sentence": "翌日，凝率大軍乞降於汴郊，莊宗釋之，復以凝為滑州兵馬留後，賜姓，名紹欽。",
    "entities": [
      {
        "text": "復以凝為滑州",
        "label": "LOC",
        "start": 18,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_073_000064",
    "sentence": "有頃，正授節度，改兗州節度使。",
