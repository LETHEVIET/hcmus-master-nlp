        "start": 11,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_087_000010",
    "sentence": "六年，追封廣王。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
