      }
    ]
  },
  {
    "sentence_id": "HCH_007_087_000053",
    "sentence": "從賓敗，高祖發哀於便殿，輟視朝三日，詔贈太傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_087_000054",
    "sentence": "是歲冬十月，詔遣莊宅使張穎監護喪事，葬於河南府萬安山。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_087_000055",
    "sentence": "天福中，追封壽王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_087_000056",
    "sentence": "妃李氏，汾州刺史玘之女也。",
    "entities": [
      {
        "text": "汾州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "刺史",
