        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_087_000007",
    "sentence": "清泰中，加兵部尚書、彰聖都指揮使，遙領常州刺史。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "遙領常州",
