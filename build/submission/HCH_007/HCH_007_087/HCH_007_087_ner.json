      }
    ]
  },
  {
    "sentence_id": "HCH_007_087_000057",
    "sentence": "重乂無子，妃後落發為尼，開運中，卒於京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_087_000058",
