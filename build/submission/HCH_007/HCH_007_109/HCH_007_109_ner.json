  },
  {
    "sentence_id": "HCH_007_109_000002",
    "sentence": "杜重威，其先朔州人，近世徙家於太原。",
    "entities": [
      {
        "text": "其先朔州",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000003",
    "sentence": "祖興，振武牙將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000004",
    "sentence": "父堆金，事唐武皇為先鋒使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000005",
    "sentence": "重威少事明宗，自護聖軍校領防州刺史。",
    "entities": [
      {
        "text": "護聖軍校領防州",
        "label": "LOC",
        "start": 8,
        "end": 15
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000006",
    "sentence": "其妻即晉高祖妹也，累封宋國大長公主。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000007",
    "sentence": "天福初，命重威典禁軍，遙授舒州刺史。",
    "entities": [
      {
        "text": "遙授舒州",
        "label": "LOC",
        "start": 11,
        "end": 15
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000008",
    "sentence": "二年，張從賓構亂，據汜水，晉高祖遣重威與候益率眾破之，以功授潞州節度使。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "以功授潞州",
        "label": "LOC",
        "start": 27,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000009",
    "sentence": "與楊光遠降範延光於鄴城，改許州節度使，兼侍衛親軍馬步軍副指揮使，尋加同平章事。",
    "entities": [
      {
        "text": "降範延光於鄴城",
        "label": "LOC",
        "start": 4,
        "end": 11
      },
      {
        "text": "改許州",
        "label": "LOC",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000010",
    "sentence": "未幾，移鎮鄆州，遷侍衛親軍馬步軍都指揮使。",
    "entities": [
      {
        "text": "移鎮鄆州",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000011",
    "sentence": "〈 （《 通鑒 》：馮道、李崧屢薦重威之能，以為都指揮使，充隨駕御營使。） 〉 及鎮州安重榮稱兵向闕，命重威禦之，敗重榮於宗城。",
    "entities": [
      {
        "text": "《 通鑒 》",
        "label": "TITLE",
        "start": 3,
        "end": 9
      },
      {
        "text": "及鎮州",
        "label": "LOC",
        "start": 40,
        "end": 43
      },
      {
        "text": "敗重榮於宗城",
        "label": "LOC",
        "start": 57,
        "end": 63
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000012",
    "sentence": "重榮奔據常山，重威尋拔其城，斬重榮首傳於闕下，授成德軍節度使。",
    "entities": [
      {
        "text": "重威尋拔其城",
        "label": "LOC",
        "start": 7,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000013",
    "sentence": "所得重榮家財及常山公帑，悉歸於己，晉高祖知而不問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000014",
    "sentence": "至鎮，復重斂於民，稅外加賦，境內苦之 〈 （《通鑒》：重威所至黷貨，民多逃亡，嘗出過市，謂左右曰：「人言我驅盡百姓，何市人之多也！」） 〉",
    "entities": [
      {
        "text": "至鎮",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "《通鑒》",
        "label": "TITLE",
        "start": 22,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000015",
    "sentence": "少帝嗣位，與契丹絕好，契丹主連年伐晉，重威但閉壁自守。",
    "entities": [
      {
        "text": "晉",
        "label": "ORG",
        "start": 17,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000016",
    "sentence": "部內城邑相繼破陷，一境生靈受屠戮，重威任居方面，未嘗以一土一騎救之。",
    "entities": [
      {
        "text": "部內城邑",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000017",
    "sentence": "每敵騎數十驅漢人千萬過城下，如入無人之境，重威但登陴註目，略無邀取之意。",
    "entities": [
      {
        "text": "驅漢人千萬過城",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000018",
    "sentence": "開運元年 秋，加北面行營招討使。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000019",
    "sentence": "二年，領大軍下新州、滿城、遂城。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "領大軍下新州",
        "label": "LOC",
        "start": 3,
        "end": 9
      },
      {
        "text": "滿城",
        "label": "LOC",
        "start": 10,
        "end": 12
      },
      {
        "text": "遂城",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000020",
    "sentence": "契丹主自古北口回軍，追躡王師，重威等狼狽而旋，至陽城，為契丹所困。",
    "entities": [
      {
        "text": "至陽城",
        "label": "LOC",
        "start": 23,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000021",
    "sentence": "會大風狂猛，軍情憤激，府彥卿、張彥澤等引軍四出，敵眾大潰，諸將欲追之，重威曰：「逢賊得命，更望復子乎！」遂收軍馳歸常山。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000022",
    "sentence": "先是，重威於州內括借錢帛，吏民大被其苦，人情鹹怨，重以境內雕弊，十室九空，重威遂無留意，連上表乞歸朝，不俟報即時上路。",
    "entities": [
      {
        "text": "重威於州",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000023",
    "sentence": "朝廷以邊上重鎮，主帥擅離，茍有奔沖，慮失禦備，然亦無如之何，即以馬全節代之，重威尋授鄴都留守。",
    "entities": [
      {
        "text": "朝廷以邊上重鎮",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000024",
    "sentence": "會鎮州軍食不繼，遣殿中監王欽祚就本州和市，重威私第有粟十餘萬斛，遂錄之以聞。",
    "entities": [
      {
        "text": "會鎮州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "監王欽祚就本州",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000025",
    "sentence": "朝廷給絹數萬匹，償其粟直。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000026",
    "sentence": "重威大忿曰：「我非反逆，安得籍沒耶！」三年冬，晉少帝詔重威與李守貞等率師經略瀛、鄚。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000027",
    "sentence": "師至瀛州城下，晉騎將梁漢璋與契丹接戰，漢璋死焉。",
    "entities": [
      {
        "text": "師至瀛州城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000028",
    "sentence": "重威即時回軍，次武強，聞契丹主南下，乃西趨鎮州，至中渡橋，與契丹夾滹水而營。",
    "entities": [
      {
        "text": "乃西趨鎮州",
        "label": "LOC",
        "start": 18,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000029",
    "sentence": "十二月八日，宋彥筠、王清等率數千人渡滹沲，陣於北岸，為敵所破。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000030",
    "sentence": "時契丹遊軍已至欒城，道路隔絕，人情危蹙，重威密遣人詣敵帳，潛布腹心。",
    "entities": [
      {
        "text": "丹遊軍已至欒城",
        "label": "LOC",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000031",
    "sentence": "契丹主大悅，許以中原帝之，重威庸暗，深以為信。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000032",
    "sentence": "一日，伏甲於內，召諸將會，告以降敵之意，諸將愕然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000033",
    "sentence": "以上將既變，乃俯首聽命，遂連署降表，令中門使高勛賫送敵帳，軍士解甲，舉聲慟哭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000034",
    "sentence": "是日，有大霧起於降軍之上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000035",
    "sentence": "契丹主使重威衣赭袍以示諸軍，尋偽加守太傅，鄴都留守如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000036",
    "sentence": "契丹主南行，命重威部轄晉軍以從，既至東京，駐晉軍於陳橋，士伍饑凍，不勝其苦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000037",
    "sentence": "重威每出入衢路，為市民所詬，俯首而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000038",
    "sentence": "契丹下令括率京城錢帛，將相公私，雷同率配，重威與李守貞各萬緡，乃告契丹主曰：「臣等以十萬漢軍降於皇帝，不免配借，臣所不甘。」契丹主笑而免之。",
    "entities": [
      {
        "text": "丹下令括率京城",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 48,
        "end": 50
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000039",
    "sentence": "尋群盜斷澶州浮梁，契丹乃遣重威歸藩。",
    "entities": [
      {
        "text": "尋群盜斷澶州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000040",
    "sentence": "明年三月，契丹主北去，至相州城下，重威與妻石氏詣牙帳貢獻而回。",
    "entities": [
      {
        "text": "至相州城",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000041",
    "sentence": "高祖車駕至闕，以重威為宋州節度使，加守太尉。",
    "entities": [
      {
        "text": "以重威為宋州",
        "label": "LOC",
        "start": 7,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000042",
    "sentence": "重威懼，閉城拒命，詔高行周率兵攻討，重威遣其子宏遂等告急於鎮州州麻答，乞師救援，旦以宏遂為質，麻答遣蕃將楊兗赴之。",
    "entities": [
      {
        "text": "閉城",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "宏遂等告急於鎮",
        "label": "LOC",
        "start": 23,
        "end": 30
      },
      {
        "text": "州州",
        "label": "LOC",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000043",
    "sentence": "未幾，鎮州軍逐滿達勒，楊兗至洺州而回。",
    "entities": [
      {
        "text": "鎮州",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "楊兗至洺州",
        "label": "LOC",
        "start": 11,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000044",
    "sentence": "十月，高祖親征，車駕至鄴城之下，遣給事中陳觀等賫詔入城，許其歸命，重威不納。",
    "entities": [
      {
        "text": "車駕至鄴城",
        "label": "LOC",
        "start": 8,
        "end": 13
      },
      {
        "text": "陳觀等賫詔入城",
        "label": "LOC",
        "start": 20,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000045",
    "sentence": "數日，高祖親率諸軍攻其壘，不克，王師傷夷者萬餘人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000046",
    "sentence": "〈 （《 宋史 ·杜漢徽傳》云：從高行周討杜重威於鄴城，屢為流矢所中，身被重創，猶力戰，觀者壯之。） 〉 高祖駐軍數旬，城中糧盡，屑麹餅以給軍士，吏民逾壘而出者甚眾，皆無人色。",
    "entities": [
      {
        "text": "《 宋史 ·杜漢徽傳》",
        "label": "TITLE",
        "start": 3,
        "end": 14
      },
      {
        "text": "討杜重威於鄴城",
        "label": "LOC",
        "start": 20,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000047",
    "sentence": "至是，重威牙將詣行宮請降，復遣節度判官王敏奉表請罪，賜優詔敦勉，許其如初。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000048",
    "sentence": "重威即遣其子宏遂、妻石氏出候高祖，重威繼踵出降，素服俟罪，復其衣冠，賜見，即日制授檢校太師、守太傅、兼中書令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000049",
    "sentence": "鄴城士庶，殍殕者十之六七。",
    "entities": [
      {
        "text": "鄴城",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000050",
    "sentence": "先是，契丹遣幽州指揮使張璉，以部下軍二千餘人屯鄴，時亦有燕軍一千五百人在京師，會高祖至闕，有上變者，言燕軍謀亂，盡誅於繁臺之下，咸稱其冤。",
    "entities": [
      {
        "text": "契丹遣幽州",
        "label": "LOC",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000051",
    "sentence": "有逃奔於鄴者，備言其事，故張璉等懼死，與重威膠固守城，略無叛誌。",
    "entities": [
      {
        "text": "與重威膠固守城",
        "label": "LOC",
        "start": 19,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000052",
    "sentence": "高祖亦悔其前失，累令宣諭，許以不死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000053",
    "sentence": "璉等於城上揚言曰：「繁臺之誅，燕軍何罪？既無生理，以死為期。」璉一軍在圍中，重威推食解衣，盡力姑息。",
    "entities": [
      {
        "text": "璉等於城",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000054",
    "sentence": "燕軍驕悍，憑陵吏民，子女金帛，公行豪奪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000055",
    "sentence": "及重威請命，璉等邀朝廷信誓，詔許璉等卻歸本土。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000056",
    "sentence": "及出降，盡誅璉等將數十人，其什長已下放歸幽州，將出漢境，剽略而去。",
    "entities": [
      {
        "text": "長已下放歸幽州",
        "label": "LOC",
        "start": 15,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000057",
    "sentence": "高祖遣三司使王章、樞密副使郭威，錄重威部下將吏盡誅之，籍其財產與重威私帑，分給將士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000058",
    "sentence": "車駕還宮，高祖不豫，既而大漸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000059",
    "sentence": "顧命之際，謂近臣將佐曰：「善防重威。」帝崩，遂收重威，重威子宏璋、宏璉、宏傑誅之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_109_000060",
    "sentence": "詔曰：「杜重威猶貯禍心，未悛逆節，梟音不改，虺性難馴。昨朕小有不安，罷朝數日，而重威父子潛肆兇言，怨謗大朝，扇惑小輩；今則顯有陳告，備驗奸期。既負深恩，須置極法，其杜重威父子並處斬。所有晉朝公主及外親族，一切如常，仍與供給。」重威父子已誅，陳屍於通衢，都人聚觀者詬罵蹴擊，軍吏不能禁，屍首狼籍，斯須而盡。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 95,
        "end": 97
      }
    ]
  },
  {
    "sentence_id": "HCH_007_109_000061",
    "sentence": "宏璉，重威之子也，累官至陳州刺史。",
    "entities": [
