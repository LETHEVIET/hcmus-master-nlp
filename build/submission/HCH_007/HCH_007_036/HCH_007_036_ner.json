    "sentence_id": "HCH_007_036_000011",
    "sentence": "後宮內職量留一百人，內官三十人，教坊一百人，鷹坊二十人，禦廚五十人，其餘任從所適。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_036_000012",
    "sentence": "諸司使務有名無實者並停。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_036_000013",
