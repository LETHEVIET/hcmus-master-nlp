      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000037",
    "sentence": "三年正月，太祖授元帥之任，以鄩為元帥府都押牙，執金吾如故。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000038",
    "sentence": "開平元年 ，授右金吾上將軍，充諸軍馬步都指揮使。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "將軍",
