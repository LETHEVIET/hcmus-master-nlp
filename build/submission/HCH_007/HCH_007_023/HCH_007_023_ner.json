        "end": 44
      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000174",
    "sentence": "劉知俊之叛也，從駕至陝，始佐楊師厚西入關。",
    "entities": [
      {
        "text": "劉知俊",
        "label": "PER",
