      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000045",
    "sentence": "太祖以鄩為佑國、同州軍兩使留後。",
    "entities": [
      {
        "text": "同州",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000046",
    "sentence": "尋改佑國軍為永平軍，以鄩為節度使、檢校司徒，行大安尹、金州管內觀察使。",
    "entities": [
