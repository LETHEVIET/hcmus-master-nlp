        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000012",
    "sentence": "歲餘，移刺淄州，署行軍司馬。",
    "entities": [
      {
        "text": "移刺淄州",
        "label": "LOC",
