      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000044",
    "sentence": "遂引兵收復長安，知俊棄郡奔鳳翔。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 5,
