      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000039",
    "sentence": "其年秋，與諸將征潞州，遷檢校司徒。",
    "entities": [
      {
        "text": "與諸將征潞州",
        "label": "LOC",
        "start": 4,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000040",
    "sentence": "三年二月，轉右威衛上將軍，依前諸軍馬步都虞候。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
