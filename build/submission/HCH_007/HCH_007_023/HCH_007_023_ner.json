        "label": "LOC",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000003",
    "sentence": "祖綬，密州戶掾，累贈左散騎常侍。",
    "entities": [
      {
        "text": "密州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000004",
    "sentence": "父融，安丘令，累贈工部尚書。",
    "entities": [
