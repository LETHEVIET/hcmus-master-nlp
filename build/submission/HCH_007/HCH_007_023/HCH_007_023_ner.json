      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000008",
    "sentence": "棣州刺史張蟾將襲師範，師範遣都指揮使盧宏攻棣州，宏反與蟾通，偽旋軍以襲師範。",
    "entities": [
      {
        "text": "棣州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "揮使盧宏攻棣州",
        "label": "LOC",
        "start": 16,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000009",
    "sentence": "師範知之，設伏兵以迎宏，既而享之，先誡鄩曰：「宏至即斬之。」鄩如約，斬弧於座上，同亂者皆誅之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_023_000010",
    "sentence": "師範以鄩為馬步軍副都指揮使，攻下棣州，殺張蟾，朝廷因授師範平盧軍節度使。",
    "entities": [
      {
        "text": "攻下棣州",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000011",
    "sentence": "光化初，師範表鄩為登州刺史。",
    "entities": [
      {
        "text": "師範表鄩為登州",
        "label": "LOC",
