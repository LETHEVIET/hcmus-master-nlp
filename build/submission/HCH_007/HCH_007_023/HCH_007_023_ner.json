        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000171",
    "sentence": "太祖復命遙領宣州節度使、檢校太傅、同平章事。",
    "entities": [
      {
        "text": "祖復命遙領宣州",
