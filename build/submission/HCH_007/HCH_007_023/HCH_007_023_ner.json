        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_023_000005",
    "sentence": "鄩幼有大志，好兵略，涉獵史傳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_023_000006",
    "sentence": "唐中和中，事青州節度使王敬武為小校。",
