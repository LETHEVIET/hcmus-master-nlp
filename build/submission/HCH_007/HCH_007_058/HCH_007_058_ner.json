      }
    ]
  },
  {
    "sentence_id": "HCH_007_058_000156",
    "sentence": "自吏部侍郎拜中書門下平章事，與李琪同輔梁室，事多矛盾。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 3,
