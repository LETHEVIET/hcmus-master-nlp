      }
    ]
  },
  {
    "sentence_id": "HCH_007_058_000160",
    "sentence": "卒時年六十九。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_058_000161",
    "sentence": "輟朝一日，贈太子少師。",
    "entities": [
      {
        "text": "太子",
