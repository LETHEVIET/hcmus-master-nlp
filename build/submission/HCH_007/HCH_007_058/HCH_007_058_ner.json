      }
    ]
  },
  {
    "sentence_id": "HCH_007_058_000158",
    "sentence": "數年，遷太子賓客。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_058_000159",
    "sentence": "天成初，為禮部尚書、太常卿、太子少保致仕。",
    "entities": [
      {
