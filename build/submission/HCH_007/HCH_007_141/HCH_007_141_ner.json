    "entities": []
  },
  {
    "sentence_id": "HCH_007_141_000095",
    "sentence": "朝廷以軍食不充，分命使臣諸道括粟麥，晉祚自茲衰矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_141_000096",
    "sentence": "漢乾祐元年七月，青、鄆、兗、齊、濮、沂、密、邢、曹皆言蝝生。",
