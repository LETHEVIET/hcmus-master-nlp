      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000007",
    "sentence": "後以唐乾寧二年，歲在乙卯，二月四日生帝於太原。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000008",
    "sentence": "帝弱不好弄，嚴重寡言，及長，面紫色，目睛多白。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000009",
    "sentence": "初事唐明宗，列於麾下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000010",
    "sentence": "明宗與梁人對柵於德勝，時晉高祖為梁人所襲，馬甲連革斷，帝輟騎以授之，取斷革者自跨之，徐殿其後，晉高祖感而壯之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000011",
    "sentence": "明宗踐阼，晉高祖為北京留守，以帝前有護援之力，奏移麾下，署為牙門都校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000012",
    "sentence": "應順初，晉高祖鎮常山，唐明宗召赴闕，會閔帝出奔，與晉高祖相遇於途，遂俱入衛州，泊於郵舍。",
    "entities": [
      {
        "text": "晉高祖鎮",
        "label": "LOC",
        "start": 4,
        "end": 8
      },
      {
        "text": "遂俱入衛州",
        "label": "LOC",
        "start": 33,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000013",
    "sentence": "閔帝左右謀害晉高祖，帝密遣禦士石敢袖鎚立於晉高祖後，及有變，敢擁晉高祖入一室，以巨木塞門，敢尋死焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000014",
    "sentence": "帝率眾盡殺閔帝左右，遂免晉高祖於難。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000015",
    "sentence": "〈 （《通鑒考異》引《漢高祖實錄》云：是夜，偵知少帝伏甲，欲與從臣謀害晉高祖，詐屏人對語，方坐庭廡。帝密遣禦士石敢袖鎚立於後，俄頃伏甲者起，敢有勇力，擁晉高祖入一室，以巨木塞門，敢力當其鋒，死之。帝解佩刀，遇夜晦，以在地葦炬未然者奮擊之，眾謂短兵也，遂散走。帝乃匿身長垣下，聞帝親將李洪信謂人曰：「石太尉死矣。」帝隔垣呼洪信曰：「太尉無恙。」乃逾垣出就洪信兵，共護晉高祖，殺建謀者，以少主授王宏贄。） 〉",
    "entities": [
      {
        "text": "《通鑒考異》",
        "label": "TITLE",
        "start": 3,
        "end": 9
      },
      {
        "text": "《漢高祖實錄》",
        "label": "TITLE",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000016",
    "sentence": "清泰元年，晉高祖復鎮河東。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "晉高祖復鎮",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000017",
    "sentence": "三年夏，移鎮汶陽。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "移鎮",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000018",
    "sentence": "帝勸晉高祖舉義，贊成密計，經綸之始，中外賴之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000019",
    "sentence": "晉高祖以帝為北京馬步軍都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000020",
    "sentence": "及契丹以全軍赴難，大破張敬達之眾於晉陽城下，有降軍千餘人，晉高祖將置之於親衛，帝盡殺之。",
    "entities": [
      {
        "text": "達之眾於晉陽城",
        "label": "LOC",
        "start": 13,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000021",
    "sentence": "晉國初建，加檢校司空，充侍衛馬步都指揮使，權點檢隨駕六軍諸衛事，尋改陜州節度使，充侍衛親軍馬步都虞候。",
    "entities": [
      {
        "text": "尋改陜州",
        "label": "LOC",
        "start": 32,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000022",
    "sentence": "契丹主送晉高祖至上黨，指帝謂高祖曰：「此都軍甚操剌，無大故不可棄之。」晉高祖入洛，委帝巡警，都邑肅然，無敢犯令。",
    "entities": [
      {
        "text": "都邑",
        "label": "LOC",
        "start": 46,
        "end": 48
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000023",
    "sentence": "天福二年夏四月，加檢校太保。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000024",
    "sentence": "八月，改許州節度使，典軍如故。",
    "entities": [
      {
        "text": "改許州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000025",
    "sentence": "三年夏四月，加檢校太傅。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000026",
    "sentence": "冬十月，授侍衛親軍馬步軍都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000027",
    "sentence": "十一月，移授宋州，加檢校太尉。",
    "entities": [
      {
        "text": "移授宋州",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000028",
    "sentence": "十二月，加同平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000029",
    "sentence": "時帝與杜重威同制加恩，帝憤然不樂，懇讓不受，杜門不出者數日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000030",
    "sentence": "〈 （《通鑒》：知遠自以有佐命功，重威起於外戚，無大功，恥與之同制。制下數日，杜門四表辭不受。） 〉 晉高祖怒，召宰相趙瑩等議落帝兵權，任歸私第。",
    "entities": [
      {
        "text": "《通鑒》",
        "label": "TITLE",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000031",
    "sentence": "瑩等以為不可，乃遣端明殿學士和凝就第宣諭，帝乃承命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000032",
    "sentence": "五年三月，改鄴都留守兼侍衛親軍馬步軍都指揮使。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000033",
    "sentence": "九月，奉詔赴闕，晉高祖幸其第。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000034",
    "sentence": "六年七月，授北京留守、河東節度使。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000035",
    "sentence": "七年正月，加侍中。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000036",
    "sentence": "時天下大蝗，惟不入河東界。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000037",
    "sentence": "六月，晉高祖崩於鄴宮，少帝即位，加帝檢校太師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000038",
    "sentence": "八年三月，進位中書令。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000039",
    "sentence": "開運元年正月，契丹南下，契丹主以大軍直抵澶州，遣蕃將偉王率兵入雁門。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "以大軍直抵澶州",
        "label": "LOC",
        "start": 15,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000040",
    "sentence": "朝廷以帝為幽州道行營招討使，帝大破偉王於忻口。",
    "entities": [
      {
        "text": "朝廷以帝為幽州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000041",
    "sentence": "尋奉詔起兵至土門，軍至樂平，會契丹退，乃還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000042",
    "sentence": "三月，封太原王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000043",
    "sentence": "七月，兼北面行營都統。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000044",
    "sentence": "二年四月，封北平王。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000045",
    "sentence": "三年五月，加守太尉。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000046",
    "sentence": "是月，帝誅吐渾白承福等五族凡四百人，以別部王義宗統其餘眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000047",
    "sentence": "九月，契丹犯塞，帝親率牙兵至朔州南陽武谷，大破之。",
    "entities": [
      {
        "text": "親率牙兵至朔州",
        "label": "LOC",
        "start": 9,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000048",
    "sentence": "〈 （《東都事略·郭進傳》：契丹屠安陽，高祖遣進拒戰，契丹敗走，以功除刺史。） 〉 十一月，契丹主率蕃漢大軍由易、定抵鎮州，杜重威等駐軍於中渡橋以禦之。",
    "entities": [
      {
        "text": "《東都事略·郭進傳》",
        "label": "TITLE",
        "start": 3,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 35,
        "end": 37
      },
      {
        "text": "定抵鎮州",
        "label": "LOC",
        "start": 57,
        "end": 61
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000049",
    "sentence": "十二月十日，杜重威等以全軍降於契丹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000050",
    "sentence": "十七日，相州節度使張彥澤受契丹命，陷京城，遷少帝於開封府。",
    "entities": [
      {
        "text": "相州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "陷京城",
        "label": "LOC",
        "start": 17,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000051",
    "sentence": "帝聞之大駭，分兵守境，以備寇患。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000052",
    "sentence": "天福十二年春正月丁亥朔，契丹主入東京。",
    "entities": [
      {
        "text": "十二年",
        "label": "TME",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000053",
    "sentence": "癸巳，晉少帝蒙塵於封禪寺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000054",
    "sentence": "癸卯，少帝北遷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000055",
    "sentence": "二月丁巳朔，契丹主具漢法服，禦崇元殿受朝，制改晉國為大遼國，大赦天下，號會同十年。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 38,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000056",
    "sentence": "是月，帝遣牙將王峻奉表於契丹，契丹主賜詔褒美，呼帝為兒，又賜木拐一。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000057",
    "sentence": "蕃法，貴重大臣方得此賜，亦猶漢儀賜几杖之比也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000058",
    "sentence": "王峻持持而歸，契丹望之皆避路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000059",
    "sentence": "及峻至太原，帝知契丹政亂，乃議建號焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_099_000060",
    "sentence": "是月，秦州節度使何建以其地入於蜀。",
    "entities": [
      {
        "text": "秦州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000061",
    "sentence": "戊辰，河東行軍司馬張彥威與文武將吏等，以中原無主，帝威望日隆，群情所屬，上箋勸進，帝謙讓不允。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_099_000062",
    "sentence": "自是群官三上箋，諸軍將吏、緇黃耆耋，相次迫請，教答允之。",
    "entities": []
  },
  {
