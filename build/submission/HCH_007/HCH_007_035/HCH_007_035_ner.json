  },
  {
    "sentence_id": "HCH_007_035_000002",
    "sentence": "世事武皇，及其錫姓也，遂編於屬籍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_035_000003",
    "sentence": "四代祖諱聿，皇贈麟州刺史。",
