  },
  {
    "sentence_id": "HCH_007_045_000006",
    "sentence": "二年四月，加檢校太保、同平章事、河南尹，判六軍諸衛事。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_045_000007",
    "sentence": "十一月，加檢校太傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_045_000008",
    "sentence": "三年三月，授汴州節度使。",
    "entities": [
