        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_045_000013",
    "sentence": "秦王從榮，帝同母兄也，以帝有德望，深所猜忌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_045_000014",
    "sentence": "帝在鄴宮，憂其禍，然善於承順，竟免閑隙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_045_000015",
    "sentence": "四年十一月二十日，秦王誅。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_045_000016",
    "sentence": "翌日，明宗遣宣徽使孟漢瓊馳驛召帝，二十六日，明宗崩，二十九日，帝至自鄴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_045_000017",
    "sentence": "十二月癸卯朔，發喪於西宮，帝於柩前即位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_045_000018",
    "sentence": "丁未，群臣上表請聽政，表再上，詔允。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_045_000019",
    "sentence": "己酉，中外將士給賜有差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_045_000020",
    "sentence": "庚戌，帝縗服見群臣於廣壽門之東廡下，宰臣馮道進曰：「陛下久居哀毀，臣等鹹願一睹聖顏。」朱宏昭前舉帽，群臣再拜而退。",
    "entities": [
      {
        "text": "朱宏昭",
        "label": "PER",
        "start": 43,
        "end": 46
      }
    ]
  },
  {
    "sentence_id": "HCH_007_045_000021",
    "sentence": "禦光政樓存問軍民。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_045_000022",
    "sentence": "辛亥，賜司衣王氏死，坐秦王事也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_045_000023",
    "sentence": "癸丑，以前鎮州節度使、涇王從敏權知河南府事，尋以盧質代之。",
    "entities": [
