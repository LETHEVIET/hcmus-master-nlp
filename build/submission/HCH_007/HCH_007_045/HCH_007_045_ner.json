        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_045_000004",
    "sentence": "帝髫齔好讀《 春秋 》，略通大義，貌類明宗，尤鍾愛。",
    "entities": [
      {
        "text": "《 春秋 》",
        "label": "TITLE",
        "start": 5,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_045_000005",
    "sentence": "天成元年 ，授金紫光祿大夫、檢校司徒。",
