      }
    ]
  },
  {
    "sentence_id": "HCH_007_045_000009",
    "sentence": "四年，移鎮河東。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "移鎮",
