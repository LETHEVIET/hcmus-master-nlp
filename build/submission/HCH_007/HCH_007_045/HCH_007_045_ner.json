      }
    ]
  },
  {
    "sentence_id": "HCH_007_045_000010",
    "sentence": "長興元年 ，改授鎮州節度使，尋封宋王。",
    "entities": [
      {
        "text": "改授鎮州",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_045_000011",
    "sentence": "二年，加檢校太尉、兼侍中，移鎮鄴都。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
