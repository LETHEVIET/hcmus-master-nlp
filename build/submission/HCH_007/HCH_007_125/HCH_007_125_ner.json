      },
      {
        "text": "以兵攻其城",
        "label": "LOC",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000090",
    "sentence": "長興中，為興州刺史，以乾渠為治所。",
    "entities": [
      {
        "text": "為興州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000091",
    "sentence": "會兩川叛，蜀人來侵，暉以眾寡不敵，奔歸鳳翔，朝廷怒其失守，詔於同州衙職安置。",
    "entities": [
      {
        "text": "詔於同州",
        "label": "LOC",
        "start": 29,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000092",
    "sentence": "未幾，從晉高祖討蜀，蜀人守劍門，領部下兵逾越險阻，從他道出於劍門之左掩擊之，殺守兵殆盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000093",
    "sentence": "會晉祖班師，朝廷以暉為澶州刺史。",
    "entities": [
      {
        "text": "朝廷以暉為澶州",
        "label": "LOC",
        "start": 6,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000094",
    "sentence": "晉天福初，範延光據鄴叛，以暉為馬步都將，孫銳為監軍，自六明鎮渡河，將襲滑臺，尋為官軍所敗，暉退歸鄴，為延光城守。",
    "entities": [
      {
        "text": "自六明鎮",
        "label": "LOC",
        "start": 26,
        "end": 30
      },
      {
        "text": "為延光城",
        "label": "LOC",
        "start": 50,
        "end": 54
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000095",
    "sentence": "明年秋，暉因出戰而降，授滑州節度使、檢校太傅。",
    "entities": [
      {
        "text": "授滑州",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000096",
    "sentence": "鄴平，移鎮靈武。",
    "entities": [
      {
        "text": "移鎮",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000097",
    "sentence": "初，張希崇鎮靈州，以久在蕃，頗究邊事，數年之間，侵盜並息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000098",
    "sentence": "希崇卒，未有主帥，蕃部寇鈔，無復畏憚，朝廷以暉強暴之名聞於遐僥，故以命之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000099",
    "sentence": "及暉到鎮，大張宴席，酒殽豐備，郡夷告醉，爭陳獻賀，暉皆以錦彩酬之，蕃情大悅。",
    "entities": [
      {
        "text": "及暉到鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000100",
    "sentence": "党項拓拔彥昭者，州界部族之大者，暉至來謁，厚加待遇，仍為治第，豐其服玩，因留之不令歸部。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000101",
    "sentence": "河西羊馬，由是易為交市。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000102",
    "sentence": "暉期年得馬五千匹，而蕃部歸心，朝議患之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000103",
    "sentence": "〈 （《隆平集·藥元福傳》：西戎三族攻靈州，命元福佐朔方節度使馮暉討之。朔方距威州七百里，地無水草，謂之「旱海」。攜糧至，暉食盡，詰朝行四十里，而敵騎數萬扼要路。暉大懼，遣人致賂求成，雖許，及日中猶未決。暉曰：「奈何？」元福曰：「彼正欲困我耳，察其勢，敵雖眾，特依西山而陣者，其精兵也，請以驍銳先薄西山，彼或少怯，當舉黃旗為識。」暉善其謀，斬馘殆盡。） 〉",
    "entities": [
      {
        "text": "西戎三族攻靈州",
        "label": "LOC",
        "start": 14,
        "end": 21
      },
      {
        "text": "朔方距威州",
        "label": "LOC",
        "start": 36,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000104",
    "sentence": "晉開運初，桑維翰輔政，欲圖大舉以制北方，命將佐十五人，皆列藩之帥也。",
    "entities": [
      {
        "text": "桑維翰",
        "label": "PER",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000105",
    "sentence": "惟暉不預其數，乃上章自陳，且言未老可用，而制書見遺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000106",
    "sentence": "詔報云：「非制書忽忘，實以朔方重地，蕃部窺邊，非卿雄名，何以彈壓！比欲移卿內地，受代亦須奇才。」暉得詔甚喜，又達情乞移鎮邠州，即以節鉞授之。",
    "entities": [
      {
        "text": "又達情乞移鎮",
        "label": "LOC",
        "start": 54,
        "end": 60
      },
      {
        "text": "邠州",
        "label": "LOC",
        "start": 60,
        "end": 62
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000107",
    "sentence": "行未及邠，又除陜州，暉獻馬千匹、駝五百頭。",
    "entities": [
      {
        "text": "又除陜州",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000108",
    "sentence": "在陜未幾，除侍衛步軍都指揮使，兼領河陽，即以王令溫為靈武節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000109",
    "sentence": "暉既典禁兵，兼領近鎮，為朝廷縻留，頗悔離靈武。",
    "entities": [
      {
        "text": "兼領近鎮",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000110",
    "sentence": "及馮玉、李彥韜用事，暉善奉之，未幾，復以暉為朔方節度使，加檢校太師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000111",
    "sentence": "漢高祖革命，就加同平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000112",
    "sentence": "隱帝嗣位，加兼侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000113",
    "sentence": "國初，加中書令，封陳留王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000114",
    "sentence": "廣順三年夏，病卒，年六十。",
    "entities": [
      {
        "text": "廣順三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000115",
    "sentence": "追贈衛王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000116",
    "sentence": "子繼業，朔方衙內都虞候。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000117",
    "sentence": "暉亡，三軍請知軍府事，因授檢校太保，充朔方兵馬留後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000118",
    "sentence": "皇朝乾德中，移於內地，今為同州節度使。",
    "entities": [
      {
        "text": "今為同州",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000119",
    "sentence": "高允權",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000120",
    "sentence": "高允權，延州人。",
    "entities": [
      {
        "text": "延州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000121",
    "sentence": "祖懷遷，本郡牙將。",
    "entities": [
      {
        "text": "本郡",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000122",
    "sentence": "懷遷生二子，長曰萬興，次曰萬金，梁、唐之間為延州節度使，卒於鎮。",
    "entities": [
      {
        "text": "唐之間為延州",
        "label": "LOC",
        "start": 18,
        "end": 24
      },
      {
        "text": "卒於鎮",
        "label": "LOC",
        "start": 28,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000123",
    "sentence": "允權即萬金子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000124",
    "sentence": "雖出於將門，不嫻武藝，起家為義川主簿，歷膚施縣令，罷秩歸延州之第。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 22,
        "end": 24
      },
      {
        "text": "罷秩歸延州",
        "label": "LOC",
        "start": 25,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000125",
    "sentence": "晉開運末，以周密為延帥，延有東西二城，其中限以深澗。",
    "entities": [
      {
        "text": "延有東西二城",
        "label": "LOC",
        "start": 12,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000126",
    "sentence": "及契丹入汴，一日，州兵亂，攻密，密固守東城。",
    "entities": [
      {
        "text": "密固守東城",
        "label": "LOC",
        "start": 16,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000127",
    "sentence": "亂兵既無帥，亦無敢為帥者，或曰：「取高家西宅郎君為帥可也。」是夜未曙，允權方寢，亂軍排闥，請知留後事，遂居於西城，與密相拒數日。",
    "entities": [
      {
        "text": "遂居於西城",
        "label": "LOC",
        "start": 51,
        "end": 56
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000128",
    "sentence": "河東遣供奉官陳光穗宣撫河西，允權乃遣支使李彬奉表太原，周密棄東城而去。",
    "entities": [
      {
        "text": "周密棄東城",
        "label": "LOC",
        "start": 27,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000129",
    "sentence": "漢祖遣使就加允權檢校太傅，仍正授旄鉞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000130",
    "sentence": "漢祖入汴，允權屢修貢奉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000131",
    "sentence": "隱帝即位，加檢校太尉、同平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000132",
    "sentence": "允權與夏州李彜興不協，其年李守貞據河中叛，密構彜興為援，及朝廷用兵夏州，軍逼延州，允權上章論列，彜興亦紛然自訴，朝廷賜詔和解之。",
    "entities": [
      {
        "text": "允權與夏州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "李守貞",
        "label": "PER",
        "start": 13,
        "end": 16
      },
      {
        "text": "及朝廷用兵夏州",
        "label": "LOC",
        "start": 28,
        "end": 35
      },
      {
        "text": "軍逼延州",
        "label": "LOC",
        "start": 36,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000133",
    "sentence": "太子太師致仕劉景巖，允權妻之祖也，退老於州之別墅。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "劉景巖",
        "label": "PER",
        "start": 6,
        "end": 9
      },
      {
        "text": "退老於州",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000134",
    "sentence": "景巖舊事高氏為牙校，亦嘗為延帥，甚得民心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000135",
    "sentence": "景巖以允權婚家後輩，心輕之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000136",
    "sentence": "允權恒忌其強，是歲冬，盡殺景巖之家，收其家財萬計，以謀叛聞，朝廷不能辨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000137",
    "sentence": "關西賊平，方面例覃恩命，就加允權檢校太師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000138",
    "sentence": "太祖即位，加兼侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000139",
    "sentence": "廣順三年春卒，其子紹基匿喪久之，又擅主軍政，欲邀承襲。",
    "entities": [
      {
        "text": "廣順三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000140",
    "sentence": "觀察判官李彬以為不可，當聽朝旨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000141",
    "sentence": "紹基與群小等惡其異議，乃殺彬，紿奏云：「彬結構內外，謀殺都指揮使及行軍副使，自據城池，已誅戮訖，其妻子及諸房骨肉，尋令捕系次。」太祖聞之，詔並釋之，仍令都送汝州安置。",
    "entities": [
      {
        "text": "自據城",
        "label": "LOC",
        "start": 38,
        "end": 41
      },
      {
        "text": "仍令都送汝州",
        "label": "LOC",
        "start": 74,
        "end": 80
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000142",
    "sentence": "後朝廷令六宅使張仁謙往巡檢，紹基乃發喪以聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000143",
    "sentence": "輟視朝兩日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000144",
    "sentence": "折從阮",
    "entities": [
      {
        "text": "折從阮",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000145",
    "sentence": "折從阮，字可久，本名從遠，避漢高祖舊名下一字，故改焉。",
    "entities": [
      {
        "text": "折從阮",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000146",
    "sentence": "代家雲中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000147",
    "sentence": "父嗣倫，為麟州刺史，累贈太子太師。",
    "entities": [
      {
        "text": "為麟州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000148",
    "sentence": "從阮性溫厚，弱冠居父喪，以孝聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000149",
    "sentence": "唐莊宗初有河朔之地，以代北諸部屢為邊患，起從阮為河東牙將，領府州副使。",
    "entities": [
      {
        "text": "領府州",
        "label": "LOC",
        "start": 29,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000150",
    "sentence": "同光中，授府州刺史。",
    "entities": [
      {
        "text": "授府州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000151",
    "sentence": "長興初，入朝，明宗以從阮洞習邊事，加檢校工部尚書，復授府川刺史。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 22,
        "end": 24
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000152",
    "sentence": "晉高祖起義，以契丹有援立之恩，賂以雲中、河西之地，從阮由是以郡北屬。",
    "entities": [
      {
        "text": "從阮由是以郡",
        "label": "LOC",
        "start": 25,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000153",
    "sentence": "既而契丹欲盡徙河西之民以實遼東，人心大擾，從阮因保險拒之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000154",
    "sentence": "晉少帝嗣位，北絕邊好，乃遣使持詔諭從阮令出師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000155",
    "sentence": "明年春，從阮率兵深入邊界，連拔十餘寨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000156",
    "sentence": "開運初，加檢校太保，遷本州團練使。",
    "entities": [
      {
        "text": "遷本州",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000157",
    "sentence": "其年，兼領朔州刺史、安北都護、振武軍節度使、契丹西南面行營馬步都虞候。",
    "entities": [
      {
        "text": "兼領朔州",
        "label": "LOC",
        "start": 3,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000158",
    "sentence": "漢祖建號晉陽，引兵南下，從阮率眾歸之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000159",
    "sentence": "尋升府州為永安軍，析振武之勝州並沿河五鎮以隸焉。",
    "entities": [
      {
        "text": "尋升府州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "析振武之勝州",
        "label": "LOC",
        "start": 9,
        "end": 15
      },
      {
        "text": "並沿河五鎮",
        "label": "LOC",
        "start": 15,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000160",
    "sentence": "授從阮光祿大夫、檢校太尉、永安軍節度、府勝等州觀察處置等使，仍賜功臣名號。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "府勝等州",
        "label": "LOC",
        "start": 19,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000161",
    "sentence": "乾祐元年，加特進、檢校太師。",
    "entities": [
      {
        "text": "乾祐元年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000162",
    "sentence": "明年春，從阮舉族入覲，朝廷命其子德扆為府州團練使，授從阮武勝節度使。",
    "entities": [
      {
        "text": "其子德扆為府州",
        "label": "LOC",
        "start": 14,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000163",
    "sentence": "太祖受命，加同平章事，尋移鎮滑州，又改陜州。",
    "entities": [
      {
        "text": "尋移鎮滑州",
        "label": "LOC",
        "start": 11,
        "end": 16
      },
      {
        "text": "又改陜州",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000164",
    "sentence": "二年冬，授靜難軍節度使。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000165",
    "sentence": "世宗即位，就加兼侍中，以年老上章請代，優詔許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000166",
    "sentence": "顯德二年冬，赴闕，行次西京，以疾卒，時年六十四。",
    "entities": [
      {
        "text": "顯德二年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000167",
    "sentence": "制贈中書令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000168",
    "sentence": "王饒",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000169",
    "sentence": "王饒，字受益，慶州華池人也。",
    "entities": [
      {
        "text": "慶州",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000170",
    "sentence": "父柔，以饒貴，累贈太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000171",
    "sentence": "饒沈毅有才幹，始事晉高祖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000172",
    "sentence": "天福初，授控鶴軍使，稍遷奉國軍校，累加檢校尚書左僕射。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000173",
    "sentence": "六年，從杜重威平常山，以功加檢校司空，遷本軍都校，領鄆州刺史。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "杜重威",
        "label": "PER",
        "start": 4,
        "end": 7
      },
      {
        "text": "領鄆州",
        "label": "LOC",
        "start": 25,
        "end": 28
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000174",
    "sentence": "時安從進叛於襄陽，晉祖命高行周率兵討之，以饒為行營步軍都指揮使，賊平，授深州刺史。",
    "entities": [
      {
        "text": "安從進",
        "label": "PER",
