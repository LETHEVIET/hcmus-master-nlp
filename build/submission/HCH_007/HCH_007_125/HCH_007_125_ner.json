      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000081",
    "sentence": "子永昌，仕皇朝，歷內諸司使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000082",
    "sentence": "馮暉",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000083",
    "sentence": "馮暉，魏州人也。",
