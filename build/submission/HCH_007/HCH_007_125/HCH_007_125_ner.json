        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000089",
    "sentence": "時荊州高季興叛，以兵攻其城，暉拒之，屢敗荊軍。",
    "entities": [
      {
        "text": "時荊州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "高季興",
