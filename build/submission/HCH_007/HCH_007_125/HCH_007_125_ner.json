      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000058",
    "sentence": "河池據關防之要，密邇邛、蜀，兵少勢孤，知濬撫士得宜，人皆盡力，故西疆無牧圉之失。",
    "entities": [
      {
