      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000056",
    "sentence": "晉高祖即位，用為奉國右廂都指揮使，領舒州刺史，從征範延光於鄴，遷宿州團練使，俄改隴州防禦使。",
    "entities": [
      {
        "text": "領舒州",
        "label": "LOC",
