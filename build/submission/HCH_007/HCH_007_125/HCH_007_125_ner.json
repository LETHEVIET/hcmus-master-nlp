      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000179",
    "sentence": "國初，就加同平章事，賜推誠奉義翊戴功臣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000180",
    "sentence": "顯德初，以郊丘禮畢，加檢校太尉，移鎮貝州。",
    "entities": [
      {
        "text": "移鎮貝州",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000181",
    "sentence": "世宗嗣位，加兼侍中，改彰德軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000182",
    "sentence": "滿歲受代，入奉朝請。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000183",
    "sentence": "顯德四年冬，以疾卒於東京之私第，年五十九。",
    "entities": [
      {
        "text": "顯德四年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000184",
    "sentence": "追封巢國公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000185",
    "sentence": "饒性寬厚，體貌詳雅，所蒞藩鎮，民皆便之。",
    "entities": [
      {
        "text": "所蒞藩鎮",
        "label": "LOC",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000186",
    "sentence": "每接賓佐，必怡聲緩氣，恂恂如也，故士君子亦以此多之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000187",
    "sentence": "孫方諫",
    "entities": [
      {
        "text": "孫方諫",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000188",
    "sentence": "孫方諫，鄚州清苑縣人也。",
    "entities": [
      {
        "text": "孫方諫",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "鄚州清苑縣",
