[
  {
    "sentence_id": "HCH_007_125_000001",
    "sentence": "趙暉",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000002",
    "sentence": "趙暉，字重光，澶州人也。",
    "entities": [
      {
        "text": "澶州",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000003",
    "sentence": "弱冠以驍果應募，始隸於莊宗帳前，與大梁兵經百餘戰，以功遷馬直軍使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000004",
    "sentence": "同光中，從魏王破蜀，命暉分統所部，南戍蠻陬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000005",
    "sentence": "明宗即位，征還，授禁軍指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000006",
    "sentence": "晉有天下，參掌衛兵，從馬全節圍安陸，佐杜重威戰宗城，皆有功，改奉國指揮使。",
    "entities": [
      {
        "text": "馬全節",
        "label": "PER",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000007",
    "sentence": "開運末，以部兵屯於陜，屬契丹入汴，慨然有憤激之意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000008",
    "sentence": "及聞漢祖建義於並門，乃與部將王晏、侯章戮力葉謀，逐契丹所命官屬，據有陜州，即時馳騎聞於漢祖。",
    "entities": [
      {
        "text": "據有陜州",
        "label": "LOC",
        "start": 32,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000009",
    "sentence": "〈 （《通鑒》：契丹主賜趙暉詔，即以為保義留後。暉斬契丹使者，焚其詔，遣支使河間趙矩奉表晉陽。） 〉 漢祖乃命暉為保義軍節度、陜虢等州觀察處置等使。",
    "entities": [
      {
        "text": "《通鑒》",
        "label": "TITLE",
        "start": 3,
        "end": 7
      },
      {
        "text": "陜虢等州",
