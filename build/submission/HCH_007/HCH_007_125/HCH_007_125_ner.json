        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000021",
    "sentence": "顯德元年，受代歸闕，以疾告老，授太子太師致仕，進封秦國公。",
    "entities": [
