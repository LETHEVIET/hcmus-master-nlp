        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000066",
    "sentence": "晉高祖為明宗將，署為帳中小校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000067",
    "sentence": "天福中，為六宅副使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000068",
    "sentence": "性負氣不遜，禁中與同列忿爭，出配義州軍。",
    "entities": [
      {
        "text": "出配義州",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000069",
    "sentence": "歲餘，為奉國指揮使，從契丹主至相州，遂令以本軍戍守。",
    "entities": [
      {
        "text": "從契丹主至相州",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000070",
    "sentence": "契丹主留高唐英為相州節度使。",
    "entities": [
      {
        "text": "留高唐英為相州",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000071",
    "sentence": "唐英善待繼宏，每候其第，則升堂拜繼宏之母，贈遺甚厚，倚若親戚，又給以兵仗，略無猜忌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000072",
    "sentence": "會契丹主死，漢祖趨洛，唐英遣使歸款，漢祖大悅，將厚待唐英。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000073",
    "sentence": "使未回，繼宏與指揮使樊暉等共殺唐英，繼宏自稱留後，令判官張易奉表於漢祖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000074",
    "sentence": "人或責以見利忘義，繼宏曰：「吾儕小人也，若不因利乘便，以求富貴，畢世以來，未可得志也。」及漢祖征杜重威至德清軍，繼宏來朝，乃正授節旄。",
    "entities": [
      {
        "text": "杜重威",
        "label": "PER",
        "start": 48,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_007_125_000075",
    "sentence": "是歲，就加檢校太傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000076",
    "sentence": "節度判官張易，每見繼宏不法，必切言之，繼宏以為輕己。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000077",
    "sentence": "乾祐中，因事誣奏殺之，尋又害觀察推官張制。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_125_000078",
    "sentence": "漢末，移鎮貝州，就加檢校太尉。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "移鎮貝州",
