[
  {
    "sentence_id": "HCH_007_132_000001",
    "sentence": "李茂貞",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000002",
    "sentence": "李茂貞，本姓宋，名文通，深州博野人。",
    "entities": [
      {
        "text": "深州",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000003",
    "sentence": "祖鐸，父端。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000004",
    "sentence": "唐乾符中，鎮州有博野軍，宿衛京師，屯於奉天，文通時隸本軍為市巡，累遷至隊長。",
    "entities": [
      {
        "text": "鎮州",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000005",
    "sentence": "黃巢犯闕，博野軍留於鳳翔，時鄭畋理兵於岐下，畋遣文通以本軍敗尚讓之眾於龍尾坡，以功為神策軍指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000006",
    "sentence": "朱玫之亂，唐僖宗再幸興元，文通扈蹕山南，論功第一，遷檢校太保、同平章事、洋蓬壁等州節度使，賜姓，名茂貞，僖宗親為制字曰正臣。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 11,
        "end": 12
      },
      {
        "text": "洋蓬壁等州",
        "label": "LOC",
        "start": 36,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000007",
    "sentence": "光啟二年 ，王行瑜殺朱玫於京師，李昌符擁兵於岐下，詔茂貞與陳佩等討之。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000008",
    "sentence": "三年，誅昌符，車駕還京，以茂貞為鳳翔節度使，加檢校太尉、兼待中、隴西郡王。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "隴西郡",
        "label": "LOC",
        "start": 32,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000009",
    "sentence": "大順二年 ，觀軍容使楊復恭得罪，奔山南，與楊守亮據興元叛，茂貞與王行瑜討平之。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "元",
        "label": "ORG",
        "start": 26,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000010",
    "sentence": "詔以宰相徐彥若鎮興元，茂貞違詔，表其假子繼徽為留後，堅請旄鉞，昭宗不得已而授之。",
    "entities": [
      {
        "text": "以宰相徐彥若鎮",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "元",
        "label": "ORG",
        "start": 9,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000011",
    "sentence": "自是茂貞恃勛恣橫，擅兵窺伺，頗幹朝政，始萌問鼎之志矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000012",
    "sentence": "既而逐涇原節度使張球、洋州節度使楊守忠、鳳州刺史滿存，皆奪據其地，奏請子弟為牧伯，朝廷不能制。",
    "entities": [
      {
        "text": "洋州",
        "label": "LOC",
        "start": 11,
        "end": 13
      },
      {
        "text": "鳳州",
        "label": "LOC",
        "start": 20,
        "end": 22
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000013",
    "sentence": "大臣奏議言其過者，茂貞即上章論列，辭旨不遜，奸邪者因之附麗，遂成朋黨，朝政於是隳焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000014",
    "sentence": "昭宗性英俊，不任其逼，欲加討伐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000015",
    "sentence": "乾寧初，命宰臣杜讓能調發軍旅，師未越境，為茂貞所敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000016",
    "sentence": "茂貞乘勝進屯三橋，京師大震，士庶奔散，天子乃誅中尉西門君遂、李周潼等謝之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000017",
    "sentence": "茂貞嚴兵不解，勢將指闕，抗言讓能之罪，誅之方罷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000018",
    "sentence": "及韋昭度、李谿為相，茂貞聽崔昭緯之邪說，復沮其事，表昭度等無相業，不可置之臺司，恐亂天下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000019",
    "sentence": "詔報曰：「軍旅之事，吾則與藩臣圖之，朝廷命相，出自朕懷。」又請授王珙河中節度使，詔報曰：「太原表先至，已許王珂，不可追改。」 乾寧二年 五月，茂貞與王行瑜、韓建稱兵入覲，京師震恐，天子禦樓待之，抗表請殺宰相韋昭度、李谿以謝天下，移王珙於河中。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 65,
        "end": 67
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000020",
    "sentence": "既還，留其假子繼鵬宿衛，即閻珪也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000021",
    "sentence": "時後唐武皇上表，請討三鎮以寧關輔。",
    "entities": [
      {
        "text": "請討三鎮以寧關",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000022",
    "sentence": "是歲七月，太原之師至河中，繼鵬與中尉景宣之子繼晟迫車駕幸鳳翔，昭宗曰：「太原軍未至，鑾輿不可輒動，朕與諸王固守大內，卿等安輯京師，如太原實至，吾可以方略制之。」繼鵬與景宣、中尉駱全權因燔燒東市，中夜大噪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000023",
    "sentence": "昭宗登承天門樓避亂，令捧日都將李雲守樓下，繼鵬率眾攻雲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000024",
    "sentence": "昭宗憑軒慰諭，繼鵬彎弧大呼，矢拂禦衣，中樓桷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000025",
    "sentence": "侍臣掖昭宗下樓還宮，繼鵬即縱火攻宮門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000026",
    "sentence": "昭宗詔諸王謀其所向，李雲奏曰：「事急矣，請且幸臣營。」雲乃與扈蹕都將李君慶衛昭宗出啟夏門，駐華嚴寺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000027",
    "sentence": "晡晚，出幸南山之莎城，駐於石門山之佛寺。",
    "entities": [
      {
        "text": "出幸南山之莎城",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000028",
    "sentence": "是月，武皇至渭北，遣副使王瑰奉表行在，昭宗以武皇為行營都統，進討邠、岐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000029",
    "sentence": "茂貞懼，斬繼鵬、繼晟，上表待罪，昭宗原之，武皇曰：「不誅茂貞，關輔無由寧謐。」時附茂貞者奏云：「若太原盡殄邠、岐，必入關輔，京師憂未艾也。」乃詔武皇與茂貞和。",
    "entities": [
      {
        "text": "必入關",
        "label": "LOC",
        "start": 57,
        "end": 60
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000030",
    "sentence": "及行瑜誅，武皇班師，茂貞怨望驕橫如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000031",
    "sentence": "明年五月，制授茂貞東川節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000032",
    "sentence": "仍命通王、覃王治禁軍於闕下，如茂貞違詔，即討之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000033",
    "sentence": "茂貞懼，將赴鎮。",
    "entities": [
      {
        "text": "將赴鎮",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000034",
    "sentence": "王師至興平，夜自驚潰，茂貞因出乘之，官軍大敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000035",
    "sentence": "車駕倉卒出幸華州，茂貞之眾因犯京師，焚燒宮闕，大掠坊市而去，自此長安大內盡為丘墟矣。",
    "entities": [
      {
        "text": "駕倉卒出幸華州",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000036",
    "sentence": "四年，昭宗復命宰臣孫偓統軍進討，韓建諫止，令茂貞上章請雪。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000037",
    "sentence": "光化中，加茂貞尚書令、岐王，令其子繼筠以兵宿衛。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000038",
    "sentence": "天復元年十月，梁祖攻同、華，勢逼京師。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000039",
    "sentence": "十一月六日，繼筠與中尉韓全誨劫昭宗幸鳳翔，茂貞遂與全誨矯詔征兵天下，將討梁祖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000040",
    "sentence": "宰相崔允召梁祖引四鎮之兵屯岐下，重溝復壘圍守。",
    "entities": [
      {
        "text": "允召梁祖引四鎮",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000041",
    "sentence": "三年，茂貞山南諸州盡為王建所陷，涇、原、秦、隴、邠、鄜、延、夏皆降於汴。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "茂貞山南諸州",
        "label": "LOC",
        "start": 3,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000042",
    "sentence": "茂貞獨據孤城，內外援絕，乃請車駕還京，求和於汴，即斬韓全誨等二十人首級送於梁祖。",
    "entities": [
      {
        "text": "茂貞獨據孤城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000043",
    "sentence": "自是兵力殫盡，垂翅不振，懼梁祖復討，請落尚書令，許之。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000044",
    "sentence": "〈 （《九國誌·李彥琦傳》：彥琦本姓楊氏，鳳翔李茂貞委以心腹之任，易姓李氏，齒於諸子。後昭宗西幸，梁祖迎駕，攻逼岐下者累年，及昭宗東還，長圍方解。大軍之後，府庫空竭，彥琦請使甘州以通回鶻，往復二載，美玉、名馬相繼而至，所獲萬計，茂貞賴之。） 〉 及梁祖建號，茂貞與王建會兵於太原，誌圖興復，竟無成功。",
    "entities": [
      {
        "text": "《九國誌·李彥琦傳》",
        "label": "TITLE",
        "start": 3,
        "end": 13
      },
      {
        "text": "彥琦請使甘州",
        "label": "LOC",
        "start": 83,
        "end": 89
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000045",
    "sentence": "茂貞疆土危蹙，不遂僭竊之志，但開岐王府，署天官，目妻為皇后，鳴鞘掌扇，宣詞令，一如王者之制，然尚行昭宗之正朔焉。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000046",
    "sentence": "茂貞鼠形，多智數，軍旅之事，一經耳目，無忘之者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000047",
    "sentence": "性至寬，有部將符昭者，人或告其謀變，茂貞親至其家，去其爪牙，熟寢經宿而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000048",
    "sentence": "軍士有鬥而訴者，茂貞曰：「吃令公一碗不托，與爾和解。」遂致上下服之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000049",
    "sentence": "尤善事母，母終，茂貞哀毀幾滅性，聞者嘉之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000050",
    "sentence": "但禦軍整眾，都無紀律，當食則造庖廚，往往席地而坐，內外持管鑰者，亦呼為司空太保，與夫細柳、大樹之威名，蓋相遠矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000051",
    "sentence": "及莊宗平梁，茂貞自為季父，以書賀之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000052",
    "sentence": "及聞莊宗入洛，懼不自安，方上表稱臣，尋遣其子繼嚴來朝，詔茂貞仍舊官，進封秦王，所賜詔敕不名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000053",
    "sentence": "又以茂貞宿望耆老，特加優禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000054",
    "sentence": "及疾篤，遣中使遣醫藥問訊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000055",
    "sentence": "同光二年 夏四月薨，年六十九。",
    "entities": [
      {
        "text": "同光二年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000056",
    "sentence": "謚曰忠敬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000057",
    "sentence": "子從嚴嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000058",
    "sentence": "從嚴，茂貞之長子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000059",
    "sentence": "未冠，授諮議參軍，賜緋魚袋，尋還領彭州副使、鳳翔衙內都指揮使。",
    "entities": [
      {
        "text": "尋還領彭州",
        "label": "LOC",
        "start": 14,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000060",
    "sentence": "天復中，自秦王府行軍司馬、檢校太傅出為涇州兩使留後。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "校太傅出為涇州",
        "label": "LOC",
        "start": 14,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000061",
    "sentence": "茂貞尋承制加開府儀同三司、檢校太尉、兼待中，四鎮北庭行軍、彰義軍節度使。",
    "entities": [
      {
        "text": "四鎮",
        "label": "LOC",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000062",
    "sentence": "及唐莊宗平梁，茂貞令從嚴入覲，制加從嚴兼中書令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000063",
    "sentence": "俄而茂貞薨，遣奏權知鳳翔軍府事，詔起復，授鳳翔節度、管內觀察處置等使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000064",
    "sentence": "三年九月，以魏王繼岌伐蜀，詔充供軍轉運應接使。",
