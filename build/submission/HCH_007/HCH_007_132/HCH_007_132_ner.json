      {
        "text": "元年",
        "label": "TME",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000179",
    "sentence": "乾德五年秋，卒於鎮。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "卒於鎮",
