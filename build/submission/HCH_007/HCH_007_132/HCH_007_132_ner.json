  },
  {
    "sentence_id": "HCH_007_132_000105",
    "sentence": "逾年，以太子太傅致仕。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000106",
    "sentence": "同光中，復名茂勛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000107",
    "sentence": "天成初，以疾卒於洛陽。",
