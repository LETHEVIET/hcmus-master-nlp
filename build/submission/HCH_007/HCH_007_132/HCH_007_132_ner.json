        "start": 25,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000174",
    "sentence": "開運元年 春，詔以彜興為契丹西南面招討使。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000175",
