      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000125",
    "sentence": "唐同光中，檢校太保，充保大軍兩使留後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000126",
    "sentence": "萬興卒，允韜自理所奔喪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000127",
    "sentence": "天成初，起復檢校太傅，充延州節度使。",
    "entities": [
      {
        "text": "充延州",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000128",
    "sentence": "長興元年 ，移鎮邢州，頃之，為右龍武統軍，未幾，授滑州節度使。",
    "entities": [
      {
        "text": "移鎮邢州",
        "label": "LOC",
        "start": 6,
        "end": 10
      },
      {
        "text": "授滑州",
        "label": "LOC",
        "start": 24,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000129",
    "sentence": "清泰二年 八月，卒於任，年四十二。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000130",
    "sentence": "詔贈太師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000131",
    "sentence": "韓遜",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000132",
    "sentence": "韓遜，本靈州之列校也。",
    "entities": [
      {
        "text": "本靈州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000133",
    "sentence": "會唐季之亂，因據有其地，朝廷乃授以節鉞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000134",
    "sentence": "梁初，累加檢校太尉、同平章事。",
    "entities": [
      {
        "text": "梁",
        "label": "ORG",
        "start": 0,
        "end": 1
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000135",
    "sentence": "開平中，梁將劉知俊自同州叛歸鳳翔，李茂貞以地褊不能容，乃借兵以窺靈武，且圖牧圉之地。",
    "entities": [
      {
        "text": "將劉知俊自同州",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000136",
    "sentence": "知俊乃帥邠、岐、秦、涇之師數萬攻遜於靈州，遜竭力以拒之，久之，知俊遁去。",
    "entities": [
      {
        "text": "數萬攻遜於靈州",
        "label": "LOC",
        "start": 13,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000137",
    "sentence": "梁祖嘉之，自是累加官至中書令，封潁川郡王。",
    "entities": [
      {
        "text": "封潁川郡",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000138",
    "sentence": "遜亦善於為理，部民請立生祠堂於其地，梁祖許之，仍詔禮部待郎薛廷珪撰文以賜之，其廟至今在焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000139",
    "sentence": "貞明初，遜卒於鎮。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "遜卒於鎮",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000140",
    "sentence": "洙，遜之子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000141",
    "sentence": "遜卒，三軍推為留後，梁末帝聞之，起復正授靈武節度使、特進、檢校太傅、同平章事。",
    "entities": [
      {
        "text": "梁",
        "label": "ORG",
        "start": 10,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000142",
    "sentence": "貞明四年 春，靈武將軍尚貽敏等上言，洙已服闋，乞落起復。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000143",
    "sentence": "梁末帝令中書商量，宰臣奏曰：「舊例藩鎮落起復，如先人已是一品階，即與加爵；如未是一品階，即合加階。」乃授洙開府儀同三司。",
    "entities": [
      {
        "text": "梁",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "舊例藩鎮",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000144",
    "sentence": "唐莊宗、明宗累加官爵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000145",
    "sentence": "天成四年 夏，洙卒，朝廷以其弟澄為朔方軍節度觀察留後。",
    "entities": [
      {
        "text": "天成四年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000146",
    "sentence": "是歲，有列校李賓作亂，部內不安，乃遣使上表請帥於朝廷，明宗命前磁州刺史康福為朔方河西等軍節度、靈威雄警涼等州觀察處置度支、溫池榷稅等使，仍遣福領兵萬人赴鎮，其後靈武遂受代焉。",
    "entities": [
      {
        "text": "明宗命前磁州",
        "label": "LOC",
        "start": 27,
        "end": 33
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 33,
        "end": 35
      },
      {
        "text": "靈威雄警涼等州",
        "label": "LOC",
        "start": 47,
        "end": 54
      },
      {
        "text": "福領兵萬人赴鎮",
        "label": "LOC",
        "start": 70,
        "end": 77
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000147",
    "sentence": "李仁福",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000148",
    "sentence": "李仁福，世為夏州牙將，本拓拔氏之族也。",
    "entities": [
      {
        "text": "世為夏州",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000149",
    "sentence": "唐乾符中，有拓拔思恭為夏州節度使，廣明之亂，唐僖宗在蜀，詔以思恭為京城西北收復都統，預破黃巢有功，僖宗賜姓，故仁福亦以李為氏。",
    "entities": [
      {
        "text": "拓拔思恭為夏州",
        "label": "LOC",
        "start": 6,
        "end": 13
      },
      {
        "text": "詔以思恭為京城",
        "label": "LOC",
        "start": 28,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000150",
    "sentence": "思恭卒，弟思諫繼之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000151",
    "sentence": "梁 開平元年 ，授思諫檢校太尉、兼待中。",
    "entities": [
      {
