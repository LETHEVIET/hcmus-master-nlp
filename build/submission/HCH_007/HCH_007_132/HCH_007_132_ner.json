      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000116",
    "sentence": "天祐五年 冬，敬璋卒，崇本以其愛將劉萬子為鄜延帥，萬子以兇暴而失士心。",
    "entities": [
