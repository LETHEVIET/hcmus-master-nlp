        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000121",
    "sentence": "莊宗定河洛，萬興來朝，預郊禮陪位，既還鎮，復以舊爵授之。",
    "entities": [
      {
        "text": "既還鎮",
        "label": "LOC",
        "start": 17,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000122",
    "sentence": "同光三年 十二月，卒於位，以其子允韜權典留後。",
    "entities": [
