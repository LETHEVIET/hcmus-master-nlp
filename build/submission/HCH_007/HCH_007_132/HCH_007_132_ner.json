        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000166",
    "sentence": "彜超亦上表謝罪，乃授彜超檢校司徒，充定難軍節度使，既而修貢如初。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000167",
    "sentence": "清泰二年 ，卒於鎮。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "卒於鎮",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_132_000168",
    "sentence": "弟彜興襲其位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000169",
    "sentence": "彜興，本名彜殷，宋受命之初，以犯廟諱故改之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_132_000170",
    "sentence": "彜超既卒，時彜興為夏州行軍司馬，三軍推為留後，唐末帝聞之，正授定難軍節度使。",
    "entities": [
      {
        "text": "時彜興為夏州",
