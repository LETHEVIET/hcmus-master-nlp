      }
    ]
  },
  {
    "sentence_id": "HCH_007_029_000002",
    "sentence": "帝還魏州，命昭義軍節度使李嗣昭權知幽州軍府事。",
    "entities": [
      {
        "text": "帝還魏州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "李嗣昭權知幽州",
        "label": "LOC",
        "start": 12,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_029_000003",
    "sentence": "三月，帝兼領幽州，遣近臣李紹宏提舉府事。",
    "entities": [
      {
        "text": "帝兼領幽州",
        "label": "LOC",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_029_000004",
    "sentence": "夏四月，梁將賀瑰圍德勝南城，百道攻擊，復以艨艟扼斷津渡。",
    "entities": [
      {
        "text": "賀瑰圍德勝南城",
        "label": "LOC",
        "start": 6,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_029_000005",
    "sentence": "帝馳而往，陣於北岸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_029_000006",
    "sentence": "南城守將氏延賞告急，且言矢石將盡。",
    "entities": [
      {
        "text": "南城",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_029_000007",
    "sentence": "帝以重賄召募能破賊艦者，於是獻技者數十，或言能吐火焚舟，或言能禁咒兵刃，悉命試之，無驗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_029_000008",
    "sentence": "帝憂形於色，親從都將王建及進曰：「臣請效命。」乃以巨索連舟十艘，選效節勇士三百人，持斧被鎧，鼓枻而進，至中流。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_029_000009",
    "sentence": "梁樓船三層，蒙以牛革，懸板為楯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_029_000010",
    "sentence": "建及率持斧者入艨艟間，斬其竹笮，破其懸楯；又於上流取甕數百，用竹笮維之，積薪於上，灌以脂膏，火發亙空；又以巨艦載甲士，令乘煙鼓噪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_029_000011",
    "sentence": "梁之樓船斷絏而下，沈溺者殆半。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_029_000012",
    "sentence": "軍既得渡，梁軍乃退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_029_000013",
    "sentence": "命騎軍追襲至濮陽，俘斬千計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_029_000014",
    "sentence": "賀瑰由此飲氣遘疾而卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_029_000015",
    "sentence": "秋七月，帝歸晉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_029_000016",
    "sentence": "八月，梁將王瓚帥眾數萬自黎陽渡河，營於楊村，造舟為梁，以通津路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_029_000017",
    "sentence": "冬十月，帝自晉陽至魏州，發徒數萬以廣德勝北城，自是，日與梁軍接戰。",
    "entities": [
      {
        "text": "帝自晉陽至魏州",
        "label": "LOC",
        "start": 4,
        "end": 11
      },
      {
        "text": "萬以廣德勝北城",
        "label": "LOC",
        "start": 15,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_029_000018",
    "sentence": "十二月戊戌，帝軍於河南，夜伏步兵於潘張村梁軍寨下，以騎軍掠其餉運，擒其斥候。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_029_000019",
    "sentence": "梁王瓚結陣以待，帝軍以鐵騎突之，諸軍繼進，梁軍大奔，赴水死者甚眾，瓚走保北城。",
    "entities": [
      {
        "text": "瓚走保北城",
        "label": "LOC",
        "start": 33,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_007_029_000020",
    "sentence": "天祐十七年春，幽州民於田中得金印，文曰：「關中龜印」，李紹宏獻於行台。",
    "entities": [
      {
        "text": "十七年",
        "label": "TME",
        "start": 2,
        "end": 5
      },
      {
        "text": "幽州",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_029_000021",
    "sentence": "秋七月，梁將劉鄩、尹皓寇同州。",
    "entities": [
      {
        "text": "尹皓寇同州",
        "label": "LOC",
        "start": 9,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_029_000022",
    "sentence": "先是，河中節度使朱友謙取同州，以其子令德主留務，請梁主降節。",
    "entities": [
      {
        "text": "使朱友謙取同州",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_029_000023",
    "sentence": "梁主怒，不與，遂請旄節於帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_029_000024",
    "sentence": "梁主乃遣劉鄩與華州節度使尹皓帥兵圍同州，友謙來告難，帝遣蕃漢總管李存審、昭義節度使李嗣昭、代州刺史王建及率師赴援。",
    "entities": [
      {
        "text": "乃遣劉鄩與華州",
        "label": "LOC",
        "start": 2,
        "end": 9
      },
      {
        "text": "尹皓帥兵圍同州",
        "label": "LOC",
        "start": 12,
        "end": 19
      },
      {
        "text": "代州",
