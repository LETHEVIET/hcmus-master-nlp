  },
  {
    "sentence_id": "HCH_007_097_000060",
    "sentence": "一日，逢留司御史於天津橋，從兵百人，不分路而過，排御史於水中，從賓紿奏其酒醉，其兇傲如此。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000061",
    "sentence": "及范延光據鄴城叛，詔從賓為副部署使，從楊光遠同討延光。",
    "entities": [
      {
        "text": "及范延光據鄴城",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "楊光遠",
        "label": "PER",
        "start": 19,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000062",
    "sentence": "會延光使人誘從賓，從賓時在河陽，乃起兵以應之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000063",
    "sentence": "先害皇子重信，及入洛，又害皇子重乂，取內庫金帛以給部伍，因東據汜水關，且欲觀望軍勢。",
    "entities": [
      {
        "text": "因東據汜水關",
        "label": "LOC",
        "start": 28,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000064",
    "sentence": "高祖命杜重威、侯益分兵討之，從賓大敗，乘馬入河，溺水而死焉。",
    "entities": [
      {
        "text": "杜重威",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000065",
    "sentence": "張延播",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000066",
    "sentence": "張延播者，汶陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000067",
    "sentence": "始為郡之牙將，唐同光初，明宗下其城，因收隸左右。",
    "entities": [
      {
        "text": "始為郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "明宗下其城",
        "label": "LOC",
        "start": 12,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000068",
    "sentence": "天成中，累授檢校司空、兩河發運營田使、柳州刺史。",
    "entities": [
      {
        "text": "柳州",
        "label": "LOC",
        "start": 19,
        "end": 21
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000069",
    "sentence": "長興元年，出牧蔡州，加檢校司徒，入為左領軍衛大將軍，充客省使。",
    "entities": [
      {
        "text": "出牧蔡州",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 22,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000070",
    "sentence": "伐蜀之役，命為馬軍都監。",
    "entities": [
      {
        "text": "蜀",
        "label": "ORG",
        "start": 1,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000071",
    "sentence": "三年，遷鳳州防禦使、西面水陸轉運使。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "遷鳳州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000072",
    "sentence": "高祖即位，除東都副留守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000073",
    "sentence": "車駕幸汴，遣兼洛京巡檢使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000074",
    "sentence": "張從賓作亂，令延播知河南府事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000075",
    "sentence": "從賓敗，伏誅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000076",
    "sentence": "楊光遠",
    "entities": [
      {
        "text": "楊光遠",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000077",
    "sentence": "楊光遠，小字阿檀，及長，止名檀，唐天成中，以明宗改御名為亶，以偏傍字犯之，始改名光遠，字德明，其先沙陀部人也。",
    "entities": [
      {
        "text": "楊光遠",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000078",
    "sentence": "父阿噔啜，後改名瑊，事唐武皇為隊長。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000079",
    "sentence": "光遠事莊宗為騎將，唐天祐中，莊宗遣振武節度使周德威討劉守光於幽州，因令光遠隸於德威麾下。",
    "entities": [
      {
        "text": "討劉守光於幽州",
        "label": "LOC",
        "start": 25,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000080",
    "sentence": "後與德威拒契丹於新州，一軍以深入致敗，因傷其臂，遂廢，罷於家。",
    "entities": [
      {
        "text": "威拒契丹於新州",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000081",
    "sentence": "莊宗即位，思其戰功，命為幽州馬步軍都指揮使、檢校尚書右僕射，戍瓦橋關久之。",
    "entities": [
      {
        "text": "命為幽州",
        "label": "LOC",
        "start": 10,
        "end": 14
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 24,
        "end": 26
      },
      {
        "text": "戍瓦橋關",
        "label": "LOC",
        "start": 30,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000082",
    "sentence": "明宗朝，歷媯、瀛、易、冀四州刺史。",
    "entities": [
      {
        "text": "冀四州",
        "label": "LOC",
        "start": 11,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000083",
    "sentence": "光遠雖不識字，然有口辯，通於吏理，在郡有政聲，明宗頗重之。",
    "entities": [
      {
        "text": "在郡",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000084",
    "sentence": "長興中，契丹有中山之敗，生擒其將紮拉等數十人，送於闕下，其後契丹既通和，遣使乞歸之，明宗與大臣謀議，特放還蕃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000085",
    "sentence": "一日，召光遠於便殿言其事，光遠曰：「紮拉等北土之善戰者，彼失之如喪手足；又在此累年，備諳中國事，若放還非便。」明宗曰：「蕃人重盟誓，既通歡好，必不相負。」光遠曰：「臣恐後悔不及也。」明宗遂止，深嘉其抗直。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000086",
    "sentence": "後自振武節度使移鎮中山，累加檢校太傅，將兵戍蔚州。",
    "entities": [
      {
        "text": "振武節度使移鎮",
        "label": "LOC",
        "start": 2,
        "end": 9
      },
      {
        "text": "將兵戍蔚州",
        "label": "LOC",
        "start": 19,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000087",
    "sentence": "高祖舉義於太原，唐末帝遣光遠與張敬達屯兵於城下，俄而契丹大至，為其所敗，圍其寨久之，軍中糧絕，光遠乃與次將安審琦等殺敬達，擁眾歸命。",
    "entities": [
      {
        "text": "唐",
        "label": "ORG",
        "start": 8,
        "end": 9
      },
      {
        "text": "張敬達屯兵於城",
        "label": "LOC",
        "start": 15,
        "end": 22
      },
      {
        "text": "安審琦",
        "label": "PER",
        "start": 53,
        "end": 56
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000088",
    "sentence": "從高祖入洛，加檢校太尉，充宣武軍節度使、同平章事，判六軍諸衛事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000089",
    "sentence": "是時，光遠每對高祖，常悒然不樂，高祖慮有不足，密遣近臣訊之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000090",
    "sentence": "光遠附奏曰：「臣貴為將相，非有不足，但以張生鐵死得其所，臣弗如也，衷心內愧，是以不樂。」生鐵，蓋敬達之小字也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000091",
    "sentence": "高祖聞其言，以光遠為忠純之最者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000092",
    "sentence": "其實光遠故為其言，以邀高祖之重信也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000093",
    "sentence": "明年，范延光據鄴城叛，高祖命光遠率師討之。",
    "entities": [
      {
        "text": "范延光據鄴城",
        "label": "LOC",
        "start": 3,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000094",
    "sentence": "將濟河，會滑州軍亂，時軍眾欲推光遠為主。",
    "entities": [
      {
        "text": "會滑州",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000095",
    "sentence": "光遠曰：「自古有折臂天子乎？且天子豈公輩販弄之物？晉陽之降，乃勢所窮迫，今若為之，直反賊也。」由是其下惕然，無復言者。",
    "entities": [
      {
        "text": "晉",
        "label": "ORG",
        "start": 25,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000096",
    "sentence": "高祖聞之，尤加寵重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000097",
    "sentence": "光遠既圍延光，尋授魏博行府節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000098",
    "sentence": "兵柄在手，以為高祖懼己，稍干預朝政，或抗有所奏，高祖亦曲從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000099",
    "sentence": "復下詔以其子承祚尚長安公主，次子承信皆授美官。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 9,
        "end": 11
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000100",
    "sentence": "恩渥殊等，為當時之冠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000101",
    "sentence": "桑維翰為樞密使，往往彈射其事，光遠心銜之。",
    "entities": [
      {
        "text": "桑維翰",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000102",
    "sentence": "及延光降，光遠入朝，面奏維翰擅權。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000103",
    "sentence": "高祖以光遠方有功於國，乃出維翰鎮相州，光遠為西京留守，兼鎮河陽，因罷其兵權。",
    "entities": [
      {
        "text": "乃出維翰鎮相州",
        "label": "LOC",
        "start": 11,
        "end": 18
      },
      {
        "text": "兼鎮",
        "label": "LOC",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000104",
    "sentence": "光遠由此怨望，潛貯異志，多以珍玩奉契丹，訴己之屈，又私養部曲千餘人，撓法犯禁，河、洛之人，恒如備盜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000105",
    "sentence": "尋冊拜太尉、兼中書令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000106",
    "sentence": "時范延光致仕，輦囊裝妓妾，居於河陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000107",
    "sentence": "光遠利其奇貨，且慮為子孫之讎，因奏延光不家汴、洛，出舍外藩，非南走淮夷，則北走契丹，宜早除之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000108",
    "sentence": "高祖以許之不死，鐵券在焉，持疑未允。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000109",
    "sentence": "光遠乃遣子承勛以甲士圍其第，逼令自裁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000110",
    "sentence": "延光曰：「天子在上，安得如此！」乃遣使者乞移居洛下，行及河橋，擯於流而溺殺之，矯奏雲延光自投河，朝廷以適會其意，弗之理。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000111",
    "sentence": "後逾歲入覲，高祖為置曲宴，教坊伶人以光遠暴斂重賦，因陳戲譏之，光遠殊無慚色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000112",
    "sentence": "高祖謂光遠曰：「元城之役，卿左右皆立功，未曾旌賞，今各與一郡，俾厘任以榮之。」因命為刺史者凡數人。",
    "entities": [
      {
        "text": "元城",
        "label": "LOC",
        "start": 8,
        "end": 10
      },
      {
        "text": "今各與一郡",
        "label": "LOC",
        "start": 25,
        "end": 30
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 42,
        "end": 44
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000113",
    "sentence": "時王建立自青州移鎮上黨，乃以光遠為平盧軍節度使，封東平王。",
    "entities": [
      {
        "text": "移鎮",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000114",
    "sentence": "光遠面奏，請與長子同行，尋授承勛萊州防禦使。",
    "entities": [
      {
        "text": "尋授承勛萊州",
        "label": "LOC",
        "start": 12,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000115",
    "sentence": "及赴任，仆從妓妾至千餘騎，滿盈僭侈，為方嶽之最。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000116",
    "sentence": "下車之後，惟以刻剝為事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000117",
    "sentence": "少帝嗣位，冊拜太師，封壽王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000118",
    "sentence": "〈 （《宋史·馬仁鎬傳》：晉天福中，青州楊光遠將圖不軌，以仁鎬為節度副使，伺其動靜。歷二年，或譖仁鎬於朝，改護國軍行軍司馬。仁鎬至河中數月，光遠反書聞。） 〉 後因景延廣上言，請取光遠麾下所借官馬二百匹，光遠怒曰：「此馬先帝賜我，何以復取？是疑我也。」遂遣人潛召取子承祚自單州奔歸，朝廷乃就除淄州刺史，以從其便。",
    "entities": [
