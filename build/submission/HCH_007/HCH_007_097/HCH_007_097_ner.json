  },
  {
    "sentence_id": "HCH_007_097_000002",
    "sentence": "范延光，字子環，鄴郡臨漳人也。",
    "entities": [
      {
        "text": "鄴郡",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000003",
    "sentence": "少隸於郡牙，唐明宗牧相州，收為親校。",
    "entities": [
      {
        "text": "少隸於郡",
        "label": "LOC",
