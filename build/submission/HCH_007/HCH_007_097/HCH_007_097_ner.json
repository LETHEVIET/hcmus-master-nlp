      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000025",
    "sentence": "高祖入洛，尋封臨清王，以寬其反側。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000026",
    "sentence": "後延光擅殺齊州防禦使秘瓊，而聚兵部下，復收部內刺史入城，高祖甚疑之，乃東幸夷門。",
    "entities": [
      {
        "text": "後延光擅殺齊州",
