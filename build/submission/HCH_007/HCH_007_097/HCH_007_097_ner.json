        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000008",
    "sentence": "中夜至河上，為梁兵所獲，送夷門下獄，榜笞數百，威以白刃，終不泄其事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000009",
    "sentence": "復為獄吏所護，在獄半年，不復理問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_097_000010",
    "sentence": "及莊宗將至汴城，獄吏即去其桎梏，拜謝而出之，乃見於路側。",
    "entities": [
      {
        "text": "及莊宗將至汴城",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_097_000011",
    "sentence": "莊宗喜，授銀青光祿大夫、檢校工部尚書。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "尚書",
