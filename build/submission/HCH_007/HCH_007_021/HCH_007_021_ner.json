        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000175",
    "sentence": "貞明二年四月，改鄭州防禦使。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "改鄭州",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000176",
    "sentence": "三年十二月，授西面行營馬軍都指揮使，加檢校太傅，依前鄭州防禦使。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "依前鄭州",
        "label": "LOC",
        "start": 24,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000177",
    "sentence": "頃之，授行營諸軍左廂馬軍都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_021_000178",
    "sentence": "五年五月，遷許州兩使留後，軍職如故。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "遷許州",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000179",
    "sentence": "六年正月，正授許州匡國軍節度使，充散指揮都頭都軍使，進封開國侯。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "正授許州",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000180",
    "sentence": "未幾，授北面行營副招討使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_021_000181",
    "sentence": "七年正月，移領滑州。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "移領滑州",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000182",
    "sentence": "龍德三年四月晦，晉師陷鄆州，中外大恐。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "晉師陷鄆州",
        "label": "LOC",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000183",
    "sentence": "五月，以彥章代戴思遠為北面招討使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_021_000184",
    "sentence": "拜命之日，促裝以赴滑台，遂自楊村寨浮河而下，水陸俱進，斷晉人德勝之浮梁，攻南城，拔之。",
    "entities": [
      {
        "text": "攻南城",
        "label": "LOC",
        "start": 36,
        "end": 39
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000185",
    "sentence": "晉人遂棄北城，並軍保楊劉。",
    "entities": [
      {
        "text": "晉人遂棄北城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000186",
    "sentence": "彥章以舟師沿流而下，晉人盡徹北城，拆屋木編筏，置步軍於其上，與彥章各行一岸。",
    "entities": [
      {
        "text": "晉人盡徹北城",
        "label": "LOC",
        "start": 10,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000187",
    "sentence": "每遇轉灘水彙，即中流交鬥，流矢雨集，或舟筏覆沒，比及楊劉，凡百餘戰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_021_000188",
    "sentence": "彥章急攻楊劉，晝夜不息，晉人極力固守，垂陷者數四。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_021_000189",
    "sentence": "六月，晉王親援其城，彥章之軍，重壕復壘，晉人不能入。",
    "entities": [
      {
        "text": "晉王親援其城",
        "label": "LOC",
        "start": 3,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000190",
    "sentence": "晉王乃於博州東岸築壘，以應鄆州。",
    "entities": [
      {
        "text": "晉王乃於博州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "以應鄆州",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000191",
    "sentence": "彥章聞之，馳軍而至，急攻其柵，自旦及午，其城將拔，會晉王以大軍來援，彥章及退。",
    "entities": [
      {
        "text": "其城",
        "label": "LOC",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000192",
    "sentence": "七月，晉王至楊劉，彥章軍不利，遂罷彥章兵權，詔令歸闕，以段凝為招討使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_021_000193",
    "sentence": "先是，趙、張二族撓亂朝政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_021_000194",
    "sentence": "彥章深惡之，性復剛直，不能緘忍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_021_000195",
    "sentence": "及授招討之命，因謂所親曰：「待我立功之後，回軍之日，當盡誅奸臣，以謝天下。」趙、張聞之，私相謂曰：「我輩寧死於沙陀之手，不當為彥章所殺。」因協力以傾之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_021_000196",
    "sentence": "時段凝以賄賂交結，自求兵柄，素與彥章不協，潛害其功，陰行逗撓，遂至王師不利，竟退彥章而用段凝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_021_000197",
    "sentence": "未及十旬，國以之亡矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_021_000198",
    "sentence": "是歲秋九月，朝廷聞晉人將自兗州路出師，末帝急遣彥章領保鑾騎士數千於東路守捉。",
    "entities": [
      {
        "text": "聞晉人將自兗州",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000199",
    "sentence": "且以鄆州為敵人所據，因圖進取，令張漢傑為監軍。",
    "entities": [
      {
        "text": "且以鄆州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000200",
    "sentence": "一日，彥章渡汶，以略鄆境，至遞坊鎮，為晉人所襲，彥章退保中都。",
    "entities": [
      {
        "text": "至遞坊鎮",
        "label": "LOC",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000201",
    "sentence": "十月四日，晉王以大軍至，彥章以眾拒戰，兵敗，為晉將夏魯奇所擒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_021_000202",
