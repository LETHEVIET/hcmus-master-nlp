      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000169",
    "sentence": "五年三月，朝廷議割魏州為兩鎮，慮魏人不從，遣彥章率精騎五百屯鄴城，駐於金波亭，以備非常。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "朝廷議割魏州",
