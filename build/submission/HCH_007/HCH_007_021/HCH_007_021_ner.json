        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000164",
    "sentence": "乾化元年，改行營左先鋒馬軍使，加金紫光祿大夫、檢校司空，依前左監門衛上將軍。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
