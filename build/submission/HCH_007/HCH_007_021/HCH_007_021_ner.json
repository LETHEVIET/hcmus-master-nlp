        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_021_000167",
    "sentence": "未幾，改先鋒步軍都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_021_000168",
    "sentence": "四年，為澶州刺史，進封開國伯。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
