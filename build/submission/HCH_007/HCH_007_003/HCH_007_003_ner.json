        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_003_000077",
    "sentence": "馬殷奏破淮寇；靜海軍節度使曲裕卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_003_000078",
    "sentence": "七月丙申，以靜海軍行營司馬權知留後曲顥起復為安南都護，充節度使。",
    "entities": [
