      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000064",
    "sentence": "且言劉知俊三敗汴軍於寧州，靈、夏危蹙，岐、隴之師大舉，決取河西。",
    "entities": [
      {
        "text": "劉知俊",
