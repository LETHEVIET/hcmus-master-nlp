        "end": 16
      },
      {
        "text": "千騎致師於柏鄉",
        "label": "LOC",
        "start": 18,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000086",
    "sentence": "梁將怒，悉其軍結陣而來，德威與之轉戰至高邑南，梁軍列陣，橫亙六七里。",
    "entities": [
      {
        "text": "與之轉戰至高邑",
        "label": "LOC",
        "start": 14,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000087",
    "sentence": "時帝軍未成列，李存璋引諸軍陣於野河之上，梁以五百人爭橋，鎮、定之師與血戰，梁軍敗而復整者數四。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_027_000088",
    "sentence": "帝與張承業登高觀望，梁人戈矛如束，申令之後，囂聲若雷，王師進退有序，步騎嚴整，寂然無聲。",
    "entities": [
      {
        "text": "張承業",
        "label": "PER",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000089",
    "sentence": "帝臨陣誓眾，人百其勇，短兵既接，無不奮力。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_027_000090",
    "sentence": "梁有龍驤、神威、拱宸等軍，皆武勇之士也，每一人鎧仗，費數十萬，裝以組繡，飾以金銀，人望而畏之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_027_000091",
    "sentence": "自巳及午，騎軍接戰，至晡，梁軍欲抽退，塵埃漲天，德威周麾而呼曰：「汴人走矣！」 帝軍齊噪以進，魏人收軍漸退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_027_000092",
    "sentence": "李嗣源率親軍與史建瑭、安金全兼北部吐渾諸軍衝陣夾攻，梁軍大敗，棄鎧投仗之聲，震動天地，龍驤、神威、神捷諸軍，殺戮殆盡。",
    "entities": [
      {
        "text": "李嗣源",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "史建瑭",
        "label": "PER",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000093",
    "sentence": "自陣至柏鄉數十里，僵屍枕籍，敗旗折戟，所在蔽地。",
    "entities": [
      {
        "text": "自陣至柏鄉",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000094",
    "sentence": "夜漏一鼓，帝軍入柏鄉，梁軍輜重、帳幄、資財、奴仆，皆為帝軍所有。",
    "entities": [
      {
        "text": "帝軍入柏鄉",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000095",
    "sentence": "梁將王景仁、韓勍、李思安等以數十騎夜遁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_027_000096",
    "sentence": "是役也，斬首二萬級，獲馬三千匹，鎧甲兵仗七萬，輜車鍋幕不可勝計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_027_000097",
    "sentence": "擒梁將陳思權以下二百八十五人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_027_000098",
    "sentence": "帝號令收軍於趙州。",
    "entities": [
      {
        "text": "號令收軍於趙州",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000099",
    "sentence": "既而梁人棄深、冀二州而遁。",
    "entities": [
      {
        "text": "冀二州",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000100",
    "sentence": "初，杜廷隱之襲深、冀也，聲言分兵就食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_027_000101",
    "sentence": "時王鎔將石公立戍深州，欲杜關不納，鎔遽令啟關，命公立移車於外，廷隱遂據其城。",
    "entities": [
      {
