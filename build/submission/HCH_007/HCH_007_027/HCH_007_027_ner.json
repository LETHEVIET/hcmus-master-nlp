        "start": 42,
        "end": 44
      },
      {
        "text": "會魏州",
        "label": "LOC",
        "start": 51,
        "end": 54
      },
      {
        "text": "王彥章",
        "label": "PER",
        "start": 66,
        "end": 69
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000074",
    "sentence": "丁丑，景仁營於柏鄉，帝遂親征，自讚皇縣東下。",
    "entities": [
      {
        "text": "景仁營於柏鄉",
        "label": "LOC",
        "start": 3,
        "end": 9
      },
      {
        "text": "自讚皇縣",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000075",
    "sentence": "辛巳，至趙州，與周德威兵合。",
    "entities": [
      {
        "text": "至趙州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000076",
    "sentence": "帝令史建瑭以輕騎嘗寇，獲芻牧者二百人，問其兵數，精兵七萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_027_000077",
    "sentence": "是日，帝觀兵於石橋南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_027_000078",
    "sentence": "詰旦，進軍，距柏鄉一舍，周德威、史建瑭率蕃落勁騎以挑戰，四面馳射，梁軍閉壁不出，乃退。",
    "entities": [
      {
        "text": "距柏鄉",
        "label": "LOC",
        "start": 6,
        "end": 9
      },
      {
        "text": "史建瑭",
        "label": "PER",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000079",
    "sentence": "翌日，進軍，距柏鄉五里，遣騎軍逼其營。",
    "entities": [
      {
        "text": "距柏鄉",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000080",
    "sentence": "梁將韓勍、李思安率步騎三萬，鎧甲炫曜，其勢甚盛，分道以薄帝軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_027_000081",
    "sentence": "德威且戰且退，距河而止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_027_000082",
    "sentence": "既而德威偵知梁人造浮橋，乃退保高邑。",
    "entities": [
      {
        "text": "乃退保高邑",
        "label": "LOC",
        "start": 12,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000083",
    "sentence": "乙酉，致師於柏鄉，帝禱戰於光武廟。",
    "entities": [
      {
        "text": "致師於柏鄉",
        "label": "LOC",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000084",
    "sentence": "柏鄉無芻粟之備，梁軍以樵采為給，為帝之遊軍所獲，由是堅壁不出，剉屋茅坐席以秣其馬，眾心益恐。",
    "entities": [
      {
        "text": "柏鄉",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_027_000085",
    "sentence": "天祐八年正月丁亥，周德威、史建瑭帥三千騎致師於柏鄉，設伏於村塢間，遣三百騎直壓其營。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "史建瑭",
