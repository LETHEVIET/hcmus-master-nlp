        "start": 23,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000100",
    "sentence": "高祖革命，遷尚書屯田員外郎、知制誥。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000101",
    "sentence": "天福三年，改樞密院直學士，未幾，自祠部郎中、知制誥召充翰林學士，正拜中書舍人，賜金紫。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000102",
    "sentence": "少帝嗣位，遷禮部侍郎，知貢舉，尋遘疾而卒，年四十二。",
    "entities": [
      {
        "text": "侍郎",
