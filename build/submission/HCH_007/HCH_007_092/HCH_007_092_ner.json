        "start": 37,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000031",
    "sentence": "天成初，拜琦殿中侍御史，遷駕部員外郎，兼侍御史知雜事。",
    "entities": [
      {
        "text": "御史",
