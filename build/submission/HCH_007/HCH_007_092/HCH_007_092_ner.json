        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000018",
    "sentence": "贈左僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_092_000019",
    "sentence": "子惟和嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_092_000020",
    "sentence": "顗疏於財，而禦家無術，既死，斂葬之資不備，家人俟賻物及鬻第方能舉喪而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_092_000021",
    "sentence": "士大夫愛其廉而鄙其拙。",
