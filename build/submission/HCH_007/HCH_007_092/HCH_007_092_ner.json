        "start": 20,
        "end": 22
      },
      {
        "text": "博陸五邑",
        "label": "LOC",
        "start": 26,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000066",
    "sentence": "為寧晉日，擅給驛廩，以貸饑民，民甚感之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_092_000067",
    "sentence": "及為樂壽令，里人為之立碑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_092_000068",
    "sentence": "同光中，任圜為真定尹，擢為本府司錄，不應命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_092_000069",
    "sentence": "郭崇韜領其地，辟為從事，及明宗代崇韜，以舊職縻之。",
    "entities": [
      {
        "text": "郭崇韜",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000070",
    "sentence": "明宗即位，入為文昌正郎，安重誨薦為河南少尹，判府事，尋命為樞密院直學士。",
    "entities": [
      {
        "text": "安重誨",
        "label": "PER",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000071",
    "sentence": "時圭以受知於重誨，重誨奏令圭與同列閻至俱升殿侍立，以備顧問，明宗可之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_092_000072",
    "sentence": "尋自左諫議大夫拜尚書右丞，有入相之望。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000073",
    "sentence": "圭敏於吏事，重誨本不知書，為事剛愎，每於明宗前可否重務，圭恬然終日，不能剖正其事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_092_000074",
    "sentence": "長興中，重誨既誅，圭出為貝州刺史，未幾罷免，退歸常山。",
    "entities": [
      {
        "text": "圭出為貝州",
        "label": "LOC",
        "start": 9,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000075",
    "sentence": "由是閉門杜絕人事，雖親戚故人造者不見其面，每遊別墅，則乘婦人氈車以自蔽匿，人莫知其心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_092_000076",
    "sentence": "高祖登極，征為刑部侍郎，判鹽鐵副使，皆宰臣馮道之奏請也。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000077",
    "sentence": "始圭在明宗時為右丞，權判銓事，道在中書，嘗以堂判衡銓司所註官，圭怒，力爭之，道亦微有不足之色，至是圭首為道所舉，方愧其度量遠不及也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_092_000078",
    "sentence": "旋改吏部侍郎，分知銓事，而圭素厲廉守節，大著公平之譽。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000079",
    "sentence": "圭前為河南少尹日，有嵩山術士遺圭石藥如鬥，謂圭曰：「服之可以延壽，然不可中輟，輟則疾作矣。」圭後服之，神爽力健，深寶惜焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_092_000080",
    "sentence": "清泰末，圭在常山，遇秘瓊之亂，時貯於衣笥，為賊所劫，後不復得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_092_000081",
    "sentence": "天福中，疾生胸臆之間，常如火灼，圭知不濟，求歸鄉里，詔許之。",
    "entities": [
      {
        "text": "求歸鄉",
        "label": "LOC",
        "start": 21,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000082",
    "sentence": "及涉河，竟為藥氣所蒸，卒於路，歸葬石邑，時年六十八。",
    "entities": [
      {
        "text": "歸葬石邑",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000083",
    "sentence": "裴皞，字司東，系出中眷裴氏，世居河東為望族。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_092_000084",
    "sentence": "皞容止端秀，性卞急，剛直而無隱，少而好學，苦心文藝，雖遭亂離，手不釋卷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_092_000085",
    "sentence": "唐光化三年，擢進士第，釋褐授校書郎，歷諫職。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000086",
    "sentence": "梁初，當路推其文學，遷翰林學士、中書舍人。",
    "entities": [
      {
        "text": "梁",
        "label": "ORG",
        "start": 0,
        "end": 1
      }
    ]
  },
  {
    "sentence_id": "HCH_007_092_000087",
    "sentence": "唐莊宗時，擢為禮部侍郎，後以語觸當事，改太子賓客，旋授兵部尚書，以老致仕。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "太子",
