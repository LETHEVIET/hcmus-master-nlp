      }
    ]
  },
  {
    "sentence_id": "HCH_007_056_000003",
    "sentence": "初事武皇為帳中騎督，驍勇，便騎射，膽氣智數皆過人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_056_000004",
    "sentence": "久在雲中，諳熟邊事，望煙塵之警，懸知兵勢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_056_000005",
    "sentence": "乾寧中，為鐵林軍使，武皇討王行瑜，以功加檢校左僕射，移內衙軍副。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_056_000006",
    "sentence": "光化二年 三月，汴將氏叔琮率眾逼太原。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_056_000007",
    "sentence": "有陳章者，以虓勇知名，眾謂之「夜叉」，言於叔琮曰：「晉人所恃者周陽五，願擒之，請賞以郡。」陳章嘗乘驄馬朱甲以自異。",
    "entities": [
      {
        "text": "請賞以郡",
        "label": "LOC",
        "start": 39,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_007_056_000008",
    "sentence": "武皇戒德威曰：「我聞陳夜叉欲取爾求郡，宜善備之。」德威曰：「陳章大言，未知鹿死誰手！」他日致師，戒部下曰：「如陣上見陳夜叉，爾等但走。」 德威微服挑戰，部下偽退，陳章縱馬追之，德威背揮鐵楇擊墮馬，生獲以獻，由是知名。",
    "entities": [
      {
        "text": "夜叉欲取爾求郡",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_056_000009",
    "sentence": "天復中，我師不利於潘縣，汴將朱友寧、氏叔琮來逼晉陽。",
    "entities": [
      {
        "text": "我師不利於潘縣",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_056_000010",
    "sentence": "時諸軍未集，城中大恐，德威與李嗣昭選募銳兵出諸門，攻其壘，擒生斬馘，汴人枝梧不暇，乃退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_056_000011",
    "sentence": "天祐三年 ，與李嗣昭合燕軍攻潞州，降丁會，以功加檢校太保、代州刺史；代嗣昭為蕃漢都將。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "昭合燕軍攻潞州",
