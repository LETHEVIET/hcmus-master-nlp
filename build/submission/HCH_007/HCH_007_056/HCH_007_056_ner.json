      }
    ]
  },
  {
    "sentence_id": "HCH_007_056_000028",
    "sentence": "十二月，帝親征。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_056_000029",
    "sentence": "二十五日，進薄汴營，距柏鄉五里，營於野河上。",
    "entities": [
      {
        "text": "距柏鄉",
        "label": "LOC",
