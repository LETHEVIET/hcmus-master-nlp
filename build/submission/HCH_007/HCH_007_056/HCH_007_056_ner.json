        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_007_056_000012",
    "sentence": "李思安之寇潞州也，德威軍於餘吾。",
    "entities": [
      {
        "text": "李思安之寇潞州",
        "label": "LOC",
