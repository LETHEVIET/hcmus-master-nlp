      }
    ]
  },
  {
    "sentence_id": "HCH_007_056_000013",
    "sentence": "時汴軍十萬築夾城，圍潞州，內外斷絕，德威以精騎薄之，屢敗汴人，進營高河，令遊騎邀其芻牧。",
    "entities": [
      {
        "text": "汴軍十萬築夾城",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
