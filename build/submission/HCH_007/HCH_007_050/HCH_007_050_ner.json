        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000053",
    "sentence": "嗣肱進兵定媯、儒、武等三州，授山北都團練使。",
    "entities": [
      {
        "text": "武等三州",
        "label": "LOC",
        "start": 9,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000054",
    "sentence": "二十年春，卒於新州，時年四十五。",
    "entities": [
      {
        "text": "二十年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "卒於新州",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000055",
    "sentence": "克恭，武皇之諸弟也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000056",
    "sentence": "龍紀中，為決勝軍使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000057",
    "sentence": "大順初，潞帥李克修卒，克恭代為昭義節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000058",
    "sentence": "性驕橫不法，未閑軍政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000059",
    "sentence": "潞人素便克修之簡正，惡克恭之恣縱，又以克修非罪暴卒，人士離心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000060",
    "sentence": "時武皇初定邢、洺三州，將有事於河朔，大搜軍實。",
    "entities": [
      {
        "text": "洺三州",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000061",
    "sentence": "潞州有後院軍，兵之雄勁者，克恭選其五百人獻於武皇，軍使安居受惜其兵。",
    "entities": [
      {
        "text": "潞州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000062",
    "sentence": "不悅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000063",
    "sentence": "克恭令裨校李元審、安建、紀綱、馮霸部送太原，行次銅鞮縣，馮霸劫眾謀叛，殺都將劉杲、縣令戴勞謙，循山而南，比及沁水，有眾三千。",
    "entities": [
      {
        "text": "行次銅鞮縣",
