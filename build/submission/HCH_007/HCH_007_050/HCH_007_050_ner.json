[
  {
    "sentence_id": "HCH_007_050_000001",
    "sentence": "◎宗室",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000002",
    "sentence": "克讓，武皇之仲弟也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000003",
    "sentence": "少善騎射，以勇悍聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000004",
    "sentence": "咸通中，從討龐勳，以功為振武都校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000005",
    "sentence": "乾符中，王仙芝陷荊、襄，朝廷征兵，克讓率師奉詔，賊平，以功授金吾將軍，留宿衛。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000006",
    "sentence": "初，懿祖歸朝，憲宗賜宅於親仁坊，自長慶以來，相次一人典衛兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000007",
    "sentence": "武皇之起雲中，殺段文楚，朝議罪之，命加兵於我，懼，將逃歸，天子詔巡使王處存夜圍親仁坊捕克讓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000008",
    "sentence": "詰旦兵合，克讓與紀綱何相溫、安文寬、石的曆十餘騎彎弧躍馬，突圍而出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000009",
    "sentence": "官軍數千人追之，比至渭橋，死者數百。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000010",
    "sentence": "克讓自夏陽掠船而濟，歸於雁門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000011",
    "sentence": "明年，武皇昭雪，克讓復入宿衛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000012",
    "sentence": "黃巢犯闕，僖宗幸蜀，克讓時守潼關，為賊所敗，以部下六七騎伏於南山佛寺，夜為山僧所害。",
    "entities": [
      {
        "text": "克讓時守潼關",
        "label": "LOC",
        "start": 10,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000013",
    "sentence": "克讓既死，紀綱渾進通冒刃獲免，歸於黃巢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000014",
    "sentence": "中和二年冬，武皇入關討賊，屯沙苑。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "武皇入關",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000015",
    "sentence": "黃巢遣使米重威齎賂修好，因送渾進通至，兼擒送害克讓僧十人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000016",
    "sentence": "武皇燔偽詔，還其使，盡誅諸僧，為克讓發哀行服，悲慟久之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000017",
    "sentence": "克修，字崇遠，武皇從父弟也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000018",
    "sentence": "父德成，初為天寧軍使，從獻祖討龐勳，以功授朔州刺史。",
    "entities": [
      {
        "text": "以功授朔州",
        "label": "LOC",
        "start": 18,
        "end": 23
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000019",
    "sentence": "克修少便弓馬，從父征討，所至立功，武皇節制雁門，以克修為奉誠軍使，從入關為前鋒，破黃揆於華陰，敗尚讓於梁田坡，蹙黃巢於光順門，每戰皆捷，勇懾諸軍。",
    "entities": [
      {
        "text": "從入關",
        "label": "LOC",
        "start": 33,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000020",
    "sentence": "賊平，以功檢校刑部尚書，為左營軍使。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000021",
    "sentence": "其年十月，潞州牙將安居受來乞師，請復昭義軍，武皇遣大將賀公雅、李筠、安金俊等以兵從。",
    "entities": [
      {
        "text": "潞州",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000022",
    "sentence": "與孟方立戰於銅鞮，不利，武皇乃令克修將兵繼進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000023",
    "sentence": "是月，平潞州，斬其刺史李殷銳，乃表克修為昭義節度使。",
    "entities": [
      {
        "text": "平潞州",
        "label": "LOC",
        "start": 3,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000024",
    "sentence": "光啟二年九月，克修出師山東，收復邢、洺。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000025",
    "sentence": "十一月，拔故鎮。",
    "entities": [
      {
        "text": "拔故鎮",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000026",
    "sentence": "孟方立遣將呂臻來援，戰於焦崗，大敗之，擒呂臻，俘斬萬計，進拔武安、臨洺諸屬縣，乘勝進圍邢州。",
    "entities": [
      {
        "text": "臨洺諸屬縣",
        "label": "LOC",
        "start": 33,
        "end": 38
      },
      {
        "text": "乘勝進圍邢州",
        "label": "LOC",
        "start": 39,
        "end": 45
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000027",
    "sentence": "方立求援於鎮州，王鎔出師三萬援之，克修軍退。",
    "entities": [
      {
        "text": "方立求援於鎮州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000028",
    "sentence": "及李罕之來歸，武皇授以澤州刺史，與克修合勢進攻河陽，連歲出師，以苦懷、孟。",
    "entities": [
      {
        "text": "武皇授以澤州",
        "label": "LOC",
        "start": 7,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000029",
    "sentence": "文德元年十月，孟方立遣將奚忠信將兵三萬襲我遼州，克修設伏於遼之東山，大敗賊軍，擒忠信以獻。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "兵三萬襲我遼州",
        "label": "LOC",
        "start": 16,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000030",
    "sentence": "龍紀元年，武皇大舉以伐邢、洺，及班師，因撫封於上黨。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000031",
    "sentence": "克修性儉嗇，不事華靡，供帳饔膳，品數簡陋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000032",
    "sentence": "武皇怒其菲薄，笞而詬之，克修慚憤發疾；明年三月，卒於潞之府第，時年三十一。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000033",
    "sentence": "莊宗即位，追贈太師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000034",
    "sentence": "克修子二人，長曰嗣弼，次曰嗣肱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000035",
    "sentence": "嗣弼初授澤州刺史，曆昭義、橫海節度副使，改海州刺史。",
    "entities": [
      {
        "text": "嗣弼初授澤州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "改海州",
        "label": "LOC",
        "start": 20,
        "end": 23
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000036",
    "sentence": "天祐十九年，契丹犯燕、趙，陷涿郡， 〈 （《遼史·太祖紀》：十二月癸亥，圍涿州，有白兔緣壘而上，是日破其郛。） 〉 嗣弼舉家被俘，遷於幕庭。",
    "entities": [
      {
        "text": "十九年",
        "label": "TME",
        "start": 2,
        "end": 5
      },
      {
        "text": "陷涿郡",
        "label": "LOC",
        "start": 13,
        "end": 16
      },
      {
        "text": "《遼史·太祖紀》",
        "label": "TITLE",
        "start": 21,
        "end": 29
      },
      {
        "text": "圍涿州",
        "label": "LOC",
        "start": 36,
        "end": 39
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000037",
    "sentence": "嗣肱，少有膽略，屢立戰功，夾城之役，從周德威為前鋒。",
    "entities": [
      {
        "text": "夾城",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000038",
    "sentence": "時兄嗣弼為昭義副使，與嗣昭守城，兄弟內外奮戰，忠力威壯，感動三軍。",
    "entities": [
      {
        "text": "與嗣昭守城",
        "label": "LOC",
        "start": 10,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000039",
    "sentence": "潞圍既解，以功授檢校左僕射，入為三城巡檢，知衙內事。",
    "entities": [
      {
        "text": "入為三城",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000040",
    "sentence": "天祐七年，周德威援靈、夏，党項阻道，音驛不通。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000041",
    "sentence": "嗣肱奉命自麟州渡河，應接德威，與党項轉戰數十里，合德威軍。",
    "entities": [
      {
        "text": "嗣肱奉命自麟州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000042",
    "sentence": "柏鄉之戰，嗣肱為馬步都虞候。",
    "entities": [
      {
        "text": "柏鄉",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000043",
    "sentence": "明年，從莊宗會朱友謙於猗氏，改教練使，與存審援河中，敗汴軍於胡壁堡，獲將龐讓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000044",
    "sentence": "十年，與存審屯趙州，擊汴人於觀津。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "與存審屯趙州",
        "label": "LOC",
        "start": 3,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000045",
    "sentence": "時梁祖新屠棗強，其將賀德倫急攻蓚縣，率師五萬合勢營於蓚之西。",
    "entities": [
      {
        "text": "賀德倫急攻蓚縣",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000046",
    "sentence": "嗣肱自下博率騎三百，薄晚與梁之樵芻者相雜，日既晡，入梁軍營門，諸騎相合，大噪，弧矢星發，虓闞馳突。",
    "entities": [
      {
        "text": "梁",
        "label": "ORG",
        "start": 26,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000047",
    "sentence": "汴人不知所為，營中擾，既暝，斂騎而退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000048",
    "sentence": "是夜，梁祖燒營而遁，解蓚縣之圍。",
    "entities": [
      {
        "text": "解蓚縣",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000049",
    "sentence": "以功特授蔚州刺史、雁門以北都知兵馬使。",
    "entities": [
      {
        "text": "以功特授蔚州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000050",
    "sentence": "從平劉守光。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_050_000051",
    "sentence": "十二年，改應州刺史，累遷澤、代二州刺史、石嶺以北都知兵馬使。",
    "entities": [
      {
        "text": "十二年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "改應州",
        "label": "LOC",
