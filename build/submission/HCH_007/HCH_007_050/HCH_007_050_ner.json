        "end": 9
      },
      {
        "text": "代二州",
        "label": "LOC",
        "start": 14,
        "end": 17
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_050_000052",
    "sentence": "十九年，新州刺史王鬱叛入契丹。",
    "entities": [
      {
        "text": "十九年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "新州",
        "label": "LOC",
