[
  {
    "sentence_id": "HCH_007_070_000001",
    "sentence": "元行欽，本幽州劉守光之愛將。",
    "entities": [
      {
        "text": "本幽州",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000002",
    "sentence": "守光之奪父位也，令行欽攻大恩山，又令殺諸兄弟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000003",
    "sentence": "天祐九年，周德威攻圍山州，守光困蹙，令行欽於山北募兵，以應契丹。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "周德威攻圍山州",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000004",
    "sentence": "時明宗為將，攻行欽於山北，與之接戰，矢及明宗馬鞍，既而以勢迫來降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000005",
    "sentence": "明宗憐其有勇，奏隸為假子，後因從征討，恩禮特隆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000006",
    "sentence": "常臨敵擒生，必有所獲，名聞軍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000007",
    "sentence": "莊宗東定趙、魏，選驍健置之麾下，因索行欽，莊宗不得已而遣之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000008",
    "sentence": "時有散指揮都頭，名為散員，命行欽為都部署，賜姓，名紹榮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000009",
    "sentence": "莊宗好戰，勇於大敵，或臨陣有急兵，行欽必橫身解鬥翼衛之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000010",
    "sentence": "莊宗營於德勝也，與汴軍戰於潘張，王師不利，諸軍奔亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000011",
    "sentence": "莊宗得三四騎而旋，中野為汴軍數百騎攢槊攻之，事將不測，行欽識其幟，急馳一騎，奮劍斷二矛，斬一級，汴軍乃解圍，翼莊宗還宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000012",
    "sentence": "莊宗因流涕言曰：「富貴與卿共之。」自是寵冠諸將，官至檢校太傅、忻州刺史。",
    "entities": [
      {
        "text": "忻州",
        "label": "LOC",
        "start": 31,
        "end": 33
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000013",
    "sentence": "及莊宗平梁，授武寧軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000014",
    "sentence": "嘗因內宴群臣，使相預會，行欽官為保傅，當地褥下坐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000015",
    "sentence": "酒酣樂作，莊宗敘生平戰陣之事，因左右顧視，曰：「紹榮安在？」所司奏云：「有敕，使相預會，紹榮散官，殿上無位。」莊宗徹會不懌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000016",
    "sentence": "翌日，以行欽為同平章事，由是不宴百官於內殿，但宴武臣而已，",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000017",
    "sentence": "三年，行欽喪婦。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000018",
    "sentence": "莊宗有所愛宮人生皇子者，劉皇后心忌之，會行欽入侍，莊宗勞之曰：「紹榮喪婦復娶耶！吾給爾婚財。」皇后指所忌宮人謂莊宗曰：「皇帝憐紹榮，可使為婦。」莊宗難違所請，微許之。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 47,
        "end": 49
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 60,
        "end": 62
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000019",
    "sentence": "皇后即命紹榮謝之，未退，肩輿已出。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000020",
    "sentence": "莊宗心不懌，佯不豫者累日，業已遣去，無如之何。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000021",
    "sentence": "及貝州軍亂，趙在禮入魏州，莊宗方擇將，皇后曰：「小事不勞大將，促紹榮指揮可也。」乃以行欽為鄴都行營招撫使，領騎二千進討。",
    "entities": [
      {
        "text": "及貝州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "魏",
        "label": "ORG",
        "start": 10,
        "end": 11
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000022",
    "sentence": "洎至鄴城，攻之不能下，退保於澶州。",
    "entities": [
      {
        "text": "洎至鄴城",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "退保於澶州",
        "label": "LOC",
        "start": 11,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000023",
    "sentence": "未幾，諸道之師稍集，復進軍於鄴城之南。",
    "entities": [
      {
        "text": "復進軍於鄴城",
        "label": "LOC",
        "start": 10,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000024",
    "sentence": "及明宗為帥，領軍至鄴，行欽來謁於軍中，拜起之際，誤呼萬歲者再，明宗驚駭，遏之方止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000025",
    "sentence": "既而明宗營於城西，行欽營於城南。",
    "entities": [
      {
        "text": "既而明宗營於城",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "行欽營於城",
        "label": "LOC",
        "start": 9,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000026",
    "sentence": "三月八日夜，明宗為亂軍所迫，惟行欽之軍不動，按甲以自固。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000027",
    "sentence": "明宗密令張虔釗至行欽營，戒之曰：「且堅壁勿動，計會同殺亂軍，莫錯疑誤。」行欽不聽，將步騎萬人棄甲而退。",
    "entities": [
      {
        "text": "張虔釗",
        "label": "PER",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000028",
    "sentence": "自知失策，且保衛州，因誣奏明宗曰：「鎮師已入賊軍，終不為國使。」明宗既劫出鄴城，令人走馬上章，申理其事，言：「臣且於近郡聽進止。」莊宗覽奏釋然曰：「吾知紹榮妄矣。」因令白從訓與明宗子繼璟至軍前，欲令見明宗，行欽縶繼璟於路。",
    "entities": [
      {
        "text": "且保衛州",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "明宗既劫出鄴城",
        "label": "LOC",
        "start": 32,
        "end": 39
      },
      {
        "text": "臣且於近郡",
        "label": "LOC",
        "start": 55,
        "end": 60
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000029",
    "sentence": "明宗凡奏軍機，拘留不達，故旬日之間，音驛斷絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000030",
    "sentence": "及莊宗出成皋，知明宗在黎陽，復令繼璟渡河召明宗，行欽即殺之，仍勸班師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000031",
    "sentence": "四月一日，莊宗既崩，行欽引皇后、存渥，得七百騎出師子門，將之河中就存霸，沿路部下解散，從者數騎而已。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000032",
    "sentence": "四日，至平陸縣界，為百姓所擒，縣令裴進折其足，檻車以獻。",
    "entities": [
      {
        "text": "至平陸縣",
        "label": "LOC",
        "start": 3,
        "end": 7
      },
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000033",
    "sentence": "明宗即位，詔削奪行欽在位官爵，斬於洛陽。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000034",
    "sentence": "夏魯奇，字邦傑，青州人也。",
    "entities": [
      {
        "text": "青州",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000035",
    "sentence": "初事宣武軍為軍校，與主將不協，遂歸於莊宗，以為護衛指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000036",
    "sentence": "從周德威攻幽州，燕將有單廷珪、元行欽，時稱驍勇，魯奇與之鬥，兩不能解，將士皆釋兵縱觀。",
    "entities": [
      {
        "text": "從周德威攻幽州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000037",
    "sentence": "幽州平，魯奇功居多。",
    "entities": [
      {
        "text": "幽州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000038",
    "sentence": "梁將劉鄩在洹水，莊宗深入致師，鄩設伏於魏縣西南葭蘆中。",
    "entities": [
      {
        "text": "鄩設伏於魏縣",
        "label": "LOC",
        "start": 15,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000039",
    "sentence": "莊宗不滿千騎，汴人伏兵萬餘，大噪而起，圍莊宗數重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000040",
    "sentence": "魯奇與王門關、烏德兒等奮命決戰，自午至申，俄而李存審兵至方解。",
    "entities": [
      {
        "text": "魯奇與王門關",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000041",
    "sentence": "魯奇持槍攜劍，獨衛莊宗，手殺百餘人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_070_000042",
    "sentence": "烏德兒等被擒，魯奇傷痍遍體，自是莊宗尤憐之，曆磁州刺史。",
    "entities": [
      {
        "text": "曆磁州",
        "label": "LOC",
