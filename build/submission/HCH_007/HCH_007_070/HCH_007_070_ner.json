        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_070_000047",
    "sentence": "天成初，移鎮許州，加同平章事。",
    "entities": [
      {
        "text": "移鎮許州",
        "label": "LOC",
        "start": 4,
