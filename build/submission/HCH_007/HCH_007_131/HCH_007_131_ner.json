        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_131_000180",
    "sentence": "坐受榷鹽使王景遇厚賂，謫於均州。",
    "entities": [
      {
        "text": "謫於均州",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_131_000181",
    "sentence": "漢初歸朝，除右司郎中，兼侍御史知雜事。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
