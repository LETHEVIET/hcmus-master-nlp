      }
    ]
  },
  {
    "sentence_id": "HCH_007_131_000174",
    "sentence": "遘為人謙和，勤於接下，每文士投贄，必擇其賢者而譽之，故當時後進之士多歸焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_131_000175",
    "sentence": "李知損",
    "entities": [
