      }
    ]
  },
  {
    "sentence_id": "HCH_007_131_000164",
    "sentence": "二年，授太府卿，判司天監事。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_131_000165",
    "sentence": "其年夏初，火犯靈臺，延乂自言星官所忌，又言身命宮災並，未幾其子卒，尋又妻卒，俄而延乂嬰疾，故人省之，舉手曰：「多謝諸親，死災不可逭也。」尋卒，年五十八。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_131_000166",
    "sentence": "贈光祿卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_131_000167",
    "sentence": "沈遘",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_131_000168",
    "sentence": "沈遘，字期遠，睢陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_131_000169",
    "sentence": "父振，貝州永濟令，累贈左諫議大夫。",
    "entities": [
      {
        "text": "貝州",
        "label": "LOC",
