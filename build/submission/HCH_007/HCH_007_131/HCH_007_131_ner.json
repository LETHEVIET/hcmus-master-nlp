      }
    ]
  },
  {
    "sentence_id": "HCH_007_131_000188",
    "sentence": "及在郵亭，行止穢雜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_131_000189",
    "sentence": "王峻聞而奏之，乃責授棣州司馬。",
    "entities": [
      {
        "text": "乃責授棣州",
        "label": "LOC",
