        "end": 1
      },
      {
        "text": "桑維翰",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_131_000037",
    "sentence": "維翰出鎮，奏為記室。",
    "entities": [
      {
        "text": "維翰出鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_131_000038",
    "sentence": "從維翰入朝，授殿中侍御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_131_000039",
    "sentence": "歲餘，自侍御史改祠部員外郎知制誥，召入翰林為學士。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_131_000040",
    "sentence": "維翰罷相，馮玉用事，不欲沆居禁密，改右諫議大夫，罷其職。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_131_000041",
    "sentence": "漢祖至汴，轉右常侍，復用為學士，未幾，遷工部尚書充職。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_131_000042",
    "sentence": "明年，以營奉葬事求解職，改禮部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_131_000043",
    "sentence": "及歸朝，復為學士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_131_000044",
    "sentence": "太祖以沆耳疾罷職，改刑部尚書。",
    "entities": [
