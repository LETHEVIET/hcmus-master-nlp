        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_131_000055",
    "sentence": "父達，累贈戶部侍郎。",
    "entities": [
      {
        "text": "侍郎",
