[
  {
    "sentence_id": "HCH_007_024_000001",
    "sentence": "李珽",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000002",
    "sentence": "李珽，字公度，隴西敦煌人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000003",
    "sentence": "五世祖忠懿公憕，有大節，見《唐史》。",
    "entities": [
      {
        "text": "《唐史》",
        "label": "TITLE",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000004",
    "sentence": "父縠，仕懿、僖朝，官至右諫議大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000005",
    "sentence": "珽聰悟，有才學，尤工詞賦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000006",
    "sentence": "僖宗朝，晉公王鐸提兵柄，鎮滑台，縠居賓席，鐸見珽，大賞歎之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000007",
    "sentence": "年二十四登進士第，解褐授校書郎，拜監察御史，俄丁內艱。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000008",
    "sentence": "先是，父旅殯在遠，家貧無以襄事，與弟琪當臘雪以單縗扶杖，銜哀告人，由是兩克遷祔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000009",
    "sentence": "而珽日不過食一溢，恒羸臥喪廬中不能興。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000010",
    "sentence": "大為時賢所歎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000011",
    "sentence": "憂闋，再征為御史，以瘠不起。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000012",
    "sentence": "成汭之鎮荊州，辟為掌書記，逾時乃就。",
    "entities": [
      {
        "text": "成汭之鎮荊州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000013",
    "sentence": "天復中，淮寇大舉圍夏口，逼巴陵，太祖患之，飛命成汭率水軍十萬援於鄂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000014",
    "sentence": "珽入言曰：「今舳艫容介士千人，載稻倍之，緩急不可動。吳人剽輕，若為所絆，則武陵、武安皆我之仇也，將有後慮；不如遣驍將屯巴陵，大軍對岸，一日不與戰，則吳寇糧絕，而鄂州圍解矣。」汭性剛決，不聽。",
    "entities": [
      {
        "text": "吳",
        "label": "ORG",
        "start": 26,
        "end": 27
      },
      {
        "text": "而鄂州",
        "label": "LOC",
        "start": 79,
        "end": 82
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000015",
    "sentence": "淮人果乘風縱火，舟盡焚，兵盡溺，汭亦自沈於江，朗人、潭人遂入荊渚，一如所料。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000016",
    "sentence": "未幾，襄帥趙匡凝復奏為掌記，入為左補闕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000017",
    "sentence": "又明年，太祖為元帥，以襄陽貳於己，率兵擊破之，趙匡凝奔揚州，太祖復署珽為天平軍掌書記。",
    "entities": [
      {
        "text": "趙匡凝奔揚州",
        "label": "LOC",
        "start": 23,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000018",
    "sentence": "一日，大會將佐，指珽曰：「此真書記也。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000019",
    "sentence": "滄州節度使劉守文拒命，太祖引兵十餘萬圍之，久而未下，乃召珽草檄。",
    "entities": [
      {
        "text": "滄州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000020",
    "sentence": "珽即就外次，筆不停綴，登時而成，大為太祖嗟賞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000021",
    "sentence": "受禪之歲，宰臣除為考功員外郎、知制誥，珽揣太祖未欲首以舊僚超拜清顯，三上章固辭，優詔褒允，尋以本官監曹州事。",
    "entities": [
      {
        "text": "尋以本官監曹州",
        "label": "LOC",
        "start": 45,
        "end": 52
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000022",
    "sentence": "曹去京數舍，吏民豪猾，前後十餘政，未有善罷者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000023",
    "sentence": "珽在任期歲，眾庶以寧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000024",
    "sentence": "入為兵部郎中、崇政院學士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000025",
    "sentence": "未幾，以許帥馮行襲疾甚，出為許州留後。",
    "entities": [
      {
        "text": "出為許州",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000026",
    "sentence": "先是，行襲有牙兵二千，皆蔡人也，太祖深以為憂，乃遣珽馳往，以伺察之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000027",
    "sentence": "珽至傳舍，召將吏親加撫慰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000028",
    "sentence": "行襲欲使人代受詔，珽曰：「東首加朝服，禮也。」乃於臥內宣詔，令善自補養，苟有不諱，子孫俱保後福。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000029",
    "sentence": "行襲泣謝，遂解二印以授珽，代掌軍府事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000030",
    "sentence": "太祖覽奏曰：「予固知珽必辦吾事，行襲門戶不朽矣。」乃以珽為匡國軍留後，尋征為左諫議大夫兼宣徽副使。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 41,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000031",
    "sentence": "從征至魏縣，過內黃，因侍立於行廄，太祖顧曰：「此何故名內黃？」珽曰：「河南有外黃、小黃，故此有內黃。」又曰：「在何處？」對曰：「秦有外黃都尉，理外黃，有故墉，今在雍丘。小黃為高齊所廢，其故墉今在陳留。」太祖稱獎數四。",
    "entities": [
      {
        "text": "從征至魏縣",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000032",
    "sentence": "及庶人友珪篡位，除右散騎常侍，充侍講學士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000033",
    "sentence": "內討之日，軍士大擾，珽其夕為亂兵所傷，卒於洛陽。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000034",
    "sentence": "珽性孝友，與弟琪有敦睦之愛，為搢紳所稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000035",
    "sentence": "〈 （案：《歐陽史》有《裴迪》、《韋震傳》，今原文已佚，無可采補。） 〉",
    "entities": [
      {
        "text": "《歐陽史》",
        "label": "TITLE",
        "start": 5,
        "end": 10
      },
      {
        "text": "《裴迪》",
        "label": "TITLE",
        "start": 11,
        "end": 15
      },
      {
        "text": "《韋震傳》",
        "label": "TITLE",
        "start": 16,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000036",
    "sentence": "盧曾",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000037",
    "sentence": "盧曾，字孝伯，其先范陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000038",
    "sentence": "頗好書，有所執守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000039",
    "sentence": "始為齊州防禦使朱瓊從事，瓊降，預其謀，與之皆來。",
    "entities": [
      {
        "text": "始為齊州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000040",
    "sentence": "瓊沒，太祖辟為宣義幕職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000041",
    "sentence": "曾性忠狷，好貢直，又不能取容於眾，每勳府宴語稍洽，曾率然糾正，輒又忤旨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000042",
    "sentence": "左長直軍使劉捍委任方重，曾亦不能平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000043",
    "sentence": "冀王友謙初定陝府，命曾往議事，有使院小將從行，嗜酒，荒逸過度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000044",
    "sentence": "曾復命，欲發其罪，致疏於袖中，累日未果言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000045",
    "sentence": "小將恐事泄，先誣告曾使酒，幾敗軍事，劉捍因證之，由是罷職，歸於齊之別墅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000046",
    "sentence": "俄而王師範起兵叛，太祖促召曾，謂之曰：「子能緩頰說青州使無背盟，吾不負子矣。」曾持檄以往。",
    "entities": [
      {
        "text": "子能緩頰說青州",
        "label": "LOC",
        "start": 20,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000047",
    "sentence": "既至青，師範囚之，送於淮南，遇害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000048",
    "sentence": "後太祖暴師範之罪曰：「喪我骨肉，殺我賓僚。」遂族誅之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000049",
    "sentence": "因召曾二子，皆授以官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000050",
    "sentence": "孫騭",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000051",
    "sentence": "孫騭，滑台人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000052",
    "sentence": "嗜學知書，微有辭筆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000053",
    "sentence": "唐光啟中，魏博從事公乘億以女妻之，因教以箋奏程式。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000054",
    "sentence": "時中原多難，文章之士，縮影竄跡不自顯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000055",
    "sentence": "億既死，魏帥以章表箋疏淹積，兼月不能發一字，或以騭為言，即署本職，主奏記事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000056",
    "sentence": "累遷職自支使、掌記至節度判官；奏官自校書、御史郎官、中丞、檢校常侍至兵部尚書。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 21,
        "end": 23
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 36,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000057",
    "sentence": "太祖禦天下，念潛龍時，騭奉其主，好問往來數十返，甚錄之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000058",
    "sentence": "開平三年，除右諫議大夫，滿歲，遷左散騎常侍。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000059",
    "sentence": "騭雅好聚書，有《六經》、漢史洎百家之言，凡數千卷，皆簡翰精至，披勘詳定，得暇即朝夕耽玩，曾無少怠。",
    "entities": [
      {
        "text": "《六經》",
        "label": "TITLE",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000060",
    "sentence": "乾化二年春，太祖將議北巡，選朝士三十餘人扈從。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000061",
    "sentence": "二月甲子，車駕發自洛陽。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000062",
    "sentence": "禺中，次白馬頓，召文武官就食，以從臣未集，駐蹕以俟之；又命飛騎促於道，而騭與諫議大夫張衍、兵部郎中張俊等累刻方至，太祖性本卞急，因茲大怒，並格殺於前墀。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 40,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000063",
    "sentence": "張俊",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000064",
    "sentence": "張俊，字彥臣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000065",
    "sentence": "祖、父咸有聞於時。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000066",
    "sentence": "俊少孤，自修飾，善為五言詩，其警句頗為人所稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000067",
    "sentence": "唐廣明中，黃巢犯京師，天子幸蜀，士皆竄伏窟穴，以保其生。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 2,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_024_000068",
    "sentence": "俊亦晦跡浮泛，不失其道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_024_000069",
    "sentence": "及僖宗還京師，由校書郎、西畿尉登朝為御史、補闕、起居郎、司勳員外、萬年縣令，以事黜官峽中，將十年。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
