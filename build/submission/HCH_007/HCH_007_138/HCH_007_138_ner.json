        "end": 44
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000032",
    "sentence": "晉天福五年，義金卒，子元德立。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 3,
