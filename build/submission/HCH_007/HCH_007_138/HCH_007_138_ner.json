        "end": 24
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 34,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000020",
    "sentence": "至漢隱帝時，涼州留後折逋嘉施來請命，漢即以爲節度使。",
    "entities": [
      {
        "text": "涼州",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000021",
    "sentence": "嘉施，土豪也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_138_000022",
    "sentence": "周廣順二年，嘉施遣人市馬京師。",
    "entities": [
      {
        "text": "廣順二年",
        "label": "TME",
        "start": 1,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000023",
    "sentence": "是時樞密使王峻用事，峻故人申師厚者，少起盜賊，爲兗州牙將，與峻相友善。",
    "entities": [
      {
        "text": "爲兗州",
        "label": "LOC",
        "start": 23,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000024",
    "sentence": "後峻貴，師厚弊衣蓬首，日候峻出，馬前訴以饑寒，峻未有以發。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_138_000025",
    "sentence": "而嘉施等來請帥，峻即建言，涼州深入夷狄，中國未嘗命吏，請帥募府率供奉官能往者。",
    "entities": [
      {
        "text": "涼州",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000026",
    "sentence": "月餘，無應募者，乃奏起師厚爲左衛將軍，已而拜河西節度使。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000027",
    "sentence": "師厚至涼州，奏薦押牙副使崔虎心、陽妃谷首領沈念般等，及中國留人子孫王廷翰、溫崇樂、劉少英爲將吏，又自安國鎮至涼州立三州以控扼諸羌，用其酋豪爲刺史。",
    "entities": [
      {
        "text": "師厚至涼州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "又自安國鎮",
        "label": "LOC",
        "start": 48,
        "end": 53
      },
      {
        "text": "至涼州立三州",
        "label": "LOC",
        "start": 53,
        "end": 59
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 70,
        "end": 72
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000028",
    "sentence": "然涼州夷夏雜處，師厚小人，不能撫有，至世宗時，師厚留其子而逃歸，涼州遂絕於中國。",
    "entities": [
      {
