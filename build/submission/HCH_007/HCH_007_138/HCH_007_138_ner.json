[
  {
    "sentence_id": "HCH_007_138_000001",
    "sentence": "吐蕃 回鶻 高麗 渤海靺鞨 黑水靺鞨 新羅 党項 昆明部落 于闐 占城 牂牁蠻",
    "entities": [
      {
        "text": "占城",
        "label": "LOC",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000002",
    "sentence": "吐蕃",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_138_000003",
    "sentence": "吐蕃，本漢西羌之地，或雲南涼禿發利鹿孤之後，其子孫以禿發爲國號，語訛爲吐蕃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_138_000004",
    "sentence": "國人號其主爲贊普，置大論、小論以理國事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_138_000005",
    "sentence": "其俗隨畜牧無常居，然亦有城郭，都城號邏些城。",
    "entities": [
      {
        "text": "然亦有城",
        "label": "LOC",
        "start": 9,
        "end": 13
      },
      {
        "text": "都城號邏些城",
        "label": "LOC",
        "start": 15,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000006",
    "sentence": "不知節候，以麥熟爲歲首。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_138_000007",
    "sentence": "唐時屢爲邊患。",
    "entities": [
      {
        "text": "唐",
        "label": "ORG",
        "start": 0,
        "end": 1
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000008",
    "sentence": "初，唐分天下爲十道，河西、隴右三十三州，涼州最爲大鎮。",
    "entities": [
      {
        "text": "隴右三十三州",
        "label": "LOC",
        "start": 13,
        "end": 19
      },
      {
        "text": "涼州最爲大鎮",
        "label": "LOC",
        "start": 20,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000009",
    "sentence": "天寶置八監，牧馬三十萬，又置都護以控制之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_138_000010",
    "sentence": "安祿山之亂，肅宗在靈武，悉召河西戍卒收復兩京，吐蕃乘虛取河西、隴右，華人百萬皆陷於吐蕃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_138_000011",
    "sentence": "開成時，朝廷嘗遣使至西域，見甘、涼、瓜、沙等州城邑如故，陷吐蕃之人見唐使者旌節，夾道迎呼涕泣曰：「皇帝猶念陷吐蕃生靈否？」其人皆天寶中陷吐蕃者子孫，其語言小訛，而衣服未改。",
    "entities": [
      {
        "text": "沙等州城邑",
        "label": "LOC",
        "start": 20,
        "end": 25
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 49,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000012",
    "sentence": "至五代時，吐蕃已微弱，回鶻、党項諸羌夷分侵其地，而不有其人民。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_138_000013",
    "sentence": "值中國衰亂，不能撫有，惟甘、涼、瓜、沙四州常自通於中國。",
    "entities": [
      {
        "text": "沙四州",
        "label": "LOC",
        "start": 18,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000014",
    "sentence": "甘州爲回鶻牙帳，而涼、瓜、沙三州將吏猶稱唐官，數來請命。",
    "entities": [
      {
        "text": "甘州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "沙三州",
        "label": "LOC",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000015",
    "sentence": "自梁太祖時，常以靈武節度使兼領河西節度，而觀察甘、肅、威等州，然雖有其名，而涼州自立守將。",
    "entities": [
      {
        "text": "威等州",
        "label": "LOC",
        "start": 27,
        "end": 30
      },
      {
        "text": "而涼州",
        "label": "LOC",
        "start": 37,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000016",
    "sentence": "唐長興四年，涼州留後孫超遣大將拓拔承謙及僧道士耆老楊通信等至京師，明宗拜孫超節度使。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 3,
        "end": 5
      },
      {
        "text": "涼州",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000017",
    "sentence": "清泰元年，留後李文謙來請命。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000018",
    "sentence": "後數年，涼州人逐出文謙，靈武馮暉遣牙將吳繼興代文謙爲留後，是時天福七年。",
    "entities": [
      {
        "text": "涼州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "七年",
        "label": "TME",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_007_138_000019",
    "sentence": "明年，晉高祖遣涇州押牙陳延暉齎詔書安撫涼州，涼州人共劫留延暉，立以爲刺史。",
    "entities": [
      {
        "text": "晉高祖遣涇州",
        "label": "LOC",
