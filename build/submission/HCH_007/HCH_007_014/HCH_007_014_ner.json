      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000121",
    "sentence": "由是豐其飲膳，嘉羞法饌，動費萬錢，僦斂網商，其徒如市，權勢熏灼，人皆阿附。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000122",
    "sentence": "及唐莊宗滅梁室，岩逾垣而逸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000123",
    "sentence": "素與徐州溫韜相善，岩往依之。",
    "entities": [
      {
        "text": "素與徐州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000124",
    "sentence": "既至，韜斬岩首送京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000125",
    "sentence": "仲弟 昶",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000126",
    "sentence": "昶，字大東，犨仲弟也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000127",
    "sentence": "弱冠習兵機，沈默大度，神形灑落，臨事有通變之才。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000128",
    "sentence": "及兄犨為陳州刺史，以昶為防禦都指揮使。",
    "entities": [
      {
        "text": "及兄犨為陳州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000129",
    "sentence": "未幾，巢將孟楷擁眾萬餘據項城縣，昶與兄犨領兵擊破之，擒楷以歸。",
    "entities": [
      {
        "text": "擁眾萬餘據項城",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000130",
    "sentence": "不數月，巢黨悉眾攻陳，以報孟楷之役；又與蔡寇合從，凶醜百萬，棲於陳郊，陳人大恐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000131",
    "sentence": "一夕，昶因巡警，假寐於闍，恍惚間如有陰助，昶異而待之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000132",
    "sentence": "遲明，開門決戰，人心兵勢，勇不可遏，若有陰兵前導。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000133",
    "sentence": "是日，擒賊將數人，斬首千餘級，群凶氣沮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000134",
    "sentence": "其後連日交戰，無不應機俘斬，未嘗小衄，以至重圍數月，士心如一。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000135",
    "sentence": "及賊敗圍解，朝廷紀勳，昶一門之中，疊加爵秩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000136",
    "sentence": "當時方鎮之內，言忠勇者、言守禦者、言功勳者、言政事者，皆以犨、昶為首焉。",
    "entities": [
      {
        "text": "當時方鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000137",
    "sentence": "及犨遙領泰寧軍節度，以昶為本州刺史、檢校右僕射。",
    "entities": [
      {
        "text": "以昶為本州",
        "label": "LOC",
        "start": 10,
        "end": 15
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000138",
    "sentence": "俄而犨有疾，遂以軍州盡付於昶。",
    "entities": [
      {
        "text": "遂以軍州",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000139",
    "sentence": "詔授兵馬留後，旋遷忠武軍節度使，亦以陳州為理所。",
    "entities": [
      {
        "text": "亦以陳州",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000140",
    "sentence": "時宗權未滅，中原方受其毒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000141",
    "sentence": "陳、蔡封疆相接，昶每選精銳，深入蔡境。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000142",
    "sentence": "蔡賊雖眾，終不能抗，以至宗權敗焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000143",
    "sentence": "朝廷賞勳，加檢校司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000144",
    "sentence": "昶以大寇削平之後，益留心於政事，勸課農桑，大布恩惠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000145",
    "sentence": "景福元年秋，陳、許將吏耆老錄其功，詣闕以聞，天子嘉之，命文臥撰德政碑植於通衢，以旌其功。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000146",
    "sentence": "俄加同平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000147",
    "sentence": "昶自圍解之後，恒曰：「梁王之恩，不敢忘也。」是後太祖每有征伐，昶訓練兵甲，饋挽供億，無有不至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000148",
    "sentence": "乾寧二年寢疾，薨於鎮，年五十五，追贈太尉。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "薨於鎮",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000149",
    "sentence": "季弟 珝",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000150",
    "sentence": "珝，字有節，犨季弟也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000151",
    "sentence": "幼而剛毅，器宇深沉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000152",
    "sentence": "既冠，好書籍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000153",
    "sentence": "及壯，工騎射，尤精《三略》。",
    "entities": [
      {
        "text": "《三略》",
        "label": "TITLE",
        "start": 9,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000154",
    "sentence": "及犨為陳州刺史，以珝為親從都知兵馬使。",
    "entities": [
      {
        "text": "及犨為陳州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000155",
    "sentence": "時巢黨東出商、鄧，與蔡賊會，眾至百餘萬，掘長壕五百道攻陳，陳人大懼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000156",
    "sentence": "珝與二兄堅心誓眾，激勵將校，約以死節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000157",
    "sentence": "珝以祖先鬆楸，去郭數里，慮為群盜穿發，乃夜縱心膂之士，遷柩入城。",
    "entities": [
      {
        "text": "遷柩入城",
        "label": "LOC",
        "start": 27,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000158",
    "sentence": "府庫舊有巨弩數百枝，機牙皆缺，工人咸謂不可用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000159",
    "sentence": "珝即創意制度，自調弦筈，置之雉堞間，矢激五百餘步，凡中人馬，皆洞達胸腋，群賊畏之，不敢逼近。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000160",
    "sentence": "自仲秋至於首夏，軍食將竭，士雖不飽，而堅拒之志不移。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000161",
    "sentence": "會太祖率大軍解其圍，珝兄弟抆泣感謝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000162",
    "sentence": "其後朝廷議功，加檢校右僕射，遙領處州刺史。",
    "entities": [
      {
        "text": "遙領處州",
        "label": "LOC",
        "start": 14,
        "end": 18
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000163",
    "sentence": "犨薨，昶為忠武軍節度使，珝遷為行軍司馬、檢校司空。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000164",
    "sentence": "昶薨，珝知忠武軍留後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000165",
    "sentence": "珝公幹之才，播於遠邇，至於符籍虛實，財穀耗登，備閱其根本，民之利病，無不洞知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000166",
    "sentence": "庶事簡廉，公私俱濟，太祖深加慰薦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000167",
    "sentence": "尋加特進、檢校司徒，充忠武軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000168",
    "sentence": "陳州土壤卑疏，每歲壁壘摧圮，工役不暇，珝遂營度力用，俾以甓周砌四墉，自是無霖潦之虞。",
    "entities": [
      {
        "text": "陳州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000169",
    "sentence": "光化二年，加檢校太保、平章事。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000170",
    "sentence": "明年，檢校侍中，進封天水郡公。",
    "entities": [
      {
        "text": "進封天水郡",
        "label": "LOC",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000171",
    "sentence": "珝博通前古，以陳州本伏羲所都，南頓乃光武舊地，遂稽考古制，崇飾廟貌，為四民祈福之所。",
    "entities": [
      {
        "text": "以陳州",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000172",
    "sentence": "又詢鄧艾故址，決翟王河以溉稻粱，大實倉廩，民獲其利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000173",
    "sentence": "珝兄弟節制陳、許，繼擁旌鉞，共二十餘年，陳人愛戴，風化大行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000174",
    "sentence": "天復元年冬，韓建為忠武軍節度使，乃征珝知同州匡國軍節度留後。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "乃征珝知同州",
        "label": "LOC",
        "start": 16,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000175",
    "sentence": "時太祖統軍岐下，珝輸挽調發，旁午道途。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000176",
    "sentence": "俄而昭宗還長安，詔征入覲，錫迎鑾功臣之號。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000177",
    "sentence": "珝因堅辭藩鎮，遂加檢校太傅、右金吾衛上將軍。",
    "entities": [
      {
        "text": "珝因堅辭藩鎮",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000178",
    "sentence": "及扈從東遷，歲餘，以痼疾免官，遂歸淮陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000179",
    "sentence": "未幾，薨於私第，年五十五。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000180",
    "sentence": "詔贈侍中，陳人為之罷市。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000181",
    "sentence": "子縠，仕至左驍衛大將軍、宣徽北院使。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000182",
    "sentence": "唐莊宗入汴，與從兄岩皆族誅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000183",
    "sentence": "王珂",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000184",
    "sentence": "王珂，河中人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000185",
    "sentence": "祖縱，鹽州刺史。",
    "entities": [
      {
        "text": "鹽州",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000186",
    "sentence": "父重榮，河東節度使，破黃巢有大功，封琅邪郡王。",
    "entities": [
      {
        "text": "封琅邪郡",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000187",
    "sentence": "珂本重榮兄重簡之子，出繼重榮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000188",
    "sentence": "唐僖宗光啟三年，重榮為部將常行儒所害，推重榮弟重盈為蒲帥，以珂為行軍司馬。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 5,
        "end": 7
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 34,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000189",
    "sentence": "及重盈卒，軍府推珂為留後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000190",
    "sentence": "時重盈子珙為陝州節度使，瑤為絳州刺史，由是爭為蒲帥，瑤、珙連上章論列，又與太祖書云：「珂非吾兄弟，蓋餘家之蒼頭也，小字忠兒，安得繼嗣！」珂亦上章云：「亡父有興復之功。」又遣使求援於太原，李克用為保薦於朝，昭宗可之。",
    "entities": [
      {
        "text": "重盈子珙為陝州",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "瑤為絳州",
        "label": "LOC",
        "start": 12,
        "end": 16
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000191",
    "sentence": "既而珙厚結王行瑜、李茂貞、韓建為援，三鎮互相表薦，昭宗詔諭之曰：「吾以太原與重榮有再造之功，已俞其奏矣。」乾寧二年五月，三鎮率兵入覲，賊害時政，請以河中授珙、瑤，又連兵以攻河中。",
    "entities": [
      {
        "text": "三鎮",
        "label": "LOC",
        "start": 18,
        "end": 20
      },
      {
        "text": "二年",
        "label": "TME",
        "start": 55,
        "end": 57
      },
      {
        "text": "三鎮",
        "label": "LOC",
        "start": 60,
        "end": 62
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000192",
    "sentence": "克用聞之，出師以討三鎮，瑤、珙兵退，晉師拔絳州，擒瑤斬之。",
    "entities": [
      {
        "text": "出師以討三鎮",
        "label": "LOC",
        "start": 5,
        "end": 11
      },
      {
        "text": "晉師拔絳州",
        "label": "LOC",
        "start": 18,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000193",
    "sentence": "及克用駐軍於渭北，昭宗以珂為河中節度使，正授旄鉞，克用因以女妻珂；珂至太原謝婚成禮，克用令李嗣昭將兵助珂，攻珙於陝焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000194",
    "sentence": "光化末，太祖謂張存敬曰：「珂恃太原之勢，侮慢鄰封，爾為我持一繩以縛之。」天復元年春，存敬兵下晉、絳，令何糸因守晉州以扼太原援師。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 38,
        "end": 40
      },
      {
        "text": "令何糸因守晉州",
        "label": "LOC",
        "start": 50,
        "end": 57
