      }
    ]
  },
  {
    "sentence_id": "HCH_007_014_000099",
    "sentence": "獻捷於行在。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_014_000100",
    "sentence": "五年八月，除犨為蔡州節度使。",
