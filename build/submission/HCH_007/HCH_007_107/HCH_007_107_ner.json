[
  {
    "sentence_id": "HCH_007_107_000001",
    "sentence": "史弘肇　楊邠　王章　李洪建　閻晉卿　聶文進　後贊　郭允明　劉銖",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000002",
    "sentence": "史宏肇",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000003",
    "sentence": "史宏肇，字化元，鄭州滎澤人也。",
    "entities": [
      {
        "text": "鄭州",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000004",
    "sentence": "父潘，本田家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000005",
    "sentence": "宏肇少遊俠無行，拳勇健步，日行二百里，走及奔馬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000006",
    "sentence": "梁末，每七戶出一兵，宏肇在籍中，後隸本州開道都，選入禁軍。",
    "entities": [
      {
        "text": "梁",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "後隸本州",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000007",
    "sentence": "嘗在晉祖麾下，遂留爲親從，及踐阼，用爲控鶴小校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000008",
    "sentence": "高祖鎮太原，奏請從行，升爲牙校，後置武節左右指揮，以宏肇爲都將，遙領雷州刺史。",
    "entities": [
      {
        "text": "高祖鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "遙領雷州",
        "label": "LOC",
        "start": 32,
        "end": 36
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 36,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000009",
    "sentence": "高祖建號之初，代州王暉叛，以城歸契丹，宏肇征之，一鼓而拔，尋授許州節度使，充侍衞步軍都指揮使。",
    "entities": [
      {
        "text": "代州",
        "label": "LOC",
        "start": 7,
        "end": 9
      },
      {
        "text": "以城",
        "label": "LOC",
        "start": 13,
        "end": 15
      },
      {
        "text": "尋授許州",
        "label": "LOC",
        "start": 29,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000010",
    "sentence": "會王守恩以上黨求附，契丹主命大將耿崇美率眾登太行，欲取上黨，高祖命宏肇以軍應援。",
    "entities": [
      {
        "text": "王守恩",
        "label": "PER",
        "start": 1,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000011",
    "sentence": "軍至潞州，契丹退去，翟令奇以澤州迎降。",
    "entities": [
      {
        "text": "軍至潞州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "翟令奇以澤州",
        "label": "LOC",
        "start": 10,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000012",
    "sentence": "會河陽武行德遣人迎宏肇，遂率眾南下，與行德合。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000013",
    "sentence": "故高祖由蒲、陜赴洛如歸，宏肇前鋒之功也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000014",
    "sentence": "宏肇嚴毅寡言，部轄軍眾，有過無舍，兵士所至，秋毫不犯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000015",
    "sentence": "部下有指揮使，嘗因指使少不從命，宏肇立撾殺之，將吏股栗，以至平定兩京，無敢幹忤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000016",
    "sentence": "從駕征鄴回，加同平章事，充侍衞親軍都指揮使，兼鎮宋州。",
    "entities": [
      {
        "text": "兼鎮宋州",
        "label": "LOC",
        "start": 22,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000017",
    "sentence": "高祖大漸，與樞密使楊邠、周太祖、蘇逢吉等同受顧命。",
    "entities": [
      {
        "text": "蘇逢吉",
        "label": "PER",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000018",
    "sentence": "隱帝嗣位，加檢校太師、兼侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000019",
    "sentence": "居無何，河中、永興、鳳翔連橫謀叛，關輔大擾，朝廷日有征發，群情憂揣，亦有不逞之徒，妄構虛語，流布京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000020",
    "sentence": "宏肇都轄禁軍，警衞都邑，專行刑殺，略無顧避，無賴之輩，望風匿跡，路有遺棄，人不敢取。",
    "entities": [
      {
        "text": "警衞都邑",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000021",
    "sentence": "然而不問罪之輕重，理之所在，但雲有犯，便處極刑，枉濫之家，莫敢上訴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000022",
    "sentence": "巡司軍吏，因緣爲奸，嫁禍脅人，不可勝紀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000023",
    "sentence": "〈 （《宋史·邊歸讜傳》：史宏肇怙權專殺，閭裏告訐成風，歸讜言曰：「邇來有匿名書及言風聞事，構害良善，有傷風化，遂使貪吏得以報復私怨，讒夫得以肆其虛誕。請明行條制，禁遏誣妄，凡顯有披論，具陳姓名。其匿名書及風聞事者，並見止絶。」論者韙之。） 〉 時太白晝見，民有仰觀者，爲坊正所拘，立斷其腰領。",
    "entities": [
      {
        "text": "《宋史·邊歸讜傳》",
        "label": "TITLE",
        "start": 3,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000024",
    "sentence": "又有醉民抵忤一軍士，則誣以訛言棄市。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000025",
    "sentence": "其他斷舌、決口、斫筋、折足者，僅無虛日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000026",
    "sentence": "故相李崧爲部曲誣告，族戮於市，取其幼女爲婢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000027",
    "sentence": "自是仕宦之家畜仆隸者，皆以姑息爲意，而舊勛故將失勢之後，爲廝養輩之所脅制者，往往有之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000028",
    "sentence": "軍司孔目吏解暉，性狡而酷，凡有推劾，隨意鍛煉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000029",
    "sentence": "人有抵軍禁者，被其苦楚，無不自誣以求死所，都人遇之，莫敢仰視。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000030",
    "sentence": "有燕人何福殷者，以商販爲業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000031",
    "sentence": "嘗以十四萬市得玉枕，遣家僮及商人李進賣於淮南，易茗而回。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000032",
    "sentence": "家僮無行，隱福殷貨財數十萬，福殷責其償，不伏，遂杖之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000033",
    "sentence": "未幾，家僮詣宏肇上變，言契丹主之入汴也，趙延壽遣福殷賫玉枕陰遺淮南，以致誠意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000034",
    "sentence": "宏肇即日遣捕福殷等系之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000035",
    "sentence": "解暉希旨，榜掠備至，福殷自誣，連罪者數輩，並棄市。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000036",
    "sentence": "妻女爲宏肇帳下分取之，其家財籍沒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000037",
    "sentence": "宏肇不喜賓客，嘗言：「文人難耐，輕我輩，謂我輩爲卒，可恨可恨！」宏肇所領睢陽，其屬府公利，委親吏楊乙就府檢校，貪戾兇橫，負勢生事，吏民畏之，副戎已下，望風展敬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000038",
    "sentence": "聚劍刻剝，無所不至，月率萬緡，以輸宏肇，一境之內，嫉之如仇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000039",
    "sentence": "〈 （《東都事略·薛居正傳》：史宏肇領侍衞親軍，威震人主，殘忍自恣，人莫敢忤其意。其部下吏告民犯鹽禁，法當死。居正疑其不實，召詰之，乃其吏以私憾而誣之也。逮捕吏鞫之，具伏，以吏抵法。宏肇雖怒甚，竟亦無以屈也。） 〉 周太祖平河中班師，推功於眾，以宏肇有翊衞鎮重之功，言之於隱帝，即授兼中書令。",
    "entities": [
      {
        "text": "《東都事略·薛居正傳》",
        "label": "TITLE",
        "start": 3,
        "end": 14
      },
      {
        "text": "以宏肇有翊衞鎮",
        "label": "LOC",
        "start": 122,
        "end": 129
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000040",
    "sentence": "隱帝自關西賊平之後，昵近小人，太后親族，頗行幹托，宏肇與楊邠甚不平之。",
    "entities": [
      {
        "text": "隱帝自關",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000041",
    "sentence": "太后有故人子求補軍職，宏肇怒而斬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000042",
    "sentence": "帝始聽樂，賜教坊使玉帶，諸伶官錦袍，往謝宏肇，宏肇讓之曰：「健兒爲國戍邊，忍寒冒暑，未能遍有沾賜，爾輩何功，敢當此賜！」盡取袍帶還官，其兇戾如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000043",
    "sentence": "周太祖有鎮鄴之命，宏肇欲兼領機樞之任，蘇逢吉異其議，宏肇忿之。",
    "entities": [
      {
        "text": "周太祖有鎮",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "蘇逢吉",
        "label": "PER",
        "start": 19,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000044",
    "sentence": "翌日，因竇貞固飲會，貴臣悉集，宏肇厲色舉爵屬周太祖曰：「昨晨廷論，一何同異！今日與弟飲此。」楊邠、蘇逢吉亦舉大爵曰：「此國家之事也，何足介意！」俱飲釂。",
    "entities": [
      {
        "text": "蘇逢吉",
        "label": "PER",
        "start": 49,
        "end": 52
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000045",
    "sentence": "宏肇又厲聲言曰：「安朝廷，定禍亂，直須長槍大劍，至如毛錐子，焉足用哉！」三司使王章曰：「雖有長槍大劍，若無毛錐子，贍軍財賦，自何而集？」宏肇默然，少頃而罷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000046",
    "sentence": "未幾，三司使王章於其第張酒樂，時宏肇與宰相、樞密使及內客省使閻晉卿等俱會。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000047",
    "sentence": "酒酣，爲手勢令，宏肇不熟其事，而閻晉卿坐次宏肇，屢教之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000048",
    "sentence": "蘇逢吉戲宏肇曰：「近坐有姓閻人，何憂罰爵！」宏肇妻閻氏，本酒妓也，宏肇謂逢吉譏之，大怒，以醜語詬逢吉。",
    "entities": [
      {
        "text": "蘇逢吉",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000049",
    "sentence": "逢吉不校，宏肇欲毆逢吉，逢吉策馬而去，宏肇遽起索劍，意欲追逢吉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000050",
    "sentence": "楊邠曰：「蘇公是宰相，公若害之，致天子何地，公細思之！」邠泣下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000051",
    "sentence": "宏肇索馬急馳而去，邠慮有非常，連鑣而進，送至第而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000052",
    "sentence": "自是將相不協如水火矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000053",
    "sentence": "隱帝遣王峻將酒樂於公子亭以和之，竟不能解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000054",
    "sentence": "其後李業、郭允明、後贊、聶文進居中用事，不悅執政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000055",
    "sentence": "又見隱帝年漸長，厭爲大臣所制，嘗有忿言，業等乃乘間譖宏肇等，隱帝稍以爲信。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000056",
    "sentence": "業等乃言宏肇等專權震主，終必爲亂，隱帝益恐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000057",
    "sentence": "嘗一夕，聞作坊鍛甲之聲，疑外有兵仗卒至，達旦不寐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000058",
    "sentence": "自是與業等密謀禁中，欲誅宏肇等。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000059",
    "sentence": "議定，入白太后，太后曰：「此事豈可輕發耶！更問宰臣等。」李業在側，曰：「先皇帝言，朝廷大事，莫共措大商量。」太后又言之，隱帝怒曰：「閨門之內，焉知國家之事！」拂衣而出。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 37,
        "end": 39
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000060",
    "sentence": "內客省使閻晉卿潛知其事，乃詣宏肇私第，將欲告之，宏肇以他事拒之不見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000061",
    "sentence": "乾祐三年冬十一月十三日，宏肇入朝，與樞密使楊邠、三司使王章同坐於廣政殿東廡下，俄有甲士數十人自內而出，害宏肇等於閣，夷其族。",
    "entities": [
      {
        "text": "乾祐三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000062",
    "sentence": "先是，宏肇第數有異，嘗一日，於階砌隙中有煙氣蓬勃而出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000063",
    "sentence": "禍前二日昧爽，有星落於宏肇前三數步，如迸火而散，俄而被誅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000064",
    "sentence": "周太祖踐阼，追封鄭王，以禮葬，官爲立碑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000065",
    "sentence": "宏肇子 德充",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000066",
    "sentence": "宏肇子德充，乾祐中，授檢校司空，領忠州刺史。",
    "entities": [
      {
        "text": "領忠州",
        "label": "LOC",
        "start": 16,
        "end": 19
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000067",
    "sentence": "粗讀書，親儒者，常不悅父之所爲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000068",
    "sentence": "貢院嘗錄一學科於省門叫噪，申中書門下，宰相蘇逢吉令送侍衞司，請痛笞刺面。",
    "entities": [
      {
        "text": "蘇逢吉",
        "label": "PER",
        "start": 21,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000069",
    "sentence": "德充聞之，白父曰：「書生無禮，有府縣御史臺，非軍務治也。公卿如此，蓋欲彰大人之過。」宏肇深以爲然，即破械放之。",
    "entities": [
      {
        "text": "有府縣",
        "label": "LOC",
        "start": 15,
        "end": 18
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000070",
    "sentence": "後之識者尤嘉德充之爲人焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000071",
    "sentence": "宏肇弟 福",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000072",
    "sentence": "宏肇弟福，比在滎陽別墅，聞禍，匿於民間。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000073",
    "sentence": "周太祖即位，累遷閑廄使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000074",
    "sentence": "仕皇朝，歷諸衞將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000075",
    "sentence": "〈 （《宋史·李崇矩傳》：史宏肇爲先鋒都校，聞崇矩名，召署親吏。乾祐初，宏肇總禁兵，兼京城巡檢，多殘殺軍民，左右稍稍引去，惟崇矩事之益謹。及宏肇誅，獨得免。周祖與宏肇素厚善，即位，訪求宏肇親舊，得崇矩，謂之曰：「我與史公受漢厚恩，戮力同心，共獎王室，爲奸邪所構，史公卒罹大禍，我亦僅免。汝史家故吏也，爲我求其近屬，我將恤之。」崇矩上其母弟福。崇矩素主其家，盡籍財產以付福，周祖嘉之。 〉",
    "entities": [
      {
        "text": "《宋史·李崇矩傳》",
        "label": "TITLE",
        "start": 3,
        "end": 12
      },
      {
        "text": "兼京城",
        "label": "LOC",
        "start": 42,
        "end": 45
      },
      {
        "text": "周",
        "label": "ORG",
        "start": 78,
        "end": 79
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000076",
    "sentence": "楊邠",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000077",
    "sentence": "楊邠，魏州冠氏人也。",
    "entities": [
      {
        "text": "魏州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000078",
    "sentence": "少以吏給事使府，後唐租庸使孔謙，即其妻之世父也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000079",
    "sentence": "謙領度支，補勾押官，歷孟、華、鄆三州糧料使。",
    "entities": [
      {
        "text": "鄆三州",
        "label": "LOC",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000080",
    "sentence": "高祖爲鄴都留守，用爲左都押衙，高祖鎮太原，益加親委。",
    "entities": [
      {
        "text": "高祖鎮",
        "label": "LOC",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000081",
    "sentence": "漢國建，遷檢校太保、權樞密使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000082",
    "sentence": "汴、洛平，正拜樞密使、檢校太傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000083",
    "sentence": "及高祖大漸，與蘇逢吉、史宏肇等同受顧命，輔立嗣君。",
    "entities": [
      {
        "text": "蘇逢吉",
        "label": "PER",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000084",
    "sentence": "隱帝即位，宰臣李濤上章，請出邠與周太祖爲藩鎮，邠等泣訴於太后，由是罷濤而相邠，加中書侍郎兼吏部尚書、同平章事，仍兼樞密使。",
    "entities": [
      {
        "text": "與周太祖爲藩鎮",
        "label": "LOC",
        "start": 15,
        "end": 22
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 42,
        "end": 44
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 47,
        "end": 49
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000085",
    "sentence": "時中書除吏太多，訛謬者眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000086",
    "sentence": "及邠居相位，帝一以委之，凡南衙奏事，中書除命，先委邠斟酌，如不出邠意，至於一簿一掾，亦不聽從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000087",
    "sentence": "邠雖長於吏事，不識大體，常言：「爲國家者，但得帑藏豐盈，甲兵強盛，至於文章禮樂，並是虛事，何足介意也。」平河中，邠加右僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000088",
    "sentence": "邠既專國政，觸事苛細，條理煩碎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000089",
    "sentence": "前資官不得於外方居止，自京師至諸州府，行人往來，並須給公憑。",
    "entities": [
      {
        "text": "自京師至諸州",
        "label": "LOC",
        "start": 11,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000090",
    "sentence": "所由司求請公憑者，朝夕填咽，旬日之間，民情大擾，行路擁塞，邠乃止其事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000091",
    "sentence": "時史宏肇恣行慘酷，殺戮日眾，都人士庶，相目於路，邠但稱宏肇之善。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000092",
    "sentence": "太后弟武德使李業求爲宣徽使，隱帝與太后重違之，私訪於邠，邠以朝廷內使，遷拜有序，不可超居，遂止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000093",
    "sentence": "隱帝所愛耿夫人，欲立爲後，邠亦以爲太速。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000094",
    "sentence": "夫人卒，隱帝欲以後禮葬，邠又止之，隱帝意不悅，左右有承間進甘言者，隱帝益怒之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000095",
    "sentence": "〈 案：此下疑有闕文。 〉 邠繕甲兵，實帑廩，俾國用不闕，邊鄙粗寧，亦其功也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000096",
    "sentence": "〈 《宣和書譜》云：邠末年留意縉紳，延客門下，知經史有用，乃課吏傳寫。 〉",
    "entities": [
      {
        "text": "《宣和書譜》",
        "label": "TITLE",
        "start": 2,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000097",
    "sentence": "王章",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000098",
    "sentence": "王章，大名南樂人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000099",
    "sentence": "少爲吏，給事使府。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000100",
    "sentence": "同光初，隸樞密院，後歸本郡，累職至都孔目官。",
    "entities": [
      {
        "text": "後歸本郡",
        "label": "LOC",
        "start": 9,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000101",
    "sentence": "後唐清泰末，屯駐捧聖都虞候張令昭作亂，逐節度使劉延皓，自稱留後，章以本職爲令昭役使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000102",
    "sentence": "末帝遣範延光討平之，搜索叛黨甚急。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000103",
    "sentence": "章之妻即白文珂之女也，文珂與副招討李敬周善，以章爲托。",
    "entities": [
      {
        "text": "白文珂",
        "label": "PER",
        "start": 4,
        "end": 7
      },
      {
        "text": "李敬周",
        "label": "PER",
        "start": 17,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000104",
    "sentence": "及攻下逆城，敬周匿之，載於橐駝褚中，竄至洛下，匿於敬周之私第。",
    "entities": [
      {
        "text": "及攻下逆城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000105",
    "sentence": "及末帝敗，章爲省職，歷沔陽糧料使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000106",
    "sentence": "高祖典侍衞親軍，詔爲都孔目官，從至河東，專委錢穀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000107",
    "sentence": "國初，授三司使、檢校太傅，從征杜重威於鄴下。",
    "entities": [
      {
        "text": "杜重威",
        "label": "PER",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000108",
    "sentence": "明年，高祖崩，隱帝即位，加檢校太尉、同平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000109",
    "sentence": "居無何，蒲、雍、岐三鎮畔。",
    "entities": [
      {
        "text": "岐三鎮",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000110",
    "sentence": "是時，契丹犯闕之後，國家新造，物力未充。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000111",
    "sentence": "章與周太祖、史宏肇、楊邠等盡心王室，知無不爲，罷不急之務，惜無用之費，收聚財賦，專事西征，軍旅所資，供饋無乏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000112",
    "sentence": "及三叛平，賜與之外，國有餘積。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000113",
    "sentence": "然以專於權利，剝下過當，斂怨歸上，物論非之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000114",
    "sentence": "舊制，秋夏苗租，民稅一斛，別輸二升，謂之「雀鼠耗」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000115",
    "sentence": "乾祐中，輸一斛者，別令輸二斗，目之爲「省耗」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000116",
    "sentence": "百姓苦之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000117",
    "sentence": "又，官庫出納緡錢，皆以八十爲陌，至是民輸者如舊，官給者以七十七爲陌，遂爲常式。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000118",
    "sentence": "〈 《歸田錄》：用錢之法，自五代以來，以七十七爲百，謂之「省陌」。今市井交易，又克其五，謂之「依除」。 〉 民有訴田者，雖無十數戶，章必命全州覆視，幸其廣有苗額，以增邦賦，曾未數年，民力大困。",
    "entities": [
      {
        "text": "《歸田錄》",
        "label": "TITLE",
        "start": 2,
        "end": 7
      },
      {
        "text": "章必命全州",
        "label": "LOC",
        "start": 66,
        "end": 71
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000119",
    "sentence": "章與楊邠不喜儒士，郡官所請月俸，皆取不堪資軍者給之，謂之「閑雜物」，命所司高估其價，估定更添，謂之「擡估」，章亦不滿其意，隨事更令更添估。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000120",
    "sentence": "章急於財賦，峻於刑法，民有犯鹽礬酒曲之令，雖絲毫滴瀝，盡處極刑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000121",
    "sentence": "吏緣爲奸，民不堪命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000122",
    "sentence": "章與楊邠同郡，尤爲親愛，其獎用進拔者，莫非鄕舊。",
    "entities": [
      {
        "text": "章與楊邠同郡",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000123",
    "sentence": "常輕視文臣，曰：「此等若與一把算子，未知顛倒，何益於事！」後因私第開宴席，召賓客，史宏肇、蘇逢吉乘醉喧詬而罷。",
    "entities": [
      {
        "text": "蘇逢吉",
        "label": "PER",
        "start": 45,
        "end": 48
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000124",
    "sentence": "章自是忽忽不樂，潛求外任。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000125",
    "sentence": "邠與宏肇深沮其意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000126",
    "sentence": "而私第數有怪異，章愈懷憂恐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000127",
    "sentence": "乾祐三年冬，與史宏肇、楊邠等遇害，夷其族。",
    "entities": [
      {
        "text": "乾祐三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000128",
    "sentence": "妻白氏，禍前數月而卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000129",
    "sentence": "無子，惟一女，適戶部員外郎張貽肅，羸疾逾年，扶病就戮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000130",
    "sentence": "李洪建",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000131",
    "sentence": "李洪建，太后母弟也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000132",
    "sentence": "事高祖爲牙將，高祖即位，累歷軍校，遙領防禦使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000133",
    "sentence": "史宏肇等被誅，以洪建爲權侍衞馬步軍都虞候。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000134",
    "sentence": "及鄴兵南渡，命洪建誅王殷之族，洪建不即行之，但遣人監守其家，仍令給饌，竟免屠戮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000135",
    "sentence": "周太祖入京城，洪建被執，王殷感洪建之恩，累祈周太祖乞免其死，不從，遂殺之。",
    "entities": [
      {
        "text": "周太祖入京城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000136",
    "sentence": "洪建弟業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000137",
    "sentence": "洪建弟 業",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000138",
    "sentence": "業，昆仲凡六人，業處其季，故太后尤憐之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000139",
    "sentence": "高祖置之麾下，及即位，累遷武德使，出入禁中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000140",
    "sentence": "業恃太后之親，稍至驕縱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000141",
    "sentence": "隱帝嗣位，尤深倚愛，兼掌內帑，四方進貢二宮費委之出納。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000142",
    "sentence": "業喜趨權利，無所顧避，執政大臣不敢禁詰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000143",
    "sentence": "會宣徽使闕，業意欲之，太后亦令人微露風旨於執政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000144",
    "sentence": "時楊邠、史宏肇等難之，業由是積怨，蕭墻之變，自此而作。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000145",
    "sentence": "楊、史既誅，業權領侍衞步軍都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000146",
    "sentence": "北郊兵敗，業自取金寶懷之，策馬西奔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000147",
    "sentence": "行至陜郊，其節度使洪信，即其長兄也，不敢匿於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000148",
    "sentence": "業將奔太原，至絳州境，爲盜所殺，盡奪而去。",
    "entities": [
      {
        "text": "至絳州",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000149",
    "sentence": "閻晉卿",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000150",
    "sentence": "閻晉卿者，忻州人也。",
