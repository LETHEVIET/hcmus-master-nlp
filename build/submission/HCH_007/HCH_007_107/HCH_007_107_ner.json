      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000155",
    "sentence": "時宣徽使闕，晉卿以職次事望，合當其任，既而久稽拜命，晉卿頗怨執政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000156",
    "sentence": "會李業等謀殺楊、史，詔晉卿謀之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000157",
    "sentence": "晉卿退詣宏肇，將告其事，宏肇不見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000158",
    "sentence": "晉卿憂事不果，夜懸高祖御容於中堂，泣禱於前，遲明戎服入朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000159",
    "sentence": "內難既作，以晉卿權侍衞馬軍都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000160",
    "sentence": "北郊兵敗，晉卿乃自殺於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000161",
    "sentence": "聶文進",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000162",
    "sentence": "聶文進，并州人。",
    "entities": [
      {
        "text": "并州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000163",
    "sentence": "少給事於高祖帳下，高祖鎮太原，甚見委用，職至兵馬押司官。",
    "entities": [
      {
        "text": "高祖鎮",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000164",
    "sentence": "高祖入汴，授樞密院承旨，歷領軍、屯衞大將軍，遷右衞大將軍，仍領舊職。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 18,
        "end": 21
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000165",
    "sentence": "遇周太祖出征，稍至驕橫，久未遷改，深所怨望，與李業輩構成變亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000166",
    "sentence": "史宏肇等遇害之前夕，文進與同黨預作宣詔，制置朝廷之事，凡關文字，並出文進之手。",
    "entities": [
      {
        "text": "凡關",
        "label": "LOC",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000167",
    "sentence": "明日難作，文進點閱兵籍，征發軍眾，指揮取舍，以爲己任，內外咨稟，前後填咽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000168",
    "sentence": "太祖在鄴被構，初謂文進不預其事，驗其事跡，方知文進亂階之首也，大詬詈之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000169",
    "sentence": "太祖過封丘，帝次於北郊，文進告太后曰：「臣在此，請宮中勿憂。」兵散之後，文進召同黨痛飲，歌笑自若。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000170",
    "sentence": "遲明，帝遇禍，文進奔竄，爲軍士所追，梟其首。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000171",
    "sentence": "後贊",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000172",
    "sentence": "後贊，爲飛龍使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000173",
    "sentence": "贊母本倡家也，與父同郡，往來其家，生贊。",
    "entities": [
      {
        "text": "與父同郡",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000174",
    "sentence": "從職四方，父未嘗離郡，贊既長，疑其所生。",
    "entities": [
      {
        "text": "父未嘗離郡",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000175",
    "sentence": "及爲內職，不欲父之來，寓書以致其意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000176",
    "sentence": "父自郡至京師，直抵其第，贊不得已而奉之。",
    "entities": [
      {
        "text": "父自郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000177",
    "sentence": "乾祐末，宰相楊祐、侍衞親軍使史宏肇執權，贊以久次未遷，頗懷怨望，乃與樞密承旨聶文進等構變。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000178",
    "sentence": "及難作，贊與同黨更侍帝側，剖判戎事，且防間言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000179",
    "sentence": "北郊兵敗，贊竄歸兗州，慕容彥超執之以獻，有司鞫贊伏罪，周太祖命誅之。",
    "entities": [
      {
        "text": "贊竄歸兗州",
        "label": "LOC",
        "start": 5,
        "end": 10
      },
      {
        "text": "慕容彥超",
        "label": "PER",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000180",
    "sentence": "郭允明",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000181",
    "sentence": "郭允明者，小名竇十，河東人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000182",
    "sentence": "幼隸河東制置使範徽柔，被誅，允明遂爲高祖廝養，服勤既久，頗得高祖之歡心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000183",
    "sentence": "高祖鎮太原，稍歷牙職，及即位，累遷至翰林茶酒使兼鞍轡庫使。",
    "entities": [
      {
        "text": "高祖鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000184",
    "sentence": "隱帝嗣位，尤見親狎，每恃寵驕縱，略無禮敬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000185",
    "sentence": "與相州節度使郭謹以同宗之故，頗交結。",
    "entities": [
      {
        "text": "與相州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000186",
    "sentence": "謹在鎮，允明常賫禦酒以遺之，不以僭上犯禁爲意。",
    "entities": [
      {
        "text": "謹在鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000187",
    "sentence": "其他輕率，悉皆類此，執政大臣頗姑息之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000188",
    "sentence": "嘗奉使荊南，車服導從，有同節度使將，州縣郵驛，奔馳畏懾，節度使高保融承迎不暇。",
    "entities": [
      {
        "text": "州縣",
        "label": "LOC",
        "start": 18,
        "end": 20
      },
      {
        "text": "高保融",
        "label": "PER",
        "start": 31,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000189",
    "sentence": "允明潛使人步度城壁之高庳、池隍之廣隘，以動荊人，冀得重賄。",
    "entities": [
      {
        "text": "明潛使人步度城",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000190",
    "sentence": "乾祐末，兼飛龍使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000191",
    "sentence": "未幾，與李業輩構變，楊邠等諸子，允明親刃之於朝堂西廡下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000192",
    "sentence": "王章女婿戶部員外郎張貽肅，血流逆註，聞者哀之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000193",
    "sentence": "及北郊之敗，允明迫帝就民舍，手行弒逆，尋亦自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000194",
    "sentence": "劉銖",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000195",
    "sentence": "劉銖，陜州人也。",
    "entities": [
      {
        "text": "陜州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000196",
    "sentence": "少事梁邵王朱友誨爲牙將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000197",
    "sentence": "晉天福中，高祖爲侍衞親軍都指揮使，與銖有舊，乃表爲內職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000198",
    "sentence": "高祖出鎮並門，用爲左都押牙。",
    "entities": [
      {
        "text": "高祖出鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000199",
    "sentence": "銖性慘毒好殺，高祖以爲勇斷類己，深委遇之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000200",
    "sentence": "國初，授永興軍節度使，從定汴、洛、移鎮青州，加同平章事。",
    "entities": [
      {
        "text": "移鎮青州",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000201",
    "sentence": "隱帝即位，加檢校太師、兼侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000202",
    "sentence": "銖立法深峻，令行禁止，吏民有過，不問輕重，未嘗貸免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000203",
    "sentence": "每親事，小有忤旨，即令倒曳而出，至數百步外方止，膚體無完者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000204",
    "sentence": "每杖人，遣雙杖對下，謂之「合歡杖」；或杖人如其歲數，謂之「隨年杖」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000205",
    "sentence": "在任擅行賦斂，每秋苗一畝率錢三千，夏苗一畝錢二千，以備公用，部內畏之，脅肩重跡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000206",
    "sentence": "乾祐中，淄、青大蝗，銖下令捕蝗，略無遺漏，田苗無害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000207",
    "sentence": "先是，濱海郡邑，皆有兩浙回易務，厚取民利，自置刑禁，追攝王民，前後長吏利其厚賂，不能禁止。",
    "entities": [
      {
        "text": "濱海郡邑",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000208",
    "sentence": "銖即告所部，不得與吳越征負，擅行追攝，浙人惕息，莫敢幹命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_107_000209",
    "sentence": "朝廷懼銖之剛戾難制，因前浙州刺史郭瓊自海州用兵還，過青州，遂留之，即以府彥卿代銖，銖即時受代。",
    "entities": [
      {
        "text": "因前浙州",
        "label": "LOC",
        "start": 10,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "過青州",
        "label": "LOC",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_007_107_000210",
    "sentence": "〈 《隆平集》《郭瓊傳》云：劉銖守平盧，稱疾不朝，隱帝疑其叛，詔瓊領兵屯青州。銖將害之，張宴伏兵幕下，瓊無懼色，銖亦不敢發。瓊爲言去就禍福，銖趨召。 〉 離鎮之日，有私鹽數屋，雜以糞穢，填塞諸井，以土平之。",
    "entities": [
      {
        "text": "《隆平集》",
        "label": "TITLE",
        "start": 2,
        "end": 7
      },
      {
        "text": "《郭瓊傳》",
        "label": "TITLE",
