[
  {
    "sentence_id": "HCH_007_135_000001",
    "sentence": "劉守光",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000002",
    "sentence": "劉守光，深州樂壽人也。",
    "entities": [
      {
        "text": "深州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000003",
    "sentence": "其父仁恭，初隨父晟客於范陽，晟以軍吏補新興鎮將，事節度使李可舉。",
    "entities": [
      {
        "text": "以軍吏補新興鎮",
        "label": "LOC",
        "start": 15,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000004",
    "sentence": "仁恭幼多智機，數陳力於軍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000005",
    "sentence": "李全忠之攻易、定也，別將于晏圍易州，累月不能拔，仁恭穴地道以陷之，軍中號曰「劉窟頭」，稍遷裨校。",
    "entities": [
      {
        "text": "別將于晏圍易州",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000006",
    "sentence": "仁恭誌大氣豪，自言嘗夢大佛幡出於指端，或云年四十九當領旄節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000007",
    "sentence": "此言頗泄，燕帥李匡威惡之，不欲令典軍，改為府掾，出為景城令。",
    "entities": [
      {
        "text": "出為景城",
        "label": "LOC",
        "start": 24,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000008",
    "sentence": "屬瀛州軍亂，殺郡守，仁恭募白丁千人討平之，匡威壯其才，復使為帳中爪牙，令將兵戍蔚州。",
    "entities": [
      {
        "text": "屬瀛州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "殺郡",
        "label": "LOC",
        "start": 6,
        "end": 8
      },
      {
        "text": "令將兵戍蔚州",
        "label": "LOC",
        "start": 35,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000009",
    "sentence": "兵士以過期不代，思歸流怨，會李匡儔奪兄位，戍軍擁仁恭為帥，欲攻幽州，比至居庸關，為府兵所敗，仁恭挈族奔於太原。",
    "entities": [
      {
        "text": "欲攻幽州",
        "label": "LOC",
        "start": 29,
        "end": 33
      },
      {
        "text": "比至居庸關",
        "label": "LOC",
        "start": 34,
        "end": 39
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000010",
    "sentence": "武皇遇之甚厚，賜田宅以處之，出為壽陽鎮將，從征吐渾。",
    "entities": [
      {
        "text": "出為壽陽鎮",
        "label": "LOC",
        "start": 14,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000011",
    "sentence": "仁恭數進畫於蓋寓，言幽州可圖之狀，願得步騎萬人，即指期可取，武皇從之。",
    "entities": [
      {
        "text": "言幽州",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000012",
    "sentence": "洎仁恭舉兵，屢不克捷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000013",
    "sentence": "唐 乾寧元年 十一月，武皇親征匡儔。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000014",
    "sentence": "十二月，破燕軍於威塞，進拔媯州，收居庸。",
    "entities": [
      {
        "text": "進拔媯州",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000015",
    "sentence": "二十六日，匡儔棄城而遁，武皇令李存審與仁恭入城撫勞，封府庫，即以仁恭為幽州節度使，留腹心燕留德等十餘人分典軍政，武皇乃還。",
    "entities": [
      {
        "text": "匡儔棄城",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "存審與仁恭入城",
        "label": "LOC",
        "start": 16,
        "end": 23
      },
      {
        "text": "即以仁恭為幽州",
        "label": "LOC",
        "start": 30,
        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000016",
    "sentence": "二年七月，武皇討王行瑜，師於渭北，上章請授仁恭節鉞。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000017",
    "sentence": "九月，天子以仁恭為檢校司空、幽州廬龍軍節度使。",
    "entities": [
      {
        "text": "幽州",
        "label": "LOC",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000018",
    "sentence": "三年，羅宏信背盟，武皇遣李存信攻魏州，征兵於燕，仁恭托以契丹入寇，俟敵退聽命。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "遣李存信攻魏州",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000019",
    "sentence": "四年七月，武皇聞兗、鄆俱陷，復征兵於仁恭，數月之間，使車結轍，仁恭辭旨不遜。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000020",
    "sentence": "武皇以書讓之，仁恭覽書嫚罵，拘其使人，晉之戍兵在燕者皆拘之，復以厚利誘晉之驍將，由是亡命者眾矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000021",
    "sentence": "八月，武皇討仁恭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000022",
    "sentence": "九月五日，次安塞軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000023",
    "sentence": "九日，渡木瓜澗，大為燕軍所敗，死傷大半。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000024",
    "sentence": "既而仁恭告捷於梁祖，梁祖聞之喜，因表仁恭加平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000025",
    "sentence": "仁恭又遣使於武皇，自陳邊將擅興之罪，武皇以書報之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000026",
    "sentence": "仁恭既絕於晉，恒懼討罰，募兵練眾，常無虛月。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000027",
    "sentence": "光化元年 三月，令其長子襲淪州，盧彥威委城而遁，遂兼有滄、景、德三郡，以守文為留後，請節鉞於朝。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "令其長子襲淪州",
        "label": "LOC",
        "start": 8,
        "end": 15
      },
      {
        "text": "盧彥威委城",
        "label": "LOC",
        "start": 16,
        "end": 21
      },
      {
        "text": "德三郡",
        "label": "LOC",
        "start": 31,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000028",
    "sentence": "昭宗怒其擅興，不時與之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000029",
    "sentence": "會中使至范陽，仁恭私之曰：「旄節吾自有，但要長安本色耳，何以累章見阻？為吾言之。」其悖戾如此。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000030",
    "sentence": "仁恭兵鋒益盛，每戰多捷，以為天贊，遂有吞噬河朔之志。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000031",
    "sentence": "二年正月，仁恭率幽、滄步騎十萬，號三十萬，將兼並魏博、鎮定。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000032",
    "sentence": "師次貝州，一鼓而拔，無少長皆屠之，清水為之不流。",
    "entities": [
      {
        "text": "師次貝州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000033",
    "sentence": "羅紹威求援於汴，汴將李思安、葛從周赴之，思安屯內黃。",
    "entities": [
      {
        "text": "羅紹威",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000034",
    "sentence": "仁恭兵圍魏州，聞汴軍在內黃，戒其子守文曰：「李思安怯懦，汝之智勇，比之十倍，當先殄此鼠輩，次擄紹威。」守文與單可及率漁陽精甲五萬，夾清水而上。",
    "entities": [
      {
        "text": "仁恭兵圍魏州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000035",
    "sentence": "思安設伏於內黃清水之左，袁象先設伏於內黃清水之右。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000036",
    "sentence": "思安逆戰於繁陽城，偽不勝，徐退，燕人追躡，至於內黃，思安步兵成列，回擊之。",
    "entities": [
      {
        "text": "安逆戰於繁陽城",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000037",
    "sentence": "燕人將引退，左右伏兵發，燕軍大敗，臨陣斬單可及，守文單騎僅免，五萬之眾無生還者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000038",
    "sentence": "時葛從周率邢、洺之眾入魏州，與賀德倫、李暉出擊賊營。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000039",
    "sentence": "是夜，仁恭燒營遁走，汴人長驅追擊，自魏至長河數百里，僵屍蔽地，敗旗折戟，累累於路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000040",
    "sentence": "鎮人又邀擊於東境，燕軍復敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000041",
    "sentence": "仁恭自是垂翅不振者累年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000042",
    "sentence": "汴人乘勝攻滄州，仁恭率師援之，營於乾寧軍。",
    "entities": [
      {
        "text": "汴人乘勝攻滄州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000043",
    "sentence": "汴將氏叔琮逆戰，燕軍逗撓，退保瓦橋，乃卑辭厚禮乞師於晉，武皇遣兵逼邢、洺以應之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000044",
    "sentence": "十月，汴人陷瀛、鄚二州，晉將周德威將兵出飛狐，仁恭復修好於晉。",
    "entities": [
      {
        "text": "鄚二州",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000045",
    "sentence": "天祐三年 七月，梁祖自將兵攻滄州，營於長蘆。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "祖自將兵攻滄州",
        "label": "LOC",
        "start": 9,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000046",
    "sentence": "仁恭師徒屢喪，乃酷法盡發部內男子十五已上、七十已下，各自備兵糧以從軍，閭裏為之一空。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000047",
    "sentence": "部內男子無貴踐，並黥其面，文曰「定霸都」，士人黥其臂，文曰「一心事主」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000048",
    "sentence": "由是燕、薊人民例多黥涅，或伏竄而免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000049",
    "sentence": "仁恭閱眾，得二十萬，進至瓦橋，汴人深溝高壘以攻滄州，內外阻絕，仁恭不能合戰，城中大饑，人相篡啖，析骸而爨，丸土而食，轉死骨立者十之六七。",
    "entities": [
      {
        "text": "溝高壘以攻滄州",
        "label": "LOC",
        "start": 18,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000050",
    "sentence": "自七月至十月，仁恭遣使求援於晉，前後百餘輩，武皇乃征兵於燕，仁恭遣都將李溥夏侯景、監軍張居翰、書記馬郁等，以兵三萬來會。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000051",
    "sentence": "十二月，合晉師以攻潞州，降丁會，乃解滄州之圍。",
    "entities": [
      {
        "text": "合晉師以攻潞州",
        "label": "LOC",
        "start": 4,
        "end": 11
      },
      {
        "text": "乃解滄州",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000052",
    "sentence": "是時，天子播遷，中原多故，仁恭嘯傲薊門，誌意盈滿，師道士王若訥，祈長生羽化之道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000053",
    "sentence": "幽州西有名山曰大安山，仁恭乃於其上盛飾館宇，僭擬宮掖，聚室女艷婦，窮極侈麗。",
    "entities": [
      {
        "text": "幽州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000054",
    "sentence": "又招聚緇黃，合仙丹，講求法要。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000055",
    "sentence": "又以瑾泥作錢，令部內行使，盡斂銅錢於大安山巔，鑿穴以藏之，藏畢即殺匠石以滅其口。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000056",
    "sentence": "又禁江表茶商，自擷山中草葉為茶，以邀厚利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000057",
    "sentence": "改山名為大恩山。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000058",
    "sentence": "仁恭有嬖妾曰羅氏，美姿色，其子守光烝之，事泄，仁恭怒，笞守光，謫而不齒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000059",
    "sentence": "四年四月，汴將李思安以急兵攻幽州，營於石子河，仁恭在大安山，城中無備，守光自外帥兵來援，登城拒守。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "安以急兵攻幽州",
        "label": "LOC",
        "start": 9,
        "end": 16
      },
      {
        "text": "登城",
        "label": "LOC",
        "start": 44,
        "end": 46
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000060",
    "sentence": "汴軍既退，守光乃自為幽州節度，令其部將李小喜、元行欽將兵攻大安山。",
    "entities": [
      {
        "text": "守光乃自為幽州",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000061",
    "sentence": "仁恭遣兵拒戰，為小喜所敗，乃擄仁恭歸幽州，囚於別室。",
    "entities": [
      {
        "text": "乃擄仁恭歸幽州",
        "label": "LOC",
        "start": 13,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000062",
    "sentence": "仁恭左右，迨至婢媵，與守光不協者畢誅之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000063",
    "sentence": "其兄守文在滄州，聞父被囚，聚兵大哭，諭之曰：「哀哀父母，生我劬勞。自古豈有讎父者，吾家生此梟獍，吾生不如死！」即率滄、德之師討之。",
    "entities": [
      {
        "text": "其兄守文在滄州",
