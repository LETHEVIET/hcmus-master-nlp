        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000198",
    "sentence": "月餘，世宗乃旋軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_135_000199",
    "sentence": "顯德二年 十一月，崇以病死，其子承鈞襲偽位。",
    "entities": [
      {
        "text": "顯德二年",
        "label": "TME",
