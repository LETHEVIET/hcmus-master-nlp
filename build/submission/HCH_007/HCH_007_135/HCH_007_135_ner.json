      }
    ]
  },
  {
    "sentence_id": "HCH_007_135_000183",
    "sentence": "署其子承鈞為侍衛親軍都指揮使、太原尹，以判官鄭拱、趙華為宰相，副使李瑰、代州刺史張暉為腹心，尋遣承鈞率兵攻晉、隰二州，不克而退。",
    "entities": [
