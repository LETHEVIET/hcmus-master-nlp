  },
  {
    "sentence_id": "HCH_007_069_000112",
    "sentence": "延朗再上表辭曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000113",
    "sentence": "臣濫承雨露，擢處鈞衡，兼叨選部之銜，仍掌計司之重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000114",
    "sentence": "況中省文章之地，洪爐陶鑄之門，臣自揣量，何以當處。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000115",
    "sentence": "是以繼陳章表，疊貢情誠，乞請睿恩，免貽朝論。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000116",
    "sentence": "豈謂禦批累降，聖旨不移，決以此官，委臣非器，所以強收涕泗，勉遏怔忪，重思事上之門，細料盡忠之路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000117",
    "sentence": "竊以位高則危至，寵極則謗生，君臣莫保於初終，分義難防於毀譽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000118",
    "sentence": "臣若保茲重任，忘彼至公，徇情而以免是非，偷安而以固富貴，則內欺心腑，外負聖朝，何以報君父之大恩，望子孫之延慶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000119",
    "sentence": "臣若但行王道，惟守國章，任人必取當才，決事須依正理，確違形勢，堅塞幸門，則可以振舉宏綱，彌縫大化，助陛下含容之澤，彰國家至理之風，然而讒邪者必起憾詞，憎嫉者寧無謗議，或慮至尊未悉，群謗難明，不更拔本尋源，便俟甘瑕受玷，臣心可忍，臣恥可消。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000120",
    "sentence": "隻恐山林草澤之人，稱量聖製；冠履軒裳之士，輕慢朝廷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000121",
    "sentence": "臣又以國計一司，掌其經費，利權二務，職在捃收。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000122",
    "sentence": "將欲養四海之貧民，無過薄賦；贍六軍之勁士，又藉豐儲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000123",
    "sentence": "利害相隨，取與難酌，若使罄山采木，竭澤求魚，則地官之教化不行，國本之傷殘益甚，取怨黔首，是黷皇風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000124",
    "sentence": "況諸道所征賦租，雖多數額，時逢水旱，或遇蟲霜，其間則有減無添，所在又申逃係欠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000125",
    "sentence": "乃至軍儲官俸，常汲汲於供須；夏稅秋租，每懸懸於繼續。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000126",
    "sentence": "況今內外倉庫，多是罄空；遠近生民，或聞饑歉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000127",
    "sentence": "伏惟朝廷尚添軍額，更益師徒，非時之博糴難為，異日之區分轉大。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000128",
    "sentence": "竊慮年支有闕，國計可憂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000129",
    "sentence": "望陛下節例外之破除，放諸項以儉省，不添冗食，且止新兵，務急去繁，以寬經費，減奢從儉，漸俟豐盈，則屈者知恩，叛者從化，弭兵有日，富俗可期。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000130",
    "sentence": "臣又聞治民尚清，為政務易，易則煩苛並去，清則偏黨無施。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000131",
    "sentence": "若擇其良牧，委在正人，則境內蒸黎，必獲蘇息，官中倉庫，亦絕侵欺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000132",
    "sentence": "伏望誡見在之處官，無乖撫俗；擇將來之蒞事，更審求賢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000133",
    "sentence": "儻一一得人，則農無所苦；人人致理，則國復何憂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000134",
    "sentence": "但奉公善政者，不惜重酬；昧理無功者，勿頒厚俸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000135",
    "sentence": "益彰有道，兼絕徇情。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000136",
    "sentence": "伏望陛下，念臣布露之前言，閔臣驚憂於後患，察臣愚直，杜彼讒邪，臣即但副天心，不防人口，庶幾萬一，仰答聖明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000137",
    "sentence": "末帝優詔答之，召於便殿，謂之曰：「卿所論奏，深中時病，形之切言，頗救朕失。國計事重，日得商量，無勞過慮也。」延朗不得已而承命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000138",
    "sentence": "延朗有心計，善理繁劇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000139",
    "sentence": "晉高祖在太原，朝廷猜忌，不欲令有積聚，係官財貨留使之外，延朗悉遣取之，晉高祖深銜其事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000140",
    "sentence": "及晉陽起兵，末帝議親征，然亦采浮論，不能果決；延朗獨排眾議，請末帝北行，識者韙之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000141",
    "sentence": "晉高祖入洛，送台獄以誅之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000142",
    "sentence": "其後以選求計使，難得其人，甚追悔焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000143",
    "sentence": "劉延皓，應州渾元人。",
    "entities": [
      {
        "text": "應州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000144",
    "sentence": "祖建立，父茂成，皆以軍功推為邊將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000145",
    "sentence": "延皓即劉後之弟也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000146",
    "sentence": "末帝鎮鳳翔，署延皓元隨都校，奏加檢校戶部尚書。",
    "entities": [
      {
        "text": "末帝鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000147",
    "sentence": "清泰元年，除宮苑使，加檢校司空。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000148",
    "sentence": "俄改宣徽南院使、檢校司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000149",
    "sentence": "二年，遷樞密使、太保，出為鄴都留守、檢校太傅。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000150",
    "sentence": "延皓禦軍失政，為屯將張令昭所逐，出奔相州，尋詔停所任。",
    "entities": [
      {
        "text": "出奔相州",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000151",
    "sentence": "及晉高祖入洛，延皓逃匿龍門廣化寺，數日，自經而死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000152",
    "sentence": "延皓始以後戚自藩邸出入左右，甚以溫厚見稱，故末帝嗣位之後，委居近密。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000153",
    "sentence": "及出鎮大名，而所執一變，掠人財賄，納人園宅，聚歌僮為長夜之飲，而三軍所給不時，內外怨之，因為令昭所逐。",
    "entities": [
      {
        "text": "及出鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000154",
    "sentence": "時執政以延皓失守，請舉舊章，末帝以劉後內政之故，止從罷免而已，由是清泰之政弊矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000155",
    "sentence": "劉延朗，宋州虞城人也。",
    "entities": [
      {
        "text": "宋州虞城",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000156",
    "sentence": "末帝鎮河中時，為鄆城馬步都虞候，後納為腹心。",
    "entities": [
      {
        "text": "末帝鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "為鄆城",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000157",
    "sentence": "及鎮鳳翔，署為孔目吏。",
    "entities": [
      {
        "text": "及鎮",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000158",
    "sentence": "末帝將圖起義，為捍禦之備，延朗計公私粟帛，以贍其急。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000159",
    "sentence": "及西師納降，末帝赴洛，皆無所闕焉，末帝甚賞之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000160",
    "sentence": "清泰初，除宣徽北院使，俄以劉延皓守鄴，改副樞密使，累官至檢校太傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000161",
    "sentence": "時房皓為樞密使，但高枕閑眠，啟奏除授，一歸延朗，由是得志。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000162",
    "sentence": "凡藩侯郡牧，自外入者，必先賂延朗，後議進貢，賂厚者先居內地，賂薄者晚出邊藩，故諸將屢有怨訕，末帝不能察之。",
    "entities": [
      {
        "text": "凡藩侯郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000163",
    "sentence": "及晉高祖入洛，延朗將竄於南山，與從者數輩，過其私第，指而歎曰：「我有錢三十萬貫聚於此，不知為何人所得。」其愚暗如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000164",
    "sentence": "尋捕而殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000165",
    "sentence": "本北宋作品在全世界都属于 公有领域 ，因为作者逝世已经遠遠超过100年。",
    "entities": [
      {
        "text": "100年",
        "label": "TME",
        "start": 31,
        "end": 35
      }
    ]
  }
]
