      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000069",
    "sentence": "裝學書無師法，工詩非作者，僻於題壁，所至宮亭寺觀，必書爵裏，人或譏之，不以為愧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000070",
