[
  {
    "sentence_id": "HCH_007_069_000001",
    "sentence": "張憲，字允中，晉陽人，世以軍功為牙校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000002",
    "sentence": "憲始童丱，喜儒學，勵志橫經，不舍晝夜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000003",
    "sentence": "太原地雄邊服，人多尚武，恥於學業，惟憲與里人藥縱之精力遊學，弱冠盡通諸經，尤精《左傳》。",
    "entities": [
      {
        "text": "《左傳》",
        "label": "TITLE",
        "start": 39,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000004",
    "sentence": "嘗袖行所業，謁判官李襲吉，一見欣歎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000005",
    "sentence": "既辭，謂憲曰：「子勉之，將來必成佳器。」石州刺史楊守業喜聚書，以家書示之，聞見日博。",
    "entities": [
      {
