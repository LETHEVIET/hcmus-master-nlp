  {
    "sentence_id": "HCH_007_069_000089",
    "sentence": "莊宗初定魏博，選幹吏以計兵賦，以鵠為度支孔目官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000090",
