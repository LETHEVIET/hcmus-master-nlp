        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000006",
    "sentence": "莊宗為行軍司馬，廣延髦俊，素知憲名，令朱守殷齎書幣延之。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000007",
    "sentence": "歲餘，釋褐交城令，秩滿，莊宗嗣世，補太原府司錄參軍。",
    "entities": [
      {
        "text": "釋褐交城",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000008",
    "sentence": "時霸府初開，幕客馬鬱、王緘，燕中名士，盡與之遊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000009",
    "sentence": "十二年，莊宗平河朔，念藩邸之舊，征赴行台。",
    "entities": [
      {
        "text": "十二年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000010",
    "sentence": "十三年，授監察，賜緋，署魏博推官，自是恒簪筆扈從。",
    "entities": [
      {
        "text": "十三年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000011",
    "sentence": "十五年，王師戰胡柳，周德威軍不利，憲與同列奔馬北渡；梁軍急追，殆將不濟。",
    "entities": [
      {
        "text": "十五年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_069_000012",
    "sentence": "至晚渡河，人皆陷水而沒，憲與從子朗履冰而行；將及岸，冰陷，朗泣，以馬箠引之，憲曰：「吾兒去矣，勿使俱陷。」朗曰：「忍季父如此，俱死無恨。」朗偃伏引箠，憲躍身而出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000013",
    "sentence": "是夜，莊宗令於軍中求憲，或曰：「與王緘俱歿矣！」莊宗垂涕求屍，數日，聞其免也，遣使慰勞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000014",
    "sentence": "尋改掌書記、水部郎中，賜金紫，曆魏博觀察判官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_069_000015",
    "sentence": "從討張文禮，鎮州平，授魏、博、鎮、冀十郡觀察判官，改考功郎中，兼御史中丞，權鎮州留事。",
