      }
    ]
  },
  {
    "sentence_id": "HCH_007_017_000105",
    "sentence": "又與淮、蜀結連，阻絕王命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_017_000106",
    "sentence": "太祖詔湖南節度使馬殷、荊南節度使高季昌練精兵五千，遣將倪可福統之，下澧州，與潭兵合。",
    "entities": [
