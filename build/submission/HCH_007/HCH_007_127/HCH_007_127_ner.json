        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_127_000019",
    "sentence": "少帝嗣位，改太子太傅。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_127_000020",
    "sentence": "漢祖登極，轉太子太師。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_127_000021",
    "sentence": "時朝官分司在洛，雖有留臺御史，紀綱亦多不整肅，遂敕文紀別令檢轄。",
    "entities": [
      {
