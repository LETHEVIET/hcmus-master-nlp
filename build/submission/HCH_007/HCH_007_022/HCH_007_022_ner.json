      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000114",
    "sentence": "四年，加淮南西北面行營招討使，控扼淮濆，邊境安之。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000115",
    "sentence": "其冬，蔣殷據徐州逆命，存節方以大眾戍潁州，得殷逆謀，密以上聞，遽奉詔與劉鄩同討之，頓於埇上。",
    "entities": [
      {
        "text": "蔣殷據徐州",
        "label": "LOC",
        "start": 3,
        "end": 8
      },
      {
        "text": "方以大眾戍潁州",
        "label": "LOC",
        "start": 13,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000116",
    "sentence": "淮賊朱瑾以兵救殷，距宿之兩舍，聞存節兵大至，即委糧棄甲而遁，竟平徐州。",
    "entities": [
      {
        "text": "竟平徐州",
        "label": "LOC",
        "start": 30,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000117",
    "sentence": "詔加太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000118",
    "sentence": "夏中病渴且痟，屬河北用軍，末帝令率軍屯陽留以張劉鄩之勢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000119",
    "sentence": "存節忠憤彌篤，未嘗言病，料敵治戎，旦夕愈厲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000120",
    "sentence": "病革，詔歸汶陽，翌日而卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000121",
    "sentence": "將終，戒其子知業、知讓等以忠孝，言不及他。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000122",
    "sentence": "冊贈太師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000123",
    "sentence": "存節武鷙慷慨，有大節，野戰壁守，皆其所長，威名聞於境外，深為末帝所重，而木強忠厚，有賈復之風焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000124",
    "sentence": "王檀",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000125",
    "sentence": "王檀，字眾美，京兆人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000126",
    "sentence": "曾祖泚，唐左金吾衛將軍、隴州防禦使。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "隴州",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000127",
    "sentence": "祖曜，定難功臣、渭橋鎮遏使。",
    "entities": [
      {
        "text": "渭橋鎮",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000128",
    "sentence": "父環，鴻臚卿，以檀貴，累贈左僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000129",
    "sentence": "檀少英悟，美形儀，好讀兵書，洞曉韜略。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000130",
    "sentence": "唐中和中，太祖鎮大梁，檀為小將。",
    "entities": [
      {
        "text": "唐",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "太祖鎮",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000131",
    "sentence": "四年，汴將楊彥洪破巢將尚讓、李讜於尉氏門外，檀在戰中，摧鋒陷陣，遂為太祖所知，稍蒙擢用。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000132",
    "sentence": "預破蔡賊於斤溝、淝河、八角，遷踏白都副將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000133",
    "sentence": "光啟二年 ，從胡真擊淮西之眾，解河陽之圍。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000134",
    "sentence": "蔡賊張存敢乘亂據洛陽，檀與勇士數十人潛入賊柵，邀其輜重，存敢遁走。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000135",
    "sentence": "胡真至陝州，開通貢路，遣檀攻玉山寨，降賊帥石令殷。",
    "entities": [
      {
        "text": "胡真至陝州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000136",
    "sentence": "從擊秦宗賢於鄭州西北河灘之上，於太祖馬前射賊將孫安，應弦而斃。",
    "entities": [
      {
        "text": "擊秦宗賢於鄭州",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000137",
    "sentence": "三年，佐都指揮使朱珍敗徐戎於孫師陂，獲其將孫用和、束詡以獻。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000138",
    "sentence": "從擊蔡賊於板橋，偏將李重裔追賊馬躓，為蔡人所擒，檀奪取而旋，獲賊將薛注。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000139",
    "sentence": "太祖破朱瑾於劉橋，檀盡收其軍實。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000140",
    "sentence": "文德元年 三月，討羅宏信，敗魏人於內黃，檀獲其將周儒、邵神劍以歸，補衝山都虞候。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000141",
    "sentence": "是歲，與諸軍平蔡州。",
    "entities": [
      {
        "text": "與諸軍平蔡州",
        "label": "LOC",
        "start": 3,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000142",
    "sentence": "明年，佐朱珍大破時溥之眾，檀獲賊將何肱，改左踏白馬軍副將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000143",
    "sentence": "預征兗、鄆，累立戰功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000144",
    "sentence": "大順元年 ，從龐師古渡淮深入，討孫儒之亂，奪邵伯堰，破高郵軍。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000145",
    "sentence": "檀奮命擊賊，刃傷左臂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000146",
    "sentence": "未幾，遷順義都將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000147",
    "sentence": "天復中，從太祖率四鎮之師圍鳳翔，以迎昭宗。",
    "entities": [
      {
        "text": "從太祖率四鎮",
        "label": "LOC",
        "start": 4,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000148",
    "sentence": "屢立戎效，遷左踏白指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000149",
    "sentence": "從攻王師範於青州，檀以偏師收復密郡， 〈 （《永陽志》云：張訓守密州刺史，朱全忠至青州，訓謂諸將曰：「汴人將至，何以禦之？」諸將請焚城大掠而歸。訓曰：「不可。」乃封府庫，植旗幟於城上，遣羸弱居前，自以精兵殿其後而去。全忠遣王檀攻密州，數日乃敢入城。） 〉 遂權知軍州事，充本州馬步軍都指揮使，尋表授檢校右僕射，守密州刺史。",
