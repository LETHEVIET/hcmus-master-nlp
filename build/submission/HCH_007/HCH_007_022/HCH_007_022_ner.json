      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000036",
    "sentence": "師厚以衙兵圍捕，賓不能起，乃越城而遁；師厚遣騎追至肥鄉，擒其黨百餘人，歸斬於府門。",
    "entities": [
