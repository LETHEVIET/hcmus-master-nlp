        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000162",
    "sentence": "貞明元年 三月，魏博軍亂。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000163",
    "sentence": "六月，晉王入魏州，分兵收下屬郡，河北大擾，檀受詔與開封尹劉鄩犄角進師，以援河北。",
    "entities": [
      {
        "text": "分兵收下屬郡",
        "label": "LOC",
        "start": 9,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000164",
    "sentence": "檀攻澶州魏縣，下之，擒賊將李岩、王開關以獻。",
    "entities": [
      {
        "text": "檀攻澶州魏縣",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "王開關",
        "label": "LOC",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000165",
    "sentence": "頃之，檀密疏請以奇兵西趣河中，自陰地關襲取晉陽，末帝許之，即馳兵而去。",
    "entities": [
      {
        "text": "自陰地關",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000166",
    "sentence": "二年二月，師至晉陽，晝夜急攻其壘，并州幾陷。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "并州",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000167",
    "sentence": "既而蕃將石家才自潞州以援兵至，檀引軍大掠而還。",
    "entities": [
      {
        "text": "將石家才自潞州",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000168",
    "sentence": "尋授天平軍副大使，知節度使事，棄鄆、齊、曹等州觀察等使。",
    "entities": [
      {
        "text": "曹等州",
        "label": "LOC",
        "start": 20,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000169",
    "sentence": "先是，檀招誘群盜，選其勁悍者置於帳下，以為爪牙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000170",
    "sentence": "至是，數輩竊發，突入府第，檀素不為備，遂為所害，時年五十一。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000171",
    "sentence": "節度副使裴彥聞變，率府兵盡擒諸賊，州城帖然。",
    "entities": [
      {
        "text": "州城",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000172",
    "sentence": "尋冊贈太師，諡曰忠毅，葬於開封縣之皋門原。",
    "entities": [
      {
        "text": "葬於開封縣",
        "label": "LOC",
        "start": 11,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000173",
    "sentence": "有子六人，皆升朝列。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000174",
    "sentence": "【論】",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000175",
    "sentence": "史臣曰：夫大都偶國，《 春秋 》所非。",
    "entities": [
      {
