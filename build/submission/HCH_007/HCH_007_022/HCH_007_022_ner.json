      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000046",
    "sentence": "廢朝三日，贈太師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000047",
    "sentence": "師厚純謹敏幹，深為太祖知遇，委以重兵劇鎮，他莫能及。",
    "entities": [
      {
        "text": "委以重兵劇鎮",
        "label": "LOC",
        "start": 14,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000048",
    "sentence": "然而末年矜功恃眾，驟萌不軌之意，於是專割財賦，置銀槍效節軍凡數千人，皆選摘驍銳，縱恣豢養，復故時牙軍之態，時人病之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000049",
    "sentence": "向時河朔之俗，上元比屋夜遊，及師厚作鎮，乃課魏人戶立燈竿，千釭萬炬，洞照一城，縱士女嬉遊。",
    "entities": [
      {
        "text": "及師厚作鎮",
        "label": "LOC",
        "start": 14,
        "end": 19
      },
      {
        "text": "洞照一城",
        "label": "LOC",
        "start": 34,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000050",
    "sentence": "復彩畫舟舫，令女妓棹歌於御河，縱酒彌日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000051",
    "sentence": "又於黎陽采巨石，將紀德政，以鐵車負載，驅牛數百以拽之，所至之處，丘墓廬舍悉皆毀壞，百姓望之，皆曰「碑來」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000052",
    "sentence": "及碑石才至，而師厚卒，魏人以為「悲來」之應。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000053",
    "sentence": "末帝聞其卒也，於私庭受賀，乃議裂魏州為兩鎮。",
    "entities": [
      {
        "text": "乃議裂魏州",
        "label": "LOC",
        "start": 13,
        "end": 18
      },
      {
        "text": "為兩鎮",
        "label": "LOC",
        "start": 18,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000054",
    "sentence": "既而所樹親軍，果為叛亂，以招外寇，致使河朔淪陷，宗社覆滅，由師厚兆之也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000055",
    "sentence": "牛存節",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000056",
    "sentence": "牛存節，字讚貞，青州博昌人也。",
    "entities": [
      {
        "text": "青州",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000057",
    "sentence": "本名禮，太祖改而字之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000058",
    "sentence": "少以雄勇自負。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000059",
    "sentence": "唐乾符末，鄉人諸葛爽為河陽節度使，存節往從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000060",
    "sentence": "爽卒，存節謂同輩曰：「天下洶洶，當擇英主事之，以圖富貴。」遂歸於太祖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000061",
    "sentence": "初授宣義軍小將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000062",
    "sentence": "屬蔡寇至金堤驛，犯酸棗、靈昌，存節日與之鬥，凡二十餘往，每往必執俘而還，前後斬首二十餘級，獲孳畜甚眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000063",
    "sentence": "太祖擊蔡賊於板橋、赤岡、酸棗門、封禪寺、枯河北，存節皆預其行，與諸將於濮州南劉橋、範縣大破鄆眾，自此深為太祖獎遇。",
    "entities": [
      {
        "text": "與諸將於濮州",
        "label": "LOC",
        "start": 31,
        "end": 37
      },
      {
        "text": "範縣",
        "label": "LOC",
        "start": 41,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000064",
    "sentence": "文德元年 夏，李罕之以並軍圍張宗奭於河陽，太祖遣存節率軍赴之。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000065",
    "sentence": "屬歲歉，餉饋不至，村民有儲幹椹者，存節以器用、錢帛易之，以給軍食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000066",
    "sentence": "大破賊於浿河，罕之引眾北走。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000067",
    "sentence": "又預討徐、宿有功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000068",
    "sentence": "及討河北，存節前鋒下黎陽，收臨河，至內黃西，以兵千餘人當魏人萬二千眾，大破其陣，僵仆蔽野。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000069",
    "sentence": "太祖深所歎激，謂有神兵之助。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000070",
    "sentence": "大順元年 ，改滑州左右廂牢城使。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "改滑州",
        "label": "LOC",
        "start": 6,
        "end": 9
      },
      {
        "text": "左右廂牢城",
        "label": "LOC",
        "start": 9,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000071",
    "sentence": "與諸將討時溥，累破賊軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000072",
    "sentence": "景福元年 秋，改遏後都指揮使。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000073",
    "sentence": "攻濮之役，領軍先登，遂拔其壘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000074",
    "sentence": "二年四月，下徐州，梟時溥，存節力戰，其功居多。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "下徐州",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000075",
    "sentence": "乾寧二年 ，授檢校工部尚書。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000076",
    "sentence": "三年夏，太祖東討鄆州，存節領軍次故樂亭，扼其要路，都指揮使龐師古屯馬頰，存節密與都將王言謀入鄆壘。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "太祖東討鄆州",
        "label": "LOC",
        "start": 4,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000077",
    "sentence": "十二月，存節遣王言夜伏勇士於州西北，以船逾濠，舉梯登陴。",
    "entities": [
      {
        "text": "言夜伏勇士於州",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000078",
    "sentence": "既而王言不克入，存節獨率伏軍負梯童破其西甕城，奪其濠橋，諸軍俱進。",
    "entities": [
      {
        "text": "梯童破其西甕城",
        "label": "LOC",
        "start": 15,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000079",
    "sentence": "四年四月，陷其城，尋與葛從周降下兗州，加檢校右僕射。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "陷其城",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "葛從周降下兗州",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000080",
    "sentence": "其年秋，大舉以伐淮南，至濠州東，聞前軍失利於清口，諸軍退至間河，無復隊伍。",
    "entities": [
      {
        "text": "至濠州",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000081",
    "sentence": "存節遏其後，諸將釋騎步鬥，諸軍稍得濟，收合所部並敗兵共八千餘人，至於淮涘，時不食已四日矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000082",
    "sentence": "存節訓勵部分，以禦追寇，遂得旋師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000083",
    "sentence": "五年，除亳州刺史，俄遷宣武軍都指揮使，改宿州刺史。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
