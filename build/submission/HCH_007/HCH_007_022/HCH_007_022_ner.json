      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000103",
    "sentence": "三年四月，除鄜州留後。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "除鄜州",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000104",
    "sentence": "六月，劉知俊以同州叛，尋授同州留後，未幾，加檢校太保、同州節度使。",
    "entities": [
      {
        "text": "劉知俊以同州",
        "label": "LOC",
        "start": 3,
        "end": 9
      },
      {
        "text": "尋授同州",
        "label": "LOC",
