        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000021",
    "sentence": "明年，又加檢校太傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000022",
    "sentence": "三年三月，入朝，詔兼潞州行營都招討使。",
    "entities": [
