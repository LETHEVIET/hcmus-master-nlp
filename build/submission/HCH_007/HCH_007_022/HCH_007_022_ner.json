      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "改宿州",
        "label": "LOC",
        "start": 19,
        "end": 22
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000084",
    "sentence": "明年，淮賊大至彭城，存節乃以部下兵夜發，直趣彭門；淮人訝其神速，震恐而退，諸將服其智識。",
    "entities": [
      {
        "text": "淮賊大至彭城",
        "label": "LOC",
        "start": 3,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000085",
    "sentence": "光化二年 ，罷歸，復為左衙都將兼馬步教練使。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000086",
    "sentence": "天復元年 ，授潞州馬步都指揮使，法令嚴整，士庶安之。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "授潞州",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000087",
    "sentence": "及追赴行在，士卒泣送者不絕於道，加金紫光祿大夫、檢校司空，改滑州左衙步軍指揮使，知邢州軍州事。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 21,
        "end": 23
      },
      {
        "text": "改滑州",
        "label": "LOC",
        "start": 29,
        "end": 32
      },
      {
        "text": "知邢州軍州",
        "label": "LOC",
        "start": 40,
        "end": 45
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000088",
    "sentence": "天祐元年 ，授邢州團練使。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "授邢州",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000089",
    "sentence": "時州兵才及二百人，晉人知之，以大軍來寇。",
    "entities": [
      {
        "text": "時州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000090",
    "sentence": "太祖在鄴，發長直兵二千人赴援，存節率壯健出鬥，以家財賞激戰士，並軍急攻，七日不能克而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000091",
    "sentence": "太祖召至，勞慰久之，厚賚金帛鞍馬，加檢校司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000092",
    "sentence": "冬，罷軍，署為元帥府左都押衙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000093",
    "sentence": "四年，太祖受禪，除右千牛衛上將軍。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000094",
    "sentence": "其秋，攻潞州，以存節為行營馬步軍都排陣使。",
    "entities": [
      {
        "text": "攻潞州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000095",
    "sentence": "開平二年 二月，自右監門衛上將軍轉右龍虎統軍，駐留洛下。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000096",
    "sentence": "是歲，王師敗於上黨，晉人乘勝進迫澤州，州城將陷。",
    "entities": [
      {
        "text": "人乘勝進迫澤州",
