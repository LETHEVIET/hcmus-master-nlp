        "end": 15
      },
      {
        "text": "同州",
        "label": "LOC",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000105",
    "sentence": "乾化二年 ，加檢校太傅，進封開國公。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000106",
    "sentence": "存節戒嚴軍旅，常若敵至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000107",
    "sentence": "先是，州中井水鹹苦，人不可飲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000108",
    "sentence": "及並人、岐人來迫州城，或以為兵士渴乏，陷在旦夕。",
    "entities": [
      {
        "text": "岐人來迫州城",
        "label": "LOC",
        "start": 4,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000109",
    "sentence": "存節及肅拜虔祝，擇地鑿八十餘井，其味皆甘淡，由是人馬汲濯有餘，眾以為至誠之感。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000110",
    "sentence": "自八月至三年春末，人馬未嘗釋甲，以至寇退。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_022_000111",
    "sentence": "尋加同平章事，詔赴闕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000112",
    "sentence": "末帝召慰勉，賞賜甚厚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_022_000113",
    "sentence": "十一月，加開府儀同三司，食邑一千戶，授鄆州節度使。",
    "entities": [
      {
        "text": "食邑",
        "label": "LOC",
        "start": 12,
        "end": 14
      },
      {
        "text": "授鄆州",
