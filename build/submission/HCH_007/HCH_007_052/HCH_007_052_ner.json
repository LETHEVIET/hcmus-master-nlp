      {
        "text": "本以兵扼天井關",
        "label": "LOC",
        "start": 65,
        "end": 72
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000011",
    "sentence": "汴將澤州刺史劉屺棄城而遁，乃以李存璋為刺史。",
    "entities": [
