      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000045",
    "sentence": "天祐三年 ，汴人攻滄、景，劉仁恭遣使求援。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000046",
    "sentence": "十一月，嗣昭合燕軍三萬進攻潞州，降丁會，武皇乃以嗣昭為昭義節度使。",
    "entities": [
      {
        "text": "軍三萬進攻潞州",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000047",
    "sentence": "始嗣昭未到之前，上黨有占者，見一人家舍上常有氣如車蓋，視之，但一貧媼而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000048",
    "sentence": "占者謂媼：「有子乎？」曰：「有，見為軍士，出戍於外。」占者心異之，以為其子將來有土地之兆也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000049",
    "sentence": "未幾，丁會既降，嗣昭領兵入潞，以媼家四面空缺，乃駐於是舍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000050",
    "sentence": "丁會既歸太原，武皇遣使命嗣昭為帥，乃自媼舍而入理所，其氣尋息，聞者異之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000051",
    "sentence": "四年六月，汴將李思安將兵十萬攻潞州，乃築夾城，深溝高壘，內外重復，飛走路絕。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "將兵十萬攻潞州",
        "label": "LOC",
        "start": 10,
        "end": 17
      },
      {
        "text": "乃築夾城",
        "label": "LOC",
        "start": 18,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000052",
    "sentence": "嗣昭撫循士眾，登城拒守，梁祖馳書說誘百端，嗣昭焚其偽詔，斬其使者，城中固守經年，軍民乏絕，感鹽炭自生，以濟貧民。",
    "entities": [
      {
        "text": "登城",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000053",
    "sentence": "嗣昭嘗享諸將，登城張樂，賊矢中足，嗣昭密拔之，坐客不之覺，酣飲如故，以安眾心。",
    "entities": [
      {
        "text": "登城",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000054",
    "sentence": "五年五月，莊宗敗汴軍，破夾城。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "破夾城",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000055",
    "sentence": "嗣昭知武皇棄世，哀慟幾絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000056",
    "sentence": "時大兵攻圍曆年，城中士民饑死大半，廛裏蕭條。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000057",
    "sentence": "嗣昭緩法寬租，勸農務穡，一二年間，軍城完集，三面鄰於敵境，寇鈔縱橫，設法枝梧，邊鄙不聳。",
    "entities": [
