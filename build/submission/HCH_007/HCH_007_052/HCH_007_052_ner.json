    ]
  },
  {
    "sentence_id": "HCH_007_052_000058",
    "sentence": "胡柳之戰，周德威戰沒，師無行列，至晚方集。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000059",
    "sentence": "汴人四五萬登無石山，我軍懼形於色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000060",
    "sentence": "或請收軍保營，詰旦復戰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000061",
    "sentence": "嗣昭曰：「賊無營壘，去臨濮地遠，日已晡晚，皆有歸心，但以精騎逗撓，無令返旆，晡後追擊，破之必矣。我若收軍拔寨，賊人入臨濮，俟彼整齊復來，即勝負水決。」莊宗曰：「非兄言，幾敗吾事！」軍校王建及又陳方略，嗣昭與建及分兵於土山南北為掎角，汴軍懼，下山，因縱軍擊之，俘斬三萬級，由是莊宗之軍復振。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000062",
    "sentence": "十六年，嗣昭代周德威權幽州軍府事。",
    "entities": [
      {
        "text": "十六年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "代周德威權幽州",
        "label": "LOC",
        "start": 6,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000063",
    "sentence": "九月，以李紹宏代，嗣昭出薊門，百姓號泣請留，截鞍惜別，嗣昭夜遁而歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000064",
    "sentence": "十七年六月，嗣昭自德勝歸藩，莊宗帳餞於戚城。",
    "entities": [
      {
        "text": "十七年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "莊宗帳餞於戚城",
        "label": "LOC",
        "start": 14,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000065",
    "sentence": "莊宗酒酣，泣而言曰：「河朔生靈，十年饋挽，引領鶴望，俟破汴軍。今兵賦不充，寇孽猶在，坐食軍賦，有愧蒸民。」嗣昭曰：「臣忝急難之地，每一念此，寢不安席。大王且持重謹守，惠養士民。臣歸本藩，簡料兵賦，歲末春首，即舉眾復來。」莊宗離席拜送，如家人禮。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000066",
    "sentence": "是月，汴將劉鄩攻同州，朱友謙告急，嗣昭與李存審援之。",
    "entities": [
      {
        "text": "汴將劉鄩攻同州",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000067",
    "sentence": "九月，破汴軍於馮翊，乃班師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000068",
    "sentence": "十九年，莊守親征張文禮於鎮州。",
    "entities": [
      {
        "text": "十九年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "親征張文禮於鎮",
        "label": "LOC",
        "start": 6,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000069",
    "sentence": "冬，契丹三十萬奄至，嗣昭從莊宗擊之，敵騎圍之數十重，良久不解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000070",
    "sentence": "嗣昭號泣赴之，引三百騎橫擊重圍，馳突出沒者數十合，契丹退，翼莊宗而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000071",
    "sentence": "是時，閻寶為鎮人所敗，退保趙州，莊宗命嗣昭代寶攻真定。",
    "entities": [
      {
        "text": "閻寶為鎮",
        "label": "LOC",
        "start": 3,
        "end": 7
      },
      {
        "text": "退保趙州",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000072",
    "sentence": "七月二十四日，王處球之兵出自九門，嗣昭設伏於故營，賊至，發伏，擊之殆盡；餘三人匿於牆墟間，嗣昭環馬而射之，為賊矢中腦，嗣昭箙中矢盡，拔賊矢於腦射賊，一發而殪之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000073",
    "sentence": "嗣昭日暮還營，所傷血流不止，是夜卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000074",
    "sentence": "嗣昭節制澤、潞，官自司徒、太保至侍中、中書令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000075",
    "sentence": "莊宗即位，贈太師、隴西郡王。",
    "entities": [
      {
        "text": "隴西郡",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000076",
    "sentence": "長興中，詔配饗莊宗廟庭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000077",
    "sentence": "嗣昭有子七人，長曰繼儔，澤州刺史；次繼韜、繼忠、繼能、繼襲、繼遠，皆夫人楊氏所生。",
    "entities": [
      {
        "text": "澤州",
        "label": "LOC",
        "start": 12,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000078",
    "sentence": "楊氏治家善積聚，設法販鬻，致家財百萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000079",
    "sentence": "繼韜，小字留得，少驕獪無賴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000080",
    "sentence": "嗣昭既卒，莊宗詔諸子扶喪歸太原襄事，諸子違詔，以父牙兵數千擁喪歸潞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000081",
    "sentence": "莊宗令李存渥馳騎追諭，兄弟俱忿，欲害存渥，存渥遁而獲免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000082",
    "sentence": "繼韜兄繼儔，嗣昭長嫡也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000083",
    "sentence": "當襲父爵，然柔而不武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000084",
    "sentence": "方在苫廬，繼韜詐令三軍劫己為留後，囚繼儔於別室，以事奏聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000085",
    "sentence": "莊宗不得已，命為安義軍兵馬留後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000086",
    "sentence": "時軍前糧餉不充，租庸計度請潞州轉米五萬貯於相州；繼韜辭以經費不足，請轉三萬。",
    "entities": [
      {
        "text": "租庸計度請潞州",
        "label": "LOC",
        "start": 8,
        "end": 15
      },
      {
        "text": "米五萬貯於相州",
        "label": "LOC",
        "start": 16,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000087",
    "sentence": "有幕客魏琢、牙將申蒙者，因入奏公事，每摭陰事報繼韜云：「朝廷無人，終為河南吞噬，止遲速間耳。」由是陰謀叛計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000088",
    "sentence": "內官張居翰時為昭義監軍，莊宗將即位，詔赴鄴都。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000089",
    "sentence": "潞州節度判官任圜時在鎮州，亦奉詔赴鄴。",
    "entities": [
      {
        "text": "潞州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "判官任圜時在鎮",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000090",
    "sentence": "魏琢、申蒙謂繼韜曰：「國家急召此二人，情可知矣。」弟繼遠，年十五六，謂繼韜曰：「兄有家財百萬，倉儲十年，宜自為謀，莫受人所製。」繼韜曰：「定哥以為何如？」 曰：「申蒙之言是也。河北不勝河南，不如與大梁通盟，國家方事之殷，焉能討我？無如此算。」乃令繼遠將百餘騎詐雲於晉、絳擒生，遂至汴。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 49,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000091",
    "sentence": "梁主見之喜，因令董璋將兵應接，營於潞州之南，加繼韜同平章事，改昭義軍為匡義軍。",
    "entities": [
      {
        "text": "營於潞州",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000092",
    "sentence": "繼韜令其愛子二人入質於汴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000093",
    "sentence": "及莊宗平河南，繼韜惶恐，計無所出，將脫身於契丹；會有詔赦之，乃齎銀數十萬兩，隨其母楊氏詣闕，冀以賂免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000094",
    "sentence": "將行，其弟繼遠曰：「兄往與不往，利害一也。以反為名，何麵更見天下！不如深溝峻壁，坐食積粟，尚可苟延歲月，往則亡無日矣。」或曰：「君先世有大功於國，主上季父也，宏農夫人無恙，保獲萬全。」及繼韜至，厚賂宦官、伶人，言事者翕然稱：「留後本無惡意，奸人惑之故也。嗣昭親賢，不可無嗣。」楊夫人亦於宮中哀祈劉皇后，後每於莊宗前泣言先人之功，以動聖情，由是原之。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 148,
        "end": 150
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000095",
    "sentence": "在京月餘，屢從畋遊，寵待如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000096",
    "sentence": "李存渥深訶詆之，繼韜心不自安，復賂伶閹，求歸本鎮，莊宗不聽。",
    "entities": [
      {
        "text": "求歸本鎮",
        "label": "LOC",
        "start": 20,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000097",
    "sentence": "繼韜潛令紀綱書諭繼遠，欲軍城更變，望天子遣己安撫。",
    "entities": [
      {
        "text": "欲軍城",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_052_000098",
    "sentence": "事泄，斬於天津橋南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_052_000099",
    "sentence": "二子齠年質於汴，莊宗收城得之，撫其背曰：「爾幼如是，猶如能佐父造反，長復何為！」至是亦誅。",
    "entities": [
