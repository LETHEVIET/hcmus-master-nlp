    "entities": []
  },
  {
    "sentence_id": "HCH_007_055_000103",
    "sentence": "為帳中親將，驍果絕眾，善擒生設伏，望塵揣敵，所向皆捷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_055_000104",
