        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_055_000007",
    "sentence": "既收城，推武皇為大同軍防禦留後。",
    "entities": [
      {
        "text": "既收城",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_055_000008",
    "sentence": "眾狀以聞，朝廷不悅，詔征兵來討。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_055_000009",
    "sentence": "俄而獻祖失振武，武皇失雲州。",
    "entities": [
