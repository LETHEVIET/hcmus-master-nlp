      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_103_000061",
    "sentence": "九月辛巳，朗州節度使馬希萼奏請於京師別置邸院。",
    "entities": [
      {
        "text": "朗州",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_103_000062",
    "sentence": "不允。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_103_000063",
    "sentence": "是時，希萼與其弟湖南節度使希廣方構鬩墻之怨，故有是請。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_103_000064",
    "sentence": "帝以湖南已有邸務，不可更置，由是不允，仍命降詔和解焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_103_000065",
    "sentence": "冬十月己亥，帝狩於近郊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_103_000066",
    "sentence": "丙午，湖南馬希廣遣使上章，且言荊南、淮南、廣南三道結構，欲分割湖、湘，乞聊發兵師，以為援助。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_103_000067",
    "sentence": "時朝廷方議起軍，會內難，不果行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_103_000068",
    "sentence": "丁未，兩浙錢宏俶加諸道兵馬元帥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_103_000069",
    "sentence": "戊申，彰德軍節度使郭謹卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_103_000070",
    "sentence": "癸丑，以前同州節度使張彥赟為相州節度使。",
    "entities": [
      {
        "text": "以前同州",
        "label": "LOC",
        "start": 3,
        "end": 7
      },
      {
        "text": "使張彥赟為相州",
        "label": "LOC",
        "start": 9,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_103_000071",
    "sentence": "辛酉，月犯心大星。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_103_000072",
    "sentence": "十一月甲子朔，日有食之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_103_000073",
    "sentence": "乙丑，永州唐將軍祠贈太保，從湖南請也。",
    "entities": [
      {
        "text": "永州",
        "label": "LOC",
