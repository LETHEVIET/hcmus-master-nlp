        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000075",
    "sentence": "天復初，破氏叔琮前軍於洞渦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000076",
    "sentence": "三年，授石州刺史。",
