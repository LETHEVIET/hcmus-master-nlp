      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000047",
    "sentence": "定州王處存求援於武皇；武皇命存孝侵鎮、趙之南鄙，又令李存信、李存審率師出井陘以會之，並軍攻臨城、柏鄉。",
    "entities": [
      {
        "text": "定州",
        "label": "LOC",
