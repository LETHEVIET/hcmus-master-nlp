  },
  {
    "sentence_id": "HCH_007_053_000069",
    "sentence": "父牷，世吏單于府。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000070",
    "sentence": "重進初仕嵐州刺史湯群為部校，獻祖誅群，乃事武皇。",
