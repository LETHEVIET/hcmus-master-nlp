[
  {
    "sentence_id": "HCH_007_053_000001",
    "sentence": "李存信，本姓張，父君政，回鶻部人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000002",
    "sentence": "大中初，隨懷化郡王李思忠內附，因家雲中之合羅川。",
    "entities": [
      {
        "text": "隨懷化郡",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000003",
    "sentence": "存信通黠多數，會四夷語，別六蕃書，善戰，識兵勢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000004",
    "sentence": "初為獻祖親信，從武皇入關平賊，始補軍職，賜姓名。",
    "entities": [
      {
        "text": "從武皇入關",
        "label": "LOC",
        "start": 7,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000005",
    "sentence": "大順中，累遷至馬步都校，與李存孝擊張浚軍於平陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000006",
    "sentence": "時存孝驍勇冠絕，軍中皆下之，惟存信與爭功，由是相惡，有同水火。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000007",
    "sentence": "及平定潞州，存孝以功望領節度，既而康君立授旄鉞，存孝怒，大剽潞民，燒邑屋，言發流涕，疑存信擯己故也。",
    "entities": [
      {
        "text": "及平定潞州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "燒邑",
        "label": "LOC",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000008",
    "sentence": "明年，存孝得邢、洺，武皇與之節鉞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000009",
    "sentence": "存孝慮存信離間，欲立大功以勝之，屢請兵於武皇，請兼併鎮、冀，存信間之，不時許。",
    "entities": [
      {
        "text": "請兼併鎮",
        "label": "LOC",
        "start": 23,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000010",
    "sentence": "大順二年，武皇大舉略地山東，以存信為蕃漢馬步都校，存孝聞之怒，武皇令存質代之，存孝乃謀叛。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000011",
    "sentence": "既誅，以存信為蕃漢都校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000012",
    "sentence": "從討李匡儔，降赫連鐸、白義誠，以功檢校右僕射，從入關討王行瑜，加檢校司空，領郴州刺史。",
    "entities": [
      {
        "text": "從入關",
        "label": "LOC",
        "start": 23,
        "end": 26
      },
      {
        "text": "領郴州",
        "label": "LOC",
        "start": 37,
        "end": 40
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 40,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000013",
    "sentence": "乾寧三年，兗、鄆乞師於武皇，武皇遣存信營於莘縣，與硃瑄合勢以抗梁人。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "遣存信營於莘縣",
        "label": "LOC",
        "start": 16,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000014",
    "sentence": "梁祖患之，遣使諜羅宏信曰：「河東志在吞食河朔，回軍之日，貴道堪憂。」而存信戢兵無法，稍侵魏之芻牧，宏信怒，翻然結於梁祖，乃出兵三萬以攻存信。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000015",
    "sentence": "存信斂眾而退，為魏人所薄，委棄輜重，退保洺州，軍士喪失者十二三。",
    "entities": [
      {
        "text": "退保洺州",
        "label": "LOC",
        "start": 18,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000016",
    "sentence": "武皇怒，大出師攻魏博，屠陷諸邑。",
    "entities": [
      {
        "text": "屠陷諸邑",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000017",
    "sentence": "五月，存信軍於洹水，汴將葛從周、氏叔琮來援魏人，存信與鐵林都將落落遇汴人於洹水南，汴人為陷馬坎以待之，存信戰敗，落落被擒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000018",
    "sentence": "九月，存信敗葛從周於宗城，乘勝至魏州之北門。",
    "entities": [
      {
        "text": "敗葛從周於宗城",
        "label": "LOC",
        "start": 5,
        "end": 12
      },
      {
        "text": "乘勝至魏州",
        "label": "LOC",
        "start": 13,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000019",
    "sentence": "明年，聞兗、鄆皆陷，乃班師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000020",
    "sentence": "八月，從討劉仁恭，師次安塞，為燕軍所敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000021",
    "sentence": "武皇怒謂存信曰：「昨日吾醉，不悟賊至，公不辨耶！古人三敗，公姑二矣。」存信懼，泥首謝罪，幾至不測。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000022",
    "sentence": "自光化已後，存信多稱病，武皇以兵柄授李嗣昭，以存信為右校而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000023",
    "sentence": "天復二年十月，以疾卒於晉陽，時四十一。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000024",
    "sentence": "李存孝，本姓安，名敬思。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000025",
    "sentence": "《新唐書》：存孝，飛狐人。",
    "entities": [
      {
        "text": "《新唐書》",
        "label": "TITLE",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000026",
    "sentence": "少於俘囚中得隸紀綱，給事帳中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000027",
    "sentence": "及壯，便騎射，驍勇冠絕，常將騎為先鋒，未嘗挫敗；從武皇救陳、許，逐黃寇，及遇難上源，每戰無不克捷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000028",
    "sentence": "張浚之加兵於太原也，潞州小校馮霸殺其帥李克恭以城叛。",
    "entities": [
      {
        "text": "潞州",
        "label": "LOC",
        "start": 10,
        "end": 12
      },
      {
        "text": "其帥李克恭以城",
        "label": "LOC",
        "start": 17,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000029",
    "sentence": "時汴將硃崇節入潞州，梁祖令張全義攻澤州。",
    "entities": [
      {
        "text": "將硃崇節入潞州",
        "label": "LOC",
        "start": 2,
        "end": 9
      },
      {
        "text": "令張全義攻澤州",
        "label": "LOC",
        "start": 12,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000030",
    "sentence": "李罕之告急於武皇，武皇遣存孝率騎五千援之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000031",
    "sentence": "初，汴人攻澤州，呼罕之曰：「相公常恃太原，輕絕大國，今張相公圍太原，葛司空已入潞府，旬日之內，沙陀無穴自處，相公何路求生耶！」存孝聞其言不遜，選精騎五百，繞汴營呼曰：「我，沙陀求穴者，俟爾肉饌軍，可令肥者出鬥！」汴將有鄧季筠者，亦以驍勇聞，乃引軍出戰。",
    "entities": [
      {
        "text": "汴人攻澤州",
        "label": "LOC",
        "start": 2,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000032",
    "sentence": "存孝激勵部眾，舞槊先登，一戰敗之，獲馬千匹，生擒季筠於軍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000033",
    "sentence": "是夜，汴將李讜收軍而遁，存孝追擊至馬牢山，俘斬萬計，遂退攻潞州。",
    "entities": [
      {
        "text": "遂退攻潞州",
        "label": "LOC",
        "start": 26,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000034",
    "sentence": "時朝廷命京兆尹孫揆為昭義節度使，令供奉官韓歸范送旌節至平陽，揆乃仗節之潞；梁祖與揆牙兵三千為紀綱，時揆為張浚副招討，所部萬人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000035",
    "sentence": "八月，自晉、絳逾刀黃嶺趨上黨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000036",
    "sentence": "存孝引三百騎伏於長子西崖間。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000037",
    "sentence": "揆褒衣大蓋，擁眾而行，俟其軍前後不屬，存孝出騎橫擊之，擒揆與歸范及俘囚五百，獻於太原；存孝乃急攻潞州。",
    "entities": [
      {
        "text": "存孝乃急攻潞州",
        "label": "LOC",
        "start": 43,
        "end": 50
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000038",
    "sentence": "九月，葛從周棄城夜遁，存孝收城，武皇乃表康君立為潞帥。",
    "entities": [
      {
        "text": "葛從周棄城",
        "label": "LOC",
        "start": 3,
        "end": 8
      },
      {
        "text": "存孝收城",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000039",
    "sentence": "存孝怒，不食者累日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000040",
    "sentence": "十月，存孝引收潞州之師，圍張浚於平陽，營於趙城。",
    "entities": [
      {
        "text": "存孝引收潞州",
        "label": "LOC",
        "start": 3,
        "end": 9
      },
      {
        "text": "營於趙城",
        "label": "LOC",
        "start": 19,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000041",
    "sentence": "華州韓建遣壯士三百夜犯其營，存孝諜知，設伏以擊之，盡殪；進壓晉州西門，獲賊三千，自是閉壁不出。",
    "entities": [
      {
        "text": "華州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "進壓晉州",
        "label": "LOC",
        "start": 28,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000042",
    "sentence": "存孝引軍攻絳州。",
    "entities": [
      {
        "text": "存孝引軍攻絳州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000043",
    "sentence": "十一月，刺史張行恭棄城而去，張浚、韓建亦由含口而遁。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000044",
    "sentence": "存孝收晉、絳，以功授汾州刺史。",
    "entities": [
      {
