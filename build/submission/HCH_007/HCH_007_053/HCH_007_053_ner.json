      }
    ]
  },
  {
    "sentence_id": "HCH_007_053_000095",
    "sentence": "七月，存進代嗣昭為招討，進營東垣渡，夾滹□為壘，沙土散惡，垣壁難成。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000096",
    "sentence": "存進斬伐林樹，版築旬日而就，賊不能寇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000097",
    "sentence": "九月，王處球盡率其眾，乘其無備，奄至壘門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000098",
    "sentence": "存進聞之，得部下數人出鬥，驅賊於橋下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000099",
    "sentence": "俄而賊大至，後軍不繼，血戰而歿，時年六十六。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000100",
    "sentence": "同光時，贈太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000101",
    "sentence": "存進行軍出師，雖無奇跡，然能以法繩其驕放，營壘守戰之備，特推精力，議者稱之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000102",
    "sentence": "有子四人，長曰漢韶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000103",
    "sentence": "漢韶，字享天，幼有器局，風儀峻整。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_053_000104",
    "sentence": "初事莊宗，為定安軍使，遷河東牢城指揮使。",
