  },
  {
    "sentence_id": "HCH_007_053_000046",
    "sentence": "時幽州李匡威與鎮州王鎔屢弱中山，將中分其疆土。",
    "entities": [
      {
        "text": "時幽州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "李匡威與鎮州",
        "label": "LOC",
