        "start": 116,
        "end": 118
      }
    ]
  },
  {
    "sentence_id": "HCH_007_004_000064",
    "sentence": "癸巳，以禪代已來，思求賢哲，乃下令搜訪牢籠之，期以好爵，待以優榮，各隨其材，咸使登用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_004_000065",
    "sentence": "宜令所在長吏，切加搜訪，每得其人，則疏姓名以聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_004_000066",
    "sentence": "如在下位不能自振者，有司薦導之；如任使後顯立功勞，別加遷陟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_004_000067",
    "sentence": "敕禁屠宰兩月。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_004_000068",
    "sentence": "甲午，以高明門外繁台為講武台。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_004_000069",
    "sentence": "是台西漢梁孝王之時，嘗按歌閱樂於此，當時因名曰吹台。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_004_000070",
    "sentence": "其後有繁氏居於其側，里人乃以姓呼之，時代綿寢，雖官吏亦從俗焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_004_000071",
    "sentence": "帝每登眺，搜乘訓戎，宰臣以是事奏而名之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_004_000072",
    "sentence": "八月辛亥，敕應有暴露骸骨，各委差人埋瘞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_004_000073",
    "sentence": "兩浙錢鏐奏，請重鑄換諸州新印。",
    "entities": [
      {
        "text": "請重鑄換諸州",
        "label": "LOC",
        "start": 6,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_004_000074",
    "sentence": "詔禁戢諸軍節級兵士及供奉官受旨殿直以下各修禮敬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_004_000075",
    "sentence": "甲寅，太史奏，壽星見於南方。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_004_000076",
    "sentence": "兩浙錢鏐奏，改管內紫極宮為真聖觀，改臨安縣廣義鄉為衣錦鄉。",
    "entities": [
