      }
    ]
  },
  {
    "sentence_id": "HCH_007_004_000122",
    "sentence": "丙子，次汜水縣，河南尹張宗奭、河陽節度使張歸霸並來朝。",
    "entities": [
      {
        "text": "次汜水縣",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_004_000123",
