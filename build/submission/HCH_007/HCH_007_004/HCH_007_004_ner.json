      }
    ]
  },
  {
    "sentence_id": "HCH_007_004_000031",
    "sentence": "湖南馬殷遣水軍都將黃瑀率樓船遮擊之，賊眾沿流宵遁，追至鹿角鎮。",
    "entities": [
