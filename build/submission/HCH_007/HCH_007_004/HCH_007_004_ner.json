        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_004_000002",
    "sentence": "封從子友甯為安王，友倫為密王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_004_000003",
    "sentence": "幽州劉守文進海東鷹鶻、蕃馬、氈罽、方物。",
    "entities": [
      {
        "text": "幽州",
        "label": "LOC",
