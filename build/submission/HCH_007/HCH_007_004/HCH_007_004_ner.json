        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_004_000082",
    "sentence": "九月丙子，太原軍出陰地關南牧，寇掠郡縣，晉、絳有備。",
