  },
  {
    "sentence_id": "HCH_007_004_000106",
    "sentence": "壬戌，禦宣和殿，宴宰臣文武百官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_004_000107",
    "sentence": "十一月辛未，禦宣和殿，宴宰臣文武百官，以大駕還京故也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_004_000108",
