[
  {
    "sentence_id": "HCH_007_137_000001",
    "sentence": "契丹者，古匈奴之種也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_137_000002",
    "sentence": "代居遼澤之中，潢水南岸，南距榆關一千一百里，榆關南距幽州七百里，本鮮卑之舊地也。",
    "entities": [
      {
        "text": "南距榆關",
        "label": "LOC",
