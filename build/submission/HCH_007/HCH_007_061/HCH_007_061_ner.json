[
  {
    "sentence_id": "HCH_007_061_000001",
    "sentence": "安金全，代北人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000002",
    "sentence": "世為邊將，少驍果，便騎射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000003",
    "sentence": "武皇時為騎將，屢從征討。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000004",
    "sentence": "莊宗之救潞州及平河朔，皆有戰功，累為刺史，以老病退居太原。",
    "entities": [
      {
        "text": "莊宗之救潞州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000005",
    "sentence": "天祐中，汴將王檀率師三萬，乘莊宗在鄴，來襲并州。",
    "entities": [
      {
        "text": "來襲并州",
        "label": "LOC",
        "start": 19,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000006",
    "sentence": "時城無備兵，敵軍奄至，監軍張承業大恐，計無所出，閱諸司丁匠，登陴禦捍。",
    "entities": [
      {
        "text": "時城",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000007",
    "sentence": "外攻甚急，金全遽出謂承業曰：「老夫退居抱病，不任軍事。然吾王家屬在此，王業本根之地，如一旦為敵所有，大事去矣。請以庫甲見授，為公備寇。」承業即時授之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000008",
    "sentence": "金全被甲跨馬，召率子弟及退閑諸將，得數百人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000009",
    "sentence": "夜出北門，擊賊於羊馬城內，梁人驚潰，由是退卻。",
    "entities": [
      {
        "text": "擊賊於羊馬城",
        "label": "LOC",
        "start": 5,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000010",
    "sentence": "俄而石君立自潞州至，汴軍退走。",
    "entities": [
      {
        "text": "而石君立自潞州",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000011",
    "sentence": "微金全之奮命，城幾危矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000012",
    "sentence": "莊宗性矜伐，凡大將立功，不時行賞，故金全終莊宗世，名位不進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000013",
    "sentence": "明宗與之有舊，及登極，授金全同平章事，充振武軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000014",
    "sentence": "在任二年，治民為政非所長，詔赴闕，俄而病卒。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000015",
    "sentence": "廢視朝二日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000016",
    "sentence": "初，南北對壘，汴之遊騎每出，必為金全所獲，故梁之偵邏者鹹懼，目之為「安五道」，蓋比鬼將有五道之名也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000017",
    "sentence": "子審琦等，皆位至方鎮，別有傳。",
    "entities": [
      {
        "text": "皆位至方鎮",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000018",
    "sentence": "審通，金全之猶子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000019",
    "sentence": "幼事莊宗，累有戰功，轉先鋒指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000020",
    "sentence": "同光初，為北京右廂馬軍都指揮使，屯奉化軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000021",
    "sentence": "四年春，赴明宗急詔，軍趨夷臒，為前鋒。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000022",
    "sentence": "天成初，授單州刺史，改齊州防禦使，兼諸道先鋒馬軍都指揮使。",
    "entities": [
      {
        "text": "授單州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "改齊州",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000023",
    "sentence": "奉詔北征，從房知溫營於盧台。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000024",
    "sentence": "會龍至部下兵亂，審通脫身酒筵，奪般以濟，促騎士介馬，及亂兵南行，盡戮之，以功授檢校太傅、滄州節度使。",
    "entities": [
      {
        "text": "滄州",
        "label": "LOC",
        "start": 44,
        "end": 46
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000025",
    "sentence": "圍王都於中山，躬冒矢石，為飛石所中而卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000026",
    "sentence": "贈太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000027",
    "sentence": "安元信，字子言，代北人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000028",
    "sentence": "父順琳，為降野軍使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000029",
    "sentence": "元信以將族子，便騎射，幼事武皇，從平巢、蔡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000030",
    "sentence": "光啟中，吐渾赫連鐸寇雲中，武皇使元信拒之，元信兵敗於居庸關。",
    "entities": [
      {
        "text": "信兵敗於居庸關",
        "label": "LOC",
        "start": 22,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000031",
    "sentence": "武皇性嚴急，元信不敢還，遂奔定州；王處存待之甚厚，用為突騎都校。",
    "entities": [
      {
        "text": "遂奔定州",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000032",
    "sentence": "乾寧中，處存子郜嗣位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000033",
    "sentence": "時梁軍攻河朔三鎮，奔命不暇，梁將張存敬軍奄至城下，既無宿備，郜懼，挈其族奔太原，元信從之；武皇待之如初，用為鐵林軍使。",
    "entities": [
      {
        "text": "梁軍攻河朔三鎮",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "張存敬軍奄至城",
        "label": "LOC",
        "start": 16,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000034",
    "sentence": "梁將氏叔琮之攻河東也，別將葛從周自馬嶺入，元信伏於榆次，挫其前鋒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000035",
    "sentence": "梁將李思安之攻上黨也，王師將壁高河，為梁軍所逼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000036",
    "sentence": "別將秦武者，尤為難敵，元信與鬥，斃之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000037",
    "sentence": "由是梁軍解去，城壘得立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000038",
    "sentence": "武皇賜所乘馬及細鎧仗，遷突陣都將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000039",
    "sentence": "莊宗嗣晉王位，元信從救上黨，破夾寨，復澤、潞，以功授檢校司空、遼州刺史，賜玉鞭名馬。",
    "entities": [
      {
        "text": "遼州",
        "label": "LOC",
        "start": 31,
        "end": 33
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000040",
    "sentence": "柏鄉之役，日晚戰酣，元信重傷，莊宗自臨傅藥。",
    "entities": [
      {
        "text": "柏鄉",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000041",
    "sentence": "其年，改檢校司徒、武州刺史，充內衙副都指揮使、山北諸州都團練副使。",
    "entities": [
      {
        "text": "武州",
        "label": "LOC",
        "start": 9,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "山北諸州",
        "label": "LOC",
        "start": 23,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000042",
    "sentence": "從莊宗定魏博，移為博州刺史。",
    "entities": [
      {
        "text": "移為博州",
        "label": "LOC",
        "start": 7,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000043",
    "sentence": "與梁對壘德勝渡，元信為右廂排陣使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000044",
    "sentence": "未幾，為大同軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000045",
    "sentence": "莊宗平定河南，移授橫海軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000046",
    "sentence": "時契丹犯邊，元信與霍彥威從明宗屯常山。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000047",
    "sentence": "元信恃功，每對明宗以成敗勇怯戲侮彥威，彥威不敢答。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000048",
    "sentence": "明宗曰：「成由天地，不由於人。當氏叔琮圍太原，公有何勇！今國家運興，致我等富貴。」勿以小勝小捷掛於口吻，取笑於長者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000049",
    "sentence": "元信乃起謝，不復以彥威為戲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000050",
    "sentence": "明宗即位，以元信嘗為內衙都校，尤厚待之，加同中書門下平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000051",
    "sentence": "明年，移鎮徐州。",
    "entities": [
      {
        "text": "移鎮徐州",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000052",
    "sentence": "王師之討高季興，襄帥劉訓逗撓軍期，移授元信山南東道節度使以代訓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000053",
    "sentence": "歲餘，改歸德軍節度使，就加兼侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000054",
    "sentence": "明宗不豫，求入。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000055",
    "sentence": "末帝即位，授潞州節度使，加檢校太尉。",
    "entities": [
      {
        "text": "授潞州",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000056",
    "sentence": "清泰三年二月，以疾卒於鎮，時年七十四。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "以疾卒於鎮",
        "label": "LOC",
        "start": 7,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000057",
    "sentence": "贈太師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000058",
    "sentence": "晉高祖即位，以元信宿望，令禮官定諡曰忠懿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000059",
    "sentence": "有子六人，長曰友權，曆諸衛大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000060",
    "sentence": "次曰友親，為滁州刺史，卒於任。",
    "entities": [
      {
        "text": "為滁州",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000061",
    "sentence": "安重霸，雲州人也。",
    "entities": [
      {
        "text": "雲州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000062",
    "sentence": "性狡譎，多智算。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000063",
    "sentence": "初，自代北與明宗俱事武皇，因負罪奔梁；在梁復以罪奔蜀，蜀以蕃人善騎射，因為親將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000064",
    "sentence": "蜀後主王衍，幼年襲位，其政多僻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000065",
    "sentence": "宦官王承休居中用事，與成都尹韓昭內外相結，專采擇聲色，以固寵幸。",
    "entities": [
      {
        "text": "成都",
        "label": "LOC",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000066",
    "sentence": "武臣宿將，居常切齒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000067",
    "sentence": "重霸諂事承休，特見委信。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000068",
    "sentence": "梁末，岐下削弱，蜀人奪取秦、成、階等州，重霸說承休求鎮秦州。",
    "entities": [
      {
        "text": "梁",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "階等州",
        "label": "LOC",
        "start": 16,
        "end": 19
      },
      {
        "text": "重霸說承休求鎮",
        "label": "LOC",
        "start": 20,
        "end": 27
      },
      {
        "text": "秦州",
        "label": "LOC",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000069",
    "sentence": "仍於軍中選山東驍果，得數千人，號龍武都，以承休為軍帥，重霸副焉，俱在天水。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000070",
    "sentence": "歲餘，承休欲求旄鉞，乃以隴西花木入獻，又稱秦州山水之美，人物之盛，請後主臨幸，而韓昭讚成之。",
    "entities": [
      {
        "text": "又稱秦州",
        "label": "LOC",
        "start": 19,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000071",
    "sentence": "〈 （《太平廣記》引《王氏見聞錄》云：承休請從諸軍揀選官健，得驍勇數千，號龍武軍，承休自為統帥，並特加衣糧，日有優給。因乞秦州節度使，且云：「願與陛下於秦州采掇美麗。」且說秦州風土，多出國色，仍請幸天水。少主甚悅，即遣仗節赴鎮，應所選龍武精銳，並充衙隊從行。） 〉",
    "entities": [
      {
        "text": "《太平廣記》",
        "label": "TITLE",
        "start": 3,
        "end": 9
      },
      {
        "text": "《王氏見聞錄》",
        "label": "TITLE",
        "start": 10,
        "end": 17
      },
      {
        "text": "因乞秦州",
        "label": "LOC",
        "start": 59,
        "end": 63
      },
      {
        "text": "願與陛下於秦州",
        "label": "LOC",
        "start": 71,
        "end": 78
      },
      {
        "text": "且說秦州",
        "label": "LOC",
        "start": 84,
        "end": 88
      },
      {
        "text": "即遣仗節赴鎮",
        "label": "LOC",
        "start": 107,
        "end": 113
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000072",
    "sentence": "同光二年十月，蜀主率眾數萬，由劍閣將出興、鳳，以遊秦州；至興州，遇魏王繼岌軍至，狼狽而旋。",
