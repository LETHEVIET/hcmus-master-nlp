        "text": "改雲州",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000087",
    "sentence": "居無何，以病求代，時家寄上黨，及歸而卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000088",
    "sentence": "重霸善悅人，好賂遺，時人目之為俊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000089",
    "sentence": "弟重進，尤凶惡。",
    "entities": []
  },
