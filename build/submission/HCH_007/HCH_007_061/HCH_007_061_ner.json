  {
    "sentence_id": "HCH_007_061_000130",
    "sentence": "先是，絳州刺史王瓘叛，武皇言於彥琮，意欲致之。",
    "entities": [
      {
        "text": "絳州",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000131",
    "sentence": "無幾，從略於汾、晉之郊，彥琮奔絳，瓘以為附己，待之甚厚，因命為騎將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000132",
    "sentence": "會瓘出獵，於馳驅之際，彥琮刃瓘之首來獻，武皇甚奇之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000133",
    "sentence": "從莊宗解上黨之圍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000134",
    "sentence": "同光初，稍遷至鐵林指揮使、磁州刺史。",
    "entities": [
      {
        "text": "磁州",
        "label": "LOC",
        "start": 13,
        "end": 15
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000135",
    "sentence": "後明宗赴難京師，授華州留後，尋正授節旄。",
    "entities": [
      {
        "text": "授華州",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000136",
    "sentence": "天成三年，改左武衛上將軍。",
    "entities": [
      {
        "text": "天成三年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000137",
    "sentence": "未幾，改陝州節度使，尋移鎮邠州，卒於鎮，時年六十四。",
    "entities": [
      {
        "text": "改陝州",
        "label": "LOC",
        "start": 3,
        "end": 6
      },
      {
        "text": "尋移鎮邠州",
        "label": "LOC",
        "start": 10,
        "end": 15
      },
      {
        "text": "卒於鎮",
        "label": "LOC",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000138",
    "sentence": "贈太傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000139",
    "sentence": "袁建豐，武皇破巢時得於華陰，年方九歲，愛其精神爽俊，俾收養之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000140",
    "sentence": "漸長，列於左右，復習騎射，補鐵林都虞候。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000141",
    "sentence": "從破邠州王行瑜，以功遷左親騎軍使，轉突騎指揮使。",
    "entities": [
      {
        "text": "從破邠州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000142",
    "sentence": "從莊宗解圍上黨，破柏鄉陣，累功遷右僕射、左廂馬軍指揮使。",
    "entities": [
      {
        "text": "破柏鄉",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000143",
    "sentence": "明宗為內衙指揮使，建豐為副。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000144",
    "sentence": "北討劉守光，常身先士伍，轉都教練使，權蕃漢副總管。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000145",
    "sentence": "莊宗入鄴，以心腹幹能，選為魏府都巡檢使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000146",
    "sentence": "從征劉鄩，下衛、磁、洺有功，加檢校司空，授州洺州刺史。",
    "entities": [
      {
        "text": "授州洺州",
        "label": "LOC",
        "start": 20,
        "end": 24
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000147",
    "sentence": "於臨洺西敗梁將王遷數千人，生獲將領七十餘人，俄拜相州刺史。",
    "entities": [
      {
        "text": "俄拜相州",
        "label": "LOC",
        "start": 22,
        "end": 26
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000148",
    "sentence": "征赴河上，豫戰於胡柳陂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000149",
    "sentence": "建豐領相州軍士，行營在外，委州事於小人，失於撫馭，指揮使孟守謙據城以叛，建豐引兵討平之。",
    "entities": [
      {
        "text": "建豐領相州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "委州",
        "label": "LOC",
        "start": 13,
        "end": 15
      },
      {
        "text": "揮使孟守謙據城",
        "label": "LOC",
        "start": 26,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000150",
    "sentence": "改隰州刺史，染風痹於任。",
    "entities": [
      {
        "text": "改隰州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000151",
    "sentence": "明宗嗣位，念及平昔副貳之舊，詔赴洛下，親幸其第，撫問隆厚，加檢校太傅，遙授鎮南節度使，俾請俸自給。",
    "entities": [
      {
        "text": "遙授鎮",
        "label": "LOC",
        "start": 35,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000152",
    "sentence": "後卒於洛陽，年五十六。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000153",
    "sentence": "廢朝一日，贈太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000154",
    "sentence": "子可鈞，仕皇朝，位至諸衛大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000155",
    "sentence": "西方鄴，定州滿城人也。",
    "entities": [
      {
        "text": "定州滿城",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000156",
    "sentence": "父再遇，為州軍校。",
    "entities": [
      {
        "text": "為州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000157",
    "sentence": "鄴居軍中，以勇力聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000158",
    "sentence": "年二十，南渡河遊梁，不見用，復歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000159",
    "sentence": "莊宗以為孝義軍指揮使，累從征伐皆有功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000160",
    "sentence": "同光中，為曹州刺史，以州兵屯汴州。",
    "entities": [
      {
        "text": "為曹州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "以州兵屯汴州",
        "label": "LOC",
        "start": 10,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000161",
    "sentence": "明宗自魏州，南渡河，時莊宗東幸汴州。",
    "entities": [
      {
        "text": "明宗自魏州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "時莊宗東幸汴州",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000162",
    "sentence": "汴州節度使孔循懷二誌，使北門迎明宗，西門迎莊宗，所以供帳委積悉如一，曰：「先至者入之。」 鄴因責循曰：「主上破梁室於公，有不殺之恩，奈何欲納總管而負國？」循不答。",
    "entities": [
      {
        "text": "汴州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000163",
    "sentence": "鄴度循不可爭，以石敬瑭妻，明宗女也，時方在汴，欲殺之以堅人心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000164",
    "sentence": "循知其謀，取之藏其家，鄴無如之何。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000165",
    "sentence": "而明宗已及汴，乃將麾下兵五百騎西迎莊宗，見於汜水，嗚咽泣下，莊宗亦為之噓唏，使以兵為先鋒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000166",
    "sentence": "莊宗至汴西，不得入，還洛陽，遇弑。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000167",
    "sentence": "明宗入洛，鄴請死於馬前，明宗嘉歎久之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000168",
    "sentence": "明年，荊南高季興叛，明宗遣襄州節度使劉訓等招討，而以東川董璋為西南招討使，乃拜鄴夔州刺史，副璋，以兵出三峽。",
    "entities": [
      {
        "text": "明宗遣襄州",
        "label": "LOC",
        "start": 10,
        "end": 15
      },
      {
        "text": "乃拜鄴夔州",
        "label": "LOC",
        "start": 37,
        "end": 42
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 42,
        "end": 44
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000169",
    "sentence": "已而訓等無功見黜，諸將皆罷，璋未嘗出兵，惟鄴獨取夔、忠、萬三州，乃以夔州為寧江軍，拜鄴節度使。",
    "entities": [
      {
        "text": "萬三州",
        "label": "LOC",
        "start": 28,
        "end": 31
      },
      {
        "text": "乃以夔州",
        "label": "LOC",
        "start": 32,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000170",
    "sentence": "已而又取歸州，數敗季興之兵。",
    "entities": [
      {
        "text": "已而又取歸州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000171",
    "sentence": "鄴，武人，所為多不中法度，判官譚善達數以諫鄴，鄴怒，遣人告善達受人金，下獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000172",
    "sentence": "善達素剛，辭益不遜，遂死於獄中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000173",
    "sentence": "鄴病，見善達為祟，卒於鎮。",
    "entities": [
      {
        "text": "卒於鎮",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000174",
    "sentence": "張遵誨，魏州人也。",
    "entities": [
      {
        "text": "魏州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000175",
    "sentence": "父為宗城令，羅紹威殺牙軍之歲，為梁軍所害。",
    "entities": [
      {
        "text": "父為宗城",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000176",
    "sentence": "遵誨奔太原，武皇以為牙門將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000177",
    "sentence": "莊宗定山東，遵誨以典客從，曆幽、鎮二府馬步都虞候。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000178",
    "sentence": "同光中，為金吾大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000179",
    "sentence": "明宗即位，任圜保薦，授西都副留守，知留守事、京兆尹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000180",
    "sentence": "天成四年，入為客省使、守衛尉卿。",
    "entities": [
      {
        "text": "天成四年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000181",
    "sentence": "及將有事於南郊，為修儀仗法物使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000182",
    "sentence": "初，遵誨自以歷位尹正，與安重誨素亦相款，衷心有望於節鉞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000183",
    "sentence": "及郊禋畢，止為絳州刺史，鬱鬱不樂。",
    "entities": [
      {
        "text": "止為絳州",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000184",
    "sentence": "離京之日，白衣乘馬於隼之下，至郡無疾，翌日而卒。",
    "entities": [
      {
        "text": "至郡",
        "label": "LOC",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000185",
    "sentence": "孫璋，齊州曆城人。",
    "entities": [
      {
        "text": "齊州曆城",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000186",
    "sentence": "出身行間，隸梁將楊師厚麾下，稍補奉化軍使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000187",
    "sentence": "莊宗入鄴，累遷澶州都指揮使。",
    "entities": [
      {
        "text": "累遷澶州",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000188",
    "sentence": "明宗鎮常山，擢為裨校。",
    "entities": [
      {
        "text": "明宗鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000189",
    "sentence": "鄴兵之變，從明宗赴難京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000190",
    "sentence": "天成初，曆趙、登二州刺史，齊州防禦使。",
    "entities": [
      {
        "text": "登二州",
        "label": "LOC",
        "start": 7,
        "end": 10
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "齊州",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000191",
    "sentence": "王都之據中山，璋為定州行營都虞候，賊平，加檢校太保。",
    "entities": [
      {
        "text": "璋為定州",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000192",
    "sentence": "長興初，授鄜州節度使，罷鎮，卒於洛陽，年六十一。",
    "entities": [
      {
        "text": "授鄜州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "罷鎮",
        "label": "LOC",
        "start": 11,
        "end": 13
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_061_000193",
    "sentence": "贈太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000194",
    "sentence": "史臣曰：夫天地斯晦，則帝王於是龍飛；雲雷構屯，則王侯以之蟬蛻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000195",
    "sentence": "良以適遭亂世，得奮雄圖，故金全而下，咸以軍旅之功，坐登藩閫之位，垂名簡冊，亦可貴焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_061_000196",
    "sentence": "惟重霸以奸險而仗旄鉞，蓋非數子之儔也。",
    "entities": []
  },
