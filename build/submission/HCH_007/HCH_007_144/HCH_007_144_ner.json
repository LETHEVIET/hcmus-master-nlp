[
  {
    "sentence_id": "HCH_007_144_000001",
    "sentence": "◎樂誌上",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_144_000002",
    "sentence": "古之王者，理定制禮，功成作樂，所以昭事天地，統和人神，歷代已來，舊章斯在。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_144_000003",
    "sentence": "洎唐季之亂，鹹、鎬為墟；梁運雖興，《英》、《莖》掃地。",
    "entities": [
      {
        "text": "《英》",
        "label": "TITLE",
        "start": 17,
        "end": 20
      },
      {
        "text": "《莖》",
        "label": "TITLE",
        "start": 21,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_144_000004",
    "sentence": "莊宗起於朔野，經始霸圖，其所存者，不過邊部鄭聲而已，先王雅樂，殆將泯絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_144_000005",
    "sentence": "當同光、天成之際，或有事清廟，或祈祀泰壇，雖簨虡猶施，而宮商孰辨？",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_144_000006",
    "sentence": "遂使磬襄、鼗武，入河、漢而不歸；湯、舜韶，混陵谷而俱失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_144_000007",
    "sentence": "洎晉高祖奄登大寶，思迪前規，爰詔有司，重興二舞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_144_000008",
    "sentence": "旋屬烽火為亂，明法罔修，漢祚幾何，無暇制作。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_144_000009",
    "sentence": "周顯德五年冬，將立歲仗，有司以崇牙樹羽，宿設於殿庭。",
    "entities": [
      {
        "text": "顯德五年",
        "label": "TME",
        "start": 1,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_144_000010",
    "sentence": "世宗因親臨樂懸，試其聲奏，見鐘磬之類，有設而不擊者，訊於工師，皆不能對。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_144_000011",
    "sentence": "世宗惻然，乃命翰林學士、判太常寺事竇儼參詳其制，又命樞密使王樸考正其聲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_144_000012",
    "sentence": "樸乃用古累黍之法，以審其度，造成律準，其狀如琴而巨，凡設十三弦以定六律、六呂旋相為宮之義。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_144_000013",
    "sentence": "世宗善之，申命百官議而行之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_144_000014",
    "sentence": "今亦備紀於後，以誌五代雅樂沿革之由焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_144_000015",
