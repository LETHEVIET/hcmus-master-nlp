        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_136_000056",
    "sentence": "是年冬，改元天漢，又改元光天。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_136_000057",
    "sentence": "在位十二年，年七十二。",
