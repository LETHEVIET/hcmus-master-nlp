        "end": 23
      },
      {
        "text": "二年",
        "label": "TME",
        "start": 72,
        "end": 74
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000047",
    "sentence": "子從訓，昭宗在華時授太子侍學，賜名文禮，尋拜屯田員外郎。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000048",
    "sentence": "國初為都官郎中，賜紫，年未弱冠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000049",
    "sentence": "時朝廷命從訓告國哀於陳、許，至二日軍亂，與建並命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000050",
    "sentence": "乾化三年，追贈太師。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000051",
    "sentence": "李罕之",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000052",
    "sentence": "李罕之，陳州項城人。",
    "entities": [
      {
        "text": "陳州項城",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000053",
    "sentence": "父文，世田家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000054",
    "sentence": "罕之拳勇趫捷，力兼數人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000055",
    "sentence": "少學為儒，不成，又落發為僧，以其無賴，所至不容。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000056",
    "sentence": "曾乞食於酸棗縣，自旦至晡，無與之者，乃擲缽於地，毀棄僧衣，亡命為盜。",
    "entities": [
      {
        "text": "曾乞食於酸棗縣",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000057",
    "sentence": "會黃巢起曹、濮，罕之因合徒作剽，漸至魁首。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000058",
    "sentence": "及賊巢渡江，罕之因以兵將背賊歸於唐，高駢錄其功，表為光州刺史。",
    "entities": [
      {
        "text": "表為光州",
        "label": "LOC",
        "start": 24,
        "end": 28
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000059",
    "sentence": "歲餘，為蔡賊秦宗權寇迫，不能守，乃棄郡歸項城，收合餘眾，依河陽諸葛爽，爽署為懷州刺史。",
    "entities": [
      {
        "text": "乃棄郡歸項城",
        "label": "LOC",
        "start": 16,
        "end": 22
      },
      {
        "text": "爽署為懷州",
        "label": "LOC",
        "start": 35,
        "end": 40
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 40,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000060",
    "sentence": "光啟初，僖宗以爽為東南面招討，以擊宗權，爽乃表罕之為副，令將兵屯宋州。",
    "entities": [
      {
        "text": "令將兵屯宋州",
        "label": "LOC",
        "start": 28,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000061",
    "sentence": "蔡寇凶焰日熾，兵鋒不敵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000062",
    "sentence": "中和四年，爽表罕之為河南尹、東都留守。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000063",
    "sentence": "是歲，李克用脫上源之難，斂軍西歸，路由洛陽，罕之迎謁，供帳館待甚優，因與克用厚相結托。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000064",
    "sentence": "時罕之有眾三千，以聖善寺為府。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000065",
    "sentence": "光啟元年，蔡賊秦宗權遣將孫儒來攻，罕之對壘數月，以兵少備竭，委城而遁，西保於澠池。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "委城",
        "label": "LOC",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000066",
    "sentence": "蔡賊據京城月餘，焚燒宮闕，剽剝居民。",
    "entities": [
      {
        "text": "蔡賊據京城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000067",
    "sentence": "賊既退去，鞠為煨燼，寂無雞犬之音。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000068",
    "sentence": "罕之復引其眾，築壘於市西。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000069",
    "sentence": "明年冬，諸葛爽死，其將劉經推爽子仲方為帥，經懼罕之難製，自引兵鎮洛陽。",
    "entities": [
      {
        "text": "自引兵鎮",
        "label": "LOC",
        "start": 28,
        "end": 32
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000070",
    "sentence": "罕之部曲有李瑭、郭璆者，情不相葉，欲相圖害，罕之怒，誅璆，軍情由是不睦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000071",
    "sentence": "劉經因其有間，掩擊罕之於澠池。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000072",
    "sentence": "軍亂，保乾壕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000073",
    "sentence": "經急攻之，為罕之所敗，罕之乘勝追至洛陽。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000074",
    "sentence": "時經保敬愛寺，罕之保苑中飛龍廄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000075",
    "sentence": "罕之激勵其眾攻敬愛寺，數日，因風縱火，盡燔之，經眾奔竄，追斬殆盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000076",
    "sentence": "罕之進逼河陽，營於鞏縣，陳舟於汜水，將渡，諸葛仲方遣將張言率師拒於河上。",
    "entities": [
      {
        "text": "營於鞏縣",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000077",
    "sentence": "時仲方年幼，政在劉經，諸將心多不附。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000078",
    "sentence": "張言密與罕之修好；經知其謀，言懼，引眾渡河歸罕之，因合勢攻河陽，為經所敗，罕之與言退保懷州。",
    "entities": [
      {
        "text": "之與言退保懷州",
        "label": "LOC",
        "start": 38,
        "end": 45
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000079",
    "sentence": "冬，蔡將孫儒陷河陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000080",
    "sentence": "仲方泛輕舟來奔，孫儒遂自稱節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000081",
    "sentence": "俄而蔡賊為我軍所敗，孫儒棄河陽歸蔡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000082",
    "sentence": "罕之與言收合其眾，求援於太原，李克用遣澤州刺史安金俊率騎助之，遂收河陽。",
    "entities": [
      {
        "text": "李克用遣澤州",
        "label": "LOC",
        "start": 15,
        "end": 21
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000083",
    "sentence": "克用表罕之為節度、同平章事；又表言為河南尹、東都留守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000084",
    "sentence": "罕之既與言患難交契，刻臂為盟，永同休戚，如張耳、陳餘之義也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000085",
    "sentence": "罕之雖有膽決，雄猜翻覆，而撫民禦眾無方略，率多苛暴，性復貪冒，不得士心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000086",
    "sentence": "既得河陽，出兵攻晉、絳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000087",
    "sentence": "時大亂之後，野無耕稼，罕之部下以俘剽為資，啖人作食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000088",
    "sentence": "絳州刺史王友遇以城降，罕之乃進攻晉州，河中王重盈遣使求援於太祖。",
    "entities": [
      {
        "text": "絳州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "罕之乃進攻晉州",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000089",
    "sentence": "時張言治軍有法，善積聚，勤於播植，軍儲不乏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000090",
    "sentence": "言輸粟於罕之，以給其軍，罕之求索無限，言頗苦之，力不能應，罕之則錄河南府吏笞責之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000091",
    "sentence": "東諸侯修貢行在，多為罕之邀留，王重盈苦其侵削，密結張言請圖之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000092",
    "sentence": "文德元年春，會罕之盡出其眾攻平陽，言夜出師掩擊河陽，罕之無備，單步僅免，舉族為言所俘。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000093",
    "sentence": "罕之奔於太原，李克用表為澤州刺史，仍領河陽節度使。",
    "entities": [
      {
        "text": "李克用表為澤州",
        "label": "LOC",
        "start": 7,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000094",
    "sentence": "三月，克用遣其將李存孝率師三萬助之，來攻懷、孟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000095",
    "sentence": "城中食盡，備豫皆竭，張言遣其孥入質，且求救於太祖；太祖遣葛從周、牛存節赴之，逆戰於流河店。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000096",
    "sentence": "會晉將安休休以一軍奔於蔡，存孝引軍而退，罕之保於澤州。",
    "entities": [
      {
        "text": "罕之保於澤州",
        "label": "LOC",
        "start": 20,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000097",
    "sentence": "自是罕之日以兵寇鈔懷、孟、晉、絳，數百里內，郡邑無長吏，閭裏無居民。",
    "entities": [
      {
        "text": "郡邑",
        "label": "LOC",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000098",
    "sentence": "河內百姓，相結屯寨，或出樵汲，即為俘馘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000099",
    "sentence": "雖奇峰絕磴，梯危架險，亦為罕之部眾攻取。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000100",
    "sentence": "先是，蒲、絳之間有山曰摩雲，邑人立柵於上，以避寇亂；罕之以百餘人攻下之，軍中因號罕之為李摩雲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000101",
    "sentence": "自是數州之民，屠啖殆盡，荊棘蔽野，煙火斷絕，凡十餘年。",
    "entities": [
      {
        "text": "自是數州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000102",
    "sentence": "乾寧二年，李克用出師以拒邠、鳳，營於渭北，天子以克用為邠州行營四面都統，克用乃表罕之為副。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "子以克用為邠州",
        "label": "LOC",
        "start": 22,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000103",
    "sentence": "及誅王行瑜，罕之以功授檢校太尉，食邑千戶。",
    "entities": [
      {
        "text": "食邑",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000104",
    "sentence": "罕之自以功多，私謂晉將蓋寓曰：「餘自河陽失守，來依巨蔭，歲月滋久，功效未施。比年以來，倦於師旅，所謂老夫耄矣，無能為也。望吾王仁湣，太傅哀憐，與一小鎮，休兵養疾，一二年間即歸老菟裘，幸也。」寓為言之，克用不對。",
    "entities": [
      {
        "text": "與一小鎮",
        "label": "LOC",
        "start": 71,
        "end": 75
      },
      {
        "text": "一二年",
        "label": "TME",
        "start": 81,
        "end": 84
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000105",
    "sentence": "每藩鎮缺帥，議所不及，罕之私心鬱鬱，蓋寓懼其他圖，亟為論之。",
    "entities": [
      {
        "text": "每藩鎮",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000106",
    "sentence": "克用曰：「吾於罕之，豈惜一鎮；吾有罕之，亦如董卓之有呂布，雄則雄矣，鷹鳥之性，飽則颺去，實懼翻覆毒餘也。」",
    "entities": [
      {
        "text": "豈惜一鎮",
        "label": "LOC",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000107",
    "sentence": "光化元年十二月，晉之潞帥薛誌勤卒，罕之乘其喪，自澤州率眾徑入潞州，自稱留後，以狀聞於克用曰：「聞誌勤之喪，新帥未至，慮為他盜所窺，不俟命，已屯於潞矣。」克用怒，遣李昭嗣討之，罕之執其守將馬溉、伊鐸、何萬友，沁州刺史傅瑤等，遣其子顥拘送於太祖以求援焉。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "自澤州",
        "label": "LOC",
        "start": 23,
        "end": 26
      },
      {
        "text": "率眾徑入潞州",
        "label": "LOC",
        "start": 26,
        "end": 32
      },
      {
        "text": "沁州",
        "label": "LOC",
        "start": 103,
        "end": 105
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 105,
        "end": 107
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000108",
    "sentence": "〈 （《新唐書》：全忠表罕之昭義軍節度使。） 〉 會罕之暴病，不能視事。",
    "entities": [
      {
        "text": "《新唐書》",
        "label": "TITLE",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000109",
    "sentence": "明年六月，病篤，太祖令丁會代之，移罕之為河陽節度使；行至懷州，卒於傳舍，時年五十八。",
    "entities": [
      {
        "text": "行至懷州",
        "label": "LOC",
        "start": 26,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000110",
    "sentence": "其子顥以舟載柩，歸葬河陰縣。",
    "entities": [
      {
        "text": "歸葬河陰縣",
        "label": "LOC",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000111",
    "sentence": "開平二年春，詔贈中書令。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000112",
    "sentence": "馮行襲",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000113",
    "sentence": "馮行襲，字正臣，武當人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000114",
    "sentence": "曆職為本郡都校。",
    "entities": [
      {
        "text": "曆職為本郡",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000115",
    "sentence": "中和中，僖宗在蜀，有賊首孫喜者，聚徒數千人慾入武當，刺史呂煜惶駭無策略。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000116",
    "sentence": "行襲伏勇士於江南，乘小舟逆喜，謂喜曰：「郡人得良牧，眾心歸矣，但緣兵多，民懼擄掠。若駐軍江北，領肘腋以赴之，使某前導，以安慰士民，可立定也。」喜然之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000117",
    "sentence": "既渡江，軍吏迎謁，伏甲奮起，行襲擊喜仆地，仗劍斬之，其黨盡殪，賊眾在江北者悉奔潰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000118",
    "sentence": "山南節度使劉巨容以功上言，尋授均州刺史。",
    "entities": [
      {
        "text": "尋授均州",
        "label": "LOC",
        "start": 13,
        "end": 17
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000119",
    "sentence": "州西有長山，當襄、漢、蜀路，群賊屯據，以邀劫貢奉，行襲又破之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000120",
    "sentence": "洋州節度使葛佐奏辟為行軍司馬，請將兵鎮穀口，通秦、蜀道，由是益知名。",
    "entities": [
      {
        "text": "洋州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "請將兵鎮",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000121",
    "sentence": "李茂貞遣養子繼臻竊據金州，行襲攻下之，因授金州防禦使。",
    "entities": [
      {
        "text": "因授金州",
        "label": "LOC",
        "start": 19,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000122",
    "sentence": "時興元楊守亮將襲京師，道出金、商，行襲逆擊，大破之。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 2,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000123",
    "sentence": "詔升金州為節鎮，以戎昭軍為額，即以行襲為節度使。",
    "entities": [
      {
        "text": "詔升金州為節鎮",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000124",
    "sentence": "及太祖義旗西征，行襲遣副使魯崇矩稟受制令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000125",
    "sentence": "會唐昭宗幸鳳翔，太祖帥師奉迎，久之未出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000126",
    "sentence": "中尉韓全誨遣中官郤文晏等二十餘人分命矯詔，欲征江、淮兵屯於金州，以脅太祖之軍，行襲定策盡殺之，收其詔敕送於太祖。",
    "entities": [
      {
        "text": "淮兵屯於金州",
        "label": "LOC",
        "start": 25,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000127",
    "sentence": "天祐元年，兼領洋州節度使。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "兼領洋州",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000128",
    "sentence": "太祖之伐荊、襄，行襲令其子勖以舟師會於均、房，預收復功，遷匡國軍節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000129",
    "sentence": "到任，誅大吏張澄，暴其罪，州人莫不惴懾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000130",
    "sentence": "在許三年，上供外，別進助軍羨糧二十萬石。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000131",
    "sentence": "及太祖郊禋，行襲請入覲，貢獻巨萬，恩禮殊厚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000132",
    "sentence": "尋詔翰林學士杜曉撰德政碑以賜之，累官至兼中書令，冊拜司空。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000133",
    "sentence": "開平中卒，輟朝一日，贈太傅，諡曰忠敬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000134",
    "sentence": "行襲性嚴烈，為政深刻，然所至有天幸，境內嘗大蝗，尋有群鳥啄食，不為害；民或艱食，必有穭穀，出於壟畝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000135",
    "sentence": "雖威福在己，而恆竭力以奉於王室，故能保其功名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000136",
    "sentence": "行襲魁岸雄壯，麵有青誌，當時目為「馮青麵」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000137",
    "sentence": "長子勖，曆蘄、沁二州刺史。",
    "entities": [
      {
        "text": "沁二州",
        "label": "LOC",
        "start": 7,
        "end": 10
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000138",
    "sentence": "次子德晏，仕至金吾將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000139",
    "sentence": "孫德昭",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000140",
    "sentence": "孫德昭，鹽州五原縣人，世為州校。",
    "entities": [
      {
        "text": "鹽州五原縣",
        "label": "LOC",
        "start": 4,
        "end": 9
      },
      {
        "text": "世為州",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000141",
    "sentence": "父惟晸，有功於唐朝，遙領荊南節度，分判右神策軍事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000142",
    "sentence": "德昭藉父蔭，累職為右神策軍都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000143",
    "sentence": "光化三年，唐昭宗為閹宦所廢，矯立德王，時中外以權在禁闥，莫能致討，近藩朋附，章表繼有至者。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000144",
    "sentence": "丞相崔胤，外與太祖申結輔佐之好，內遣心腹密講忠義。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000145",
    "sentence": "有以事喻德昭者， 〈 （《通鑒》：德昭常惋不平，崔胤聞之，遣判官石戩與之遊。德昭每酒酣必泣，戩知其誠，乃密以允意說之。） 〉 德昭感慨，乃與本軍孫承誨、董從實三人，奮發應命，誓圖返正，崔又割衣手筆以通其志。",
    "entities": [
      {
        "text": "《通鑒》",
        "label": "TITLE",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000146",
    "sentence": "天復元年正月一日未旦，逆豎左軍容劉季述早入，德昭伏甲要路以俟，追其前驅，邀而斬之，孫承誨等分捕左軍容王仲先黨伍。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000147",
    "sentence": "唐昭宗方幽辱東內，聞外喧，大恐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000148",
    "sentence": "德昭馳至，扣閣曰：「逆賊劉季述伏誅矣，請上皇開鑰復皇帝位。」皇后何氏呼曰：「汝可進逆人首，門乃可開。」俄而承誨、從實俱以馘獻，昭宗悲而嘉之。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 25,
        "end": 27
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000149",
    "sentence": "於是丞相崔胤奉迎禦丹鳳樓，率百辟待罪，泣且奏曰：「臣居大位，不能討奸，賴東平王全忠首奮忠貞，誅殺邸吏，遂致德昭等擒戮妖逆，再清禁闈。」即日議功，以德昭為檢校太保、靜海軍節度使，承誨邕州節度使，從實容州節度使，並同平章事，錫姓李，賜號扶傾濟難忠烈功臣，圖形淩煙閣，俱留京師。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "承誨邕州",
        "label": "LOC",
        "start": 88,
        "end": 92
      },
      {
        "text": "從實容州",
        "label": "LOC",
        "start": 96,
        "end": 100
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000150",
    "sentence": "錫賚宴賞之厚，恩寵權幸之勢，近代罕比。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000151",
    "sentence": "其年十一月，閹宦韓全誨縱火脅昭宗西幸鳳翔，承誨、從實並變節，為中官所誘，始欲驅擁百僚，將圖出令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000152",
    "sentence": "而德昭獨按兵，與太祖親吏婁敬思葉力衛丞相及文武百官，與長安吏民保於街東，免為所劫。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000153",
    "sentence": "太祖遣從事相繼勞問，遺以龍鳳劍、鬥雞紗，委令製輯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000154",
    "sentence": "於是百官次華州，連狀請太祖迎奉。",
    "entities": [
      {
        "text": "於是百官次華州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000155",
    "sentence": "及大旆入關，德昭以軍禮上謁，立道左，太祖命左右扶騎控至長安，賜與甚厚，署權知同州節度留後。",
    "entities": [
      {
        "text": "及大旆入關",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 27,
        "end": 29
      },
      {
        "text": "署權知同州",
        "label": "LOC",
        "start": 35,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000156",
    "sentence": "將赴任，復徇民請，留充兩街製置使，賜錢百萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000157",
    "sentence": "德昭以本部兵八千人獻於太祖，由是愈見賞重，又賜甲第一區，俾先還洛陽。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000158",
    "sentence": "及昭宗東遷，奏授左威衛上將軍，以疾免，歸於別墅。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000159",
    "sentence": "太祖受禪，以左領衛上將軍征赴闕。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000160",
    "sentence": "開平四年，拜左金吾大將軍，充街使。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000161",
    "sentence": "末帝即位，俾將命於兩浙，對見失儀，不果行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000162",
    "sentence": "尋改授右武衛上將軍，俄復左金吾大將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000163",
    "sentence": "卒於官，詔贈太傅，輟視朝一日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000164",
    "sentence": "天復初，德昭與孫承誨、董從實以返正功，時人呼為「三使相」，恩澤俱冠世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000165",
    "sentence": "及承誨至鳳翔，易名繼誨，從實改名彥弼，皆為李茂貞所養。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000166",
    "sentence": "後閹官之敗，俱戮於京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000167",
    "sentence": "惟德昭克全終始，有所稱雲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000168",
    "sentence": "趙克裕",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000169",
    "sentence": "，河陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000170",
    "sentence": "祖、父皆為軍吏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000171",
    "sentence": "克裕少為牙將，好讀書，謹儀範，牧伯皆奇待之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000172",
    "sentence": "累居右職，擢為虎牢關使。",
    "entities": [
      {
        "text": "擢為虎牢關",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000173",
    "sentence": "光啟中，蔡寇陷河陽，克裕率所部歸於太祖，隸於宣義軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000174",
    "sentence": "太祖東征徐、鄆，克裕屢受指顧，無不如意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000175",
    "sentence": "數年之內，繼領亳、鄭二州刺史。",
    "entities": [
      {
        "text": "鄭二州",
        "label": "LOC",
        "start": 9,
        "end": 12
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000176",
    "sentence": "時關東藩鎮方為蔡寇所毒，黎元流散，不能相保，克裕妙有農戰之備，復善於綏懷，民賴而獲安者眾。",
    "entities": [
      {
        "text": "時關東藩鎮",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000177",
    "sentence": "太祖表為河陽節度使、檢校右僕射，尋移理許田，入為金吾衛大將軍、檢校司空。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 27,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000178",
    "sentence": "及太祖為元帥，以克裕為元帥府左都押衙，復統六軍，兗州平，命權知泰寧軍留後。",
    "entities": [
      {
        "text": "兗州",
        "label": "LOC",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000179",
    "sentence": "數月，暴疾而卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000180",
    "sentence": "開平初，追贈太保。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000181",
    "sentence": "張慎思",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000182",
    "sentence": "張慎思，清河人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000183",
    "sentence": "自黃巢軍來歸，累授軍職，曆諸軍都指揮使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000184",
    "sentence": "從平巢、蔡、兗、鄆，皆著功，表授檢校工部尚書，兼宋州長史。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 20,
        "end": 22
      },
      {
        "text": "兼宋州",
        "label": "LOC",
        "start": 23,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000185",
    "sentence": "光化中，加檢校右僕射，權知亳州。",
    "entities": [
      {
        "text": "權知亳州",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000186",
    "sentence": "天復三年，昭宗還長安，以從太祖迎駕功，賜號迎鑾毅勇功臣，尋除汝州防禦使。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 8,
        "end": 10
      },
      {
        "text": "尋除汝州",
        "label": "LOC",
        "start": 28,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000187",
    "sentence": "天祐元年，授左龍武統軍。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000188",
    "sentence": "其冬，除許州匡國軍節度使。",
    "entities": [
      {
        "text": "除許州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000189",
    "sentence": "明年十一月，權知徐州武寧軍兩使留後。",
    "entities": [
      {
        "text": "權知徐州",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000190",
    "sentence": "太祖受禪，入為左金吾大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000191",
    "sentence": "開平二年，除宋州刺史，未幾，復拜左金吾大將軍。",
    "entities": [
