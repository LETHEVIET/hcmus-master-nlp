[
  {
    "sentence_id": "HCH_007_015_000001",
    "sentence": "韓建",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000002",
    "sentence": "韓建，字佐時，許州長社人。",
    "entities": [
      {
        "text": "許州",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000003",
    "sentence": "父叔豐，世為牙校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000004",
    "sentence": "初，秦宗權之據蔡州，招合亡命，建隸為軍士，累轉至小校。",
    "entities": [
      {
        "text": "秦宗權之據蔡州",
        "label": "LOC",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000005",
    "sentence": "唐中和初，忠武監軍楊復光起兵於蔡，宗權遣其將鹿宴宏赴之，建與里人王建俱隸宴宏軍，入援京師。",
    "entities": [
      {
        "text": "唐",
        "label": "ORG",
        "start": 0,
        "end": 1
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000006",
    "sentence": "賊平，復光暴卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000007",
    "sentence": "時僖宗在蜀，宴宏率所部赴行在。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000008",
    "sentence": "路出南山，因攻剽郡邑，據有興元。",
    "entities": [
      {
        "text": "因攻剽郡邑",
        "label": "LOC",
        "start": 5,
        "end": 10
      },
      {
        "text": "元",
        "label": "ORG",
        "start": 14,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000009",
    "sentence": "宴宏自為留後，以建為蜀郡刺史。",
    "entities": [
      {
        "text": "以建為蜀郡",
        "label": "LOC",
        "start": 7,
        "end": 12
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000010",
    "sentence": "唐軍容使田令孜密遣人誘建，啖以厚利，建時懼為宴宏所並，乃率所部歸行在，令孜補為神策都校、金吾將軍，出為潼關防禦使兼華州刺史。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 46,
        "end": 48
      },
      {
        "text": "出為潼關",
        "label": "LOC",
        "start": 49,
        "end": 53
      },
      {
        "text": "防禦使兼華州",
        "label": "LOC",
        "start": 53,
        "end": 59
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 59,
        "end": 61
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000011",
    "sentence": "河、潼經大寇之後，戶口流散，建披荊棘，辟汙萊，勸課農事，樹植蔬果，出入閭裏，親問疾苦，不數年，流亡畢復，軍民充實。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000012",
    "sentence": "建比不知書，治郡之暇，日課學習。",
    "entities": [
      {
        "text": "治郡",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000013",
    "sentence": "遣人於器皿、床榻之上各題其名，建視之既熟，乃漸通文字。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000014",
    "sentence": "俄遷華商節度、潼關守捉等使，累加檢校太尉、平章事。",
    "entities": [
      {
        "text": "潼關",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000015",
    "sentence": "乾寧二年，建與鳳翔李茂貞、邠州王行瑜舉兵赴闕，迫昭宗請以王珙為河中帥，害大臣於都下。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "邠州",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000016",
    "sentence": "河中王珂召晉軍以為援，及晉軍渡河，昭宗幸石門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000017",
    "sentence": "三年四月，昭宗遣延王、通王率禁兵討李茂貞，為茂貞所敗，車駕幸渭橋。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000018",
    "sentence": "翌日，次富平，將幸河中，建奉表迎駕，俄自至渭北，懇乞東幸，許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000019",
    "sentence": "七月十五日，昭宗至華下，百官士庶相繼而至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000020",
    "sentence": "建尋加兼中書令，充京畿安撫製置等使，又兼京兆尹、京城把截使。",
    "entities": [
      {
        "text": "京城",
        "label": "LOC",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000021",
    "sentence": "昭宗久在華州，思還宮掖，每花朝月夕，遊宴西溪，與群臣屬詠歌詩，歔欷流涕。",
    "entities": [
      {
        "text": "昭宗久在華州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000022",
    "sentence": "建每從容奏曰：「臣為陛下修營大內，結信諸侯，一二年間，必期興復。」乃以建兼領修創京城使，建自華督役輦運工作，復治大明宮。",
    "entities": [
      {
        "text": "一二年",
        "label": "TME",
        "start": 22,
        "end": 25
      },
      {
        "text": "建兼領修創京城",
        "label": "LOC",
        "start": 35,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000023",
    "sentence": "四年二月，有詣建告睦王已下八王謀殺建，建囚八王於別宅，放散隨駕殿後軍二萬人，殺捧日都頭李筠。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000024",
    "sentence": "自是天子益微，宿衛之士盡矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000025",
    "sentence": "八月，建以兵圍十六宅，通王以下十一王並遇害於石堤穀，以謀逆聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000026",
    "sentence": "又害太子詹事馬道殷、將作監許岩士，貶宰相朱樸，皆昭宗寵昵者也。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000027",
    "sentence": "建尋兼同州節度使。",
    "entities": [
      {
        "text": "建尋兼同州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000028",
    "sentence": "光化元年，升華州為興德府，以建為尹。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "升華州",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000029",
    "sentence": "八月，車駕還京。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000030",
    "sentence": "九月，冊拜太傅，進封許國公，並賜鐵券。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000031",
    "sentence": "天復元年十一月，宦官韓全誨迫天子幸鳳翔，建亦預其謀。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000032",
    "sentence": "太祖聞之，自河中引軍而西。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000033",
    "sentence": "前鋒至同州，建判官司馬鄴以城降，遂移軍迫華州，建懼乞降。",
    "entities": [
      {
        "text": "前鋒至同州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "遂移軍迫華州",
        "label": "LOC",
        "start": 16,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000034",
    "sentence": "太祖責以脅君之罪，建拜伏稱從事李巨川之謀也，太祖即誅巨川。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000035",
    "sentence": "〈 （《北夢瑣言》：韓建曰：「某不識字，凡朝廷章奏、鄰封書檄，皆巨川為之。」因斬之。《新唐書· 李巨川傳》云：巨川詣軍門納款，因言當世利害。全忠屬官敬翔以文翰事左右，疑巨川用則全忠待己或衰，乃詭說曰：「巨川誠奇才，顧不利主人，若何！」是日，全忠殺之。） 〉 太祖與建素有軍中昆弟之契，及見，其怒驟息，尋表建為許州節度使。",
    "entities": [
      {
        "text": "《北夢瑣言》",
        "label": "TITLE",
        "start": 3,
        "end": 9
      },
      {
        "text": "《新唐書· 李巨川傳》",
        "label": "TITLE",
        "start": 42,
        "end": 53
      },
      {
        "text": "尋表建為許州",
        "label": "LOC",
        "start": 150,
        "end": 156
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000036",
    "sentence": "昭宗東遷，以建為佑國軍節度使、京兆尹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000037",
    "sentence": "車駕至陝，召太祖與建侍宴，宮妓奏樂，何皇后舉觴以賜太祖，建躡足，太祖遽起曰：「臣醉不任。」偽若顛仆即去。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000038",
    "sentence": "建私謂太祖曰：「上與宮人附耳而語，幕下有兵仗聲，恐圖王爾。」天祐三年，改青州節度使。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 32,
        "end": 34
      },
      {
        "text": "改青州",
        "label": "LOC",
        "start": 35,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000039",
    "sentence": "及受禪，征為司徒、平章事，充諸道鹽鐵轉運使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000040",
    "sentence": "開平二年，加侍中，充建昌宮使。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000041",
    "sentence": "三年，郊祀於洛，以建為大禮使。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_015_000042",
    "sentence": "建為上宰，每謁見，時有直言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000043",
    "sentence": "太祖為性剛嚴，群下將迎不暇，待建稍異，故優容之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000044",
    "sentence": "九月，冊拜太保，罷知政事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_015_000045",
    "sentence": "〈 （《五代會要》：開平三年十月，詔曰：太保韓建，每月旦、十五日入閣稱賀，即令赴朝參，餘時弗入見。示優禮也。） 〉 四年三月，除匡國軍節度使、陳許蔡觀察使，仍令中書不議除替。",
    "entities": [
      {
        "text": "《五代會要》",
        "label": "TITLE",
        "start": 3,
