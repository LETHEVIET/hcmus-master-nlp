        "start": 23,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000176",
    "sentence": "保衡舉其城來降，末帝命霍彥威為邠帥，由是邠、寧復為末帝所有。",
    "entities": [
      {
