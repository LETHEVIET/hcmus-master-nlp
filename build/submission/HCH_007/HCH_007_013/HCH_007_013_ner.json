        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000159",
    "sentence": "楊崇本，不知何許人，幼為李茂貞之假子，因冒姓李氏，名繼徽。",
    "entities": [
      {
        "text": "楊崇本",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000160",
    "sentence": "唐光化中，茂貞表為邠州節度使。",
    "entities": [
      {
        "text": "茂貞表為邠州",
        "label": "LOC",
        "start": 5,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000161",
    "sentence": "天復元年冬，太祖自鳳翔移軍北伐，駐旆於邠郊，命諸軍攻其城。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "命諸軍攻其城",
        "label": "LOC",
        "start": 22,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000162",
    "sentence": "崇本懼，出城請降。",
    "entities": [
      {
        "text": "出城",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000163",
    "sentence": "太祖復置為邠州節度使，仍令復其本姓名焉。",
    "entities": [
      {
        "text": "太祖復置為邠州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000164",
    "sentence": "及師還，遷其族於河中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000165",
    "sentence": "其後，太祖因統戎往來由於蒲津，以崇本妻素有姿色，嬖之於別館。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000166",
    "sentence": "其婦素剛烈，私懷愧恥，遣侍者讓崇本曰：「丈夫擁旄仗鉞，不能庇其伉儷，我已為朱公婦，今生無面目對卿，期於刀繩而已。」崇本聞之，但灑淚含怒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000167",
    "sentence": "及昭宗自鳳翔回京，崇本之家得歸邠州。",
    "entities": [
      {
        "text": "本之家得歸邠州",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000168",
    "sentence": "崇本恥其妻見辱，因茲復貳於太祖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000169",
    "sentence": "乃遣使告茂貞曰：「朱氏兆亂，謀危唐祚，父為國家磐石，不可坐觀其禍，宜於此時畢命興復，事苟不濟，死為社稷可也。」茂貞乃遣使會兵於太原。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000170",
    "sentence": "時西川王建亦令大將出師以助之，岐、蜀連兵以攻雍、華，關西大震。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000171",
    "sentence": "太祖遣郴王友裕帥師禦之，會友裕卒於行，乃班師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000172",
    "sentence": "天祐三年冬十月，崇本復領鳳翔、邠、涇、秦、隴之師，會延州胡章之眾，合五六萬，屯於美原，列柵十五，其勢甚盛。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "會延州",
        "label": "LOC",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000173",
    "sentence": "太祖命同州節度使劉知俊及康懷英帥師拒之，崇本大敗，復歸於邠州，自是垂翅久之。",
    "entities": [
      {
        "text": "太祖命同州",
