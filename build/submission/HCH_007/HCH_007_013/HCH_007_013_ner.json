      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000192",
    "sentence": "守光遂兼有滄、景之地，令其子繼威主留務。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000193",
    "sentence": "繼威年幼，未能政事，以萬進佐之，凡關軍政，一皆委任。",
