[
  {
    "sentence_id": "HCH_007_013_000001",
    "sentence": "朱瑄",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000002",
    "sentence": "朱瑄，宋州下邑人也。",
    "entities": [
      {
        "text": "宋州下邑",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000003",
    "sentence": "父慶，里之豪右，以攻剽販鹽為事，吏捕之伏法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000004",
    "sentence": "瑄坐父罪以笞免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000005",
    "sentence": "因入王敬武軍為小校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000006",
    "sentence": "唐中和二年，諫議大夫張浚征兵於青州，敬武遣將曹全晸率軍赴之，以瑄隸焉。",
    "entities": [
      {
        "text": "唐",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "二年",
        "label": "TME",
        "start": 3,
        "end": 5
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "張浚征兵於青州",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000007",
    "sentence": "以戰功累遷列校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000008",
    "sentence": "賊敗出關，全晸以本軍還鎮。",
    "entities": [
      {
        "text": "賊敗出關",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "全晸以本軍還鎮",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000009",
    "sentence": "會鄆帥薛崇卒，部將崔君預據城叛，全晸攻之，殺君預自為留後。",
    "entities": [
      {
        "text": "部將崔君預據城",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000010",
    "sentence": "瑄以功授濮州刺史、鄆州馬步軍都將。",
    "entities": [
      {
        "text": "瑄以功授濮州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "鄆州",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000011",
    "sentence": "光啟初，魏博韓允中攻鄆，全晸為其所害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000012",
    "sentence": "瑄據城自固。",
    "entities": [
      {
        "text": "瑄據城",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000013",
    "sentence": "三軍推為留後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000014",
    "sentence": "允中敗，朝廷以瑄為天平軍節度使，累加官至檢校太尉、同平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000015",
    "sentence": "太祖初鎮大梁，兵威未振，連歲為秦宗權所圍，士不解甲，危殆日數四。",
    "entities": [
      {
        "text": "太祖初鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000016",
    "sentence": "太祖以瑄同宗，早兄事之，乃遣使求援於瑄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000017",
    "sentence": "光啟末，宗權急攻大梁，瑄與弟瑾率兗、鄆之師來援，大敗蔡賊，解圍而遁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000018",
    "sentence": "太祖感其力，厚禮以歸之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000019",
    "sentence": "先是，瑄、瑾駐於大梁，睹太祖軍士驍勇，私心愛之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000020",
    "sentence": "及歸，厚懸金帛於界上以誘焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000021",
    "sentence": "諸軍貪其厚利，私遁者甚眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000022",
    "sentence": "太祖移牒以讓之，瑄來詞不遜，由是始構隙焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000023",
    "sentence": "及秦宗權敗，太祖移軍攻時溥於徐州。",
    "entities": [
      {
        "text": "軍攻時溥於徐州",
        "label": "LOC",
        "start": 9,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000024",
    "sentence": "時瑄方右溥，乃遣使來告太祖曰：「巢、權繼為蛇虺，毒螫中原，與君把臂同盟，輔車相依。今賊已平殄，人粗聊生，吾弟宜念遠圖，不可自相魚肉。或行人之失辭，疆吏之逾法，可以理遣，未得便睽和好。投鼠忌器，弟幸思之。 」太祖方怒時溥通於孫儒，不從其言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000025",
    "sentence": "及龐師古攻徐州，瑄出師來援，太祖深銜之。",
    "entities": [
      {
        "text": "及龐師古攻徐州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000026",
    "sentence": "徐既平，太祖並兵以攻鄆，自景福元年冬遣朱友裕領軍渡濟，至乾寧三年宿軍齊、鄆間，大小凡數十戰，語在《太祖紀》中。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 15,
        "end": 17
      },
      {
        "text": "朱友裕",
        "label": "PER",
        "start": 19,
        "end": 22
      },
      {
        "text": "三年",
        "label": "TME",
        "start": 30,
        "end": 32
      },
      {
        "text": "《太祖紀》",
        "label": "TITLE",
        "start": 48,
        "end": 53
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000027",
    "sentence": "自是野無人耕，屬城悉為我有。",
    "entities": [
      {
        "text": "屬城",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000028",
    "sentence": "瑄乃遣人求救於太原，李克用遣其將李承嗣、史儼等援之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000029",
    "sentence": "尋為羅宏信所扼，援路既絕，瑄、瑾竟敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000030",
    "sentence": "乾寧四年正月，龐師古攻陷鄆州，遁至中都北，匿於民家，為其所箠，並妻榮氏擒之來獻，俱斬於汴橋下。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "龐師古攻陷鄆州",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000031",
    "sentence": "朱瑾",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000032",
    "sentence": "朱瑾，瑄從父弟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000033",
    "sentence": "雄武絕倫，性頗殘忍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000034",
    "sentence": "光啟中，瑾與兗州節度使齊克讓婚，瑾自鄆盛飾車服，私藏兵甲，以赴禮會。",
    "entities": [
      {
        "text": "瑾與兗州",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000035",
    "sentence": "親迎之夜，甲士竊發，擄克讓，自稱留後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000036",
    "sentence": "及蔡賊鴟張，瑾與太祖連衡，同討宗權，前後屢捷，以功正授兗州節度使。",
    "entities": [
      {
        "text": "以功正授兗州",
        "label": "LOC",
        "start": 23,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000037",
    "sentence": "既得士心，有兼並天下之意，太祖亦忌之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000038",
    "sentence": "瑾以厚利招誘太祖軍士，以為間諜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000039",
    "sentence": "及太祖攻鄆，瑾出師來援，累與太祖接戰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000040",
    "sentence": "乾寧二年春，太祖令大將朱友恭攻瑾，掘塹柵以環之。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000041",
    "sentence": "朱瑄遣將賀瑰及蕃將何懷寶赴援，為友恭所擒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000042",
    "sentence": "十一月，瑾從兄齊州刺史瓊以州降。",
    "entities": [
      {
        "text": "瑾從兄齊州",
        "label": "LOC",
        "start": 4,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000043",
    "sentence": "太祖令執賀瑰、懷寶及瓊以徇於城下，語曰：「卿兄已敗，早宜效順。」瑾偽遣牙將瑚兒持書幣送降，太祖自至延壽門外，與瑾交語。",
    "entities": [
      {
        "text": "寶及瓊以徇於城",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000044",
    "sentence": "瑾謂太祖曰：「欲令大將送符印，願得兄瓊來押領，所貴骨肉，盡布腹心也。」太祖遣瓊與客將劉捍取符笥，瑾單馬立於橋上，揮手謂捍曰：「可令兄來，余有密款。」即令瓊往。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000045",
    "sentence": "瑾先令騎士董懷進伏於橋下，及瓊至，懷進突出，擒瓊而入，俄而斬瓊首投於城外，太祖乃班師。",
    "entities": [
      {
        "text": "而斬瓊首投於城",
        "label": "LOC",
        "start": 28,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000046",
    "sentence": "及鄆州陷，龐師古乘勝攻兗，瑾與李承嗣方出兵求芻粟於豐沛間，瑾之二子及大將康懷英、判官辛綰、小校閻寶以城降師古。",
    "entities": [
      {
        "text": "及鄆州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "沛",
        "label": "LOC",
        "start": 26,
        "end": 27
      },
      {
        "text": "康懷英",
        "label": "PER",
        "start": 36,
        "end": 39
      },
      {
        "text": "小校閻寶以城",
        "label": "LOC",
        "start": 45,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000047",
    "sentence": "瑾無歸路，即與承嗣將麾下士將保沂州，刺史尹處賓拒關不納，乃保海州。",
    "entities": [
      {
        "text": "麾下士將保沂州",
        "label": "LOC",
        "start": 10,
        "end": 17
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "乃保海州",
        "label": "LOC",
        "start": 28,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000048",
    "sentence": "為師古所迫，遂擁州民渡淮依楊行密。",
    "entities": [
      {
        "text": "遂擁州",
        "label": "LOC",
        "start": 6,
        "end": 9
      },
      {
        "text": "楊行密",
        "label": "PER",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000049",
    "sentence": "行密表瑾領徐州節度使。",
    "entities": [
      {
        "text": "行密表瑾領徐州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000050",
    "sentence": "龐師古渡淮，行密令瑾率師以禦之，清口之敗，瑾有力焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000051",
    "sentence": "自是瑾率淮軍連歲北寇徐、宿，大為東南之患。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000052",
    "sentence": "及行密卒，子渭繼立，以徐溫子知訓為行軍副使，寵遇頗深。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000053",
    "sentence": "後楊溥僭號，知訓為樞密使，知政事，以瑾為同平章事，仍督親軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000054",
    "sentence": "時徐溫父子恃寵專政，慮瑾不附己。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000055",
    "sentence": "〈 （陳彭年《江南別錄》云：徐知訓初學兵法於朱瑾，瑾悉心教之。後與瑾有隙，夜遣壯士殺瑾，瑾手刃數人，埋於舍後。） 〉 貞明四年六月，出瑾為淮寧軍節度使。",
    "entities": [
      {
        "text": "《江南別錄》",
        "label": "TITLE",
        "start": 6,
        "end": 12
      },
      {
        "text": "徐知訓",
        "label": "PER",
        "start": 14,
        "end": 17
      },
      {
        "text": "四年",
        "label": "TME",
        "start": 61,
        "end": 63
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000056",
    "sentence": "知訓設家宴以餞瑾，瑾事之逾遜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000057",
    "sentence": "翌日，詣知訓第謝，留門久之，知訓家僮私謂瑾曰：「政事相公此夕在白牡丹妓院，侍者無得往。」瑾謂典謁曰：「吾不奈朝饑，且歸。」既而知訓聞之，愕然曰：「晚當過瑾。」瑾厚備供帳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000058",
    "sentence": "瑾有所乘名馬，冬以錦帳貯之，夏以羅幬護之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000059",
    "sentence": "愛妓桃氏，有絕色，善歌舞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000060",
    "sentence": "及知訓至，奉卮酒為壽，初以名馬奉，知訓喜而言曰：「相公出鎮，與吾暫別，離恨可知，願此盡歡。」瑾即延知訓於中堂，出桃氏，酒既醉，瑾斬知訓首，示其部下。",
    "entities": [
      {
        "text": "相公出鎮",
        "label": "LOC",
        "start": 25,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000061",
    "sentence": "因以其眾急趨衙城，知訓之黨已闔門矣，唯瑾得獨入，與衙兵戰。",
    "entities": [
      {
        "text": "以其眾急趨衙城",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000062",
    "sentence": "復逾城而出，傷足，求馬不獲，遂自刎。",
    "entities": [
      {
        "text": "復逾城",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_013_000063",
    "sentence": "暴其屍於市，盛夏無蠅蛆，徐溫令投之於江，部人竊收葬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000064",
    "sentence": "溫疾亟，夢瑾被髮引滿將射之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000065",
    "sentence": "溫乃為之禮葬，立祠以祭之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_013_000066",
    "sentence": "〈 （馬令《南唐書》云：初，宿衛將李球、馬謙挾楊隆演登樓，取庫兵以誅知訓，陣於門橋。知訓與戰，頻卻。朱瑾適自外來，以一騎前視其陣，曰：「不足為也。」因反顧一麾，外兵爭進，遂斬球、謙，亂兵皆潰。瑾嘗有德於知訓者也，及其凶終，吳人皆謂曲在知訓。《五代史補》：瑾之奔淮南也，時行密方圖霸，其為禮待，有加於諸將數等。瑾感行密見知，欲立奇功為報，但憾無入陣馬，忽忽不樂。一日晝寢，夢老叟，眉發皓然，謂謹曰：「君長憾無入陣馬，今馬生矣！」及廄隸報，適退槽馬生一駒，見臥未能起。瑾驚曰：「何應之速也！」行往視之，見骨目皆非常馬，大喜曰：「事辦矣！」其後破杜洪，取鍾傳，未嘗不得力焉。初，瑾之來也，徐溫睹其英烈，深忌之，故瑾不敢預政。及行密死，子溥嗣位，溫與張鎬爭權，襲殺鎬，自是事無大小，皆決於溫。既而溫復為自安之計，乃以子知訓自代，然後引兵出居金陵，實欲控製中外。知訓尤恣橫，瑾居常嫉之。一旦知訓欲得瑾所乘馬，瑾怒，遂擊殺知訓，提其首請溥起兵誅溫。溥素怯懦，見之掩麵而走。瑾曰：「老婢兒不足為計！」亦自殺，中外大駭且懼。溫至，遽以瑾屍暴之市中。時盛暑，肌肉累日不壞，至青蠅無敢輒泊。人有病者，或於暴屍處取土煎而服之，無不愈。） 〉",
