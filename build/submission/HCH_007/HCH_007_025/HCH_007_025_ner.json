        "end": 108
      },
      {
        "text": "隴西郡",
        "label": "LOC",
        "start": 127,
        "end": 130
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000083",
    "sentence": "是時，武皇既收長安，軍勢甚雄，諸侯之師皆畏之。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000084",
    "sentence": "武皇一目微眇，故其時號為「獨眼龍」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000085",
    "sentence": "是月，武皇仗節赴鎮。",
    "entities": [
      {
        "text": "武皇仗節赴鎮",
        "label": "LOC",
        "start": 3,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000086",
    "sentence": "遣使報鄭從讜，請治裝歸朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000087",
    "sentence": "武皇次於郊外，因往赴雁門寧覲獻祖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000088",
    "sentence": "八月，自雁門赴鎮河東，時年二十有八。",
    "entities": [
      {
        "text": "自雁門赴鎮",
        "label": "LOC",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000089",
    "sentence": "十一月，平潞州，表其弟克修為昭義節度使。",
    "entities": [
      {
        "text": "平潞州",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000090",
    "sentence": "潞帥孟方立退保於邢州。",
    "entities": [
      {
        "text": "方立退保於邢州",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000091",
    "sentence": "十二月，許帥田從異、汴帥朱溫、徐帥時溥、陳州刺史趙犨各遣使來告，以巢、蔡合從，凶鋒尚熾，請武皇共力討賊。",
    "entities": [
      {
        "text": "陳州",
        "label": "LOC",
        "start": 20,
        "end": 22
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000092",
    "sentence": "中和四年春，武皇率蕃漢之師五萬，自澤、潞將下天井關；河陽節度使諸葛爽辭以河橋不完，乃屯兵於萬善。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "潞將下天井關",
        "label": "LOC",
        "start": 19,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000093",
    "sentence": "數日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000094",
    "sentence": "移軍自河中南渡，趨汝、洛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000095",
    "sentence": "四月，武皇合徐、汴之師破尚讓於太康，斬獲萬計，進攻賊於西華，賊將黃鄴棄營而遁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000096",
    "sentence": "是夜大雨，巢營中驚亂，乃棄西華之壘，退營陳州北故陽裏。",
    "entities": [
      {
        "text": "退營陳州",
        "label": "LOC",
        "start": 18,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000097",
    "sentence": "五月癸亥，大雨震電，平地水深數尺，賊營為水所漂而潰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000098",
    "sentence": "戊辰，武皇引軍營於中牟，大破賊於王滿渡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000099",
    "sentence": "庚午，巢賊大至，濟汴而北。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000100",
    "sentence": "是夜，復大雨，賊黨驚潰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000101",
    "sentence": "武皇營於鄭州，賊眾分寇汴境。",
    "entities": [
      {
        "text": "武皇營於鄭州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000102",
    "sentence": "武皇渡汴，遇賊將渡而南，半濟擊之，大敗之，臨陣斬賊將李周、王濟安、陽景彪等。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000103",
    "sentence": "是夜，賊大敗，殘眾保於胙縣、冤句。",
    "entities": [
      {
        "text": "殘眾保於胙縣",
        "label": "LOC",
        "start": 7,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000104",
    "sentence": "大軍躡之，黃巢乃攜妻子兄弟千餘人東走，武皇追賊至於曹州。",
    "entities": [
      {
        "text": "皇追賊至於曹州",
        "label": "LOC",
        "start": 20,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000105",
    "sentence": "是月，班師過汴，汴帥迎勞於封禪寺，請武皇休於府第，乃以從官三百人及監軍使陳景思館於上源驛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000106",
    "sentence": "是夜，張樂陳宴席，汴帥自佐饗，出珍幣侑勸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000107",
    "sentence": "武皇酒酣，戲諸侍妓，與汴帥握手，敘破賊事以為樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000108",
    "sentence": "汴帥素忌武皇，乃與其將楊彥洪密謀竊發，彥洪於巷陌連車樹柵，以扼奔竄之路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000109",
    "sentence": "時武皇之從官皆醉，俄而伏兵竄發，來攻傳舍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000110",
    "sentence": "武皇方大醉，噪聲動地，從官十餘人捍賊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000111",
    "sentence": "侍人郭景銖滅燭扶武皇，以茵幕裹之，匿於床下，以水灑麵，徐曰：「汴帥謀害司空！」武皇方張目而起，引弓抗賊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000112",
    "sentence": "有頃，煙火四合，復大雨震電，武皇得從者薛鐵山、賀回鶻等數人而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000113",
    "sentence": "雨水如澍，不辨人物，隨電光登尉氏門，縋城而出，得還本營。",
    "entities": [
      {
        "text": "縋城",
        "label": "LOC",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000114",
    "sentence": "監軍陳景思、大將史敬思並遇害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000115",
    "sentence": "武皇既還營，與劉夫人相向慟哭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000116",
    "sentence": "詰旦，欲勒軍攻汴，夫人曰：「司空比為國家討賊，赴東諸侯之急，雖汴人謀害，自有朝廷論列。若反戈攻城，則曲在我也，人得以為辭。」乃收軍而去，馳檄於汴帥。",
    "entities": [
      {
        "text": "若反戈攻城",
