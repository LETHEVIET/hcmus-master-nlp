      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000147",
    "sentence": "河南尹張全義潛兵夜襲李罕之於河陽，城陷，舉族為全義所擄；罕之逾垣獲免，遂來歸於武皇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000148",
    "sentence": "遣李存孝、薛阿檀、史儼兒、安金俊、安休休將七千騎送罕之至河陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000149",
    "sentence": "汴將丁會、牛存節、葛從周將兵赴援，李存孝率精騎逆戰於溫縣。",
