[
  {
    "sentence_id": "HCH_007_025_000001",
    "sentence": "太祖武皇帝，諱克用，本姓朱耶氏，其先隴右金城人也。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "其先隴右金城",
        "label": "LOC",
        "start": 16,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000002",
    "sentence": "始祖拔野，唐貞觀中為墨離軍使，從太宗討高麗、薛延陁有功，為金方道副都護，因家於瓜州。",
    "entities": [
      {
        "text": "因家於瓜州",
        "label": "LOC",
        "start": 36,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000003",
    "sentence": "太宗平薛延陁諸部，於安西、北庭置都護屬之，分同羅、仆骨之人，置沙陁都督府。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000004",
    "sentence": "蓋北庭有磧曰沙陁，故因以為名焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000005",
    "sentence": "永徽中，以拔野為都督，其後子孫五世相承。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000006",
    "sentence": "曾祖盡忠，貞元中，繼為沙陀府都督。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 6,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000007",
    "sentence": "既而為吐蕃所陷，乃舉其族七千帳徙於甘州。",
    "entities": [
      {
        "text": "七千帳徙於甘州",
        "label": "LOC",
        "start": 12,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000008",
    "sentence": "盡忠尋率部眾三萬東奔，俄而吐蕃追兵大至，盡忠戰歿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000009",
    "sentence": "祖執宜，即盡忠之長子也，收合餘眾，至於靈州，德宗命為陰山府都督。",
    "entities": [
      {
        "text": "至於靈州",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000010",
