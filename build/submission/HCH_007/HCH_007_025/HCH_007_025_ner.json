        "end": 35
      },
      {
        "text": "屯於代州",
        "label": "LOC",
        "start": 36,
        "end": 40
      },
      {
        "text": "與幽州",
        "label": "LOC",
        "start": 41,
        "end": 44
      },
      {
        "text": "赫連鐸同攻蔚州",
        "label": "LOC",
        "start": 48,
        "end": 55
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000042",
    "sentence": "獻祖以一軍禦之，武皇以一軍南抵遮虜城以拒李鈞。",
    "entities": [
      {
        "text": "一軍南抵遮虜城",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000043",
    "sentence": "是冬大雪，弓弩弦折，南軍苦寒，臨戰大敗，奔歸代州，李鈞中流矢而卒。",
    "entities": [
      {
        "text": "奔歸代州",
        "label": "LOC",
        "start": 20,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000044",
    "sentence": "廣明元年春，天子復命元帥李涿率兵數萬屯代州。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "率兵數萬屯代州",
        "label": "LOC",
        "start": 14,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000045",
    "sentence": "武皇令軍使傅文達起兵於蔚州，朔州刺史高文集與薛葛、安慶等部將縛文達送於李涿。",
    "entities": [
      {
        "text": "文達起兵於蔚州",
        "label": "LOC",
        "start": 6,
        "end": 13
      },
      {
        "text": "朔州",
        "label": "LOC",
        "start": 14,
        "end": 16
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000046",
    "sentence": "六月，李涿引大軍攻蔚州，獻祖戰不利，乃率其族奔於達靼部。",
    "entities": [
      {
        "text": "涿引大軍攻蔚州",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000047",
    "sentence": "居數月，吐渾赫連鐸密遣人賂達靼以離間獻祖，既而漸生猜阻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000048",
    "sentence": "武皇知之，每召其豪右射獵於野，或與之百步馳射馬鞭，或以懸針樹葉為的，中之如神，由是部人心伏，不敢竊發。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000049",
    "sentence": "俄而黃巢自江、淮北渡，武皇椎牛釃酒，饗其酋首。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000050",
    "sentence": "酒酣，諭之曰：「予父子為賊臣讒間，報國無由。今聞黃巢北犯江、淮，必為中原之患。一日天子赦宥，有詔征兵，仆與公等向南而定天下，是予心也。人生世間，光景幾何，曷能終老沙堆中哉！公等勉之。」達靼知無留意，皆釋然無間。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000051",
    "sentence": "是歲十一月，黃巢寇潼關，天子令河東監軍陳景思為代北起軍使，收兵破賊。",
    "entities": [
      {
        "text": "黃巢寇潼關",
        "label": "LOC",
        "start": 6,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000052",
    "sentence": "十二月，黃巢犯長安，僖宗幸蜀，陳景思與李友金發沙陁諸部五千騎南赴京師。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000053",
    "sentence": "友金即武皇之族父也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000054",
    "sentence": "〈 （《通鑒》：友金初與高文集並降於李琢，故得與陳景思南赴京師。） 〉",
    "entities": [
      {
        "text": "《通鑒》",
        "label": "TITLE",
        "start": 3,
        "end": 7
      },
      {
        "text": "金",
        "label": "ORG",
        "start": 9,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000055",
    "sentence": "中和元年二月，友金軍至絳州，將渡河，刺史瞿稹謂陳景思曰：「巢賊方盛，不如且還代北，徐圖利害。」四月，友金旋軍雁門，瞿稹至代州，半月之間，募兵三萬，營於崞縣之西。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "友金軍至絳州",
        "label": "LOC",
        "start": 7,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "瞿稹至代州",
        "label": "LOC",
        "start": 57,
        "end": 62
      },
      {
        "text": "營於崞縣",
        "label": "LOC",
        "start": 73,
        "end": 77
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000056",
    "sentence": "其軍皆北邊五部之眾，不閑軍法，瞿正、李友金不能制。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000057",
    "sentence": "友金謂景思曰：「興大眾，成大事，當威名素著，則可以伏人。今軍雖數萬，苟無善帥，進亦無功。吾兄李司徒父子，去歲獲罪於國家，今寄北部，雄武之略，為眾所推。若驃騎急奏召還，代北之人，一麾響應，則妖賊不足平也。」景思然之，促奏行在。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000058",
    "sentence": "天子乃以武皇為雁門節度使，仍令以本軍討賊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000059",
    "sentence": "〈 （《新唐書·王重榮傳》：重榮懼黃巢復振，憂之，與復光計，復光曰：「我世與李克用共憂患，其人忠不顧難，死義如己，若乞師焉，事蔑不濟。」乃遣使者約連和。） 〉 李友金發五百騎齎詔召武皇於達靼，武皇即率達靼諸部萬人趨雁門。",
    "entities": [
      {
        "text": "《新唐書·王重榮傳》",
        "label": "TITLE",
        "start": 3,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000060",
    "sentence": "五月，整兵二萬，南向京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000061",
    "sentence": "太原鄭從讜以兵守石嶺關，武皇乃引軍出他道；至太原城下，會大雨，班師於雁門。",
    "entities": [
      {
        "text": "讜以兵守石嶺關",
        "label": "LOC",
        "start": 4,
        "end": 11
      },
      {
        "text": "至太原城",
        "label": "LOC",
        "start": 21,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000062",
    "sentence": "中和二年八月，獻祖自達靼部率其族歸代州。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "部率其族歸代州",
        "label": "LOC",
        "start": 12,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000063",
    "sentence": "十月，武皇率忻、代、蔚、朔、達靼之軍三萬五千騎赴難於京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000064",
    "sentence": "先移檄太原，鄭從讜拒關不納，武皇以兵擊之，進軍至城下，遣人齎幣馬遺從讜；從讜亦遣人饋武皇貨幣、饔餼、軍器。",
    "entities": [
      {
        "text": "鄭從讜拒關",
        "label": "LOC",
        "start": 6,
        "end": 11
      },
      {
        "text": "進軍至城",
        "label": "LOC",
        "start": 21,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000065",
    "sentence": "武皇南去，自陰地趨晉、絳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000066",
    "sentence": "十二月，武皇至河中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000067",
    "sentence": "中和三年正月，晉國公王鐸承製授武皇東北面行營都統。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000068",
    "sentence": "武皇令其弟克修領前鋒五百騎渡河視賊，黃巢遣將米重威齎重賂及偽詔以賜武皇；武皇納其賂以給諸將，燔其偽詔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000069",
    "sentence": "是時，諸道勤王之師雲集京畿，然以賊勢尚熾，未敢爭鋒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000070",
    "sentence": "及武皇將至，賊帥相謂曰：「鴉兒軍至，當避其鋒。」武皇以兵自夏陽濟河。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000071",
    "sentence": "二月，營於乾坑店。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000072",
    "sentence": "黃巢大將尚讓、林言、王璠、趙璋等引軍十五萬屯於梁田坡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000073",
    "sentence": "翌日，大軍合戰，自午及晡，巢賊大敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000074",
    "sentence": "是夜，賊眾遁據華州。",
    "entities": [
      {
        "text": "賊眾遁據華州",
        "label": "LOC",
        "start": 3,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000075",
    "sentence": "武皇進軍圍之，巢弟黃鄴、黃揆固守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000076",
    "sentence": "三月，尚讓引大軍赴援，武皇率兵萬餘逆戰於零口，巢軍大敗，武皇進軍渭橋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000077",
    "sentence": "翌日，黃揆棄華州而遁。",
    "entities": [
      {
        "text": "黃揆棄華州",
        "label": "LOC",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000078",
    "sentence": "王鐸承製授武皇雁門節度使、檢校尚書左僕射。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000079",
    "sentence": "四月，黃巢燔長安，收其餘眾，東走藍關。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 6,
        "end": 8
      },
      {
        "text": "東走藍關",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000080",
    "sentence": "武皇時收京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_025_000081",
    "sentence": "七月，天子授武皇金紫光祿大夫、檢校左僕射、河東節度使。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000082",
    "sentence": "〈 （《舊唐書·僖宗紀》：五月，製以雁門以北行營節度、忻代蔚朔等州觀察處置等使、檢校尚書左僕射、代州刺史、上柱國、食邑七百戶李克用檢校司空、同平章事兼太原尹、北京留守，充河東節度、管內觀察處置等使。《新唐書·沙陀傳》云：收京師功第一，進同中書門下平章事、隴西郡公。未幾，以克用領河東節度。） 〉",
    "entities": [
      {
        "text": "《舊唐書·僖宗紀》",
        "label": "TITLE",
        "start": 3,
