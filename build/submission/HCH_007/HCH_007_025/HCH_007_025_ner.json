        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000124",
    "sentence": "王處存亦敗燕軍於易州。",
    "entities": [
      {
        "text": "亦敗燕軍於易州",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_025_000125",
    "sentence": "十一月，河中王重榮遣使來乞師，且言邠州朱玫、鳳翔李符將加兵於己。",
    "entities": [
