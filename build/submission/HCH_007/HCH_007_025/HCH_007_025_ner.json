        "end": 33
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 42,
        "end": 44
      },
      {
        "text": "代州",
        "label": "LOC",
        "start": 48,
        "end": 50
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 50,
        "end": 52
      },
      {
        "text": "食邑",
        "label": "LOC",
        "start": 57,
        "end": 59
      },
      {
        "text": "《新唐書·沙陀傳》",
        "label": "TITLE",
