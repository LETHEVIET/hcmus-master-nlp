        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_074_000014",
    "sentence": "王衍自利州奔歸成都，斷吉柏津浮梁，以絕諸軍。",
    "entities": [
      {
        "text": "王衍自利州",
        "label": "LOC",
