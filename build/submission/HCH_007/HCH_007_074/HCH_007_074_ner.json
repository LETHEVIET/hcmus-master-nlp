        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_007_074_000008",
    "sentence": "莊宗屏人問梁兵機，延孝備陳利害，語在《莊宗紀》中。",
    "entities": [
      {
        "text": "《莊宗紀》",
