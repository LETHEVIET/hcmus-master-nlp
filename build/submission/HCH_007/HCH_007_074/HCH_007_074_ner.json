        "text": "郭崇韜",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_007_074_000024",
    "sentence": "時延孝軍於城西，毛璋軍於城東，董璋軍於城中。",
    "entities": [
      {
        "text": "時延孝軍於城",
