[
  {
    "sentence_id": "HCH_007_074_000001",
    "sentence": "康延孝，塞北部落人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_074_000002",
    "sentence": "初隸太原，因得罪，亡命於汴梁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_074_000003",
    "sentence": "開平、乾化中，自隊長積勞至部校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_074_000004",
    "sentence": "梁末帝時，頻立軍功。",
