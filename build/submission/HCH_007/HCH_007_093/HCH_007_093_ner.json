      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000151",
    "sentence": "開運中，自兵部郎中授右諫議大夫，賞筆削之功也。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000152",
    "sentence": "及契丹犯闕，偽旨遣使於晉州率配豪民錢幣，以實行橐。",
    "entities": [
      {
        "text": "偽旨遣使於晉州",
