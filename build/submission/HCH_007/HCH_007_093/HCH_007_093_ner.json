        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000163",
    "sentence": "其子俟服闋與官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_093_000164",
    "sentence": "後又遣兗州節度使李從溫就其舊業，賜牲幣綿帛等物，以旌其忠也。",
