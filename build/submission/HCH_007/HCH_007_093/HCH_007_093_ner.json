[
  {
    "sentence_id": "HCH_007_093_000001",
    "sentence": "盧質",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_093_000002",
    "sentence": "盧質，字子徵，河南人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_093_000003",
    "sentence": "曾祖偲，唐太原府祁縣尉，累贈右僕射。",
    "entities": [
      {
        "text": "唐太原府祁縣",
        "label": "LOC",
        "start": 4,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000004",
    "sentence": "祖衍，唐刑部侍郎、太子賓客，累贈太保。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000005",
    "sentence": "父望，唐尚書司勛郎中，累贈太子少傅。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000006",
    "sentence": "質幼聰慧，善屬文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_093_000007",
    "sentence": "年十六，陜帥王重盈奏授芮城令，能以色養。",
    "entities": [
      {
        "text": "王重盈奏授芮城",
        "label": "LOC",
        "start": 6,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000008",
    "sentence": "又爲同州澄城令，從私便也。",
    "entities": [
      {
        "text": "又爲同州澄城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000009",
    "sentence": "秩滿改秘書郎，丁母憂，歸河南故裏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_093_000010",
    "sentence": "天祐三年，北遊太原，時李襲吉在武皇幕府，以女妻之。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000011",
    "sentence": "武皇憐其才，承制授檢校兵部郎中，充河東節度掌書記，賜緋魚袋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_093_000012",
    "sentence": "武皇厭代，其弟克寧握兵柄，有嗣襲之望，質與張承業等密謀，同立莊宗爲嗣，有翊贊之功。",
    "entities": [
      {
        "text": "張承業",
        "label": "PER",
        "start": 21,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000013",
    "sentence": "及莊宗四征，質皆從行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_093_000014",
    "sentence": "十六年，轉節度判官、檢校禮部尚書。",
    "entities": [
      {
        "text": "十六年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000015",
    "sentence": "十九年，莊宗將即帝位，命爲大禮使，累加至銀青光祿大夫、檢校右僕射。",
    "entities": [
      {
        "text": "十九年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000016",
    "sentence": "二十年，授行臺禮部尚書。",
    "entities": [
      {
        "text": "二十年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000017",
    "sentence": "莊宗既登極，欲相之，質性疏逸，不喜居高位，固辭獲免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_093_000018",
    "sentence": "尋以本官兼太原尹，充北京留守事，未赴任，改戶部尚書、知制誥，充翰林學士承旨。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000019",
    "sentence": "同光元年冬，從平大梁，權判租庸事，逾月隨駕都洛，旋受詔權知汴州軍府事。",
    "entities": [
      {
        "text": "同光元年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "旋受詔權知汴州",
        "label": "LOC",
        "start": 24,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000020",
    "sentence": "時孔謙握利權，志在聚斂，累移文於汴，配民放絲，質堅論之，事雖不行，時論賞之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_093_000021",
    "sentence": "俄又改金紫光祿大夫、兵部尚書、知制誥、翰林學士承旨，仍賜論思匡佐功臣。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000022",
    "sentence": "會覆試進士，質以「後從諫則聖」爲賦題，以「堯、舜、禹、湯傾心求過」爲韻，舊例賦韻四平四側，質所出韻乃五平三側，由是大爲識者所誚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_093_000023",
    "sentence": "天成元年，制授特進、檢校司空、同州節度使。",
    "entities": [
      {
        "text": "天成元年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "同州",
        "label": "LOC",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000024",
    "sentence": "時宰相馮道以詩餞別，其警句云：「視草北來唐學士，擁旄西去漢將軍。」儒者榮之。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000025",
    "sentence": "明年，改賜耀忠匡定保節功臣，就加檢校司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_093_000026",
    "sentence": "三年，入拜兵部尚書，判太僕卿事。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000027",
    "sentence": "四年，進封開國公。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000028",
    "sentence": "長興二年，授檢校太保、河陽節度使，未幾，移鎮滄州，入爲右僕射。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "移鎮滄州",
        "label": "LOC",
        "start": 20,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000029",
    "sentence": "及秦王得罪，奉詔權知河南府事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_093_000030",
    "sentence": "應順初，遷檢校太傅，正拜河南尹，後改太子少師。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000031",
    "sentence": "清泰末，復爲右僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_093_000032",
    "sentence": "高祖登極，質以微恙分司洛宅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_007_093_000033",
    "sentence": "少帝嗣位，拜太子太保。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000034",
    "sentence": "天福七年秋，卒於洛陽，年七十六。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000035",
    "sentence": "累贈太子太師，謚曰文忠。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_007_093_000036",
    "sentence": "〈 （《五代會要》：漢乾祐元年九月，其子尚書兵部員外郎盧瓊上章請謚，下太常議，謚曰文忠。） 〉",
    "entities": [
