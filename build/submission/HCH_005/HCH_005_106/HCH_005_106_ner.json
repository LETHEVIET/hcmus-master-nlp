    ]
  },
  {
    "sentence_id": "HCH_005_106_000146",
    "sentence": "六月壬午，郡國十一大風拔樹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_106_000147",
    "sentence": "是時安帝親讒，曲直不分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_106_000148",
    "sentence": "三年，京都及郡國三十六大風拔樹。",
    "entities": [
      {
