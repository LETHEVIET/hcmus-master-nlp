        "label": "TME",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_106_000158",
    "sentence": "是時靈帝用中常侍曹節等讒言，禁錮海內清英之士，謂之黨人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_106_000159",
    "sentence": "中平二年 七月，三輔螟蟲爲害。",
