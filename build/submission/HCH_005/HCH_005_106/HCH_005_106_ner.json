        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_106_000153",
    "sentence": "獻帝 初平四年 六月，右扶風大風，發屋拔木。",
    "entities": [
