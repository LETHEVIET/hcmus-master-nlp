[
  {
    "sentence_id": "HCH_005_080c_000001",
    "sentence": "張升",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000002",
    "sentence": "張升字彥眞，陳留尉氏人，富平侯放之孫也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000003",
    "sentence": "升少好學，多關覽，而任情不羈。",
    "entities": [
      {
        "text": "多關",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000004",
    "sentence": "其意相合者，則傾身交結，不問窮賤；如乖眞志好者，雖王公大人，終不屈從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000005",
    "sentence": "常嘆曰：「死生有命，富貴在天。其有知我，雖胡越可親；苟不相識，從物何益？」",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000006",
    "sentence": "仕郡爲綱紀，以能出守外黃令。",
    "entities": [
      {
        "text": "仕郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000007",
    "sentence": "吏有受賕者，即論殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000008",
    "sentence": "或譏：「升守領一時，何足趨明威戮乎？」對曰：「昔仲尼暫相，誅齊之侏儒，手足異門而出，故能威震強國，反其侵地。君子仕不爲己，職思其憂，豈以久近而異其度哉？」遇黨錮去官，後竟見誅，年四十九。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000009",
    "sentence": "著賊、誄、頌、碑、書，凡六十篇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000010",
    "sentence": "趙壹",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000011",
    "sentence": "趙壹字元叔，漢陽西縣人也。",
    "entities": [
      {
        "text": "漢陽西縣",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000012",
    "sentence": "體貌魁梧，身長九尺，美須豪眉，望之甚偉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000013",
    "sentence": "而恃才倨傲，爲鄉黨所擯，乃作《解擯》。",
    "entities": [
      {
        "text": "爲鄉",
        "label": "LOC",
        "start": 6,
        "end": 8
      },
      {
        "text": "《解擯》",
        "label": "TITLE",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000014",
    "sentence": "後屢抵罪，幾至死，友人救，得免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000015",
    "sentence": "壹乃貽書謝恩曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000016",
    "sentence": "昔原大夫贖桑下絶氣，傳稱其仁；秦越人還虢太子結脈，世著其神。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000017",
    "sentence": "設曩之二人不遭仁遇神，則結絶之氣竭矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000018",
    "sentence": "然而糒脯出乎車軨，針石運乎手爪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000019",
    "sentence": "今所賴者，非直車軨之糒脯，手爪之針石也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000020",
    "sentence": "乃收之於斗極，還之於司命，使乾皮復含血，枯骨復被肉，允所謂遭仁遇神，眞所宜傳而著之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000021",
    "sentence": "餘畏禁，不敢班班顯言，竊爲《窮鳥賦》一篇。",
    "entities": [
      {
        "text": "《窮鳥賦》",
        "label": "TITLE",
        "start": 13,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000022",
    "sentence": "其辭曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000023",
    "sentence": "有一窮鳥，戢翼原野。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000024",
    "sentence": "畢網加上，機穽在下，前見蒼隼，後見驅者，繳彈張右，羿子彀左，飛丸激矢，交集於我。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000025",
    "sentence": "思飛不得，欲鳴不可，舉頭畏觸，搖足恐墮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000026",
    "sentence": "內獨怖急，乍冰乍火。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000027",
    "sentence": "幸賴大賢，我矜我憐，昔濟我南，今振我西。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000028",
    "sentence": "鳥也雖頑，猶識密思。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000029",
    "sentence": "內以書心，外用告天。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000030",
    "sentence": "天乎祚賢，歸賢永年，且公且侯，子子孫孫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000031",
    "sentence": "又作《刺世疾邪賦》，以舒其怨憤。",
    "entities": [
      {
        "text": "《刺世疾邪賦》",
        "label": "TITLE",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000032",
    "sentence": "曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000033",
    "sentence": "伊五帝之不同禮，三王亦又不同樂，數極自然變化，非是故相反駁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000034",
    "sentence": "德政不能救世混亂，賞罰豈足懲時清濁？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000035",
    "sentence": "春秋時禍敗之始，戰國愈復增其荼毒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000036",
    "sentence": "秦、漢無以相逾越，乃更加其怨酷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000037",
    "sentence": "寧計生民之命，唯利己而自足。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000038",
    "sentence": "於茲迄今，情僞萬方。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000039",
    "sentence": "佞諂日熾，剛克消亡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000040",
    "sentence": "舐痔結駟，正色徒行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000041",
    "sentence": "嫗 𡟥 名勢，撫拍豪強。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000042",
    "sentence": "偃蹇反俗，立致咎殃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000043",
    "sentence": "捷懾逐物，日富月昌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000044",
    "sentence": "渾然同惑，孰温孰凉？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000045",
    "sentence": "邪夫顯進，直士幽藏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000046",
    "sentence": "原斯瘼之攸興，實執政之匪賢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000047",
    "sentence": "女謁掩其視聽兮，近習秉其威權。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000048",
    "sentence": "所好則鑽皮出其毛羽，所惡則洗垢求其瘢痕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000049",
    "sentence": "雖欲謁誠而盡忠，路絶嶮而靡緣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000050",
    "sentence": "九重旣不可啓，又群吠之狺狺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000051",
    "sentence": "安危於於旦夕，肆嗜欲於目前。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000052",
    "sentence": "奚異涉海之失舵，積薪而待燃？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000053",
    "sentence": "榮納由於閃揄，孰知辯其蚩姸？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000054",
    "sentence": "故法禁屈撓干勢族，恩澤不逮於單門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000055",
    "sentence": "寧飢寒於堯、舜之荒歲兮，不飽暖於當今之豐年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000056",
    "sentence": "乘理雖死而非亡，違義雖生而匪存。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000057",
    "sentence": "有秦客者，乃爲詩曰：「河清不可俟，人命不可延。順風激靡草，富貴者稱賢。文籍雖滿腹，不如一囊錢。伊優北堂上，抗臟倚門邊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000058",
    "sentence": "魯生聞此辭，繫而作歌曰：勢家多所宜，咳唾自成珠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000059",
    "sentence": "被褐懷金玉，蘭蕙化爲芻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000060",
    "sentence": "賢者雖獨悟，所困在群愚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000061",
    "sentence": "且各守爾分，勿復空馳驅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000062",
    "sentence": "哀哉復哀哉，此是命矣夫！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000063",
    "sentence": "光和元年 ，舉郡上計，到京師。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "舉郡",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000064",
    "sentence": "是時，司徒袁逢受計，計吏數百人，皆拜伏庭中，莫敢仰視。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000065",
    "sentence": "壹獨長揖而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000066",
    "sentence": "逢望而異之，令左右往讓之，曰：「下郡計吏而揖三公，何也？」對曰：「昔酈食其長揖漢王，今揖三公，何遽怪哉？」逢則斂衽下堂，執其手，延置上坐，因問西方事，大悅，顧謂坐中曰：「此人漢陽趙元叔也。朝臣莫有過之者，吾請爲諸君分坐。」坐者皆屬觀。",
    "entities": [
      {
        "text": "下郡",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000067",
    "sentence": "旣出，往造河南尹羊陟，不得見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000068",
    "sentence": "壹以公卿中非陟無足以託名者，乃日往到門，陟自強許通，尙臥未起。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000069",
    "sentence": "壹徑入上堂，遂前臨之，曰：「竊伏西州，承高風舊矣。乃今方遇而忽然，奈何命也！」因舉聲哭，門下驚，皆奔入滿側。",
    "entities": [
      {
        "text": "竊伏西州",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000070",
    "sentence": "陟知其非常人，乃起，延與語，大奇之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000071",
    "sentence": "謂曰：「子出矣。」陟明旦大從車騎，奉謁造壹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000072",
    "sentence": "時，諸計吏多盛飭車馬帷幕，而壹獨柴車草屛，露宿其傍，延陟前坐於車下，左右莫不嘆愕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000073",
    "sentence": "陟遂與言談，至熏夕，極歡而去，執其手曰：「良璞不剖，必有泣血以相明者矣！」陟乃與袁逢共稱薦之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000074",
    "sentence": "名動京師，士大夫想望其風采。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000075",
    "sentence": "及西還，道經弘農，過侯太守皇甫規，門者不即通，壹遂遁去。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "皇甫規",
        "label": "PER",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000076",
    "sentence": "門吏懼，以白之，規聞壹名大驚，乃追書謝曰：「蹉跌不面，企德懷風，虛心委質，爲日久矣。側聞仁者愍其區區，冀承清誨，以釋遙悚。今旦，外白有一尉兩計吏，不道屈尊門下，更啓乃知已去。如印綬可投，夜豈待旦。惟君明睿，平其夙心。寧當慢慠，加於所天。事在悖惑，不足具責。倘可原察，追修前好，則何福如之！謹遣主簿奉書。下筆氣結，汗流竟趾。」壹報曰：「君學成師範，縉紳歸慕，仰高希驥，歷年滋多。旋轅兼道，渴於言侍，沐浴晨興，昧旦守門，實望仁君，昭其懸遲。以貴下賤，握發垂接。高可敷玩墳典，起發聖意；下則抗論當世，消弭時災。豈悟君子，自生怠倦，失恂恂善誘之德，同亡國驕惰之志！蓋見機而作，不俟終日，是以夙退自引，畏使君勞。昔人或歷説而不遇，或思士而無從，皆歸之於天，不尤於物。今壹自譴而已，豈敢有猜！仁君忽一匹夫，於德何損？而遠辱手筆，追路相尋，誠足愧也。壹之區區，曷云量己？其嗟可去，謝也可食，誠則頑薄，實識其趣。但關節疢動，膝炙壞潰，請俟他日，乃奉其情。輒誦來貺，永以自慰。」遂去不顧。",
    "entities": [
      {
        "text": "但關",
        "label": "LOC",
        "start": 398,
        "end": 400
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000077",
    "sentence": "州郡爭致禮命，十辟公府，幷不就，終於家。",
    "entities": [
      {
        "text": "州郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000078",
    "sentence": "初袁逢使善相者相壹，云「仕不過郡吏」，竟如其言。",
    "entities": [
      {
        "text": "仕不過郡",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000079",
    "sentence": "著賦、頌、箴、誄、書、論及雜文十六篇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000080",
    "sentence": "劉梁",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000081",
    "sentence": "劉梁字曼山，一名岑，東平寧陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000082",
    "sentence": "梁宗室子孫，而少孤貧，賣書於市以自資。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000083",
    "sentence": "常疾世多利交，以邪曲相黨，乃著《破群論》。",
    "entities": [
      {
        "text": "《破群論》",
        "label": "TITLE",
        "start": 15,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000084",
    "sentence": "時之覽者以爲：「仲尼作《 春秋 》，亂臣知懼。今此論之作，俗士豈不愧心！」其文不存。",
    "entities": [
      {
        "text": "《 春秋 》",
        "label": "TITLE",
        "start": 11,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000085",
    "sentence": "又著《辯和同之論》。",
    "entities": [
      {
        "text": "《辯和同之論》",
        "label": "TITLE",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000086",
    "sentence": "其辭曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000087",
    "sentence": "夫事有違而得道，有順而失義，有愛而爲害，有惡而爲美。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000088",
    "sentence": "其故何乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000089",
    "sentence": "蓋明智之所得，暗僞之所失也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000090",
    "sentence": "是以君子之於事也，無適無莫，必考之以義焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000091",
    "sentence": "得由和興，失由同起，故以可濟否謂之和，好惡不殊謂之同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000092",
    "sentence": "《春秋傳》曰：「和如羹焉，酸苦以劑其味，君子食之以平其心。同如水焉，若以水濟水，誰能食之？琴瑟之專一，誰能聽之？」是以君子之行，周而不比，和而不同；以救過爲正，以匡惡爲忠。",
    "entities": [
      {
        "text": "《春秋傳》",
        "label": "TITLE",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000093",
    "sentence": "經曰：「將順其美，匡救其惡，則上下和睦能相親也。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000094",
    "sentence": "昔楚恭王有疾，召其大夫曰：「不穀不德，少主社稷。失先君之緒，覆楚國之師，不穀之罪也。若以宗廟之靈，得保首領以歿，請爲靈若厲。」大夫許諸。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "楚國",
        "label": "ORG",
        "start": 31,
        "end": 33
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 63,
        "end": 65
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000095",
    "sentence": "及其卒也，子囊曰：「不然。夫事君者，從其善，不從其過。赫赫楚國，而君臨之，撫正南海，訓及諸夏，其寵大矣。有是寵也，而知其過，可不謂恭乎！」大夫眾之。",
    "entities": [
      {
        "text": "楚國",
        "label": "ORG",
        "start": 29,
        "end": 31
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 69,
        "end": 71
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000096",
    "sentence": "此諱而得道者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000097",
    "sentence": "及靈王驕淫，暴虐無度，芋尹申亥從王之欲，以殯於乾溪，殉之二女。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000098",
    "sentence": "此順而失義者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000099",
    "sentence": "鄢陵之役，晉楚對戰，陽穀獻酒，子反以斃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000100",
    "sentence": "此愛而害之者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000101",
    "sentence": "臧武仲曰：「孟孫之惡我，藥石也；季孫之愛我，美疢也。疢毒滋厚，石猶生我。」此惡而爲美者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000102",
    "sentence": "孔子曰：「智之難也！有臧武仲之智，而不容於魯國，抑有由也。作不順而施不恕也。」蓋善其知義，譏其違道也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000103",
    "sentence": "夫知而違之，僞也；不知而失之，暗也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000104",
    "sentence": "暗爲僞焉，其患一也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000105",
    "sentence": "患之所在，非徒在智之不及，又在及而違這者矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000106",
    "sentence": "故曰「智及之，仁不能守之，雖得之，必失之」也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000107",
    "sentence": "《夏書》曰：「念茲在茲，庶事恕施。」忠智之謂矣。",
    "entities": [
      {
        "text": "《夏書》",
        "label": "TITLE",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000108",
    "sentence": "故君子之行，動則思義，不爲利回，不爲義疚，進退周旋，唯道是務。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000109",
    "sentence": "苟失其道，則兄弟不阿；苟得其義，雖仇讎不廢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000110",
    "sentence": "故解狐蒙祁奚之薦，二叔被周公之害，勃鞮以逆文爲成，傅瑕以順厲爲敗，管蘇以憎忤取進，申侯以愛從見退：考之以義也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000111",
    "sentence": "故曰：「不在逆順，以義爲斷；不在憎愛，以道爲貴。」《禮記》曰：「愛而知其惡，憎而知其善。」考義之謂也。",
    "entities": [
      {
        "text": "《禮記》",
        "label": "TITLE",
        "start": 25,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000112",
    "sentence": "桓帝時，舉孝廉，除北新城長。",
    "entities": [
      {
        "text": "除北新城",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000113",
    "sentence": "告縣人曰：「昔文翁在蜀，道著巴漢；庚桑瑣隸，風移碨磥。吾雖小宰，猶有社稷，苟赴期會，理文墨，豈本志乎！」乃更大作講舍，延聚生徙數百人，朝夕自往勸誡，身執經卷，試策殿最，儒化大行。",
    "entities": [
      {
        "text": "告縣",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000114",
    "sentence": "此邑至後猶稱其教焉。",
    "entities": [
      {
        "text": "此邑",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000115",
    "sentence": "特召入拜尙書郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000116",
    "sentence": "累遷，後爲野王令，未行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000117",
    "sentence": "光和中，病卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000118",
    "sentence": "孫楨，亦以文才知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000119",
    "sentence": "邊讓",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000120",
    "sentence": "邊讓字文禮，除留浚儀人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000121",
    "sentence": "少辯博，能屬文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000122",
    "sentence": "作《章華賦》，雖多淫麗之辭，而終之以正，亦如相如之諷也。",
    "entities": [
      {
        "text": "《章華賦》",
        "label": "TITLE",
        "start": 1,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000123",
    "sentence": "其辭曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000124",
    "sentence": "楚靈王旣遊雲夢之澤，息於荆臺之上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000125",
    "sentence": "前方淮之水，左洞庭之波，右顧彭蠡之隩，南眺巫山之阿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000126",
    "sentence": "延目廣望，聘觀終日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000127",
    "sentence": "顧謂左史倚相曰：「盛哉斯樂，可以遺老而忘死也！」於是遂作章華之臺，築乾谿之室，窮木土之技，單珍府之實。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000128",
    "sentence": "舉國營之，數年乃成。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000129",
    "sentence": "設長夜之淫宴，作北裏之新聲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000130",
    "sentence": "於是伍舉知夫陳、蔡之將生謀也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000131",
    "sentence": "乃作斯賦以諷之：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000132",
    "sentence": "胄高陽之苗胤兮，承聖祖之洪澤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000133",
    "sentence": "建列籓於南楚兮，等威靈於二伯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000134",
    "sentence": "超有商之大彭兮，越隆周之兩虢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000135",
    "sentence": "達皇佐之高勛兮，馳仁聲之顯赫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000136",
    "sentence": "惠風春施，神武電斷，華夏肅清，五服攸亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000137",
    "sentence": "旦垂精於萬機兮，夕回輦於門館。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000138",
    "sentence": "設長夜之歡飲兮，展中情之嬿婉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000139",
    "sentence": "竭四海之妙珍兮，盡生人之秘玩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000140",
    "sentence": "爾乃攜窈窕，從好仇，徑肉林，登糟丘，蘭肴山竦，椒酒淵流。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000141",
    "sentence": "激玄醴於清池兮，靡微風而行舟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000142",
    "sentence": "登瑤臺以回望兮，冀彌日而消憂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000143",
    "sentence": "於是招宓妃，命湘娥，齊倡列，鄭女羅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000144",
    "sentence": "揚《激楚》之清宮兮，展新聲而長歌。",
    "entities": [
      {
        "text": "《激楚》",
        "label": "TITLE",
        "start": 1,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000145",
    "sentence": "繁手超於北裏，妙舞麗於《陽阿》。",
    "entities": [
      {
        "text": "《陽阿》",
        "label": "TITLE",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000146",
    "sentence": "金石類聚，絲竹群分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000147",
    "sentence": "神輕袿，曳華文，羅衣飄颻，組綺繽紛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000148",
    "sentence": "縱輕軀以迅赴，若孤鵠之失群；振華袂以逶迤，若遊龍之登雲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000149",
    "sentence": "於是歡嬿旣洽，長夜向半，琴瑟易調，繁手改彈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000150",
    "sentence": "清聲發而響激，微音逝而流散。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000151",
    "sentence": "振弱支而紆繞兮，若綠繁之垂干；忽飄颻以輕逝兮，似鸞飛於天漢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000152",
    "sentence": "舞無常態，鼓無定節，尋聲響應，修短靡跌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000153",
    "sentence": "長袖奮而生風，清氣激而繞結。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000154",
    "sentence": "爾乃姸媚遞進，巧弄相加，俯仰異容，忽兮神化。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000155",
    "sentence": "體迅輕鴻，榮曜春華，進如浮雲，退如激波。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000156",
    "sentence": "雖復柳惠，能不咨嗟！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000157",
    "sentence": "於是天河旣回，淫樂未終，清籥發徵，《激楚》揚風。",
    "entities": [
      {
        "text": "《激楚》",
        "label": "TITLE",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000158",
    "sentence": "於是音氣發於絲竹兮，飛響軼於雲中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000159",
    "sentence": "比目應節而雙躍兮，孤雌感聲而鳴雄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000160",
    "sentence": "美繁手之輕妙兮，嘉新聲之彌隆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000161",
    "sentence": "於是眾變已盡，群樂旣考。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000162",
    "sentence": "歸乎生風之廣夏兮，修黃軒之要道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000163",
    "sentence": "攜西子之弱腕兮，援毛嬪之素肘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000164",
    "sentence": "形便娟以嬋媛兮，若流風之靡草。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000165",
    "sentence": "美儀操之姣麗兮，忽遺生而忘老。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000166",
    "sentence": "爾乃清夜晨，妙技單，收尊俎，徹鼓盤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000167",
    "sentence": "惘焉若酲，撫劍而嘆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000168",
    "sentence": "慮理國之須才，悟稼穡之艱難。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000169",
    "sentence": "美呂尙之佐周，善管仲之輔桓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000170",
    "sentence": "將超世而作理，焉沈湎於此歡！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000171",
    "sentence": "於是罷女樂，墮瑤臺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000172",
    "sentence": "思夏禹之卑官，慕有虞之土階。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000173",
    "sentence": "舉英奇於仄陋，拔髦秀於蓬萊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000174",
    "sentence": "君明哲以知人，官隨任而處能。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000175",
    "sentence": "百揆時敍，庶績咸熙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000176",
    "sentence": "諸侯慕義，不召同期。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000177",
    "sentence": "繼高陽之絶軌，崇成、莊之洪基。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000178",
    "sentence": "雖齊醒之一匡，豈足方於大持？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000179",
    "sentence": "爾乃育之以仁，臨之以明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000180",
    "sentence": "致虔報於鬼神，盡肅恭乎上京。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000181",
    "sentence": "馳淳化於黎元，永歷世而太平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000182",
    "sentence": "大將軍何進聞讓才名，欲辟命之。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000183",
    "sentence": "恐不至，詭以軍事徵召。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000184",
    "sentence": "旣到，署令史，進以禮見之。",
    "entities": [
      {
        "text": "令史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000185",
    "sentence": "讓善占射，能辭對。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000186",
    "sentence": "時，賓客滿堂，莫不羨其風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000187",
    "sentence": "府掾孔融、王朗幷修刺候焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000188",
    "sentence": "議郎蔡邕深敬之，以爲讓宜處高任，乃薦於何進曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000189",
    "sentence": "伏惟幕府初開，博選清英，華髮舊德，幷爲元鬼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000190",
    "sentence": "雖振鷺之集西雍，濟濟之在周庭，無以或加。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000191",
    "sentence": "竊見令史陳留邊讓，天授逸才，聰明賢智。",
    "entities": [
      {
        "text": "令史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000192",
    "sentence": "髫齓夙孤，不盡家訓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000193",
    "sentence": "及就學廬，便受大典。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000194",
    "sentence": "初涉諸經，見本知義。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000195",
    "sentence": "授者不能對其問，章句不能逮其意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000196",
    "sentence": "心通性達，口辯辭長。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000197",
    "sentence": "非禮不動，非法不言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000198",
    "sentence": "若處狐疑之論，定嫌審之分，經典交至，撿括參合，眾夫寂焉，莫之能奪也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000199",
    "sentence": "使讓生在唐、虞，則元、凱之次，運値仲尼，則顔、冉之亞，豈徒俗之凡偶近器而已者哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000200",
    "sentence": "階級名位，亦宜超然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000201",
    "sentence": "若復隨輩而進，非所以章瑰偉之高價，昭知人之絶明也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000202",
    "sentence": "傳曰：「函牛之鼎以亨雞，多汁則淡而不可食，少計則熬而不可熟。」此言大器之於小用，固有所不宜也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000203",
    "sentence": "邕竊悁邑，怪此寶鼎未受犧牛大羹之和，久在煎熬臠割之間。",
    "entities": [
      {
        "text": "邕竊悁邑",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000204",
    "sentence": "願明將軍回謀垂慮，裁加少納，貢之機密，展之力用。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000205",
    "sentence": "若以年齒爲嫌，則顔回不得貫德行之首，子奇終無理阿之功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000206",
    "sentence": "苟堪其事，古今一也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000207",
    "sentence": "讓後以高才擢進，屢遷，出爲九江太守，不以爲能也。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000208",
    "sentence": "初平中，王室大亂，讓去官還家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000209",
    "sentence": "恃才氣，不屈曹操，多輕侮之言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000210",
    "sentence": "建安中，其鄉人有構讓於操，操告郡就殺之。",
    "entities": [
      {
        "text": "其鄉",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "操告郡",
        "label": "LOC",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000211",
    "sentence": "文多遺失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000212",
    "sentence": "酈炎",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000213",
    "sentence": "酈炎字文勝，范陽人，酈食其之後也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000214",
    "sentence": "炎有文才，解音律，言論給捷，多服其能理。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000215",
    "sentence": "靈帝時，州郡辟命，皆不就，有志氣。",
    "entities": [
      {
        "text": "州郡",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000216",
    "sentence": "作詩二篇曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000217",
    "sentence": "大道夷且長，窘路狹且促。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000218",
    "sentence": "修冀無卑栖，遠趾不步局。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000219",
    "sentence": "舒吾陵霄羽，奮此千里足。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000220",
    "sentence": "超邁絶塵驅，倏忽誰能逐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000221",
    "sentence": "賢愚豈常類，稟性在清濁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000222",
    "sentence": "富貴有人籍，貧賤無天錄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000223",
    "sentence": "通塞苟由已，志士不相卜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000224",
    "sentence": "陳平敖里社，韓信釣河曲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000225",
    "sentence": "終居天下宰，食此萬鍾祿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000226",
    "sentence": "德音流千載，功名重山岳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000227",
    "sentence": "靈芝生河洲，動搖因洪波。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000228",
    "sentence": "蘭榮一何晚，嚴霜瘁其柯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000229",
    "sentence": "哀哉二芳草，不植太山阿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000230",
    "sentence": "文質道所貴，遭時用有嘉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000231",
    "sentence": "絳、灌臨衡宰，謂誼崇浮華。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000232",
    "sentence": "賢才抑不用，遠投荆南沙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000233",
    "sentence": "抱玉乘龍驥，不逢樂與和。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000234",
    "sentence": "安得孔仲尼，爲世陳四科。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000235",
    "sentence": "炎後風病慌忽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000236",
    "sentence": "性至孝，遭母憂，病甚發動。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000237",
    "sentence": "妻始産而驚死，妻家訟之，收繫獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000238",
    "sentence": "炎病不能理對，嘉平六年，遂死獄中，時年二十八。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000239",
    "sentence": "尙書盧植爲之誄贊，以昭其懿德。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000240",
    "sentence": "侯瑾",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000241",
    "sentence": "侯瑾字子瑜，敦煌人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000242",
    "sentence": "少孤貧，依宗人居。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000243",
    "sentence": "性篤學，恆傭作爲資，暮還輒燃柴以讀書。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000244",
    "sentence": "常以禮自牧，獨處一房，如對嚴賓焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000245",
    "sentence": "州郡累召，公車有道徵，幷稱疾不到。",
    "entities": [
      {
        "text": "州郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000246",
    "sentence": "作《矯世論》以譏切當時，而徙入山中，覃思著述。",
    "entities": [
      {
        "text": "《矯世論》",
        "label": "TITLE",
        "start": 1,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000247",
    "sentence": "以莫知於世，故作《應賓難》以自寄。",
    "entities": [
      {
        "text": "《應賓難》",
        "label": "TITLE",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000248",
    "sentence": "又案《漢記》撰中興以後行事，爲《皇德傳》三十篇，行於世。",
    "entities": [
      {
        "text": "《漢記》",
        "label": "TITLE",
        "start": 2,
        "end": 6
      },
      {
        "text": "《皇德傳》",
        "label": "TITLE",
        "start": 15,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000249",
    "sentence": "餘所作雜文數十篇，多亡失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000250",
    "sentence": "河西人敬其才而不敢名之，皆稱爲侯君雲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000251",
    "sentence": "高彪",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000252",
    "sentence": "高彪字義方，吳郡無錫人也。",
    "entities": [
      {
        "text": "吳郡",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000253",
    "sentence": "家本單寒，至彪爲諸生，遊太學。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000254",
    "sentence": "有雅才而訥於言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000255",
    "sentence": "嘗從馬融欲訪大義，融疾，不獲見，乃復剌遺融書曰：「承服風問，從來有年，故不待介者而謁大君子之門，冀一見龍光，以敍腹心之願。不圖遭疾，幽閉莫啓。昔周公旦父文兄武，九命作伯，以尹華夏，猶揮沐吐餐，垂接白屋，故周道以隆，天下歸德。公今養疴傲士，故其宜也。」融省書慚，追謝還之，彪逝而不顧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000256",
    "sentence": "後郡舉孝廉，試經第一。",
    "entities": [
      {
        "text": "後郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000257",
    "sentence": "除郎中，校書東觀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000258",
    "sentence": "數奏賦、頌、奇文，因事諷諫，靈帝異之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000259",
    "sentence": "時，京兆第五永爲督軍御史，使督幽州。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "使督幽州",
        "label": "LOC",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000260",
    "sentence": "百官大會，祖餞於長樂觀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000261",
    "sentence": "議郎葵邑等皆賦詩，彪乃獨作箴曰：「文武將墜，乃俾俊臣。整我皇綱，董此不虔。古之君子，即戎忘身。明其果毅，尙其桓桓。呂尙七十，氣冠三軍，詩人作歌，如鷹如鸇。天有太一，五將三門；地有九變，丘陵山川；人有計策，六奇五間。總茲三事，謀則咨詢。無曰己能，務在求賢，淮陰之勇，廣野是尊。周公大聖，石碏純臣，以威克愛，以義滅親。勿謂時險，不正其身。勿謂無人，莫識己眞。忘富遺貴，福祿乃存。枉道依合，復無所觀。先公高節，越可永遵。佩藏斯戒，以厲終身。」邕等甚美其文，以爲莫尙也。",
    "entities": [
      {
        "text": "議郎葵邑",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "明",
        "label": "ORG",
        "start": 47,
        "end": 48
      },
      {
        "text": "周",
        "label": "ORG",
        "start": 137,
        "end": 138
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000262",
    "sentence": "後遷外黃令，帝敕同僚臨送，祖於上東門，詔東觀畫彪像以勸學者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000263",
    "sentence": "彪到官，有德政，上書薦縣人申徒蟠等。",
    "entities": [
      {
        "text": "上書薦縣",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000264",
    "sentence": "病卒於官，文章多亡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000265",
    "sentence": "子岱，亦知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000266",
    "sentence": "張超",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000267",
    "sentence": "張超字子幷，河間鄚人也，留侯良之後也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000268",
    "sentence": "有文才。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000269",
    "sentence": "靈帝時，從車騎將軍朱雋徵黃巾，爲別部司馬。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000270",
    "sentence": "著賦、頌、碑文、薦、檄、箋、書、謁文、嘲，凡十九篇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000271",
    "sentence": "超又善於草書，妙絶時人，世共傳之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000272",
    "sentence": "禰衡",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000273",
    "sentence": "禰衡字正平，平原般人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000274",
    "sentence": "少有才辯，而尙氣剛傲，好矯時慢物。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000275",
    "sentence": "興平中，避難荆州。",
    "entities": [
      {
        "text": "避難荆州",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000276",
    "sentence": "建安初，來遊許下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000277",
    "sentence": "始達潁川，乃陰懷一剌，旣而無所之適，至於刺字漫滅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000278",
    "sentence": "是時，許都新建，賢士大夫，四方來集。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000279",
    "sentence": "或問衡曰：「盍從陳長文、司馬伯達乎？」對曰：「吾焉能從屠沽兒耶！」又問：「荀文若、趙稚長云何？」衡曰：「文若可借面弔喪，稚長可使監廚請客。」唯善魯國孔融及弘農楊脩。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000280",
    "sentence": "常稱曰：「大兒孔文舉，小兒楊德祖。餘子碌碌，莫足數也。」融亦深愛其才。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000281",
    "sentence": "衡始弱冠，而融年四十，遂與爲交友。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000282",
    "sentence": "上疏薦之曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000283",
    "sentence": "臣聞洪水橫流，帝思俾乂，旁求四方，以招賢俊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000284",
    "sentence": "昔孝武繼統，將弘祖業，疇咨熙載，群士響臻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000285",
    "sentence": "陛下睿聖，纂承基緒，遭遇厄運，勞謙日昃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000286",
    "sentence": "惟岳降神，異人幷出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000287",
    "sentence": "竊見處士平原禰衡，年二十四，字正平，淑質貞亮，英才卓礫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000288",
    "sentence": "初涉藝文，昇堂睹奧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000289",
    "sentence": "目所一見，輒誦於口；耳所瞥聞，不忘於心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000290",
    "sentence": "性與道合，思若有神。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000291",
    "sentence": "弘羊潛計，安世默識，以衡準之，誠不足怪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000292",
    "sentence": "忠果正直，志懷霜雪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000293",
    "sentence": "見善若驚，疾惡若仇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000294",
    "sentence": "任座抗行，史魚厲節，殆無以過也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000295",
    "sentence": "鷙鳥累伯，不如一鶚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000296",
    "sentence": "使衡立朝，必有可觀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000297",
    "sentence": "飛辯騁辭，溢氣坌涌，解疑釋結，臨敵有餘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000298",
    "sentence": "昔賈誼求試屬國，詭繫單於；終軍欲以長纓，牽致勁越。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000299",
    "sentence": "弱冠慷慨，前世美之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000300",
    "sentence": "近日路粹、嚴象，亦用異才，擢拜臺郎，衡宜與爲比。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000301",
    "sentence": "如得龍躍天衢，振翼雲漢，揚聲紫微，垂光虹蜺，足以昭近署之多士，增四門之穆穆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000302",
    "sentence": "鈞天廣樂，必有奇麗之觀；帝室皇居，必蓄非常之寶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000303",
    "sentence": "若衡等輩，不可多得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000304",
    "sentence": "《激楚》、《楊阿》，至妙之容，臺牧者之所貪；飛兔、騕褭，絶足奔放，良、樂之所急。",
    "entities": [
      {
        "text": "《激楚》",
        "label": "TITLE",
        "start": 0,
        "end": 4
      },
      {
        "text": "《楊阿》",
        "label": "TITLE",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000305",
    "sentence": "臣等區區，敢不以聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000306",
    "sentence": "融旣愛衡才，數稱述於曹操。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000307",
    "sentence": "操欲見之，而衡素相輕疾，自稱狂病，不肯往，而數有恣言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000308",
    "sentence": "操懷忿，而以其才名，不欲殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000309",
    "sentence": "聞衡善擊鼓，乃召爲鼓史，因大會賓客，閲試音節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000310",
    "sentence": "諸史過者，皆令脫其故衣，更著岑牟、單絞之服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000311",
    "sentence": "次至衡，衡方爲《漁陽》參撾，蹀 𨄌 而前，容態有異，聲節悲壯，聽者莫不慷慨。",
    "entities": [
      {
        "text": "《漁陽》",
        "label": "TITLE",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000312",
    "sentence": "衡進至操前而止，吏呵之曰：「鼓史何不改裝，而輕敢進乎？」衡曰：「諾。」於是先解衵衣，次釋餘服，裸身而立，徐取岑牟、單絞而著之，畢，復參撾而去，顔色不怍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000313",
    "sentence": "操笑曰：「本欲辱衡，衡反辱孤。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000314",
    "sentence": "孔融退而數之曰：「正平大雅，固當爾邪？」因宣操區區之意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000315",
    "sentence": "衡許往。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000316",
    "sentence": "融復見操，説衡狂疾，今求得自謝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000317",
    "sentence": "操喜，敕門者有客便通，待之極晏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000318",
    "sentence": "衡乃著布單衣、疏巾，手持三尺梲杖，坐大營門，以杖捶地大駡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000319",
    "sentence": "吏曰：「外有狂生，坐於營門，言語悖逆，請收案罪。」操怒，謂融曰：「禰衡竪子，孤殺之猶雀鼠耳。顧此人素有虛名，遠近將謂孤不能容之，今送與劉表，視當何如。」於是遣人騎送之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000320",
    "sentence": "臨發，眾人爲之祖道，先供設於城南，乃更相戒曰：「禰衡勃虐無禮，今因其後到，咸當以不起折之也。」及衡至，眾人莫肯興，衡坐而大號。",
    "entities": [
      {
        "text": "先供設於城",
        "label": "LOC",
        "start": 10,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000321",
    "sentence": "眾問其故，衡曰：「坐者爲冢，臥者爲屍。屍冢之間，能不悲乎！」",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000322",
    "sentence": "劉表及荆州士大夫，先服其才名，甚賓禮之，文章言議，非衡不定。",
    "entities": [
      {
        "text": "劉表及荆州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000323",
    "sentence": "表嘗與諸文人共草章奏，幷極其才思。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000324",
    "sentence": "時衡出，還見之，開省未周，因毁以抵地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000325",
    "sentence": "表憮然爲駭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000326",
    "sentence": "衡乃從求筆札，須臾立成，辭義可觀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000327",
    "sentence": "表大悅，益重之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000328",
    "sentence": "後復侮慢於表，表恥，不能容，以江夏太守黃祖性急，故送衡與之，祖亦善待焉。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000329",
    "sentence": "衡爲作書記，輕重疏密，各得體宜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000330",
    "sentence": "祖持其手曰：「處士，此正得祖意，如祖腹中之所欲言也。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000331",
    "sentence": "祖長子射，爲章陵太守，尤善於衡。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080c_000332",
    "sentence": "嘗與衡俱遊，共讀蔡邕所作碑文，射愛其辭，還恨不繕寫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000333",
    "sentence": "衡曰：「吾雖一覽，猶能識之，唯其中石缺二字，爲不明耳。」因書出之，躬馳使寫碑，還校，如衡所書，莫不嘆伏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000334",
    "sentence": "射時大會賓客，人有獻鸚鵡者，射舉巵於衡曰：「願先生賦之，以娛嘉賓。」衡攬筆而作，文無加點，辭采甚麗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000335",
    "sentence": "後黃祖在蒙衝船上，大會賓客，而衡言不遜順，祖慚，乃呵之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000336",
    "sentence": "衡更熟視曰：「死公！云等道？」祖大怒，令五百將出，欲加箠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000337",
    "sentence": "衡方大駡，祖恚，遂令殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000338",
    "sentence": "祖主簿素疾衡，即時殺焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000339",
    "sentence": "射徒跣來救，不及。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000340",
    "sentence": "祖亦悔之，乃厚加棺斂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000341",
    "sentence": "衡時年二十六，其文章多亡雲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000342",
    "sentence": "贊",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000343",
    "sentence": "贊曰：情志旣動，篇辭爲貴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000344",
    "sentence": "抽心呈貌，非雕非蔚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000345",
    "sentence": "殊狀共體，同聲異氣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080c_000346",
    "sentence": "言觀麗則，永監淫費。",
    "entities": []
  }
]
