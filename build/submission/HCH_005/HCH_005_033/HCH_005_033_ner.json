    ]
  },
  {
    "sentence_id": "HCH_005_033_000134",
    "sentence": "柱卒，子定嗣，官至羽林中郎將。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000135",
    "sentence": "定卒，無子，國除。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000136",
    "sentence": "定弟石，襲母公主封獲嘉侯，亦為侍中，稍遷衛尉。",
    "entities": [
      {
        "text": "公主",
