        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000126",
    "sentence": "魴性矜嚴公正，在位數進忠言，多見納用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000127",
    "sentence": "十四年，詔復爵士。",
    "entities": [
      {
        "text": "十四年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000128",
    "sentence": "明年，東巡郡國，留魴宿衛南宮。",
    "entities": [
      {
        "text": "東巡郡",
        "label": "LOC",
        "start": 3,
