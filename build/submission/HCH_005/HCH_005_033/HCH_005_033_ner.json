[
  {
    "sentence_id": "HCH_005_033_000001",
    "sentence": "朱浮",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000002",
    "sentence": "朱浮字叔元，沛國蕭人也。",
    "entities": [
      {
        "text": "沛",
        "label": "LOC",
        "start": 6,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000003",
    "sentence": "初從光武為大司馬主簿，遷偏將軍，從破邯鄲。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000004",
    "sentence": "光武遣吳漢誅更始幽州牧苗曾，乃拜浮為大將軍幽州牧，守薊城，遂討定北邊。",
    "entities": [
      {
        "text": "吳漢誅更始幽州",
        "label": "LOC",
        "start": 3,
        "end": 10
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 18,
        "end": 21
      },
      {
        "text": "守薊城",
        "label": "LOC",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000005",
    "sentence": "建武二年，封舞陽侯，食三縣。",
    "entities": [
      {
        "text": "建武二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "食三縣",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000006",
    "sentence": "浮年少有才能，頗欲厲風跡，收士心，辟召州中名宿涿郡王岑之屬，以為從事，及王莽時故吏二千石，皆引置幕府，乃多發諸郡倉谷，稟贍其妻子。",
    "entities": [
      {
        "text": "辟召州",
        "label": "LOC",
        "start": 17,
        "end": 20
      },
      {
        "text": "中名宿涿郡",
        "label": "LOC",
        "start": 20,
        "end": 25
      },
      {
        "text": "乃多發諸郡",
        "label": "LOC",
        "start": 51,
        "end": 56
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000007",
    "sentence": "漁陽太守彭寵以為天下未定，師旅方起，不宜多置官屬，以損軍實，不從其實。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000008",
    "sentence": "浮性矜急自多，頗有不平，因以峻文詆，寵亦很強，歉負其功，嫌怨轉積。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000009",
    "sentence": "浮密奏寵遣吏迎妻而不迎其母，又受貨賄，殺害友人，多聚兵谷，意計難量。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000010",
    "sentence": "寵既積怨，聞之，遂大怒，而舉兵攻浮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000011",
    "sentence": "浮以書質責之曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000012",
    "sentence": "蓋聞知者順時而謀，愚者逆理而動，常竊悲京城太叔以不知足而無賢輔，卒自棄於鄭也。",
    "entities": [
      {
        "text": "常竊悲京城",
        "label": "LOC",
        "start": 16,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000013",
    "sentence": "伯通以名字典郡，有佐命之功，臨人親職，愛惜倉庫，而浮秉征伐之任，欲權時救急，二者皆為國耳。",
    "entities": [
      {
        "text": "伯通以名字典郡",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000014",
    "sentence": "即疑浮相譖，何不詣闕自陳，而為族滅之計乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000015",
    "sentence": "朝廷之於伯通，恩亦厚矣，委以大郡，任以威武，事有柱石之寄，情同子孫之親。",
    "entities": [
      {
        "text": "委以大郡",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000016",
    "sentence": "匹夫媵母尚能致命一餐，豈有身帶三綬，職典大邦，而不顧恩義，生心外畔者乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000017",
    "sentence": "伯通與吏人語，何以為顏？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000018",
    "sentence": "行步拜起，何以為容？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000019",
    "sentence": "坐臥念之，何以為心？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000020",
    "sentence": "引鏡窺影，何施眉目？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000021",
    "sentence": "舉措建功，何以為人？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000022",
    "sentence": "惜乎棄休令之嘉名，造梟鴟之逆謀，捐傳世之慶祚，招破敗之重災，高論堯、舜之道，不忍桀、紂之性，生為世笑，死為愚鬼，不亦哀乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000023",
    "sentence": "伯通與耿俠遊俱起佐命，同被國恩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000024",
    "sentence": "俠遊廉讓，屢有降挹之言；而伯通自伐，以為功高天下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000025",
    "sentence": "往時遼東有豕，生子白頭，異而獻之，行至河東，見群豕皆白，懷慚而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000026",
    "sentence": "若以子之功論於朝廷，則為遼東豕也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000027",
    "sentence": "今乃愚妄，自比六國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000028",
    "sentence": "六國之時，其勢各盛，廓土數千里，勝兵將百萬，故能據國相持，多歷年世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000029",
    "sentence": "今天下幾裏，列郡幾城，奈何以區區漁陽而結怨天子？",
    "entities": [
      {
        "text": "列郡幾城",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000030",
    "sentence": "此猶河濱之人捧土以塞孟津，多見其不知量也！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000031",
    "sentence": "方今天下適定，海內願安，土無賢不肖，皆樂立名於世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000032",
    "sentence": "而伯通獨中風狂走，自捐盛時，內聽驕婦之失計，外信讒邪之諛言，長為群後惡法，永為功臣鑒戒，豈不誤哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000033",
    "sentence": "定海內者無私仇，勿以前事自誤，願留意顧老母幼弟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000034",
    "sentence": "凡舉事無為親厚者所痛，而為見仇者所快。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000035",
    "sentence": "寵得書愈怒，攻浮轉急。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000036",
    "sentence": "明年，涿郡太守張豐亦舉兵反。",
    "entities": [
      {
        "text": "涿郡",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000037",
    "sentence": "時，二郡畔戾，北州憂恐，浮以為天子必自將兵討之，而但遣遊擊將軍鄧隆陰助浮。",
    "entities": [
      {
        "text": "二郡",
        "label": "LOC",
        "start": 2,
        "end": 4
      },
      {
        "text": "北州",
        "label": "LOC",
        "start": 7,
        "end": 9
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000038",
    "sentence": "浮懷懼，以為帝怠於敵，不能救之，乃上疏曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000039",
    "sentence": "昔楚、宋列國，俱為諸侯，莊王以宋執其使，遂有投袂之師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000040",
    "sentence": "魏公子顧朋友之要，觸冒強秦之鋒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000041",
    "sentence": "夫楚、魏非有分職匡正之大義也，莊王但為爭強而發忿，公子以一言而立信耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000042",
    "sentence": "今彭寵反畔，張豐逆節，以為陛下必棄捐它事，以時滅之，既歷時月，寂寞無音。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000043",
    "sentence": "從圍城而不救，放逆虜而不討，臣誠惑之。",
    "entities": [
      {
        "text": "從圍城",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000044",
    "sentence": "昔高祖聖武，天下既定，猶身自征伐，未嘗寧居。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000045",
    "sentence": "陛下雖興大業，海內未集，而獨逸豫，不顧北垂，百姓遑遑，無所系心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000046",
    "sentence": "三河、冀州，曷足以傳後哉！",
    "entities": [
      {
        "text": "冀州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000047",
    "sentence": "今秋稼已熟，復為漁陽所掠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000048",
    "sentence": "張豐狂悖，奸黨日增，連年拒守，吏士疲勞，甲胄生蟣虱，弓弩不得施，上下焦心，相望救護，仰希陛下生活之恩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000049",
    "sentence": "詔報曰：『往年赤眉跋扈長安，吾策其無谷必東，果來歸降。今度此反虜，勢無久全，其中必有內相斬者。今軍資未充，故須後麥耳。』浮城中糧盡，人相食。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 11,
        "end": 13
      },
      {
        "text": "浮城",
        "label": "LOC",
        "start": 60,
        "end": 62
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000050",
    "sentence": "會上谷太守耿況遣騎來救浮，浮乃得遁走。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000051",
    "sentence": "南至良鄉，其兵長反遮之，浮恐不得脫，乃下馬刺殺其妻，僅以身免，城降於寵，尚書令侯霸奏浮敗亂幽州，構成寵罪，徒勞軍師，不能死節，罪當伏誅。",
    "entities": [
      {
        "text": "南至良鄉",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 36,
        "end": 38
      },
      {
        "text": "霸奏浮敗亂幽州",
        "label": "LOC",
        "start": 40,
        "end": 47
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000052",
    "sentence": "帝不忍，以浮代賈復為執金吾，徙封父城侯。",
    "entities": [
      {
        "text": "徙封父城",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000053",
    "sentence": "後豐、寵並自敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000054",
    "sentence": "帝以二千石長吏多不勝任，時有纖微之過者，必見斥罷，交易紛擾，百姓不寧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000055",
    "sentence": "六年，有日食之異，浮因上疏曰：",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000056",
    "sentence": "臣聞日者眾陽之所宗，君上之位也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000057",
    "sentence": "凡居官治民，據郡典縣，皆為陽為上，為尊為長。",
    "entities": [
      {
        "text": "據郡典縣",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000058",
    "sentence": "若陽上不明，尊長不足，則幹動三光，垂示王者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000059",
    "sentence": "五典紀國家之政，《鴻範》別災異之文，皆宣明天道，以征來事者也。",
    "entities": [
      {
        "text": "《鴻範》",
        "label": "TITLE",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000060",
    "sentence": "陛下哀湣海內新罹禍毒，保宥生人，使得蘇息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000061",
    "sentence": "而今牧人之吏，多未稱職，小違理實，輒見斥罷，豈不粲然黑白分明哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000062",
    "sentence": "然以堯、舜之盛，猶如三考，大漢之興，亦累功效，吏皆積久，養老於官，至名子孫，因為氏姓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000063",
    "sentence": "當時吏職，何能悉理；論議之徒，豈不喧嘩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000064",
    "sentence": "蓋以為天地之功不可倉卒，艱難之業當累日也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000065",
    "sentence": "而間者守宰數見換易，迎新相代，疲勞道路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000066",
    "sentence": "尋其視事日淺，未足昭見其職，既加嚴切，人不自呆，各自顧望，無自安之心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000067",
    "sentence": "有司或因睚眥以騁私怨，茍求長短，求媚上意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000068",
    "sentence": "二千石及長吏迫於舉劾，懼於刺譏，故爭飾詐偽，以希虛譽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000069",
    "sentence": "斯皆群陽騷動，日月失行之應。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000070",
    "sentence": "夫物暴長者必矢折，功卒成者必亟壞，如摧長久之業，而造速成之功，非陛下之福也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000071",
    "sentence": "天下非一時之用也，海內非一旦之功也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000072",
    "sentence": "願陛下遊意於經年之外，望化於一世之後，天下幸甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000073",
    "sentence": "帝下其議，群臣多同於浮，自是牧守易代頗簡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000074",
    "sentence": "舊制，州牧奏二千石長吏不任位者，事皆先下三公，三公遣掾史案驗，然後黜退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000075",
    "sentence": "帝時用明察，不復委任三府，而權歸刺舉之吏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000076",
    "sentence": "浮復上疏曰：『陛下清明履約，率禮無違，自宗室諸王、外家後親，皆奉遵繩墨，無黨勢之名。至或乘牛車，齊於編人。斯固法令整齊，下無作威者也。求之於事，宜以和平，而災異猶見者，而豈徒然？天道信誠，不可不察。竊見陛下疾往者上威不行，不專國命，即位以來，不用舊典，信賴舉之宮，黜鼎輔之任，至於有所劾奏，便加免退，復案不關三府，罪譴不蒙澄察。陛下以使者為腹心，而使者以從事為耳目，是為尚書之平，決於百石之吏，故群下苛刻，各自為能。兼以私情容長，憎愛在職，皆競張空虛，以要時利，故有罪者心不厭服，無咎者坐被空文，不可經盛衰，貽後王也。夫事積久則自重，吏安則人自靜。傳曰：「五年再閏，天道乃備。」夫以天地之靈，猶五載以成其化，況人道哉！臣浮愚戇，不勝惓惓，願陛下留心千里之任，省察偏言之奏。』",
    "entities": [
      {
        "text": "復案不關",
        "label": "LOC",
        "start": 150,
        "end": 154
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 185,
        "end": 187
      },
      {
        "text": "五年",
        "label": "TME",
        "start": 278,
        "end": 280
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000077",
    "sentence": "七年，轉太仆。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000078",
    "sentence": "浮又以國學既興，宜廣博士之選，乃上書曰：",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000079",
    "sentence": "夫太學者，禮義之官，教化所由興也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000080",
    "sentence": "陛下尊敬先聖，垂意古典，官室未飾，幹戈未休，而先建太學，進立橫舍，比日車駕親臨觀饗，將以弘時雍之化，顯勉進之功也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000081",
    "sentence": "尋博士之官，為天下宗師，使孔聖之言傳而不絕。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000082",
    "sentence": "舊事，策試博士，必廣求詳選，爰自畿夏，延及四方，是以博舉明經，惟賢是登，學者精勵，遠近同慕，伏聞詔書更試五人，惟取見在洛陽城者。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "惟取見在洛陽城",
        "label": "LOC",
        "start": 55,
        "end": 62
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000083",
    "sentence": "臣恐自今以往，將有所失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000084",
    "sentence": "求之密邇，容或未盡，而四方之學，無所勸樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000085",
    "sentence": "凡策試之本，貴得其真，非有期會，不及遠方也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000086",
    "sentence": "又諸所征試，皆私自發遣，非有傷費煩擾於事也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000087",
    "sentence": "語曰：『中國失禮，求之於野。』臣浮幸得與講圖讖，故敢越職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000088",
    "sentence": "帝然之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000089",
    "sentence": "二十年，代竇融為大司空，二十二年，坐賣弄國恩免。",
    "entities": [
      {
        "text": "二十年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "二十二年",
        "label": "TME",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000090",
    "sentence": "二十五年，徙封新息侯。",
    "entities": [
      {
        "text": "二十五年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000091",
    "sentence": "帝以浮陵轢同列，每銜之，惜其功能，不忍加罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000092",
    "sentence": "永平中，有人單辭告浮事者，顯宗大怒，賜浮死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000093",
    "sentence": "長水校尉樊鯈言於帝曰：『唐堯大聖，兆人獲所，尚優遊四兇之獄，厭服海內之心，使天下鹹知，然後殛罰。浮事雖昭明，而未達人聽，宜下廷尉，章著其事。』帝亦悔之。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000094",
    "sentence": "論曰：吳起與田文論功，文不及者三，朱買臣難公孫弘十策，弘不得其一，終之田文相魏，公孫宰漢，誠知宰相自有體也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000095",
    "sentence": "故曾子曰：『君子所貴乎道者三，籩豆之事則有司存。』而光武、明帝躬好吏事，亦以課核三公，其人或失而其禮稍薄，至有誅斥詰辱之累。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000096",
    "sentence": "任職責過，一至於此，追感賈生之論，不亦篤乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000097",
    "sentence": "朱浮譏諷苛察欲速之弊，然矣，焉得長者之言哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000098",
    "sentence": "馮魴",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000099",
    "sentence": "馮魴字孝孫，南陽湖陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000100",
    "sentence": "其先魏之支別，食菜馮城，因以氏焉。",
    "entities": [
      {
        "text": "食菜馮城",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000101",
    "sentence": "秦滅魏，遷於湖陽，為郡族姓。",
    "entities": [
      {
        "text": "為郡",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000102",
    "sentence": "王莽末，四方潰畔，魴乃聚賓客，招豪桀，作營塹，以待所歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000103",
    "sentence": "是時湖陽大姓虞都尉反城稱兵，先與同縣申屠季有仇，而殺其兄，謀滅季族。",
    "entities": [
      {
        "text": "大姓虞都尉反城",
        "label": "LOC",
        "start": 4,
        "end": 11
      },
      {
        "text": "先與同縣",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000104",
    "sentence": "季亡歸魴，魴將季欲還其宮，道逢都尉從弟長卿來，欲執季。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000105",
    "sentence": "魴叱長卿曰：『我與季雖無素故，士窮想歸，要當以死任之，卿為何言？』遂與俱歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000106",
    "sentence": "季謝曰：『蒙恩得全，死無以為報，有牛馬財物，願悉獻之。』魴作色曰：『吾老親弱弟皆在賊城中，今日相與，尚無所顧，何雲財物乎？』季慚不敢復言。",
    "entities": [
      {
        "text": "親弱弟皆在賊城",
        "label": "LOC",
        "start": 36,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000107",
    "sentence": "魴自是為縣邑所敬信，故能據營自固。",
    "entities": [
      {
        "text": "魴自是為縣邑",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000108",
    "sentence": "時天下未定，而四方之士擁兵矯稱者甚眾，唯魴自守，兼有方略。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000109",
    "sentence": "光武聞而嘉之，建武三年，征詣行在所，見於雲臺，拜虞令。",
    "entities": [
      {
        "text": "建武三年",
        "label": "TME",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000110",
    "sentence": "為政敢殺伐，以威信稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000111",
    "sentence": "遷郟令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000112",
    "sentence": "後車駕西征隗囂，潁川資賊群起，郟賊延褒等眾三千餘人，攻圍縣舍，魴率吏士七十許人，力戰連日，弩矢盡，城陷，魴乃遁去。",
    "entities": [
      {
        "text": "攻圍縣",
        "label": "LOC",
        "start": 26,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000113",
    "sentence": "帝聞郡國反，即馳赴潁川，魴詣行在所。",
    "entities": [
      {
        "text": "帝聞郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000114",
    "sentence": "帝案行鬥處，知魴力戰，乃嘉之曰：『此健令也。所當討擊，勿拘州郡。』褒等聞帝至，皆自髡剔，負鈇锧，將其眾請罪。",
    "entities": [
      {
        "text": "勿拘州郡",
        "label": "LOC",
        "start": 27,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000115",
    "sentence": "帝且赦之，使魴轉降諸聚落，縣中平定，詔乃悉以褒等還魴誅之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000116",
    "sentence": "魴責讓以行軍法，皆叩頭曰：『今日受誅，死無所恨。』魴曰：『汝知悔過伏罪，今一切相赦，聽各反農桑，為令作耳目。』皆稱萬歲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000117",
    "sentence": "是時每有盜賊，並為褒等所發，無敢動者，縣界清靜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000118",
    "sentence": "十三年，遷魏郡太守。",
    "entities": [
      {
        "text": "十三年",
