  {
    "sentence_id": "HCH_005_033_000142",
    "sentence": "順帝既立，石與喜皆以阿黨閻顯、江京等策免，復為衛尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000143",
    "sentence": "卒，子代嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000144",
    "sentence": "代卒，弟承嗣，為步兵校尉。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000145",
    "sentence": "石弟光，和帝時詔封楊邑侯，亦以石寵，官至城門校尉。",
    "entities": [
      {
        "text": "和帝時詔封楊邑",
        "label": "LOC",
        "start": 4,
        "end": 11
      },
      {
        "text": "官至城",
        "label": "LOC",
        "start": 18,
        "end": 21
      },
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000146",
    "sentence": "卒，子肅嗣，為黃門侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000147",
    "sentence": "虞延",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000148",
    "sentence": "虞延字子大，陳留東昏人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000149",
    "sentence": "延初生，其上有物若一匹練，遂上升上，占者以為吉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000150",
    "sentence": "及長，長八尺六寸，要帶十圍，力能扛鼎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000151",
    "sentence": "少為戶牖亭長。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000152",
    "sentence": "時王莽貴人魏氏賓客放從，延率吏卒突入其家捕之，以此見怨，故位不升。",
    "entities": [
      {
        "text": "魏氏",
        "label": "ORG",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000153",
    "sentence": "性敦樸，不拘小節，又無鄉曲之譽。",
    "entities": [
      {
        "text": "又無鄉",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000154",
    "sentence": "王莽末，天下大亂，延常嬰甲胄，擁衛親族，扞禦抄盜，賴其全者甚眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000155",
    "sentence": "延從女弟年在孩乳，其母不能活之，棄於溝中，延聞其號聲，哀而收之，養至成人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000156",
    "sentence": "建武初，仕執金吾府，除細陽令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000157",
    "sentence": "每至歲時伏臘，輒休遣徒系，各使歸家，並感其恩德，應期而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000158",
    "sentence": "有囚於家被病，自載詣獄，既至而死，延率掾史，殯於門外，百姓感悅之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000159",
    "sentence": "後去官還鄉裏，太守富宗聞延名，召署功曹。",
    "entities": [
      {
        "text": "後去官還鄉",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000160",
    "sentence": "宗性奢靡，車服器物，多不中節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000161",
    "sentence": "延諫曰：『昔晏嬰輔齊，鹿裘不完，季文子相魯，妾不衣帛，以約失之者鮮矣。』宗不悅，延即辭退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000162",
    "sentence": "居有頃，宗果以侈從被誅，臨當伏刑，攬涕而嘆曰：『恨不用功曹虞延之諫！』光武聞而奇之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000163",
    "sentence": "二十年東巡，路過小黃，高帝母昭靈後園陵在焉，時延為部督郵，詔呼引見，問園陵之事。",
    "entities": [
      {
        "text": "二十年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000164",
    "sentence": "延進止從容，占拜可觀，其陵樹株蘗，皆諳其數，俎豆犧牲，頗曉其禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000165",
    "sentence": "帝善之，敕延從駕到魯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000166",
    "sentence": "還經封丘城門，門下小，不容羽蓋，帝怒，使撻侍禦史，延因下見引咎，以為罪在督郵。",
    "entities": [
      {
        "text": "還經封丘城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000167",
    "sentence": "言辭激揚，有感帝意，乃制誥曰：『以陳留督郵虞延故，貰禦史罪。』延從送車駕西盡郡界，賜錢及劍帶佩刀還郡，於是聲名遂振。",
    "entities": [
      {
        "text": "從送車駕西盡郡",
        "label": "LOC",
        "start": 32,
        "end": 39
      },
      {
        "text": "及劍帶佩刀還郡",
        "label": "LOC",
        "start": 43,
        "end": 50
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000168",
    "sentence": "二十三年，司徒玉況辟焉。",
    "entities": [
      {
        "text": "二十三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000169",
    "sentence": "時元正朝賀，帝望而識延，遣小黃門馳問之，即日召拜公車令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000170",
    "sentence": "明年，遷洛陽令。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000171",
    "sentence": "是時，陰氏有客馬成者，常為奸盜，延收考之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000172",
    "sentence": "陰氏屢請，獲一書輒加篣二百。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000173",
    "sentence": "信陽侯陰就乃訴帝，譖延多所冤枉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000174",
    "sentence": "帝乃臨禦道之館，親錄囚徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000175",
    "sentence": "延陳其獄狀可論者在東，無理者居西。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000176",
    "sentence": "成乃回欲趨東，延前執之，謂曰：『爾人之巨蠹，久依城社，不畏熏燒。今考實未竟，宜當盡法！』成大呼稱枉，陛戟郎以戟刺延，叱使置之。",
    "entities": [
      {
        "text": "久依城",
        "label": "LOC",
        "start": 22,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000177",
    "sentence": "帝知延不私，謂成曰：『汝犯王法，身自取之！』呵使速去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000178",
    "sentence": "後數日伏誅，於是外戚斂手，莫敢幹法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000179",
    "sentence": "在縣三年，遷南陽太守。",
    "entities": [
      {
        "text": "在縣",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000180",
    "sentence": "永平初，有新野功曹鄧衍，以外戚小侯每豫朝會，而容姿趨步，有出於眾，顯宗目之，顧左右曰：『朕之儀貌，豈若此人！』特賜輿馬衣服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000181",
    "sentence": "延以衍雖有容儀而無實行，未嘗加禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000182",
    "sentence": "帝既異之，乃詔衍令自稱南陽功曹詣闕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000183",
    "sentence": "既到，拜郎中，遷玄武司馬。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000184",
    "sentence": "衍在職不服父喪，帝聞之，乃嘆曰：『「知人則哲，惟帝難之。」信哉斯言！』衍慚而退，由是以延為明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000185",
    "sentence": "三年，征代趙憙為太尉；八年，代範遷為司徒，歷位二府，十餘年無異政績。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "八年",
        "label": "TME",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000186",
    "sentence": "會楚王英謀反，陰氏欲中傷之，使人私之楚謀告延，延以英藩戚至親，不然其言，又欲辟幽州從事公孫弘，以弘交通楚王而止，並不奏聞。",
    "entities": [
      {
        "text": "又欲辟幽州",
        "label": "LOC",
        "start": 36,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000187",
    "sentence": "及英事發覺，詔書切讓，延遂自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000188",
    "sentence": "家至清貧，子孫不免寒餧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000189",
    "sentence": "延從曾孫放，字子仲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000190",
    "sentence": "少為太尉楊震門徒，及震被讒自殺，順帝初，放詣闕追訟震罪，由是知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000191",
    "sentence": "桓帝時為尚書，以議誅大將軍梁冀功封都亭侯，後為司空，坐水災免。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000192",
    "sentence": "性疾惡宦官，遂為所陷，靈帝初，與長樂少府李膺等俱以黨事誅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000193",
    "sentence": "鄭弘",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000194",
    "sentence": "鄭弘字巨君，會稽山陰人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000195",
    "sentence": "從祖吉，宣帝時為西域都護。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000196",
    "sentence": "弘少為鄉嗇夫，太守第五倫行春，見而深奇之，召署督郵，舉孝廉。",
    "entities": [
      {
        "text": "弘少為鄉",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "第五倫",
        "label": "PER",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000197",
    "sentence": "弘師同郡河東太守焦貺。",
    "entities": [
      {
        "text": "弘師同郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000198",
    "sentence": "楚王英謀反發覺，以疏引貺，貺被收捕，疾病於道亡沒，妻子閉系詔獄，掠考連年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000199",
    "sentence": "諸生故人懼相連及，皆改變名姓，以逃其禍，弘獨髡頭負鈇锧，詣闕上章，為貺訟罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000200",
    "sentence": "顯宗覺悟，即赦其家屬，弘躬送貺喪及妻子還鄉裏，由是顯名。",
    "entities": [
      {
        "text": "貺喪及妻子還鄉",
        "label": "LOC",
        "start": 14,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000201",
    "sentence": "拜為騶令，政有仁惠，民稱蘇息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000202",
    "sentence": "遷淮陰太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000203",
    "sentence": "四遷，建初初，為尚書令。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000204",
    "sentence": "舊制，尚書郎限滿補縣長令史丞尉。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "令史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000205",
    "sentence": "弘奏以為臺職雖尊，而酬賞甚薄，至於開選，多無樂者，請使郎補千石令，令史為長。",
    "entities": [
      {
        "text": "令史",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000206",
    "sentence": "帝從其議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000207",
    "sentence": "弘前後所陳有補益王政者，皆著之南宮，以為故事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000208",
    "sentence": "出為平原相，征拜侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000209",
    "sentence": "建初八年，代鄭眾為大司農。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000210",
    "sentence": "舊交阯七郡貢獻轉運，皆從東冶泛海而至，風波艱阻，沈溺相系。",
    "entities": [
      {
        "text": "舊交阯七郡",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000211",
    "sentence": "弘奏開零陵、桂陽嶠道，於是夷通，至今遂為常路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000212",
    "sentence": "在職二年，所息省三億萬計。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000213",
    "sentence": "時歲天下遭旱，邊方有警，人食不足，而帑藏殷積。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000214",
    "sentence": "弘又奏宜省貢獻，減徭費，以利饑人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000215",
    "sentence": "帝順其議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000216",
    "sentence": "元和元年 ，代鄧彪為太尉。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000217",
    "sentence": "時舉將第五倫為司空，班次在下，每正朔朝見，弘曲躬而自卑。",
    "entities": [
      {
        "text": "第五倫",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000218",
    "sentence": "帝問知其故，遂聽置雲母屏風，分隔其間，由此以為故事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000219",
    "sentence": "在位四年，奏尚書張林阿附侍中竇憲，而素行臧穢，又上洛陽令楊光，憲之賓客，在官貪殘，並不宜處位。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000220",
    "sentence": "書奏，吏與光故舊，因以告之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000221",
    "sentence": "光報憲，憲奏弘大臣漏泄密事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000222",
    "sentence": "帝詰讓弘，收上印綬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000223",
    "sentence": "弘自詣廷尉，詔敕出之，因乞骸骨歸，未許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000224",
    "sentence": "病篤，上書陳謝，並言竇憲之短。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000225",
    "sentence": "帝省章，遣醫占弘病，比至已卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000226",
    "sentence": "臨歿悉還賜物，敕妻子褐巾布衣素棺殯殮，以還鄉裏。",
    "entities": [
      {
        "text": "以還鄉",
        "label": "LOC",
        "start": 19,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000227",
    "sentence": "周章",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000228",
    "sentence": "周章子次叔，南陽隨人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000229",
    "sentence": "初仕郡為功曹。",
    "entities": [
      {
        "text": "初仕郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000230",
    "sentence": "時大將軍竇憲免，封冠軍侯就國。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 1,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000231",
    "sentence": "章從太守行春到冠軍，太守猶欲謁之。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000232",
    "sentence": "章進諫曰：『今日公行春，豈可越儀私交。且憲椒房之親，勢傾王室，而退就藩國，禍福難量。明府剖符大臣，千里重任，舉止進退，其可輕乎？』太守不聽，遂便升車。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 42,
        "end": 43
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 65,
        "end": 67
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000233",
    "sentence": "章前拔佩刀絕馬鞅，於是乃止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000234",
    "sentence": "及憲被誅，公卿以下多以交關得罪，太守幸免，以此重章。",
    "entities": [
      {
        "text": "卿以下多以交關",
        "label": "LOC",
        "start": 6,
        "end": 13
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000235",
    "sentence": "舉孝廉，六遷為五官中郎將。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000236",
    "sentence": "延平元年，為光祿勳。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000237",
    "sentence": "永初元年，代魏霸為太常。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000238",
    "sentence": "其冬，代尹勤為司空。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000239",
    "sentence": "是時中常侍鄭眾，蔡倫等皆秉勢豫政，章數進直言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000240",
    "sentence": "初，和帝崩，鄧太後以皇子勝有痼疾，不可奉承宗廟，貪殤帝孩抱，養為己子，故立之，以勝為平原王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000241",
    "sentence": "及殤帝崩，群臣以勝疾非痼、意咸歸之，太后以前既不立，恐後為怨，乃立和帝兄清河孝王子祜，是為安帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000242",
    "sentence": "章以眾心不附，遂密謀閉宮門，誅車騎將軍鄧騭兄弟及鄭眾、蔡倫，劫尚書，廢太后於南宮，封帝為遠國王，而立平原王勝。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 17,
        "end": 19
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000243",
    "sentence": "事覺，策免，章自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000244",
    "sentence": "家無餘財，諸子易衣而出，並日而食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000245",
    "sentence": "論曰：孔子稱『可與立，未可與權』。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000246",
    "sentence": "權也者，反常者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000247",
    "sentence": "將從反常之事，必資非常之會，使夫舉無違妄，誌行名全。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000248",
    "sentence": "周章身非負圖之托，德乏萬夫之望，主無絕天之舋？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000249",
    "sentence": "地有既安之執，而創慮於難圖，希功於理絕，不已悖乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000250",
    "sentence": "如令君器易以下議，即斗筲必能叨天業，狂夫豎臣亦自奮矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000251",
    "sentence": "孟軻有言曰：『有伊尹之心則可，無伊尹之心則篡矣。』於戲，方來之人戒之哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000252",
    "sentence": "【贊】",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000253",
    "sentence": "贊曰：朱定北州，激成寵尤。",
    "entities": [
      {
        "text": "朱定北州",
        "label": "LOC",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_033_000254",
    "sentence": "魴用降帑，延感歸囚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_033_000255",
    "sentence": "鄭、竇怨偶，代相為仇，周章反道，小智大謀。",
    "entities": []
  }
]
