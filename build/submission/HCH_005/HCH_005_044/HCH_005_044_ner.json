[
  {
    "sentence_id": "HCH_005_044_000001",
    "sentence": "鄧彪",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000002",
    "sentence": "鄧彪字智伯，南陽新野人，太傅禹之宗也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000003",
    "sentence": "父邯，中興初以功封鄳侯，　　仕至勃海太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000004",
    "sentence": "彪少勵志，修孝行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000005",
    "sentence": "父卒，讓國於異母弟荊鳳，顯宗高其節，下詔許焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000006",
    "sentence": "注續漢書曰：「其先楚人，鄧況始居新野，子孫以農桑為業。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000007",
    "sentence": "後仕州郡，辟公府，五遷桂陽太守。",
    "entities": [
      {
        "text": "後仕州郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000008",
    "sentence": "永平十七年 ，征入為太僕。",
    "entities": [
      {
        "text": "永平十七年",
        "label": "TME",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000009",
    "sentence": "數年，喪後母，辭疾乞身，詔以光祿大夫行服。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000010",
    "sentence": "服竟，拜奉車都尉，遷大司農。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000011",
    "sentence": "數月，代鮑昱為太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000012",
    "sentence": "彪在位清白，為百僚式。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000013",
    "sentence": "視事四年，以疾乞骸骨。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000014",
    "sentence": "元和元年 ，賜策罷，贈錢三十萬，在所以二千石奉終其身。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000015",
    "sentence": "又詔太常四時致宗廟之胙，　　河南尹遣丞存問，常以八月旦奉羊、酒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000016",
    "sentence": "和帝即位，以彪為太傅，錄尚書事，賜爵關*(中)***侯。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "賜爵關",
        "label": "LOC",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000017",
    "sentence": "永元初，竇氏專權驕縱，朝廷多有諫爭，而彪在位修身而已，不能有所匡正。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 1,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000018",
    "sentence": "又嘗奏免御史中丞周紆，紆前失竇氏旨，故頗以此致譏，然當時宗其禮讓。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000019",
    "sentence": "及竇氏誅，以老病上還樞機職，詔賜養牛酒而許焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000020",
    "sentence": "五年春，薨於位，天子親臨吊臨。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000021",
    "sentence": "張禹",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000022",
    "sentence": "張禹字伯達，趙國襄國人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000023",
    "sentence": "祖父況族姊為皇祖考夫人，數往來南頓，見光武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000024",
    "sentence": "光武為大司馬，過邯鄲，況為郡吏，謁見光武。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "況為郡",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000025",
    "sentence": "光武大喜，曰：「乃今得我大舅乎！」因與俱北，到高邑，以為元氏令。",
    "entities": [
      {
        "text": "到高邑",
        "label": "LOC",
        "start": 22,
        "end": 25
      },
      {
        "text": "元氏",
        "label": "ORG",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000026",
    "sentence": "遷涿郡太守。",
    "entities": [
      {
        "text": "遷涿郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000027",
    "sentence": "後為常山關長。",
    "entities": [
      {
        "text": "後為常山關",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000028",
    "sentence": "會赤眉攻關城，況戰歿。",
    "entities": [
      {
        "text": "會赤眉攻關城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000029",
    "sentence": "父歆，初以報仇逃亡，後仕為淮陽相，終於汲令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000030",
    "sentence": "注皇祖考，鉅鹿都尉回。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000031",
    "sentence": "禹性篤厚節儉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000032",
    "sentence": "父卒，汲吏人賻送前後數百萬，悉無所受。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000033",
    "sentence": "又以田宅推與伯父，身自寄止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000034",
    "sentence": "注東觀記曰：「禹好學，習歐陽尚書，事太常桓榮，惡衣食。」",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000035",
    "sentence": "永平八年 ，舉孝廉，稍遷；建初中，拜楊州刺史。",
    "entities": [
      {
        "text": "永平八年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "拜楊州",
        "label": "LOC",
        "start": 17,
        "end": 20
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000036",
    "sentence": "當過江行部，中土*(民)***皆以江有子胥之神，難於濟涉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000037",
    "sentence": "禹將度，吏固請不聽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000038",
    "sentence": "禹厲言曰：「子胥如有靈，知吾志在理察枉訟，豈危我哉？」遂鼓楫而過。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000039",
    "sentence": "歷行郡邑，深幽之處莫不畢到，親錄囚徒，多所明舉。",
    "entities": [
      {
        "text": "歷行郡邑",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000040",
    "sentence": "吏民希見使者，*(民)***懷喜悅，怨德美惡，莫不自歸焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000041",
    "sentence": "注酈元水經注曰，吳王賜子胥死，浮屍於江。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000042",
    "sentence": "夫差悔，與腢臣臨江設祭，修塘道及壇，吳人因為立廟而祭焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000043",
    "sentence": "元和二年 ，轉兗州刺史，亦有清平稱。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "轉兗州",
        "label": "LOC",
        "start": 6,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000044",
    "sentence": "三年，遷下邳相。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000045",
    "sentence": "徐縣北界有蒲陽坡，　　傍多良田，而堙廢莫修。",
    "entities": [
      {
        "text": "徐縣",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000046",
    "sentence": "禹為開水門，通引灌溉，遂成孰田數百頃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000047",
    "sentence": "勸率吏民，假與種糧，親自勉勞，遂大收谷實。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000048",
    "sentence": "鄰郡貧者歸之千餘戶，室廬相屬，其下成巿。",
    "entities": [
      {
        "text": "鄰郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000049",
    "sentence": "後歲至墾千餘頃，民用溫給。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000050",
    "sentence": "功曹史戴閏，故太尉掾也，權動郡內。",
    "entities": [
      {
        "text": "權動郡",
        "label": "LOC",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000051",
    "sentence": "有小譴，禹令自致徐獄，然後正其法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000052",
    "sentence": "自長史以下，莫不震肅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000053",
    "sentence": "注東觀記曰：「坡水廣二十里，逕且百里，在道西，其東有田可萬頃。」「坡」與「陂」同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000054",
    "sentence": "永元六年 ，入為大司農，拜太尉，和帝甚禮之。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000055",
    "sentence": "十五年，南巡祠園廟，禹以太尉兼□尉留守。",
    "entities": [
      {
        "text": "十五年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000056",
    "sentence": "聞車駕當進幸江陵，以為不宜冒險遠，驛馬上諫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000057",
    "sentence": "詔報曰：「祠謁既訖，當南禮大江，會得君奏，臨漢回輿而旋。」及行還，禹特蒙賞賜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000058",
    "sentence": "注東觀記曰「禹留守北宮，太官朝夕送食，賜闟登具物，除子男盛為郎」也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000059",
    "sentence": "延平元年 ，遷為太傅，錄尚書事。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000060",
    "sentence": "鄧太后以殤帝初育，欲令重臣居禁內，乃詔禹捨宮中，給帷帳默褥，太官朝夕進食，五日一歸府。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000061",
    "sentence": "每朝見，特贊，與三公絕席。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000062",
    "sentence": "禹上言：「方諒闇密靜之時，不宜依常有事於苑囿。其廣成、上林空地，宜且以假貧民。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000063",
    "sentence": "太后從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000064",
    "sentence": "及安帝即位，數上疾乞身。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000065",
    "sentence": "詔遣小黃門問疾，賜牛一頭，酒十斛，勸令就第。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000066",
    "sentence": "其錢布、刀□、衣物，前後累至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000067",
    "sentence": "注育，生也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000068",
    "sentence": "永初元年 ，以定策功封安鄉侯，食邑千二百戶，與太尉徐防、司空尹勤同日俱封。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "以定策功封安鄉",
        "label": "LOC",
        "start": 6,
        "end": 13
      },
      {
        "text": "食邑",
        "label": "LOC",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000069",
    "sentence": "其秋，以寇賊水雨策免防、勤，而禹不自安，上書乞骸骨，更拜太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000070",
    "sentence": "四年，新野君病，皇太后車駕幸其第。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000071",
    "sentence": "禹與司徒夏勤、司空張敏俱上表言：「新野君不安，車駕連日宿止，臣等誠竊惶懼。臣聞王者動設先置，止則交戟，清道而後行，清室而後御，離宮不宿，所以重宿□也。陛下體烝烝之至孝，親省方藥，恩情發中，久處單外，百官露止，議者所不安。宜且還宮，上為宗廟社稷，下為萬國子民。」比三上，固爭，乃還宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000072",
    "sentence": "後連歲災荒，府臧空虛，禹上疏求入三歲租稅，以助郡國稟假。",
    "entities": [
      {
        "text": "以助郡",
        "label": "LOC",
        "start": 21,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000073",
    "sentence": "詔許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000074",
    "sentence": "五年，以陰陽不和策免。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000075",
    "sentence": "七年，卒於家。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000076",
    "sentence": "使者弔祭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000077",
    "sentence": "除小子曜為郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000078",
    "sentence": "長子盛嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000079",
    "sentence": "注鄧太后母陰氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000080",
    "sentence": "徐防",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_044_000081",
    "sentence": "徐防字謁卿，沛國銍人也。",
    "entities": [
      {
        "text": "沛",
        "label": "LOC",
        "start": 6,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_044_000082",
