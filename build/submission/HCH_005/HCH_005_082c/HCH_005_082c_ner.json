        "text": "後還鄉",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_082c_000005",
    "sentence": "元初七年 ，郡界有芝草生，太守劉祗欲上言之，以問檀。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
