      }
    ]
  },
  {
    "sentence_id": "HCH_005_082c_000052",
    "sentence": "資具以狀上，詔書遣五陽兵到。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_082c_000053",
    "sentence": "彥推遁甲，教以時進兵，一戰破賊，燔燒屯塢，徐、兗二州，一時平夷。",
    "entities": [
      {
        "text": "兗二州",
        "label": "LOC",
        "start": 23,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_005_082c_000054",
    "sentence": "樊志張",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_082c_000055",
    "sentence": "樊志張者，漢中南鄭人也。",
    "entities": [
