[
  {
    "sentence_id": "HCH_005_119_000001",
    "sentence": "《書》曰：「明試以功，車服以庸。」言昔者聖人興天下之大利，除天下之大害，躬親其事，身履其勤，憂之勞之，不避寒暑，使天下之民物，各得安其性命，無夭昏暴陵之災。",
    "entities": [
      {
        "text": "《書》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000002",
    "sentence": "是以天下之民，敬而愛之，若親父母；則而養之，若仰日月。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000003",
    "sentence": "夫愛之者欲其長久，不憚力役，相與起作宮室，上棟下宇，以雍覆之，欲其長久也；敬之者欲其尊嚴，不憚勞煩，相與起作輿輪旌旗章表，以尊嚴之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000004",
    "sentence": "斯愛之至，敬之極也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000005",
    "sentence": "苟心愛敬，雖報之至，情由未盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000006",
    "sentence": "或殺身以為之，盡其情也；弈世以祀之，明其功也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000007",
    "sentence": "是以流光與天地比長。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000008",
    "sentence": "後世聖人，知恤民之憂思深大者，必饗其樂；勤仁毓物使不夭折者，必受其福。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000009",
    "sentence": "故為之製禮以節之，使夫上仁繼天統物，不伐其功，民物安逸，若道自然，莫知所謝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000010",
    "sentence": "《老子》曰：「聖人不仁，以百姓為芻狗」。",
    "entities": [
      {
        "text": "《老子》",
        "label": "TITLE",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000011",
    "sentence": "此之謂也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000012",
    "sentence": "夫禮服之興也，所以報功章德，尊仁尚賢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000013",
    "sentence": "故禮尊尊貴貴，不得相逾，所以為禮也，非其人不得服其服，所以順禮也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000014",
    "sentence": "順則上下有序，德薄者退，德盛者縟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000015",
    "sentence": "故聖人處乎天子之位，服玉藻邃延，日月昇龍，山車金根飾，黃屋左纛，所以副其德，章其功也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000016",
    "sentence": "賢仁佐聖，封國受民，黼黻文繡，降龍路車，所以顯其仁，光其能也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000017",
    "sentence": "及其季末，聖人不得其位，賢者隱伏，是以天子微弱，諸侯脅矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000018",
    "sentence": "於此相貴以等，相讟以貨，相賂以利，天下之禮亂矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000019",
    "sentence": "至周夷王下堂而迎諸侯，此天子失禮，微弱之始也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000020",
    "sentence": "自是諸侯宮縣樂食，祭以白牡，擊玉磬，朱幹設鍚，冕而儛《大武》。",
    "entities": [
      {
        "text": "自是諸侯宮縣",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "《大武》",
        "label": "TITLE",
        "start": 26,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000021",
    "sentence": "大夫臺門旅樹反坫，繡黼丹朱中衣，鏤簋朱紘，此大夫之僭諸侯禮也。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000022",
    "sentence": "《詩》刺「彼己之子，不稱其服」，傷其敗化。",
    "entities": [
      {
        "text": "《詩》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000023",
    "sentence": "《易》譏「負且乘，致寇至」，言小人乘君子器，盜思奪之矣。",
    "entities": [
      {
        "text": "《易》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000024",
    "sentence": "自是禮制大亂，兵革並作；上下無法，諸侯陪臣，山楶藻梲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000025",
    "sentence": "降及戰國，奢僭益熾，削滅禮籍，蓋惡有害己之語。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000026",
    "sentence": "競修奇麗之服，飾以輿馬，文罽玉纓，象鑣金鞍，以相誇上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000027",
    "sentence": "爭錐刀之利，殺人若刈草然，其宗祀亦旋夷滅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000028",
    "sentence": "榮利在己，雖死不悔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000029",
    "sentence": "及秦並天下，攬其輿服，上選以供御，其次以錫百官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000030",
    "sentence": "漢興，文學既缺，時亦草創，承秦之製，後稍改定，參稽《六經》，近於雅正。",
    "entities": [
      {
        "text": "《六經》",
        "label": "TITLE",
        "start": 25,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000031",
    "sentence": "孔子曰：「其或繼周者，行夏之正，乘殷之輅，服周之冕，樂則《韶》、《舞》。」故撰《輿服》著之於篇，以觀古今損益之義云。",
    "entities": [
      {
        "text": "《韶》",
        "label": "TITLE",
        "start": 28,
        "end": 31
      },
      {
        "text": "《舞》",
        "label": "TITLE",
        "start": 32,
        "end": 35
      },
      {
        "text": "《輿服》",
        "label": "TITLE",
        "start": 39,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000032",
    "sentence": "上古聖人，見轉蓬始知為輪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000033",
    "sentence": "輪行可載，因物知生，復為之輿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000034",
    "sentence": "輿輪相乘，流運罔極，任重致遠，天下獲其利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000035",
    "sentence": "後世聖人觀於天，視斗周旋，魁方杓曲，以攜龍、角為帝車，於是乃曲其輈，乘牛駕馬，登險赴難，周覽八極。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000036",
    "sentence": "故《易·震》乘《乾》，謂之《大壯》，言器莫能有上之者也。",
    "entities": [
      {
        "text": "《易·震》",
        "label": "TITLE",
        "start": 1,
        "end": 6
      },
      {
        "text": "《乾》",
        "label": "TITLE",
        "start": 7,
        "end": 10
      },
      {
        "text": "《大壯》",
        "label": "TITLE",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000037",
    "sentence": "自是以來，世加其飾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000038",
    "sentence": "至奚仲為夏車正，建其斿旐，尊卑上下，各有等級。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000039",
    "sentence": "周室大備，官有六職，百工與居一焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000040",
    "sentence": "一器而群工致巧者，車最多，是故具物以時，六材皆良。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000041",
    "sentence": "輿方法地，蓋圓像天；三十輻以像日月；蓋弓二十八以像列星；龍旂九斿，七仞齊軫，以像大火；鳥旟七斿，五仞齊較，以像鶉火；熊旗六斿，五仞齊肩，以像參、伐；龜旐四斿，四仞齊首，以像營室；弧旌枉矢，以像弧也：此諸侯以下之所建者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000042",
    "sentence": "天子玉路，以玉為飾，鍚樊纓十有再就，建太常，十有二斿，九仞曳地，日月昇龍，像天明也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000043",
    "sentence": "夷王以下，周室衰弱，諸侯大路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000044",
    "sentence": "秦並天下，閱三代之禮，或曰殷瑞山車，金根之色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000045",
    "sentence": "漢承秦制，御為乘輿，所謂孔子乘殷之路者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000046",
    "sentence": "乘輿、金根、安車、立車，輪皆朱班重牙，貳轂兩轄，金薄繆龍，為輿倚較，文虎伏軾，龍首銜軛，左右吉陽筩，鸞雀立衡，𣝛文畫輈，羽蓋華蚤，建大旂，十有二斿，畫日月昇龍，駕六馬，象鑣鏤鍚，金鍐鋄方釳，插翟尾，朱兼樊纓，赤罽易茸，金就十有二，左纛以氂牛尾為之，在左騑馬軛上，大如斗，是為德車。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000047",
    "sentence": "五時車，安、立亦皆如之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000048",
    "sentence": "各如方色，馬亦如之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000049",
    "sentence": "白馬者，朱其髦尾為朱鬣雲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000050",
    "sentence": "所御駕六，餘皆駕四，後從為副車。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000051",
    "sentence": "耕車，其飾皆如之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000052",
    "sentence": "有三蓋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000053",
    "sentence": "一曰芝車，置𨏟耒耜之箙，上親耕所乘也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000054",
    "sentence": "戎車，其飾皆如之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000055",
    "sentence": "蕃以矛麾金鼓羽析幢翳，𨏟冑甲弩之箙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000056",
    "sentence": "獵車，其飾皆如之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000057",
    "sentence": "重輞縵輪，繆龍繞之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000058",
    "sentence": "一曰闟豬車，親校獵乘之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000059",
    "sentence": "太皇太后、皇太后法駕，皆御金根，加交絡帳裳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000060",
    "sentence": "非法駕，則乘紫罽軿車。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000061",
    "sentence": "雲𣝛文畫輈，黃金塗五末，蓋蚤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000062",
    "sentence": "左右騑，駕三馬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000063",
    "sentence": "長公主赤罽軿車。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000064",
    "sentence": "大貴人、貴人、公主、王妃、封君油畫軿車。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000065",
    "sentence": "大貴人加節畫輈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000066",
    "sentence": "皆右騑而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000067",
    "sentence": "皇太子、皇子皆安車，朱班輪，青蓋，金華蚤，黑𣝛文，畫轓文輈，金塗五末。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000068",
    "sentence": "皇子為王，錫以乘之，故曰王青蓋車。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000069",
    "sentence": "皇孫則綠車以從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000070",
    "sentence": "皆左右騑，駕三。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000071",
    "sentence": "公、列侯安車，朱班輪，倚鹿較，伏熊軾，皁繒蓋，黑轓，右輫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000072",
    "sentence": "中二千石、二千石皆皁蓋，朱兩轓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000073",
    "sentence": "其千石、六百石，朱左轓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000074",
    "sentence": "轓長六尺，下屈廣八寸，上業廣尺二寸，九文，十二初，後謙一寸，若月初生，示不敢自滿也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000075",
    "sentence": "景帝中元五年，始詔六百石以上施車轓，得銅五末，軛有吉陽筩。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000076",
    "sentence": "中二千石以上右騑，三百石以上皁布蓋，千石以上皁繒覆蓋，二百石以下白布蓋，皆有四維槓衣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000077",
    "sentence": "賈人不得乘馬車。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000078",
    "sentence": "除吏赤畫槓，其餘皆青雲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000079",
    "sentence": "公、列侯、中二千石、二千石夫人，會朝若蠶，各乘其夫之安車，右騑，加交絡帷裳，皆皁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000080",
    "sentence": "非公會，不得乘朝車，得乘漆布輜軿車，銅五末。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000081",
    "sentence": "乘輿大駕，公卿奉引，太僕御，大將軍參乘。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000082",
    "sentence": "屬車八十一乘，備千乘萬騎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000083",
    "sentence": "西都行祠天郊，甘泉備之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000084",
    "sentence": "官有其註，名曰甘泉鹵簿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000085",
    "sentence": "東都唯大行乃大駕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000086",
    "sentence": "大駕，太僕校駕；法駕，黃門令校駕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000087",
    "sentence": "乘輿法駕，公卿不在鹵簿中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000088",
    "sentence": "河南尹、執金吾、雒陽令奉引，奉車郎御，侍中參乘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000089",
    "sentence": "屬車三十六乘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000090",
    "sentence": "前驅有九斿雲罕，鳳皇闟戟，皮軒鸞旗，皆大夫載。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000091",
    "sentence": "鸞旗者，編羽旄，列系幢旁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000092",
    "sentence": "民或謂之雞翹，非也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000093",
    "sentence": "後有金鉦黃鉞，黃門鼓車。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000094",
    "sentence": "古者諸侯貳車九乘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000095",
    "sentence": "秦滅九國，兼其車服，故大駕屬車八十一乘，法駕半之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000096",
    "sentence": "屬車皆皁蓋赤裡，朱轓，戈矛弩箙，尚書、御史所載。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000097",
    "sentence": "最後一車懸豹尾，豹尾以前比省中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000098",
    "sentence": "行祠天郊以法駕，祠地、明堂省什三，祠宗廟尤省，謂之小駕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000099",
    "sentence": "每出，太僕奉駕上鹵簿，中常侍、小黃門副；尚書主者，郎令史副；侍御史，蘭台令史副。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 20,
        "end": 22
      },
      {
        "text": "令史",
        "label": "TITLE",
        "start": 26,
        "end": 28
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 31,
        "end": 33
      },
      {
        "text": "令史",
        "label": "TITLE",
        "start": 36,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000100",
    "sentence": "皆執注，以督整車騎，謂之護駕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000101",
    "sentence": "春秋上陵，尤省於小駕，直事尚書一人從，其餘令以下，皆先行後罷。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000102",
    "sentence": "輕車，古之戰車也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000103",
    "sentence": "洞朱輪輿，不巾不蓋，建矛戟幢麾，𨏟輒弩服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000104",
    "sentence": "藏在武庫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000105",
    "sentence": "大駕、法駕出，射聲校尉、司馬吏士載，以次屬車，在鹵簿中。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000106",
    "sentence": "諸車有矛戟，其飾幡斿旗幟皆五采，制度從《周禮》。",
    "entities": [
      {
        "text": "《周禮》",
        "label": "TITLE",
        "start": 19,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000107",
    "sentence": "吳、孫《兵法》云：「有巾有蓋，謂之武剛車。」武剛車者，為先驅。",
    "entities": [
      {
        "text": "《兵法》",
        "label": "TITLE",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000108",
    "sentence": "又為屬車輕車，為後殿焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000109",
    "sentence": "大使車，立乘，駕駟，赤帷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000110",
    "sentence": "持節者，重導從：賊曹車、斧車、督車、功曹車皆兩；大車，伍伯璅弩十二人；闢車四人；從車四乘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000111",
    "sentence": "無節，單導從，減半。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000112",
    "sentence": "小使車，不立乘，有騑，赤屏泥油，重絳帷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000113",
    "sentence": "導無斧車。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000114",
    "sentence": "近小使車，蘭輿赤轂，白蓋赤帷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000115",
    "sentence": "從騶騎四十人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000116",
    "sentence": "此謂追捕考案，有所敕取者之所乘也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000117",
    "sentence": "諸使車皆朱班輪，四輻，赤衡軛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000118",
    "sentence": "其送葬，白堊已下，灑車而後還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000119",
    "sentence": "公、卿、中二千石、二千石，郊廟、明堂、祠陵，法出，皆大車，立乘、駕駟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000120",
    "sentence": "他出，乘安車。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000121",
    "sentence": "大行載車，其飾如金根車，加施組連璧交絡四角，金龍首銜璧，垂五采，析羽流蘇前後，雲氣畫帷裳，𣝛文畫曲轓，長懸車等。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000122",
    "sentence": "太僕御，駕六布施馬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000123",
    "sentence": "布施馬者，淳白駱馬也，以黑藥灼其身為虎文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000124",
    "sentence": "既下，馬斥賣，車藏城北秘宮，皆不得入城門。",
    "entities": [
      {
        "text": "車藏城",
        "label": "LOC",
        "start": 7,
        "end": 10
      },
      {
        "text": "皆不得入城",
        "label": "LOC",
        "start": 14,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000125",
    "sentence": "當用，太僕考工乃內飾治，禮吉凶不相干也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000126",
    "sentence": "公卿以下至縣三百石長導從，置門下五吏：賊曹、督盜賊、功曹，皆帶劍，三車導；主簿、主記，兩車為從。",
    "entities": [
      {
        "text": "公卿以下至縣",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000127",
    "sentence": "縣令以上，加導斧車。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000128",
    "sentence": "公乘安車，則前後並馬立乘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000129",
    "sentence": "長安、雒陽令及王國都縣加前後兵車，亭長，設右騑，駕兩。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "陽令及王國都縣",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000130",
    "sentence": "弩車前伍伯，公八人，中二千石、二千石、六百石皆四人，自四百石以下至二百石皆二人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000131",
    "sentence": "黃綬，武官伍伯，文官闢車。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000132",
    "sentence": "鈴下、侍閣、門蘭、部署、街里走卒，皆有程品，多少隨所典領。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000133",
    "sentence": "驛馬三十里一置，卒皆赤幘絳韝云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000134",
    "sentence": "古者軍出，師旅皆從；秦省其卒，取其師旅之名焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000135",
    "sentence": "公以下至二千石，騎吏四人，千石以下至三百石，縣長二人，皆帶劍，持戟為前列，揵弓韣九鞬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000136",
    "sentence": "諸侯王法駕，官屬傅相以下，皆備鹵簿，似京都官騎，張弓帶鞬，遮迾出入稱促。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000137",
    "sentence": "列侯，家丞、庶子導從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000138",
    "sentence": "若會耕祠，主縣假給闢車鮮明卒，備其威儀。",
    "entities": [
      {
        "text": "主縣",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000139",
    "sentence": "導從事畢，皆罷所假。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000140",
    "sentence": "諸車之文：乘輿，倚龍伏虎，文畫輈，龍首鸞衡，重牙班輪，昇龍飛軨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000141",
    "sentence": "皇太子、諸侯王，倚虎伏鹿，文畫輈轓，吉陽，朱班輪，鹿文飛軨，旂旗九降龍。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000142",
    "sentence": "公、列侯，倚鹿伏熊，黑轓，朱班輪，鹿文飛軨，九降龍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000143",
    "sentence": "卿，朱兩轓，五降龍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000144",
    "sentence": "二千石以下各從科品，諸轓車以上，軛皆有吉陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000145",
    "sentence": "諸馬之文：案乘輿，金方釳，插翟象鑣，龙画𦁕，沫昇龍，赤扇汗，青兩翅，燕尾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000146",
    "sentence": "駙馬，左右赤珥流蘇，飛鳥節，赤膺兼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000147",
    "sentence": "皇太子或亦如之。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_119_000148",
    "sentence": "王、公、列侯，鏤鍚文髦，朱鑣朱鹿，朱文，絳扇汗，青翅燕尾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000149",
    "sentence": "卿以下有騑者，緹扇汗，青翅尾，當盧文髦，上下皆通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_119_000150",
    "sentence": "中二千石以上及使者，乃有騑駕云。",
    "entities": []
  }
]
