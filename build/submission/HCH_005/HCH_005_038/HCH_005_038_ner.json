      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000054",
    "sentence": "風政修明，流愛于人，在事七年，道不拾遺。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000055",
    "sentence": "順帝末，揚、徐盜賊群起，磐牙連歲。",
    "entities": []
  },
  {
