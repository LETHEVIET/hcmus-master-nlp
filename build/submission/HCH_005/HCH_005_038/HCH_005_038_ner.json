[
  {
    "sentence_id": "HCH_005_038_000001",
    "sentence": "後漢書卷三十八　張法滕馮度楊列傳　第二十八",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000002",
    "sentence": "張宗",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000003",
    "sentence": "張宗字諸君，南陽魯陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000004",
    "sentence": "王莽時，為縣陽泉鄉佐。",
    "entities": [
      {
        "text": "為縣陽泉鄉",
        "label": "LOC",
        "start": 4,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000005",
    "sentence": "會莽敗，義兵起，宗乃率陽泉民三四百人起兵略地，西至長安，更始以宗為偏將軍。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 25,
        "end": 27
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 34,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000006",
    "sentence": "宗見更始政亂，因將家屬客安邑。",
    "entities": [
      {
        "text": "因將家屬客安邑",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000007",
    "sentence": "及大司徒鄧禹西征，定河東，宗詣禹自歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000008",
    "sentence": "禹聞宗素多權謀，乃表為偏將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000009",
    "sentence": "禹軍到栒邑，赤眉大眾且至，禹以栒邑不足守，欲引師進就堅城，而眾人多畏賊追，憚為後拒。",
    "entities": [
      {
        "text": "禹軍到栒邑",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "禹以栒邑",
        "label": "LOC",
        "start": 13,
        "end": 17
      },
      {
        "text": "欲引師進就堅城",
        "label": "LOC",
        "start": 21,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000010",
    "sentence": "禹乃書諸將名於竹簡，署其前後，亂著笥中，令各探之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000011",
    "sentence": "宗獨不肯探，曰：「死生有命，張宗豈辭難就逸乎！」禹歎息謂曰：「將軍有親弱在營，奈何不顧？」宗曰：「愚聞一卒畢力，百人不當；萬夫致死，可以橫行。宗今擁兵數千，以承大威，何遽其必敗乎！」遂留為後拒。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000012",
    "sentence": "諸營既引兵，宗方勒厲軍士，堅壘壁，以死當之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000013",
    "sentence": "禹到前縣，議曰：「以張將軍之眾，當百萬之師，猶以小雪投沸湯，雖欲戮力，其埶不全也。」乃遣步騎二千人反還迎宗。",
    "entities": [
      {
        "text": "禹到前縣",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000014",
    "sentence": "宗引兵始發，而赤眉卒至，宗與戰，卻之，乃得歸營，於是諸將服其勇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000015",
    "sentence": "及還到長安，宗夜將銳士入城襲赤眉，中矛貫胛，又轉攻諸營保，為流矢所激，皆幾至於死。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "宗夜將銳士入城",
        "label": "LOC",
        "start": 6,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000016",
    "sentence": "及鄧禹徵還，光武以宗為京輔都尉，將突騎與征西大將軍馮異共擊關中諸營保，破之，遷河南都尉。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 22,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000017",
    "sentence": "建武六年 ，都尉官省，拜太中大夫。",
    "entities": [
      {
        "text": "建武六年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000018",
    "sentence": "八年，潁川桑中盜賊群起，宗將兵擊定之。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000019",
    "sentence": "後青、冀盜賊屯聚山澤，宗以謁者督諸郡兵討平之。",
    "entities": [
      {
        "text": "宗以謁者督諸郡",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000020",
    "sentence": "十六年，琅邪、北海盜賊復起，宗督二郡兵討之，乃設方略，明購賞，皆悉破散，於是沛、楚、東海、臨淮群賊懼其威武，相捕斬者數千人，青、徐震慄。",
    "entities": [
      {
        "text": "十六年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "宗督二郡",
        "label": "LOC",
        "start": 14,
        "end": 18
      },
      {
        "text": "沛",
        "label": "LOC",
        "start": 38,
        "end": 39
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000021",
    "sentence": "後遷琅邪相，其政好嚴猛，敢殺伐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000022",
    "sentence": "永平二年 ，卒於官。",
    "entities": [
      {
        "text": "永平二年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000023",
    "sentence": "法雄",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000024",
    "sentence": "法雄字文彊，扶風郿人也，齊襄王法章之後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000025",
    "sentence": "秦滅齊，子孫不敢稱田姓，故以法為氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000026",
    "sentence": "宣帝時，徙三輔，世為二千石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000027",
    "sentence": "雄初仕郡功曹，辟太傅張禹府，舉雄高第，除平氏長。",
    "entities": [
      {
        "text": "雄初仕郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000028",
    "sentence": "善政事，好發擿姦伏，盜賊稀發，吏人畏愛之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000029",
    "sentence": "南陽太守鮑得上其理狀，遷宛陵令。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000030",
    "sentence": "永初三年 ，海賊張伯路等三千餘人，冠赤幘，服絳衣，自稱「將軍」，寇濱海九郡，殺二千石令長。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 28,
        "end": 30
      },
      {
        "text": "寇濱海九郡",
        "label": "LOC",
        "start": 32,
        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000031",
    "sentence": "初，遣侍御史龐雄督州郡兵擊之，伯路等乞降，尋復屯聚。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000032",
    "sentence": "明年，伯路復與平原劉文河等三百餘人稱「使者」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000033",
    "sentence": "攻厭次城，殺長吏，轉入高唐，燒官寺，出繫囚，渠帥皆稱「將軍」，共朝謁伯路。",
    "entities": [
      {
        "text": "攻厭次城",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000034",
    "sentence": "伯路冠五梁冠，佩印綬，黨眾浸盛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000035",
    "sentence": "乃遣御史中丞王宗持節發幽、冀諸郡兵，合數萬人，乃徵雄為青州刺史，與王宗并力討之。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "冀諸郡",
        "label": "LOC",
        "start": 13,
        "end": 16
      },
      {
        "text": "乃徵雄為青州",
        "label": "LOC",
        "start": 23,
        "end": 29
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000036",
    "sentence": "連戰破賊，斬首溺死者數百人，餘皆奔走，收器械財物甚眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000037",
    "sentence": "會赦詔到，賊猶以軍甲未解，不敢歸降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000038",
    "sentence": "於是王宗召刺史太守共議，皆以為當遂擊之。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000039",
    "sentence": "雄曰：「不然。兵，凶器；戰，危事。勇不可恃，勝不可必。賊若乘船浮海，深入遠島，攻之未易也。及有赦令，可且罷兵，以慰誘其心，埶必解散，然後圖之，可不戰而定也。」宗善其言，即罷兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000040",
    "sentence": "賊聞大喜，乃還所略人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000041",
    "sentence": "而東萊郡兵獨未解甲，賊復驚恐，遁走遼東，止海島上。",
    "entities": [
      {
        "text": "而東萊郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000042",
    "sentence": "五年春，乏食，復抄東萊閒，雄率郡兵擊破之，賊逃還遼東，遼東人李久等共斬平之，於是州界清靜。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "雄率郡",
        "label": "LOC",
        "start": 13,
        "end": 16
      },
      {
        "text": "於是州",
        "label": "LOC",
        "start": 38,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000043",
    "sentence": "雄每行部，錄囚徒，察顏色，多得情偽，長吏不奉法者皆解印綬去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000044",
    "sentence": "在州四年，遷南郡太守，斷獄省少，戶口益增。",
    "entities": [
      {
        "text": "在州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "遷南郡",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000045",
    "sentence": "郡濱帶江沔，又有雲夢藪澤，永初中，多虎狼之暴，前太守賞募張捕，反為所害者甚眾。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000046",
    "sentence": "雄乃移書屬縣曰：「凡虎狼之在山林，猶人之居城市。古者至化之世，猛獸不擾，皆由恩信寬澤，仁及飛走。太守雖不德，敢忘斯義。記到，其毀壞檻阱，不得妄捕山林。」是後虎害稍息，人以獲安。",
    "entities": [
      {
        "text": "雄乃移書屬縣",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "猶人之居城",
        "label": "LOC",
        "start": 17,
        "end": 22
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 48,
        "end": 50
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000047",
    "sentence": "在郡數歲，歲常豐稔。",
    "entities": [
      {
        "text": "在郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000048",
    "sentence": "元初中卒官。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 0,
        "end": 1
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000049",
