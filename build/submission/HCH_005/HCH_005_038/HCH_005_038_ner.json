      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000057",
    "sentence": "燿、顯軍敗，為賊所殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000058",
    "sentence": "又陰陵人徐鳳、馬勉等復寇郡縣，殺略吏人。",
    "entities": [
      {
        "text": "馬勉等復寇郡縣",
        "label": "LOC",
        "start": 7,
