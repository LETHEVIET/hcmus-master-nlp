      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000096",
    "sentence": "時天下飢饉，帑藏虛盡，每出征伐，常減公卿奉祿，假王侯租賦，前後所遣將帥，宦官輒陷以折耗軍資，往往抵罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000097",
    "sentence": "緄性烈直，不行賄賂，懼為所中，乃上疏曰：「埶得容姦，伯夷可疑；苟曰無猜，盜跖可信。故樂羊陳功，文侯示以謗書。願請中常侍一人監軍財費。」尚書朱穆奏緄以財自嫌，失大臣之節。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 67,
        "end": 69
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000098",
    "sentence": "有詔勿劾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000099",
    "sentence": "緄軍至長沙，賊聞，悉詣營道乞降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000100",
    "sentence": "進擊武陵蠻夷，斬首四千餘級，受降十餘萬人，荊州平定。",
    "entities": [
      {
        "text": "荊州",
        "label": "LOC",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000101",
    "sentence": "詔書賜錢一億，固讓不受。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000102",
    "sentence": "振旅還京師，推功於從事中郎應奉，薦以為司隸校尉，而上書乞骸骨，朝廷不許。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000103",
    "sentence": "監軍使者張敞承宦官旨，奏緄將傅婢二人戎服自隨，又輒於江陵刻石紀功，請下吏案理。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000104",
    "sentence": "尚書令黃雋奏議，以為罪無正法，不合致糾。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000105",
    "sentence": "會長沙賊復起，攻桂陽、武陵，緄以軍還盜賊復發，策免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000106",
    "sentence": "頃之，拜將作大匠，轉河南尹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000107",
    "sentence": "上言「舊典，中官子弟不得為牧人職」，帝不納。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000108",
    "sentence": "復為廷尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000109",
    "sentence": "時山陽太守單遷以罪繫獄，緄考致其死。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000110",
    "sentence": "遷，故車騎將軍單超之弟，中官相黨，遂共誹章誣緄，坐與司隸校尉李膺、大司農劉祐俱輸左校。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000111",
    "sentence": "應奉上疏理緄等，得免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000112",
    "sentence": "後拜屯騎校尉，復為廷尉，卒於官。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000113",
    "sentence": "緄弟允，清白有孝行，能理尚書，善推步之術。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000114",
    "sentence": "拜降虜校尉，終於家。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000115",
    "sentence": "度尚",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000116",
    "sentence": "度尚字博平，山陽湖陸人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000117",
    "sentence": "家貧，不修學行，不為鄉里所推舉。",
    "entities": [
      {
        "text": "不為鄉",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000118",
    "sentence": "積困窮，乃為宦者同郡侯覽視田，得為郡上計吏，拜郎中，除上虞長。",
    "entities": [
      {
        "text": "乃為宦者同郡",
        "label": "LOC",
        "start": 4,
        "end": 10
      },
      {
        "text": "得為郡",
        "label": "LOC",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000119",
    "sentence": "為政嚴峻，明於發擿姦非，吏人謂之神明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000120",
    "sentence": "遷文安令，遇時疾疫，穀貴人飢，尚開倉稟給，營救疾者，百姓蒙其濟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000121",
    "sentence": "時冀州刺史朱穆行部，見尚甚奇之。",
    "entities": [
      {
        "text": "時冀州",
        "label": "LOC",
        "start": 0,
