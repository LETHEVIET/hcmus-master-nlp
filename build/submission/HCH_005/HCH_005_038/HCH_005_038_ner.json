      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000050",
    "sentence": "滕撫",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000051",
    "sentence": "滕撫字叔輔，北海劇人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000052",
    "sentence": "初仕州郡，稍遷為涿令，有文武才用。",
    "entities": [
      {
        "text": "初仕州郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000053",
    "sentence": "太守以其能，委任郡職，兼領六縣。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "委任郡",
        "label": "LOC",
