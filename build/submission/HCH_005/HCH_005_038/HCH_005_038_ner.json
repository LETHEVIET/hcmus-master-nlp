        "end": 47
      },
      {
        "text": "二郡",
        "label": "LOC",
        "start": 52,
        "end": 54
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000123",
    "sentence": "遣御史中丞盛修募兵討之，不能剋。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000124",
    "sentence": "豫章艾縣人六百餘人，應募而不得賞直，怨恚，遂反，焚燒長沙郡縣，寇益陽，殺縣令，眾漸盛。",
    "entities": [
      {
        "text": "豫章艾縣",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "焚燒長沙郡縣",
        "label": "LOC",
        "start": 24,
        "end": 30
      },
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 36,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000125",
    "sentence": "又遣謁者馬睦，督荊州刺史劉度擊之，軍敗，睦、度奔走。",
    "entities": [
      {
        "text": "督荊州",
        "label": "LOC",
        "start": 7,
        "end": 10
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000126",
    "sentence": "桓帝詔公卿舉任代劉度者，尚書朱穆舉尚，自右校令擢為荊州刺史。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "右校令擢為荊州",
        "label": "LOC",
        "start": 20,
        "end": 27
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000127",
    "sentence": "尚躬率部曲，與同勞逸，廣募雜種諸蠻夷，明設購賞，進擊，大破之，降者數萬人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000128",
    "sentence": "桂陽宿賊渠帥卜陽、潘鴻等畏尚威烈，徙入山谷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000129",
    "sentence": "尚窮追數百里，遂入南海，破其三屯，多獲珍寶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000130",
    "sentence": "而陽、鴻等黨眾猶盛，尚欲擊之，而士卒驕富，莫有鬥志。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000131",
    "sentence": "尚計緩之則不戰，逼之必逃亡，乃宣言卜陽、潘鴻作賊十年，習於攻守，今兵寡少，未易可進，當須諸郡所發悉至，爾乃并力攻之。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 24,
        "end": 26
      },
      {
        "text": "當須諸郡",
        "label": "LOC",
        "start": 42,
        "end": 46
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000132",
    "sentence": "申令軍中，恣聽射獵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000133",
    "sentence": "兵士喜悅，大小皆相與從禽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000134",
    "sentence": "尚乃密使所親客潛焚其營，珍積皆盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000135",
    "sentence": "獵者來還，莫不泣涕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000136",
    "sentence": "尚人人慰勞，深自咎責，因曰：「卜陽等財寶足富數世，諸卿但不并力耳。所亡少少，何足介意！」眾聞咸憤踊，尚敕令秣馬蓐食，明旦，徑赴賊屯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000137",
    "sentence": "陽、鴻等自以深固，不復設備，吏士乘銳，遂大破平之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000138",
    "sentence": "尚出兵三年，群寇悉定。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000139",
    "sentence": "七年，封右鄉侯，遷桂陽太守。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "封右鄉",
        "label": "LOC",
        "start": 3,
        "end": 6
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000140",
    "sentence": "明年，徵還京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000141",
    "sentence": "時荊州兵朱蓋等，征戍役久，財賞不贍，忿恚，復作亂，與桂陽賊胡蘭等三千餘人復攻桂陽，焚燒郡縣，太守任胤棄城走，賊眾遂至數萬。",
    "entities": [
      {
        "text": "時荊州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "焚燒郡縣",
        "label": "LOC",
        "start": 41,
        "end": 45
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 46,
        "end": 48
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000142",
    "sentence": "轉攻零陵，太守陳球固守拒之。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000143",
    "sentence": "於是以尚為中郎將，將幽、冀、黎陽、烏桓步騎二萬六千人救球，又與長沙太守抗徐等發諸郡兵，并埶討擊，大破之，斬蘭等首三千五百級，餘賊走蒼梧。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 5,
        "end": 8
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000144",
    "sentence": "詔賜尚錢百萬，餘人各有差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000145",
    "sentence": "時抗徐與尚俱為名將，數有功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000146",
    "sentence": "徐字伯徐，丹陽人，鄉邦稱其膽智。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000147",
    "sentence": "初試守宣城長，悉移深林遠藪椎髻鳥語之人置於縣下，由是境內無復盜賊。",
    "entities": [
      {
        "text": "初試守宣城",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "鳥語之人置於縣",
        "label": "LOC",
        "start": 15,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000148",
    "sentence": "後為中郎將宗資別部司馬，擊太山賊公孫舉等，破平之，斬首三千餘級，封烏程東鄉侯五百戶。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 2,
        "end": 5
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "封烏程東鄉",
        "label": "LOC",
        "start": 32,
        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000149",
    "sentence": "遷太山都尉，寇盜望風奔亡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000150",
    "sentence": "及在長沙，宿賊皆平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000151",
    "sentence": "卒於官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000152",
    "sentence": "桓帝下詔追增封徐五百戶，并前千戶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000153",
    "sentence": "復以尚為荊州刺史。",
    "entities": [
      {
        "text": "復以尚為荊州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000154",
    "sentence": "尚見胡蘭餘黨南走蒼梧，懼為己負，乃偽上言蒼梧賊入荊州界，於是徵交阯刺史張磐下廷尉。",
    "entities": [
      {
        "text": "言蒼梧賊入荊州",
        "label": "LOC",
        "start": 19,
        "end": 26
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000155",
    "sentence": "辭狀未正，會赦見原。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000156",
    "sentence": "磐不肯出獄，方更牢持械節，獄吏謂磐曰：「天恩曠然而君不出，何乎？」磐因自列曰：「前長沙賊胡蘭作難荊州，餘黨散入交阯。磐身嬰甲冑，涉危履險，討擊凶患，斬殄渠帥，餘盡鳥竄冒遁，還奔荊州。刺史度尚懼磐先言，怖畏罪戾，伏奏見誣。磐備位方伯，為國爪牙，而為尚所枉，受罪牢獄。夫事有虛實，法有是非。磐實不辜，赦無所除。如忍以苟免，永受侵辱之恥，生為惡吏，死為敝鬼。乞傳尚詣廷尉，面對曲直，足明真偽。尚不徵者，磐埋骨牢檻，終不虛出，望塵受枉。」廷尉以其狀上，詔書徵尚到廷尉，辭窮受罪，以先有功得原。",
    "entities": [
      {
        "text": "賊胡蘭作難荊州",
        "label": "LOC",
        "start": 43,
        "end": 50
      },
      {
        "text": "還奔荊州",
        "label": "LOC",
        "start": 86,
        "end": 90
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 91,
        "end": 93
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000157",
    "sentence": "磐字子石，丹陽人，以清白稱，終於廬江太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000158",
    "sentence": "尚後為遼東太守，數月，鮮卑率兵攻尚，與戰，破之，戎狄憚畏。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000159",
    "sentence": "年五十， 延熹九年 ，卒於官。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000160",
    "sentence": "楊琁",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000161",
    "sentence": "楊琁字機平，會稽烏傷人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000162",
    "sentence": "高祖父茂，本河東人，從光武征伐，為威寇將軍，封烏傷新陽鄉侯。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 19,
        "end": 21
      },
      {
        "text": "封烏傷新陽鄉",
        "label": "LOC",
        "start": 22,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000163",
    "sentence": "建武中就國，傳封三世，有罪國除，因而家焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000164",
    "sentence": "父扶，交阯刺史，有理能名。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000165",
    "sentence": "兄喬，為尚書，容儀偉麗，數上言政事，桓帝愛其才貌，詔妻以公主，喬固辭不聽，遂閉口不食，七日而死。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000166",
    "sentence": "琁初舉孝廉，稍遷，靈帝時為零陵太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000167",
    "sentence": "是時蒼梧、桂陽猾賊相聚，攻郡縣，賊眾多而琁力弱，吏人憂恐。",
    "entities": [
      {
        "text": "攻郡縣",
        "label": "LOC",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000168",
    "sentence": "琁乃特制馬車數十乘，以排囊盛石灰於車上，繫布索於馬尾，又為兵車，專彀弓弩，剋共會戰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000169",
    "sentence": "乃令馬車居前，順風鼓灰，賊不得視，因以火燒布，然馬驚，奔突賊陣，因使後車弓弩亂發，鉦鼓鳴震。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000170",
    "sentence": "群盜波駭破散，追逐傷斬無數，梟其渠帥，郡境以清。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000171",
    "sentence": "荊州刺史趙凱，誣奏琁實非身破賊，而妄有其功。",
    "entities": [
      {
        "text": "荊州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000172",
    "sentence": "琁與相章奏，凱有黨助，遂檻車徵琁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000173",
    "sentence": "防禁嚴密，無由自訟，乃噬臂出血，書衣為章，具陳破賊形埶，及言凱所誣狀，潛令親屬詣闕通之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000174",
    "sentence": "詔書原琁，拜議郎，凱反受誣人之罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000175",
    "sentence": "琁三遷為勃海太守，所在有異政，以事免。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000176",
    "sentence": "後尚書令張溫特表薦之，徵拜尚書僕射。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 1,
        "end": 3
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000177",
    "sentence": "以病乞骸骨，卒於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000178",
    "sentence": "史論",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000179",
    "sentence": "論曰：安順以後，風威稍薄，寇攘寖橫，緣隙而生，剽人盜邑者不闋時月，假署皇王者蓋以十數。",
    "entities": [
      {
        "text": "剽人盜邑",
        "label": "LOC",
        "start": 23,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000180",
    "sentence": "或託驗神道，或矯妄冕服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000181",
    "sentence": "然其雄渠魁長，未有聞焉，猶至壘盈四郊，奔命首尾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000182",
    "sentence": "若夫數將者，並宣力勤慮，以勞定功，而景風之賞未甄，膚受之言互及。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000183",
    "sentence": "以此而推，政道難乎以免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000184",
    "sentence": "贊曰：張宗裨禹，敢殿後拒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000185",
