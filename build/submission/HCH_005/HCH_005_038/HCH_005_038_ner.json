      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000059",
    "sentence": "鳳衣絳衣，帶黑綬，稱「無上將軍」，勉皮冠黃衣，帶玉印，稱「黃帝」，築營於當塗山中。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000060",
    "sentence": "乃建年號，置百官，遣別帥黃虎攻沒合肥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000061",
    "sentence": "明年，廣陵賊張嬰等復聚眾數千人反，據廣陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000062",
    "sentence": "朝廷博求將帥，三公舉撫有文武才，拜為九江都尉，與中郎將趙序助馮緄合州郡兵數萬人共討之。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 24,
        "end": 27
      },
      {
        "text": "趙序助馮緄合州",
        "label": "LOC",
        "start": 27,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000063",
    "sentence": "又廣開賞募，錢、邑各有差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000064",
    "sentence": "梁太后慮群賊屯結，諸將不能制，又議遣太尉李固。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000065",
    "sentence": "未及行，會撫等進擊，大破之，斬馬勉、范容、周生等千五百級，徐鳳遂將餘眾攻燒東城縣。",
    "entities": [
      {
        "text": "將餘眾攻燒東城",
        "label": "LOC",
        "start": 32,
        "end": 39
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000066",
    "sentence": "下邳人謝安應募，率其宗親設伏擊鳳，斬之，封安為平鄉侯，邑三千戶。",
    "entities": [
      {
        "text": "封安為平鄉",
        "label": "LOC",
        "start": 20,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000067",
    "sentence": "拜撫中郎將，督揚徐二州事。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 2,
        "end": 5
      },
      {
        "text": "督揚徐二州",
        "label": "LOC",
        "start": 6,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000068",
    "sentence": "撫復進擊張嬰，斬獲千餘人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000069",
    "sentence": "趙序坐畏懦不進，詐增首級，徵還棄市。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000070",
    "sentence": "又歷陽賊華孟自稱「黑帝」，攻九江，殺郡守。",
    "entities": [
      {
        "text": "殺郡",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000071",
    "sentence": "撫乘勝進擊，破之，斬孟等三千八百級，虜獲七百餘人，牛馬財物不可勝筭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000072",
    "sentence": "於是東南悉平，振旅而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000073",
    "sentence": "以撫為左馮翊，除一子為郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000074",
    "sentence": "撫所得賞賜，盡分於麾下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000075",
    "sentence": "性方直，不交權埶，宦官懷忿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000076",
    "sentence": "及論功當封，太尉胡廣時錄尚書事，承旨奏黜撫，天下怨之。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000077",
    "sentence": "卒於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000078",
    "sentence": "馮緄",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000079",
    "sentence": "馮緄字鴻卿，巴郡宕渠人也，少學春秋、司馬兵法。",
    "entities": [
      {
        "text": "巴郡",
        "label": "LOC",
        "start": 6,
        "end": 8
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000080",
    "sentence": "父煥，安帝時為幽州刺史，疾忌姦惡，數致其罪。",
    "entities": [
      {
        "text": "安帝時為幽州",
        "label": "LOC",
        "start": 3,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000081",
    "sentence": "時玄菟太守姚光亦失人和。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000082",
    "sentence": "建光元年 ，怨者乃詐作璽書譴責煥、光，賜以歐刀。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000083",
    "sentence": "又下遼東都尉龐奮使速行刑，奮即斬光收煥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000084",
    "sentence": "煥欲自殺，緄疑詔文有異，止煥曰：「大人在州，志欲去惡，實無它故，必是凶人妄詐，規肆姦毒。願以事自上，甘罪無晚。」煥從其言，上書自訟，果詐者所為，徵奮抵罪。",
    "entities": [
      {
        "text": "大人在州",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000085",
    "sentence": "會煥病死獄中，帝愍之，賜煥、光錢各十萬，以子為郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000086",
    "sentence": "緄由是知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000087",
    "sentence": "家富好施，賑赴窮急，為州里所歸愛。",
    "entities": [
      {
        "text": "為州",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000088",
    "sentence": "初舉孝廉，七遷為廣漢屬國都尉，徵拜御史中丞。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000089",
    "sentence": "順帝末，以緄持節督揚州諸郡軍事，與中郎將滕撫擊破群賊，遷隴西太守。",
    "entities": [
      {
        "text": "以緄持節督揚州",
        "label": "LOC",
        "start": 4,
        "end": 11
      },
      {
        "text": "諸郡",
        "label": "LOC",
        "start": 11,
        "end": 13
      },
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 17,
        "end": 20
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000090",
    "sentence": "後鮮卑寇邊，以緄為遼東太守，曉喻降集，虜皆弭散。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000091",
    "sentence": "徵拜京兆尹，轉司隸校尉，所在立威刑。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000092",
    "sentence": "遷廷尉、太常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_038_000093",
    "sentence": "時長沙蠻寇益陽，屯聚積久，至延熹五年，眾轉盛，而零陵蠻賊復反應之，合二萬餘人，攻燒城郭，殺傷長吏。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 16,
        "end": 18
      },
      {
        "text": "攻燒城",
        "label": "LOC",
        "start": 39,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000094",
    "sentence": "又武陵蠻夷悉反，寇掠江陵閒，荊州刺史劉度、南郡太守李肅並奔走荊南，皆沒。",
    "entities": [
      {
        "text": "荊州",
        "label": "LOC",
        "start": 14,
        "end": 16
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "南郡",
        "label": "LOC",
        "start": 21,
        "end": 23
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000095",
    "sentence": "於是拜緄為車騎將軍，將兵十餘萬討之，詔策緄曰：「蠻夷猾夏，久不討攝，各焚都城，蹈籍官人。州郡將吏，死職之臣，相逐奔竄，曾不反顧，可愧言也。將軍素有威猛，是以擢授六師。前代陳湯、馮、傅之徒，以寡擊眾，郅支、夜郎、樓蘭之戎，頭懸都街，衛、霍北征，功列金石，是皆將軍所究覽也。今非將軍，誰與修復前跡？進赴之宜，權時之策，將軍一之，出郊之事，不復內御。已命有司祖于國門。詩不云乎：『進厥虎臣，闞如虓虎，敷敦淮濆，仍執醜虜。』將軍其勉之！」",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
