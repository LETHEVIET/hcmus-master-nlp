      }
    ]
  },
  {
    "sentence_id": "HCH_005_038_000122",
    "sentence": "延熹五年 ，長沙、零陵賊合七八千人，自稱「將軍」，入桂陽、蒼梧、南海、交阯，交阯刺史及蒼梧太守望風逃奔，二郡皆沒。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
