[
  {
    "sentence_id": "HCH_005_077_000001",
    "sentence": "漢承戰國餘烈，多豪猾之民。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000002",
    "sentence": "其並兼者則陵橫邦邑，桀健者則雄張閭里。",
    "entities": [
      {
        "text": "兼者則陵橫邦邑",
        "label": "LOC",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000003",
    "sentence": "且宰守曠遠，戶口殷大。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000004",
    "sentence": "故臨民之職，專事威斷，族滅姦軌，先行後聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000005",
    "sentence": "肆情剛烈，成其不橈之威。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000006",
    "sentence": "違眾用己，表其難測之智。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000007",
    "sentence": "至於重文橫入，為窮怒之所遷及者，亦何可勝言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000008",
    "sentence": "故乃積骸滿穽，漂血十里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000009",
    "sentence": "致溫舒有虎冠之吏，延年受屠伯之名，豈虛也哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000010",
    "sentence": "若其揣挫強傷，摧勒公卿，碎裂頭腦而不顧，亦為壯也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000011",
    "sentence": "自中興以後，科網稍密，吏人之嚴害者，方於前世省矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000012",
    "sentence": "而閹人親婭，侵虐天下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000013",
    "sentence": "至使陽球磔王甫之屍，張儉剖曹節之墓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000014",
    "sentence": "若此之類，雖厭快眾憤，亦云酷矣！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000015",
    "sentence": "儉知名，故附《黨人篇》。",
    "entities": [
      {
        "text": "《黨人篇》",
        "label": "TITLE",
        "start": 6,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000016",
    "sentence": "董宣",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000017",
    "sentence": "董宣，字少平，陳留圉人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000018",
    "sentence": "初為司徒侯霸所辟，舉高第，累遷北海相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000019",
    "sentence": "到官，以大姓公孫丹為五官掾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000020",
    "sentence": "丹新造居宅，而卜工以為當有死者，丹乃令其子殺道行人，置屍舍內，以塞其咎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000021",
    "sentence": "宣知，即收丹父子殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000022",
    "sentence": "丹宗族親黨三十餘人，操兵詣府，稱冤叫號。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000023",
    "sentence": "宣以丹前附王莽、慮交通海賊，乃悉收繫劇獄，使門下書佐水丘岑盡殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000024",
    "sentence": "青州以其多濫，奏宣考岑，宣坐徵詣廷尉。",
    "entities": [
      {
        "text": "青州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000025",
    "sentence": "在獄，晨夜諷誦，無憂色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000026",
    "sentence": "及當出刑，​​官屬具饌送之，宣乃厲色曰：「董宣生平未曾食人之食，況死乎！」升車而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000027",
    "sentence": "時，同刑九人，次應及宣，光武馳使騶騎特原宣刑，且令還獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000028",
    "sentence": "遣使者詰宣多殺無辜，宣具以狀對，言水丘岑受臣旨意，罪不由之，願殺臣活岑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000029",
    "sentence": "使者以聞，有詔左轉宣懷令，令青州勿案岑罪。",
    "entities": [
      {
        "text": "令青州",
        "label": "LOC",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000030",
    "sentence": "岑官至司隸校尉。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000031",
    "sentence": "後江夏有劇賊夏喜等寇亂郡境，以宣為江夏太守。",
    "entities": [
      {
        "text": "賊夏喜等寇亂郡",
        "label": "LOC",
        "start": 5,
        "end": 12
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000032",
    "sentence": "到界，移書曰：「朝廷以太守能禽奸賊，故辱斯任。今勒兵界首，檄到，幸思自安之宜。」喜等聞，懼，即歸降散。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000033",
    "sentence": "外戚陰氏為郡都尉，宣輕慢之，坐免。",
    "entities": [
      {
        "text": "外戚陰氏為郡",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000034",
    "sentence": "後特徵為洛陽令。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000035",
    "sentence": "時湖陽公主蒼頭白日殺人，因匿主家，吏不能得。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000036",
    "sentence": "及主出行，而以奴驂乘，宣於夏門亭候之，乃駐車叩馬，以刀畫地，大言數主之失，叱奴下車，因格殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000037",
    "sentence": "主即還宮訴帝，帝大怒，召宣，欲箠殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000038",
    "sentence": "宣叩頭曰：「願乞一言而死。」帝曰：「欲何言？」宣曰：「陛下聖德中興，而從奴殺良人，將何以理天下乎？臣不須箠，請得自殺。」即以頭擊楹，流血被面。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000039",
    "sentence": "帝令小黃門持之，使宣叩頭謝主，宣不從，強使頓之，宣兩手據地，終不肯俯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000040",
    "sentence": "主曰：「文叔為白衣時，臧主匿死，吏不敢至門。今為天子，威不能行一令乎？」帝笑曰：「天子不與白衣同。」因敕強項令出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000041",
    "sentence": "賜錢三十萬，宣悉以班諸吏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000042",
    "sentence": "由是搏擊豪強，莫不震栗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000043",
    "sentence": "京師號為「臥虎」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000044",
    "sentence": "歌之曰：「枹鼓不鳴董少平。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000045",
    "sentence": "在縣五年。",
    "entities": [
      {
        "text": "在縣",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000046",
    "sentence": "年七十四，卒於官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000047",
    "sentence": "詔遣使者臨視，唯見布被覆屍，妻子對哭，有大麥數斛、敝車一乘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000048",
    "sentence": "帝傷之，曰：「董宣廉潔，死乃知之！」以宣嘗為二千石，賜艾綬，葬以大夫禮。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000049",
    "sentence": "拜子並為郎中，後官至齊相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000050",
    "sentence": "樊曄",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000051",
    "sentence": "樊曄，字仲華，南陽新野人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000052",
    "sentence": "與光武少游舊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000053",
    "sentence": "建武初，徵為侍御史，遷河東都尉，引見雲臺。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000054",
    "sentence": "初，光武微時，嘗以事拘於新野，曄為市吏，餽餌一笥，帝德之不忘，仍賜曄御食，及乘輿服物。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000055",
    "sentence": "因戲之曰：「一笥餌得都尉，何如？」曄頓首辭謝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000056",
    "sentence": "及至郡，誅討大姓馬適匡等。",
    "entities": [
      {
        "text": "及至郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000057",
    "sentence": "盜賊清，吏人畏之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000058",
    "sentence": "數年，遷楊州牧，教民耕田種樹理家之術。",
    "entities": [
      {
        "text": "遷楊州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000059",
    "sentence": "視事十餘年，坐法左轉積長。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000060",
    "sentence": "隗囂滅後，隴右不安，乃拜曄為天水太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000061",
    "sentence": "政嚴猛，好申、韓法，善惡立斷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000062",
    "sentence": "人有犯其禁者，率不生出獄，吏人及羌胡畏之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000063",
    "sentence": "道不拾遺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000064",
    "sentence": "行旅至夜，聚衣裝道傍，曰「以付樊公」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000065",
    "sentence": "涼州為之歌曰：「遊子常苦貧，力子天所富。寧見乳虎穴，不入冀府寺。大笑期必死，忿怒或見置。嗟我樊府君，安可再遭值！」視事十四年，卒官。",
    "entities": [
      {
        "text": "涼州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "十四年",
        "label": "TME",
        "start": 59,
        "end": 62
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000066",
    "sentence": "永平中，顯宗追思曄在天水時政能，以為後人莫之及，詔賜家錢百萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000067",
    "sentence": "子融，有俊才，好黃、老，不肯為吏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000068",
    "sentence": "李章",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000069",
    "sentence": "李章，字第公，河內懷人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000070",
    "sentence": "五世二千石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000071",
    "sentence": "章習《嚴氏春秋》，經明教授，歷州郡吏。",
    "entities": [
      {
        "text": "《嚴氏春秋》",
        "label": "TITLE",
        "start": 2,
        "end": 8
      },
      {
        "text": "歷州郡",
        "label": "LOC",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000072",
    "sentence": "光武為大司馬，平定河北，召章置江曹屬，數從征伐。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000073",
    "sentence": "光武即位，拜陽平令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000074",
    "sentence": "時趙、魏豪右往往屯聚，清河大姓趙綱遂於縣界起塢壁，繕甲兵，為在所害。",
    "entities": [
      {
        "text": "大姓趙綱遂於縣",
        "label": "LOC",
        "start": 13,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000075",
    "sentence": "章到，乃設饗會，而延謁綱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000076",
    "sentence": "綱帶文劍，被羽衣，從士百餘人來到。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000077",
    "sentence": "章與對宴飲，有頃，手劍斬綱，伏兵亦悉殺其從者，因馳詣塢壁，掩擊破之，吏人遂安。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000078",
    "sentence": "遷千乘太守，坐誅斬盜賊過濫，徵下獄免。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000079",
    "sentence": "歲中拜侍御史，出為琅邪太守。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000080",
    "sentence": "時北海安丘大姓夏長思等反，遂囚太守處興，而據營陵城。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "而據營陵城",
        "label": "LOC",
        "start": 20,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000081",
    "sentence": "章聞，即發兵千人，馳往擊之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000082",
    "sentence": "掾史止章曰：「二千石行不得出界，兵不得擅發。」章按劍怒曰：「逆虜無狀，囚劫郡守，此何可忍！若坐討賊而死，吾不恨也。」遂引兵安丘城下，募勇敢燒城門，與長思戰，斬之，獲三百餘級，得牛馬五百餘頭而還。",
    "entities": [
      {
        "text": "囚劫郡",
        "label": "LOC",
        "start": 35,
        "end": 38
      },
      {
        "text": "遂引兵安丘城",
        "label": "LOC",
        "start": 58,
        "end": 64
      },
      {
        "text": "募勇敢燒城",
        "label": "LOC",
        "start": 66,
        "end": 71
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000083",
    "sentence": "興歸郡，以狀上帝，悉以所得班勞吏士。",
    "entities": [
      {
        "text": "興歸郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000084",
    "sentence": "後坐度人田不實徵，以章有功，但司冠論。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000085",
    "sentence": "月餘免刑，歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000086",
    "sentence": "复徵，會病卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000087",
    "sentence": "周䊸",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000088",
    "sentence": "周䊸，字文通，下邳徐人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000089",
    "sentence": "為人刻削少恩，好韓非之術。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000090",
    "sentence": "少為廷尉史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000091",
    "sentence": "永平中，補南行唐長。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000092",
    "sentence": "到官，曉吏人曰：「朝廷不以長不肖，使牧黎民，而性仇猾吏，志除豪賊，且勿相試！」遂殺縣中尤無狀者數十人，吏人大震。",
    "entities": [
      {
        "text": "遂殺縣",
        "label": "LOC",
        "start": 39,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000093",
    "sentence": "過博平令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000094",
    "sentence": "收考姦臧，無出獄者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000095",
    "sentence": "以威名遷齊相，亦頗嚴酷，專任刑法，而善為辭案條教，為州內所則。",
    "entities": [
      {
        "text": "為州",
        "label": "LOC",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000096",
    "sentence": "後坐殺無辜，复左轉博平令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000097",
    "sentence": "建初中，為勃海太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000098",
    "sentence": "每敕令到郡，輒隱閉不出，先遣使屬縣盡決刑罪，乃出詔書。",
    "entities": [
      {
        "text": "每敕令到郡",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "先遣使屬縣",
        "label": "LOC",
        "start": 12,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000099",
    "sentence": "坐徵詣廷尉，免歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000100",
    "sentence": "䊸廉潔無資，常築墼以自給，肅宗聞而憐之，復以為郎，再遷召陵侯相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000101",
    "sentence": "廷掾憚䊸嚴明，欲損其威，乃晨取死人斷手足，立寺門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000102",
    "sentence": "䊸聞，便往至死人邊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000103",
    "sentence": "若與死人共語狀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000104",
    "sentence": "陰察視口眼有稻芒，乃密問守門人曰：「悉誰載藁入城者？」門者對：「唯有廷掾耳。」又問鈴下：「外頗有疑令與死人語者不？」對曰：「廷掾疑君。」乃收廷掾考問，具服「不殺人，取道邊死人。」後人莫敢欺者。",
    "entities": [
      {
        "text": "悉誰載藁入城",
        "label": "LOC",
        "start": 18,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000105",
    "sentence": "徵拜洛陽令。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000106",
    "sentence": "下車，先問大姓名主，吏數閭里豪強以對，䊸厲聲怒曰：「本問貴戚若馬、竇等輩，豈能知此賣菜傭乎？」於是部吏望風旨，爭以激切為事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000107",
    "sentence": "貴戚跼蹐，京師肅清。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000108",
    "sentence": "皇后弟黃門郎竇篤從宮中歸，夜至止姦亭，亭長霍延遮止篤，篤蒼頭與爭，延遂拔劍擬篤，而肆詈恣口。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000109",
    "sentence": "篤以表聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000110",
    "sentence": "詔召司隸校尉、河南尹詣尚書譴問，遣劍戟士收䊸送廷尉詔獄。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000111",
    "sentence": "數日貰出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000112",
    "sentence": "帝知䊸奉法疾姦，不事貴戚，然苛慘失中，數為有司所奏，八年，遂免官。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000113",
    "sentence": "後為御史中丞。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000114",
    "sentence": "和帝即位，太傅鄧彪奏䊸在任過酷，不宜典司京輦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000115",
    "sentence": "免歸田里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000116",
    "sentence": "後竇氏貴盛，篤兄弟秉權，睚眥宿怨，無不僵僕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000117",
    "sentence": "䊸自謂無全，乃柴門自守，以待其禍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000118",
    "sentence": "然篤等以䊸公正，而怨隙有素，遂不敢害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000119",
    "sentence": "永元五年 ，復徵為御史中丞。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000120",
    "sentence": "諸竇雖誅，而夏陽侯瓌猶尚在朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000121",
    "sentence": "䊸疾之，乃上疏曰：「臣聯臧文仲之事君也，見有禮於君者，事之如孝子之養父母，見無禮於君者，誅之如鷹鸇之逐鳥雀。案夏陽侯瓌，本出輕薄，志在邪僻，學無經術，而妄構講舍，外招儒徒，實會姦桀。輕忽天威，侮慢王室，又造作巡狩封禪上書，惑眾不道，當伏誅戮，而主者營私，不為國計。夫涓流雖寡，浸成江河；爝火雖微，卒能燎野，履霜有漸，可不懲革？宜尋呂產專竊之亂，永惟王莽篡逆之禍，上安社稷之計，下解萬夫之惑。」會瓌歸國，䊸遷司隸校尉。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 205,
        "end": 207
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000122",
    "sentence": "六年夏，旱，車駕自幸洛陽錄囚徒，二人被掠生蟲，坐左轉騎都尉。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000123",
    "sentence": "七年，遷將作大匠。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000124",
    "sentence": "九年，卒於官。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000125",
    "sentence": "黃昌",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000126",
    "sentence": "黃昌，字聖真，會稽餘姚人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000127",
    "sentence": "本出孤微。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000128",
    "sentence": "居近學官，數見諸生修庠序之禮，因好之，遂就經學。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000129",
    "sentence": "又曉習文法，仕郡為決曹。",
    "entities": [
      {
        "text": "仕郡",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000130",
    "sentence": "刺史行部，見昌，甚奇之，辟從事。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000131",
    "sentence": "後拜宛令，政尚嚴猛，好發姦伏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000132",
    "sentence": "人有盜其車蓋者，昌初無所言，後乃密遣親客至門下賊曹家掩取得之，悉收其家，一時殺戮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000133",
    "sentence": "大姓戰懼，皆稱神明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000134",
    "sentence": "朝廷舉能，遷蜀郡太守。",
    "entities": [
      {
        "text": "遷蜀郡",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000135",
    "sentence": "先太守李根年老多悖政，百姓侵冤。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000136",
    "sentence": "及昌到，吏人訟者七百餘人，悉為斷理，莫不得所。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000137",
    "sentence": "密捕盜帥一人，脅使條諸縣強暴之人姓名居處，乃分遣掩討，無有遺脫。",
    "entities": [
      {
        "text": "脅使條諸縣",
        "label": "LOC",
        "start": 7,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000138",
    "sentence": "宿惡大奸，皆奔走他境。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000139",
    "sentence": "初，昌為州書佐，其婦歸寧於家，遇賊被獲，遂流轉入蜀為人妻。",
    "entities": [
      {
        "text": "昌為州",
        "label": "LOC",
        "start": 2,
        "end": 5
      },
      {
        "text": "蜀",
        "label": "ORG",
        "start": 24,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000140",
    "sentence": "妻子犯事，乃詣昌自訟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000141",
    "sentence": "昌疑母不為蜀人，因問所由。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000142",
    "sentence": "對曰：「妾本會稽餘姚戴次公女，州書佐黃昌妻也。妾嘗歸家，為賊所略，遂至於此。」昌驚，呼前謂曰：「何以識黃昌邪？」對曰：「昌左足心有黑子，常自言當為二千石。」昌乃出足示之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000143",
    "sentence": "因相持悲泣，還為夫婦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000144",
    "sentence": "視事四年，徵，再遷陳相。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000145",
    "sentence": "縣人彭氏舊豪縱，造起大舍，高樓臨道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000146",
    "sentence": "昌每出行縣，彭氏婦人輒陞樓而觀。",
    "entities": [
      {
        "text": "昌每出行縣",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000147",
    "sentence": "昌不喜，遂敕收付獄，案殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000148",
    "sentence": "又遷為河內太守，又再遷潁川太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000149",
    "sentence": "永和五年 ，徵拜將作大匠。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000150",
    "sentence": "漢安元年 ，進補大司農，左轉太中大夫，卒於官。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000151",
    "sentence": "陽球",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000152",
    "sentence": "陽球，字方正，漁陽泉州人也。",
    "entities": [
      {
        "text": "漁陽泉州",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000153",
    "sentence": "家世大姓冠蓋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000154",
    "sentence": "球能擊劍，習弓馬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000155",
    "sentence": "性嚴厲，好申、韓之學。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000156",
    "sentence": "郡吏有辱其母者，球結少年數十人，殺吏，滅其家，由是知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000157",
    "sentence": "初舉孝廉，補尚書侍郎，閒達故事，其章奏處議，常為臺閣所崇信。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000158",
    "sentence": "出為高唐令，以嚴苛過理，郡守收舉，會赦見原。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000159",
    "sentence": "辟司徒劉寵府，舉高第。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000160",
    "sentence": "九江山賊起，連月不解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000161",
    "sentence": "三府上球有理姦才，拜九江太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000162",
    "sentence": "球到，設方略，凶賊殄破，收郡中姦吏盡殺之。",
    "entities": [
      {
        "text": "收郡",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000163",
    "sentence": "遷平原相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000164",
    "sentence": "出教曰：「相前蒞高唐，志埽姦鄙，遂為貴郡所見枉舉。昔桓公釋管仲射鉤之仇，高祖赦季布逃亡之罪。雖以不德，敢忘前義。況君臣分定，而可懷宿者哉！今一蠲往愆，期諸來效。若受教之後而不改姦狀者，不得復有所容矣。」郡中咸畏服焉。",
    "entities": [
      {
        "text": "遂為貴郡",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000165",
    "sentence": "時，天下大旱，司空張顥條奏長吏苛酷貪污者，皆罷免之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000166",
    "sentence": "球坐嚴苦，徵詣廷尉，當免官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000167",
    "sentence": "靈帝以球九江時有功，拜議郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000168",
    "sentence": "遷將作大匠，坐事論。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000169",
    "sentence": "頃之，拜尚書令。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000170",
    "sentence": "奏罷鴻都文學，曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000171",
    "sentence": "書奏不省。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000172",
    "sentence": "時，中常侍王甫、曹節等姦虐弄權，扇動外內，球嘗拊髀發憤曰：「若陽球作司隸，此曹子安得容乎？」 光和二年 ，遷為司隸校尉。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 49,
        "end": 51
      },
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 57,
        "end": 59
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000173",
    "sentence": "王甫休沐里舍，球詣闕謝恩，奏收甫及中常侍淳于登、袁赦、封 𦐇 、中黃門劉毅、小黃門龐訓、硃禹、齊盛等，及子弟為守令者，奸猾縱恣，罪合滅族。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000174",
    "sentence": "太尉段颎諂附佞幸，宜並誅戮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000175",
    "sentence": "於是悉收甫、颎等送洛陽獄，及甫子永樂少府萌、沛相吉。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 9,
        "end": 11
      },
      {
        "text": "沛",
        "label": "LOC",
        "start": 22,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000176",
    "sentence": "球自臨考甫等，五毒備極。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000177",
    "sentence": "萌謂球曰：「父子既當伏誅，少以楚毒假借老父。」球曰：「若罪惡無狀，死不滅責，乃欲求假借邪？」萌乃罵曰：「爾前奉事吾父子如奴，如敢反汝主乎！今日困吾，行自及也！」球使以土窒萌口，箠樸交至，父子悉死杖下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000178",
    "sentence": "颎亦自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000179",
    "sentence": "乃僵磔甫屍於夏城門，大署榜曰「賊臣王甫」。",
    "entities": [
      {
        "text": "僵磔甫屍於夏城",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000180",
    "sentence": "盡沒入財產，妻、子皆徙比景。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000181",
    "sentence": "球既誅甫，复欲以次表曹節等，乃敕中都官從事曰：「且先去大猾，當次案豪右。」權門聞之，莫不屏氣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000182",
    "sentence": "諸奢飾之物，皆各緘滕，不敢陳設。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000183",
    "sentence": "京師畏震。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000184",
    "sentence": "時，順帝虞貴人葬，百官會喪還，曹節見磔甫屍道次，慨然抆淚曰：「我曹自可相食，何宜使犬舐其汁乎？」語諸常侍，今且俱入，勿過里舍也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000185",
    "sentence": "節直入省，白帝曰：「陽球故酷暴吏，前三府奏當免官，以九江微功，復見擢用。愆過之人，好為妄作，不宜使在司隸，以騁毒虐。」帝乃徙球為衛尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000186",
    "sentence": "時，球出謁陵，節敕尚書令召拜，不得稽留尺一。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000187",
    "sentence": "球被召急，因求見帝，叩頭曰：「臣無清高之行，橫蒙鷹犬之任。前雖糾誅王甫、段颎、蓋簡落狐狸，未足宣示天下。願假臣一月，必令豺狼鴟梟，各服其辜。」叩頭流血。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000188",
    "sentence": "殿上呵叱曰：「衛尉扞詔邪！」至於再三，乃受拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000189",
    "sentence": "其冬，司徒劉郃與球議收案張讓、曹節，節等知之，共誣白郃等。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000190",
    "sentence": "語已見《陳球傳》。",
    "entities": [
      {
        "text": "《陳球傳》",
        "label": "TITLE",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000191",
    "sentence": "遂收球送洛陽獄，誅死，妻、子徙邊。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000192",
    "sentence": "王吉",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000193",
    "sentence": "王吉者，陳留浚儀人，中常侍甫之養子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000194",
    "sentence": "甫在《宦者傳》。",
    "entities": [
      {
        "text": "《宦者傳》",
        "label": "TITLE",
        "start": 2,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000195",
    "sentence": "吉少好誦讀書傳，喜名聲，而性殘忍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000196",
    "sentence": "以父秉權寵，年二十餘，為沛相。",
    "entities": [
      {
        "text": "沛",
        "label": "LOC",
        "start": 12,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000197",
    "sentence": "曉達政事，能斷察疑獄，發起姦伏，多出眾議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000198",
    "sentence": "課使郡內各舉姦吏豪人諸常有微過酒肉為臧者，雖數十年猶如貶棄，注其名籍。",
    "entities": [
      {
        "text": "課使郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "十年",
        "label": "TME",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000199",
    "sentence": "專選剽悍吏，擊斷非法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000200",
    "sentence": "若有生子不養，即斬其父母，合土棘埋之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000201",
    "sentence": "凡殺人皆磔屍車上，隨其罪目，宣示屬縣。",
    "entities": [
      {
        "text": "宣示屬縣",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000202",
    "sentence": "夏月腐爛，則以繩連其骨，周遍一郡乃止，見者駭懼。",
    "entities": [
      {
        "text": "周遍一郡",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000203",
    "sentence": "視事五年，凡殺萬餘人。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000204",
    "sentence": "其餘慘毒刺刻，不可勝數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000205",
    "sentence": "郡中惴恐，莫敢自保。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000206",
    "sentence": "及陽球奏甫，乃就收執，死於洛陽獄。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000207",
    "sentence": "【史論】",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000208",
    "sentence": "論曰：古者敦庬，善惡易分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000209",
    "sentence": "至於畫衣冠，異服色，而莫之犯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000210",
    "sentence": "叔世偷薄，上下相蒙，德義不足以相洽，化導不能以懲違，遂乃嚴刑痛殺，隨而繩之，致刻深之吏，以暴理姦，倚疾邪之公直，濟忍苛之虐情。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000211",
    "sentence": "漢世所謂酷能者，蓋有聞也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000212",
    "sentence": "皆以敢捍精敏，巧附文理，風行霜烈，威譽喧赫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000213",
    "sentence": "與夫斷斷守道之吏，何工否之殊乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000214",
    "sentence": "故嚴君蚩黃霸之術，密人笑卓茂之政，猛既窮矣，而猶或未勝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000215",
    "sentence": "然硃邑不以笞辱加物，袁安未嘗鞫人臧罪，而猾惡自禁，人不敢犯。",
    "entities": [
      {
        "text": "然硃邑",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_077_000216",
    "sentence": "何者？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000217",
    "sentence": "以為威辟既用，而苟免這行興；仁信道孚，故感被之情著。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000218",
    "sentence": "苟免者威隙則姦起，感被者人亡而思存。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000219",
    "sentence": "由一邦以言天下，則刑訟繁措，可得而求乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000220",
    "sentence": "贊曰：大道既往，刑禮為薄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000221",
    "sentence": "斯人斯矣，機詐萌作。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000222",
    "sentence": "去殺由仁，濟寬非虐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_077_000223",
    "sentence": "末暴雖勝，崇本或略。",
    "entities": []
  }
]
