      }
    ]
  },
  {
    "sentence_id": "HCH_005_035_000109",
    "sentence": "進為設几杖，禮待甚優。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_035_000110",
    "sentence": "玄不受朝服，而以幅巾見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_035_000111",
    "sentence": "一宿逃去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_035_000112",
    "sentence": "時年六十，弟子河內趙商等自遠方至者數千。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_035_000113",
    "sentence": "後將軍袁隗表為侍中，以父喪不行。",
