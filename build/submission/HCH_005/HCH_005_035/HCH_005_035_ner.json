        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_035_000009",
    "sentence": "反又將兵屯田南陽，遷五官中郎將。",
    "entities": [
      {
        "text": "中郎將",
