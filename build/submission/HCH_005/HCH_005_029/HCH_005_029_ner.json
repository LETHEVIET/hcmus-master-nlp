      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000197",
    "sentence": "壽雖威嚴，而推誠下吏，皆願效死，莫有欺者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000198",
