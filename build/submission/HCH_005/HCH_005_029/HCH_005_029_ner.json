        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000171",
    "sentence": "帝嘗出獵，車駕夜還，惲拒關不開。",
    "entities": [
      {
        "text": "惲拒關",
        "label": "LOC",
