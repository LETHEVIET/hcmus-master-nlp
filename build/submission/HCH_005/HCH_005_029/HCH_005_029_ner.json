[
  {
    "sentence_id": "HCH_005_029_000001",
    "sentence": "申屠剛",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000002",
    "sentence": "申屠剛字巨卿，扶風茂陵人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000003",
    "sentence": "七世祖嘉，文帝時為丞相。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000004",
    "sentence": "剛質性方直，常慕史䲡、汲黯之為人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000005",
    "sentence": "仕郡功曹。",
    "entities": [
      {
        "text": "仕郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000006",
    "sentence": "平帝時，王莽專政，朝多猜忌，遂隔絕帝外家馮、衛二族，不得交宦，剛常疾之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000007",
    "sentence": "及舉賢良方正，因對策曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000008",
    "sentence": "臣聞王事失則神祇怨怨，奸邪亂正，故陰陽謬錯，此天所以譴告王者，欲令失道之君，曠然覺悟，懷邪之臣，懼然自刻者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000009",
    "sentence": "今朝廷不考功校德，而虛納毀譽，數下詔書，張設重法，抑斷誹謗，禁割論議，罪之重者，乃至腰斬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000010",
    "sentence": "傷忠臣之情，挫直士之銳，殆乖建進善之旌，縣敢諫之鼓，辟四門之路，明四目之義也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000011",
    "sentence": "臣聞成王幼少，周公攝政，聽言不賢，均權市寵，無舊無新，唯仁是親，動順天地，舉措不失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000012",
    "sentence": "然近則召公不悅，遠則四國流言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000013",
    "sentence": "夫子母之性，天道至親。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000014",
    "sentence": "今聖主幼少，始免繈褓，即位以來，至親分離，外戚杜隔，恩不得通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000015",
    "sentence": "且漢家之制，雖任英賢，猶援姻戚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000016",
    "sentence": "親疏相錯，杜塞間隙，誠所以安宗廟，重社稷也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000017",
    "sentence": "今馮、衛無罪，久廢不錄，或處窮僻，不若民庶，誠非慈愛忠孝承上之意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000018",
    "sentence": "夫為人後者，自有正義，至尊至卑，其勢不嫌，是以人無賢愚，莫不為怨，奸臣賊子，以之為便，不諱之變，誠難其慮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000019",
    "sentence": "今之保傅，非古之周公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000020",
    "sentence": "周公至聖，猶尚有累，何況事失其衷，不合天心者哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000021",
    "sentence": "昔周公先遣伯禽守封於魯，以義寒恩，寵不加後，故配天郊祀，三十餘世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000022",
    "sentence": "霍光秉政，輔翼少主，修善進士，名為忠直，而尊崇其宗黨，摧抑外戚，結貴據權，至堅至固，終沒之後，受禍滅門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000023",
    "sentence": "方今師傅皆以伊、周之位，據賢保之任，以此思化，則功何不至？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000024",
    "sentence": "不思其危，則禍何不到？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000025",
    "sentence": "損益之際，孔父攸嘆，持滿之戒，老氏所慎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000026",
    "sentence": "蓋功冠天下者不安，威震人主者不全。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000027",
    "sentence": "今承衰亂之後，繼重敝之世，公家屈竭，賦斂重數，苛吏奪其時，貪夫侵其財，百姓困乏，疾疫夭命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000028",
    "sentence": "盜賊群輩，且以萬數，軍行眾止，竊號自立，攻犯京師，燔燒縣邑，至乃訛言積弩入宮，宿衛驚懼。",
    "entities": [
      {
        "text": "燔燒縣邑",
        "label": "LOC",
        "start": 25,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000029",
    "sentence": "自漢興以來，誠未有也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000030",
    "sentence": "國家微弱，奸謀不禁，六極之效，危於累卵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000031",
    "sentence": "王者承天順地，典爵主刑，不敢以天官私其宗，不敢以天罰輕其親。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000032",
    "sentence": "陛下宜遂聖明之德，昭然覺悟，遠述帝王之跡，近遵孝文之業，差五品之屬，納至親之序，亟遣使者徵中山太后，置之別官，令時朝見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000033",
    "sentence": "又召馮、衛二族，裁與冗職，使得執戟，親奉宿衛，以防未然之符，以抑患禍之端，上安社稷，下全保傅，內和親戚，外絕邪謀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000034",
    "sentence": "書奏，莽令元后下詔曰：『剛聽言僻經妄說，違背大義。其罷歸田里。』",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000035",
    "sentence": "後莽篡位，剛遂避地河西，轉入巴、蜀，往來二十許年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000036",
    "sentence": "及隗囂據隴右，欲背漢而附公孫述。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000037",
    "sentence": "剛說之曰：『愚聞人所歸者天所與，人所畔者天所去也。伏念本朝躬聖德，舉義兵，龔行天罰，所當必摧，誠天之所福，非人力也。將軍本無尺土，孤立一隅，宜推誠奉順，與朝並力，上應天心，下酬人望，為國立功，可以永年。嫌疑之事，聖人所絕。以將軍之威重，遠在千里，動作舉措，可不慎與？今璽書數到，委國歸信，欲與將軍共同吉兇。布衣相與，尚有沒身不負然諾之信，況於萬乘者哉！今何畏何利，久疑如是？卒有非常之變，上負忠孝，下愧當世。夫未至豫言，固常為虛，及其已至，又無所及，是以忠言至諫，希得為用。誠願反復愚老之言。』囂不納，遂畔從述。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 58,
        "end": 60
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 112,
        "end": 114
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 146,
        "end": 148
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000038",
    "sentence": "建武七年 ，詔書徵剛。",
    "entities": [
      {
        "text": "建武七年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000039",
    "sentence": "剛將歸，與囂書曰：『愚聞專己者孤，拒諫者塞，孤塞之政，亡國之風也。雖有明聖之姿，猶屈己從眾，故慮無遺策，舉無過事。夫聖人不以獨見為明，而以萬物為心。順人者昌，逆人者亡，此古今之所共也。將軍以布衣為鄉裏所推，廊廟之計，既不豫定，動軍發眾，又不深料。今東方政教日睦，百姓平安，而西州發兵，人人憂憂，騷動惶懼，莫敢正言，群眾疑惑，人懷顧望。非徒無精銳之心，其患無所不至。夫物窮則變生，事急則計易，其勢然也。夫離道德，逆人情，而能有國有家者，古今未有也。將軍素以忠孝顯聞，是以士大夫不遠千里，慕樂德義。今茍欲決意僥幸，此何如哉？夫天所祐者順，人所助者信。如未蒙祐助，令小人受塗地之禍，毀壞終身之德，敗亂君臣之節，汙傷父子之恩，眾賢破膽，可不慎哉！』囂不納。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 92,
        "end": 94
      },
      {
        "text": "而西州",
        "label": "LOC",
        "start": 136,
        "end": 139
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 223,
        "end": 225
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 235,
        "end": 237
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000040",
    "sentence": "剛到，拜侍御史，遷尚書令。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000041",
    "sentence": "光武嘗欲出遊，剛以隴蜀未平，不宜宴安逸豫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000042",
    "sentence": "諫不見聽，遂以頭軔乘輿輪，帝遂為止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000043",
    "sentence": "時內外群官，多帝自選舉，加以法理嚴察，職事過苦，尚書近臣，乃至捶撲牽曳於前，群臣莫敢正言。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000044",
    "sentence": "剛每輒極諫，又數言皇太子宜時就東宮，簡任賢保，以成其德，帝並不納。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000045",
    "sentence": "以數切諫失旨，數年，出為平陰令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000046",
    "sentence": "復徵拜太中大夫，以病去官，卒於家。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000047",
    "sentence": "鮑永",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000048",
    "sentence": "鮑永字君長，上黨屯留人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000049",
    "sentence": "父宣，哀帝時任司隸校尉，為王莽所殺。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000050",
    "sentence": "永少有志操，習歐陽《尚書》。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000051",
    "sentence": "事後母至孝，妻嘗於母前叱狗，而永即去之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000052",
    "sentence": "初為郡功曹。",
    "entities": [
      {
        "text": "初為郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000053",
    "sentence": "莽以宣不附己，欲不其子孫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000054",
    "sentence": "都尉路平承望風旨，規欲害永。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000055",
    "sentence": "太守茍諫擁護，召以為吏，常置府中，永因數為諫陳興復漢室，剪滅篡逆之策。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000056",
    "sentence": "諫每戒永曰：『君長幾事不密，禍倚人門。』永感其言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000057",
    "sentence": "及諫卒，自送喪歸扶風，路平遂收永弟升。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000058",
    "sentence": "太守趙興到，聞乃嘆曰：『我受漢茅土，不能立節，而鮑宣死之，豈可害其子也！』敕縣出升，復署永功曹。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "敕縣",
        "label": "LOC",
        "start": 37,
        "end": 39
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000059",
    "sentence": "時，有矯稱侍中止傳舍者，興欲謁之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000060",
    "sentence": "永疑其詐，諫不聽而出，興遂駕往，永乃拔佩刀截馬當匈，乃止，後數日，莽詔書果下捕矯稱者，永由是知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000061",
    "sentence": "舉秀才，不應。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000062",
    "sentence": "更始二年 徵，再遷尚書僕射，行大將軍事，持節將兵，安集河東、并州、朔部，得自置偏裨，輒行軍法。",
    "entities": [
      {
        "text": "更始二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 15,
        "end": 18
      },
      {
        "text": "并州",
        "label": "LOC",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000063",
    "sentence": "永至河東，因擊青犢，大破之，更始封為中陽侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000064",
    "sentence": "永雖為將率，而車服敝素，為道路所識。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000065",
    "sentence": "時赤眉害更始，三輔道絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000066",
    "sentence": "光武即位，遣諫議大夫儲大伯，持節徵永詣行在所。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000067",
    "sentence": "永疑不從，乃收繋大伯，遣使馳至長安。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000068",
    "sentence": "既知更始已亡，乃發喪，出大伯等，封上將軍列侯印綬，悉罷兵，但幅巾與諸將及同心客百餘人詣河內。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000069",
    "sentence": "帝見永，問曰：『卿眾所在？』永離席叩頭曰：『臣事更始，不能令全，誠慚以其眾幸富貴，故悉罷之。』帝曰：『卿言大！』而意不悅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000070",
    "sentence": "時攻懷未拔，帝謂永曰：『我攻懷三日而兵不下，關東畏服禦，可且將故人自往城下譬之。』即拜永諫議大夫。",
    "entities": [
      {
        "text": "且將故人自往城",
        "label": "LOC",
        "start": 29,
        "end": 36
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 46,
        "end": 48
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000071",
    "sentence": "至懷，乃說更始河內太守，於是開城而降。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "於是開城",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000072",
    "sentence": "帝大喜，賜永洛陽商裏宅，固辭不受。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000073",
    "sentence": "時，董憲裨將屯兵於魯，侵害百姓，乃拜永為魯郡太守。",
    "entities": [
      {
        "text": "乃拜永為魯郡",
        "label": "LOC",
        "start": 16,
        "end": 22
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000074",
    "sentence": "永到，擊討，大破之，降者數千人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000075",
    "sentence": "唯別帥彭豐、虞休、皮常等各千餘人，稱『將軍』，不脹下。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000076",
    "sentence": "頃之，孔子闕里無故荊棘自除，從講堂至於裏門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000077",
    "sentence": "永異之，謂府丞及魯令曰：『方今危急而闕里自開，斯豈夫子欲令太守行禮，助吾誅無道邪？』乃會人眾，修鄉射之禮，請豐等共會觀視，欲因此禽之。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 29,
        "end": 31
      },
      {
        "text": "修鄉",
        "label": "LOC",
        "start": 47,
        "end": 49
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000078",
    "sentence": "豐等亦欲圖永，乃持牛酒勞饗，而潛挾兵器。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000079",
    "sentence": "永覺之，手格殺豐等，禽破黨與。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000080",
    "sentence": "帝嘉其略，封為關內侯，遷楊州牧。",
    "entities": [
      {
        "text": "封為關",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "遷楊州",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000081",
    "sentence": "時南土尚多寇暴，永以吏人痍傷之後，乃緩其銜轡，示誅強橫而鎮撫其餘，百姓安之。",
    "entities": [
      {
        "text": "示誅強橫而鎮",
        "label": "LOC",
        "start": 23,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000082",
    "sentence": "會遭母憂，去官，悉以財產與孤弟子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000083",
    "sentence": "建武十一年 ，徵為司隸校尉。",
    "entities": [
      {
        "text": "建武十一年",
        "label": "TME",
        "start": 0,
        "end": 5
      },
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000084",
    "sentence": "帝叔父趙王良尊戚貴重，永以事劾良大不敬，由是朝廷肅然，莫不戒慎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000085",
    "sentence": "乃辟扶風鮑恢為都官從事，恢亦抗直不避強禦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000086",
    "sentence": "帝常曰：『貴戚且宜斂手，以避二鮑。』其見憚如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000087",
    "sentence": "永行縣到霸陵，路經更始墓，引車入陌，從事諫止之。",
    "entities": [
      {
        "text": "永行縣",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000088",
    "sentence": "永曰：『親北面事人，寧有過墓不拜！雖以獲罪，司隸所不避也。』遂下拜，哭盡哀而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000089",
    "sentence": "西至扶風，椎牛上茍諫冢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000090",
    "sentence": "帝聞之，意不平，問公卿曰：『奉使如此何如？』太中大夫張湛對曰：『仁者行之宗，忠者義之主也。仁不遺舊，忠不忘君，行之高者也。』帝意乃釋。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000091",
    "sentence": "後大司徒韓歆坐事，永固請之不得，以此忤帝意，出為東海相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000092",
    "sentence": "坐度田事不實，被徵，諸郡守多下獄。",
    "entities": [
      {
        "text": "諸郡",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000093",
    "sentence": "永至成臯，詔書逆拜為兗州牧，便道之官。",
    "entities": [
      {
        "text": "詔書逆拜為兗州",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000094",
    "sentence": "視事三年，病卒。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000095",
    "sentence": "子昱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000096",
    "sentence": "論曰：鮑永守義於故主，斯可以事新主矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000097",
    "sentence": "恥以其眾受寵，斯可以受大寵矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000098",
    "sentence": "若乃言之者雖誠，而聞之未譬，豈茍進之悅，易以情納，持正之忤，難以理求乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000099",
    "sentence": "誠能釋利以循道，居方以從義，君子之概也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000100",
    "sentence": "子昱",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000101",
    "sentence": "昱字文泉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000102",
    "sentence": "少傳父學，客授於東平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000103",
    "sentence": "建武初，太行山中有劇賊，太守戴涉聞昱鮑永子，有智略，乃就謁，請署守高都長，昱應之，遂討擊群賊，誅其渠帥，道路開通，由是知名。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000104",
    "sentence": "後為沘陽長，政化仁愛，境內清凈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000105",
    "sentence": "荊州刺史表上之，再遷， 中元元年 ，拜司隸校尉，詔昱詣尚書，使封胡降檄。",
    "entities": [
      {
        "text": "荊州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "元年",
        "label": "TME",
        "start": 14,
        "end": 16
      },
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 21,
        "end": 23
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000106",
    "sentence": "光武遣小黃門問昱有所怪不？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000107",
    "sentence": "對曰：『臣聞故事通官文書不著姓，又當司徒露布，怪使司隸下書而著姓也。』帝報曰：『吾故欲今天下知忠臣之子復為司隸也。』昱在職，奉法守正，有父風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000108",
    "sentence": "永平五年，坐救火遲，免。",
    "entities": [
      {
        "text": "永平五年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000109",
    "sentence": "後拜汝南太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000110",
    "sentence": "郡多陂池，歲歲決壞，年費常三千餘萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000111",
    "sentence": "昱乃上作方梁石洫，水常饒足，溉田倍多，人以殷富。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000112",
    "sentence": "十七年，代王敏為司徒，賜錢帛什器帷帳，除子得為郎。",
    "entities": [
      {
        "text": "十七年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000113",
    "sentence": "建初元年 ，大旱，谷貴。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000114",
    "sentence": "肅宗召昱問曰：『旱既太甚。將何以消復災眚？』對曰：『臣聞聖人理國，三年有成。今陛下始踐天位，刑政未著，如有失得，何能致異？但臣前在汝南，典理楚事，系者千餘人，恐未能盡當其罪。先帝詔言，大獄一起，冤者過半。又諸徙者骨肉離分，孤魂不祀。一人呼嗟，王政為虧，宜一切還諸徙家屬，蠲除禁錮，興滅繼絕，死生獲所。如此，和氣可致。』帝納其言。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000115",
    "sentence": "四年，代牟融為太尉，六年，薨，年七十餘。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "六年",
        "label": "TME",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000116",
    "sentence": "子德，修志節，有名稱，累官為南陽太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000117",
    "sentence": "時歲多荒災，唯南陽豐穰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000118",
    "sentence": "吏人愛悅，號為神父。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000119",
    "sentence": "時郡學久廢，德乃修起橫舍，備俎豆黻冕，行禮奏樂。",
    "entities": [
      {
        "text": "時郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000120",
    "sentence": "又尊饗國老，宴會諸儒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000121",
    "sentence": "百姓觀者，莫不勸服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000122",
    "sentence": "在職九年，徵拜大司農，卒於官。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000123",
    "sentence": "子昂，字叔雅，有孝義節行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000124",
    "sentence": "初，德被病數年，昂俯伏左右，衣不緩帶；及處喪，毀瘠三年，抱負乃行；服闋，遂潛於墓次，不關時務。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 25,
        "end": 27
      },
      {
        "text": "不關",
        "label": "LOC",
        "start": 42,
        "end": 44
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000125",
    "sentence": "舉孝廉，辟公府，連徵不至，卒於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000126",
    "sentence": "郅惲",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000127",
    "sentence": "郅惲字君章，汝南西平人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000128",
    "sentence": "年十二失母，居喪過禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000129",
    "sentence": "及長，理《韓詩》、《嚴氏春秋》，明天文歷數。",
    "entities": [
      {
        "text": "《韓詩》",
        "label": "TITLE",
        "start": 4,
        "end": 8
      },
      {
        "text": "《嚴氏春秋》",
        "label": "TITLE",
        "start": 9,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000130",
    "sentence": "王莽時，寇賊群發，惲乃仰占玄象，嘆謂友人曰：『方今鎮、歲、熒惑並在漢分翼、軫之域，去而復來，漢必再受命，福歸有德。如有順天發策者，必成大功。』時左隊大夫逯並素好士，惲說之曰：『當今上天垂象，智者以昌，愚者以亡。昔伊尹自鬻輔商，立功全人。惲竊不遜，敢希伊尹之蹤，應天人之變。明府儻不疑逆，俾成天德。』並奇之，使署為吏。",
    "entities": [
      {
        "text": "方今鎮",
        "label": "LOC",
        "start": 23,
        "end": 26
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 74,
        "end": 76
      },
      {
        "text": "明",
        "label": "ORG",
        "start": 136,
        "end": 137
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000131",
    "sentence": "惲不謁，曰：『昔文王拔呂尚於渭濱，高宗禮傅說於巖築，桓公取管仲於射鉤，故能立弘烈，就元勛。未聞師相仲父，而可為吏位也。非窺天者不可與圖遠。君不授驥以重任，驥亦俯首裹足而去耳。』遂不受署。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000132",
    "sentence": "西至長安，乃上書王莽曰：",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000133",
    "sentence": "臣聞天地重其人，惜其物，故運機衡，垂日月，含元包一，甄陶品類，顯表紀世，圖錄豫設。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000134",
    "sentence": "漢歷久長，孔為赤制，不使愚惑，殘人亂時。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000135",
    "sentence": "智者順以成德，愚者逆以取害，神器有命，不可虛獲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000136",
    "sentence": "上天垂戒，欲悟陛下，令就臣位，轉禍為福。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000137",
    "sentence": "劉氏享天永命，陛下順節盛衰，取之以天，還之以天，可謂知命矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000138",
    "sentence": "若不早圖，是不免於竊位也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000139",
    "sentence": "且堯、舜不以天顯自與，故禪天下，陛下何貪非天顯以自累也？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000140",
    "sentence": "天為陛下嚴父，臣為陛下孝子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000141",
    "sentence": "父教不可廢，子諫不可拒，惟陛下留神。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000142",
    "sentence": "莽大怒，即收系詔獄，劾以大逆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000143",
    "sentence": "猶以惲據經讖，難即害之，使黃門近臣脅惲，令自告狂病恍忽，不覺所言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000144",
    "sentence": "惲乃瞋目詈曰：『所陳皆天文聖意，非狂人所能造。』遂系須冬，會赦得出，乃與同郡鄭敬南遁蒼梧。",
    "entities": [
      {
        "text": "乃與同郡",
        "label": "LOC",
        "start": 34,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000145",
    "sentence": "建武三年 ，又至廬江，因遇積弩將軍傅俊東徇揚州。",
    "entities": [
      {
        "text": "建武三年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000146",
    "sentence": "俊素聞惲名，乃禮請之，上為將兵長史，授以軍政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000147",
    "sentence": "惲乃誓眾曰：『無掩人不備，窮人於厄，不得斷人支體，裸人形骸，放淫婦女。』俊軍士猶發冢陳屍，掠奪百姓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000148",
    "sentence": "惲諫俊曰：『昔文王不忍露白骨，武王不以天下易一人之命，故能獲天地之應，克商如林之旅。將軍如何不師法文王，而犯逆天地之禁，多傷人害物，虐及枯屍，取罪神明？今不謝天改政，無以全命。願將軍親率士卒，收傷葬死，哭所殘暴，以明非將軍本意也。』從之，百姓悅服，所向皆下。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 42,
        "end": 44
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 89,
        "end": 91
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 109,
        "end": 111
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000149",
    "sentence": "七年，俊還京師，而上論之。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000150",
    "sentence": "惲恥以軍功取位，遂辭歸鄉里。",
    "entities": [
      {
        "text": "遂辭歸鄉",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000151",
    "sentence": "縣令卑身崇禮，請以為門下掾。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000152",
    "sentence": "惲友人董子張者，父先為鄉人所害。",
    "entities": [
      {
        "text": "父先為鄉",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000153",
    "sentence": "及子張病，將終，惲往候之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000154",
    "sentence": "子張垂歿，視惲，歔欷不能言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000155",
    "sentence": "惲曰：『吾知子不悲天命，而痛仇不復也。子在，吾憂而不手；子亡，吾手而不憂也。』子張但目擊而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000156",
    "sentence": "惲即起，將客遮仇人，取其頭以示子張。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000157",
    "sentence": "子張見而氣絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000158",
    "sentence": "惲因而詣縣，以狀自首。",
    "entities": [
      {
        "text": "惲因而詣縣",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000159",
    "sentence": "令應之遲，惲曰：『為友報仇，吏之私也。奉法不阿，君之義也。虧君以生，非臣節也。』趨出就獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000160",
    "sentence": "令跣而追惲，不及，遂自至獄，令拔刃自向以要惲曰：『子不從我出，敢以死明心。』惲得此乃出，因病去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000161",
    "sentence": "久之，太守歐陽歙請為功曹。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "歐陽歙",
        "label": "PER",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000162",
    "sentence": "汝南舊俗，十月饗會，百里內縣皆賫牛酒到府宴飲。",
    "entities": [
      {
        "text": "百里內縣",
        "label": "LOC",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000163",
    "sentence": "時臨饗禮訖，歙教曰：『西部督郵繇延，天資忠貞，稟性公方，摧破奸兇，不嚴而理。今與眾儒共論延功，顯之於朝。太守敬嘉厥休，牛酒養德。』主簿讀教，戶曹引延受賜。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 52,
        "end": 54
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000164",
    "sentence": "惲於下坐愀然前曰：『司正舉觥，以君之罪，告謝於天。案延資性貪邪，外方內員，朋黨構奸，罔上害人，所在荒亂，怨慝並作。明府以惡為善，股肱以直從曲，此既無君，又復無臣，惲敢再拜奉觥。』歙色慚動，不知所言。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 57,
        "end": 58
      }
    ]
  },
  {
    "sentence_id": "HCH_005_029_000165",
    "sentence": "門下掾鄭敬進曰：『君明臣直，功曹言切，明府德也。可無受觥哉？』歙意少解，曰：『實歙罪也，敬奉觥。』惲乃免寇謝曰：『昔虞舜輔堯，四罪鹹服，讒言弗庸，孔任不行，故能作股肱，帝用有歌。惲不忠，孔任是昭，豺虎從政，既陷誹謗，又露所言，罪莫重焉。請收惲、延，以明好惡。』歙曰：『是重吾過也。』遂不宴而罷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000166",
    "sentence": "惲歸府，稱病，延亦自退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000167",
    "sentence": "鄭敬素與惲厚，見其言許歙，乃相招去，曰：『子廷爭繇延，君猶不納。延今雖去，其勢必還。直心無諱，誠三代之道。然道不同者不相為謀，吾不能忍見子有不容君之危，盍去之乎！』惲曰：『孟軻以強其君之所不能為忠，量其君之所不能為賊。惲業已強之矣。障君於朝，既有其直，而不死職，罪也。延退而惲又去，不可。』敬乃獨隱於弋陽山中，居數月，歙果復召延，惲於是乃去，從敬止，漁釣自娛，留數十日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000168",
    "sentence": "惲志在從政，既乃喟然而嘆，謂敬曰：『天生俊士，以為人也。鳥獸不可與同群，子從我為伊、呂乎？將為巢、許，而父老堯、舜乎？』敬曰：『吾足矣。初從生步重華於南野，謂來歸為松子，今幸得全軀樹類，還奉墳墓，盡學問道，雖不從政，施之有政，是亦為政也。吾年耄矣，安得從子？子勉正性命，勿勞神以害生。』惲於是告別而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000169",
    "sentence": "敬字次都，清志高世，光武連徵不到。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_029_000170",
    "sentence": "惲遂客居江夏教授，郡舉孝廉，為上東城門候。",
    "entities": [
