[
  {
    "sentence_id": "HCH_005_085_000001",
    "sentence": "《王制》云：“東方曰夷。",
    "entities": [
      {
        "text": "《王制》",
        "label": "TITLE",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000002",
    "sentence": "”夷者，柢也，言仁而好生，萬物柢地而出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000003",
    "sentence": "故天性柔順，易以道御，至有君子、不死之國焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000004",
    "sentence": "夷有九種，曰畎夷、於夷、方夷、黄夷、白夷、赤夷、玄夷、風夷、陽夷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000005",
    "sentence": "故孔子欲居九夷也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000006",
    "sentence": "昔堯命羲仲宅嵎夷，曰旸谷，蓋日之所出也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000007",
    "sentence": "夏后氏太康失德，夷人始畔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000008",
    "sentence": "自少康已後，世服王化，遂賓於王門，獻其樂舞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000009",
    "sentence": "桀為暴虐，諸夷内侵，殷湯革命，伐而定之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000010",
    "sentence": "至於仲丁，蓝夷作寇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000011",
    "sentence": "自是或服或畔，三百餘年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000012",
    "sentence": "武乙衰敝，東夷浸盛，遂分遷淮、岱，漸居中土。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000013",
    "sentence": "及武王滅紂，肅慎來獻石砮、楛矢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000014",
    "sentence": "管、蔡畔周，乃招誘夷狄，周公征之，遂定東夷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000015",
    "sentence": "康王之時，肅慎復至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000016",
    "sentence": "後徐夷僭號，乃率九夷以伐宗周，西至河上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000017",
    "sentence": "穆王畏其方熾，乃分東方諸侯，命徐偃王主之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000018",
    "sentence": "偃王處潢池東，地方五百里，行仁義，陸地而朝者三十有六國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000019",
    "sentence": "穆王後得驥騄之乘，乃使造父御以告楚，令伐徐，一日而至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000020",
    "sentence": "於是楚文王大舉兵而滅之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000021",
    "sentence": "偃王仁而無權，不忍斗其人，故致於敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000022",
    "sentence": "乃北走彭城武原縣東山下，百姓隨之者以萬數，因名其山為徐山。",
    "entities": [
      {
        "text": "乃北走彭城",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "武原縣",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000023",
    "sentence": "厲王無道，淮夷入寇，王命虢仲征之，不克，宣王復命召分伐而平之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000024",
    "sentence": "及幽王淫亂，四夷交侵，至齊桓修霸，攘而卻焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000025",
    "sentence": "及楚靈會申，亦來豫盟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000026",
    "sentence": "後越遷琅邪，與共征戰，遂陵暴諸夏，侵滅小邦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000027",
    "sentence": "秦併六國，其淮、泗夷皆散為民户。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000028",
    "sentence": "陳涉起兵，天下崩潰，燕人衛滿避地朝鮮，因王其國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000029",
    "sentence": "百有餘歲，武帝滅之，於是東夷始通上京。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000030",
    "sentence": "王莽篡位，貊人寇邊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000031",
    "sentence": "建武之初，復來朝貢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000032",
    "sentence": "時遼東太守祭肜威讋北方，声行海表，於是濊、貊、倭、韓，萬里朝獻，故章、和已後，使聘流通。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000033",
    "sentence": "逮永初多難，始入寇鈔；桓、靈失政，漸滋曼焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000034",
    "sentence": "自中兴之後，四夷來賓，雖時有乖畔，而使驛不絕，故國俗風土，可得略记。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000035",
    "sentence": "東夷率皆土著，憙飲酒歌舞，或寇弁衣錦，器用俎豆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000036",
    "sentence": "所謂中國失礼，求之四夷者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000037",
    "sentence": "几蠻、夷、戎、狄总名四夷者，猶公、侯、伯、子、男皆號諸侯云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000038",
    "sentence": "夫餘國",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000039",
    "sentence": "夫餘國，在玄菟北千里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000040",
    "sentence": "南與高句驪，東與挹婁，西與鮮卑接，北有弱水。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000041",
    "sentence": "地方二千里，本濊地也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000042",
    "sentence": "初，北夷索離國王出行，其待兒於後妊身，王還，欲殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000043",
    "sentence": "侍兒曰：“前見天上有氣，大如雞子，來降我，因以有身。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000044",
    "sentence": "”王囚之，後遂生男。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000045",
    "sentence": "王令置於豕牢，豕以口氣嘘之，不死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000046",
    "sentence": "復徙於馬兰，馬亦如之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000047",
    "sentence": "王以為神，乃听母收養，名曰東明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000048",
    "sentence": "東明長而善射，王忌其猛，復欲殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000049",
    "sentence": "東明奔走，南至掩淲水，以弓擊水，魚鳖皆聚浮水上，東明乘之得度，因至夫餘而王之焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000050",
    "sentence": "於東夷之域，最為平敞，土宜五穀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000051",
    "sentence": "出名馬、赤玉、貂豽，大珠如酸枣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000052",
    "sentence": "以员栅為城，有宫室、仓库、牢獄。",
    "entities": [
      {
        "text": "以员栅為城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000053",
    "sentence": "其人粗大强勇而謹厚，不為寇鈔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000054",
    "sentence": "以弓矢刀矛為兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000055",
    "sentence": "以六畜名官，有馬加、牛加、狗加，其邑落皆主屬諸加，食飲用俎豆，會同拜爵洗爵，揖讓升降。",
    "entities": [
      {
        "text": "其邑",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000056",
    "sentence": "以腊月祭天，大會連日，飲食歌舞，名曰“迎鼓”。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000057",
    "sentence": "是時断刑獄，解囚徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000058",
    "sentence": "有军事亦祭天，殺牛，以蹄占其吉凶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000059",
    "sentence": "行人無昼夜，好歌吟，音声不絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000060",
    "sentence": "其俗用刑严急，被誅者皆没其家人為奴婢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000061",
    "sentence": "盗一責十二。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000062",
    "sentence": "男女淫，皆殺之，尤治恶妒婦，既殺，復尸於山上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000063",
    "sentence": "兄死妻嫂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000064",
    "sentence": "死則有椁無棺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000065",
    "sentence": "殺人殉葬，多者以百數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000066",
    "sentence": "其王葬用玉匣，漢朝常豫以玉匣付玄菟郡，王死則迎取以葬焉。",
    "entities": [
      {
        "text": "以玉匣付玄菟郡",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000067",
    "sentence": "建武中，東夷諸國皆來獻見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000068",
    "sentence": "二十五年，夫餘王遣使奉貢，光武厚答报之，於是使命歲通。",
    "entities": [
      {
        "text": "二十五年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000069",
    "sentence": "至安帝 永初五年 ，夫餘王始將步騎七八千人寇抄樂浪，殺傷吏民，後復归附。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000070",
    "sentence": "永宁元年，乃遣嗣子尉仇台詣阙貢獻，天子賜尉仇台印綬金彩。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000071",
    "sentence": "順帝 永和元年 ，其王來朝京师，帝作黄門鼓吹、角抵戏以遣之。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000072",
    "sentence": "桓帝 延熹四年 ，遣使朝賀貢獻。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000073",
    "sentence": "永康元年 ，王夫台將二萬餘人寇玄菟，玄菟太守公孫域擊破之，斬首千餘級。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000074",
    "sentence": "至靈帝 熹平三年 ，復奉章貢獻。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000075",
    "sentence": "夫餘本屬玄菟，獻帝時，其王求屬遼東云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000076",
    "sentence": "挹婁",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000077",
    "sentence": "挹婁，古肅慎之國也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000078",
    "sentence": "在夫餘東北千餘里，東濱大海，南與北沃沮接，不知其北所極。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000079",
    "sentence": "土地多山险。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000080",
    "sentence": "人形似夫餘，而言語各異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000081",
    "sentence": "有五谷、麻布，出赤玉、好貂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000082",
    "sentence": "無君長，其邑落各有大人。",
    "entities": [
      {
        "text": "其邑",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000083",
    "sentence": "處於山林之間，土氣極寒，常為穴居，以深為貴，大家至接九梯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000084",
    "sentence": "好養豕，食其肉，衣其皮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000085",
    "sentence": "冬以豕膏涂身，厚數分，以御風寒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000086",
    "sentence": "夏則裸袒，以尺布蔽其前後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000087",
    "sentence": "其人臭秽不洁，作廁於中，圜之而居。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000088",
    "sentence": "自漢兴以後，臣屬夫餘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000089",
    "sentence": "種眾雖少，而多勇力，處山险，又善射，发能入人目。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000090",
    "sentence": "弓長四尺，力如弩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000091",
    "sentence": "矢用枯，長一尺八寸，青石為鏃，鏃皆施毒，中人即死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000092",
    "sentence": "便乘船，好寇盗，邻國畏患，而卒不能服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000093",
    "sentence": "東夷夫餘飲食类皆用俎豆，唯挹婁独無，法俗最無纲纪者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000094",
    "sentence": "高句麗",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000095",
    "sentence": "高句驪，在遼東之東千里，南與朝鮮、濊貊，東與沃沮，北與夫餘接。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000096",
    "sentence": "地方二千里，多大山深谷，人隨而為居。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000097",
    "sentence": "少田业，力作不足以自资，故其俗節於飲食，而好修宫室。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000098",
    "sentence": "東夷相傳以為夫餘别種，故言語法則多同，而跪拜曳一脚，行步皆走。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000099",
    "sentence": "凡有五族，有消奴部、絕奴部、順奴部、灌奴部、桂婁部。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000100",
    "sentence": "本消奴部為王，稍微弱，後桂婁部代之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000101",
    "sentence": "其置官，有相加、对卢、沛者、古邹大加、主簿、优台、使者、帛衣先人。",
    "entities": [
      {
        "text": "沛",
        "label": "LOC",
        "start": 11,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000102",
    "sentence": "武帝滅朝鮮，以高句驪為縣，使屬玄菟，賜鼓吹伎人。",
    "entities": [
      {
        "text": "以高句驪為縣",
        "label": "LOC",
        "start": 6,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000103",
    "sentence": "其俗淫，皆洁净自熹，暮夜輒男女群聚為倡樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000104",
    "sentence": "好祠鬼神、社稷、零星，以十月祭天大會，名曰“東盟”。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000105",
    "sentence": "其國東有大穴，號禭神，亦以十月迎而祭之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000106",
    "sentence": "其公會衣服皆錦绣，金银以自飾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000107",
    "sentence": "大加、主簿皆著帻，如冠帻而無後；其小加著折風，形如弁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000108",
    "sentence": "無牢獄，有罪，諸加評议便殺之，没入妻子為奴婢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000109",
    "sentence": "其昏姻皆就婦家，生子長大，然後將還，便稍营送终之具。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000110",
    "sentence": "金银財币尽於厚葬，积石為封，亦種松柏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000111",
    "sentence": "其人性凶急，有氣力，习戰斗，好寇鈔，沃沮、東濊皆屬焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000112",
    "sentence": "句驪一名貊，有别種，依小水為居，因名曰小水貊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000113",
    "sentence": "出好弓，所謂“貊弓”是也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000114",
    "sentence": "王莽初，发句驪兵以伐匈奴，其人不欲行，强迫遣之，皆亡出塞為寇盗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000115",
    "sentence": "遼西大尹田谭追擊，戰死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000116",
    "sentence": "莽令其將严尤擊之，誘句驪侯驺入塞，斬之，傳首長安。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000117",
    "sentence": "莽大說，更名高句驪王為下句驪侯，於是貊人寇邊愈甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000118",
    "sentence": "建武八年 ，高句驪遣使朝貢，光武復其王號。",
    "entities": [
      {
        "text": "建武八年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000119",
    "sentence": "二十三年冬，句驪蠶支落大加戴升等萬餘口詣樂浪内屬。",
    "entities": [
      {
        "text": "二十三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000120",
    "sentence": "二十五年春，句驪寇右北平、渔陽、上谷、太原，而遼東太守祭肜以恩信招之，皆復款塞。",
    "entities": [
      {
        "text": "二十五年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000121",
    "sentence": "後句驪王宫生而开目能視，國人懷之，及長勇壮，數犯邊境。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000122",
    "sentence": "和帝元兴元年春，復入遼東，寇略六縣，太守耿夔擊破之，斬其渠帥。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 4,
        "end": 6
      },
      {
        "text": "遼",
        "label": "ORG",
        "start": 10,
        "end": 11
      },
      {
        "text": "寇略六縣",
        "label": "LOC",
        "start": 13,
        "end": 17
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000123",
    "sentence": "安帝 永初五年 ，宫遣使貢獻，求屬玄菟。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000124",
    "sentence": "元初五年 ，復與濊貊寇玄菟，攻華丽城。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "攻華丽城",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000125",
    "sentence": "建光元年 春，幽州刺史冯焕、玄菟太守姚光、遼東太守蔡諷等，將兵出塞擊之，捕斬濊貊渠帥，获兵馬財物。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "幽州",
        "label": "LOC",
        "start": 7,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000126",
    "sentence": "宫乃遣嗣子遂成將二千餘人逆光等，遣使詐降；光等信之，遂成因据险厄以遮大军，而潜遣三千人攻玄菟、遼東，焚城郭，殺傷二千餘人。",
    "entities": [
      {
        "text": "焚城",
        "label": "LOC",
        "start": 50,
        "end": 52
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000127",
    "sentence": "於是发广陽、渔陽、右北平、涿郡屬國三千餘騎同救之，而貊人已去。",
    "entities": [
      {
        "text": "涿郡",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000128",
    "sentence": "夏，復與遼東鮮卑八千餘人攻遼队，殺略吏人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000129",
    "sentence": "蔡諷等追擊於新昌，戰殁，功曹耿耗、兵曹掾龙端、兵馬掾公孫酺以身扞諷，俱殁於陣，死者百餘人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000130",
    "sentence": "秋，宫遂率馬韓、濊貊數千騎围玄菟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000131",
    "sentence": "夫餘王遣子尉仇台將二萬餘人，與州郡并力討破之。",
    "entities": [
      {
        "text": "與州郡",
        "label": "LOC",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000132",
    "sentence": "斬首五百餘級。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000133",
    "sentence": "是歲宫死，子遂成立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000134",
    "sentence": "姚光上言欲因其丧发兵擊之，议者皆以為可許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000135",
    "sentence": "尚书陳忠曰：“宫前桀黠，光不能討，死而擊之，非義也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000136",
    "sentence": "宜遣吊问，因責讓前罪，赦不加誅，取其後善。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000137",
    "sentence": "”安帝从之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000138",
    "sentence": "明年，遂成還漢生口，詣玄菟降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000139",
    "sentence": "詔曰：“遂成等桀逆無状，当斬断菹醢，以示百姓，幸會赦令，乞罪請降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000140",
    "sentence": "鮮卑、 濊貊連年寇鈔，驅略小民，動以千數，而裁送數十百人，非向化之心也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000141",
    "sentence": "自今已後，不與縣官戰斗而自以亲附送生口者，皆與贖直，缣人四十匹，小口半之。",
    "entities": [
      {
        "text": "不與縣",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000142",
    "sentence": "”",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000143",
    "sentence": "遂成死，子伯固立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000144",
    "sentence": "其後濊貊率服，東垂少事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000145",
    "sentence": "順帝 陽嘉元年 ，置玄菟郡屯田六部。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 5,
        "end": 7
      },
      {
        "text": "置玄菟郡",
        "label": "LOC",
        "start": 9,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000146",
    "sentence": "質、桓之間，復犯遼東西安平，殺帶方令，掠得樂浪太守妻子。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000147",
    "sentence": "建宁二年，玄菟太守耿臨討之，斬首數百級，伯固降服，乞屬玄菟云。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000148",
    "sentence": "東沃沮",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000149",
    "sentence": "東沃沮在高句驪蓋馬大山之東，東濱大海，北與挹婁、夫餘，南與濊貊接。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000150",
    "sentence": "其地東西夹，南北長，可折方千里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000151",
    "sentence": "土肥美，背山向海，宜五谷，善田種，有邑落長帥。",
    "entities": [
      {
        "text": "有邑",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000152",
    "sentence": "人性質直强勇，便持矛步戰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000153",
    "sentence": "言語、食飲、居處，衣服，有似句驪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000154",
    "sentence": "其葬，作大木椁，長十餘丈，开一頭為户，新死者先假埋之，令皮肉尽，乃取骨置椁中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000155",
    "sentence": "家人皆共一椁，刻木如生，隨死者為數焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000156",
    "sentence": "武帝滅朝鮮，以沃沮地為玄菟郡。",
    "entities": [
      {
        "text": "沃沮地為玄菟郡",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000157",
    "sentence": "後為夷貊所侵，徙郡於高句驪西北，更以沃沮為縣，屬樂浪東部都尉。",
    "entities": [
      {
        "text": "徙郡",
        "label": "LOC",
        "start": 7,
        "end": 9
      },
      {
        "text": "更以沃沮為縣",
        "label": "LOC",
        "start": 16,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000158",
    "sentence": "至光武罢都尉官，後皆以封其渠帥，為沃沮侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000159",
    "sentence": "其土迫小，介於大國之間，遂臣屬句驪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000160",
    "sentence": "句驪復置其中大人為使者，以相监領，責其租税，貂、布、魚、鹽、海中食物，发美女為婢妾焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000161",
    "sentence": "又有北沃沮，一名置沟婁，去南沃沮八百餘里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000162",
    "sentence": "其俗皆與南同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000163",
    "sentence": "界南接挹婁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000164",
    "sentence": "挹婁人喜乘船寇抄，北沃沮畏之，每夏輒臧於岩穴，至冬船道不通，乃下居邑落。",
    "entities": [
      {
        "text": "乃下居邑",
        "label": "LOC",
        "start": 30,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000165",
    "sentence": "其耆者言，嘗於海中得一布衣，其形如中人衣，而两袖長三丈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000166",
    "sentence": "又於岸際見一人乘破船，頂中復有面，與語不通，不食而死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000167",
    "sentence": "又說海中有女國，無男人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000168",
    "sentence": "或傳其國有神井，窺之輒生子云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000169",
    "sentence": "濊",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000170",
    "sentence": "濊北與高句驪、沃沮，南與辰韓接，東穷大海，西至樂浪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000171",
    "sentence": "濊及沃沮、句驪，本皆朝鮮之地也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000172",
    "sentence": "昔武王封箕子於朝鮮，箕子教以礼義田蠶，又制八条之教。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000173",
    "sentence": "其人终不相益，無門户之閉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000174",
    "sentence": "婦人貞信。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000175",
    "sentence": "飲食以籩豆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000176",
    "sentence": "其後四十餘世，至朝鮮侯准自稱王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000177",
    "sentence": "漢初大亂，燕、齊、趙人往避地者數萬口，而燕人衛滿擊破准，而自王朝鮮，傳國至孫右渠。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 0,
        "end": 1
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000178",
    "sentence": "元朔元年，濊君南閭等畔右渠，率二十八萬口詣遼東内屬，武帝以其地為蒼海郡，數年乃罢。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "以其地為蒼海郡",
        "label": "LOC",
        "start": 28,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000179",
    "sentence": "至 元封三年 ，滅朝鮮，分置樂浪、臨屯、玄菟、真番四郡。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 4,
        "end": 6
      },
      {
        "text": "真番四郡",
        "label": "LOC",
        "start": 23,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000180",
    "sentence": "至昭帝 始元五年 ，罢臨屯、真番，以并樂浪、玄菟。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000181",
    "sentence": "玄菟復徙居句驪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000182",
    "sentence": "自单单大領已東，沃沮、濊貊悉屬樂浪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000183",
    "sentence": "後以境土广遠，復分領東七縣，置樂浪東部都尉。",
    "entities": [
      {
        "text": "復分領東七縣",
        "label": "LOC",
        "start": 7,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000184",
    "sentence": "自内屬已後，風俗稍薄，法禁亦浸多，至有六十餘条。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000185",
    "sentence": "建武六年 ，省都尉官，遂棄領東地，悉封其渠帥為縣侯，皆歲時朝賀。",
    "entities": [
      {
        "text": "建武六年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "悉封其渠帥為縣",
        "label": "LOC",
        "start": 17,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000186",
    "sentence": "無大君長，其官有侯、邑君、三老。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000187",
    "sentence": "耆舊自謂與句驪同種，言語法俗大抵相类。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000188",
    "sentence": "其人性愚悫，少嗜欲，不請丐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000189",
    "sentence": "男女皆衣曲領。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000190",
    "sentence": "其俗重山川，山川各有部界，不得妄相干涉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000191",
    "sentence": "同姓不昏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000192",
    "sentence": "多所忌諱，疾病死亡，輒捐棄舊宅，更造新居。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000193",
    "sentence": "知種麻，養蠶，作綿布。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000194",
    "sentence": "晓候星宿，豫知年歲丰約。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000195",
    "sentence": "常用十月祭天，昼夜飲酒歌舞，名之為“舞天”。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000196",
    "sentence": "又祠虎以為神。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000197",
    "sentence": "邑落有相侵犯者，輒相罰，責生口牛馬，名之為“責祸”。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000198",
    "sentence": "殺人者偿死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000199",
    "sentence": "少寇盗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000200",
    "sentence": "能步戰，作矛長三丈，或數人共持之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000201",
    "sentence": "樂浪檀弓出其地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000202",
    "sentence": "又多文豹，有果下馬，海出班魚，使來皆獻之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000203",
    "sentence": "三韓",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000204",
    "sentence": "韓有三種：一曰馬韓、二曰辰韓、三曰弁辰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000205",
    "sentence": "馬韓在西，有五十四國，其北與樂浪，南與倭接，辰韓在東，十有二國，其北與濊貊接。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000206",
    "sentence": "弁辰在辰韓之南，亦十有二國，其南亦與倭接。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000207",
    "sentence": "凡七十八國，伯济是其一國焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000208",
    "sentence": "大者萬餘户，小者數千家，各在山海間，地合方四千餘里，東西以海為限，皆古之辰國也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000209",
    "sentence": "馬韓最大，共立其種為辰王，都目支國，尽王三韓之地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000210",
    "sentence": "其諸國王先皆是馬韓種人焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000211",
    "sentence": "馬韓人知田蠶，作綿布。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000212",
    "sentence": "出大栗如梨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000213",
    "sentence": "有長尾雞，尾長五尺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000214",
    "sentence": "邑落雜居，亦無城郭。",
    "entities": [
      {
        "text": "亦無城",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000215",
    "sentence": "作土室，形如冢，开户在上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000216",
    "sentence": "不知跪拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000217",
    "sentence": "無長幼男女之别。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000218",
    "sentence": "不貴金寶錦罽，不知騎乘牛馬，唯重璎珠，以缀衣為飾，及縣頸垂耳。",
    "entities": [
      {
        "text": "及縣",
        "label": "LOC",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000219",
    "sentence": "大率皆魁頭露紒，布袍草履。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000220",
    "sentence": "其人壮勇，少年有筑室作力者，輒以绳贯脊皮，缒以大木，欢呼為健。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000221",
    "sentence": "常以五月田竟祭鬼神，昼夜酒會，群聚歌舞，舞輒數十人相隨，蹋地為節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000222",
    "sentence": "十月农功毕，亦復如之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000223",
    "sentence": "諸國邑各以一人主祭天神，號為“天君”。",
    "entities": [
      {
        "text": "諸國邑",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000224",
    "sentence": "又立苏涂，建大木以縣铃鼓，事鬼神。",
    "entities": [
      {
        "text": "建大木以縣",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000225",
    "sentence": "其南界近倭，亦有文身者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000226",
    "sentence": "辰韓，耆老自言秦之亡人，避苦役，适韓國，馬韓割東界地與之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000227",
    "sentence": "其名國為邦，弓為弧，賊為寇，行酒為行觞，相呼為徒，有似秦語，故或名之為秦韓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000228",
    "sentence": "有城栅屋室。",
    "entities": [
      {
        "text": "有城",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000229",
    "sentence": "諸小别邑，各有渠帥，大者名臣智，次有儉側，次有樊秖，次有殺奚，次有邑借。",
    "entities": [
      {
        "text": "諸小别邑",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "次有邑",
        "label": "LOC",
        "start": 31,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000230",
    "sentence": "土地肥美，宜五谷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000231",
    "sentence": "知蠶桑，作缣布。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000232",
    "sentence": "乘驾牛馬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000233",
    "sentence": "嫁娶以礼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000234",
    "sentence": "行者讓路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000235",
    "sentence": "國出鐵，濊、倭、馬韓并从市之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000236",
    "sentence": "凡諸貿易，皆以鐵為貨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000237",
    "sentence": "俗喜歌舞、飲酒、鼓瑟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000238",
    "sentence": "兒生欲令其頭扁，皆押之以石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000239",
    "sentence": "弁辰與辰韓雜居，城郭衣服皆同，語言風俗有異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000240",
    "sentence": "其人形皆長大，美发，衣服洁清。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000241",
    "sentence": "而刑法严峻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000242",
    "sentence": "其國近倭，故颇有文身者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000243",
    "sentence": "初，朝鮮王准為衛滿所破，乃將其餘眾數千人走入海，攻馬韓，破之，自立為韓王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000244",
    "sentence": "准後滅絕，馬韓人復自立為辰王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000245",
    "sentence": "建武二十年 ，韓人廉斯人苏馬諟等，詣樂浪貢獻。",
    "entities": [
      {
        "text": "建武二十年",
        "label": "TME",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000246",
    "sentence": "光武封苏馬諟為漢廉斯邑君，使屬樂浪郡，四時朝謁。",
    "entities": [
      {
        "text": "馬諟為漢廉斯邑",
        "label": "LOC",
        "start": 4,
        "end": 11
      },
      {
        "text": "使屬樂浪郡",
        "label": "LOC",
        "start": 13,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000247",
    "sentence": "靈帝末，韓、濊并盛，郡縣不能制，百姓苦亂，多流亡入韓者。",
    "entities": [
      {
        "text": "郡縣",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000248",
    "sentence": "馬韓之西，海島上有州胡國。",
    "entities": [
      {
        "text": "海島上有州",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000249",
    "sentence": "其人短小，髡頭，衣韦衣，有上無下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000250",
    "sentence": "好養牛豕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000251",
    "sentence": "乘船往來，貨市韓中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000252",
    "sentence": "倭",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000253",
    "sentence": "倭在韓東南大海中，依山島為居，凡百餘國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000254",
    "sentence": "自武帝滅朝鮮，使驛通於漢者三十許國，國皆稱王，世世傳統。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000255",
    "sentence": "其大倭王居邪馬台國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000256",
    "sentence": "樂浪郡徼，去其國萬二千里，去其西北界拘邪韓國七千餘里。",
    "entities": [
      {
        "text": "樂浪郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000257",
    "sentence": "其地大較在會稽東冶之東，與硃崖、儋耳相近，故其法俗多同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000258",
    "sentence": "土宜禾稻、麻紵、蠶桑，知織绩為缣布。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000259",
    "sentence": "出白珠、青玉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000260",
    "sentence": "其山有丹土。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000261",
    "sentence": "氣温暖，冬夏生菜茹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000262",
    "sentence": "無牛、馬、虎、豹、羊、 鵲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000263",
    "sentence": "其兵有矛、楯、木弓、竹矢，或以骨為鏃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000264",
    "sentence": "男子皆黥面文身，以其文左右大小别尊卑之差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000265",
    "sentence": "其男衣皆横幅，结束相連。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000266",
    "sentence": "女人被发屈紒，衣如单被，贯頭而着之；并以丹硃坌身，如中國之用粉也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000267",
    "sentence": "有城栅屋室。",
    "entities": [
      {
        "text": "有城",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000268",
    "sentence": "父母兄弟異處，唯會同男女無别。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000269",
    "sentence": "飲食以手，而用籩豆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000270",
    "sentence": "俗皆徒跣，以蹲踞為恭敬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000271",
    "sentence": "人性嗜酒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000272",
    "sentence": "多壽考，至百餘歲者甚眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000273",
    "sentence": "國多女子，大人皆有四五妻，其餘或两或三。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000274",
    "sentence": "女人不淫不妒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000275",
    "sentence": "又俗不盗窃，少爭訟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000276",
    "sentence": "犯法者没其妻子，重者滅其門族。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000277",
    "sentence": "其死停丧十餘日，家人哭泣，不進酒食，而等类就歌舞為樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000278",
    "sentence": "灼骨以卜，用决吉凶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000279",
    "sentence": "行來度海，令一人不栉沐，不食肉，不近婦人，名曰“持衰”。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000280",
    "sentence": "若在涂吉利，則雇以財物；如病疾遭害，以為持衰不謹，便共殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000281",
    "sentence": "建武中元二年 ，倭奴國奉貢朝賀，使人自稱大夫，倭國之極南界也。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 4,
        "end": 6
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000282",
    "sentence": "光武賜以印綬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000283",
    "sentence": "安帝 永初元年 ，倭國王帥升等獻生口百六十人，願請見。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000284",
    "sentence": "桓、靈間，倭國大亂，更相攻伐，历年無主。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000285",
    "sentence": "有一女子各曰卑弥呼，年長不嫁，事鬼神道，能以妖惑眾，於是共立為王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000286",
    "sentence": "侍婢千人，少有見者，唯有男子一人給飲食，傳辞語。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000287",
    "sentence": "居處宫室、楼观城栅，皆持兵守衛。",
    "entities": [
      {
        "text": "楼观城",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000288",
    "sentence": "法俗严峻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000289",
    "sentence": "自女王國東度海千餘里，至拘奴國，雖皆倭種，而不屬女王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000290",
    "sentence": "自女王國南四千餘里，至硃儒國，人長三四尺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000291",
    "sentence": "自硃儒東南行船一年，至裸國、黑齿國，使驛所傳，極於此矣。",
    "entities": [
      {
        "text": "一年",
        "label": "TME",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000292",
    "sentence": "會稽海外有東鳀人，分為二十餘國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000293",
    "sentence": "又有夷洲及澶洲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000294",
    "sentence": "傳言秦始皇遣方士徐福將童男女數千人入海，求蓬莱神仙不得，徐福畏誅不敢還，遂止此洲，世世相承，有數萬家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000295",
    "sentence": "人民時至會稽市。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000296",
    "sentence": "會稽東治縣人有入海行遭風，流移至澶洲者。",
    "entities": [
      {
        "text": "會稽東治縣",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000297",
    "sentence": "所在絕遠，不可往來。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000298",
    "sentence": "評語",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000299",
    "sentence": "論曰：“昔箕子違衰殷之運，避地朝鮮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000300",
    "sentence": "始其國俗未有聞也，及施八条之約，使人知禁，遂乃邑無淫盗，門不夜扃，回頑薄之俗，就宽略之法，行數百千年，故東夷通以柔謹為風，異乎三方者也。",
    "entities": [
      {
        "text": "遂乃邑",
        "label": "LOC",
        "start": 21,
        "end": 24
      },
      {
        "text": "百千年",
        "label": "TME",
        "start": 47,
        "end": 50
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000301",
    "sentence": "苟政之所暢，則道義存焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000302",
    "sentence": "仲尼懷愤，以為九夷可居。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000303",
    "sentence": "或疑其陋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000304",
    "sentence": "子曰：“君子居之，何陋之有！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000305",
    "sentence": "”亦徒有以焉尔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000306",
    "sentence": "其後遂通接商賈，漸交上國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000307",
    "sentence": "而燕人衛滿扰雜其風，於是从而澆異焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000308",
    "sentence": "《老子》曰：“法令滋章，盗賊多有。",
    "entities": [
      {
        "text": "《老子》",
        "label": "TITLE",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_085_000309",
    "sentence": "”若箕子之省簡文条而用信義，其得聖賢作法之原矣！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000310",
    "sentence": "贊曰：宅是嵎夷，曰乃旸谷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000311",
    "sentence": "巢山潜海，厥區九族。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000312",
    "sentence": "嬴末紛亂，燕人違難。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000313",
    "sentence": "雜華澆本，遂通有漢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_085_000314",
    "sentence": "眇眇偏譯，或从或畔。",
    "entities": []
  }
]
