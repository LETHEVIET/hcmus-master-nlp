      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000171",
    "sentence": "及馬氏敗，免官歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000172",
    "sentence": "永元元年 ，車騎將軍竇憲，復請毅爲主記室，崔駰爲主簿。",
    "entities": [
