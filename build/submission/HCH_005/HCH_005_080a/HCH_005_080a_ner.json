        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000187",
    "sentence": "功滿當遷，和帝留，增秩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000188",
    "sentence": "六年，累遷尙書令。",
    "entities": [
