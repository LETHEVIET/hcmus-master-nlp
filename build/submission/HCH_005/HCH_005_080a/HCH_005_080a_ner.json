  {
    "sentence_id": "HCH_005_080a_000257",
    "sentence": "後蔡邕亦造此賦，未成，及見延壽所爲，甚奇之，遂輟翰而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000258",
    "sentence": "曾有異夢，意惡之，乃作《夢賦》以自厲。",
    "entities": [
      {
        "text": "《夢賦》",
        "label": "TITLE",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000259",
    "sentence": "後溺水死，時年二十餘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000260",
    "sentence": "崔琦",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000261",
    "sentence": "崔琦字子瑋，涿郡安平人，濟北相瑗之宗也。",
    "entities": [
      {
        "text": "涿郡",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000262",
    "sentence": "少遊學京師，以文章博通稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000263",
    "sentence": "初舉考廉，爲郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000264",
    "sentence": "河南尹梁冀聞其才，請與交。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000265",
    "sentence": "冀行多不軌，琦數引古今成敗以戒之，冀不能受。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000266",
    "sentence": "乃作《外戚箴》。",
    "entities": [
      {
        "text": "《外戚箴》",
        "label": "TITLE",
        "start": 2,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000267",
    "sentence": "其辭曰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000268",
    "sentence": "赦赦外戚，華寵煌煌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000269",
    "sentence": "昔在帝舜，德隆英、皇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000270",
    "sentence": "周興三母，有莘崇湯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000271",
    "sentence": "宣王晏起，姜后脱簪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000272",
    "sentence": "齊桓好樂，衞姬不音。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000273",
    "sentence": "皆輔主以禮，扶君以仁，達才進善，以義濟身。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000274",
    "sentence": "爰暨未葉，漸已穨虧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000275",
    "sentence": "貫魚不敍，九御差池。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000276",
    "sentence": "晉國之難，禍起於麗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000277",
    "sentence": "惟家之索。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000278",
    "sentence": "牝鷄之晨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000279",
    "sentence": "專權擅愛，顯已蔽人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000280",
    "sentence": "陵長間舊，圮剝至親。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000281",
    "sentence": "幷後匹嫡，淫女斃陳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000282",
    "sentence": "匪賢是上，番爲司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000283",
    "sentence": "荷爵負乘，采食名都。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000284",
    "sentence": "詩人是刺，德用無憮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000285",
    "sentence": "暴辛惑婦，拒諫自孤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000286",
    "sentence": "蝠蛇其心，縱毒不辜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000287",
    "sentence": "諸父是殺，孕子是刳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000288",
    "sentence": "天怒地忿，人謀鬼圖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000289",
    "sentence": "甲子昧爽，身首分離。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000290",
    "sentence": "初爲天子，後爲人螭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000291",
    "sentence": "非但耽色，母后尤然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000292",
    "sentence": "不相率以禮，而競奬以權。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000293",
    "sentence": "先笑後號，卒以辱殘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000294",
    "sentence": "國家泯絶，宗廟燒燔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000295",
    "sentence": "末嬉喪夏，褒姒斃周，妲已亡殷，趙靈沙丘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000296",
    "sentence": "戚姬人豕，呂宗以敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000297",
    "sentence": "陳后作巫，卒死於外。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000298",
    "sentence": "霍欲鴆子，身乃罹廢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000299",
    "sentence": "故曰：無謂我貴，天將爾摧；無恃常好，色有歇微；無怙常幸，愛有陵遲；無曰我能，天人爾違。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000300",
    "sentence": "患生不德，福有愼機。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000301",
    "sentence": "日不常中，月盈有虧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000302",
    "sentence": "履道者固，杖勢者危。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000303",
    "sentence": "微臣司戚，敢告在斯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000304",
    "sentence": "琦以言不從，失意，復作《白鵠賦》以爲風。",
    "entities": [
      {
        "text": "《白鵠賦》",
        "label": "TITLE",
        "start": 11,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000305",
    "sentence": "梁冀見之，呼琦問曰：「百官外内，各有司存，天下云云，豈獨吾人之尤，君何激刺之過乎！」琦對曰：「昔管仲相齊，樂聞機諫之言；蕭何佐漢，乃設書過之吏。今將軍累世臺輔，任齊伊、公，而德政未聞，黎元塗炭。不能結納貞良，以救禍敗，反復欲鉗塞士口，杜蔽主聽，將使玄黃改色，馬鹿易形乎？」冀無以對，因遣琦歸。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 73,
        "end": 75
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000306",
    "sentence": "後除爲臨濟長，不敢之職，解印綬去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000307",
    "sentence": "冀遂令刺客陰求殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000308",
    "sentence": "客見琦耕於陌上，懷書一巻，息輒偃而詠之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000309",
    "sentence": "客哀其志，以實告琦，曰：「將軍令吾要子，今見君賢者，情懷忍忍。可亟自逃，吾亦於此亡矣。」琦得脱走，冀後竟捕殺之。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000310",
    "sentence": "所著賦、頌、銘、誄、箴、弔、論、《九咨》、《七言》，凡十五篇。",
    "entities": [
      {
        "text": "《九咨》",
        "label": "TITLE",
        "start": 16,
        "end": 20
      },
      {
        "text": "《七言》",
        "label": "TITLE",
        "start": 21,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000311",
    "sentence": "邊韶",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000312",
    "sentence": "邊韶字孝先，陳留浚儀人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000313",
    "sentence": "以文章知名，教授數百人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000314",
    "sentence": "韶口辯，曾晝日假臥，弟子私嘲之曰：「邊孝先，腹便便。懶讀書，但欲眠。」韶潛聞之，應時對曰：「邊爲姓、考爲字。腹便便，《五經》笥。但欲眠，思經事。寐與周公通夢，靜與孔子同意。師而可嘲，出何典記？」嘲者大慚。",
    "entities": [
      {
        "text": "《五經》",
        "label": "TITLE",
        "start": 58,
        "end": 62
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000315",
    "sentence": "韶之才捷皆此類也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000316",
    "sentence": "桓帝時，爲臨潁侯相，徴拜太中大夫，著作東觀。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000317",
    "sentence": "再遷北地太守，入拜尙書令。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000318",
    "sentence": "後爲陳相，卒官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000319",
    "sentence": "著詩、頌、碑、銘、書、策，凡十五篇。",
    "entities": []
  }
]
