[
  {
    "sentence_id": "HCH_005_080a_000001",
    "sentence": "杜篤",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000002",
    "sentence": "杜篤字季雅，京兆杜陵人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000003",
    "sentence": "髙祖延年，宣帝時爲御史大夫。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000004",
    "sentence": "篤少博學，不修小節，不爲鄕人所禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000005",
    "sentence": "居美陽，與美陽令遊，數從請託，不諧，頗相恨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000006",
    "sentence": "令怒，收篤送京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000007",
    "sentence": "會大司馬呉漢薨，光武詔諸儒誄之，篤於獄中爲誄，辭最髙，美帝之，賜帛免刑。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000008",
    "sentence": "篤以關中表裏山河，先帝舊京，不宜改營洛邑，乃上奏《論都賦》曰：",
    "entities": [
      {
        "text": "篤以關",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "不宜改營洛邑",
        "label": "LOC",
        "start": 14,
        "end": 20
      },
      {
        "text": "《論都賦》",
        "label": "TITLE",
        "start": 24,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000009",
    "sentence": "臣聞知而復知，是爲重知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000010",
    "sentence": "臣所欲言，陛下已知，故略其梗槪，不敢具陳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000011",
    "sentence": "昔般庚去奢，行儉於亳；成周之隆，乃即中洛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000012",
    "sentence": "遭時制都，不常厥邑。",
    "entities": [
      {
        "text": "不常厥邑",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000013",
    "sentence": "賢聖之慮，蓋有優劣；霸王之姿，明知相絶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000014",
    "sentence": "守國之勢，同歸異術；或棄去阻厄，務處平易；或據山帶河，幷呑六國；或富貴思歸，不顧見襲；或掩空撃虚，自蜀漢出，即日車駕，策由一卒；或知而不從，久都墝埆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000015",
    "sentence": "臣不敢有所據。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000016",
    "sentence": "竊見司馬相如、楊子雲作辭賦以諷主上，臣誠慕之，伏作書一篇，名曰《論都》，謹幷封奏如左。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "《論都》",
        "label": "TITLE",
        "start": 31,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000017",
    "sentence": "皇帝以建武十八年二月甲辰，昇輿洛邑，巡於西岳。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "建武十八年",
        "label": "TME",
        "start": 3,
        "end": 8
      },
      {
        "text": "昇輿洛邑",
        "label": "LOC",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000018",
    "sentence": "推天時，順斗極，排閶闔，入函谷，觀厄於崤、黽，圖險於隴、蜀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000019",
    "sentence": "其三月丁酉，行至長安。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000020",
    "sentence": "經營宮室，傷愍舊京，即詔京兆，乃命扶風，齋肅致敬，告覲園陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000021",
    "sentence": "凄然有懷祖之思，喟乎以思諸夏之隆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000022",
    "sentence": "遂天旋雲遊，造舟於渭，北𣃚涇流。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000023",
    "sentence": "千乘方轂，萬騎駢羅，衍陳於岐、梁，東橫乎大河。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000024",
    "sentence": "瘞後土，禮B723郊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000025",
    "sentence": "其歳四月，反於洛都。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000026",
    "sentence": "明年，有詔復函谷關，作大駕宮、六王邸、髙車廄於長安。",
    "entities": [
      {
        "text": "有詔復函谷關",
        "label": "LOC",
        "start": 3,
        "end": 9
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000027",
    "sentence": "修理東都城門，橋涇、渭，往往繕離觀。",
    "entities": [
      {
        "text": "修理東都城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000028",
    "sentence": "東臨霸、滻，西望昆明，北登長平，規龍首，撫未央，覛平樂，儀建章。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000029",
    "sentence": "是時山東翕然狐疑，意聖朝之西都，懼關門之反拒也。",
    "entities": [
      {
        "text": "懼關",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000030",
    "sentence": "客有爲篤言：「彼C279井之潢汚，固不容夫呑舟；且洛邑之渟瀯，曷足以居乎萬乘哉？咸陽守國利器，不可久虚，以示奸萌。」篤未甚然其言也，故因爲述大漢之崇，世據雍州之利，而今國家未暇之故，以喩客意。",
    "entities": [
      {
        "text": "且洛邑",
        "label": "LOC",
        "start": 24,
        "end": 27
      },
      {
        "text": "世據雍州",
        "label": "LOC",
        "start": 75,
        "end": 79
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000031",
    "sentence": "曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000032",
    "sentence": "昔在強秦，爰初開畔，霸自岐、雍，國富人衍，卒以幷兼，桀虐作亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000033",
    "sentence": "天命有聖，託之大漢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000034",
    "sentence": "大漢開基，髙祖有勛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000035",
    "sentence": "斬白蛇，屯黑雲，聚五星於東井，提干將而呵暴秦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000036",
    "sentence": "蹈滄海，跨昆侖，奮彗光，掃項軍，遂濟人難，蕩滌於泗、沂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000037",
    "sentence": "劉敬建策，初都長安。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000038",
    "sentence": "太宗承流，守之以文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000039",
    "sentence": "躬履節儉，側身行仁，食不二味，衣無異采。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000040",
    "sentence": "賑人以農桑，率下以約已，曼麗之容不悅於目，鄭、衞之聲不過於耳，佞邪之臣不列於朝，巧僞之物不鬻於市，故能理昇平而刑幾措。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000041",
    "sentence": "富衍於孝、景，功傳於後嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000042",
    "sentence": "是時，孝武因其餘財府帑之蓄，始有鈎深圖遠之意，探冒頓之罪，校平城之仇。",
    "entities": [
      {
        "text": "校平城",
        "label": "LOC",
        "start": 29,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000043",
    "sentence": "遂命票騎，勤任衞靑，勇惟鷹揚，軍如流星，深之匈奴，割裂王庭，席巻漠北，叩勒祁連，橫分單於，屠裂百蠻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000044",
    "sentence": "燒罽帳，繫閼氏，燔康居，灰珍奇，椎鳴鏑，釘鹿蠡，馳坑岸，獲昆彌，虜亻數侲，驅騾驢，御宛馬，鞭B147騠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000045",
    "sentence": "拓地萬里，威震八荒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000046",
    "sentence": "肇置四郡，據守敦煌。",
    "entities": [
      {
        "text": "肇置四郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000047",
    "sentence": "幷域屬國，一郡領方。",
    "entities": [
      {
        "text": "一郡",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000048",
    "sentence": "立侯隅北，建護西羌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000049",
    "sentence": "捶驅氐、僰，寥狼卭、莋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000050",
    "sentence": "東摩烏桓，蹂轔濊貊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000051",
    "sentence": "南羈鈎町，水劍強越。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000052",
    "sentence": "殘夷文身，海波沫血。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000053",
    "sentence": "郡縣日南，漂槪硃崖。",
    "entities": [
      {
        "text": "郡縣",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000054",
    "sentence": "部尉東南，兼有黃支。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000055",
    "sentence": "連緩耳，瑣雕題，摧天督，牽象犀，椎蚌蛤，碎琉璃，甲玳瑁，戕觜觿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000056",
    "sentence": "於是同穴裘褐之域，共川鼻飲之國，莫不袒跣稽顙，失氣虜伏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000057",
    "sentence": "非夫大漢之世盛，世借雍土之饒，得御外理内之術，孰能致功若斯！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000058",
    "sentence": "故創業於髙祖，嗣傳於孝惠，德隆於太宗，財衍於孝景，威盛於聖武，政行於宣、元，侈極於成、哀、祚缺於孝平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000059",
    "sentence": "傳世十一，歴載三百，德衰而復盈，道微而復章，皆莫能遷於雍州，而背於咸陽。",
    "entities": [
      {
        "text": "皆莫能遷於雍州",
        "label": "LOC",
        "start": 22,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000060",
    "sentence": "宮室寢廟，山陵相望，髙顯弘麗，可思可榮，羲、農已來，無茲著明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000061",
    "sentence": "夫雍州本帝皇所以育業、霸王所以衍功，戰士角難之塲也。",
    "entities": [
      {
        "text": "夫雍州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000062",
    "sentence": "《禹貢》所載，厥田惟上。",
    "entities": [
      {
        "text": "《禹貢》",
        "label": "TITLE",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000063",
    "sentence": "沃野千里，原隰彌望。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000064",
    "sentence": "保殖五谷，桑麻條暢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000065",
    "sentence": "濱據南山，帶以涇、渭，號曰陸海，蠢生萬類。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000066",
    "sentence": "楩枏檀柘，蔬果成實。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000067",
    "sentence": "畎瀆潤淤，水泉灌漑，漸澤成川，粳稻陶遂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000068",
    "sentence": "厥土之膏，畝價一金。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000069",
    "sentence": "田田相如，鐇䦆株林。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000070",
    "sentence": "火耕流種，功淺得深。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000071",
    "sentence": "旣有蓄積，厄塞四臨：四被隴、蜀，南通漢中，北據谷口，東阻嶔巖。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 18,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000072",
    "sentence": "關函守嶢，山東道窮；置列汧、隴，壅偃西戎；拒守褒斜，嶺南不通；杜口絶津，朔方無從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000073",
    "sentence": "鴻、渭之流，徑入於河；大船萬艘，轉漕相過；東綜滄海，西綱流紗；朔南暨聲，諸夏是和。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000074",
    "sentence": "城池百尺，厄塞要害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000075",
    "sentence": "關梁之險，多所衿帶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000076",
    "sentence": "一卒舉礧，千夫沉滯；一人奮戟，三軍沮敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000077",
    "sentence": "地勢便利，介胄剽悍，可與守近，利以攻遠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000078",
    "sentence": "士卒易保，人不肉袒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000079",
    "sentence": "肇十有二，是爲贍腴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000080",
    "sentence": "用霸則兼幷，先據則功殊；修文則財衍，行武則士要；爲政則化上，篡逆則難誅；進攻則百克，退守則有餘：斯固帝王之淵囿，而守國之利器也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000081",
    "sentence": "逮及亡新，時漢之衰，偸忍淵囿，篡器慢違，徒以勢便，莫能卒危。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000082",
    "sentence": "假之十八，誅自京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000083",
    "sentence": "天畀更始，不能引維。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000084",
    "sentence": "慢藏招寇，復致赤眉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000085",
    "sentence": "海内雲擾，諸夏滅微。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000086",
    "sentence": "群龍幷戰，未知是非。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000087",
    "sentence": "於時聖帝，赫然申威，荷天人之符，兼不世之姿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000088",
    "sentence": "受命於皇上，獲助於靈祇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000089",
    "sentence": "立號髙邑，搴旗四麾。",
    "entities": [
      {
        "text": "立號髙邑",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000090",
    "sentence": "首策之臣，運籌出奇；虓怒之旅；如虎如螭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000091",
    "sentence": "師之攸向，無不靡披。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000092",
    "sentence": "蓋夫燔魚剸蛇，莫之方斯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000093",
    "sentence": "大呼山東，響動流沙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000094",
    "sentence": "要龍淵，首鏌鋣，命騰太白，親發狼、弧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000095",
    "sentence": "南禽公孫，北背強胡，西平隴、冀，東據洛都。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000096",
    "sentence": "乃廓平帝宇，濟蒸人於塗炭，成兆庶之[F131][F131]，遂興復乎大漢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000097",
    "sentence": "今天下新定，矢石之勤始瘳，而主上方以邊垂爲憂，忿葭萌之不柔，未遑於論都而遺思雍州也。",
    "entities": [
      {
        "text": "論都而遺思雍州",
        "label": "LOC",
        "start": 33,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000098",
    "sentence": "方躬勞聖思，以率海内，厲撫名將，略地疆外，信威於徴伐，展武乎荒裔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000099",
    "sentence": "若夫文身鼻飲緩耳之主，椎結左衽F045鍝之君，東南殊俗不羈之國，西北絶域難制之鄰，靡不重譯納貢，請爲籓臣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000100",
    "sentence": "上猶謙讓，而不伐勤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000101",
    "sentence": "意以爲獲無用之虜，不如安有益之民；略荒裔之地，不如保殖五谷之淵；遠救於已亡，不若近而存存也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000102",
    "sentence": "今國家躬修道德，吐惠含仁，湛恩沾洽，時風顯宣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000103",
    "sentence": "徒垂意於持平守實，務在愛育元元，苟有便於王政者，聖主納焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000104",
    "sentence": "何則？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000105",
    "sentence": "物罔挹而不損，道無隆而不移，陽盛則運，陰滿則虧，故存不忘亡，安不諱危，雖有仁義，猶設城池也。",
    "entities": [
      {
        "text": "猶設城",
        "label": "LOC",
        "start": 40,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000106",
    "sentence": "客以利器不可久虚，而國家亦不忘乎西都，何必去洛邑之渟瀯與？",
    "entities": [
      {
        "text": "何必去洛邑",
        "label": "LOC",
        "start": 19,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000107",
    "sentence": "篤後仕郡文學掾。",
    "entities": [
      {
        "text": "篤後仕郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000108",
    "sentence": "以目疾，二十餘年不窺京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000109",
    "sentence": "篤之外髙祖破羌將軍辛武賢，以武略稱。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "辛武賢",
        "label": "PER",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000110",
    "sentence": "篤常嘆曰：「杜氏文明善政，而篤不任爲吏；辛氏秉義經武，而篤又怯於事。外内五世，至篤衰矣！」",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000111",
    "sentence": "女弟適扶風馬氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000112",
    "sentence": "建初三年 ，車騎將軍馬防撃西羌，請篤爲從事中郎，戰沒於射姑山。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000113",
    "sentence": "所著賦、誄、弔、書、贊、《七言》、《女誡》及雜文，凡十八篇。",
    "entities": [
      {
        "text": "《七言》",
        "label": "TITLE",
        "start": 12,
        "end": 16
      },
      {
        "text": "《女誡》",
        "label": "TITLE",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000114",
    "sentence": "又著《明世論》十五篇。",
    "entities": [
      {
        "text": "《明世論》",
        "label": "TITLE",
        "start": 2,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000115",
    "sentence": "子碩，豪俠，以貨殖聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000116",
    "sentence": "王隆",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000117",
    "sentence": "王隆字文山，馮翊雲陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000118",
    "sentence": "王莽時，以父任爲郎，後避難河西，爲竇融左護軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000119",
    "sentence": "建武中，爲新汲令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000120",
    "sentence": "能文章，所著詩、賦、銘、書凡二十六篇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000121",
    "sentence": "初，王莽末，沛國史岑子孝亦以文章顯，莽以爲謁者，著頌、誄、《復神》、《説疾》凡四篇。",
    "entities": [
      {
        "text": "沛",
        "label": "LOC",
        "start": 6,
        "end": 7
      },
      {
        "text": "《復神》",
        "label": "TITLE",
        "start": 29,
        "end": 33
      },
      {
        "text": "《説疾》",
        "label": "TITLE",
        "start": 34,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000122",
    "sentence": "夏恭",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000123",
    "sentence": "夏恭字敬公，梁國蒙人也。",
    "entities": [
      {
        "text": "梁國",
        "label": "ORG",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000124",
    "sentence": "習《 韓詩 》、《孟氏易》，講授門徒常千餘人。",
    "entities": [
      {
        "text": "《 韓詩 》",
        "label": "TITLE",
        "start": 1,
        "end": 7
      },
      {
        "text": "《孟氏易》",
