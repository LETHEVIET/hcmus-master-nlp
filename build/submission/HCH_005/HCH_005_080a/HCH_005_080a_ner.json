        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000125",
    "sentence": "王莽末，盜賊從橫，攻沒郡縣。",
    "entities": [
      {
        "text": "攻沒郡縣",
        "label": "LOC",
        "start": 9,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000126",
    "sentence": "恭以恩信爲衆所附，擁兵固守，獨安全。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000127",
    "sentence": "光武即位，嘉其忠果，召拜郎中，再遷太山都尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000128",
    "sentence": "和集百姓，甚得其歡心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000129",
    "sentence": "恭善爲文，著賦、頌、詩、《勵學》凡二十篇。",
    "entities": [
      {
        "text": "《勵學》",
        "label": "TITLE",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000130",
    "sentence": "年四十九卒官，諸儒共謚曰宣明君。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000131",
    "sentence": "子牙，少習家業，著賦、頌、贊、誄凡四十篇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000132",
    "sentence": "舉孝廉，早卒，鄕人號曰文德先生。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000133",
    "sentence": "傅毅",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000134",
    "sentence": "傅毅字武仲，扶風茂陵人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000135",
    "sentence": "少傅學。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000136",
    "sentence": "永平中，於平陵習章句，因作《迪志詩》曰：",
    "entities": [
      {
        "text": "《迪志詩》",
        "label": "TITLE",
        "start": 13,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_080a_000137",
    "sentence": "咨爾庶士，迨時斯勗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000138",
    "sentence": "日月逾邁，豈雲旋復！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000139",
    "sentence": "哀我經營，旅力靡及。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000140",
    "sentence": "在茲弱寇，靡所庶立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000141",
    "sentence": "於赫我祖，顯於殷國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000142",
    "sentence": "二迹阿衡，克光其則。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000143",
    "sentence": "武丁興商，伊宗皇士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000144",
    "sentence": "爰作股肱，萬邦是紀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000145",
    "sentence": "奕世載德，迄我顯考。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000146",
    "sentence": "保膺淑懿，纘修其道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000147",
    "sentence": "漢之中葉，俊乂式序，秩彼殷宗，光此勛緒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000148",
    "sentence": "伊餘小子，穢陋靡逮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000149",
    "sentence": "懼我世烈，自茲以墜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000150",
    "sentence": "誰能革濁，淸我濯漑？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000151",
    "sentence": "誰能昭暗，啓我童昧？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000152",
    "sentence": "先人有訓，我訊我誥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000153",
    "sentence": "訓我嘉務，誨我博學。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000154",
    "sentence": "爰率朋友，尋此舊則。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000155",
    "sentence": "契闊夙夜，庶不懈忒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000156",
    "sentence": "秩秩大猷，紀綱庶式。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000157",
    "sentence": "匪勤匪昭，匪壹匪測。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000158",
    "sentence": "農夫不怠，越有黍稷，誰能云作，考之居息？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000159",
    "sentence": "二事敗業，多疾我力。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000160",
    "sentence": "如彼遵衢，則罔所極。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000161",
    "sentence": "二志靡成，聿勞我心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000162",
    "sentence": "如彼兼聽，則溷於音。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000163",
    "sentence": "於戲君子，無恆自逸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000164",
    "sentence": "徂年如流，鮮暇日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000165",
    "sentence": "行邁屢稅，胡能有迄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000166",
    "sentence": "密勿朝夕，聿同始卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_080a_000167",
    "sentence": "毅以顯宗求賢不篤，士多隱處，故作《七激》以爲諷。",
    "entities": [
      {
        "text": "《七激》",
