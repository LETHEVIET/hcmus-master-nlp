      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000217",
    "sentence": "父戒，為太尉，桓帝立，以定策封廚亭侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000218",
    "sentence": "典少篤行隱約，博學經書，弟子自遠方至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000219",
    "sentence": "建和初，四府表薦，征拜議郎，侍講禁內，再遷為侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000220",
    "sentence": "時，帝欲廣開鴻池，典諫曰：『鴻池泛溉，已且百頃，猶復增而深之，非所以崇唐、虞之約己，遵孝之愛人也。』帝納其言而止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000221",
    "sentence": "父卒，襲封。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000222",
    "sentence": "出為弘農太守，轉右扶風。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000223",
    "sentence": "公事去官，征拜城門校尉，轉將作大匠，遷少府，又轉大鴻臚。",
    "entities": [
      {
        "text": "征拜城",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000224",
    "sentence": "時，恩澤諸侯以無勞受封，群臣不悅而莫敢諫，典獨奏曰：『夫無功而賞，勞者不勸，上忝下辱，亂象幹度。且高祖之誓，非功臣不封。宜一切削免爵士，以存舊典。』帝不從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000225",
    "sentence": "頃之，轉太仆，遷太常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000226",
    "sentence": "朝廷每有災異疑議，輒咨問之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000227",
    "sentence": "典據經正對，無所曲折。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000228",
    "sentence": "每得賞賜，輒分與諸生之貧者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000229",
    "sentence": "後以諫爭違旨，免官就國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000230",
    "sentence": "會帝崩，時禁藩國諸侯不得奔吊，典慨然曰：『身從衣褐之中，致位上列。且鳥烏反哺報德，況於士邪！』遂解印綬符策付縣，而馳到京師。",
    "entities": [
      {
        "text": "解印綬符策付縣",
        "label": "LOC",
        "start": 48,
        "end": 55
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000231",
    "sentence": "州郡及大鴻臚並執處其罪，而公卿百寮嘉典之義，表請以租自贖，詔書許之。",
    "entities": [
      {
        "text": "州郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000232",
    "sentence": "再遷長樂少府、衛尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000233",
    "sentence": "公卿復表典篤學博聞，宜備國師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000234",
    "sentence": "會病卒，使者吊祠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000235",
    "sentence": "竇太后復遣使兼贈印綬，謚曰獻侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000236",
    "sentence": "典兄子謙，謙弟溫，相繼為三公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000237",
    "sentence": "兄子 謙",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000238",
    "sentence": "謙字彥信， 初平元年 ，代黃琬為太尉。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000239",
    "sentence": "獻帝遷都長安，以謙行車騎將軍，為前置。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000240",
    "sentence": "明年病罷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000241",
    "sentence": "復為司隸校尉。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000242",
    "sentence": "車師王侍子為董卓所愛，數犯法，謙收殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000243",
    "sentence": "卓大怒，殺都官從事，而素敬憚謙，故不加罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000244",
    "sentence": "轉為前將軍，遣擊白波賊，有功，封郫侯。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000245",
    "sentence": "李傕殺司徒王允，復代允為司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000246",
    "sentence": "數月病免，拜尚書令。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000247",
    "sentence": "是年卒，溢曰忠侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000248",
    "sentence": "謙弟 溫",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000249",
    "sentence": "溫字子柔，初為京兆丞，嘆曰：『大丈夫當雄飛，安能雌伏！』遂棄官去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000250",
    "sentence": "遭歲大饑，散家糧以振窮餓，所活萬餘人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000251",
    "sentence": "獻帝西遷都，為侍中，同輿輦至長安，封江南亭侯，代楊彪為司空，免，頃之，復為司徒，錄尚書事。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 14,
        "end": 16
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 41,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000252",
    "sentence": "時，李傕與郭汜相攻，傕遂虜掠禁省，動帝幸北塢，外內隔絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000253",
    "sentence": "傕素疑溫不與己同，乃內溫於塢中，又欲移乘輿於黃白城。",
    "entities": [
      {
        "text": "移乘輿於黃白城",
        "label": "LOC",
        "start": 18,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000254",
    "sentence": "溫與傕書曰：『公前托為董公報仇，然實屠陷王城，殺戮大臣，天下不可家見而戶說也。今與郭汜爭睚眥之隙，以成千鈞之仇，人在塗炭，各不聊生。曾不改悟，遂成禍亂。朝廷仍下明詔，欲令和解。上命不行，威澤日損。而復欲移轉乘輿，更幸非所，此誠老夫所不達也。於《 易 》，一為過，再為涉，三而弗改，滅其頂，兇。不如早共和解，引軍還屯，上安萬乘，下全人民，豈不幸甚。』傕大怒，欲遣人殺溫。",
    "entities": [
      {
        "text": "然實屠陷王城",
        "label": "LOC",
        "start": 16,
        "end": 22
      },
      {
        "text": "《 易 》",
        "label": "TITLE",
        "start": 121,
        "end": 126
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000255",
    "sentence": "李傕從弟應，溫故掾也，諫之數日，乃獲免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000256",
    "sentence": "溫從車駕都許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000257",
    "sentence": "建安十三年 ，以辟司空曹操子丕為掾，操怒，奏溫辟臣子弟，選舉不實，免官。",
    "entities": [
      {
        "text": "建安十三年",
        "label": "TME",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000258",
    "sentence": "是歲卒，年七十二。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000259",
    "sentence": "贊",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000260",
    "sentence": "贊曰：宣、鄭、二王，奉身清方。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000261",
    "sentence": "杜林據古，張湛矜莊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000262",
    "sentence": "典以義黜，宮由德揚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000263",
    "sentence": "大儀鵠發，見表憲王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000264",
    "sentence": "少卿誌仕，終乘高箱。",
    "entities": []
  }
]
