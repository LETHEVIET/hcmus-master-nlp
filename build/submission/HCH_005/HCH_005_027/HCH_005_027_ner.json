        "end": 12
      },
      {
        "text": "終不出關",
        "label": "LOC",
        "start": 27,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000149",
    "sentence": "大司馬嚴尤請丹，辭病不就。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000150",
    "sentence": "王莽又征之，遂與諸生逃於北地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000151",
    "sentence": "更始二年 ，三公舉丹賢能，征為諫議大夫，持節使歸南陽，安集受降。",
    "entities": [
      {
        "text": "更始二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000152",
    "sentence": "丹自去家十有二年，果乘高車出關，如其誌焉。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 6,
        "end": 8
      },
      {
        "text": "果乘高車出關",
        "label": "LOC",
        "start": 9,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000153",
    "sentence": "更始敗，諸將悉歸光武，並獲封爵；丹獨保平氏不下，為更始發喪，衰绖盡哀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000154",
    "sentence": "建武二年，遂潛逃去，敝衣間行，涉歷險阻，求謁更始妻子，奉還節傳，因歸鄉裏。",
    "entities": [
      {
        "text": "建武二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "因歸鄉",
        "label": "LOC",
        "start": 32,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000155",
    "sentence": "太守杜詩請為功曹，丹薦鄉人長者自代而去。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "丹薦鄉",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000156",
    "sentence": "詩乃嘆曰：『昔明王興化，卿士讓位，今功曹推賢，可謂至德。敕以丹事編署黃堂，以為後法。』",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000157",
    "sentence": "十三年，大司馬吳漢辟舉高第，再遷並州牧，有清平稱。",
    "entities": [
      {
        "text": "十三年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "再遷並州",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000158",
    "sentence": "轉使匈奴中郎將，遷左馮翊。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000159",
    "sentence": "永平三年 ，代李訢為司徒。",
    "entities": [
      {
        "text": "永平三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000160",
    "sentence": "在朝廉直公正，與侯霸、杜林、張湛、郭伋齊名相善。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000161",
    "sentence": "明年，坐考隴西太守鄧融事無所據，策免。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000162",
    "sentence": "五年，卒於家，時年八十七。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000163",
    "sentence": "以河南尹範遷有清行，代為司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000164",
    "sentence": "遷字子廬，沛國人，初為漁陽太守，以智略安邊，匈奴不敢入界。",
    "entities": [
      {
        "text": "沛",
        "label": "LOC",
        "start": 5,
        "end": 6
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000165",
    "sentence": "及在公輔，有宅數畝，田不過一頃，復推與兄子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000166",
    "sentence": "其妻嘗謂曰：『君有四子而無立錐之地，可余奉祿，以為後世業。』遷曰：『吾備位大臣而蓄財求利，何以示後世！』在位四年薨，家無擔石焉。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 54,
        "end": 56
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000167",
    "sentence": "後顯宗因朝會問群臣：『郭丹家今何如？』宗正劉匡對曰：『昔孫叔敖相楚，馬不秣粟，妻不衣帛，子孫竟蒙寢丘之封。丹出典州郡，入為三公，而家無遺產，子孫困匱。』帝乃下南陽訪求其嗣。",
    "entities": [
      {
        "text": "丹出典州郡",
        "label": "LOC",
        "start": 53,
        "end": 58
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000168",
    "sentence": "長子宇，官至常山太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000169",
    "sentence": "少子濟，趙相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000170",
    "sentence": "吳良",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000171",
    "sentence": "吳良字大儀，齊國臨淄人也。",
    "entities": [
      {
        "text": "齊國",
        "label": "ORG",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000172",
    "sentence": "初為郡吏，歲旦與掾史入賀，門下掾王望舉觴上壽，謅稱太守功德。",
    "entities": [
      {
        "text": "初為郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000173",
    "sentence": "良於下坐勃然進曰：『望佞邪之人，欺謅無狀，願勿受其觴。』太守斂容而止。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000174",
    "sentence": "宴罷，轉良為功曹；恥以言受進，終不肯謁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000175",
    "sentence": "時，驃騎將軍東平王蒼聞而辟之，署為西曹。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000176",
    "sentence": "蒼甚相敬受，上疏薦良曰：『臣聞為國所重，必在得人；報恩之義，莫大薦士。竊見臣府西曹掾齊國吳良，資質敦固，公方廉恪，躬儉安貧，白首一節；又治《 尚書 》，學通師法，經任博士，行中表儀。宜備宿衛，以輔聖政。臣蒼榮寵絕矣，憂責深大，私慕公叔同升之義，懼於臧文竊位之罪，敢秉愚瞽，犯冒嚴禁。』顯宗以示公卿曰：『前以事見良，鬚髮皓然，衣冠甚偉。夫薦賢助國，宰相之職，蕭何舉韓信，設壇而拜，不復考試。今以良為議郎。』",
    "entities": [
      {
        "text": "齊國",
        "label": "ORG",
        "start": 42,
        "end": 44
      },
      {
        "text": "博士",
        "label": "TITLE",
        "start": 83,
        "end": 85
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000177",
    "sentence": "永平中，車駕近出，而信陽侯陰就幹突禁衛，車府令徐匡鉤就車，收禦者送獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000178",
    "sentence": "詔書譴匡，匡乃自系。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000179",
    "sentence": "良上言曰：『信陽侯就倚恃外戚，幹犯乘輿，無人臣禮，為大不敬。匡執法守正，反下於理，臣恐聖化由是而弛。』帝雖赦匡，猶左轉良為即丘長。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000180",
    "sentence": "後遷司徒長史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000181",
    "sentence": "每處大議，輒據經典，不希旨偶俗，以僥時譽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000182",
    "sentence": "後坐事免，復拜議郎，卒於官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000183",
    "sentence": "承宮",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000184",
    "sentence": "承宮字少子，瑯邪姑幕人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000185",
    "sentence": "少孤，年八歲為人牧豕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000186",
    "sentence": "鄉裏徐子盛者，以《春秋經》授諸生數百人，宮過息廬下，樂其業，因就聽經，遂請留門下，為諸生拾薪。",
    "entities": [
      {
        "text": "《春秋經》",
        "label": "TITLE",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000187",
    "sentence": "執苦數年，勤學不倦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000188",
    "sentence": "經典既明，乃歸家教授。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000189",
    "sentence": "遭天下喪亂，遂將諸生避地漢中，後與妻子之蒙陰山，肆力耕種。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 12,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000190",
    "sentence": "禾黍將孰，人有認之者，宮不與計，推之而去，由是顯名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000191",
    "sentence": "三府更辟，皆不應。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000192",
    "sentence": "永平中，征詣公車。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000193",
    "sentence": "車駕臨辟雍，召宮拜博士，遷左中郎將。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000194",
    "sentence": "數納忠言，陳政，論議切愨，朝臣憚其節，名播匈奴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000195",
    "sentence": "時，北單於遣使求得見宮，顯宗敕自整飾，宮對曰：『夷狄眩名，非識實者也。臣狀醜，不可以示遠，宜選有威容者。』帝乃以大鴻臚魏應代之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000196",
    "sentence": "十七年，拜侍中祭酒。",
    "entities": [
      {
        "text": "十七年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000197",
    "sentence": "建初元年 ，卒，肅宗褒嘆，賜以冢地。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000198",
    "sentence": "妻上書乞歸葬鄉裏，復賜錢三十萬。",
    "entities": [
      {
        "text": "妻上書乞歸葬鄉",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000199",
    "sentence": "鄭均",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000200",
    "sentence": "鄭均字仲虞，東平任城人也。",
    "entities": [
      {
        "text": "東平任城",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000201",
    "sentence": "少好黃、老書。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000202",
    "sentence": "兄為縣吏，頗受禮遺，均數諫止，不聽。",
    "entities": [
      {
        "text": "兄為縣",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000203",
    "sentence": "即脫身為傭，歲餘，得錢帛，歸以與兄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000204",
    "sentence": "曰：『物盡可復得，為吏坐臧，終身捐棄。』兄感其言，遂為廉潔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000205",
    "sentence": "均好義篤實，養寡嫂孤兒，恩禮敦至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000206",
    "sentence": "常稱病家廷，不應州郡辟召。",
    "entities": [
      {
        "text": "不應州郡",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000207",
    "sentence": "郡將欲必致之，使縣令譎將詣門，既至，卒不能屈。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000208",
    "sentence": "均於是客於濮陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000209",
    "sentence": "建初三年 ，司徒鮑昱辟之，後舉直言，並不詣。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000210",
    "sentence": "六年，公車特征。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000211",
    "sentence": "再遷尚書，數納忠言，肅宗敬重之。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000212",
    "sentence": "後以病乞骸骨，拜議郎，告歸，因稱病篤，帝賜以衣冠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000213",
    "sentence": "元和元年 ，詔告廬江太守、東平相曰：『議郎鄭均，束脩安貧，恭儉節整，前在機密，以病致仕，守善貞固，黃髮不怠。又前安邑令毛義，躬履遜讓，比徵辭病，淳潔之風，東州稱仁。書不雲乎：「章厥有常，吉哉！」其賜均、義谷各千斛，常以八月長吏存問，賜羊酒，顯茲異行。』明年，帝東巡過任城，乃幸均舍，敕賜尚書祿以終其身，故時人號為『白衣尚書』。",
    "entities": [
