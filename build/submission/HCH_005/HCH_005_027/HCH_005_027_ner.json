    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000216",
    "sentence": "趙典字仲經，蜀郡成都人也。",
    "entities": [
      {
        "text": "蜀郡",
        "label": "LOC",
        "start": 6,
        "end": 8
      },
      {
        "text": "成都",
        "label": "LOC",
        "start": 8,
