[
  {
    "sentence_id": "HCH_005_027_000001",
    "sentence": "宣秉",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000002",
    "sentence": "宣秉字巨公，馮翊雲陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000003",
    "sentence": "少修高節，顯名三輔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000004",
    "sentence": "哀、平際，見王氏據權專政，侵削宗室，有逆亂萌，遂隱遁深山，州郡連召，常稱疾不仕。",
    "entities": [
      {
        "text": "州郡",
        "label": "LOC",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000005",
    "sentence": "王莽為宰衡，辟命不應。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000006",
    "sentence": "及莽篡位，又遣使者征之，秉固稱疾病。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000007",
    "sentence": "更始即位，征為侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000008",
    "sentence": "建武元年 ，拜禦史中丞。",
    "entities": [
      {
        "text": "建武元年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000009",
    "sentence": "光武特詔禦史中丞與司隸校尉、尚書令會同並專席而坐，故京師號曰『三獨坐』。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000010",
    "sentence": "明年，遷司隸校尉。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000011",
    "sentence": "務舉大綱，簡略苛細，百僚敬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000012",
    "sentence": "秉性節約，常服布被，蔬食瓦器。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000013",
    "sentence": "帝嘗幸其府舍，見而嘆曰：『楚國二龔，不如雲陽宣巨公。』即賜布帛帳帷什物。",
    "entities": [
      {
        "text": "楚國",
        "label": "ORG",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000014",
    "sentence": "四年，拜大司徒司直。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000015",
    "sentence": "所得祿奉，輒以收養親族。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000016",
    "sentence": "其孤弱者，分與田地，自無擔石之儲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000017",
    "sentence": "六年，卒於官，帝敏惜之，除子彪為郎。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000018",
    "sentence": "張湛",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000019",
    "sentence": "張湛字子孝，扶風平陵人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000020",
    "sentence": "矜嚴好禮，動止有則，居處幽室，必自修整，雖遇妻子，若嚴君焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000021",
    "sentence": "及在鄉黨，詳言正色，三輔以為儀表。",
    "entities": [
      {
        "text": "及在鄉",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000022",
    "sentence": "人或謂湛偽詐，湛聞而笑曰：『我誠詐也。人皆詐惡，我獨詐善，不亦可乎？』",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000023",
    "sentence": "成、哀間，為二千石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000024",
    "sentence": "王莽時，歷太守、都尉。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000025",
    "sentence": "建武初，為左馮翊，在郡修典禮，設條教，政化大行。",
    "entities": [
      {
        "text": "在郡",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000026",
    "sentence": "後告歸平陵，望寺門而步。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000027",
    "sentence": "主簿進曰：『明府位尊德重，不宜自輕。』湛曰：『《禮》，下公門，軾輅馬。孔子於鄉黨，恂恂如也。父母之國，所宜盡禮，何謂輕哉？』",
    "entities": [
      {
        "text": "《禮》",
        "label": "TITLE",
        "start": 23,
        "end": 26
      },
      {
        "text": "孔子於鄉",
        "label": "LOC",
        "start": 35,
        "end": 39
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000028",
    "sentence": "五年，拜光祿勛。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000029",
    "sentence": "光武臨朝，或有惰容，湛輒陳諫其失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000030",
    "sentence": "常乘白馬，帝每見湛，輒言『白馬生且復諫矣』。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000031",
    "sentence": "七年，以病乞身，拜光祿大夫，代王丹為太子太傅。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000032",
    "sentence": "及郭后廢，因稱疾不朝，拜太中大夫，居中東門候舍，故時人號曰中東門君。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000033",
    "sentence": "帝數存問賞賜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000034",
    "sentence": "後大徒戴涉被誅，帝強起湛以代之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000035",
    "sentence": "湛至朝堂，遺失溲便，因自陳疾篤，不能復任朝事，遂罷之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000036",
    "sentence": "後數年，卒於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000037",
    "sentence": "王丹",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000038",
    "sentence": "王丹字仲回，京兆下邽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000039",
    "sentence": "哀、平時，仕州郡。",
    "entities": [
      {
        "text": "仕州郡",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000040",
    "sentence": "王莽時，連征不至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000041",
    "sentence": "家累千金，隱居養誌，好施周急。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000042",
    "sentence": "每歲農時，輒載酒肴於田間，候勤者而勞之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000043",
    "sentence": "其墮懶者，恥不致丹，皆兼功自厲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000044",
    "sentence": "邑聚相率，以致殷富。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000045",
    "sentence": "其輕黠遊蕩廢業為患者，輒曉其父兄，使黜責之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000046",
    "sentence": "沒者則賻給，親自將護。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000047",
    "sentence": "其有遭喪憂者，輒待丹為辦，鄉鄰以為常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000048",
    "sentence": "行之十餘年，其化大洽，風俗以篤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000049",
    "sentence": "丹資性方潔，疾惡強豪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000050",
    "sentence": "時，河南太守同郡陳遵，關西之大俠也。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000051",
    "sentence": "其友人喪親，遵為護喪事，賻助甚豐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000052",
    "sentence": "丹乃懷縑一匹，陳之於主人前，曰：『如丹此縑，出自機杼。』遵聞而有慚色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000053",
    "sentence": "自以知名，欲結交於丹，丹拒而不許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000054",
    "sentence": "會前將軍鄧禹西征關中，軍糧乏，丹率宗族上表二千斛。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000055",
    "sentence": "禹在領左馮翊，稱疾不視事，免歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000056",
    "sentence": "後征為太子少傅。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000057",
    "sentence": "時，大司徒侯霸欲與交友，及丹被征，遣子昱候於道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000058",
    "sentence": "昱迎拜車下，丹下答之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000059",
    "sentence": "昱曰：『家公欲與君結交，何為見拜？』丹曰：『君房有是言，丹未之許也。』",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000060",
    "sentence": "丹子有同門生喪家，家在中山，白丹欲往奔慰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000061",
    "sentence": "結侶將行，丹怒而撻之，令寄縑以祠焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000062",
    "sentence": "或問其故，丹曰：『交道之難，未易言也。世稱管、鮑，次則王、貢。張、陳兇其終，蕭，朱隙其末，故知全之者鮮矣。』時人服其言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000063",
    "sentence": "客初有薦士於丹者，因選舉之，而後所舉者陷罪，丹坐以免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000064",
    "sentence": "客慚懼自絕，而丹終無所言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000065",
    "sentence": "尋復征為太子太傅，乃呼客謂曰：『子之自絕，何量丹之薄也？』不為設食以罰之，相待如舊。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000066",
    "sentence": "其後遜位，卒於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000067",
    "sentence": "王良",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000068",
    "sentence": "王良字仲子，東海蘭陵人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000069",
    "sentence": "少好學，習《小夏侯尚書》。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000070",
    "sentence": "王莽時，寢病不仕，教授諸生千餘人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000071",
    "sentence": "建武二年 ，大司馬吳漢辟，不應。",
    "entities": [
      {
        "text": "建武二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000072",
    "sentence": "三年，征拜諫議太夫，數有忠言，以禮進止，朝廷敬之。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000073",
    "sentence": "遷沛郡太守。",
    "entities": [
      {
        "text": "遷沛郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000074",
    "sentence": "至蘄縣，稱病不之府，官屬皆隨就之，良遂上疾篤，乞骸骨，征拜太中大夫。",
    "entities": [
      {
        "text": "至蘄縣",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000075",
    "sentence": "六年，代宣秉為大司徒司直。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000076",
    "sentence": "在位恭儉，妻子不入官舍，布被瓦器。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000077",
    "sentence": "時，司徒史鮑恢以事到東海，過候其家，而良妻布裙曳柴，從田中歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000078",
    "sentence": "恢告曰：『我司徒史也，故來受書，欲見夫人。』妻曰：『妾是也。若掾，無書。』恢乃下拜，嘆息而還，聞者莫不嘉之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000079",
    "sentence": "後以病歸，一歲復征，至滎陽，疾篤不任進道，乃過其友人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000080",
    "sentence": "友人不肯見，曰：『不有忠言奇謀而取大位，何其往來屑屑不憚煩也？』遂拒之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000081",
    "sentence": "良慚，自後連征，輒稱病。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000082",
    "sentence": "詔以玄纁聘之，遂不應。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000083",
    "sentence": "後光武幸蘭陵，遣使者問良所苦疾，不能言對。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000084",
    "sentence": "詔復其子孫邑中徭役，卒於家。",
    "entities": [
      {
        "text": "詔復其子孫邑",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000085",
    "sentence": "論曰：夫利仁者或借仁以從利，體義者不期體以合義。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000086",
    "sentence": "季文子妾不衣帛，魯人以為美談。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000087",
    "sentence": "公孫弘身服布被，汲黯譏其多詐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000088",
    "sentence": "事實未殊而譽毀別議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000089",
    "sentence": "何也？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000090",
    "sentence": "將體之與利之異乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000091",
    "sentence": "宣秉、王良處位優重，而秉甘疏薄，良妻荷薪，可謂行過乎儉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000092",
    "sentence": "然當世咨其清，人君高其節，豈非臨之以誠哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000093",
    "sentence": "語曰：『同言而信，則信在言前；同令而行，則誠在令外。』不其然乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000094",
    "sentence": "張湛不屑矜偽之誚，斯不偽矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000095",
    "sentence": "王丹難於交執之道，斯知交矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000096",
    "sentence": "杜林",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000097",
    "sentence": "杜林字伯山，扶風茂陵人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000098",
    "sentence": "父鄴，成、哀間為涼州刺史。",
    "entities": [
      {
        "text": "哀間為涼州",
        "label": "LOC",
        "start": 5,
        "end": 10
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000099",
    "sentence": "林少好學沈深，家既多書，又外氏張竦父子喜文采，林從竦受學，博洽多聞，時稱通儒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000100",
    "sentence": "初為郡吏。",
    "entities": [
      {
        "text": "初為郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000101",
    "sentence": "王莽敗，盜賊起，林與弟成及同郡範逡、孟冀等，將細弱俱客河西。",
    "entities": [
      {
        "text": "林與弟成及同郡",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000102",
    "sentence": "道逢賊數千人，遂掠取財裝，褫奪衣服，拔刃向林等將欲殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000103",
    "sentence": "冀仰曰：『願一言而死。將軍知天神乎？赤眉兵眾百萬，所向無前，而殘賊不道，卒至破敗。今將軍以數千之眾，欲規霸王之事，不行仁恩而反遵覆車，不畏天乎？』賊遂釋之，俱免於難。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 42,
        "end": 44
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000104",
    "sentence": "隗囂素聞林誌節，深相敬待，以為持書平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000105",
    "sentence": "後因疾告去，辭還祿食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000106",
    "sentence": "囂復欲令強起，遂稱篤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000107",
    "sentence": "囂意雖相望，且欲優容之，乃出令曰：『杜伯山天子所不能臣，諸侯所不能友，蓋伯夷、叔齊恥食周粟。今且從師友之位，須道開通，使順所誌。』林雖拘於囂，而終不屈節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000108",
    "sentence": "建武六年 ，弟成物故，囂乃聽林持喪東歸。",
    "entities": [
      {
        "text": "建武六年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000109",
    "sentence": "既遣而悔，追令刺客楊賢於隴坻遮殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000110",
    "sentence": "賢見林身推鹿車，載致弟喪，乃嘆曰：『當今之世，誰能行義？我雖小人，何忍殺義士！』因亡去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000111",
    "sentence": "光武聞林已還三輔，乃征拜侍禦史，引見，問以經書故舊及西州事，甚悅之，賜車馬衣被。",
    "entities": [
      {
        "text": "經書故舊及西州",
        "label": "LOC",
        "start": 21,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000112",
    "sentence": "群寮知林以名德用，甚尊憚之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000113",
    "sentence": "京師士大夫，鹹推其博洽。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000114",
    "sentence": "河南鄭興、東海衛宏等，皆長於古學。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000115",
    "sentence": "興嘗師事劉歆，林既遇之，欣然言曰：『林得興等固諧矣，使宏得林，且有以益之。』及宏見林，闇然而服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000116",
    "sentence": "濟南徐巡，始師事宏，後皆更受林學。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000117",
    "sentence": "林前於西州得漆書《古文尚書》一卷，常寶愛之，雖遭難困，握持不離身。",
    "entities": [
      {
        "text": "林前於西州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000118",
    "sentence": "出以示宏等曰：『林流離兵亂，常恐斯經將絕。何意東海衛子、濟南徐生復能傳之，是道竟不墜於地也。古文雖不合時務，然願諸生無悔所學。』宏、巡益重之，於是古文遂行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000119",
    "sentence": "明年，大議郊祀制，多以為周郊後稷，漢當祀堯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000120",
    "sentence": "詔復下公卿議，議者僉同，帝亦然之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000121",
    "sentence": "林獨以為周室之興，祚由後稷，漢業特起，功不緣堯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000122",
    "sentence": "祖宗故事，所宜因循。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000123",
    "sentence": "定從林議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000124",
    "sentence": "後代王良為大司徒司直。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000125",
    "sentence": "林薦同郡範逡、趙秉、申屠剛及隴西牛邯等，皆被擢用，士多歸之。",
    "entities": [
      {
        "text": "林薦同郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000126",
    "sentence": "十一年，司直官罷，以林代郭憲為光祿勛。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000127",
    "sentence": "內奉宿衛，外總三署，周密敬慎，選舉稱平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000128",
    "sentence": "郎有好學者，輒見誘進，朝夕滿堂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000129",
    "sentence": "十四年，群臣上言：『古者肉刑嚴重，則人畏法令；今憲律輕薄，故奸軌不勝。宜增科禁，以防其源。』詔下公卿。",
    "entities": [
      {
        "text": "十四年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000130",
    "sentence": "林奏曰：『夫人情挫辱，則義節之風損，法防繁多，則敬免之行興。孔子曰：「導之以政，齊之以刑，民免而無恥。導之以德，齊之以禮，有恥且格。」古之明王，深識遠慮，動居其厚，不務多辟，周之五刑，不過三千。大漢初興，詳鑒失得，故破矩為圓，斫雕為樸，蠲除苛政，更立疏網，海內歡欣，人懷寬德。及至其後，漸以滋章，吹毛索疵，詆欺無限。果桃菜茹之饋，集以成臧，小事無妨於義，以為大戮，故國無廉士，家無完行。至於法不能禁，令不能止，上下相遁。為敝彌深。臣愚以為宜如舊制，不合翻移。』帝從之。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 98,
        "end": 99
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000131",
    "sentence": "後皇太子彊求乞自退，封東海王，故重選官屬，以林為王傅。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000132",
    "sentence": "從駕南巡狩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000133",
    "sentence": "時諸王傅數被引命，或多交遊，不得應詔；唯林守慎，有召必至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000134",
    "sentence": "餘人雖不見譴，而林特受賞賜，又辭不敢受，帝益重之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000135",
    "sentence": "明年，代丁恭為少府。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000136",
    "sentence": "二十二年，復為光祿勛。",
    "entities": [
      {
        "text": "二十二年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000137",
    "sentence": "頃之，代朱浮為大司空。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000138",
    "sentence": "博雅多通，稱為任職相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000139",
    "sentence": "明年薨，帝親自臨喪送葬，除子喬為郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000140",
    "sentence": "詔曰：『公侯子孫，必復其始，賢者之後，宜宰城邑。其以喬為丹水長。』",
    "entities": [
      {
        "text": "宜宰城邑",
        "label": "LOC",
        "start": 19,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000141",
    "sentence": "論曰：夫威強以自禦，力損則身危；飾詐以圖己，詐窮則道屈；而忠信篤敬，蠻貊行焉者，誠以德之感物厚矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000142",
    "sentence": "故趙孟懷忠，匹夫成其仁；杜林行義，烈士假其命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000143",
    "sentence": "《易》曰：『人之所助者信』，有不誣矣。",
    "entities": [
      {
        "text": "《易》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000144",
    "sentence": "郭丹",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000145",
    "sentence": "郭丹字少卿，南陽穰人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000146",
    "sentence": "父稚，成帝時為廬江太守，有清名。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_027_000147",
    "sentence": "丹七歲而孤，小心孝順，後母哀憐之，為鬻衣裝，買產業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_027_000148",
    "sentence": "後從師長安，買符入函谷關，乃慨然嘆曰：『丹不乘使者車，終不出關。』既至京師，常為都講，諸儒鹹敬重之。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "買符入函谷關",
        "label": "LOC",
