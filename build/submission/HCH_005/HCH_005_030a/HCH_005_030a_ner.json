      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000075",
    "sentence": "年九十卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000076",
    "sentence": "統生厚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000077",
    "sentence": "厚母初與前妻子博不相安，厚年九歲，思令和親，乃託疾不言不食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000078",
    "sentence": "母知其旨，懼然改意，恩養加篤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000079",
    "sentence": "博後至光祿大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000080",
    "sentence": "厚少學統業，精力思述。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000081",
    "sentence": "初，安帝 永初三年 ，太白入斗，洛陽大水。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 7,
        "end": 9
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000082",
    "sentence": "時統為侍中，厚隨在京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000083",
    "sentence": "朝廷以問統，統對『年老耳目不明，子厚曉讀圖書，粗識其意』。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000084",
    "sentence": "鄧太后使中常侍承制問之，厚對以為『諸王子多在京師，容有非常，宜亟發遣各還本國。』太后從之，星尋滅不見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000085",
    "sentence": "又克水退期日，皆如所言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000086",
    "sentence": "除為中郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000087",
    "sentence": "太后特引見，問以圖讖，厚對不合，免歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000088",
    "sentence": "復習業犍為，不應州郡、三公之命，方正、有道、公正特徵，皆不就。",
    "entities": [
      {
        "text": "不應州郡",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000089",
    "sentence": "永建二年 ，順帝特徵，詔告郡縣督促發遣。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "詔告郡縣",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000090",
    "sentence": "厚不得已，行到長安，以病自上，因陳漢三百五十年之厄，宜蠲漢改憲之道，及消伏災異，凡五事。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 7,
        "end": 9
      },
      {
        "text": "三百五十年",
        "label": "TME",
        "start": 18,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000091",
    "sentence": "制書褒述，有詔太醫致藥，太宮賜羊酒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000092",
    "sentence": "及至，拜議郎，三遷為侍中，特蒙引見，訪以時政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000093",
    "sentence": "四年，厚上言『今夏必盛寒，當有疾疫蝗蟲之害』。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000094",
    "sentence": "是歲，果六州大蝗，疫氣流行。",
    "entities": [
      {
        "text": "果六州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000095",
    "sentence": "後又連上『西北二方有兵氣，宜備邊寇』。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000096",
    "sentence": "車駕臨當西巡，感厚言而止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000097",
    "sentence": "至 陽嘉三年 ，西羌寇隴右，明年，烏桓圍度遼將軍耿曄。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 4,
        "end": 6
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000098",
    "sentence": "永和元年 ，復上『京師應有水患，又當火災，三公有免者，蠻夷當反畔』。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000099",
    "sentence": "是夏，洛陽暴水，殺千餘人；至冬，承福殿災，太尉龐參免；荊、交二州蠻夷賊殺長吏，寇城郭。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "交二州",
        "label": "LOC",
        "start": 29,
        "end": 32
      },
      {
        "text": "寇城",
        "label": "LOC",
        "start": 39,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000100",
    "sentence": "又言『陰臣、近戚、妃黨當受禍。』明年，宋阿母與宦者褒信侯李元等遘奸廢退；後二年，中常侍張逵等復坐誣罔大將軍梁商專恣，悉伏誅。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 37,
        "end": 39
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 50,
        "end": 53
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000101",
    "sentence": "每有災異，厚輒上消救之法，而閹宦專政，言不得信。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000102",
    "sentence": "時大將軍梁冀威權傾朝，遣弟侍中不疑以車馬、珍玩致遺於厚，欲與相見。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 1,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000103",
    "sentence": "厚不答，固稱病救退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000104",
    "sentence": "帝許之，賜車馬錢帛歸家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000105",
    "sentence": "修黃、老，教授門生，上名錄者三千餘人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000106",
    "sentence": "太尉李固數薦言之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000107",
    "sentence": "本初元年 ，梁太后詔備古禮以聘厚，遂辭疾不就。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000108",
    "sentence": "建和三年 ，太后復詔徵之，經四年不至。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "四年",
        "label": "TME",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000109",
    "sentence": "年八十二，卒於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000110",
    "sentence": "策書弔祭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000111",
    "sentence": "鄉人謚曰文父。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000112",
    "sentence": "門人為立廟，郡文學掾史春秋饗射常祠之。",
    "entities": []
  }
