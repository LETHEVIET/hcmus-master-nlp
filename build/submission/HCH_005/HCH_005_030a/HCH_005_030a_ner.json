[
  {
    "sentence_id": "HCH_005_030a_000001",
    "sentence": "蘇竟",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000002",
    "sentence": "蘇竟字伯況，扶風平陵人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000003",
    "sentence": "平帝世，竟以明《 易 》為博士講《書》祭酒。",
    "entities": [
      {
        "text": "《 易 》",
        "label": "TITLE",
        "start": 7,
        "end": 12
      },
      {
        "text": "博士",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "《書》",
        "label": "TITLE",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000004",
    "sentence": "善圖緯，能通百家之言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000005",
    "sentence": "王莽時，與劉歆等共典校書，拜代郡中尉。",
    "entities": [
      {
        "text": "拜代郡",
        "label": "LOC",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000006",
    "sentence": "時匈奴擾亂，北邊多罹其禍，竟終完輯一郡。",
    "entities": [
      {
        "text": "竟終完輯一郡",
        "label": "LOC",
        "start": 13,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000007",
    "sentence": "光武即位，就拜代郡太守，使固塞以拒匈奴。",
    "entities": [
      {
        "text": "就拜代郡",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000008",
    "sentence": "建武五年 冬，盧芳略得北邊諸郡，帝使偏將軍隨弟屯代郡。",
    "entities": [
      {
        "text": "建武五年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "芳略得北邊諸郡",
        "label": "LOC",
        "start": 8,
        "end": 15
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000009",
    "sentence": "竟病篤，以兵屬弟，詣京師謝罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000010",
    "sentence": "拜侍中，數月，以病免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000011",
    "sentence": "初，延岑護軍鄧仲況擁兵據南陽陰縣為寇，而劉歆兄子龔為其謀主。",
    "entities": [
      {
        "text": "擁兵據南陽陰縣",
        "label": "LOC",
        "start": 9,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000012",
    "sentence": "竟時在南陽，與龔書曉之曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000013",
    "sentence": "君執事無恙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000014",
    "sentence": "走昔以摩研編削之才，與國師公從事出入，校定秘書，竊自依依，末由自遠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000015",
    "sentence": "蓋聞君子湣同類而傷不遇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000016",
    "sentence": "人無愚智，莫不先避害然後求利，先定志然後求名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000017",
    "sentence": "昔智果見智伯窮兵必亡，故變名遠逝，陳平知項王為天所棄，故歸心高祖，皆智之至也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000018",
    "sentence": "聞郡前權時屈節，北面延牙，乃後覺悟，棲遲養德。",
    "entities": [
      {
        "text": "聞郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000019",
    "sentence": "先世數子，又何以加。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000020",
    "sentence": "君處陰中，土多賢士，若以須臾之間，研考異同，揆之圖書，測之人事，則得失利害，可陳於目，何自負畔亂之困，不移守惡之名乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000021",
    "sentence": "與君子之道，何其反也？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000022",
    "sentence": "世之俗儒末學，醒醉不分，而稽論當世，疑誤視聽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000023",
    "sentence": "或謂天下叠興，未知誰是，稱兵據土，可圖非冀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000024",
    "sentence": "或曰聖王未啟，宜觀時變，倚強附大，顧望自守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000025",
    "sentence": "二者之論，豈其然乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000026",
    "sentence": "夫孔丘秘經，為漢赤制，玄包幽室，文隱事明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000027",
    "sentence": "且火德承堯，雖昧必亮，承積世之祚，握無窮之符，王氏雖乘間偷篡，而終嬰大戮，支分體解，宗氏屠滅，非其效歟？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000028",
    "sentence": "皇天所以眷顧蜘躕，憂漢子孫者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000029",
    "sentence": "論者若不本之於天，參之於聖，猥以《師曠雜事》輕自眩惑，說士作書，亂夫大道，焉可信哉？",
    "entities": [
      {
        "text": "《師曠雜事》",
        "label": "TITLE",
        "start": 16,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000030",
    "sentence": "諸儒或曰：今五星失晷，天時謬錯，辰星久而不效，太白出入過度，熒惑進退見態，鎮星繞帶天街，歲星不舍氐、房。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000031",
    "sentence": "以為諸如此占，歸之國家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000032",
    "sentence": "蓋災不徒設，皆應之分野，各有所主。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000033",
    "sentence": "夫房、心即宋之分，東海是也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000034",
    "sentence": "尾為燕分，漁陽是也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000035",
    "sentence": "東海董憲迷惑未降，漁陽彭寵逆亂擁兵，王赫斯怒，命將並征，故熒惑應此，憲、寵受殃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000036",
    "sentence": "太白、辰星自亡新之末，失行算度，以至於今，或守東井，或沒羽林，或裴回藩屏，或躑躅帝宮，或經天反明，或潛臧久沈，或衰微暗昧，或煌煌北南，或盈縮成鉤，或偃蹇不禁，皆大運蕩除之祥，聖帝應符之兆也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000037",
    "sentence": "賊臣亂子，往往錯互，指麾妄說，傳相壞誤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000038",
    "sentence": "由此論之，天文安得遵度哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000039",
    "sentence": "乃者，五月甲申，天有白虹，自子加午，廣可十丈，長可萬丈，正臨倚彌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000040",
    "sentence": "倚彌即黎丘，秦豐之都也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000041",
    "sentence": "是時月入於畢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000042",
    "sentence": "畢為天網，主網羅無道之君，故武王將伐紂，上祭於畢，求助天也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000043",
    "sentence": "夫仲夏甲申為八魁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000044",
    "sentence": "八魁，上帝開塞之將也，主退惡攘逆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000045",
    "sentence": "流星狀似蚩尤旗，或曰營頭，或曰天槍，出奎而西北行，至延牙營上，散為數百而滅，奎為毒螫，主庫兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000046",
    "sentence": "此二變，郡中及延牙士眾所共見也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000047",
    "sentence": "是故延牙遂之武當，託言發兵，實避其殃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000048",
    "sentence": "今年《比卦》部歲，《坤》主立冬，《坎》主冬至，水性滅火，南方之兵受歲禍也。",
    "entities": [
      {
        "text": "《比卦》",
        "label": "TITLE",
        "start": 2,
        "end": 6
      },
      {
        "text": "《坤》",
        "label": "TITLE",
        "start": 9,
        "end": 12
      },
      {
        "text": "《坎》",
        "label": "TITLE",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000049",
    "sentence": "德在中宮，刑在木，木勝土，刑制德，今年兵事畢已，中國安寧之效也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000050",
    "sentence": "五七之家三十五姓，彭、秦、延氏不得豫焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000051",
    "sentence": "如何怪惑，依而恃之？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000052",
    "sentence": "《葛累》之詩，『求福不回』，其若是乎！",
    "entities": [
      {
        "text": "《葛累》",
        "label": "TITLE",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000053",
    "sentence": "圖讖之占，眾變之驗，皆君所明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000054",
    "sentence": "善惡之分，去就之決，不可不察。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000055",
    "sentence": "無忽鄙言！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000056",
    "sentence": "夫周公之善康叔，以不從管、蔡之亂也；景帝之悅濟北，以不從吳濞之畔也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000057",
    "sentence": "自更始以來，孤恩背逆，歸義向善，臧否粲然，可不察歟！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000058",
    "sentence": "良醫不能救無命，強梁不能與天爭，故天之所壞，人不得支。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000059",
    "sentence": "宜密與太守劉君共謀降議。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000060",
    "sentence": "仲尼棲棲，墨子遑遑，憂人之甚也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000061",
    "sentence": "屠羊救楚，非要爵祿；茅焦干秦，豈求報利？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000062",
    "sentence": "盡忠博愛之誠，憤懣不能已耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000063",
    "sentence": "又與仲況書諫之，文多不載，於是仲況與龔遂降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000064",
    "sentence": "龔字孟公，長安人，善論議，扶風馬援、班彪並器重之。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000065",
    "sentence": "竟終不伐其功，潛樂道術，作《記誨篇》及文章傳於世。",
    "entities": [
      {
        "text": "《記誨篇》",
        "label": "TITLE",
        "start": 13,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000066",
    "sentence": "年七十，卒於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000067",
    "sentence": "楊厚",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000068",
    "sentence": "楊厚字仲桓，廣漢新都人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000069",
    "sentence": "祖父春卿，善圖讖學，為公孫述將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000070",
    "sentence": "漢兵平蜀，春卿自殺，臨命戒子統曰：『吾綈帙中有先祖所傳秘記，為漢家用，爾其修之。』統感父遺言，服闋，辭家從犍為周循學習先法，又就同郡鄭伯山受《河洛書》及天文推步之術。",
    "entities": [
      {
        "text": "又就同郡",
        "label": "LOC",
        "start": 62,
        "end": 66
      },
      {
        "text": "《河洛書》",
        "label": "TITLE",
        "start": 70,
        "end": 75
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000071",
    "sentence": "建初中為彭城令，一州大旱，統推陰陽消伏，縣界蒙澤。",
    "entities": [
      {
        "text": "建初中為彭城",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "一州",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000072",
    "sentence": "太守宗湛使統求為郡求雨，亦即降澍。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "宗湛使統求為郡",
        "label": "LOC",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030a_000073",
    "sentence": "自是朝廷災異，多以訪之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030a_000074",
    "sentence": "統作《家法章句》及《內讖》二卷角說，位至光祿大夫，為國三老。",
    "entities": [
      {
        "text": "《家法章句》",
        "label": "TITLE",
        "start": 2,
        "end": 8
      },
      {
        "text": "《內讖》",
        "label": "TITLE",
