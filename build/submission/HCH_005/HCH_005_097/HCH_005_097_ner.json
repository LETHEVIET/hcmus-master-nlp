[
  {
    "sentence_id": "HCH_005_097_000001",
    "sentence": "祭祀之道，自生民以來則有之矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000002",
    "sentence": "豺獺知祭祀，而況人乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000003",
    "sentence": "故人知之至於念想，猶豺獺之自然也，顧古質略而後文飾耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000004",
    "sentence": "自古以來王公所爲羣祀，至於王莽，《 漢書 ·郊祀志》既著矣，故今但列自中興以來所修用者，以爲《祭祀志》。",
    "entities": [
      {
        "text": "《 漢書 ·郊祀志》",
        "label": "TITLE",
        "start": 16,
        "end": 26
      },
      {
        "text": "《祭祀志》",
        "label": "TITLE",
        "start": 46,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_005_097_000005",
    "sentence": "〈 謝沈書曰「蔡邕引中興以來所修者為祭祀〔意」，此〕志即邕之意也。 〉",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000006",
    "sentence": "建武元年 ，光武即位于鄗，爲壇營於鄗之陽。",
    "entities": [
      {
        "text": "建武元年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_097_000007",
    "sentence": "祭告天地，采用元始中郊祭故事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000008",
    "sentence": "六宗羣神皆從，未以祖配。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000009",
    "sentence": "天地共犢，餘牲尚約。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000010",
    "sentence": "其文曰：「皇天上帝，后土神祇，睠顧降命，屬秀黎元，爲民父母，秀不敢當。羣下百僚，不謀同辭。咸曰王莽篡弑竊位，秀發憤興義兵，破王邑百萬眾於昆陽，誅王郎、銅馬、赤眉、青犢賊，平定天下，海内蒙恩，上當天心，下爲元元所歸。讖記曰：『劉秀發兵捕不道，卯金修德爲天子。』秀猶固辭，至於再，至於三。羣下曰：『皇天大命，不可稽留。』敢不敬承！」",
    "entities": [
      {
        "text": "破王邑",
        "label": "LOC",
        "start": 61,
        "end": 64
      }
    ]
  },
  {
    "sentence_id": "HCH_005_097_000011",
    "sentence": "二年正月，初制郊兆於于雒陽城南七里，依鄗。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "郊兆於于雒陽城",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_097_000012",
    "sentence": "采元始中故事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000013",
    "sentence": "爲圓壇八陛，中又爲重壇，天地位其上，皆南嚮乡，西上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000014",
    "sentence": "其外壇上爲五帝位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000015",
    "sentence": "青帝位在甲寅之地，赤帝位在丙巳之地，黄帝位在丁未之地，白帝位在庚申之地，黑帝位在壬亥之地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000016",
    "sentence": "其外壝，重營皆紫，以像紫宫；有四通道以爲門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000017",
    "sentence": "日月在中營内南道，日在東，月在西，北斗在北道之西，皆别位，不在羣神列中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000018",
    "sentence": "八陛，陛五十八醊，合四百六十四醊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000019",
    "sentence": "五帝陛郭，帝七十二醊，合三百六十五醊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000020",
    "sentence": "中營四門，門五十四神，合二百一十六神。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000021",
    "sentence": "外營四門，門百八神，合四百三十二神。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000022",
    "sentence": "皆背營内乡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000023",
    "sentence": "中營四門，門封神四，外營四門，門封神四，合三十二神。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000024",
    "sentence": "凡千五百一十四神。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000025",
    "sentence": "營即壝也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000026",
    "sentence": "封，封土筑也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000027",
    "sentence": "背中營神，五星也，及中官宿五官神及五岳之屬也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000028",
    "sentence": "背外營神，二十八宿外官星，雷公、先農、風伯、雨師、四海、四瀆、名山、大川之屬也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000029",
    "sentence": "至七年五月，詔三公曰：「漢當郊尧。其与卿大夫、博士议。」時侍御史杜林上疏，以爲「漢起不因缘尧，与殷、周異宜，而舊制以高帝配。方軍師在外，且可如元年郊祀故事」。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 1,
        "end": 3
      },
      {
        "text": "大夫",
