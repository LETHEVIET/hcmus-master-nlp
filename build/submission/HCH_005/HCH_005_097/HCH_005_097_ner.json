    ]
  },
  {
    "sentence_id": "HCH_005_097_000084",
    "sentence": "黎庶得居尔田，安尔宅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000085",
    "sentence": "書同文，车同轨，人同伦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000086",
    "sentence": "舟舆所通，人迹所至，靡不贡职。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_097_000087",
    "sentence": "建明堂，立辟雍，起靈臺，設庠序。",
