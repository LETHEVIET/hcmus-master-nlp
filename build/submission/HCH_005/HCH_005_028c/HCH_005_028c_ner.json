[
  {
    "sentence_id": "HCH_005_028c_000001",
    "sentence": "馮衍",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000002",
    "sentence": "建武末，上疏自陳曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000003",
    "sentence": "臣伏念高祖之略而陳平之謀，毀之則疏，譽之則親。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000004",
    "sentence": "以文帝以明而魏尚之忠，繩之以法則為罪，施之以德則為功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000005",
    "sentence": "逮至晚世，董仲舒言道德，見妒於公孫弘，李廣奮節於匈奴，見排於衛青，此忠臣之常所為流涕也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000006",
    "sentence": "臣衍自惟微賤之臣，上無無知之薦，下無馮唐之說，乏董生之才，寡李廣之勢，而欲免讒口，濟怨嫌，豈不難哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000007",
    "sentence": "臣衍之先祖，以忠貞之故，成私門之禍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000008",
    "sentence": "而臣衍復遭擾攘之時，值兵革之際，不敢回行求時之利，事君無傾邪之謀，將帥無虜掠之心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000009",
    "sentence": "衛尉陰興，敬慎周密，內自修敕，外遠嫌疑，故敢與交通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000010",
    "sentence": "興知臣之貧，數欲本業之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000011",
    "sentence": "臣自惟無三益之才，不敢處三損之地，固讓而不受之，昔在更始，太原執貨財之柄，居蒼卒之間，據位食祿二十餘年，而財產歲狹，居處日貧，家無布帛之積，出無輿馬之飾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000012",
    "sentence": "於今遭清明之時，飭躬力行之秋，而怨仇叢興，譏議橫世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000013",
    "sentence": "蓋富貴易為善，貧賤難為工也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000014",
    "sentence": "疏遠壟畝之臣，無望高闕之下，惶恐自陳，以救罪尤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000015",
    "sentence": "書奏，猶以前過不用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000016",
    "sentence": "衍不得志，退而作賊，又自論曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000017",
    "sentence": "馮子以為夫人之德，不碌碌如玉，落落如石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000018",
    "sentence": "風興雲蒸，一龍一蛇，與道翺翔，與時變化，夫豈守一節哉？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000019",
    "sentence": "用之則行，舍之則臧，進退無主，屈申無常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000020",
    "sentence": "故曰：『有法無法，因時為業，有度無度，與物趣舍。』常務道德之實，而不求當世之名，闊略杪小之禮，蕩佚人間之事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000021",
    "sentence": "正身直行，恬然肆誌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000022",
    "sentence": "顧嘗好俶儻之策，時莫能聽用其謀，喟然長嘆，自傷不遭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000023",
    "sentence": "久棲遲於小官，不得舒其所懷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000024",
    "sentence": "抑心折節，意淒情悲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000025",
    "sentence": "夫伐冰之家，不利雞豚之息；委積之臣，不操市井之利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000026",
    "sentence": "況歷位食祿二十餘年，而財產益狹，居處益貧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000027",
    "sentence": "惟夫君子之仕，行其道也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000028",
    "sentence": "慮時務者不能興其德，為身求者不能成其功，去而歸家，復羈旅於州郡，身愈據職，家彌窮困，卒離饑寒之災，有喪元子之禍。",
    "entities": [
      {
        "text": "復羈旅於州郡",
        "label": "LOC",
        "start": 25,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000029",
    "sentence": "先將軍葬渭陵，哀帝之崩也，營之以為園。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000030",
    "sentence": "於是以新豐之東，鴻門之上，壽安之中，地勢高敞，四通廣大，南望酈山，北屬涇渭，東瞰河華，龍門之陽，三晉之路，西顧酆鄗，周秦之丘，客觀之墟，通視千里，覽見舊都，遂定塋焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000031",
    "sentence": "退而幽居。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000032",
    "sentence": "蓋忠臣過故墟而歔欷，孝子入舊室而哀嘆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000033",
    "sentence": "每念祖考，著盛德於前，垂鴻烈於後，遭時之禍，墳墓蕪穢，春秋蒸嘗，昭穆無列，年衰歲暮，悼無成功，將西田牧肥饒之野，殖生產，修孝道，營宗廟，廣祭祀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000034",
    "sentence": "然後闔門講習道德，觀覽乎孔老之論，庶幾乎松、喬之福，上隴阪，陟高岡，遊精宇宙，流目八纮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000035",
    "sentence": "歷觀九州山川之體，追覽上古得失之風，湣道陵遲，傷德分崩。",
    "entities": [
      {
        "text": "歷觀九州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000036",
    "sentence": "夫睹其終必原其始，故存其人而詠其道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000037",
    "sentence": "疆理九野，經營五山，眇然有思陵雲之意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000038",
    "sentence": "乃作賦自厲，命其篇曰《顯志》。",
    "entities": [
      {
        "text": "《顯志》",
        "label": "TITLE",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000039",
    "sentence": "顯志者，言光明風化之情，昭章玄妙之思也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000040",
    "sentence": "其辭曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000041",
    "sentence": "開歲發春兮，百卉含英。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000042",
    "sentence": "甲子之朝兮，汨吾西征。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000043",
    "sentence": "發軔新豐兮，裴回鎬京。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000044",
    "sentence": "陵飛廉而太息兮，登平陽而懷傷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000045",
    "sentence": "悲時俗之險厄兮，哀好惡之無常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000046",
    "sentence": "棄衡石而意量兮，隨風波而飛揚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000047",
    "sentence": "紛綸流於權利兮，親雷同而妒異；獨耿介而慕古兮，豈時人之所憙？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000048",
    "sentence": "沮先聖之成論兮，𨘷名賢之高風；忽道德之珍麗兮，務富貴之樂耽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000049",
    "sentence": "遵大路而裴回兮，履孔德之窈冥；固眾夫之所眩兮，孰能觀於無形？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000050",
    "sentence": "行勁直以離尤兮，羌前人之所有；內自省而不慚兮，遂定誌而弗改。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000051",
    "sentence": "欣吾黨之唐、虞兮，湣吾生之愁勤；聊發憤而揚情兮，將以蕩夫憂心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000052",
    "sentence": "往者不可攀援兮，來者不可與期；病沒世之不稱兮，願橫逝而無由。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000053",
    "sentence": "陟雍畤而消搖兮，超略陽而不反。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000054",
    "sentence": "念人生之不再兮，悲六親之日遠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000055",
    "sentence": "陟九嵕而臨戔嶭兮，聽涇渭之波聲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000056",
    "sentence": "顧鴻門而歔欷兮，哀吾孤之早零，何天命之不純兮，信吾罪之所生；傷誠善之無辜兮，賫此恨而入冥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000057",
    "sentence": "嗟我思之不遠兮，豈則事之可悔？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000058",
    "sentence": "雖九死而不眠兮，恐余殃之有再。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000059",
    "sentence": "淚汍瀾而雨集兮，氣滂浡而雲披；心怫郁而紆結兮，意沈抑而內悲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000060",
    "sentence": "瞰太行之嵯峨兮，觀壺口之崢嶸；悼丘墓之蕪穢兮，恨昭穆之不榮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000061",
    "sentence": "歲忽忽而日邁兮，壽冉冉其不與；恥功業之無成兮，赴原野而窮處。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000062",
    "sentence": "昔伊尹之幹湯兮，七十說而乃信；臯陶釣於雷澤兮，賴虞舜而後親。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000063",
    "sentence": "無二士之遭遇兮，抱忠貞而莫達；率妻子而耕耘兮，委厥美而不伐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000064",
    "sentence": "韓盧抑而不縱兮，騏驥絆而不試；獨慷慨而遠覽兮，非庸庸之所識。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000065",
    "sentence": "卑衛賜之阜貨兮，高顏回之所慕；重祖考之洪烈兮，故收功於此路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000066",
    "sentence": "循四時之代謝兮，分五土之刑德；林相麓之所產兮，嘗水泉之所殖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000067",
    "sentence": "修神農之本業兮，采軒轅之奇策；追周棄之遺教兮，軼范蠡之絕跡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000068",
    "sentence": "陟隴山以逾望兮，眇然覽於八荒；風波飄其並興兮，情惆悵而增傷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000069",
    "sentence": "覽河華之泱漭兮，望秦晉之故國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000070",
    "sentence": "憤馮亭之不遂兮，慍去疾之遭惑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000071",
    "sentence": "流山嶽而周覽兮，徇碣石與洞庭；浮江河而入海兮，溯淮濟而上征。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000072",
    "sentence": "瞻燕齊之舊居兮，歷宋楚之名都；哀群後之不祀兮，痛列國之為墟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000073",
    "sentence": "馳中夏而升降兮，路紆軫而多艱；講聖哲之通論兮，心愊憶而紛紜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000074",
    "sentence": "惟天路之同軌兮，或帝王之異政；堯、舜煥其蕩蕩兮，禹承平而革命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000075",
    "sentence": "並日夜而幽思兮，終悇憛而洞疑；高陽𨘷其超遠兮，世孰可與論茲？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000076",
    "sentence": "訊夏啟於甘澤兮，傷帝典之始傾；頌成、康之載德兮，詠《南風》之歌聲。",
    "entities": [
      {
        "text": "《南風》",
        "label": "TITLE",
        "start": 25,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000077",
    "sentence": "思唐、虞之晏晏兮，揖稷、契與為朋；苗裔紛其條暢兮，至湯、武而勃興。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000078",
    "sentence": "昔三後之純粹兮，每季世而窮禍；吊夏桀於南巢兮，哭殷紂於牧野。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000079",
    "sentence": "詔伊尹於亳郊兮，享呂望於酆州；功與日月齊光兮，名與三王爭流。",
    "entities": [
      {
        "text": "享呂望於酆州",
        "label": "LOC",
        "start": 8,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000080",
    "sentence": "楊朱號乎衢路兮，墨子泣乎白絲；知漸染之易性兮，怨造作之弗思。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000081",
    "sentence": "美《關雎》之識微兮，湣王道之將崩；拔周唐之盛德兮，捃桓、文之譎功。",
    "entities": [
      {
        "text": "《關雎》",
        "label": "TITLE",
        "start": 1,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000082",
    "sentence": "忿戰國之遘禍兮，憎權臣之擅強；黜楚子於南郢兮，執趙武於湨梁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000083",
    "sentence": "善忠信之救時兮，惡詐謀之妄作；聘申叔於陳蔡兮，禽荀息於虞虢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000084",
    "sentence": "誅犁鋤之介聖兮，討臧倉之訴知；巽子反於彭城兮，爵管仲於夷儀。",
    "entities": [
      {
        "text": "巽子反於彭城",
        "label": "LOC",
        "start": 15,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000085",
    "sentence": "疾兵革之浸滋兮，苦攻伐之萌生；沈孫武於五湖兮，斬白起於長平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000086",
    "sentence": "惡叢巧之亂世兮，毒從橫之敗俗；流蘇秦於洹水兮，幽張儀於鬼谷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000087",
    "sentence": "澄德化之陵遲兮，烈刑罰之峭峻；燔商鞅之法術兮，燒韓非之說論。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000088",
    "sentence": "誚始皇之跋扈兮，投李斯於四裔；滅先王之法則兮，禍浸淫而弘大。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000089",
    "sentence": "援前聖以制中兮，矯二主之驕奢；馌女齊於絳臺兮，饗椒舉於章華。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000090",
    "sentence": "摛道德之光耀兮，匡衰世之眇風；褒宋襄於泓谷兮，表季劄於延陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000091",
    "sentence": "摭仁智之英華兮，激亂國之末流；觀鄭僑於溱洧兮，訪晏嬰於營丘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000092",
    "sentence": "日曀曀其將暮兮，獨於邑而煩惑；夫何九州之博大兮，迷不知路之南北；駟素虯而馳聘兮，乘翠雲而相佯；就伯夷而折中兮，得務光而愈明。",
    "entities": [
      {
        "text": "獨於邑",
        "label": "LOC",
        "start": 8,
        "end": 11
      },
      {
        "text": "夫何九州",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000093",
    "sentence": "款子高於中野兮，遇伯成而定慮；欽真人之德美兮，淹躊躇而弗去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000094",
    "sentence": "意斟愖而不淡兮，俟回風而容與；求善卷之所存兮，遇許由於負黍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000095",
    "sentence": "軔吾車於箕陽兮，秣吾馬於潁滸；聞至言而曉領兮，還吾反乎故宇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000096",
    "sentence": "覽天地之幽奧兮，統萬物之維綱；究陰陽之變化兮，昭五德之精光。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000097",
    "sentence": "躍青龍於滄海兮，豢白虎於金山；鑿巖石而為室兮，托高陽以養仙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000098",
    "sentence": "神雀翔於鴻崖兮，玄武潛於嬰冥；伏朱樓而四望兮，采三秀之華英。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000099",
    "sentence": "篡前修之誇節兮，曜往昔之光勛；披綺季之麗服兮，揚屈原之靈芬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000100",
    "sentence": "高吾寇之岌岌兮，長吾佩之洋洋；飲六醴之清液兮，食五芝之茂英。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000101",
    "sentence": "揵六枳而為籬兮，築蕙若而為室；播蘭芷於中廷兮，列杜衡於外術。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000102",
    "sentence": "攢射幹雜蘼蕪兮，構木蘭與新夷；光扈扈而煬燿兮，紛郁郁而暢美；華芳曄其發越兮，時恍忽而莫貴；非惜身之埳軻兮，憐眾美之憔悴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000103",
    "sentence": "遊精神於大宅兮，抗玄妙之常操；處清靜以養誌兮，實吾心之所樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000104",
    "sentence": "山峨峨而造天兮，林冥冥而暢茂；鸞回翔索其群兮，鹿哀鳴而求其友。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000105",
    "sentence": "誦古今以散思兮，覽聖賢以自鎮；嘉孔丘之知命兮，大老聃之貴玄；德與道其孰寶兮；名與身其孰親？",
    "entities": [
      {
        "text": "覽聖賢以自鎮",
        "label": "LOC",
        "start": 8,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000106",
    "sentence": "陂山谷而閑處兮，守寂寞而存神。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000107",
    "sentence": "夫莊周之釣魚兮，辭卿相之顯位；於陵子之灌園兮，似至人之仿佛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000108",
    "sentence": "蓋隱約而得道兮，羌窮悟而入術；離塵垢之窈冥兮，配喬、松之妙節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000109",
    "sentence": "惟吾誌之所庶兮，固與俗其不同；既俶儻而高引兮，願觀其從容。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000110",
    "sentence": "顯宗即位，又多短衍以文過其實，遂廢於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000111",
    "sentence": "衍娶北地住氏女為妻，悍忌，不得畜媵妾，兒女常自操井臼，老竟逐之，遂埳壈於時。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000112",
    "sentence": "然有大誌，不戚戚於賤貧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000113",
    "sentence": "居常慷慨嘆曰：『衍少事名賢，經歷顯位，懷金垂紫，揭節奉使，不求茍得，常有陵雲之誌。三公之貴，千金之富，不得其願，不概於懷。貧而不衰，賤而不恨，年雖疲曳，猶庶幾名賢之風。修道德於幽冥之路，以終身名，為後世法。』居貧年老，卒於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000114",
    "sentence": "所著賦、誄、銘、說、《問交》、《德誥》、《慎情》、書記說、自序、官錄說、策五十篇，肅宗甚重其文。",
    "entities": [
      {
        "text": "《問交》",
        "label": "TITLE",
        "start": 10,
        "end": 14
      },
      {
        "text": "《德誥》",
        "label": "TITLE",
        "start": 15,
        "end": 19
      },
      {
        "text": "《慎情》",
        "label": "TITLE",
        "start": 20,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000115",
    "sentence": "子豹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000116",
    "sentence": "馮豹",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000117",
    "sentence": "豹字仲文，年十二，母為父所出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000118",
    "sentence": "後母惡之，嘗因豹夜寐，欲行毒害，豹逃走得免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000119",
    "sentence": "敬事愈謹，而母疾之益深，時人稱其孝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000120",
    "sentence": "長好儒學，以《詩》、《春秋》教麗山下。",
    "entities": [
      {
        "text": "《詩》",
        "label": "TITLE",
        "start": 6,
        "end": 9
      },
      {
        "text": "《春秋》",
        "label": "TITLE",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000121",
    "sentence": "鄉里之語曰：『道德彬彬馮仲文。』舉孝廉，拜尚書郎，忠勤不懈。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000122",
    "sentence": "每奏事未報，常俯伏省閤，或從昏至明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000123",
    "sentence": "肅宗聞而嘉之，使黃門持被覆豹，敕令勿驚，由是數加賞賜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000124",
    "sentence": "是時，方平西域，以豹有才謀，拜為河西副校尉。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000125",
    "sentence": "和帝初，數言邊事，奏置戊己校尉，城郭諸國復率舊職。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000126",
    "sentence": "遷武威太守，視事二年，河西稱之，復征入為尚書。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "二年",
        "label": "TME",
        "start": 8,
        "end": 10
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000127",
    "sentence": "永元十四年，卒於官。",
    "entities": [
      {
        "text": "十四年",
        "label": "TME",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_028c_000128",
    "sentence": "史論",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000129",
    "sentence": "論曰：夫貴者負勢而驕人，才士負能而遺行，其大略然也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000130",
    "sentence": "二子不其然乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000131",
    "sentence": "馮衍之引挑妻之譬，得矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000132",
    "sentence": "夫納妻皆知取詈己者，而取士則不能。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000133",
    "sentence": "何也？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000134",
    "sentence": "豈非反妒情易，而恕義情難。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000135",
    "sentence": "光武雖得之於鮑永，猶失之於馮衍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000136",
    "sentence": "夫然，義直所以見屈於既往，守節故亦彌阻於來情。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000137",
    "sentence": "嗚呼！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000138",
    "sentence": "贊曰：譚非讖術，衍晚委質。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000139",
    "sentence": "道不相謀，詭時同失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_028c_000140",
    "sentence": "體兼上才，榮微下秩。",
    "entities": []
  }
]
