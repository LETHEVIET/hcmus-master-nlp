[
  {
    "sentence_id": "HCH_005_117_000001",
    "sentence": "執金吾",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000002",
    "sentence": "执金吾一人，中二千石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000003",
    "sentence": "〈 漢官秩云比二千石。 〉 本注曰：掌宫外戒司非常水火之事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000004",
    "sentence": "〈 胡廣曰：「衛尉巡行宮中，則金吾徼於外，相為表裏，以擒姦討猾。」 〉 月三绕行宫外，及主兵器。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000005",
    "sentence": "吾犹御也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000006",
    "sentence": "〈 應劭曰：「執金革以禦非常。」漢官曰：「員吏二十九人，其十人四科，一人二百石，文學三人百石，二人斗食，十三人佐學事，主緹騎。」 〉 丞一人，比千石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000007",
    "sentence": "〈 漢官秩云六百石。 〉 缇骑二百人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000008",
    "sentence": "本注曰：无秩，比吏食奉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000009",
    "sentence": "〈 漢官曰：「執金吾緹騎二百人，〔持戟〕五百二十人，輿服導從，光滿道路，群僚之中，斯最壯矣。世祖歎曰；『仕宦當作執金吾。』」 〉",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000010",
    "sentence": "武库令一人，六百石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000011",
    "sentence": "本注曰：主兵器。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000012",
    "sentence": "丞一人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000013",
    "sentence": "右属执金吾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000014",
    "sentence": "本注曰：本有式道、左右中候三人，六百石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000015",
    "sentence": "车驾出，掌在前清道，还持麾至宫门，宫门乃开。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000016",
    "sentence": "中兴但一人，又不常置，每出，以郎兼式道候，事已罢，不复属执金吾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_117_000017",
    "sentence": "又省中垒、寺互、都船令、丞、尉及左右京辅都尉。",
    "entities": []
  },
