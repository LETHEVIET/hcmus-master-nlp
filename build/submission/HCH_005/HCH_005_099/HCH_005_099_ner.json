        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_099_000017",
    "sentence": "太祖东面，惠、文、武、元帝为昭，景、宣帝为穆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000018",
    "sentence": "惠、景、昭三帝非殷祭时不祭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000019",
    "sentence": "光武皇帝崩，明帝即位，以光武帝拨乱中兴，更为起庙，尊号曰世祖庙。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_099_000020",
    "sentence": "以元帝于光武为穆，故虽非宗，不毁也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000021",
    "sentence": "后遂为常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000022",
    "sentence": "明帝临终遗诏，遵俭无起寝庙，藏主于世祖庙更衣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000023",
    "sentence": "孝章即位，不敢违，以更衣有小别，上尊号曰显宗庙，间祠于更衣，四时合祭于世祖庙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000024",
    "sentence": "语在《章纪》。",
    "entities": [
      {
        "text": "《章纪》",
        "label": "TITLE",
        "start": 2,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_099_000025",
    "sentence": "章帝临崩，遗诏无起寝庙，庙如先帝故事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000026",
    "sentence": "和帝即位不敢违，上尊号曰肃宗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000027",
    "sentence": "后帝承尊，皆藏主于世祖庙，积多无别，是后显宗但为陵寝之号。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000028",
    "sentence": "永元中，和帝追尊其母梁贵人曰恭怀皇后，陵曰西陵。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_099_000029",
    "sentence": "以窦后配食章帝，恭怀后别就陵寝祭之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000030",
    "sentence": "和帝崩，上尊号曰穆宗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000031",
    "sentence": "殇帝生三百余日而崩，邓太后摄政，以尚婴孩，故不列于庙，就陵寝祭之而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000032",
    "sentence": "安帝以清河孝王子即位，建光元年，追尊其祖母宋贵人曰敬隐后，陵曰敬北陵。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_099_000033",
    "sentence": "亦就陵寝祭，太常领如西陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000034",
    "sentence": "追尊父清河孝王曰孝德皇，母曰孝德后，清河嗣王奉祭而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000035",
    "sentence": "安帝以谗害大臣，废太子，及崩，无上宗之奏。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_099_000036",
    "sentence": "后以自建武以来无毁者，故遂常祭，因以其陵号称恭宗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000037",
    "sentence": "顺帝即位，追尊其母曰恭愍后，陵曰恭北陵，就陵寝祭，如敬北陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000038",
    "sentence": "顺帝崩，上尊号曰敬宗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000039",
    "sentence": "冲质帝皆小崩，梁太后摄政，以殇帝故事，就陵寝祭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000040",
    "sentence": "凡祠庙讫，三公分祭之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000041",
    "sentence": "桓帝以河间孝王孙蠡吾侯即位，亦追尊祖考，王国奉祀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000042",
    "sentence": "语在《章和八王传》。",
    "entities": [
      {
        "text": "《章和八王传》",
        "label": "TITLE",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_099_000043",
    "sentence": "桓帝崩，上尊号曰威宗，无嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000044",
    "sentence": "灵帝以河间孝王曾孙解犊侯即位，亦追尊祖考。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000045",
    "sentence": "语在《章和八王传》。",
    "entities": [
      {
        "text": "《章和八王传》",
        "label": "TITLE",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_099_000046",
    "sentence": "灵帝时，京都四时所祭高庙五主，世祖庙七主，少帝三陵，追尊后三陵，凡牲用十八太牢，皆有副倅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000047",
    "sentence": "故高庙三主亲毁之后，亦但殷祭之岁奉祠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000048",
    "sentence": "灵帝崩，献帝即位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000049",
    "sentence": "初平中，相国董卓、左中郎将蔡邕等以和帝以下，功德无殊，而有过差，不应为宗，及余非宗者追尊三后，皆奏毁之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000050",
    "sentence": "四时所祭，高庙一祖二宗，及近帝四，凡七帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000051",
    "sentence": "古不墓祭，汉诸陵皆有园寝，承秦所为也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000052",
    "sentence": "说者以为古宗庙前制庙，后制寝，以象人之居前有朝，后有寝也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000053",
    "sentence": "《月令》有「先荐寝庙」，《诗》称「寝庙弈弈」，言相通也。",
    "entities": [
      {
        "text": "《月令》",
        "label": "TITLE",
        "start": 0,
        "end": 4
      },
      {
        "text": "《诗》",
        "label": "TITLE",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_099_000054",
    "sentence": "庙以藏主，以四时祭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000055",
    "sentence": "寝有衣冠几杖象生之具，以荐新物。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000056",
    "sentence": "秦始出寝，起于墓侧，汉因而弗改，故陵上称寝殿，起居衣服象生人之具，古寝之意也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000057",
    "sentence": "建武以来，关西诸陵以转久远，但四时特牲祠；帝每幸长安谒诸陵，乃太牢祠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000058",
    "sentence": "自雒阳诸陵至灵帝，皆以晦望二十四气伏腊及四时祠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000059",
    "sentence": "庙日上饭，太官送用物，园令、食监典省，其亲陵所宫人随鼓漏理被枕，具盥水，陈严具。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000060",
    "sentence": "建武二年 ，立太社稷于雒阳，在宗庙之右，方坛，无屋，有墙门而已。",
    "entities": [
      {
        "text": "建武二年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_099_000061",
    "sentence": "二月、八月及腊，一岁三祠，皆太牢具，使有司祠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000062",
    "sentence": "《 孝经 援神契》曰：「社者，土地之主也。稷者，五谷之长也。」《礼记》及《 国语 》皆谓共工氏之子曰句龙，为后土官，能平九土，故祀以为社。",
    "entities": [
      {
        "text": "《 孝经 援神契》",
        "label": "TITLE",
        "start": 0,
        "end": 9
      },
      {
        "text": "《礼记》",
        "label": "TITLE",
        "start": 31,
        "end": 35
      },
      {
        "text": "《 国语 》",
        "label": "TITLE",
        "start": 36,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_005_099_000063",
    "sentence": "烈山氏之子曰柱，能植百谷疏，自夏以上祀以为稷，至殷以柱久远，而尧时弃为后稷，亦植百谷，故废柱，祀弃为稷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000064",
    "sentence": "大司农郑玄说，古者官有大功，则配食其神。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000065",
    "sentence": "故句龙配食于社，弃配食于稷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000066",
    "sentence": "郡县置社稷，太守、令、长侍祠，牲用羊F5B9。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_099_000067",
    "sentence": "唯州所治有社无稷，以其使官。",
    "entities": [
      {
        "text": "唯州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_099_000068",
    "sentence": "古者师行平有载社主，不载稷也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000069",
    "sentence": "国家亦有五祀之祭，有司掌之，其礼简于社稷云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000070",
    "sentence": "汉兴八年，有言周兴而邑立后稷之祀，于是高帝令天下立灵星祠。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "有言周兴而邑",
        "label": "LOC",
        "start": 5,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_099_000071",
    "sentence": "言祠后稷而谓之灵星者，以后稷又配食星也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000072",
    "sentence": "旧说，星谓天田星也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000073",
    "sentence": "一曰，龙左角为天田官，主谷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_099_000074",
    "sentence": "祀用壬辰位祠之。",
    "entities": []
  },
  {
