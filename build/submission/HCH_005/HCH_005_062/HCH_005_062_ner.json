    "entities": []
  },
  {
    "sentence_id": "HCH_005_062_000042",
    "sentence": "視事三日，進拜司空。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_062_000043",
    "sentence": "爽自被徵命及登臺司，九十五日。",
    "entities": []
  },
