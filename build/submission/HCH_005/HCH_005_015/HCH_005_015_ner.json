[
  {
    "sentence_id": "HCH_005_015_000001",
    "sentence": "李通",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000002",
    "sentence": "李通，字次元，南陽宛人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000003",
    "sentence": "世以貸殖著姓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000004",
    "sentence": "父守，身長九尺，容貌絕異，為人嚴毅，居家如官廷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000005",
    "sentence": "初事劉歆，好星曆讖記，為王莽宗卿師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000006",
    "sentence": "通亦為五威將軍從事，出補巫丞，有能名。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000007",
    "sentence": "莽未，百姓愁怨，通素聞守說讖云『劉氏復興，李氏為輔』，私常懷之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000008",
    "sentence": "且居家富逸，為閭里雄，以此不樂為吏，乃自免歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000009",
    "sentence": "及下江、新市兵起，南陽騷動，通從弟軼，亦素好事，乃共計議曰：『今四方擾亂，新室且亡，漢當更興。南陽宗室，獨劉伯升兄弟泛愛容眾，可與謀大事。』通笑曰：『吾意也。』會光武避吏在宛，通聞之，即遣軼往迎光武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000010",
    "sentence": "光武初以通士君子相慕也，故往答之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000011",
    "sentence": "及相見，共語移日，握手極歡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000012",
    "sentence": "通因具言讖文事，光武初殊不意，未敢當之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000013",
    "sentence": "時守在長安，光武乃微觀通曰：『即如此，當如宗卿師何？』通曰：『已自有度矣。』因復備言其計。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000014",
    "sentence": "光武既深知通意，乃遂相約結，定謀議，期以材官都試騎士日，欲劫前隊大夫及屬正，因以號令大眾。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000015",
    "sentence": "乃使光武與軼歸舂陵，舉兵以相應。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000016",
    "sentence": "遣從兄子季之長安，以事報守。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000017",
    "sentence": "季於道病死，守密知之，欲亡歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000018",
    "sentence": "素與邑人黃顯相善，時顯為中郎將，聞之，謂守曰：『今關門禁嚴，君狀貌非心，將以此安之？不如詣闕自歸。事既未然，脫可免禍。』守從其計，即上書歸死，章未及報，留闕下。",
    "entities": [
      {
        "text": "素與邑",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 12,
        "end": 15
      },
      {
        "text": "今關",
        "label": "LOC",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000019",
    "sentence": "會事發覺，通得亡走，莽聞之，乃系守於獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000020",
    "sentence": "而黃顯為請曰：『守聞子無狀，不敢逃亡，守義自信，歸命宮闕。臣顯願質守俱東，曉說其子。如遂悖逆，令守北向刎首，以謝大恩。』莽然其言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000021",
    "sentence": "會前隊復上通起兵之狀，莽怒，欲殺守，顯爭之，遂並被誅，及守家在長安者盡殺之。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000022",
    "sentence": "南陽亦誅通兄弟、門宗六十四人，皆焚屍宛市。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000023",
    "sentence": "時，漢兵亦已大合。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000024",
    "sentence": "通與光武、李軼相遇棘陽，遂共破前隊，殺甄阜、梁丘賜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000025",
    "sentence": "更始立，以通為柱國大將軍、輔漢侯。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000026",
    "sentence": "從至長安，更拜為大將軍，封西平王；軼為舞陰王；通從弟松為丞相。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 2,
        "end": 4
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 8,
        "end": 11
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000027",
    "sentence": "更始使通持節還鎮荊州，通因娶光武女弟伯姬，是為寧平公主。",
    "entities": [
      {
        "text": "始使通持節還鎮",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "荊州",
        "label": "LOC",
        "start": 8,
        "end": 10
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000028",
    "sentence": "光武即位，征通為衛尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000029",
    "sentence": "建武二年，封固始侯，拜大司農。",
    "entities": [
      {
        "text": "建武二年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000030",
    "sentence": "帝每征討四方，常令通居守京師，鎮百姓，修宮室，起學宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000031",
    "sentence": "五年春，代王梁為前將軍。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000032",
    "sentence": "六年夏，領破奸將軍侯進、捕虜將軍王霸等十營擊漢中賊。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "漢",
        "label": "ORG",
        "start": 22,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000033",
    "sentence": "公孫述遣兵赴救，通等與戰於西城，破之，還，屯田順陽。",
    "entities": [
      {
        "text": "通等與戰於西城",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000034",
    "sentence": "時，天下略定，通思欲避榮寵，以病上書乞身。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000035",
    "sentence": "詔下公卿群臣議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000036",
    "sentence": "大司徒侯霸等曰：『王莽篡漢，傾亂天下。通懷伊、呂、蕭、曹之謀，建造大策，扶助神靈，輔成聖德。破家為國。忘身奉主，有扶危存亡之義。功德最高，海內所聞。通以天下平定，謙讓辭位。夫安不忘危，宜令通居職療疾。欲就諸侯，不可聽。』於是詔通勉致醫藥，以時視事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000037",
    "sentence": "其夏，引拜為大司空。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000038",
    "sentence": "通布衣唱義，助成大業，重以寧平公主故，特見親重。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000039",
    "sentence": "然性謙恭，常欲避權勢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000040",
    "sentence": "素有消疾，自為宰相，謝病不視事，連年乞骸骨，帝每優寵之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000041",
    "sentence": "令以公位歸第養疾，通復固辭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000042",
    "sentence": "積二歲，乃聽上大司空印綬，以特進奉朝請。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000043",
    "sentence": "有司奏請封諸皇子，帝感通首創大謀，即日封通少子雄為召陵侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000044",
    "sentence": "每幸南陽，常遣使者以太牢祠通父冢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000045",
    "sentence": "十八年卒，謚曰恭侯。",
    "entities": [
      {
        "text": "十八年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000046",
    "sentence": "帝及皇后親臨弔，送葬。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000047",
    "sentence": "子音嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000048",
    "sentence": "音卒，子定嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000049",
    "sentence": "定卒，子黃嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000050",
    "sentence": "黃卒，子壽嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000051",
    "sentence": "李軼後為朱鮪所殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000052",
    "sentence": "更始之敗，李松戰死，唯通能以功名終。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000053",
    "sentence": "永平中，顯宗幸宛，詔諸李隨安眾宗室會見，並受賞賜，恩寵篤焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000054",
    "sentence": "論曰：子曰：『富與貴是人之所欲，不以其道得之，不處也。』李通豈知夫所欲而未識以道者乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000055",
    "sentence": "夫天道性命，聖人難言之，況乃億測微隱，猖狂無妄之福，汙滅親宗，以觖一切之功哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000056",
    "sentence": "昔蒙穀負書，不徇楚難；即墨用齊，義雪燕恥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000057",
    "sentence": "彼之趣捨所立，其殆與通異乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000058",
    "sentence": "王常",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000059",
    "sentence": "王常字顏卿，潁川舞陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000060",
    "sentence": "王莽未，為弟報仇，亡命江夏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000061",
    "sentence": "久之，與王鳳、王匡等起兵雲杜綠林中，聚眾數萬人，以常為偏裨，攻傍縣。",
    "entities": [
      {
        "text": "攻傍縣",
        "label": "LOC",
        "start": 30,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000062",
    "sentence": "後與成丹、張卬別入南郡藍口，號下江兵。",
    "entities": [
      {
        "text": "張卬別入南郡",
        "label": "LOC",
        "start": 5,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000063",
    "sentence": "王莽遣嚴尤、陳茂擊破之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000064",
    "sentence": "常與丹、卬收散卒入蔞谿，劫略鐘、龍間，眾復振。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000065",
    "sentence": "引軍與刑州牧戰於上唐，大破之，遂北至宜秋。",
    "entities": [
      {
        "text": "引軍與刑州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000066",
    "sentence": "是時，漢兵與新市、平林眾俱敗於小長安，各欲解去。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000067",
    "sentence": "伯升聞下江軍在宜秋，即與光武及李通俱造常壁，曰：『願見下江一賢將，議大事。』成丹、張卬共推遣常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000068",
    "sentence": "伯升見常，說以合從之利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000069",
    "sentence": "常大悟，曰：『王莽篡弒，殘虐天下，百姓思漢，故豪傑並起。今劉氏復興，即真主也。誠思出身為用，輔成大功。』伯升曰：『如事成，豈敢獨饗之哉！』遂與常深相結而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000070",
    "sentence": "常還，具為丹、卬言之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000071",
    "sentence": "丹、卬負其從，皆曰：『大丈夫既起，當各自為主，何故受人制乎？』常心獨歸漢，乃稍曉說其將帥曰：『往者成、哀衰微無嗣，故王莽得承間篡位。既有天下，而政令苛酷，積失百姓之心。民之謳吟思漢，非一日也，故使吾屬因此得起。夫民所怨者，天所去也；民所思者，天所與也。舉大事，必當下順民心，上合天意，功乃可成。若負強恃勇，觸情恣欲，雖得天下，必復失之。以秦、項之勢，尚至夷覆，況今布衣相聚草澤？以此行之，滅亡之道也。今南陽諸劉舉宗起兵，觀其來議事者，皆有深計大慮，王公之才，與之並合，必成大功，此天所以祐吾屬也。』下江諸將雖屈強少識，然素敬常，乃皆謝曰：『無王將軍，吾屬幾陷於不義。願敬受教。』即引兵與漢軍及新市、平林合。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 272,
        "end": 274
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000072",
    "sentence": "於是諸部齊心同力，銳氣益壯，遂俱進，破殺甄阜、梁丘賜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000073",
    "sentence": "及諸將議立宗室，唯常與南陽士大夫同意欲立伯升，而朱鮪、張卬等不聽。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000074",
    "sentence": "及更始立，以常為廷尉、大將軍，封知命侯。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000075",
    "sentence": "別徇汝南、沛郡，還入昆陽，與光武共擊破王尋、王邑。",
    "entities": [
      {
        "text": "沛郡",
        "label": "LOC",
        "start": 5,
        "end": 7
      },
      {
        "text": "王邑",
        "label": "LOC",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000076",
    "sentence": "更始西都長安，以常行南陽太守事，令專命誅賞，封為鄧王，食八縣，賜姓劉氏。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "食八縣",
        "label": "LOC",
        "start": 27,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000077",
    "sentence": "常性恭儉，遵法度，南方稱之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000078",
    "sentence": "更始敗，建武二年夏，常將妻子詣洛陽，肉袒自歸。",
    "entities": [
      {
        "text": "建武二年",
        "label": "TME",
        "start": 4,
        "end": 8
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000079",
    "sentence": "光武見常甚歡，勞之曰：『王廷尉良苦。每念往時共更艱厄，何日忘之。莫往莫來，豈違平生之言乎？』常頓首謝曰：『臣蒙大命，得以鞭策托身陛下。始遇宜秋，後會昆陽，幸賴靈武，輒成斷金。更始不量愚臣，任以南州。赤眉之難，喪心失望，以為天下復失綱紀。聞陛下即位河北，心開目明，今得見闕庭，死於遺恨。』帝笑曰：『吾與廷尉戲耳。吾見廷尉，不憂南方矣。』乃召公卿將軍以下大會，具為群臣言：『常以匹夫興義兵，明於知天命，故更始封為知命侯。與吾相遇兵中，尤相厚善。』特加賞賜，拜為左曹，封山桑侯。",
    "entities": [
      {
        "text": "任以南州",
        "label": "LOC",
        "start": 94,
        "end": 98
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 171,
        "end": 173
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000080",
    "sentence": "後帝於大會中指常謂群臣曰：『此家率下江諸將輔翼漢室，心如金石，真忠臣也。』是日遷常為漢忠將軍，遣南擊鄧奉、董訢，令諸將皆屬焉。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 44,
        "end": 46
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000081",
    "sentence": "又詔常北擊河間、漁陽，平諸屯聚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000082",
    "sentence": "五年秋，攻拔湖陵，又與帝會任城，因從破蘇茂、龐萌。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "又與帝會任城",
        "label": "LOC",
        "start": 9,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000083",
    "sentence": "進攻下邳，常部當城門戰，一日數合，賊反走入城，常追迫之，城上射矢雨下，帝從百餘騎自城南高處望，常戰力甚，馳遣中黃門詔使引還，賊遂降。",
    "entities": [
      {
        "text": "常部當城",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "賊反走入城",
        "label": "LOC",
        "start": 17,
        "end": 22
      },
      {
        "text": "帝從百餘騎自城",
        "label": "LOC",
        "start": 35,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000084",
    "sentence": "又別率騎都尉王霸共平沛郡賊。",
    "entities": [
      {
        "text": "尉王霸共平沛郡",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000085",
    "sentence": "六年春，征還洛陽，令夫人迎常於舞陽，歸家上冢。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000086",
    "sentence": "西屯長安，拒隗囂。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000087",
    "sentence": "七年，使使者持璽書，即拜常為橫野大將軍，位次與諸將絕席。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000088",
    "sentence": "常別擊破隗囂將高峻於朝那。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000089",
    "sentence": "囂遣將過烏氏，常要擊破之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000090",
    "sentence": "轉降保塞羌諸營壁，皆平之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000091",
    "sentence": "九年，擊內黃賊，破降之。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000092",
    "sentence": "後北屯故安，拒盧芳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000093",
    "sentence": "十二年，薨於屯所，謚曰節侯。",
    "entities": [
      {
        "text": "十二年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000094",
    "sentence": "子廣嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000095",
    "sentence": "三十年，徙封石城侯。",
    "entities": [
      {
        "text": "三十年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "徙封石城",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000096",
    "sentence": "永平十四年，坐與楚事相連，國除。",
    "entities": [
      {
        "text": "永平十四年",
        "label": "TME",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000097",
    "sentence": "鄧晨",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000098",
    "sentence": "鄧晨字偉卿，南陽新野人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000099",
    "sentence": "世吏二千石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000100",
    "sentence": "父宏，預章都尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000101",
    "sentence": "晨初聚光武姊元。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000102",
    "sentence": "王莽末，光武嘗與兄伯升及晨俱之宛，與穰人蔡少公等宴語。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000103",
    "sentence": "少公頗學圖讖，言劉秀當為天子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000104",
    "sentence": "或曰：『是國師公劉秀乎？』光武戲曰：『何用知非仆耶？』坐者皆大笑，晨心獨喜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000105",
    "sentence": "及光武與家屬避吏新野，舍晨廬，甚相親愛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000106",
    "sentence": "晨因謂光武曰：『王莽悖暴，盛夏斬人，此天亡之時也。往時會宛，獨當應耶？』光武笑不答。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000107",
    "sentence": "及漢兵起，晨將賓客會棘陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000108",
    "sentence": "漢兵敗小長安，諸將多亡家屬，光武單馬遁走。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000109",
    "sentence": "遇女弟伯姬，與共騎而奔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000110",
    "sentence": "前行復見元，超令上馬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000111",
    "sentence": "元以手撝曰：『行矣，不能相救，無為兩沒也。』會追兵至，元及三女皆遇害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000112",
    "sentence": "漢兵退保棘陽，而新野宰乃汙晨宅，焚其冢墓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000113",
    "sentence": "宗族皆恚怒，曰：『家自富足，何故隨婦家人入湯鑊中？』最終無恨色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000114",
    "sentence": "更始立，以晨為偏將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000115",
    "sentence": "與光武略地潁川，俱夜出昆陽城，擊破王尋、王邑。",
    "entities": [
      {
        "text": "俱夜出昆陽城",
        "label": "LOC",
        "start": 8,
        "end": 14
      },
      {
        "text": "王邑",
        "label": "LOC",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000116",
    "sentence": "又別徇陽翟以東，至京、密，皆下之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000117",
    "sentence": "更始北都洛陽，以晨為常山太守。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000118",
    "sentence": "會王郎反，光武自薊走信都，晨亦間行會於巨鹿下，自請從擊邯鄲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000119",
    "sentence": "光武曰：『偉卿以一身從我，不如以一郡為我北道主人。』乃遣晨歸郡。",
    "entities": [
      {
        "text": "不如以一郡",
        "label": "LOC",
        "start": 13,
        "end": 18
      },
      {
        "text": "乃遣晨歸郡",
        "label": "LOC",
        "start": 26,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000120",
    "sentence": "光武追銅馬、高胡群賊於冀州，晨發積射士千人，又遣委輸給軍不絕。",
    "entities": [
      {
        "text": "高胡群賊於冀州",
        "label": "LOC",
        "start": 6,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000121",
    "sentence": "光武即位，封晨房子侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000122",
    "sentence": "帝又感悼姊沒於亂兵，追封謚元為新野節義長公主，立廟於縣西。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 20,
        "end": 22
      },
      {
        "text": "立廟於縣",
        "label": "LOC",
        "start": 23,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000123",
    "sentence": "封晨長子汎為吳房侯，以奉公主之祀。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000124",
    "sentence": "建武三年，征晨還京師，數宴見，說故舊平生為歡。",
    "entities": [
      {
        "text": "建武三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000125",
    "sentence": "晨從容謂帝曰：『仆竟辦之。』帝大笑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000126",
    "sentence": "從幸章陵，拜光祿大夫，使持節監執金吾賈復等擊平邵陵、新息賊。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000127",
    "sentence": "四年，從幸壽春，留鎮九江。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "留鎮",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000128",
    "sentence": "晨好樂郡職，由是復拜為中山太守，吏民稱之，常為冀州高第。",
    "entities": [
      {
        "text": "晨好樂郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "常為冀州",
        "label": "LOC",
        "start": 21,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000129",
    "sentence": "十三年，更封南䜌侯。",
    "entities": [
      {
        "text": "十三年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000130",
    "sentence": "入奉朝請，復為汝南太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000131",
    "sentence": "十八年，行幸章陵，征晨行廷尉事。",
    "entities": [
      {
        "text": "十八年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000132",
    "sentence": "從至新野，置酒酣宴，賞賜數百千萬，復遣歸郡。",
    "entities": [
      {
        "text": "復遣歸郡",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000133",
    "sentence": "晨興鴻郤陂數千頃田，汝土以殷，魚稻之饒，流衍它郡。",
    "entities": [
      {
        "text": "流衍它郡",
        "label": "LOC",
        "start": 20,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000134",
    "sentence": "明年，定封西華侯，復征奉朝請。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000135",
    "sentence": "二十五年卒，詔遣中謁者備公主官屬禮儀，招迎新野主魂，與晨合葬於北芒。",
    "entities": [
      {
        "text": "二十五年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000136",
    "sentence": "乘輿與中宮親臨喪送葬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000137",
    "sentence": "謚曰惠侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000138",
    "sentence": "小子棠嗣，後徙封武當。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000139",
    "sentence": "棠卒，子固嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000140",
    "sentence": "固卒，子國嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000141",
    "sentence": "國卒，子福嗣，永建元年卒，無子，國除。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000142",
    "sentence": "來歙",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000143",
    "sentence": "來歙字君叔，南陽新野人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_015_000144",
    "sentence": "六世祖漢，有才力，武帝世，以光祿大夫副樓船將軍楊仆，擊破南越、朝鮮。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_005_015_000145",
    "sentence": "父仲，哀帝時為諫大夫，娶光武祖姑，生歙。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
