  },
  {
    "sentence_id": "HCH_005_102_000101",
    "sentence": "张为周地，彗星犯之为兵乱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_102_000102",
    "sentence": "后四年，京都大发兵击黄巾贼。",
