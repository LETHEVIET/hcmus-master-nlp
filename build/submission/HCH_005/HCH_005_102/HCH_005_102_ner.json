        "label": "TME",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_005_102_000092",
    "sentence": "白气冲北斗为大战，明年冬，扬州刺史臧旻、丹阳太守陈寅，攻盗贼苴康，斩首数千级。",
    "entities": [
      {
        "text": "扬州",
