    "entities": []
  },
  {
    "sentence_id": "HCH_005_053_000069",
    "sentence": "始在髫鬌，而知廉讓；[一]十歳就學，能通詩、論；及長，專精禮、易。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_053_000070",
