    "entities": []
  },
  {
    "sentence_id": "HCH_005_053_000061",
    "sentence": "注[一]燕具獨行篇周嘉傳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_053_000062",
    "sentence": "注[二]頤，頷也。",
    "entities": []
  },
  {
