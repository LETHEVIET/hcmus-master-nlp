      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000088",
    "sentence": "四事：臣竊見皇子未立，儲宮無主，仰觀天文，太子不明。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
