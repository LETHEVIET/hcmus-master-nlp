      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000130",
    "sentence": "於《易雄雌秘曆》，今值困乏。",
    "entities": [
      {
        "text": "《易雄雌秘曆》",
        "label": "TITLE",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000131",
    "sentence": "凡九二困者，眾小人欲共困害君子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000132",
    "sentence": "《經》曰：『困而不失其所，其唯君子乎！』唯獨賢聖之君，遭困遇險，能致命遂志，不去其道。",
    "entities": [
      {
        "text": "《經》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000133",
    "sentence": "陛下乃者潛龍養德，幽隱屈厄，即位之元，紫宮驚動，歷運之會，時氣已應。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000134",
    "sentence": "然猶恐妖祥未盡，君子思患而豫防之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000135",
    "sentence": "臣以為戌仲已竟，來年入季，文帝改法，除肉刑之罪，至今適三百載。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000136",
    "sentence": "宜因斯際，大蠲法令，官名稱號，輿服器械，事有所更，變大為小，去奢就儉，機衡之政，除煩為簡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000137",
    "sentence": "改元更始，招求幽隱，舉方正，徵有道，博采異謀，開不諱之路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000138",
    "sentence": "臣陳引際會，恐犯忌諱，書不盡言，未敢究暢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000139",
    "sentence": "臺詰顗曰：『對云「白虹貫日，政變常也。」朝廷率由舊章，何所變易而言變常？又言「當大蠲法令，革易官號」。或云變常以致災，或改舊以除異，何也？又陽嘉初建，復欲改元，據何經典？其以實對。』顗對曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000140",
    "sentence": "方春東作，布德之元，陽氣開發，養導萬物。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000141",
    "sentence": "王者因天視聽，奉順時氣，宜務崇溫柔，尊其行令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000142",
    "sentence": "而今立春之後，考事不息，秋冬之政，行乎春夏，故白虹春見，掩蔽日曜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000143",
    "sentence": "凡邪氣乘陽，則虹霓在日，斯皆臣下執事刻急所致。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000144",
    "sentence": "殆非朝廷優寬之本。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000145",
    "sentence": "此其變常之咎也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000146",
    "sentence": "又今選舉皆歸三司，非有周、召之才，而當則哲之重，每有選用，輒參之掾屬，公府門巷，賓客填集，送去迎來，財貨無已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000147",
    "sentence": "其當遷者，競相薦謁，各遣子弟，充塞道路，開長奸門，興致浮偽，非所謂率由舊章也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000148",
    "sentence": "尚書職在機衡，宮禁嚴密，私曲之意，羌不得通，偏黨之恩，或無所用。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000149",
    "sentence": "選舉之任，不如還在機密。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000150",
    "sentence": "臣誠愚戇，不知折中，斯固遠近之論，當今之宜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000151",
    "sentence": "又孔子曰：『漢三百載，鬥歷改憲。』三百四歲為一德，五德千五百二十歲，五行更用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000152",
    "sentence": "王者隨天，譬猶自春徂夏，改青服絳者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000153",
    "sentence": "自文帝省刑，適三百年，而輕微之禁，漸已殷積。",
    "entities": [
      {
        "text": "三百年",
        "label": "TME",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000154",
    "sentence": "王者之法，譬猶江河，當使易避而難犯也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000155",
    "sentence": "故《易》曰：『易則易知，簡則易從，易簡而天下之理得矣。』今去奢即儉，以先天下，改易名號，隨事稱謂。",
    "entities": [
      {
        "text": "《易》",
        "label": "TITLE",
        "start": 1,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000156",
    "sentence": "《易》曰：『君子之道，或出或處，同歸殊塗，一致百慮。』是知變常而善，可以除災，變常而惡，必致於異。",
    "entities": [
      {
        "text": "《易》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000157",
    "sentence": "今年仲竟，來年入季，仲終季始，歷運變改，故可改元，所以順天道也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000158",
    "sentence": "臣顗愚蔽，不足以答聖問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000159",
    "sentence": "顗又上書薦黃瓊、李固，並陳消災之術曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000160",
    "sentence": "臣前對七事，要政急務，宜於今者，所當施用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000161",
    "sentence": "誠知愚淺，不合聖聽，人賤言廢，當受誅罰，徵營惶怖，靡知厝身。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000162",
    "sentence": "臣聞刳舟剡楫，將欲濟江海也；聘賢選佐，將以安天下也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000163",
    "sentence": "昔唐堯在上，群龍為用，文、武創德，周、召作輔，是以能建天地之功，增日月之耀者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000164",
    "sentence": "《詩》云：『赫赫王命，仲山甫將之。邦國若否，仲山甫明之。』宣王是賴，以致雍熙。",
    "entities": [
      {
        "text": "《詩》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000165",
    "sentence": "陛下踐祚以來，勤心庶政，而三九之位，未見其人，是以災害屢臻，四國未寧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000166",
    "sentence": "臣考之國典，驗之聞見，莫不以得賢為功，失士為敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000167",
    "sentence": "且賢者出處，翔而後集，爵以德進，則其情不茍，然後使君子恥貧賤而樂富貴矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000168",
    "sentence": "若有德不報，有言不酬，來無所樂，進無所趨，則皆懷歸藪澤，修其故誌矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000169",
    "sentence": "夫求賢者，上以承天，下以為人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000170",
    "sentence": "不用之，則逆天統，違人望。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000171",
    "sentence": "逆天統則災眚降，違人望則化不行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000172",
    "sentence": "災眚降則下呼嗟，化不行則君道虧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000173",
    "sentence": "四始之缺，五際之厄，其咎由此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000174",
    "sentence": "豈可不剛健篤實，矜矜栗栗，以守天功盛德大業乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000175",
    "sentence": "臣伏見光祿大夫江夏黃瓊，耽道樂術，清亮自然，被褐懷寶，含味經籍，又果於從政，明達變復。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000176",
    "sentence": "朝廷前加優寵，賓於上位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000177",
    "sentence": "瓊入朝日淺，謀謨未就，因以喪病，致命遂誌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000178",
    "sentence": "《老子》曰：『大音希聲，大器晚成。』善人為固，三年乃立。",
    "entities": [
      {
        "text": "《老子》",
        "label": "TITLE",
        "start": 0,
        "end": 4
      },
      {
        "text": "三年",
        "label": "TME",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000179",
    "sentence": "天下莫不嘉朝廷有此良人，而復怪其不時還任。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000180",
    "sentence": "陛下宜加降崇之恩，極養賢之禮，徵反京師，以慰天下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000181",
    "sentence": "又處士漢中李固，年四十，通遊、夏之藝，履顏、閔之仁。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 3,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000182",
    "sentence": "潔白之節，情同敫日，忠貞之操，好是正直，卓冠古人，當世莫及。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000183",
    "sentence": "元精所生，王之佐臣，天之生固，必為聖漢，宜蒙特徵，以示四方。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000184",
    "sentence": "夫有出倫之才，不應限以官次。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000185",
    "sentence": "昔顏子十八，天下歸仁；子奇稚齒，化阿有聲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000186",
    "sentence": "若還瓊徵固，任以時政，伊尹、傅說，不足為此，則可垂景光，致休祥矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000187",
    "sentence": "臣顗明不知人，伏聽眾言，百姓所歸，臧否共嘆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000188",
    "sentence": "願泛問百僚，核其名行，有一不合，則臣為欺國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000189",
    "sentence": "惟留聖神，不以人廢言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000190",
    "sentence": "謹復條便宜四事，附奏於左：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000191",
    "sentence": "一事：孔子作《春秋》，書『正月』者，敬歲之始也。",
    "entities": [
      {
        "text": "《春秋》",
        "label": "TITLE",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000192",
    "sentence": "王者則天之象，因時之序，宜開發德號，爵賢命士，流寬大之澤，垂仁厚之德，順助元氣，含養庶類。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000193",
    "sentence": "如此，則天文昭爛，星辰顯列，五緯循軌，四時和睦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000194",
    "sentence": "不則太陽不光，天地混濁，時氣錯逆，霾霧蔽日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000195",
    "sentence": "自立春以來，累經旬朔，未見仁德有所施布，但聞罪罰考掠之聲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000196",
    "sentence": "夫天之應人，疾如景響，而自從入歲，常有蒙氣，月不舒光，日不宣曜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000197",
    "sentence": "日者太陽，以象人君，政變於下，日應於天。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000198",
    "sentence": "清濁之占，隨政抑揚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000199",
    "sentence": "天之見異，事無虛作。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000200",
    "sentence": "豈獨陛下倦於萬機，帷幄之政有所闕歟？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000201",
    "sentence": "何天戒之數見也！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000202",
    "sentence": "臣願陛下發揚乾剛，援引賢能，勤求機衡之寄，以獲斷金之利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000203",
    "sentence": "臣之所陳，輒以太陽為先者，明其不可久暗，急當改正。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000204",
    "sentence": "其異雖微，其事甚重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000205",
    "sentence": "臣言雖約，其旨甚廣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000206",
    "sentence": "惟陛下乃眷臣章，深留明思。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000207",
    "sentence": "二事：孔子曰：『雷之始發《大壯》始，君弱臣強從《解》起。』今月九日至十四日，《大壯》用事，消息之卦也。",
    "entities": [
      {
        "text": "《大壯》",
        "label": "TITLE",
        "start": 12,
        "end": 16
      },
      {
        "text": "《解》",
        "label": "TITLE",
        "start": 23,
        "end": 26
      },
      {
        "text": "《大壯》",
        "label": "TITLE",
        "start": 38,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000208",
    "sentence": "於此六日之中，雷當發聲，發聲則歲氣和，王道興也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000209",
    "sentence": "《易》曰：『雷出地奮，豫，先王以作樂崇德，殷薦之上帝。』雷者，所以開發萌牙，辟陰除害。",
    "entities": [
      {
        "text": "《易》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000210",
    "sentence": "萬物須雷而解，資雨而潤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000211",
    "sentence": "故《經》曰：『雷以動之，雨以潤之。』王者崇寬大，順春令，則雷應節，不則發動於冬，當震反潛。",
    "entities": [
      {
        "text": "《經》",
        "label": "TITLE",
        "start": 1,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000212",
    "sentence": "故《易傳》曰：『當雷不雷，太陽弱也。』今蒙氣不除，日月變色，則其效也。",
    "entities": [
      {
        "text": "《易傳》",
        "label": "TITLE",
        "start": 1,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000213",
    "sentence": "天網恢恢，疏而不失，隨時進退，應政得失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000214",
    "sentence": "大人者，與天地合其德，與日月合其明，璇璣動作，與天相應。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000215",
    "sentence": "雷者號令，其德生養。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000216",
    "sentence": "號令殆廢，當生而殺，則雷反作，其時無歲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000217",
    "sentence": "陛下若欲除災昭祉，順天致和，宜察臣下尤酷害者，亟加斥黜，以安黎元，則太皓悅和，雷聲乃發。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000218",
    "sentence": "三事：去年十月二十日癸亥，太白與歲星合於房、心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000219",
    "sentence": "太白在北，歲星在南，相離數寸，光芒交接。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000220",
    "sentence": "房、心者，天帝明堂布政之宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000221",
    "sentence": "《 孝經 鉤命決》曰：『歲星守心年穀豐。』《尚書洪範記》曰：『月行中道，移節應期，德厚受福，重華留之。』重華者，謂歲星在心也。",
    "entities": [
      {
        "text": "《 孝經 鉤命決》",
        "label": "TITLE",
        "start": 0,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000222",
    "sentence": "今太白從之，交合明堂，金木相賊，而反同合，此以陰陵陽，臣下專權之異也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000223",
    "sentence": "房、心東方，其國主宋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000224",
    "sentence": "《石氏經》曰：『歲星出左有年，出右無年。』今金木俱東，歲星在南，是為出右，恐年穀不成，宋人饑也。",
    "entities": [
      {
        "text": "《石氏經》",
        "label": "TITLE",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000225",
    "sentence": "陛下宜審詳明堂布政之務，然後妖異可消，五緯順序矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000226",
    "sentence": "四事：《易傳》曰：『陽無德則旱，陰僭陽亦旱。』陽無德者，人君恩澤不施於人也。",
    "entities": [
      {
        "text": "《易傳》",
        "label": "TITLE",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000227",
    "sentence": "陰僭陽者，祿去公室，臣下專權也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000228",
    "sentence": "自冬涉春，訖無嘉澤，數有西風，反逆時節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000229",
    "sentence": "朝廷勞心，廣為禱祈，薦祭山川，暴龍移市。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000230",
    "sentence": "臣聞皇天感物，不為偽動，災變應人，要在責已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000231",
    "sentence": "若令雨可請降，水可攘止，則歲無隔並，太平可待。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000232",
    "sentence": "然而災害不息者，患不在此也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000233",
    "sentence": "立春以來，未見朝廷賞錄有功，表顯有德，存問孤寡，賑恤貧弱，而但見洛陽都官奔車東西，收系纖介，牢獄充盈。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000234",
    "sentence": "臣聞恭陵火處，比有光曜，明此天災，非人之咎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000235",
    "sentence": "丁丑大風，掩蔽天地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000236",
    "sentence": "風者號令，天之威怒，皆所以感悟人君忠厚之戒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000237",
    "sentence": "又連月無雨，將害宿麥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000238",
    "sentence": "若一穀不登，則饑者十三四矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000239",
    "sentence": "陛下誠宜廣被恩澤，貸贍元元。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000240",
    "sentence": "昔堯遭九年之水，人有十載之蓄者，簡稅防災，為其方也。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000241",
    "sentence": "願陛下早宣德澤，以應天功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000242",
    "sentence": "若臣言不用，朝政不改者，立夏之後乃有澍雨，於今之際未可望也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000243",
    "sentence": "若政變於朝而天不雨，則臣為誣上，愚不知量，分當鼎鑊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000244",
    "sentence": "書奏，特詔拜郎中，辭病不就，即去歸家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000245",
    "sentence": "至四月京師地震，遂陷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000246",
    "sentence": "其夏大旱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000247",
    "sentence": "秋，鮮卑入馬邑城，破代郡兵。",
    "entities": [
      {
        "text": "鮮卑入馬邑城",
        "label": "LOC",
        "start": 2,
        "end": 8
      },
      {
        "text": "破代郡",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000248",
    "sentence": "明年，西羌寇隴右。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000249",
    "sentence": "皆略如顗言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000250",
    "sentence": "後復公車徵，不行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000251",
    "sentence": "同縣孫禮者，積惡凶暴，好遊俠，與其同里人常慕顗名德，欲與親善。",
    "entities": [
      {
        "text": "同縣",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000252",
    "sentence": "顗不顧，以此結怨，遂為禮所殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000253",
    "sentence": "襄楷",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000254",
    "sentence": "襄楷字公矩，平原隰陰人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000255",
    "sentence": "好學博古，善天文陰陽之術。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000256",
    "sentence": "桓帝時，宦官專朝，政刑暴濫，又比失皇子，災異尤數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000257",
    "sentence": "延熹九年 ，楷自家詣闕上疏曰：",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000258",
    "sentence": "臣聞皇天不言，以文象設教。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000259",
    "sentence": "堯、舜雖聖，必歷象日月星辰，察五緯所在，故能享百年之壽，為萬世之法。",
    "entities": [
      {
        "text": "百年",
        "label": "TME",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000260",
    "sentence": "臣竊見去歲五月，熒惑入太微，犯帝座，出端門，不軌常道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000261",
    "sentence": "其閏月良辰，太白入房，犯心小星，震動中耀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000262",
    "sentence": "中耀，天王也；傍小星者，天王子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000263",
    "sentence": "夫太微天廷，五帝之坐，而金火罰星揚光其中，於占，天子凶；又俱入房、心，法無繼嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000264",
    "sentence": "今年歲星久守太微，逆行西至掖門，還切執漢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000265",
    "sentence": "歲為木精，好生惡殺，而淹留不去者，咎在仁德不修，誅罰太酷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000266",
    "sentence": "前七年十二月，熒惑與歲星俱入軒轅，逆行四十餘日，而鄧皇后誅。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 1,
        "end": 3
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000267",
    "sentence": "其冬大寒，殺鳥獸，害魚鱉，城傍竹柏之葉有傷枯者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000268",
    "sentence": "臣聞於師曰：『柏傷竹枯，不出三年，天子當之。』今洛陽城中人夜無故叫呼，云有火光，人聲正喧，於占亦與竹柏枯同。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 14,
        "end": 16
      },
      {
        "text": "今洛陽城",
        "label": "LOC",
        "start": 23,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000269",
    "sentence": "自春夏以來，連有霜雹及大雨雷，而臣作威作福，刑罰急刻之所感也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000270",
    "sentence": "太原太守劉質、南陽太守成晉，志除奸邪，其所誅剪，皆合人望，而陛下受閹豎之譖，乃遠加考逮。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000271",
    "sentence": "三公上書乞哀質等，不見采察，而嚴被譴讓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000272",
    "sentence": "憂國之臣，將遂杜口矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000273",
    "sentence": "臣聞殺無罪，誅賢者，禍及三世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000274",
    "sentence": "自陛下即位以來，頻行誅伐，梁、寇、孫、鄧，並見族滅，其從坐者，又非其數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000275",
    "sentence": "李雲上書，明主所不當諱，杜眾乞死，諒以感悟聖朝，曾無赦宥，而並被殘戮，天下之人，咸知其冤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000276",
    "sentence": "漢興以來，未有拒諫誅賢，用刑太深如今者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000277",
    "sentence": "永平舊典，諸當重論皆須冬獄，先請後刑，所以重人命也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000278",
    "sentence": "頃數十歲以來，州郡玩習，又欲避請讞之煩，輒托疾病，多死牢獄。",
    "entities": [
      {
        "text": "州郡",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000279",
    "sentence": "長吏殺生自己，死者多非其罪，魂神冤結，無所歸訴，淫厲疾疫，自此而起。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000280",
    "sentence": "昔文王一妻，誕至十子，今宮女數千，未聞慶育。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000281",
    "sentence": "宜修德省刑，以廣《螽斯》之祚。",
    "entities": [
      {
        "text": "《螽斯》",
        "label": "TITLE",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000282",
    "sentence": "又七年六月十三日，河內野王山上有龍死，長可數十丈。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000283",
    "sentence": "扶風有星隕為石，聲聞三郡。",
    "entities": [
      {
        "text": "聲聞三郡",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000284",
    "sentence": "夫龍形狀不一，小大無常，故《 周易 》況之大人，帝王以為符瑞。",
    "entities": [
      {
        "text": "《 周易 》",
        "label": "TITLE",
        "start": 13,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000285",
    "sentence": "或聞河內龍死，諱以為蛇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000286",
    "sentence": "夫龍能變化，蛇亦有神，皆不當死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000287",
    "sentence": "昔秦之將衰，華山神操璧以授鄭客，曰『今年祖龍死』，始皇逃之，死於沙丘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000288",
    "sentence": "王莽 天鳳二年 ，訛言黃山宮有死龍之異，後漢誅莽，光武復興。",
    "entities": [
      {
        "text": "天鳳二年",
        "label": "TME",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000289",
    "sentence": "虛言猶然，況於實邪？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000290",
    "sentence": "夫星辰麗天，猶萬國之附王者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000291",
    "sentence": "下將畔上，故星亦畔天。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000292",
    "sentence": "石者安類，墜者失勢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000293",
    "sentence": "春秋五石隕宋，其後襄公為楚所執。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000294",
    "sentence": "秦之亡也，石隕東郡。",
    "entities": [
      {
        "text": "石隕東郡",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000295",
    "sentence": "今損扶風，與先帝園陵相近，不有大喪，必有畔逆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000296",
    "sentence": "案春秋以來及古帝王，未有河清及學門自壞者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000297",
    "sentence": "臣以為河者，諸侯位也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000298",
    "sentence": "清者屬陽，濁者屬陰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000299",
    "sentence": "河當濁而反清者，陰欲為陽，諸侯欲為帝也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000300",
    "sentence": "太學，天子教化之宮，其門無故自壞者，言文德將喪，教化廢也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000301",
    "sentence": "京房《易傳》曰：『河水清，天下平。』今天垂盡，地吐妖，人厲疫，三者並時而有河清，猶春秋麟不當見而見，孔子書之以為異也。",
    "entities": [
      {
        "text": "《易傳》",
        "label": "TITLE",
        "start": 2,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000302",
    "sentence": "臣前上瑯邪宮崇受 干吉 神書，不合明聽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000303",
    "sentence": "臣聞布穀鳴於孟夏，蟋蟀吟於始秋，物有微而志信，人有賤而言忠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000304",
    "sentence": "臣雖至賤，誠願賜清閑，極盡所言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000305",
    "sentence": "書奏不省。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000306",
    "sentence": "十餘日，復上書曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000307",
    "sentence": "臣伏見太白北入數日，復出東方，其占當有大兵，中國弱，四夷強。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000308",
    "sentence": "臣又推步，熒惑今當出而潛，必有陰謀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000309",
    "sentence": "皆由獄多冤結，忠臣被戮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000310",
    "sentence": "德星所以久守執法，亦為此也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000311",
    "sentence": "陛下宜承天意，理察冤獄，為劉質、成晉虧除罪辟，追錄李雲、杜眾等子孫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000312",
    "sentence": "夫天子事天不孝，則日食星鬥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000313",
    "sentence": "比年日食於正朔，三光不明，五緯錯戾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000314",
    "sentence": "前者宮崇所獻神書，專以奉天地順五行為本，亦有興國廣嗣之術。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000315",
    "sentence": "其文易曉，參同經典，而順帝不行，故國胤不興，孝沖、孝質頻世短祚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000316",
    "sentence": "臣又聞之，得主所好，自非正道，神為生虐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000317",
    "sentence": "故周衰，諸侯以力徵相尚，於是夏育、申休、宋萬、彭生、任鄙之徒生於其時。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000318",
    "sentence": "殷紂好色，妲已是出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000319",
    "sentence": "葉公好龍，真龍遊廷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000320",
    "sentence": "今黃門常侍，天刑之人，陛下愛待，兼倍常寵，系嗣未兆，豈不為此？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000321",
    "sentence": "天官宦者星不在紫宮而在天市，明當給使主市裏也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000322",
    "sentence": "今乃反處常伯之位，實非天意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000323",
    "sentence": "又聞宮中立黃、老、浮屠之祠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000324",
    "sentence": "此道清虛，貴尚無為，好生惡殺，省欲去奢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000325",
    "sentence": "今陛下嗜欲不去，殺罰過理，既乖其道，豈獲其祚哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000326",
    "sentence": "或言老子入夷狄為浮屠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000327",
    "sentence": "浮屠不三宿桑下，不欲久生恩愛，精之至也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000328",
    "sentence": "天神遺以好女，浮屠曰：『此但革囊盛血。』遂不眄之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000329",
    "sentence": "其守一如此，乃能成道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000330",
    "sentence": "今陛下淫女艷婦，極天下之麗，甘肥飲美，單天下之味，奈何欲如黃、老乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000331",
    "sentence": "書上，即召詣尚書問狀。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000332",
    "sentence": "楷曰：『臣聞古者本無宦臣，武帝末，春秋高，數遊後宮，始置之耳。後稍見任，至於順帝，遂益繁熾。今陛下爵之，十倍於前。至今無繼嗣者，豈獨好之而使之然乎？』尚書上其對，詔下有司處正。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 75,
        "end": 77
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000333",
    "sentence": "尚書承旨奏曰：『其宦者之官，非近世所置。漢初張澤為大謁者，佐絳侯誅諸呂；孝文使趙談參乘，而子孫昌盛。楷不正辭理，指陳要務，而析言破律，違背經藝，假借星宿，偽托神靈，造合私意，誣上罔事。請下司隸，正楷罪法，收送洛陽獄。』帝以楷言雖激切，然皆天文恒象之數，故不誅，猶司寇論刑。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "漢",
        "label": "ORG",
        "start": 20,
        "end": 21
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 104,
        "end": 106
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000334",
    "sentence": "初，順帝時，瑯邪宮崇詣闕，上其師干吉於曲陽泉水上所得神書百七十卷，皆縹白素朱介青首朱目，號《 太平清領書 》。",
    "entities": [
      {
        "text": "《 太平清領書 》",
        "label": "TITLE",
        "start": 45,
        "end": 54
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000335",
    "sentence": "其言以陰陽五行為家，而多巫覡雜語。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000336",
    "sentence": "有司奏崇所上妖妄不經，乃收臧之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000337",
    "sentence": "後張角頗有其書焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000338",
    "sentence": "及靈帝即位，以楷書為然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000339",
    "sentence": "太傅陳蕃舉方正，不就。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000340",
    "sentence": "鄉里宗之，每太守至，輒致禮清。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000341",
    "sentence": "中平中，與荀爽、鄭玄俱以博士徵，不至，卒於家。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000342",
    "sentence": "【史論】",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000343",
    "sentence": "論曰：古人有云：『善言天者，必有驗於人。』而張衡亦云：『天文歷數，陰陽占候，今所宜急也。』郎顗、襄楷能仰瞻俯察，參諸人事，禍福吉凶既應，引之教義亦明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000344",
    "sentence": "此蓋道術所以有補於時，後人所當取鑒者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000345",
    "sentence": "然而其敝好巫，故君子不以專心焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000346",
    "sentence": "贊曰：仲桓術深，蒲車屢尋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000347",
    "sentence": "蘇竟飛書，清我舊陰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000348",
    "sentence": "襄、郎災戒，實由政淫。",
    "entities": []
  }
