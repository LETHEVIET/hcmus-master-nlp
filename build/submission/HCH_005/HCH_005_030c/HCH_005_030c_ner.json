[
  {
    "sentence_id": "HCH_005_030c_000001",
    "sentence": "郎顗",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000002",
    "sentence": "郎顗字雅光，北海安丘人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000003",
    "sentence": "父宗，字仲綏，學《京氏易》，善風角、星算、六日七分，能望氣占候吉凶，常賣卜自奉。",
    "entities": [
      {
        "text": "《京氏易》",
        "label": "TITLE",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000004",
    "sentence": "安帝徵之，對策為諸儒表，後拜吳令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000005",
    "sentence": "時卒有暴風，宗占知京師當有大火，記識時日，遣人參候，果如其言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000006",
    "sentence": "諸公聞而表上，以博士徵之。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000007",
    "sentence": "宗恥以占驗見知，聞徵書到，夜縣印綬於縣廷而遁去，遂終身不仕。",
    "entities": [
      {
        "text": "夜縣印綬於縣",
        "label": "LOC",
        "start": 13,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000008",
    "sentence": "顗少傳父業，兼明經典，隱居海畔，延致學徒常數百人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000009",
    "sentence": "晝研精義，夜占象度，勤心銳思，朝夕無倦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000010",
    "sentence": "州郡辟召，舉有道、方正，不就。",
    "entities": [
      {
        "text": "州郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000011",
    "sentence": "順帝時，災異屢見， 陽嘉二年 正月，公正徵，顗乃詣闕拜章曰：",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000012",
    "sentence": "臣聞天垂妖象，地見災符，所以譴告人主，責躬修德，使正機平衡，流化興政也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000013",
    "sentence": "《易內傳》曰：『凡災異所生，各以其政。變之則除，消之亦除。』伏惟陛下躬日吳之聽，溫三省之勤，思過念咎，務消祇悔。",
    "entities": [
      {
        "text": "《易內傳》",
        "label": "TITLE",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000014",
    "sentence": "方今時俗奢佚，淺恩薄義。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000015",
    "sentence": "夫救奢必於儉約，拯薄無若敦厚，安上理人，莫善於禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000016",
    "sentence": "修禮遵約，蓋惟上興，革文變薄，事不在下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000017",
    "sentence": "故《周南》之德，《關雎》政本。",
    "entities": [
      {
        "text": "《周南》",
        "label": "TITLE",
        "start": 1,
        "end": 5
      },
      {
        "text": "《關雎》",
        "label": "TITLE",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000018",
    "sentence": "本立道生，風行草從，澄其源者流清，混其本者末濁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000019",
    "sentence": "天地之道，其猶鼓籥，以虛為德，自近及遠者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000020",
    "sentence": "伏見往年以來，園陵數災，炎光熾猛，驚動神靈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000021",
    "sentence": "《易天人應》曰：『君子不思遵利，茲謂無澤，厥災孽火燒其宮。』又曰：『君高臺府，犯陰侵陽，厥災火。』又曰：『上不儉，下不節，炎火並作燒君室。』自頃繕理西蒼，修復太學，宮殿官府，多所構飾。",
    "entities": [
      {
        "text": "《易天人應》",
        "label": "TITLE",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000022",
    "sentence": "昔盤庚遷殷，去奢即儉，夏後卑室，盡力致美。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000023",
    "sentence": "又魯人為長府，閔子騫曰：『仍舊貫，何必改作。』臣愚以為諸所繕修，事可省減，稟恤貧人，賑贍孤寡，此天之意也，人之慶也，仁之本也，儉之要也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000024",
    "sentence": "焉有應天養人，為仁為儉，而不降福者哉？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000025",
    "sentence": "土者地祇，陰性澄靜，宜以施化之時，敬而勿擾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000026",
    "sentence": "竊見正月以來，陰暗連日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000027",
    "sentence": "《易內傳》曰：『久陰不雨，亂氣也，《蒙》之《比》也。蒙者，君臣上下相冒亂也。』又曰：『欲德不用，厥異常陰。』夫賢者化之本，雲者雨之具也。",
    "entities": [
      {
        "text": "《易內傳》",
        "label": "TITLE",
        "start": 0,
        "end": 5
      },
      {
        "text": "《蒙》",
        "label": "TITLE",
        "start": 17,
        "end": 20
      },
      {
        "text": "《比》",
        "label": "TITLE",
        "start": 21,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000028",
    "sentence": "得賢而不用，猶久陰而不雨也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000029",
    "sentence": "又頃前數日，寒過其節，冰既解釋，還復凝合。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000030",
    "sentence": "夫寒往則暑來，暑往則寒來，此言日月相推，寒暑相避，以成物也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000031",
    "sentence": "今立春之後，火卦用事，當溫而寒，違反時節，由功賞不至，而刑罰必加也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000032",
    "sentence": "宜須立秋，順氣行罰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000033",
    "sentence": "臣伏案《飛侯》，參察眾政，以為立夏之後，當有震裂湧水之害。",
    "entities": [
      {
        "text": "《飛侯》",
        "label": "TITLE",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000034",
    "sentence": "又比熒惑失度，盈縮往來，涉歷輿鬼，環繞軒轅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000035",
    "sentence": "火精南方，夏之政也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000036",
    "sentence": "政有失禮，不從夏令，則熒惑失行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000037",
    "sentence": "正月三日至乎九日，三公卦也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000038",
    "sentence": "三公上應臺階，下同元首。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000039",
    "sentence": "政失其道，則寒陰反節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000040",
    "sentence": "『節彼南山』，詠自《周詩》；『股肱良哉』，著於《虞典》。",
    "entities": [
      {
        "text": "《周詩》",
        "label": "TITLE",
        "start": 9,
        "end": 13
      },
      {
        "text": "《虞典》",
        "label": "TITLE",
        "start": 23,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000041",
    "sentence": "而今之在位，競托高虛，納累鐘之奉，忘天下之憂，棲遲偃仰，寢疾自逸，被策文，得賜錢，即復起矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000042",
    "sentence": "何疾之易而愈之速』以此消伏災眚，興致升平，其可得乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000043",
    "sentence": "今選舉牧守，委任三府。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000044",
    "sentence": "長吏不良，既咎州郡，州郡有失，豈得不歸責舉者？",
    "entities": [
      {
        "text": "既咎州郡",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "州郡",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000045",
    "sentence": "而陛下崇之彌優，自下慢事愈甚，所謂大網疏，小網數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000046",
    "sentence": "三公非臣之仇，臣非狂夫之作，所以發憤忘食，懇懇不已者，誠念朝廷欲致興平，非不能面譽也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000047",
    "sentence": "臣生長草野，不曉禁忌，披露肝膽，書不擇言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000048",
    "sentence": "伏锧鼎鑊，死不敢恨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000049",
    "sentence": "謹詣闕奉章，伏待重誅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000050",
    "sentence": "書奏，帝復使對尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000051",
    "sentence": "顗對曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000052",
    "sentence": "臣聞明王聖主好聞其過，忠臣孝子言無隱情。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000053",
    "sentence": "臣備生人倫視聽之類，而稟性愚愨，不識忌諱，故出死亡命，懇懇重言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000054",
    "sentence": "誠欲陛下修乾坤之德，開日月之明，披圖籍，案經典，覽帝王之務，識先後之政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000055",
    "sentence": "如有闕遺，退而自改。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000056",
    "sentence": "本文、武之業，擬堯、舜之道，攘災延慶，號令天下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000057",
    "sentence": "此誠臣顗區區之願，夙夜夢寤，盡心所計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000058",
    "sentence": "謹條序前章，暢其旨趣，條便宜七事，具如狀對：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000059",
    "sentence": "一事：陵園至重，聖神攸馮，而災火炎赫，迫近寢殿，魂而有靈，猶將驚動。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000060",
    "sentence": "尋宮殿宮府，近始永平，歲時未積，便更修造。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000061",
    "sentence": "又西苑之設，禽畜是處，離房別觀，本不常居，而皆條精土木，營建無已，消功單賄，巨億為計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000062",
    "sentence": "《易內傳》曰：『人君奢侈，多飾宮室，其時旱，其災火。』是故魯僖遭旱，修政自敕，下鐘鼓之縣，休繕治之官，雖則不寧，而時雨自降。",
    "entities": [
      {
        "text": "《易內傳》",
        "label": "TITLE",
        "start": 0,
        "end": 5
      },
      {
        "text": "下鐘鼓之縣",
        "label": "LOC",
        "start": 39,
        "end": 44
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000063",
    "sentence": "由此言之，天之應人，敏於景響。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000064",
    "sentence": "今月十七日戊午，徵日也，日加申，風從寅來，丑時而止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000065",
    "sentence": "丑、寅、申皆徵也，不有火災，必當為旱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000066",
    "sentence": "願陛下校計繕修之費，永念百姓之勞，罷將作之官，減雕文之飾，損皰廚之饌，退宴私之樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000067",
    "sentence": "《易中孚傳》曰：『陽感天，不旋日。』如是，則景雲降集，眚沴息矣。",
    "entities": [
      {
        "text": "《易中孚傳》",
        "label": "TITLE",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000068",
    "sentence": "二事：去年以來，《兌卦》用事，類多不效。",
    "entities": [
      {
        "text": "《兌卦》",
        "label": "TITLE",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000069",
    "sentence": "《易傳》曰：『有貌無實，佞人也；有實無貌，道人也。』寒溫為實，清濁為貌。",
    "entities": [
      {
        "text": "《易傳》",
        "label": "TITLE",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000070",
    "sentence": "今三公皆令色足恭，外厲內荏，以虛事上，無佐國之實，故清濁效而寒溫不效也，是以陰寒侵犯消息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000071",
    "sentence": "占曰：『日乘則有妖風，日蒙則有地裂。』如是三年，則致日食，陰侵其陽，漸積所致。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000072",
    "sentence": "立春前後溫氣應節者，詔令寬也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000073",
    "sentence": "其後復寒者，無寬之實也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000074",
    "sentence": "夫十室之邑，必有忠信，率土之人，豈無貞賢，未聞朝廷有所賞拔，非所以求善贊務，弘濟元元。",
    "entities": [
      {
        "text": "夫十室之邑",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_030c_000075",
    "sentence": "宜采納良臣，以助聖化。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000076",
    "sentence": "三事：臣聞天道不遠，三五復反。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000077",
    "sentence": "今年少陽之歲，法當乘起，恐後年已往，將遂驚動，涉歷天門，災成戊巳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000078",
    "sentence": "今春當旱，夏必有水，臣以六日七分候之可知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000079",
    "sentence": "未災眚之來，緣類而應。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000080",
    "sentence": "行有玷缺，則氣逆於天，精感變出，以戒人君。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000081",
    "sentence": "王者之義，時有不登，則損滋徹膳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000082",
    "sentence": "數年以來，穀收稍減，家貧戶饉，歲不如昔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000083",
    "sentence": "百姓不足，君誰與足？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000084",
    "sentence": "水旱之災，雖尚未至，然君子遠覽，防微慮萌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_030c_000085",
    "sentence": "《 老子 》曰：『人之饑也，以其上食稅之多也。』故孝文皇帝綈袍革舄，木器無文，約身薄賦，時致升平。",
