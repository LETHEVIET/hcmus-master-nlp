    "entities": []
  },
  {
    "sentence_id": "HCH_005_096_000262",
    "sentence": "太皇太后、皇太后崩，司空以特牲告謚於祖廟如儀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_096_000263",
