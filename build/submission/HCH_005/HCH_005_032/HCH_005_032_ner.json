[
  {
    "sentence_id": "HCH_005_032_000001",
    "sentence": "樊宏",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000002",
    "sentence": "樊宏字靡卿，南陽湖陽人也，世祖之舅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000003",
    "sentence": "其先周仲山甫，封於樊，因而氏焉，為鄉里著姓。",
    "entities": [
      {
        "text": "為鄉",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000004",
    "sentence": "父重，字君雲，世善農稼，好貨殖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000005",
    "sentence": "重性溫厚，有法度，三世共財，子孫朝夕禮敬，常若公家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000006",
    "sentence": "其營理產業，物無所棄，課役童隸，各得其宜，故能上下戮力，財利歲倍，至乃開廣田土三百餘頃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000007",
    "sentence": "其所起廬舍，皆有重堂高閣，陂渠灌註。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000008",
    "sentence": "又池魚牧畜，有求必給。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000009",
    "sentence": "嘗欲作器物，先種梓漆，時人嗤之，然積以歲月，皆得其用，向之笑者咸求假焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000010",
    "sentence": "資至巨萬，而賑贍宗族，恩加鄉閭。",
    "entities": [
      {
        "text": "恩加鄉",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000011",
    "sentence": "外孫何氏兄弟爭財，重恥之，以田二頃解其忿訟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000012",
    "sentence": "縣中稱美，推為三老。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000013",
    "sentence": "年八十餘終。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000014",
    "sentence": "其素所假貸人間數百萬，遺令焚削文契。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000015",
    "sentence": "責家聞者皆慚，爭往償之，諸子從敕，竟不肯受。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000016",
    "sentence": "宏少有誌行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000017",
    "sentence": "王莽末，義兵起，劉伯升與族兄賜俱將兵攻湖陽，城守不下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000018",
    "sentence": "賜女弟為宏妻，湖陽由是收系宏妻子，令出譬伯升，宏因留不反。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000019",
    "sentence": "湖陽軍帥欲殺其妻子，長吏以下共相謂曰：『樊重子父，禮義恩德行於鄉里，雖有罪，且當在後。』會漢兵日盛，湖陽惶急，未敢殺之，遂得免脫。",
    "entities": [
      {
        "text": "禮義恩德行於鄉",
        "label": "LOC",
        "start": 25,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000020",
    "sentence": "更始立，欲以宏為將，宏叩頭辭曰：『書生不習兵事。』竟得免歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000021",
    "sentence": "與宗家親屬作營塹自守，老弱歸之者千餘家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000022",
    "sentence": "時赤眉賊掠唐子鄉，多所殘殺，欲前攻宏營，宏遣人持牛酒米穀，勞遺赤眉。",
    "entities": [
      {
        "text": "赤眉賊掠唐子鄉",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000023",
    "sentence": "赤眉長老先聞宏仁厚，皆稱曰：『樊君素善，且今見待如此，何心攻之。』引兵而去，遂免寇難。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000024",
    "sentence": "世祖即位，拜光祿大夫，位特進，次三公。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000025",
    "sentence": "建武五年 ，封長羅侯。",
    "entities": [
      {
        "text": "建武五年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000026",
    "sentence": "十三年，封弟丹為射陽侯，兄子尋玄鄉侯，族兄忠更父侯。",
    "entities": [
      {
        "text": "十三年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "兄子尋玄鄉",
        "label": "LOC",
        "start": 12,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000027",
    "sentence": "十五年，定封宏壽張侯。",
    "entities": [
      {
        "text": "十五年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000028",
    "sentence": "十八年，帝南祠章陵，過湖陽，祠重墓，追爵謚為壽張敬侯，立廟於湖陽，車駕每南巡，常幸其墓，賞賜大會。",
    "entities": [
      {
        "text": "十八年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000029",
    "sentence": "宏為人謙柔畏慎，不求茍進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000030",
    "sentence": "常戒其子曰：『富貴盈溢，未有能終者。吾非不喜榮勢也，天道惡滿而好謙，前世貴戚皆明戒也。保身全己，豈不樂哉！』每當朝會，輒迎期先到，俯伏待事，時至乃起。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000031",
    "sentence": "帝聞之，常敕騶騎臨朝乃告，勿令豫到。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000032",
    "sentence": "宏所上便宜及言得失，輒手自書寫，毀削草本。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000033",
    "sentence": "公朝訪逮，不敢眾對。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000034",
    "sentence": "宗族染其化，未嘗犯法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000035",
    "sentence": "帝甚重之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000036",
    "sentence": "及病困，車駕臨視，留宿，問其所欲言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000037",
    "sentence": "宏頓首自陳：『無功享食大國，誠恐子孫不能保全厚恩，令臣魂神慚負黃泉，願還壽張，食小鄉亭。』帝悲傷其言，而竟不許。",
    "entities": [
      {
        "text": "食小鄉",
        "label": "LOC",
        "start": 39,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000038",
    "sentence": "二十七年，卒。",
    "entities": [
      {
        "text": "二十七年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000039",
    "sentence": "遺敕薄葬，一無所用，以為棺柩一臧，不宜復見，如有腐敗，傷孝子之心，使與夫人同墳異臧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000040",
    "sentence": "帝善其令，以書示百官，因曰：『今不順壽張侯意，無以彰其德。且吾萬歲之後，欲以為式。』賻錢千萬，布萬匹，謚為恭侯，贈以印綬，車駕親送葬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000041",
    "sentence": "子鯈嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000042",
    "sentence": "帝悼宏不已，復封少子茂為平望侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000043",
    "sentence": "樊氏侯者凡五國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000044",
    "sentence": "明年，賜鯈弟鮪及從昆弟七人合錢五千萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000045",
    "sentence": "子 鯈",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000046",
    "sentence": "鯈字長魚，謹約有父風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000047",
    "sentence": "事後母至孝，及母卒，哀思過禮，毀病不自支，世祖常遣中黃門朝暮送饘粥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000048",
    "sentence": "服闋，就侍中丁恭受《公羊嚴氏春秋》。",
    "entities": [
      {
        "text": "《公羊嚴氏春秋》",
        "label": "TITLE",
        "start": 9,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000049",
    "sentence": "建武中，禁網尚闊，諸王既長，各招引賓客，以鯈外戚，爭遣致之，而鯈清靜自保，無所交結。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000050",
    "sentence": "及沛王輔事發，貴戚子弟多見收捕，鯈以不豫得免。",
    "entities": [
      {
        "text": "沛",
        "label": "LOC",
        "start": 1,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000051",
    "sentence": "帝崩，鯈為復土校尉。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000052",
    "sentence": "永平元年 ，拜長水校尉，與公卿雜定郊祠禮儀，以讖記正《五經》異說。",
    "entities": [
      {
        "text": "永平元年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "《五經》",
        "label": "TITLE",
        "start": 26,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000053",
    "sentence": "北海周澤、瑯邪承宮並海內大儒，鯈皆以為師友而致之於朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000054",
    "sentence": "上言郡國舉孝廉，率取年少能報恩者，耆宿大賢多見廢棄，宜敕郡國簡用良俊。",
    "entities": [
      {
        "text": "上言郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "宜敕郡",
        "label": "LOC",
        "start": 26,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000055",
    "sentence": "又議刑辟宜須秋月，以順時氣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000056",
    "sentence": "顯宗並從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000057",
    "sentence": "二年，以壽張國益東平王，徙封鯈燕侯。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000058",
    "sentence": "其後廣陵王荊有罪，帝以至親悼傷之，詔鯈與羽林監南陽任隗雜理其獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000059",
    "sentence": "事竟，奏請誅荊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000060",
    "sentence": "引見宣明殿，帝怒曰：『諸卿以我弟故，欲誅之，即我子，卿等敢爾邪！』鯈仰而對曰：『天下高帝天下，非陛下之天下也。《春秋》之義。「君親無將，將而誅焉」。是以周公誅弟，季友鴆兄，經傳大之。臣等以荊屬託母弟，陛下留聖心，加惻隱，故敢請耳。如令陛下子，臣等專誅而已。』帝嘆息良久。",
    "entities": [
      {
        "text": "《春秋》",
        "label": "TITLE",
        "start": 55,
        "end": 59
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000061",
    "sentence": "鯈益以此知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000062",
    "sentence": "其後弟鮪為子賞求楚王英女敬鄉公主，鯈聞而止之，曰：『建武時，吾家並受榮寵，一宗五侯。時特進一言，女可以配王，男可以尚主，但以貴寵過盛，即為禍患，故不為也。且爾一子，奈何棄之於楚乎？』鮪不從。",
    "entities": [
      {
        "text": "求楚王英女敬鄉",
        "label": "LOC",
        "start": 7,
        "end": 14
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000063",
    "sentence": "十年，鯈卒，赗贈甚厚，謚曰哀侯。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000064",
    "sentence": "帝遣小黃門張音問所遺言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000065",
    "sentence": "先是河南縣亡失官錢，典負者坐死及罪徙者甚眾，遂委責於人，以償其耗。",
    "entities": [
      {
        "text": "先是河南縣",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000066",
    "sentence": "鄉部吏司因此為奸，鯈常疾之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000067",
    "sentence": "又野王歲獻甘醪、膏餳，每輒擾人，吏以為利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000068",
    "sentence": "鯈並欲奏罷之，疾病未及得上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000069",
    "sentence": "音歸，具以聞，帝覽之而悲嘆，敕二郡並令從之。",
    "entities": [
      {
        "text": "敕二郡",
        "label": "LOC",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000070",
    "sentence": "長子汜嗣，以次子郴、梵為郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000071",
    "sentence": "其後楚事發覺，帝追念鯈謹恪，又聞其止鮪婚事，故其諸子得不坐焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000072",
    "sentence": "梵字文高，為郎二十餘年，三署服其重懼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000073",
    "sentence": "悉推財物二千餘萬與孤兄子，官至大鴻臚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000074",
    "sentence": "汜卒，子時嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000075",
    "sentence": "時卒，子建嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000076",
    "sentence": "建卒，無子，國絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000077",
    "sentence": "永寧元年，鄧太后復封建弟盼。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000078",
    "sentence": "盼卒，子尚嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000079",
    "sentence": "初，鯈刪定《公羊嚴氏春秋》章句，世號『樊侯學』，教授門徒前後三千餘人。",
    "entities": [
      {
        "text": "《公羊嚴氏春秋》",
        "label": "TITLE",
        "start": 5,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000080",
    "sentence": "弟子潁川李脩、九江夏勤，皆為三公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000081",
    "sentence": "勤字伯宗，為京、宛二縣令，零陵太守，所在有理能稱。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000082",
    "sentence": "安帝時，位至司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000083",
    "sentence": "族曾孫 準",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000084",
    "sentence": "準字幼陵，宏之族曾孫也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000085",
    "sentence": "父瑞，好黃老言，清靜少欲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000086",
    "sentence": "準少勵志行，修儒術，以先父產業數百萬讓孤兄子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000087",
    "sentence": "永元十五年 ，和帝幸南陽，準為郡功曹，召見，帝器之，拜郎中，從車駕還宮，特補尚書郎。",
    "entities": [
      {
        "text": "十五年",
        "label": "TME",
        "start": 2,
        "end": 5
      },
      {
        "text": "準為郡",
        "label": "LOC",
        "start": 13,
        "end": 16
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 38,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000088",
    "sentence": "鄧太后臨朝，儒學陵替，準乃上疏曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000089",
    "sentence": "臣聞賈誼有言，『人君不可以不學』。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000090",
    "sentence": "故雖大舜聖德，孳孳為善；成王賢主，崇明師傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000091",
    "sentence": "及光武皇帝受命中興，群雄崩擾，旌旗亂野，東西誅戰，不遑啟處，然猶投戈講藝，息馬論道。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000092",
    "sentence": "至孝明皇帝，兼天地之姿，用日月之明，庶政萬機，無不簡心，而垂情古典，遊意經藝，每饗射禮畢，正坐自講，諸儒並聽，四方欣欣。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000093",
    "sentence": "雖闕里之化，矍相之事，誠不足言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000094",
    "sentence": "又多徵名儒，以充禮官，如沛國趙孝、瑯邪承宮等，或安車結駟，告歸鄉里；或豐衣博帶，從見宗廟。",
    "entities": [
      {
        "text": "沛",
        "label": "LOC",
        "start": 12,
        "end": 13
      },
      {
        "text": "告歸鄉",
        "label": "LOC",
        "start": 29,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000095",
    "sentence": "其餘以經術見優者，布在廊廟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000096",
    "sentence": "故朝多皤皤之良，華首之老。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000097",
    "sentence": "每宴會，則論難衎衎，共求政化。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000098",
    "sentence": "詳覽群言，響如振玉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000099",
    "sentence": "朝者進而思政，罷者退而備問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000100",
    "sentence": "小大隨化，雍雍可嘉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000101",
    "sentence": "期門羽林介胄之士，悉通《孝經》。",
    "entities": [
      {
        "text": "《孝經》",
        "label": "TITLE",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000102",
    "sentence": "博士議郎，一人開門，徒眾百數。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000103",
    "sentence": "化自聖躬，流及蠻荒，匈奴遣伊秩訾王大車且渠來入就學。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000104",
    "sentence": "八方肅清，上下無事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000105",
    "sentence": "是以議者每稱盛時，咸言永平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000106",
    "sentence": "今學者蓋少，遠方尤甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000107",
    "sentence": "博士倚席不講，儒者竟論浮麗，忘謇謇之忠，習諓々之辭。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000108",
    "sentence": "文吏則去法律而學詆欺，銳錐刀之鋒，斷刑辟之重，德陋俗薄，以致苛刻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000109",
    "sentence": "昔孝文竇後性好黃老，而清靜之化流景、武之間。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000110",
    "sentence": "臣愚以為宜下明詔，博求幽隱，發揚巖穴，寵進儒雅，有如孝、宮者，徵詣公車，以侯聖上講習之期。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000111",
    "sentence": "公卿各舉明經及舊儒子孫，進其爵位，使纘其業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000112",
    "sentence": "復召郡國書佐，使讀律令。",
    "entities": [
      {
        "text": "復召郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000113",
    "sentence": "如此，則廷頸者日有所見，傾耳者月有所聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000114",
    "sentence": "伏願陛下推述先帝進業之道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000115",
    "sentence": "太后深納其言，是後屢舉方正、敦樸、仁賢之士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000116",
    "sentence": "準再遷御史中丞。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000117",
    "sentence": "永初之初，連年水旱災異，郡國多被饑困，準上疏曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000118",
    "sentence": "臣聞傳曰：『饑而不損茲曰太，厥災水。』《春秋穀梁傳》曰：『五穀不登，謂之大侵。大侵之禮，百官備而不制，群神禱而不祠。』由是言之，調和陰陽，實在儉節。",
    "entities": [
      {
        "text": "《春秋穀梁傳》",
        "label": "TITLE",
        "start": 19,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000119",
    "sentence": "朝廷雖勞心元元，事從省約，而在職之吏，尚未奉承。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000120",
    "sentence": "夫建化致理，由近及遠，故《詩》曰『京師翼翼，四方是則』。",
    "entities": [
      {
        "text": "《詩》",
        "label": "TITLE",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000121",
    "sentence": "今可先令太官、尚方、考功、上林池籞諸官，實減無事之物，五府調省中都官吏京師作者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000122",
    "sentence": "如此，則化及四方，人勞省息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000123",
    "sentence": "伏見被災之郡，百姓雕殘，恐非賑給所能勝贍，雖有其名，終無其實。",
    "entities": [
      {
        "text": "伏見被災之郡",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000124",
    "sentence": "可依徵和元年故事，遣使持節慰安。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000125",
    "sentence": "尤困乏者，徙置荊、揚孰郡，既省轉運之費，且令百姓各安其所。",
    "entities": [
      {
        "text": "揚孰郡",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000126",
    "sentence": "今雖有西屯之役，宜先東州之急。",
    "entities": [
      {
        "text": "宜先東州",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000127",
    "sentence": "如遣使者與二千石隨事消息，悉留富人守其舊士，轉尤貧者過所衣食，誠父母之計也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000128",
    "sentence": "願以臣言下公卿平議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000129",
    "sentence": "太后從之，悉以公田賦與貧人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000130",
    "sentence": "即擢準與議郎呂倉並守光祿大夫，準使冀州，倉使兗州。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "準使冀州",
        "label": "LOC",
        "start": 15,
        "end": 19
      },
      {
        "text": "倉使兗州",
        "label": "LOC",
        "start": 20,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000131",
    "sentence": "準到部，開倉廩食，尉安生業，流人咸得蘇息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000132",
    "sentence": "還，拜巨鹿太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000133",
    "sentence": "時饑荒之餘，人庶流迸，家戶且盡，準課督農桑，廣施方略，期年間，穀粟豐賤數十倍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000134",
    "sentence": "而趙、魏之郊數為羌所抄暴，準外禦寇虜，內撫百姓，郡境以安。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000135",
    "sentence": "五年，轉河內太守。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000136",
    "sentence": "時羌復屢入郡界，準輒將兵討逐，修理塢壁，威名大行。",
    "entities": [
      {
        "text": "時羌復屢入郡",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000137",
    "sentence": "視事三年，以疾徵，三轉為尚書令，明習故事，遂見任用。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000138",
    "sentence": "元初三年，代周暢為光祿勛。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000139",
    "sentence": "五年，卒於官。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000140",
    "sentence": "陰識",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000141",
    "sentence": "陰識字次伯，南陽新野人也，光烈皇后之前母兄也。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000142",
    "sentence": "其先出自管仲，管仲七世孫修，自齊適楚，為陰大夫，因而氏焉。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000143",
    "sentence": "秦、漢之際，始家新野。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000144",
    "sentence": "及劉伯升起義兵，識時遊學長安，聞之，委業而歸，率子弟、宗族、賓客千餘人往詣伯升。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000145",
    "sentence": "伯升乃以識為校尉。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000146",
    "sentence": "更始元年 ，遷偏將軍，從攻宛，別降新野、淯陽、杜衍、冠軍、湖陽。",
    "entities": [
      {
        "text": "更始元年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000147",
    "sentence": "二年，更始封識陰德侯，行大將軍事。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000148",
    "sentence": "建武元年 ，光武遣使迎陰貴人於新野，並徵識。",
    "entities": [
      {
        "text": "建武元年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000149",
    "sentence": "識隨貴人至，以為騎都尉，更封陰鄉侯。",
    "entities": [
      {
        "text": "更封陰鄉",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000150",
    "sentence": "二年，以征伐軍功增封，識叩頭讓曰：『天下初定，將帥有功者眾，臣托屬掖廷，仍加爵邑，不可以示天下。』帝甚美之，以為關都尉，鎮函谷。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "仍加爵邑",
        "label": "LOC",
        "start": 36,
        "end": 40
      },
      {
        "text": "以為關",
        "label": "LOC",
        "start": 54,
        "end": 57
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000151",
    "sentence": "遷侍中，以母憂辭歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000152",
    "sentence": "十五年，定封原鹿侯。",
    "entities": [
      {
        "text": "十五年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000153",
    "sentence": "及顯宗立為皇太子，以識守執金吾，輔導東宮。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000154",
    "sentence": "帝每巡郡國，識常留鎮守京師，委以禁兵。",
    "entities": [
      {
        "text": "帝每巡郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "識常留鎮",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_032_000155",
    "sentence": "入雖極言正議，及與賓客語，未嘗及國事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000156",
    "sentence": "帝敬重之，常指識以敕戒貴戚，激厲左右焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_032_000157",
    "sentence": "識所用掾史皆簡賢者，如虞廷、傅寬、薛愔等，多至公卿校尉。",
    "entities": [
      {
        "text": "校尉",
