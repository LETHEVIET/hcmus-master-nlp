        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000199",
    "sentence": "子阜嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000200",
    "sentence": "植後為輔威將軍，封威邑侯。",
