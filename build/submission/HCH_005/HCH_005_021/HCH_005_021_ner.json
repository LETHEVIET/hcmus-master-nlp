[
  {
    "sentence_id": "HCH_005_021_000001",
    "sentence": "任光",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000002",
    "sentence": "任光字伯卿，南陽宛人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000003",
    "sentence": "少忠厚，為鄉裏所愛。",
    "entities": [
      {
        "text": "為鄉",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000004",
    "sentence": "初為鄉嗇夫、郡縣吏。",
    "entities": [
      {
        "text": "初為鄉",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "郡縣",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000005",
    "sentence": "漢兵至宛，軍人見光冠服鮮明，令解衣，將殺而奪之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000006",
    "sentence": "會光祿勛劉賜適至，視光容貌長者，乃救全之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000007",
    "sentence": "光因率黨與從賜，為安集掾，拜偏將軍，與世祖破王尋、王邑。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "王邑",
        "label": "LOC",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000008",
    "sentence": "更始至洛陽，以光為信都太守。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000009",
    "sentence": "及王郎起，郡國皆降之，光獨不肯，遂與都尉李忠、令萬脩、功曹阮況、五官掾郭唐等同心固守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000010",
    "sentence": "廷掾持王郎檄詣府白光，光斬之於市，以徇百姓，發精兵四千人城守。",
    "entities": [
      {
        "text": "發精兵四千人城",
        "label": "LOC",
        "start": 22,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000011",
    "sentence": "更始二年春，世祖自薊還，狼狽不知所向，傳聞信都獨為漢拒邯鄲，即馳赴之。",
    "entities": [
      {
        "text": "更始二年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000012",
    "sentence": "光等孤城獨守，恐不能全，聞世祖至，大喜，吏民皆稱萬歲，即時開門，與李忠、萬脩率官屬迎謁。",
    "entities": [
      {
        "text": "光等孤城",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000013",
    "sentence": "世祖入傳舍，謂光曰：『伯卿，今勢力虛弱，欲俱入城頭子路、力子都兵中，何如邪？』光曰：『不可。』世祖曰：『卿兵少，如何？』光曰：『可募發奔命，出攻傍縣，若不降者，恣聽掠之。人貪財物，則兵可招而致也。』世祖從之。",
    "entities": [
      {
        "text": "欲俱入城",
        "label": "LOC",
        "start": 20,
        "end": 24
      },
      {
        "text": "出攻傍縣",
        "label": "LOC",
        "start": 70,
        "end": 74
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000014",
    "sentence": "拜光為左大將軍，封武成侯，留南陽宗廣領信都太守事，使光將兵從。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 4,
        "end": 7
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000015",
    "sentence": "光乃多作檄文曰：『大司馬劉公將城頭子路、力子都兵百萬眾從東方來，擊諸反虜。』遣騎馳至巨鹿界中。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000016",
    "sentence": "吏民得檄，傳相告語。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000017",
    "sentence": "世祖遂與光等投暮入堂陽界，使騎各持炬火，彌滿澤中，光炎燭天地，舉城莫不震驚惶怖，其夜即降。",
    "entities": [
      {
        "text": "舉城",
        "label": "LOC",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000018",
    "sentence": "旬日之間，兵眾大盛，因攻城邑，遂屠邯鄲，乃遣光歸郡。",
    "entities": [
      {
        "text": "因攻城邑",
        "label": "LOC",
        "start": 10,
        "end": 14
      },
      {
        "text": "乃遣光歸郡",
        "label": "LOC",
        "start": 20,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000019",
    "sentence": "城頭子路者，東平人，姓爰，名曾，字子路，與肥城劉詡起兵盧城頭，故號其兵為『城頭子路』。",
    "entities": [
      {
        "text": "與肥城",
        "label": "LOC",
        "start": 20,
        "end": 23
      },
      {
        "text": "劉詡起兵盧城",
        "label": "LOC",
        "start": 23,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000020",
    "sentence": "曾自稱『都從事』，詡稱『校三老』，寇掠河、濟間，眾至二十餘萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000021",
    "sentence": "更始立，曾遣使降，拜曾東萊郡太守，詡濟南太守，皆行大將軍事。",
    "entities": [
      {
        "text": "拜曾東萊郡",
        "label": "LOC",
        "start": 9,
        "end": 14
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 20,
        "end": 22
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000022",
    "sentence": "是歲，曾為其將所殺，眾推詡為主，更始封詡助國侯，令罷兵歸本郡。",
    "entities": [
      {
        "text": "令罷兵歸本郡",
        "label": "LOC",
        "start": 24,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000023",
    "sentence": "力子都者，東海人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000024",
    "sentence": "起兵鄉裏，抄擊徐、兗界，眾有六七萬。",
    "entities": [
      {
        "text": "起兵鄉",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000025",
    "sentence": "更始立，遣使降，拜子都徐州牧。",
    "entities": [
      {
        "text": "拜子都徐州",
        "label": "LOC",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000026",
    "sentence": "為其部曲所殺，餘黨復相聚，與諸賊會於檀鄉，因號為檀鄉。",
    "entities": [
      {
        "text": "與諸賊會於檀鄉",
        "label": "LOC",
        "start": 13,
        "end": 20
      },
      {
        "text": "因號為檀鄉",
        "label": "LOC",
        "start": 21,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000027",
    "sentence": "檀鄉渠帥董次仲始起茌平，遂渡河入魏郡清河，與五校合，眾十餘萬。",
    "entities": [
      {
        "text": "檀鄉",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000028",
    "sentence": "建武元年 ，世祖入洛陽，遣大司馬吳漢等擊檀鄉，明年春，大破降之。",
    "entities": [
      {
        "text": "建武元年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 9,
        "end": 11
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000029",
    "sentence": "是歲，更封光阿陵侯，食邑萬戶。",
    "entities": [
      {
        "text": "食邑",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000030",
    "sentence": "五年，征詣京師，奉朝請。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000031",
    "sentence": "其冬卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000032",
    "sentence": "子隗嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000033",
    "sentence": "後阮況為南陽太守，郭唐至河南尹，皆有能名。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000034",
    "sentence": "隗字仲和，少好黃、老，清靜寡欲，所得奉秩，常以賑恤宗族，收養孤寡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000035",
    "sentence": "顯宗聞之，擢奉朝請，遷羽林左監、虎賁中郎將，又遷長水校尉。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 18,
        "end": 21
      },
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000036",
    "sentence": "肅宗即位，雅相敬愛，數稱其行，以為將作大匠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000037",
    "sentence": "將作大匠自建武以來常謁者兼之，至隗乃置真焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000038",
    "sentence": "建初五年，遷太仆，八年，代竇固為光祿勛，所歷皆有稱。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "八年",
        "label": "TME",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000039",
    "sentence": "章和元年，拜司空。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000040",
    "sentence": "隗義行內修，不求名譽，而以沈正見重於世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000041",
    "sentence": "和帝即位，大將軍竇憲秉權，專作威福，內外朝臣莫不震懾。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000042",
    "sentence": "時，憲擊匈奴，國用勞費，隗奏議征憲還，前後十上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000043",
    "sentence": "獨與司徒袁安同心畢力，持重處正，鯁言直議，無所回隱，語在《袁安傳》。",
    "entities": [
      {
        "text": "《袁安傳》",
        "label": "TITLE",
        "start": 28,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000044",
    "sentence": "永元四年 薨，子屯嗣。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000045",
    "sentence": "帝追思隗忠，擢屯為步兵校尉，徙封西陽侯。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000046",
    "sentence": "屯卒，子勝嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000047",
    "sentence": "勝卒，子世嗣，徙封北鄉侯。",
    "entities": [
      {
        "text": "徙封北鄉",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000048",
    "sentence": "李忠",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000049",
    "sentence": "李忠字仲都，東萊黃人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000050",
    "sentence": "父為高密都尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000051",
    "sentence": "忠元始中以父任為郎，署中數十人，而忠獨以好禮修整稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000052",
    "sentence": "王莽時為新博屬長，郡中鹹敬信之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000053",
    "sentence": "更始立，使使者行郡國，即拜忠都尉官。",
    "entities": [
      {
        "text": "使使者行郡",
        "label": "LOC",
        "start": 4,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000054",
    "sentence": "忠遂與任光同奉世祖，以為右大將軍，封武固侯。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000055",
    "sentence": "時，世祖自解所佩綬以帶忠，因從攻下屬縣。",
    "entities": [
      {
        "text": "因從攻下屬縣",
        "label": "LOC",
        "start": 13,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000056",
    "sentence": "至苦陘，世祖會諸將，問所得財物，唯忠獨無所掠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000057",
    "sentence": "世祖曰：『我欲特賜，李忠，諸卿得無望乎？』即以所乘大驪馬及繡被衣物賜之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000058",
    "sentence": "進圍巨鹿，未下，王郎遣將攻信都，信都大姓馬寵等開城內之，收太守宗廣及忠母、妻，而令親屬招呼忠。",
    "entities": [
      {
        "text": "大姓馬寵等開城",
        "label": "LOC",
        "start": 18,
        "end": 25
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000059",
    "sentence": "時，寵弟從忠為校尉，忠即時召見，責數以背恩反城，因格殺之。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "責數以背恩反城",
        "label": "LOC",
        "start": 16,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000060",
    "sentence": "諸將皆驚曰：『家屬在人手中，殺其弟，何猛也！』忠曰：『若縱賊不誅，則二心也。』世祖聞而美之，謂忠曰：『今吾兵已成矣，將軍可歸救老母、妻、子，宜自募吏民能得家屬者，賜錢千萬，來從我取。』忠曰：『蒙明公大恩，思得效命，誠不敢內顧宗親。』世祖乃使任光將兵救信都，光兵於道散降王郎，無功而還。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 58,
        "end": 60
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000061",
    "sentence": "會更始遣將攻破信都，忠家屬得全。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000062",
    "sentence": "世祖因使忠還，行太守事，收郡中大姓附邯鄲者，誅殺數百人。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "收郡",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000063",
    "sentence": "及任光歸郡，忠乃還復為都尉。",
    "entities": [
      {
        "text": "及任光歸郡",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000064",
    "sentence": "建武二年 ，更封中水侯，食邑三千戶。",
    "entities": [
      {
        "text": "建武二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "食邑",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000065",
    "sentence": "其年，征拜五官中郎將，從平寵萌，董憲等。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000066",
    "sentence": "六年，遷丹陽太守。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000067",
    "sentence": "是時，海內新定，南方海濱江淮，多擁兵據土。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000068",
    "sentence": "忠到郡，招懷降附，其不服者悉誅之，旬月皆平。",
    "entities": [
      {
        "text": "忠到郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000069",
    "sentence": "忠以丹陽越俗不好學，嫁娶禮儀，衰於中國，乃為起學校，習禮容，春秋鄉飲，選用明經，郡中向慕之。",
    "entities": [
      {
        "text": "春秋鄉",
        "label": "LOC",
        "start": 30,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000070",
    "sentence": "墾田增多，三歲間流民占著者五萬餘口。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000071",
    "sentence": "十四年，三公奏課為天下第一，遷豫章太守。",
    "entities": [
      {
        "text": "十四年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000072",
    "sentence": "病去官，征詣京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000073",
    "sentence": "十九年，卒。",
    "entities": [
      {
        "text": "十九年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000074",
    "sentence": "子威嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000075",
    "sentence": "威卒，子純嗣， 永平九年 ，坐母殺純叔父。",
    "entities": [
      {
        "text": "永平九年",
        "label": "TME",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000076",
    "sentence": "國除。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000077",
    "sentence": "永初七年 ，鄧太后復封純琴亭侯。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000078",
    "sentence": "純卒，子廣嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000079",
    "sentence": "萬脩",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000080",
    "sentence": "萬脩字君遊，扶風茂陵人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000081",
    "sentence": "更始時，為信都令，與太守任光、都尉李忠共城守，迎世祖，拜為偏將軍，封造義侯。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "都尉李忠共城",
        "label": "LOC",
        "start": 15,
        "end": 21
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000082",
    "sentence": "及破邯鄲，拜右將軍，從平河北。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000083",
    "sentence": "建武二年 ，更封槐裏侯。",
    "entities": [
      {
        "text": "建武二年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000084",
    "sentence": "與揚化將軍堅鐔俱擊南陽，未克而病，卒於軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000085",
    "sentence": "子普嗣，徙封泫氏侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000086",
    "sentence": "普卒，子親嗣，徙封扶柳侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000087",
    "sentence": "親卒，無子，國除。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000088",
    "sentence": "永初七年 ，鄧太后紹封脩曾孫豐為曲平亭侯。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000089",
    "sentence": "豐卒，子熾嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000090",
    "sentence": "永建元年 }，熾卒，無子，國除。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000091",
    "sentence": "延熹二年 ，桓帝紹封脩玄孫恭為門德亭侯。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000092",
    "sentence": "邳彤",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000093",
    "sentence": "邳彤字偉君，信都人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000094",
    "sentence": "父吉，為遼西太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000095",
    "sentence": "彤初為王莽和成卒正。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000096",
    "sentence": "世祖徇河北，至下曲陽，彤舉城降，復以為太守，留止數日。",
    "entities": [
      {
        "text": "彤舉城",
        "label": "LOC",
        "start": 11,
        "end": 14
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000097",
    "sentence": "世祖北至薊，會王郎兵起，使其將徇地，所到縣莫不奉迎，唯和成、信都堅守不下。",
    "entities": [
      {
        "text": "所到縣",
        "label": "LOC",
        "start": 18,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000098",
    "sentence": "彤聞世祖從薊還，失軍，欲至信都，乃先使五官掾張萬、督郵尹綏，選精騎二千餘匹，緣路迎世祖軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000099",
    "sentence": "彤尋與世祖會信都。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000100",
    "sentence": "世祖雖得二郡之助，而兵眾未合，議者多言可因信都兵自送，西還長安。",
    "entities": [
      {
        "text": "世祖雖得二郡",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000101",
    "sentence": "彤廷對曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000102",
    "sentence": "議者之言皆非也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000103",
    "sentence": "吏民歌吟思漢久矣，故更始舉尊號而天下響應，三輔清宮除道以迎之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000104",
    "sentence": "一夫荷戟大呼，則千里之將無不捐城遁逃，虜伏請降。",
    "entities": [
      {
        "text": "里之將無不捐城",
        "label": "LOC",
        "start": 9,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000105",
    "sentence": "自上古以來，亦未有感物動民其如此者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000106",
    "sentence": "又卜者王郎，假名因勢，驅集烏合之眾，遂震燕、趙之地；況明公奮二郡之兵，揚響應之威，以攻則何城不克，以戰則何軍不服！",
    "entities": [
      {
        "text": "況明公奮二郡",
        "label": "LOC",
        "start": 26,
        "end": 32
      },
      {
        "text": "以攻則何城",
        "label": "LOC",
        "start": 41,
        "end": 46
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000107",
    "sentence": "今釋此而歸，豈徒空失河北，必要驚動三輔，墮損威重，非計之得者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000108",
    "sentence": "若明公無復征伐之意，則雖信都之兵猶難會也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000109",
    "sentence": "何者？",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000110",
    "sentence": "明公既西，則邯鄲城民不肯捐父母、背城主，而千里送公，其離散亡逃可必也。",
    "entities": [
      {
        "text": "則邯鄲城",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "背城",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000111",
    "sentence": "世祖善其言而止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000112",
    "sentence": "即日拜彤為後大將軍，和成太守如故，使將兵居前。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 6,
        "end": 9
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000113",
    "sentence": "比至堂陽，堂陽已反屬王郎，彤使張萬、尹綏先曉譬吏民，世祖夜至，即開門出迎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000114",
    "sentence": "引兵擊破白奢賊於中山。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000115",
    "sentence": "自此常從戰攻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000116",
    "sentence": "信都復反為王郎，郎所置信都王捕系彤父弟及妻子，使為手書呼彤曰：『降者封爵，不降族滅。』彤涕泣報曰：『事君者不得顧家。彤親屬所以至今得安於信都者，劉公之恩也。公方爭國事，彤不得復念私也。』會更始所遣將攻拔信都，郎兵敗走，彤家屬得免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000117",
    "sentence": "及拔邯鄲，封武義侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000118",
    "sentence": "建武元年 ，更封靈壽侯，行大司空事。",
    "entities": [
      {
        "text": "建武元年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000119",
    "sentence": "帝入洛陽，拜彤太常，月餘日轉少府，是年免。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000120",
    "sentence": "復為左曹侍中，常從征伐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000121",
    "sentence": "六年，就國。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000122",
    "sentence": "彤卒，子湯嗣，九年，徙封樂陵侯。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000123",
    "sentence": "十九年，湯卒，子某嗣；無子，國除。",
    "entities": [
      {
        "text": "十九年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000124",
    "sentence": "元初元年，鄧太后紹封彤孫音為平亭侯。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000125",
    "sentence": "音卒、子柴嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000126",
    "sentence": "初，張萬，尹綏與彤俱迎世祖，皆拜偏將軍，亦從征伐。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000127",
    "sentence": "萬封重平侯，綏封平臺侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000128",
    "sentence": "論曰：凡言成事者，以功著易顯；謀幾初者，以理隱難昭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000129",
    "sentence": "斯固原情比跡，所宜推察者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000130",
    "sentence": "若乃議者欲因二郡之眾，建入關之策，委成業，臨不測，而世主未悟，謀夫景同，邳彤之廷對，其為幾乎！",
    "entities": [
      {
        "text": "乃議者欲因二郡",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "建入關",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000131",
    "sentence": "語曰『一言可以興邦』，斯近之矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000132",
    "sentence": "劉植",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000133",
    "sentence": "劉植字伯先，巨鹿昌城人也。",
    "entities": [
      {
        "text": "巨鹿昌城",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000134",
    "sentence": "王郎起，植與弟喜、從兄歆率宗族賓客，聚兵數千人據昌城。",
    "entities": [
      {
        "text": "兵數千人據昌城",
        "label": "LOC",
        "start": 19,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000135",
    "sentence": "聞世祖從薊還，乃開門迎世祖，以植為驍騎將軍，喜、歆偏將軍，皆為列侯。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 19,
        "end": 21
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000136",
    "sentence": "時真定王劉揚起兵以附王郎，眾十餘萬，世祖遣植說揚，揚乃降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000137",
    "sentence": "世祖因留真定，納郭后，後即揚之甥也，故以此結之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000138",
    "sentence": "乃與揚及諸將置酒郭氏漆裏舍，揚擊築為歡，因得進兵拔邯鄲，從平河北。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000139",
    "sentence": "建武二年 ，更封植為昌城侯。",
    "entities": [
      {
        "text": "建武二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "更封植為昌城",
        "label": "LOC",
        "start": 6,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000140",
    "sentence": "討密縣賊，戰歿。",
    "entities": [
      {
        "text": "討密縣",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000141",
    "sentence": "子向嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000142",
    "sentence": "帝使喜代將植營，復為驍騎將軍，封觀津侯。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000143",
    "sentence": "喜卒，復以歆為驍騎將軍，封浮陽侯。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000144",
    "sentence": "喜、歆從征伐，皆傳國於後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000145",
    "sentence": "向徙封東武陽侯，卒，子述嗣， 永平十五年 ，坐與楚王英謀反，國除。",
    "entities": [
      {
        "text": "永平十五年",
        "label": "TME",
        "start": 15,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000146",
    "sentence": "耿純",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000147",
    "sentence": "耿純字伯山，巨鹿宋子人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000148",
    "sentence": "父艾，為王莽濟平尹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000149",
    "sentence": "純學於長安，因除為納言士。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000150",
    "sentence": "王莽敗，更始立，使舞陰王李軼降諸郡國，純父艾降，還為濟南太守。",
    "entities": [
      {
        "text": "陰王李軼降諸郡",
        "label": "LOC",
        "start": 10,
        "end": 17
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000151",
    "sentence": "時李軼兄弟用事，專制方面，賓客遊說者甚眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000152",
    "sentence": "純連求謁不得通，久之乃得見，因說軼曰：『大王以龍虎之姿，遭風雲之時，奮迅拔起，期月之間兄弟稱王，而德信不聞於士民，功勞未施於百姓，寵祿暴興，此智者之所忌也。兢兢自危，猶懼不終，而況沛然自足，可以成功者乎？』軼奇之，且以其巨鹿大姓，乃承制拜為騎都尉，授以節，令安集趙、魏。",
    "entities": [
      {
        "text": "沛",
        "label": "LOC",
        "start": 90,
        "end": 91
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000153",
    "sentence": "會世祖度河至邯鄲，純即謁見，世祖深接之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000154",
    "sentence": "純退，見官屬將兵法度不與它將同，遂求自結納，獻馬及縑帛數百匹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000155",
    "sentence": "世祖北至中山，留純邯鄲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000156",
    "sentence": "會王郎反，世祖自薊東南馳，純與從昆弟訢、宿、植共率宗族賓客二千餘人，老病者皆載木自隨，奉迎於育。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000157",
    "sentence": "拜純為前將軍，封耿鄉侯，訢、宿、植皆偏將軍，使與純居前，降宋子，從攻下曲陽及中山。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "封耿鄉",
        "label": "LOC",
        "start": 7,
        "end": 10
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000158",
    "sentence": "是時，郡國多降邯鄲者，純恐宗家懷異心，乃使訢、宿歸燒其廬舍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000159",
    "sentence": "世祖問純故，對曰：『竊見明公單車臨河北，非有府臧之蓄，重賞甘餌，可以聚人者也，徒以恩德懷之，是故士眾樂附。今邯鄲自立，北州疑惑，純雖舉族歸命，老弱在行，猶恐宗人賓客半有不同心者，故燔燒屋室，絕其反顧之望。』世祖漢息。",
    "entities": [
      {
        "text": "北州",
        "label": "LOC",
        "start": 59,
        "end": 61
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000160",
    "sentence": "及至鄗，世祖止傳舍，鄗大姓蘇公反城開門內王郎將李惲。",
    "entities": [
      {
        "text": "鄗大姓蘇公反城",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000161",
    "sentence": "純先覺知，將兵逆與惲戰，大破斬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000162",
    "sentence": "從平邯鄲，又破銅馬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000163",
    "sentence": "時，赤眉、青犢、上江、大彤、鐵脛、五幡十餘萬眾並在射犬，世祖引兵將擊之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000164",
    "sentence": "純軍在前，去眾營數裏，賊忽夜攻純，雨射營中，士多死傷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000165",
    "sentence": "純勒部曲，堅守不動。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000166",
    "sentence": "選敢死二千人，俱持強弩，各傅三矢，使銜枚間行，繞出賊後，齊聲呼噪，強弩並發，賊眾驚走，追擊，遂破之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000167",
    "sentence": "馳騎白世祖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000168",
    "sentence": "世祖明旦與諸將俱至營，勞純曰：『昨夜困乎？』純曰：『賴明公威德，幸而獲全。』世祖曰：『大兵不可夜動，故不相救耳。軍營進退無常，卿宗族不可悉居軍中。』乃以純族人耿伋為蒲吾長，悉令將親屬居焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000169",
    "sentence": "世祖即位，封純高陽侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000170",
    "sentence": "擊劉永於濟陰，下定陶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000171",
    "sentence": "初，純從攻王郎，墮馬折肩，時疾發，乃還詣懷宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000172",
    "sentence": "帝問：『卿兄弟誰可使者？』純舉從弟植，於是使植將純營，純猶以前將軍從。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000173",
    "sentence": "時真定王劉揚復造作讖記雲：『赤九之後，癭揚為主。』揚病癭，欲以惑眾，與綿曼賊交通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000174",
    "sentence": "建武二年春，遣騎都尉陳副、遊擊將軍鄧隆征揚，揚閉城門，不內副等。",
    "entities": [
      {
        "text": "建武二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "揚閉城",
        "label": "LOC",
        "start": 22,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000175",
    "sentence": "乃復遣純持節，行赦令於幽、冀，所過並使勞慰王侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000176",
    "sentence": "密敕純曰：『劉揚若見，因而收之。』純從吏士百餘騎與副、隆會元氏，俱至真定，止傳舍。",
    "entities": [
      {
        "text": "元氏",
        "label": "ORG",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000177",
    "sentence": "揚稱病不謁，以純真定宗室之出，遣使與純書，欲相見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000178",
    "sentence": "純報曰：『奉使見王侯牧守，不得先詣，如欲面會，宜出傳舍。』時，揚弟臨邑侯讓及從兄細各擁兵萬餘人，揚自恃眾強而純意安靜，即從官屬詣之，兄弟並將輕兵在門外。",
    "entities": [
      {
        "text": "揚弟臨邑",
        "label": "LOC",
        "start": 31,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000179",
    "sentence": "揚入見純，純接以禮敬，因延請其兄弟，皆入，乃閉閤悉誅之，因勒兵而出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000180",
    "sentence": "真定震怖，無敢動者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000181",
    "sentence": "帝憐揚、讓謀未發，並封其子，復故國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_005_021_000182",
    "sentence": "純還京師，因自請曰：『臣本吏家子孫，幸遭大漢復興，聖帝受命，備位列將，爵為通侯。天下略定，臣無所用誌，願試治一郡，盡力自效。』帝笑曰：『卿既治武，復欲修文邪？』乃拜純為東郡太守。",
    "entities": [
      {
        "text": "願試治一郡",
        "label": "LOC",
        "start": 51,
        "end": 56
      },
      {
        "text": "乃拜純為東郡",
        "label": "LOC",
        "start": 80,
        "end": 86
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 86,
        "end": 88
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000183",
    "sentence": "時，東郡未平，純視事數月，盜賊清寧。",
    "entities": [
      {
        "text": "東郡",
        "label": "LOC",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_005_021_000184",
    "sentence": "四年，詔純將兵擊更始東平太守範荊，荊降。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "太守",
