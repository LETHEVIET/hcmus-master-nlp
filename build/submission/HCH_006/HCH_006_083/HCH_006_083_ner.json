        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000110",
    "sentence": "吏民大驚，不意博應事變乃至於此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000111",
    "sentence": "後博徐問，果老從事教民聚會。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000112",
    "sentence": "博殺此吏，州郡畏博威嚴。",
    "entities": [
      {
        "text": "州郡",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000113",
    "sentence": "徙為并州刺史，護漕都尉，遷琅邪太守。",
    "entities": [
      {
        "text": "徙為并州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000114",
    "sentence": "齊郡舒緩養名，博新視事，右曹掾史皆移病臥。",
    "entities": [
      {
        "text": "齊郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000115",
    "sentence": "博問其故，對言「惶恐！故事二千石新到，輒遣吏存問致意，乃敢起就職。」博奮髯抵几曰：「觀齊兒欲以此為俗邪！」乃召見諸曹史書佐及縣大吏，選視其可用者，出教置之。",
    "entities": [
      {
        "text": "諸曹史書佐及縣",
        "label": "LOC",
        "start": 56,
        "end": 63
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000116",
    "sentence": "皆斥罷諸病吏，白巾走出府門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000117",
    "sentence": "郡中大驚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000118",
    "sentence": "頃之，門下掾贛遂耆老大儒，教授數百人，拜起舒遲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000119",
    "sentence": "博出教主簿：「贛老生不習吏禮，主簿且教拜起，閑習乃止。」又敕功曹：「官屬多褒衣大袑，不中節度，自今掾史衣皆令去地三寸。」博尤不愛諸生，所至郡輒罷去議曹，曰：「豈可復置謀曹邪！」文學儒吏時有奏記稱說云云，博見謂曰：「如太守漢吏，奉三尺律令以從事耳，亡奈生所言聖人道何也！且持此道歸，堯舜君出，為陳說之。」其折逆人如此。",
    "entities": [
      {
        "text": "所至郡",
        "label": "LOC",
        "start": 67,
        "end": 70
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 108,
        "end": 110
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000120",
    "sentence": "視事數年，大改其俗，掾史禮節如楚、趙吏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000121",
    "sentence": "博治郡，常令屬縣各用其豪桀以為大吏，文武從宜。",
    "entities": [
      {
        "text": "博治郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "常令屬縣",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000122",
    "sentence": "縣有劇賊及它非常，博輒移書以詭責之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000123",
    "sentence": "其盡力有效，必加厚賞；懷詐不稱，誅罰輒行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000124",
    "sentence": "以是豪強慹服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000125",
    "sentence": "姑幕縣有群輩八人報仇廷中，皆不得。",
    "entities": [
      {
        "text": "姑幕縣",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000126",
    "sentence": "長吏自繫書言府，賊曹掾史自白請至姑幕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000127",
    "sentence": "事留不出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000128",
    "sentence": "功曹諸掾即皆自白，復不出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000129",
    "sentence": "於是府丞詣閤，博乃見丞掾曰：「以為縣自有長吏，府未嘗與也，丞掾謂府當與之邪？」閤下書佐入，博口占檄文曰：「府告姑幕令丞：言賊發不得，有書。檄到，令丞就職，游徼王卿力有餘，如律令！」王卿得敕惶怖，親屬失色，晝夜馳騖，十餘日間捕得五人。",
    "entities": [
      {
        "text": "以為縣",
        "label": "LOC",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000130",
    "sentence": "博復移書曰：「王卿憂公甚效！檄到，齎伐閱詣府。部掾以下亦可用，漸盡其餘矣。」其操持下，皆此類也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000131",
    "sentence": "以高弟入守左馮翊，滿歲為真。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000132",
    "sentence": "其治左馮翊，文理聰明殊不及薛宣，而多武譎，網絡張設，少愛利，敢誅殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000133",
    "sentence": "然亦縱舍，時有大貸，下吏以此為盡力。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000134",
    "sentence": "長陵大姓尚方禁少時嘗盜人妻，見斫，創著其頰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000135",
    "sentence": "府功曹受賂，白除禁調守尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000136",
    "sentence": "博聞知，以它事召見，視其面，果有瘢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000137",
    "sentence": "博辟左右問禁：「是何等創也？」禁自知情得，叩頭服狀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000138",
    "sentence": "博笑曰：「大丈夫固時有是。馮翊欲洒卿恥，抆拭用禁，能自效不？」禁且喜且懼，對曰：「必死！」博因敕禁：「毋得泄語，有便宜，輒記言。」因親信之以為耳目。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000139",
    "sentence": "禁晨夜發起部中盜賊及它伏姦，有功效。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000140",
    "sentence": "博擢禁連守縣令。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000141",
    "sentence": "久之，召見功曹，閉閤數責以禁等事，與筆札便自記，「積受取一錢以上，無得有所匿。欺謾半言，斷頭矣！」功曹惶怖，具自疏姦臧，大小不敢隱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000142",
    "sentence": "博知其對以實，乃令就席，受敕自改而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000143",
    "sentence": "投刀使削所記，遣出就職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000144",
    "sentence": "功曹後常戰栗，不敢蹉跌，博遂成就之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000145",
    "sentence": "遷為大司農。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000146",
    "sentence": "歲餘，坐小法，左遷犍為太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000147",
    "sentence": "先是南蠻若兒數為寇盜，博厚結其昆弟，使為反間，襲殺之，郡中清。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000148",
    "sentence": "徙為山陽太守，病免官。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000149",
    "sentence": "復徵為光祿大夫，遷廷尉，職典決疑，當讞平天下獄。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000150",
    "sentence": "博恐為官屬所誣，視事，召見正監典法掾史，謂曰：「廷尉本起於武吏，不通法律，幸有眾賢，亦何憂！然廷尉治郡斷獄以來且二十年，亦獨耳剽日久，三尺律令，人事出其中。掾史試與正監共撰前世決事吏議難知者數十事，持以問廷尉，得諸君覆意之。」正監以為博苟強，意未必能然，即共條白焉。",
    "entities": [
      {
        "text": "然廷尉治郡",
        "label": "LOC",
        "start": 46,
        "end": 51
      },
      {
        "text": "二十年",
        "label": "TME",
        "start": 56,
        "end": 59
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000151",
    "sentence": "博皆召掾史，並坐而問，為平處其輕重，十中八九。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000152",
    "sentence": "官屬咸服博之疏略，材過人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000153",
    "sentence": "每遷徙易官，所到輒出奇譎如此，以明示下為不可欺者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000154",
    "sentence": "久之，遷後將軍，與紅陽侯立相善。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000155",
    "sentence": "立有罪就國，有司奏立黨友，博坐免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_083_000156",
    "sentence": "後歲餘，哀帝即位，以博名臣，召見，起家復為光祿大夫，遷為京兆尹，數月超為大司空。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000157",
    "sentence": "初，漢興襲秦官，置丞相、御史大夫、太尉。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000158",
    "sentence": "至武帝罷太尉，始置大司馬以冠將軍之號，非有印綬官屬也。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000159",
    "sentence": "及成帝時，何武為九卿，建言「古者民樸事約，國之輔佐必得賢聖，然猶則天三光，備三公官，各有分職。今末俗文弊，政事煩多，宰相之材不能及古，而丞相獨兼三公之事，所以久廢而不治也。宜建三公官，定卿大夫之任，分職授政，以考功效。」其後上以問師安昌侯張禹，禹以為然。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 68,
        "end": 70
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 94,
        "end": 96
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000160",
    "sentence": "時曲陽侯王根為大司馬票騎將軍，而何武為御史大夫。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 19,
        "end": 21
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_006_083_000161",
    "sentence": "於是上賜曲陽侯根大司馬印綬，置官屬，罷票騎將軍官，以御史大夫何武為大司空，封列侯，皆增奉如丞相，以備三公官焉。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 21,
