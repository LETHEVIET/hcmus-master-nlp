  {
    "sentence_id": "HCH_006_038_000111",
    "sentence": "益封朱虛侯、東牟侯各二千戶，黃金千斤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000112",
    "sentence": "齊後諸王",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000113",
    "sentence": "是歲，齊哀王薨，子文王則嗣。",
