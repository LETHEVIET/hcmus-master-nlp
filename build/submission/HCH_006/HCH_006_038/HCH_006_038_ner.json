[
  {
    "sentence_id": "HCH_006_038_000001",
    "sentence": "高皇帝八男：呂后生 孝惠帝 ，曹夫人生 齊悼惠王 肥，薄姬生 孝文帝 ，戚夫人生 趙隱王 如意，趙姬生 淮南厲王 長，諸姬生 趙幽王 友、 趙共王 恢、 燕靈王 建。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000002",
    "sentence": "淮南厲王長自有傳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000003",
    "sentence": "齊悼惠王",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000004",
    "sentence": "齊悼惠王肥，其母高祖微時外婦也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000005",
    "sentence": "高祖六年立，食七十餘城。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "食七十餘城",
        "label": "LOC",
        "start": 6,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000006",
    "sentence": "諸民能齊言者皆與齊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000007",
    "sentence": "孝惠二年，入朝。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000008",
    "sentence": "帝與齊王燕飲太后前，置齊王上坐，如家人禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000009",
    "sentence": "太后怒，乃令人酌兩卮鴆酒置前，令齊王為壽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000010",
    "sentence": "齊王起，帝亦起，欲俱為壽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000011",
    "sentence": "太后恐，自起反卮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000012",
    "sentence": "齊王怪之，因不敢飲，陽醉去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000013",
    "sentence": "問知其鴆，乃憂，自以為不得脫長安。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000014",
    "sentence": "內史士曰：「太后獨有帝與魯元公主，今王有七十餘城，而公主乃食數城。王誠以一郡上太后為公主湯沐邑，太后必喜，王無患矣。」於是齊王獻城陽郡以尊公主為王太后。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "今王有七十餘城",
        "label": "LOC",
        "start": 17,
        "end": 24
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 26,
        "end": 28
      },
      {
        "text": "王誠以一郡",
        "label": "LOC",
        "start": 33,
        "end": 38
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 42,
        "end": 44
      },
      {
        "text": "於是齊王獻城",
        "label": "LOC",
        "start": 59,
        "end": 65
      },
      {
        "text": "陽郡",
        "label": "LOC",
        "start": 65,
        "end": 67
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 69,
        "end": 71
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000015",
    "sentence": "呂太后喜而許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000016",
    "sentence": "乃置酒齊邸，樂飲，遣王歸國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000017",
    "sentence": "後十三年薨，子襄嗣。",
    "entities": [
      {
        "text": "十三年",
        "label": "TME",
        "start": 1,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000018",
    "sentence": "趙隱王",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000019",
    "sentence": "趙隱王如意，九年立。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000020",
    "sentence": "四年，高祖崩，呂太后徵王到長安，鴆殺之。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000021",
    "sentence": "無子，絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000022",
    "sentence": "趙幽王",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000023",
    "sentence": "趙幽王友，十一年立為淮陽王。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000024",
    "sentence": "趙隱王如意死，孝惠元年，徙友王趙，凡立十四年。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 9,
        "end": 11
      },
      {
        "text": "十四年",
        "label": "TME",
        "start": 19,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000025",
    "sentence": "友以諸呂女為后，不愛，愛它姬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000026",
    "sentence": "諸呂女怒去，讒之於太后曰：「王曰『呂氏安得王？太后百歲後，吾必擊之。』」太后怒，以故召趙王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000027",
    "sentence": "趙王至，置邸不見，令衛圍守之，不得食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000028",
    "sentence": "其群臣或竊饋之，輒捕論之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000029",
    "sentence": "趙王餓，乃歌曰：「諸呂用事兮，劉氏微；迫脅王侯兮，彊授我妃。我妃既妒兮，誣我以惡；讒女亂國兮，上曾不寤。我無忠臣兮，何故棄國？自快中野兮，蒼天與直！于嗟不可悔兮，寧早自賊！為王餓死兮，誰者憐之？呂氏絕理兮，託天報仇！」遂幽死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000030",
    "sentence": "以民禮葬之長安。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000031",
    "sentence": "高后崩，孝文即位，立幽王子遂為趙王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000032",
    "sentence": "二年，有司請立皇子為王。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000033",
    "sentence": "上曰：「趙幽王幽死，朕甚憐之。已立其長子遂為趙王。遂弟辟彊及齊悼惠王子朱虛侯章、東牟侯興居有功，皆可王。」於是取趙之河間立辟彊，是為河間文王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000034",
    "sentence": "文王立十三年薨，子哀王福嗣。",
    "entities": [
      {
        "text": "十三年",
        "label": "TME",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000035",
    "sentence": "一年薨。",
    "entities": [
      {
        "text": "一年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000036",
    "sentence": "無子，國除。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000037",
    "sentence": "趙王遂立二十六年，孝景時晁錯以過削趙常山郡，諸侯怨，吳楚反，遂與合謀起兵。",
    "entities": [
      {
        "text": "二十六年",
        "label": "TME",
        "start": 4,
        "end": 8
      },
      {
        "text": "以過削趙常山郡",
        "label": "LOC",
        "start": 14,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000038",
    "sentence": "其相建德、內史王悍諫，不聽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000039",
    "sentence": "遂燒殺德、悍，發兵住其西界，欲待吳楚俱進，北使匈奴與連和。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000040",
    "sentence": "漢使曲周侯酈寄擊之，趙王城守邯鄲，相距七月。",
    "entities": [
      {
        "text": "趙王城",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000041",
    "sentence": "吳楚敗，匈奴聞之，亦不肯入邊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000042",
    "sentence": "欒布自破齊還，并兵引水灌趙城。",
    "entities": [
      {
        "text": "并兵引水灌趙城",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000043",
    "sentence": "城壞，王遂自殺，國除。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000044",
    "sentence": "景帝憐趙相、內史守正死，皆封其子為列侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000045",
    "sentence": "趙共王",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000046",
    "sentence": "趙共王恢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000047",
    "sentence": "十一年，梁王彭越誅，立恢為梁王。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000048",
    "sentence": "十六年，趙幽王死，呂后徙恢王趙，恢心不樂。",
    "entities": [
      {
        "text": "十六年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000049",
    "sentence": "太后以呂產女為趙王后，王后從官皆諸呂也，內擅權，微司趙王，王不得自恣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000050",
    "sentence": "王有愛姬，王后鴆殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000051",
    "sentence": "王乃為歌詩四章，令樂人歌之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000052",
    "sentence": "王悲思，六月自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000053",
    "sentence": "太后聞之，以為用婦人故自殺，無思奉宗廟禮，廢其嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000054",
    "sentence": "燕靈王",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000055",
    "sentence": "燕靈王建。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000056",
    "sentence": "十一年，燕王盧綰亡入匈奴，明年，立建為燕王。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000057",
    "sentence": "十五年薨，有美人子，太后使人殺之，絕後。",
    "entities": [
      {
        "text": "十五年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000058",
    "sentence": "齊悼惠王子，前後凡九人為王：太子襄為齊哀王，次子章為城陽景王，興居為濟北王，將閭為齊王，志為濟北王，辟光為濟南王，賢為菑川王，卬為膠西王，雄渠為膠東王。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "次子章為城",
        "label": "LOC",
        "start": 22,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000059",
    "sentence": "齊哀王 襄",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000060",
    "sentence": "齊哀王襄，孝惠六年嗣立。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000061",
    "sentence": "明年，惠帝崩，呂太后稱制。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000062",
    "sentence": "元年，以其兄子鄜侯呂台為呂王，割齊之濟南郡為呂王奉邑。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "割齊之濟南郡",
        "label": "LOC",
        "start": 15,
        "end": 21
      },
      {
        "text": "為呂王奉邑",
        "label": "LOC",
        "start": 21,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000063",
    "sentence": "明年，哀王弟章入宿衛於漢，高后封為朱虛侯，以呂祿女妻之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000064",
    "sentence": "後四年，封章弟興居為東牟侯，皆宿衛長安。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 1,
        "end": 3
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000065",
    "sentence": "高后七年，割齊琅邪郡，立營陵侯劉澤為琅邪王。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "割齊琅邪郡",
        "label": "LOC",
        "start": 5,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000066",
    "sentence": "是歲，趙王友幽死于邸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000067",
    "sentence": "三趙王既廢，高后立諸呂為三王，擅權用事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000068",
    "sentence": "章年二十，有氣力，忿劉氏不得職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000069",
    "sentence": "嘗入侍燕飲，高后令章為酒吏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000070",
    "sentence": "章自請曰：「臣，將種也，請得以軍法行酒。」高后曰：「可。」酒酣，章進歌舞，已而曰：「請為太后言耕田。」高后兒子畜之，笑曰：「顧乃父知田耳，若生而為王子，安知田乎？」章曰：「臣知之。」太后曰：「試為我言田意。」章曰：「深耕穊種，立苗欲疏；非其種者，鉏而去之。」太后默然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000071",
    "sentence": "頃之，諸呂有一人醉，亡酒，章追，拔劍斬之，而還報曰：「有亡酒一人，臣謹行軍法斬之。」太后左右大驚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000072",
    "sentence": "業已許其軍法，亡以罪也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000073",
    "sentence": "因罷酒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000074",
    "sentence": "自是後，諸呂憚章，雖大臣皆依朱虛侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000075",
    "sentence": "劉氏為彊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000076",
    "sentence": "其明年，高后崩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000077",
    "sentence": "趙王呂祿為上將軍，呂王產為相國，皆居長安中，聚兵以威大臣，欲為亂。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000078",
    "sentence": "章以呂祿女為婦，知其謀，乃使人陰出告其兄齊王，欲令發兵西，朱虛侯、東牟侯欲從中與大臣為內應，以誅諸呂，因立齊王為帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000079",
    "sentence": "齊王聞此計，與其舅駟鈞、郎中令祝午、中尉魏勃陰謀發兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000080",
    "sentence": "齊相召平聞之，乃發兵入衛王宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000081",
    "sentence": "魏勃紿平曰：「王欲發兵，非有漢虎符驗也。而相君圍王，固善。勃請為君將兵衛衛王。」召平信之，乃使魏勃將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000082",
    "sentence": "勃既將，以兵圍相府。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000083",
    "sentence": "召平曰：「嗟乎！道家之言『當斷不斷，反受其亂』。」遂自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000084",
    "sentence": "於是齊王以駟鈞為相，魏勃為將軍，祝午為內史，悉發國中兵。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000085",
    "sentence": "使祝午紿琅邪王曰：「呂氏為亂，齊王發兵欲西誅之。齊王自以兒子，年少，不習兵革之事，願舉國委大王。大王自高帝將也，習戰事。齊王不敢離兵，使臣請大王幸之臨菑見齊王計事，并將齊兵以西平關中之亂。」琅邪王信之，以為然，乃馳見齊王。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 24,
        "end": 25
      },
      {
        "text": "齊",
        "label": "ORG",
        "start": 60,
        "end": 61
      },
      {
        "text": "將齊兵以西平關",
        "label": "LOC",
        "start": 83,
        "end": 90
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000086",
    "sentence": "齊王與魏勃等因留琅邪王，而使祝午盡發琅邪國而并將其兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000087",
    "sentence": "琅邪王劉澤既欺，不得反國，乃說齊王曰：「齊悼惠王，高皇帝長子也，推本言之，大王高皇帝適長孫也，當立。今諸大臣狐疑未有所定，而澤於劉氏最為長年，大臣固待澤決計。今大王留臣無為也，不如使我入關計事。」齊王以為然，乃益具車送琅邪王。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 26,
        "end": 28
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 40,
        "end": 42
      },
      {
        "text": "不如使我入關",
        "label": "LOC",
        "start": 88,
        "end": 94
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000088",
    "sentence": "琅邪王既行，齊遂舉兵西攻呂國之濟南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000089",
    "sentence": "於是齊王遺諸侯王書曰：「高帝平定天下，王諸子弟。悼惠王薨，惠帝使留侯張良立臣為齊王。惠帝崩，高后用事，春秋高，聽諸呂擅廢帝更立，又殺三趙王，滅梁、趙、燕，以王諸呂，分齊國為四。忠臣進諫，上或亂不聽。今高后崩，皇帝春秋富，未能治天下，固待大臣諸侯。今諸呂又擅自尊官，聚官嚴威，劫列侯忠臣，撟制以令天下，宗廟以危。寡人帥兵入誅不當為王者。」",
    "entities": [
      {
        "text": "齊國",
        "label": "ORG",
        "start": 83,
        "end": 85
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 104,
        "end": 106
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000090",
    "sentence": "漢聞之，相國呂產等遣大將軍潁陰侯灌嬰將兵擊之。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000091",
    "sentence": "嬰至滎陽，乃謀曰：「諸呂舉兵關中，欲危劉氏而自立，今我破齊還報，是益呂氏資也。」乃留兵屯滎陽，使人諭齊王及諸侯，與連和，以待呂氏之變而共誅之。",
    "entities": [
      {
        "text": "諸呂舉兵關",
        "label": "LOC",
        "start": 10,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000092",
    "sentence": "齊王聞之，乃屯兵西界待約。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000093",
    "sentence": "呂祿、呂產欲作亂，朱虛侯章與太尉勃、丞相平等誅之。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000094",
    "sentence": "章首先斬呂產，太尉勃等乃盡誅諸呂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000095",
    "sentence": "而琅邪王亦從齊至長安。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000096",
    "sentence": "大臣議欲立齊王，皆曰：「母家駟鈞惡戾，虎而冠者也。訪以呂氏故，幾亂天下，今又立齊王，是欲復為呂氏也。代王母家薄氏，君子長者，且代王，高帝子，於今見在，最為長。以子則順，以善人則大臣安。」於是大臣乃謀迎代王，而遣章以誅呂氏事告齊王，令罷兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000097",
    "sentence": "灌嬰在滎陽，聞魏勃本教齊王反，既誅呂氏，罷齊兵，使使召責問魏勃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000098",
    "sentence": "勃曰：「失火之家，豈暇先言丈人後救火乎！」因退立，股戰而栗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000099",
    "sentence": "恐不能言者，終無他語。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000100",
    "sentence": "灌將軍孰視，笑曰：「人謂魏勃勇，妄庸人耳，何能為乎！」乃罷勃。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000101",
    "sentence": "勃父以善鼓琴見秦皇帝。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000102",
    "sentence": "及勃少時，欲求見齊相曹參，家貧無以自通，乃常獨早埽齊相舍人門外。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000103",
    "sentence": "舍人怪之，以為物而司之，得勃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000104",
    "sentence": "勃曰：「願見相君無因，故為子埽，欲以求見。」於是舍人見勃，曹參因以為舍人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000105",
    "sentence": "壹為參御言事，以為賢，言之悼惠王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000106",
    "sentence": "王召見，拜為內史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000107",
    "sentence": "始悼惠王得自置二千石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000108",
    "sentence": "及悼惠王薨，哀王嗣，勃用事重於相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000109",
    "sentence": "齊王既罷兵歸，而代王立，是為孝文帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000110",
    "sentence": "文帝元年，盡以高后時所割齊之城陽、琅邪、濟南郡復予齊，而徙琅邪王王燕。",
    "entities": [
      {
