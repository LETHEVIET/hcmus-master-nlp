      }
    ]
  },
  {
    "sentence_id": "HCH_006_038_000198",
    "sentence": "自吳楚誅後，稍奪諸侯權，左官附益阿黨之法設。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_038_000199",
    "sentence": "其後諸侯唯得衣食租稅，貧者或乘牛車。",
    "entities": []
  }
]
