      }
    ]
  },
  {
    "sentence_id": "HCH_006_009_000132",
    "sentence": "五月壬辰，帝崩于未央宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_009_000133",
    "sentence": "毀太上皇、孝惠、孝景皇帝廟。",
