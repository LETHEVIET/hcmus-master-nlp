      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000034",
    "sentence": "是日大風，拔甘泉畤中大木十韋以上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000035",
    "sentence": "郡國被災什四以上，毋收田租。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000036",
    "sentence": "二年春正月，罷雍五畤。",
