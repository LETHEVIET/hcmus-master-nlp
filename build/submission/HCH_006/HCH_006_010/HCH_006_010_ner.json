        "text": "大夫",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000027",
    "sentence": "賜舅王譚、商、立、根、逢時爵關內侯。",
    "entities": [
      {
        "text": "逢時爵關",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000028",
    "sentence": "夏四月，黃霧四塞，博問公卿大夫，無有所諱。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 13,
