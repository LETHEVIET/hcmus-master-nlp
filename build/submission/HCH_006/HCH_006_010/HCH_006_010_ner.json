    "sentence_id": "HCH_006_010_000194",
    "sentence": "行幸雍，祠五畤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000195",
    "sentence": "夏四月，以大司馬票騎大將軍根爲大司馬，罷將軍官。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 10,
        "end": 13
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000196",
    "sentence": "御史大夫爲大司空，封爲列侯。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000197",
    "sentence": "益大司馬、大司空奉如丞相。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000198",
    "sentence": "秋八月庚戌，中山王興薨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000199",
    "sentence": "冬十一月，立楚孝王孫景爲定陶王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000200",
    "sentence": "定陵侯淳于長大逆不道，下獄死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000201",
    "sentence": "廷尉孔光使持節賜貴人許氏藥，飲藥死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000202",
    "sentence": "十二月，罷部刺史，更置州牧，秩二千石。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "更置州",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000203",
    "sentence": "二年春正月，行幸甘泉，郊泰畤。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000204",
    "sentence": "二月壬子，丞相翟方進薨。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "翟方進",
        "label": "PER",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000205",
    "sentence": "三月，行幸河東，祠后土。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000206",
    "sentence": "丙戌，帝崩于未央宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000207",
    "sentence": "皇太后詔有司復長安南北郊。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000208",
    "sentence": "四月己卯，葬延陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000209",
    "sentence": "贊",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000210",
    "sentence": "贊曰：臣之姑充後宮爲婕妤，父子昆弟侍帷幄，數爲臣言成帝善修容儀，升車正立，不內顧，不疾言，不親指，臨朝淵嘿，尊嚴若神，可謂穆穆天子之容者矣！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000211",
    "sentence": "博覽古今，容受直辭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000212",
    "sentence": "公卿稱職，奏議可述。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000213",
    "sentence": "遭世承平，上下和睦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000214",
    "sentence": "然湛于酒色，趙氏亂內，外家擅朝，言之可爲於邑。",
    "entities": [
      {
        "text": "言之可爲於邑",
        "label": "LOC",
        "start": 16,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000215",
    "sentence": "建始以來，王氏始執國命，哀、平短祚，莽遂篡位，蓋其威福所由來者漸矣！",
    "entities": []
  }
]
