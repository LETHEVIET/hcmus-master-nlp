        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000004",
    "sentence": "宣帝愛之，字曰太孫，常置左右。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000005",
    "sentence": "年三歳而宣帝崩，元帝即位，帝爲太子。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000006",
    "sentence": "壯好經書，寬博謹慎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000007",
    "sentence": "初居桂宮，上嘗急召，太子出龍樓門，不敢絶馳道，西至直城門，得絶乃度，還入作室門。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "西至直城",
        "label": "LOC",
        "start": 23,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000008",
    "sentence": "上遲之，問其故，以狀對。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000009",
    "sentence": "上大説，乃著令，令太子得絶馳道云。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000010",
    "sentence": "其後幸酒，樂燕樂，上不以爲能。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000011",
    "sentence": "而定陶恭王有材藝，母傅昭儀又愛幸，上以故常有意欲以恭王爲嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_010_000012",
    "sentence": "賴侍中史丹護太子家，輔助有力，上亦以先帝尤愛太子，故得無廢。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000013",
    "sentence": "竟寧元年 五月，元帝崩。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000014",
    "sentence": "六月己未，太子即皇帝位，謁高廟。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000015",
    "sentence": "尊皇太后曰太皇太后，皇后曰皇太后。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_010_000016",
    "sentence": "以元舅侍中衞尉陽平侯王鳳爲大司馬大將軍，領尚書事。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
