        "text": "司馬",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000185",
    "sentence": "初，丞相孔光爲御史大夫，時賢父恭爲御史，事光。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
