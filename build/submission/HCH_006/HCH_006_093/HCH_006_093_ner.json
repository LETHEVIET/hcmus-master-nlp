[
  {
    "sentence_id": "HCH_006_093_000001",
    "sentence": "鄧通 附:趙談 韓嫣 弟:説 李延年　石顯　淳于長　董賢",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000002",
    "sentence": "序",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000003",
    "sentence": "漢興，佞倖寵臣，高祖時則有籍孺，孝惠有閎孺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000004",
    "sentence": "此兩人非有材能，但以婉媚貴幸，與上臥起，公卿皆因關説。",
    "entities": [
      {
        "text": "公卿皆因關",
        "label": "LOC",
        "start": 20,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000005",
    "sentence": "故孝惠時，郎侍中皆冠鵔鸃，貝帶，傅脂粉，化閎、籍之屬也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000006",
    "sentence": "兩人徙家安陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000007",
    "sentence": "其後寵臣，孝文時士人則鄧通，宦者則趙談、北宮伯子；孝武時士人則韓嫣，宦者則李延年；孝元時宦者則弘恭、石顯；孝成時士人則張放、淳于長；孝哀時則有董賢。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 42,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000008",
    "sentence": "孝景、昭、宣時皆無寵臣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000009",
    "sentence": "景帝唯有郎中令周仁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000010",
    "sentence": "昭帝時，駙馬都尉秺侯金賞嗣父車騎將軍日磾爵爲侯，二人之寵取過庸，不篤。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000011",
    "sentence": "宣帝時，侍中中郎將張彭祖少與帝微時同席研書，及帝即尊位，彭祖以舊恩封陽都侯，出常參乘，號爲愛幸。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000012",
    "sentence": "其人謹敕，無所虧損，爲其小妻所毒薨，國除。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000013",
    "sentence": "鄧通",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000014",
    "sentence": "鄧通，蜀郡南安人也，以濯船爲黃頭郎。",
    "entities": [
      {
        "text": "蜀郡",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000015",
    "sentence": "文帝嘗夢欲上天，不能，有一黃頭郎推上天，顧見其衣尻帶後穿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000016",
    "sentence": "覺而之漸台，以夢中陰目求推者郎，見鄧通，其衣後穿，夢中所見也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000017",
    "sentence": "召問其名姓，姓鄧，名通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000018",
    "sentence": "鄧猶登也，文帝甚説，尊幸之，日日異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000019",
    "sentence": "通亦願謹，不好外交，雖賜洗沐，不欲出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000020",
    "sentence": "於是文帝賞賜通巨萬以十數，官至上大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000021",
    "sentence": "文帝時間如通家遊戲，然通無他技能，不能有所薦達，獨自謹身以媚上而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000022",
    "sentence": "上使善相人者相通，曰：「當貧餓死。」上曰：「能富通者在我，何説貧？」於是賜通蜀嚴道銅山，得自鑄錢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000023",
    "sentence": "鄧氏錢布天下，其富如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000024",
    "sentence": "文帝嘗病癰，鄧通常爲上嗽吮之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000025",
    "sentence": "上不樂，從容問曰：「天下誰最愛我者乎？」通曰：「宜莫若太子。」太子入問疾，上使太子齰癰。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 27,
        "end": 29
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 31,
        "end": 33
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 39,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000026",
    "sentence": "太子齰癰而色難之。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000027",
    "sentence": "已而聞通嘗爲上齰之，太子慚，由是心恨通。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000028",
    "sentence": "及文帝崩，景帝立，鄧通免，家居。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000029",
    "sentence": "居無何，人有告通盜出徼外鑄錢，下吏驗問，頗有，遂竟案，盡沒入之，通家尚負責數巨萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000030",
    "sentence": "長公主賜鄧通，吏輒隨沒入之，一簪不得著身。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000031",
    "sentence": "於是長公主乃令假衣食。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000032",
    "sentence": "竟不得名一錢，寄死人家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000033",
    "sentence": "附 趙談",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000034",
    "sentence": "趙談者，以星氣幸，北宮伯子長者愛人，故親近，然皆不比鄧通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000035",
    "sentence": "韓嫣",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000036",
    "sentence": "韓嫣字王孫，弓高侯穨當之孫也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000037",
    "sentence": "武帝爲膠東王時，嫣與上學書相愛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000038",
    "sentence": "及上爲太子，愈益親嫣。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000039",
    "sentence": "嫣善騎射，聰慧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000040",
    "sentence": "上即位，欲事伐胡，而嫣先習兵，以故益尊貴，官至上大夫，賞賜擬鄧通。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000041",
    "sentence": "始時，嫣常與上共臥起。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000042",
    "sentence": "江都王入朝，從上獵上林中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000043",
    "sentence": "天子車駕蹕道未行，先使嫣乘副車，從數十百騎馳視獸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000044",
    "sentence": "江都王望見，以爲天子，辟從者，伏謁道旁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000045",
    "sentence": "嫣驅不見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000046",
    "sentence": "既過，江都王怒，爲皇太后泣，請得歸國入宿衛，比韓嫣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000047",
    "sentence": "太后由此銜嫣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000048",
    "sentence": "嫣侍，出入永巷不禁，以奸聞皇太后。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000049",
    "sentence": "太后怒，使使賜嫣死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000050",
    "sentence": "上爲謝，終不能得，嫣遂死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000051",
    "sentence": "嫣弟 説",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000052",
    "sentence": "嫣弟説，亦愛幸，以軍功封案道侯，巫蠱時爲戾太子所殺。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000053",
    "sentence": "子增封龍雒侯、大司馬、車騎將軍，自有傳。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000054",
    "sentence": "李延年",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000055",
    "sentence": "李延年，中山人，身及父母兄弟皆故倡也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000056",
    "sentence": "延年坐法腐刑，給事狗監中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000057",
    "sentence": "女弟得幸於上，號李夫人，列《外戚傳》。",
    "entities": [
      {
        "text": "《外戚傳》",
        "label": "TITLE",
        "start": 13,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000058",
    "sentence": "延年善歌，爲新變聲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000059",
    "sentence": "是時，上方興天地祠，欲造樂，令司馬相如等作詩頌。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000060",
    "sentence": "延年輒承意弦歌所造詩，爲之新聲曲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000061",
    "sentence": "而李夫人產昌邑王，延年由是貴爲協律都尉，佩二千石印綬，而與上臥起，其愛幸埒韓嫣。",
    "entities": [
      {
        "text": "而李夫人產昌邑",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000062",
    "sentence": "久之，延年弟季與中人亂，出入驕恣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000063",
    "sentence": "及李夫人卒後，其愛弛，上遂誅延年兄弟宗族。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000064",
    "sentence": "是後，寵臣大氐外戚之家也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000065",
    "sentence": "衞青、霍去病皆愛幸，然亦以功能自進。",
    "entities": [
      {
        "text": "霍去病",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000066",
    "sentence": "石顯",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000067",
    "sentence": "石顯字君房，濟南人；弘恭，沛人也。",
    "entities": [
      {
        "text": "沛",
        "label": "LOC",
        "start": 13,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000068",
    "sentence": "皆少坐法腐刑，爲中黃門，以選爲中尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000069",
    "sentence": "宣帝時任中書官，恭明習法令故事，善爲請奏，能稱其職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000070",
    "sentence": "恭爲令，顯爲僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000071",
    "sentence": "元帝即位數年，恭死，顯代爲中書令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000072",
    "sentence": "是時，元帝被疾，不親政事，方隆好於音樂，以顯久典事，中人無外黨，精專可信任，遂委以政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000073",
    "sentence": "事無小大，因顯白決，貴幸傾朝，百僚皆敬事顯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000074",
    "sentence": "顯爲人巧慧習事，能探得人主微指，內深賊，持詭辯以中傷人，忤恨睚眥，輒被以危法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000075",
    "sentence": "初元中，前將軍蕭望之及光祿大夫周堪、宗正劉更生皆給事中。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "蕭望之",
        "label": "PER",
        "start": 7,
        "end": 10
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000076",
    "sentence": "望之領尚書事，知顯專權邪辟，建白以爲：「尚書百官之本，國家樞機，宜以通明公正處之。武帝游宴後庭，故用宦者，非古制也。宜罷中書宦官，應古不近刑人。」元帝不聽，由是大與顯忤。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000077",
    "sentence": "後皆害焉，望之自殺，堪、更生廢錮，不得復進用，語在《望之傳》。",
    "entities": [
      {
        "text": "《望之傳》",
        "label": "TITLE",
        "start": 25,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000078",
    "sentence": "後太中大夫張猛、魏郡太守京房、御史中丞陳咸、待詔賈捐之皆嘗奏封事，或召見，言顯短。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "魏郡",
        "label": "LOC",
        "start": 8,
        "end": 10
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000079",
    "sentence": "顯求索其罪，房、捐之棄市，猛自殺於公車，咸抵罪，髡爲城旦。",
    "entities": [
      {
        "text": "髡爲城",
        "label": "LOC",
        "start": 24,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000080",
    "sentence": "及鄭令蘇建得顯私書奏之，後以它事論死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000081",
    "sentence": "自是公卿以下畏顯，重足一跡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000082",
    "sentence": "顯與中書僕射牢梁、少府五鹿充宗結爲黨友，諸附倚者皆得寵位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000083",
    "sentence": "民歌之曰：「牢邪石邪，五鹿客邪！印何纍纍，綬若若邪！」言其兼官據勢也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000084",
    "sentence": "顯見左將軍馮奉世父子爲公卿著名，女又爲昭儀在內，顯心欲附之，薦言昭儀兄謁者逡修敕宜侍帷幄。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "馮奉世",
        "label": "PER",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000085",
    "sentence": "天子召見，欲以爲侍中，逡請間言事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000086",
    "sentence": "上聞逡言顯顓權，天子大怒，罷逡歸郎官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000087",
    "sentence": "其後御史大夫缺，群臣皆舉逡兄大鴻臚野王行能第一，天子以問顯，顯曰：「九卿無出野王者。然野王親昭儀兄，臣恐後世必以陛下度越眾賢，私後宮親以爲三公。」上曰：「善，吾不見是。」乃下詔嘉美野王，廢而不用，語在《野王傳》。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "《野王傳》",
        "label": "TITLE",
        "start": 100,
        "end": 105
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000088",
    "sentence": "顯內自知擅權事柄在掌握，恐天子一旦納用左右耳目，有以間己，乃時歸誠，取一信以爲驗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000089",
    "sentence": "顯嘗使至諸官有所征發，顯先自白，恐後漏盡宮門閉，請使詔吏開門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000090",
    "sentence": "上許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000091",
    "sentence": "顯故投夜還，稱詔開門入。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000092",
    "sentence": "後果有上書告顯顓命矯詔開宮門，天子聞之，笑以其書示顯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000093",
    "sentence": "顯因泣曰：「陛下過私小臣，屬任以事，群下無不嫉妒欲陷害臣者，事類如此非一，唯獨明主知之。愚臣微賤，誠不能以一軀稱快萬眾，任天下之怨，臣願歸樞機職，受後宮掃除之役，死無所恨，唯陛下哀憐財幸，以此全活小臣。」天子以爲然而憐之，數勞勉顯，加厚賞賜，賞賜及賂遺訾一萬萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000094",
    "sentence": "初，顯聞眾人匈匈，言己殺前將軍蕭望之。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "蕭望之",
        "label": "PER",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000095",
    "sentence": "望之當世名儒，顯恐天下學士姍己，病之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000096",
    "sentence": "是時，明經著節士琅邪貢禹爲諫大夫，顯使人致意，深自結納。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000097",
    "sentence": "顯因薦禹天子，歷位九卿，至御史大夫，禮事之甚備。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000098",
    "sentence": "議者於是稱顯，以爲不妒譖望之矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000099",
    "sentence": "顯之設變詐以自解免取信人主者，皆此類也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000100",
    "sentence": "元帝晚節寢疾，定陶恭王愛幸，顯擁祐太子頗有力。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000101",
    "sentence": "元帝崩，成帝初即位，遷顯爲長信中太僕，秩中二千石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000102",
    "sentence": "顯失倚，離權數月，丞相御史條奏顯舊惡，及其黨牢梁、陳順皆免官。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000103",
    "sentence": "顯與妻子徙歸故郡，憂滿不食，道病死。",
    "entities": [
      {
        "text": "與妻子徙歸故郡",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000104",
    "sentence": "諸所交結，以顯爲官，皆廢罷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000105",
    "sentence": "少府五鹿充宗左遷玄菟太守，御史中丞伊嘉爲雁門都尉。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000106",
    "sentence": "長安謠曰：「伊徙雁，鹿徙菟，去牢與陳實無賈。」",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000107",
    "sentence": "淳于長",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000108",
    "sentence": "淳于長字子𡦗，魏郡元城人也。",
    "entities": [
      {
        "text": "魏郡元城",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000109",
    "sentence": "少以太后姊子爲黃門郎，未進幸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000110",
    "sentence": "會大將軍王鳳病，長侍病，晨夜扶丞左右，甚爲甥舅之恩。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 1,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000111",
    "sentence": "鳳且終，以長屬托太后及帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000112",
    "sentence": "帝嘉長義，拜爲列校尉諸曹，遷水衡都尉侍中，至衛尉九卿。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000113",
    "sentence": "久之，趙飛燕貴幸，上欲立以爲皇后，太后以其所出微，難之。",
    "entities": [
      {
        "text": "趙飛燕",
        "label": "PER",
        "start": 3,
        "end": 6
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000114",
    "sentence": "長主往來通語東宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000115",
    "sentence": "歲餘，趙皇后得立，上甚德之，乃追顯長前功，下詔曰：「前將作大匠解萬年奏請營作昌陵，罷弊海內，侍中衛尉長數白宜止徙家反故處，朕以長言下公卿，議者皆合長計。首建至策，民以康寧。其賜長爵關內侯。」後遂封爲定陵侯，大見信用，貴傾公卿。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "其賜長爵關",
        "label": "LOC",
        "start": 86,
        "end": 91
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000116",
    "sentence": "外交諸侯牧守，賂遺賞賜亦累巨萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000117",
    "sentence": "多畜妻妾，淫於聲色，不奉法度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000118",
    "sentence": "初，許皇后坐執左道廢處長定宮，而後姊靡爲龍額思侯夫人，寡居。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000119",
    "sentence": "長與靡私通，因取爲小妻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000120",
    "sentence": "許后因靡賂遺長，欲求復爲婕妤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000121",
    "sentence": "長受許后金錢乘輿服御物前後千餘萬，詐許爲白上，立以爲左皇后。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000122",
    "sentence": "靡每入長定宮，輒與靡書，戲侮許后，嫚易無不言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000123",
    "sentence": "交通書記，賂遺連年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000124",
    "sentence": "是時，帝舅曲陽侯王根爲大司馬票騎將軍，輔政數歲，久病，數乞骸骨。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000125",
    "sentence": "長以外親居九卿位，次第當代根。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000126",
    "sentence": "根兄子新都侯王莽心害長寵，私聞長取許靡，受長定宮賂遺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000127",
    "sentence": "莽侍曲陽侯疾，因言：「長見將軍久病，意喜，自以當代輔政，至對衣冠議語署置。」具言其罪過。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000128",
    "sentence": "根怒曰：「即如是，何不白也？」莽曰：「未知將軍意，故未敢言。」根曰：「趣白東宮。」莽求見太后，具言長驕佚，欲代曲陽侯，對莽母上車，私與長定貴人姊通，受取其衣物。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000129",
    "sentence": "太后亦怒曰：「兒至如此！往白之帝！」莽白上，上乃免長官，遣就國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000130",
    "sentence": "初，長爲侍中，奉兩宮使，親密。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000131",
    "sentence": "紅陽侯立獨不得爲大司馬輔政，立自疑爲長毀譖，常怨毒長。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000132",
    "sentence": "上知之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000133",
    "sentence": "及長當就國也，立嗣子融從長請車騎，長以珍寶因融重遺立，立因爲長言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000134",
    "sentence": "於是天子疑焉，下有司案驗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000135",
    "sentence": "史捕融，立令融自殺以滅口。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000136",
    "sentence": "上愈疑其有大奸，遂逮長系洛陽詔獄窮治。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000137",
    "sentence": "長具服戲侮長定宮，謀立左皇后，罪至大逆，死獄中。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000138",
    "sentence": "妻子當坐者徙合浦，母若歸故郡。",
    "entities": [
      {
        "text": "母若歸故郡",
        "label": "LOC",
        "start": 9,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000139",
    "sentence": "紅陽侯立就國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000140",
    "sentence": "將軍、卿、大夫、郡守坐長免罷者數十人。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000141",
    "sentence": "莽遂代根爲大司馬。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000142",
    "sentence": "久之，還長母及子酺於長安。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000143",
    "sentence": "後酺有罪，莽復殺之，徙其家屬歸故郡。",
    "entities": [
      {
        "text": "徙其家屬歸故郡",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000144",
    "sentence": "始，長以外親親近，其愛幸不及富平侯張放。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000145",
    "sentence": "放常與上臥起，俱爲微行出入。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000146",
    "sentence": "董賢",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000147",
    "sentence": "董賢字聖卿，雲陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000148",
    "sentence": "父恭，爲御史，任賢爲太子舍人。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000149",
    "sentence": "哀帝立，賢隨太子官爲郎。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000150",
    "sentence": "二歲餘，賢傳漏在殿下，爲人美麗自喜，哀帝望見，説其儀貌，識而問之，曰：「是舍人董賢邪？」因引上與語，拜爲黃門郎，由是始幸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000151",
    "sentence": "問及其父爲雲中侯，即日徵爲霸陵令，遷光祿大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000152",
    "sentence": "賢寵愛日甚，爲駙馬都尉侍中，出則參乘，入御左右，旬月間賞賜累巨萬，貴震朝廷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000153",
    "sentence": "常與上臥起。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000154",
    "sentence": "嘗晝寢，偏藉上袖，上欲起，賢未覺，不欲動賢，乃斷袖而起。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000155",
    "sentence": "其恩愛至此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000156",
    "sentence": "賢亦性柔和便辟，善爲媚以自固。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000157",
    "sentence": "每賜洗沐，不肯出，常留中視醫藥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000158",
    "sentence": "上以賢難歸，詔令賢妻得通引籍殿中，止賢廬，若吏妻子居官寺捨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000159",
    "sentence": "又召賢女弟以爲昭儀，位次皇后，更名其捨爲椒風，以配椒房雲。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000160",
    "sentence": "昭儀及賢與妻旦夕上下，並侍左右。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000161",
    "sentence": "賞賜昭儀及賢妻亦各千萬數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000162",
    "sentence": "遷賢父爲少府，賜爵關內侯，食邑，復徙爲衛尉。",
    "entities": [
      {
        "text": "賜爵關",
        "label": "LOC",
        "start": 7,
        "end": 10
      },
      {
        "text": "食邑",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000163",
    "sentence": "又以賢妻父爲將作大匠，弟爲執金吾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000164",
    "sentence": "詔將作大匠爲賢起大第北闕下，重殿洞門，木土之功窮極技巧，柱檻衣以綈錦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000165",
    "sentence": "下至賢家僮僕皆受上賜，及武庫禁兵，上方珍寶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000166",
    "sentence": "其選物上弟盡在董氏，而乘輿所服乃其副也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000167",
    "sentence": "及至東園秘器，珠襦玉柙，豫以賜賢，無不備具。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000168",
    "sentence": "又令將作爲賢起塚塋義陵旁，內爲便房，剛柏題湊，外爲徼道，周垣數里，門闕罘罳甚盛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000169",
    "sentence": "上欲侯賢而未有緣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000170",
    "sentence": "會待詔孫寵、息夫躬等告東平王雲後謁祠祀祝詛，下有司治，皆伏其辜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000171",
    "sentence": "上於是令躬、寵爲因賢告東平事者，乃以其功下詔封賢爲高安侯，躬宜陵侯，寵方陽侯，食邑各千戶。",
    "entities": [
      {
        "text": "食邑",
        "label": "LOC",
        "start": 39,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000172",
    "sentence": "頃之，復益封賢二千戶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000173",
    "sentence": "丞相王嘉內疑東平事冤，甚惡躬等，數諫爭，以賢爲亂國制度，嘉竟坐言事下獄死。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000174",
    "sentence": "上初即位，祖母傅太后、母丁太后皆在，兩家先貴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_093_000175",
    "sentence": "傅太后從弟喜先爲大司馬輔政，數諫，失太后指，免官。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_093_000176",
    "sentence": "上舅丁明代爲大司馬，亦任職，頗害賢寵，及丞相王嘉死，明甚憐之。",
    "entities": [
      {
        "text": "明",
