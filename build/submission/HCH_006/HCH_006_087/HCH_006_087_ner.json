        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000074",
    "sentence": "《法言》文多不著，獨著其目：",
    "entities": [
      {
        "text": "《法言》",
        "label": "TITLE",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000075",
    "sentence": "天降生民，倥侗顓蒙，恣于情性，聦明不開，訓諸理。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000076",
    "sentence": "譔《學行》第一。",
    "entities": [
      {
        "text": "《學行》",
