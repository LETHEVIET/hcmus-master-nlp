      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000021",
    "sentence": "成帝時",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000022",
    "sentence": "孝成帝時，客有薦雄文似相如者，上方郊祠甘泉泰畤、汾陰后土，以求繼嗣，召雄待詔承明之庭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000023",
    "sentence": "正月，從上甘泉，還奏《 甘泉賦 》以風。",
    "entities": [
      {
        "text": "《 甘泉賦 》",
        "label": "TITLE",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000024",
    "sentence": "其辭曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000025",
    "sentence": "甘泉本因秦離宮，旣奢泰，而武帝復增通天、高光、迎風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000026",
    "sentence": "宮外近則洪厓、旁皇、儲胥、弩阹，遠則石關、封巒、枝鵲、露寒、棠棃、師得，遊觀屈竒瑰偉，非木摩而不彫，牆塗而不畫，周宣所考，般庚所遷，夏卑宮室，唐虞棌椽三等之制也。",
    "entities": [
      {
        "text": "遠則石關",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000027",
    "sentence": "且其爲已乆矣，非成帝所造，欲諫則非時，欲默則不能已，故遂推而隆之，迺上比於帝室紫宮，若曰此非人力之所爲，黨鬼神可也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000028",
    "sentence": "又是時趙昭儀方大幸，每上甘泉，常法從，在屬車閒豹尾中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000029",
    "sentence": "故雄聊盛言車騎之衆，參麗之駕，非所以感動天地，逆釐三神。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000030",
    "sentence": "又言「屏玉女，郤虙妃」，以微戒齋肅之事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000031",
    "sentence": "賦成奏之，天子異焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000032",
    "sentence": "其三月，將祭后土，上迺帥羣臣橫大河，湊汾陰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000033",
    "sentence": "旣祭，行遊介山，回安邑，顧龍門，覽鹽池，登歷觀，陟西岳以望八荒，迹殷周之虛，眇然以思唐虞之風。",
    "entities": [
      {
        "text": "回安邑",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000034",
    "sentence": "雄以爲臨川羨魚不如歸而結罔，還，上《 河東賦 》以勸，其辭曰：",
    "entities": [
      {
        "text": "《 河東賦 》",
        "label": "TITLE",
        "start": 17,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000035",
    "sentence": "其十二月羽獵，雄從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000036",
    "sentence": "以爲昔在二帝三王，宮館、臺榭、沼池、苑囿、林麓、藪澤財足以奉郊廟，御賔客，充庖厨而已，不奪百姓膏腴穀土桑柘之地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000037",
    "sentence": "女有餘布，男有餘粟，國家殷富，上下交足，故甘露零其庭，醴泉流其唐，鳳皇巢其樹，黃龍游其沼，麒麟臻其囿，神爵棲其林。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000038",
    "sentence": "昔者禹任益虞而上下和，屮木茂；成湯好田而天下用足；文王囿百里，民以爲尚小；齊宣王囿四十里，民以爲大：裕民之與奪民也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000039",
    "sentence": "武帝廣開上林，南至宜春、鼎胡、御宿、昆吾，旁南山而西，至長揚、五柞，北繞黃山，瀕渭而東，周袤數百里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000040",
    "sentence": "穿昆明象滇河，營建章、鳳闕、神明、馺娑，漸臺、泰液，象海水周流方丈、瀛洲、蓬萊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000041",
    "sentence": "游觀侈靡，窮妙極麗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000042",
    "sentence": "雖頗割其三垂以贍齊民，然至羽獵田車戎馬器械儲偫禁禦所營，尚泰奢麗誇詡，非堯、舜、成湯、文王三驅之意也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000043",
    "sentence": "又恐後世復脩前好，不折中以泉臺，故聊因《 校獵賦 》以風，其辭曰：",
    "entities": [
      {
        "text": "《 校獵賦 》",
        "label": "TITLE",
        "start": 19,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000044",
    "sentence": "下",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000045",
    "sentence": "明年 ，上將大誇胡人以多禽獸，秋，命右扶風發民入南山，西自襃斜，東至弘農，南敺漢中，張羅罔罝罘，捕熊羆豪豬虎豹狖玃狐菟麋鹿，載以檻車，輸長楊射熊館。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 39,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000046",
    "sentence": "以罔爲周阹，縱禽獸其中，令胡人手搏之，自取其獲，上親臨觀焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000047",
    "sentence": "是時，農民不得收斂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000048",
    "sentence": "雄從至射熊館，還，上《 長楊賦 》，聊因筆墨之成文章，故藉翰林以爲主人，子墨爲客卿以風。",
    "entities": [
      {
        "text": "《 長楊賦 》",
        "label": "TITLE",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000049",
    "sentence": "其辭曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000050",
    "sentence": "哀帝時",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000051",
    "sentence": "哀帝時，丁、傅、董賢用事，諸附離之者或起家至二千石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000052",
    "sentence": "時雄方草《 太玄 》，有以自守，泊如也。",
    "entities": [
      {
        "text": "《 太玄 》",
        "label": "TITLE",
        "start": 4,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000053",
    "sentence": "或謿雄以玄尚白，而雄解之，號曰《 解謿 》。",
    "entities": [
      {
        "text": "《 解謿 》",
        "label": "TITLE",
        "start": 15,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000054",
    "sentence": "其辭曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000055",
    "sentence": "雄以爲賦者，將以風之，必推類而言，極麗靡之辭，閎侈鉅衍，競於使人不能加也，旣迺歸之於正，然覽者已過矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000056",
    "sentence": "往時武帝好神仙，相如上《 大人賦 》，欲以風，帝反縹縹有陵雲之志。",
    "entities": [
      {
        "text": "《 大人賦 》",
        "label": "TITLE",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000057",
    "sentence": "繇是言之，賦勸而不止，明矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000058",
    "sentence": "又頗似俳優淳于髡、優孟之徒，非法度所存，賢人君子詩賦之正也，於是輟不復爲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000059",
    "sentence": "而大潭思渾天，參摹而四分之，極於八十一。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000060",
    "sentence": "旁則三摹九据，極之七百二十九贊，亦自然之道也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000061",
    "sentence": "故觀《易》者，見其卦而名之；觀《玄》者，數其畫而定之。",
    "entities": [
      {
        "text": "《易》",
        "label": "TITLE",
        "start": 2,
        "end": 5
      },
      {
        "text": "《玄》",
        "label": "TITLE",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000062",
    "sentence": "《玄》首四重者，非卦也，數也。",
    "entities": [
      {
        "text": "《玄》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000063",
    "sentence": "其用自天元推一晝一夜陰陽數度律曆之紀，九九大運，與天終始。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000064",
    "sentence": "故玄三方、九州、二十七部、八十一家、二百四十三表、七百二十九贊，分爲三卷，曰一二三，與《泰初曆》相應，亦有顓頊之曆焉。",
    "entities": [
      {
        "text": "九州",
        "label": "LOC",
        "start": 5,
        "end": 7
      },
      {
        "text": "《泰初曆》",
        "label": "TITLE",
        "start": 43,
        "end": 48
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000065",
    "sentence": "𢶅之以三策，關之以休咎，絣之以象類，播之以人事，文之以五行，擬之以道德仁義禮知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000066",
    "sentence": "無主無名，要合《五經》，苟非其事，文不虛生。",
    "entities": [
      {
        "text": "《五經》",
        "label": "TITLE",
        "start": 7,
        "end": 11
      }
    ]
  },
