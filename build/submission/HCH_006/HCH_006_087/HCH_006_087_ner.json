        "start": 1,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000077",
    "sentence": "降周迄孔，成于王道，終後誕章乖離，諸子圖微。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000078",
    "sentence": "譔《吾子》第二。",
    "entities": [
      {
        "text": "《吾子》",
        "label": "TITLE",
        "start": 1,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_087_000079",
    "sentence": "事有本真，陳施於億，動不克咸，本諸身。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_087_000080",
    "sentence": "譔《修身》第三。",
