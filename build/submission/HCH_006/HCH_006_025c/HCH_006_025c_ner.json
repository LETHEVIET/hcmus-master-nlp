    "entities": []
  },
  {
    "sentence_id": "HCH_006_025c_000130",
    "sentence": "亦施恩澤，時所過毋出田租，賜百戶牛酒，或賜爵，赦罪人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_025c_000131",
