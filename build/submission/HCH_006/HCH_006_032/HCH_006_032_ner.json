[
  {
    "sentence_id": "HCH_006_032_000001",
    "sentence": "張耳、陳餘",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000002",
    "sentence": "張耳，大梁人也，少時及魏公子毋忌為客。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000003",
    "sentence": "嘗亡命遊外黃，外黃富人女甚美，庸奴其夫，亡邸父客。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000004",
    "sentence": "父客謂曰：「必欲求賢夫，從張耳。」女聽，為請決，嫁之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000005",
    "sentence": "女家厚奉給耳，耳以故致千里客，宦為外黃令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000006",
    "sentence": "陳餘，亦大梁人，好儒術。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000007",
    "sentence": "遊趙苦陘，富人公乘氏以其女妻之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000008",
    "sentence": "餘年少，父事耳，相與為刎頸交。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000009",
    "sentence": "高祖為布衣時，嘗從耳遊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000010",
    "sentence": "秦滅魏，購求耳千金，餘五百金。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000011",
    "sentence": "兩人變名姓，俱之陳，為里監門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000012",
    "sentence": "吏嘗以過笞餘，餘欲起，耳攝使受笞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000013",
    "sentence": "吏去，耳數之曰：「始吾與公言何如？今見小辱而欲死一吏乎？」餘謝罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000014",
    "sentence": "陳涉起蘄至陳，耳、餘上謁涉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000015",
    "sentence": "涉及左右生平數聞耳、餘賢，見，大喜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_032_000016",
    "sentence": "陳豪桀說涉曰：「將軍被堅執銳，帥士卒以誅暴秦，復立楚社稷，功德宜為王。」陳涉問兩人，兩人對曰：「將軍瞋目張膽，出萬死不顧之計，為天下除殘。今始至陳而王之，視天下私。願將軍毋王，急引兵而西，遣人立六國後，自為樹黨。如此，野無交兵，誅暴秦，據咸陽以令諸侯，則帝業成矣。今獨王陳，恐天下解矣。」涉不聽，遂立為王。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "將軍",
