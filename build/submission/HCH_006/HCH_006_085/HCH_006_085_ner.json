[
  {
    "sentence_id": "HCH_006_085_000001",
    "sentence": "谷永",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000002",
    "sentence": "谷永字子雲，長安人也。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000003",
    "sentence": "父吉，為衛司馬，使送郅支單于侍子，為郅支所殺，語在陳湯傳。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000004",
    "sentence": "永少為長安小史，後博學經書。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000005",
    "sentence": "建昭中，御史大夫繁延壽聞其有茂材，除補屬，舉為太常丞，數上疏言得失。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000006",
    "sentence": "建始三年冬，日食地震同日俱發，詔舉方正直言極諫之士，太常陽城侯劉慶忌舉永待詔公車。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "太常陽城",
        "label": "LOC",
        "start": 26,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000007",
    "sentence": "對曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000008",
    "sentence": "陛下秉至聖之純德，懼天地之戒異，飭身修政，納問公卿，又下明詔，帥舉直言，燕見紬繹，以求咎愆，使臣等得造明朝，承聖問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000009",
    "sentence": "臣材朽學淺，不通政事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000010",
    "sentence": "竊聞明王即位，正五事，建大中，以承天心，則庶徵序於下，日月理於上；如人君淫溺後宮，般樂游田，五事失於躬，大中之道不立，則咎徵降而六極至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000011",
    "sentence": "凡災異之發，各象過失，以類告人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000012",
    "sentence": "乃十二月朔戊申，日食婺女之分，地震蕭牆之內，二者同日俱發，以丁寧陛下，厥咎不遠，宜厚求諸身。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000013",
    "sentence": "意豈陛下志在閨門，未卹政事，不慎舉錯，婁失中與？",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000014",
    "sentence": "內寵大盛，女不遵道，嫉妒專上，妨繼嗣與？",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000015",
    "sentence": "古之王者廢五事之中，失夫婦之紀，妻妾得意，謁行於內，勢行於外，至覆傾國家，或亂陰陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000016",
    "sentence": "昔褒姒用國，宗周以喪；閻妻驕扇，日以不臧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000017",
    "sentence": "此其效也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000018",
    "sentence": "經曰：「皇極，皇建其有極。」傳曰：「皇之不極，是謂不建，時則有日月亂行。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000019",
    "sentence": "陛下踐至尊之祚為天下主，奉帝王之職以統群生，方內之治亂，在陛下所執。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000020",
    "sentence": "誠留意於正身，勉強於力行，損燕私之閒以勞天下，放去淫溺之樂，罷歸倡優之笑，絕卻不享之義，慎節游田之虞，起居有常，循禮而動，躬親政事，致行無倦，安服若性。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000021",
    "sentence": "經曰：「繼自今嗣王，其毋淫于酒，毋逸于游田，惟正之共。」未有身治正而臣下邪者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000022",
    "sentence": "夫妻之際，王事綱紀，安危之機，聖王所致慎也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000023",
    "sentence": "昔舜飭正二女，以崇至德；楚莊忍絕丹姬，以成伯功；幽王惑於褒姒，周德降亡；魯桓脅於齊女，社稷以傾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000024",
    "sentence": "誠修後宮之政，明尊卑之序，貴者不得嫉妒專寵，以絕驕嫚之端，抑褒、閻之亂，賤者咸得秩進，各得厥職，以廣繼嗣之統，息白華之怨，後宮親屬，饒之以財，勿與政事，以遠皇父之類，損妻黨之權，未有閨門治而天下亂者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000025",
    "sentence": "治遠自近始，習善在左右。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000026",
    "sentence": "昔龍筦納言，而帝命惟允；四輔既備，成王靡有過事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000027",
    "sentence": "誠敕正左右齊栗之臣，戴金貂之飾執常伯之職者皆使學先王之道，知君臣之義，濟濟謹孚，無敖戲驕恣之過，則左右肅艾，群僚仰法，化流四方。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000028",
    "sentence": "經曰：「亦惟先正克左右。」未有左右正而百官枉者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000029",
    "sentence": "治天下者尊賢考功則治，簡賢違功則亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000030",
    "sentence": "誠審思治人之術，歡樂得賢之福，論材選士，必試於職，明度量以程能，考功實以定德，無用比周之虛譽，毋聽寖潤之譖愬，則抱功修職之吏無蔽傷之憂，比周邪偽之徒不得即工，小人日銷，俊艾日隆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000031",
    "sentence": "經曰：「三載考績，三考黜陟幽明。」又曰：「",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000032",
    "sentence": "九德咸事，俊艾在官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000033",
    "sentence": "」未有功賞得於前眾賢布於官而不治者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000034",
    "sentence": "堯遭洪水之災，天下分絕為十二州，制遠之道微而無乖畔之難者，德厚恩深，無怨於下也。",
    "entities": [
      {
        "text": "下分絕為十二州",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000035",
    "sentence": "秦居平土，一夫大呼而海內崩析者，刑罰深酷，吏行殘賊也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000036",
    "sentence": "夫違天害德，為上取怨於下，莫甚乎殘賊之吏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000037",
    "sentence": "誠放退殘賊酷暴之吏一廢勿用，益選溫良上德之士以親萬姓，平刑釋冤以理民命，務省繇役，毋奪民時，薄收賦稅，毋殫民財，使天下黎元咸安家樂業，不苦踰時之役，不患苛暴之政，不疾酷烈之吏，雖有唐堯之大災，民無離上之心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000038",
    "sentence": "經曰：「懷保小人，惠于鰥寡。」未有德厚吏良而民畔者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000039",
    "sentence": "臣聞災異，皇天所以譴告人君過失，猶嚴父之明誡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000040",
    "sentence": "畏懼敬改，則禍銷福降；忽然簡易，則咎罰不除。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000041",
    "sentence": "經曰：「饗用五福，畏用六極。」傳曰：「六沴作見，若不共御，六罰既侵，六極其下。」今三年之間，災異鋒起，小大畢具，所行不享上帝，上帝不豫，炳然甚著。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 41,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000042",
    "sentence": "不求之身，無所改正，疏舉廣謀，又不用其言，是循不享之跡，無謝過之實也，天責愈深。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000043",
    "sentence": "此五者，王事之綱紀，南面之急務，唯陛下留神。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000044",
    "sentence": "對奏，天子異焉，特召見永。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000045",
    "sentence": "其夏，皆令諸方正對策，語在杜欽傳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000046",
    "sentence": "永對畢，因曰：「臣前幸得條對災異之效，禍亂所極，言關於聖聰。書陳於前，陛下委棄不納，而更使方正對策，背可懼之大異，問不急之常論，廢承天之至言，角無用之虛文，欲末殺災異，滿讕誣天，是故皇天勃然發怒，甲己之間暴風三溱，拔樹折木，此天至明不可欺之效也。」上特復問永，永對曰：「日食地震，皇后貴妾專寵所致。」語在五行志。",
    "entities": [
      {
        "text": "言關",
        "label": "LOC",
        "start": 24,
        "end": 26
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 140,
        "end": 142
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000047",
    "sentence": "是時，上初即位，謙讓委政元舅大將軍王鳳，議者多歸咎焉。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000048",
    "sentence": "永知鳳方見柄用，陰欲自託，乃復曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000049",
    "sentence": "方今四夷賓服，皆為臣妾，北無薰粥冒頓之患，南無趙佗、呂嘉之難，三垂晏然，靡有兵革之警。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000050",
    "sentence": "諸侯大者乃食數縣，漢吏制其權柄，不得有為，亡吳、楚、燕、梁之勢。",
    "entities": [
      {
        "text": "侯大者乃食數縣",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "吳",
        "label": "ORG",
        "start": 22,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000051",
    "sentence": "百官盤互，親疏相錯，骨肉大臣有申伯之忠，洞洞屬屬，小心畏忌，無重合、安陽、博陸之亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000052",
    "sentence": "三者無毛髮之辜，不可歸咎諸舅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000053",
    "sentence": "此欲以政事過差丞相父子、中尚書宦官，檻塞大異，皆瞽說欺天者也。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000054",
    "sentence": "竊恐陛下舍昭昭之白過，忽天地之明戒，聽晻昧之瞽說，歸咎乎無辜，倚異乎政事，重失天心，不可之大者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000055",
    "sentence": "陛下即位，委任遵舊，未有過政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000056",
    "sentence": "元年正月，白氣較然起乎東方，至其四月，黃濁四塞，覆冒京師，申以大水，著以震蝕。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000057",
    "sentence": "各有占應，相為表裏，百官庶事無所歸倚，陛下獨不怪與？",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000058",
    "sentence": "白氣起東方，賤人將興之表也；黃濁冒京師，王道微絕之應也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000059",
    "sentence": "夫賤人當起而京師道微，二者已醜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000060",
    "sentence": "陛下誠深察愚臣之言，致懼天地之異，長思宗廟之計，改往反過，抗湛溺之意，解偏駮之愛，奮乾剛之威，平天覆之施，使列妾得人人更進，猶尚未足也，急復益納宜子婦人，毋擇好醜，毋避嘗字，毋論年齒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000061",
    "sentence": "推法言之，陛下得繼嗣於微賤之間，乃反為福。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000062",
    "sentence": "得繼嗣而已，母非有賤也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000063",
    "sentence": "後宮女史使令有直意者，廣求於微賤之間，以遇天所開右，慰釋皇太后之憂慍，解謝上帝之譴怒，則繼嗣蕃滋，災異訖息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000064",
    "sentence": "陛下則不深察愚臣之言，忽於天地之戒，咎根不除，水雨之災，山石之異，將發不久；發則災異已極，天變成形，臣雖欲捐身關策，不及事已。",
    "entities": [
      {
        "text": "臣雖欲捐身關",
        "label": "LOC",
        "start": 50,
        "end": 56
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000065",
    "sentence": "疏賤之臣，至敢直陳天意，斥譏帷幄之私，欲間離貴后盛妾，自知忤心逆耳，必不免於湯鑊之誅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000066",
    "sentence": "此天保右漢家，使臣敢直言也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000067",
    "sentence": "三上封事，然後得召；待詔一旬，然後得見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000068",
    "sentence": "夫由疏賤納至忠，甚苦；由至尊聞天意，甚難。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000069",
    "sentence": "語不可露，願具書所言，因侍中奏陛下，以示腹心大臣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000070",
    "sentence": "腹心大臣以為非天意，臣當伏妄言之誅；即以為誠天意也，奈何忘國家大本，背天意而從欲！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000071",
    "sentence": "唯陛下省察熟念，厚為宗廟計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000072",
    "sentence": "時對者數十人，永與杜欽為上第焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000073",
    "sentence": "上皆以其書示後宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000074",
    "sentence": "後上嘗賜許皇后書，采永言以責之，語在外戚傳。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000075",
    "sentence": "永既陰為大將軍鳳說矣，能實最高，由是擢為光祿大夫。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 4,
        "end": 7
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
