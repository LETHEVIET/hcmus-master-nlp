      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000209",
    "sentence": "哀帝即位，遷為涼州刺史。",
    "entities": [
      {
        "text": "遷為涼州",
        "label": "LOC",
        "start": 5,
