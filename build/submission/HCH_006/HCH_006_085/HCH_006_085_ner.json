      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000121",
    "sentence": "《詩》云：「殷監不遠，在夏后之世。」願陛下追觀夏、商、周、秦所以失之，以鏡考己行。",
    "entities": [
      {
        "text": "《詩》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000122",
    "sentence": "有不合者，臣當伏妄言之誅！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000123",
    "sentence": "漢興九世，百九十餘載，繼體之主七，皆承天順道，遵先祖法度，或以中興，或以治安。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000124",
    "sentence": "至於陛下，獨違道縱欲，輕身妄行，當盛壯之隆，無繼嗣之福，有危亡之憂，積失君道，不合天意，亦已多矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000125",
    "sentence": "為人後嗣，守人功業，如此，豈不負哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000126",
    "sentence": "方今社稷宗廟禍福安危之機在於陛下，陛下誠肯發明聖之德，昭然遠寤，畏此上天之威怒，深懼危亡之徵兆，蕩滌邪辟之惡志，厲精致政，專心反道，絕群小之私客，免不正之詔除，悉罷北宮私奴車馬惰出之具，克己復禮，毋貳微行出飲之過，以防迫切之禍，深惟日食再既之意，抑損椒房玉堂之盛寵，毋聽後宮之請謁，除掖庭之亂獄，出炮格之陷阱，誅戮邪佞之臣及左右執左道以事上者以塞天下之望，且寑初陵之作，止諸繕治宮室，闕更減賦，盡休力役，存卹振捄困乏之人以弭遠方，厲崇忠直，放退殘賊，無使素餐之吏久尸厚祿，以次貫行，固執無違，夙夜孳孳，婁省無怠，舊衍畢改，新德既章，纖介之邪不復載心，則赫赫大異庶幾可銷，天命去就庶幾可復，社稷宗廟庶幾可保。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000127",
    "sentence": "唯陛下留神反覆，熟省臣言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000128",
    "sentence": "臣幸得備邊部之吏，不知本朝失得，瞽言觸忌諱，罪當萬死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000129",
    "sentence": "成帝性寬而好文辭，又久無繼嗣，數為微行，多近幸小臣，趙、李從微賤專寵，皆皇太后與諸舅夙夜所常憂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000130",
    "sentence": "至親難數言，故推永等使因天變而切諫，勸上納用之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000131",
    "sentence": "永自知有內應，展意無所依違，每言事輒見答禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000132",
    "sentence": "至上此對，上大怒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000133",
    "sentence": "衛將軍商密擿永令發去。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000134",
    "sentence": "上使侍御史收永，敕過交道廄者勿追。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000135",
    "sentence": "御史不及永，還，上意亦解，自悔。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000136",
    "sentence": "明年，徵永為太中大夫，遷光祿大夫給事中。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000137",
    "sentence": "元延元年，為北地太守。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000138",
    "sentence": "時災異尤數，永當之官，上使衛尉淳于長受永所欲言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000139",
    "sentence": "永對曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000140",
    "sentence": "臣永幸得以愚朽之材為太中大夫，備拾遺之臣，從朝者之後，進不能盡思納忠輔宣聖德，退無被堅執銳討不義之功，猥蒙厚恩，仍遷至北地太守。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 61,
        "end": 63
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000141",
    "sentence": "絕命隕首，身膏草野，不足以報塞萬分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000142",
    "sentence": "陛下聖德寬仁，不遺易忘之臣，垂周文之聽，下及芻蕘之愚，有詔使衛尉受臣永所欲言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000143",
    "sentence": "臣聞事君之義，有言責者盡其忠，有官守者修其職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000144",
    "sentence": "臣永幸得免於言責之辜，有官守之任，當畢力遵職，養綏百姓而已，不宜復關得失之辭。",
    "entities": [
      {
        "text": "不宜復關",
        "label": "LOC",
        "start": 30,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000145",
    "sentence": "忠臣之於上，志在過厚，是故遠不違君，死不忘國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000146",
    "sentence": "昔史魚既沒，餘忠未訖，委柩後寑，以屍達誠；汲黯身外思內，發憤舒憂，遺言李息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000147",
    "sentence": "經曰：「雖爾身在外，乃心無不在王室。」臣永幸得給事中出入三年，雖執干戈守邊垂，思慕之心常存於省闥，是以敢越郡吏之職，陳累年之憂。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 28,
        "end": 30
      },
      {
        "text": "是以敢越郡",
        "label": "LOC",
        "start": 49,
        "end": 54
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000148",
    "sentence": "臣聞天生蒸民，不能相治，為立王者以統理之，方制海內非為天子，列土封疆非為諸侯，皆以為民也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000149",
    "sentence": "垂三統，列三正，去無道，開有德，不私一姓，明天下乃天下之天下，非一人之天下也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000150",
    "sentence": "王者躬行道德，承順天地，博愛仁恕，恩及行葦，籍稅取民不過常法，宮室車服不踰制度，事節財足，黎庶和睦，則卦氣理效，五徵時序，百姓壽考，庶屮蕃滋，符瑞並降，以昭保右。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000151",
    "sentence": "失道妄行，逆天暴物，窮奢極欲，湛湎荒淫，婦言是從，誅逐仁賢，離逖骨肉，群小用事，峻刑重賦，百姓愁怨，則卦氣悖亂，咎徵著郵，上天震怒，災異婁降，日月薄食，五星失行，山崩川潰，水泉踊出，妖孽並見，茀星耀光，饑饉荐臻，百姓短折，萬物夭傷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000152",
    "sentence": "終不改寤，惡洽變備，不復譴告，更命有德。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000153",
    "sentence": "《詩》云：「乃眷西顧，此惟予宅。」",
    "entities": [
      {
        "text": "《詩》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000154",
    "sentence": "夫去惡奪弱，遷命賢聖，天地之常經，百王之所同也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000155",
    "sentence": "加以功德有厚薄，期質有修短，時世有中季，天道有盛衰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000156",
    "sentence": "陛下承八世之功業，當陽數之標季，涉三七之節紀，遭无妄之卦運，直百六之災阨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000157",
    "sentence": "三難異科，雜焉同會。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000158",
    "sentence": "建始元年以來二十載間，群災大異，交錯鋒起，多於春秋所書。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000159",
    "sentence": "八世著記，久不塞除，重以今年正月己亥朔日有食之，三朝之會，四月丁酉四方眾星白晝流隕，七月辛未彗星橫天。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000160",
    "sentence": "乘三難之際會，畜眾多之災異，因之以饑饉，接之以不贍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000161",
    "sentence": "彗星，極異也，土精所生，流隕之應出於飢變之後，兵亂作矣，厥期不久，隆德積善，懼不克濟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000162",
    "sentence": "內則為深宮後庭將有驕臣悍妾醉酒狂悖卒起之敗，北宮苑囿街巷之中臣妾之家幽閒之處徵舒、崔杼之亂；外則為諸夏下土將有樊並、蘇令、陳勝、項梁奮臂之禍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000163",
    "sentence": "內亂朝暮，日戒諸夏，舉兵以火角為期。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000164",
    "sentence": "安危之分界，宗廟之至憂，臣永所以破膽寒心，豫言之累年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000165",
    "sentence": "下有其萌，然後變見於上，可不致慎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000166",
    "sentence": "禍起細微，姦生所易。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000167",
    "sentence": "願陛下正君臣之義，無復與群小媟黷燕飲；中黃門後庭素驕慢不謹嘗以醉酒失臣禮者，悉出勿留。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000168",
    "sentence": "勤三綱之嚴，修後宮之政，抑遠驕妒之寵，崇近婉順之行，加惠失志之人，懷柔怨恨之心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000169",
    "sentence": "保至尊之重，秉帝王之威，朝覲法出而後駕，陳兵清道而後行，無復輕身獨出，飲食臣妾之家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000170",
    "sentence": "三者既除，內亂之路塞矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000171",
    "sentence": "諸夏舉兵，萌在民饑饉而吏不卹，興於百姓困而賦斂重，發於下怨離而上不知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000172",
    "sentence": "《易》曰：「屯其膏，小貞吉，大貞凶。」傳曰：「飢而不損茲謂泰，厥災水，厥咎亡。」訞辭曰：「關動牡飛，辟為無道，臣為非，厥咎亂臣謀篡。」王者遭衰難之世，有飢饉之災，不損用而大自潤，故凶；百姓困貧無以共求，愁悲怨恨，故水；城關守國之固，固將去焉，故牡飛。",
    "entities": [
      {
        "text": "《易》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      },
      {
        "text": "城關",
        "label": "LOC",
        "start": 109,
        "end": 111
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000173",
    "sentence": "往年郡國二十一傷於水災，禾黍不入。",
    "entities": [
      {
        "text": "往年郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000174",
    "sentence": "今年蠶麥咸惡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000175",
    "sentence": "百川沸騰，江河溢決，大水泛濫郡國十五有餘。",
    "entities": [
      {
        "text": "大水泛濫郡",
        "label": "LOC",
        "start": 10,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000176",
    "sentence": "比年喪稼，時過無宿麥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000177",
    "sentence": "百姓失業流散，群輩守關。",
    "entities": [
      {
        "text": "群輩守關",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000178",
    "sentence": "大異較炳如彼，水災浩浩，黎庶窮困如此，宜損常稅小自潤之時，而有司奏請加賦，甚繆經義，逆於民心，布怨趨禍之道也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000179",
    "sentence": "牡飛之狀，殆為此發。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000180",
    "sentence": "古者穀不登虧膳，災婁至損服，凶年不塈塗，明王之制也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000181",
    "sentence": "《詩》云：「凡民有喪，扶服捄之。」論語曰：「百姓不足，君孰予足？」臣願陛下勿許加賦之奏，益減大官、導官、中御府、均官、掌畜、廩犧用度，止尚方、織室、京師郡國工服官發輸造作，以助大司農。",
    "entities": [
      {
        "text": "《詩》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      },
      {
        "text": "京師郡",
        "label": "LOC",
        "start": 74,
        "end": 77
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000182",
    "sentence": "流恩廣施，振贍困乏，開關梁，內流民，恣所欲之，以救其急。",
    "entities": [
      {
        "text": "開關",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000183",
    "sentence": "立春，遣使者循行風俗，宣布聖德，存卹孤寡，問民所苦，勞二千石，敕勸耕桑，毋奪農時，以慰綏元元之心，防塞大姦之侽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000184",
    "sentence": "諸夏之亂，庶幾可息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000185",
    "sentence": "臣聞上主可與為善而不可與為惡，下主可與為惡而不可與為善。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000186",
    "sentence": "陛下天然之性，疏通聰敏，上主之姿也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000187",
    "sentence": "少省愚臣之言，感寤三難，深畏大異，定心為善，捐忘邪志，毋貳舊愆，厲精致改，至誠應天，則積異塞於上，禍亂伏於下，何憂患之有？",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000188",
    "sentence": "竊恐陛下公志未專，私好頗存，尚愛群小，不肯為耳！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000189",
    "sentence": "對奏，天子甚感其言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000190",
    "sentence": "永於經書，汎為疏達，與杜欽、杜鄴略等，不能洽浹如劉向父子及揚雄也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000191",
    "sentence": "其於天官、京氏易最密，故善言災異，前後所上四十餘事，略相反覆，專攻上身與後宮而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000192",
    "sentence": "黨於王氏，上亦知之，不甚親信也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000193",
    "sentence": "永所居任職，為北地太守歲餘，衛將軍商薨，曲陽侯根為票騎將軍，薦永，徵入為大司農。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000194",
    "sentence": "歲餘，永病，三月，有司奏請免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000195",
    "sentence": "故事，公卿病，輒賜告，至永獨即時免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000196",
    "sentence": "數月，卒於家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000197",
    "sentence": "本名並，以尉氏樊並反，更名永云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000198",
    "sentence": "杜鄴",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000199",
    "sentence": "杜鄴字子夏，本魏郡繁陽人也。",
    "entities": [
      {
        "text": "本魏郡",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000200",
    "sentence": "祖父及父積功勞皆至郡守，武帝時徙茂陵。",
    "entities": [
      {
        "text": "父積功勞皆至郡",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_085_000201",
    "sentence": "鄴少孤，其母張敞女。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000202",
    "sentence": "鄴壯，從敞子吉學問，得其家書。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000203",
    "sentence": "以孝廉為郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_085_000204",
    "sentence": "與車騎將軍王音善。",
