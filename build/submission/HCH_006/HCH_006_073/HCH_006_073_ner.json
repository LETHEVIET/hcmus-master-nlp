[
  {
    "sentence_id": "HCH_006_073_000001",
    "sentence": "韋賢",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000002",
    "sentence": "韋賢字長孺，魯國鄒人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000003",
    "sentence": "其先韋孟，家本彭城，為楚元王傅，傅子夷王及孫王戊。",
    "entities": [
      {
        "text": "家本彭城",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000004",
    "sentence": "戊荒淫不遵道，孟作詩風諫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000005",
    "sentence": "後遂去位，徙家於鄒，又作一篇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000006",
    "sentence": "其諫詩曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000007",
    "sentence": "肅肅我祖，國自豕韋，黼衣朱紱，四牡龍旂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000008",
    "sentence": "彤弓斯征，撫寧遐荒，總齊群邦，以翼大商，迭彼大彭，勳績惟光。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000009",
    "sentence": "至于有周，歷世會同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000010",
    "sentence": "王赧聽譖，寔絕我邦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000011",
    "sentence": "我邦既絕，厥政斯逸，賞罰之行，非繇王室。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000012",
    "sentence": "庶尹群后，靡扶靡衛，五服崩離，宗周以隊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000013",
    "sentence": "我祖斯微，遷于彭城，在予小子，勤誒厥生，阨此嫚秦，耒耜以耕。",
    "entities": [
      {
        "text": "遷于彭城",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000014",
    "sentence": "悠悠嫚秦，上天不寧，乃眷南顧，授漢于京。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000015",
    "sentence": "於赫有漢，四方是征，靡適不懷，萬國逌平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000016",
    "sentence": "乃命厥弟，建侯於楚，俾我小臣，惟傅是輔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000017",
    "sentence": "兢兢元王，恭儉淨壹，惠此黎民，納彼輔弼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000018",
    "sentence": "饗國漸世，垂烈于後，乃及夷王，克奉厥緒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000019",
    "sentence": "咨命不永，唯王統祀，左右陪臣，此惟皇士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000020",
    "sentence": "如何我王，不思守保，不惟履冰，以繼祖考！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000021",
    "sentence": "邦事是廢，逸游是娛，犬馬繇繇，是放是驅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000022",
    "sentence": "務彼鳥獸，忽此稼苗，烝民以匱，我王以媮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000023",
    "sentence": "所弘非德，所親非俊，唯囿是恢，唯諛是信。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000024",
    "sentence": "睮睮諂夫，咢咢黃髮，如何我王，曾不是察！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000025",
    "sentence": "既藐下臣，追欲從逸，嫚彼顯祖，輕茲削黜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000026",
    "sentence": "嗟嗟我王，漢之睦親，曾不夙夜，以休令聞！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000027",
    "sentence": "穆穆天子，臨爾下土，明明群司，執憲靡顧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000028",
    "sentence": "正遐繇近，殆其怙茲，嗟嗟我王，曷不此思！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000029",
    "sentence": "非思非鑒，嗣其罔則，彌彌其失，岌岌其國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000030",
    "sentence": "致冰匪霜，致隊靡嫚，瞻惟我王，昔靡不練。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000031",
    "sentence": "興國救顛，孰違悔過，追思黃髮，秦繆以霸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000032",
    "sentence": "歲月其徂，年其逮耇，於昔君子，庶顯于後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000033",
    "sentence": "我王如何，曾不斯覽！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000034",
    "sentence": "黃髮不近，胡不時監！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000035",
    "sentence": "其在鄒詩曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000036",
    "sentence": "微微小子，既耇且陋，豈不牽位，穢我王朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000037",
    "sentence": "王朝肅清，唯俊之庭，顧瞻余躬，懼穢此征。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000038",
    "sentence": "我之退征，請于天子，天子我恤，矜我髮齒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000039",
    "sentence": "赫赫天子，明悊且仁，懸車之義，以洎小臣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000040",
    "sentence": "嗟我小子，豈不懷土？",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000041",
    "sentence": "庶我王寤，越遷于魯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000042",
    "sentence": "既去禰祖，惟懷惟顧，祁祁我徒，戴負盈路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000043",
    "sentence": "爰戾于鄒，鬋茅作堂，我徒我環，築室于牆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000044",
    "sentence": "我既讓逝，心存我舊，夢我瀆上，立于王朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000045",
    "sentence": "其夢如何？",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000046",
    "sentence": "夢爭王室。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000047",
    "sentence": "其爭如何？",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000048",
    "sentence": "夢王我弼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000049",
    "sentence": "寤其外邦，歎其喟然，念我祖考，泣涕其漣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000050",
    "sentence": "微微老夫，咨既遷絕，洋洋仲尼，視我遺烈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000051",
    "sentence": "濟濟鄒魯，禮義唯恭，誦習弦歌，于異他邦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000052",
    "sentence": "我雖鄙耇，心其好而，我徒侃爾，樂亦在而。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000053",
    "sentence": "孟卒于鄒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000054",
    "sentence": "或曰其子孫好事，述先人之志而作是詩也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000055",
    "sentence": "自孟至賢五世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000056",
    "sentence": "賢為人質朴少欲，篤志於學，兼通禮、尚書，以詩教授，號稱鄒魯大儒。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000057",
    "sentence": "徵為博士，給事中，進授昭帝詩，稍遷光祿大夫詹事，至大鴻臚。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000058",
    "sentence": "昭帝崩，無嗣，大將軍霍光與公卿共尊立孝宣帝。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000059",
    "sentence": "帝初即位，賢以與謀議，安宗廟，賜爵關內侯，食邑。",
    "entities": [
      {
        "text": "賜爵關",
        "label": "LOC",
        "start": 15,
        "end": 18
      },
      {
        "text": "食邑",
        "label": "LOC",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000060",
    "sentence": "徙為長信少府。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000061",
    "sentence": "以先帝師，甚見尊重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000062",
    "sentence": "本始三年，代蔡義為丞相，封扶陽侯，食邑七百戶。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "食邑",
        "label": "LOC",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000063",
    "sentence": "時賢七十餘，為相五歲，地節三年以老病乞骸骨，賜黃金百斤，罷歸，加賜弟一區。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000064",
    "sentence": "丞相致仕自賢始。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000065",
    "sentence": "年八十二薨，諡曰節侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000066",
    "sentence": "賢四子：長子方山為高寢令，早終；次子弘，至東海太守；次子舜，留魯守墳墓；少子玄成，復以明經歷位至丞相。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 23,
        "end": 25
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 48,
        "end": 50
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000067",
    "sentence": "故鄒魯諺曰：「遺子黃金滿籯，不如一經。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000068",
    "sentence": "玄成字少翁，以父任為郎，常侍騎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000069",
    "sentence": "少好學，修父業，尤謙遜下士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000070",
    "sentence": "出遇知識步行，輒下從者，與載送之，以為常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000071",
    "sentence": "其接人，貧賤者益加敬，繇是名譽日廣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000072",
    "sentence": "以明經擢為諫大夫，遷大河都尉。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000073",
    "sentence": "初，玄成兄弘為太常丞，職奉宗廟，典諸陵邑，煩劇多罪過。",
    "entities": [
      {
        "text": "典諸陵邑",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000074",
    "sentence": "父賢以弘當為嗣，故敕令自免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000075",
    "sentence": "弘懷謙，不去官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000076",
    "sentence": "及賢病篤，弘竟坐宗廟事繫獄，罪未決。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000077",
    "sentence": "室家問賢當為後者，賢恚恨不肯言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000078",
    "sentence": "於是賢門下生博士義倩等與宗家計議，共矯賢令，使家丞上書言大行，以大河都尉玄成為後。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000079",
    "sentence": "賢薨，玄成在官聞喪，又言當為嗣，玄成深知其非賢雅意，即陽為病狂，臥便利，妄笑語昏亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000080",
    "sentence": "徵至長安，既葬，當襲爵，以病狂不應召。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000081",
    "sentence": "大鴻臚奉狀，章下丞相御史案驗。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000082",
    "sentence": "玄成素有名聲，士大夫多疑其欲讓爵辟兄者。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000083",
    "sentence": "案事丞相史乃與玄成書曰：「古之辭讓，必有文義可觀，故能垂榮於後。今子獨壞容貌，蒙恥辱，為狂癡，光曜晻而不宣。微哉！子之所託名也。僕素愚陋，過為宰相執事，願少聞風聲。不然，恐子傷高而僕為小人也。」玄成友人侍郎章亦上疏言：「聖王貴以禮讓為國，宜優養玄成，勿枉其志，使得自安衡門之下。」而丞相御史遂以玄成實不病，劾奏之。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 101,
        "end": 103
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 141,
        "end": 143
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 143,
        "end": 145
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000084",
    "sentence": "有詔勿劾，引拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000085",
    "sentence": "玄成不得已受爵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000086",
    "sentence": "宣帝高其節，以玄成為河南太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000087",
    "sentence": "兄弘太山都尉，遷東海太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000088",
    "sentence": "數歲，玄成徵為未央衛尉，遷太常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000089",
    "sentence": "坐與故平通侯楊惲厚善，惲誅，黨友皆免官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000090",
    "sentence": "後以列侯侍祀孝惠廟，當晨入廟，天雨淖，不駕駟馬車而騎至廟下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000091",
    "sentence": "有司劾奏，等輩數人皆削爵為關內侯。",
    "entities": [
      {
        "text": "數人皆削爵為關",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000092",
    "sentence": "玄成自傷貶黜父爵，歎曰：「吾何面目以奉祭祀！」作詩自劾責，曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000093",
    "sentence": "赫矣我祖，侯于豕韋，賜命建伯，有殷以綏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000094",
    "sentence": "厥績既昭，車服有常，朝宗商邑，四牡翔翔。",
    "entities": [
      {
        "text": "朝宗商邑",
        "label": "LOC",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000095",
    "sentence": "德之令顯，慶流于裔，宗周至漢，群后歷世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000096",
    "sentence": "肅肅楚傅，輔翼元、夷，厥駟有庸，惟慎惟祗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000097",
    "sentence": "嗣王孔佚，越遷于鄒，五世壙僚，至我節侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000098",
    "sentence": "惟我節侯，顯德遐聞，左右昭、宣，五品以訓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000099",
    "sentence": "既耇致位，惟懿惟奐，厥賜祁祁，百金洎館。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000100",
    "sentence": "國彼扶陽，在京之東，惟帝是留，政謀是從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000101",
    "sentence": "繹繹六轡，是列是理，威儀濟濟，朝享天子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000102",
    "sentence": "天子穆穆，是宗是師，四方遐爾，觀國之煇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000103",
    "sentence": "茅土之繼，在我俊兄，惟我俊兄，是讓是形。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000104",
    "sentence": "於休厥德，於赫有聲，致我小子，越留於京。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000105",
    "sentence": "惟我小子，不肅會同，惮彼車服，黜此附庸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000106",
    "sentence": "赫赫顯爵，自我隊之；微微附庸，自我招之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000107",
    "sentence": "誰能忍媿，寄之我顏；誰將遐征，從之夷蠻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000108",
    "sentence": "於赫三事，匪俊匪作，於蔑小子，終焉其度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000109",
    "sentence": "誰謂華高，企其齊而；誰謂德難，厲其庶而。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000110",
    "sentence": "嗟我小子，于貳其尤，隊彼令聲，申此擇辭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000111",
    "sentence": "四方群后，我監我視，威儀車服，唯肅是履！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000112",
    "sentence": "初，宣帝寵姬張婕妤男淮陽憲王好政事，通法律，上奇其材，有意欲以為嗣，然用太子起於細微，又早失母，故不忍也。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 36,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000113",
    "sentence": "久之，上欲感風憲王，輔以禮讓之臣，乃召拜玄成為淮陽中尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000114",
    "sentence": "是時王未就國，玄成受詔，與太子太傅蕭望之及五經諸儒雜論同異於石渠閣，條奏其對。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "蕭望之",
        "label": "PER",
        "start": 17,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000115",
    "sentence": "及元帝即位，以玄成為少府，遷太子太傅，至御史大夫。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 20,
        "end": 22
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000116",
    "sentence": "永光中，代于定國為丞相。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000117",
    "sentence": "貶黜十年之間，遂繼父相位，封侯故國，榮當世焉。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000118",
    "sentence": "玄成復作詩，自著復玷缺之艱難，因以戒示子孫，曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000119",
    "sentence": "於肅君子，既令厥德，儀服此恭，棣棣其則。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000120",
    "sentence": "咨余小子，既德靡逮，曾是車服，荒嫚以隊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000121",
    "sentence": "明明天子，俊德烈烈，不遂我遺，恤我九列。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000122",
    "sentence": "我既茲恤，惟夙惟夜，畏忌是申，供事靡惰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000123",
    "sentence": "天子我監，登我三事，顧我傷隊，爵復我舊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000124",
    "sentence": "我既此登，望我舊階，先后茲度，漣漣孔懷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000125",
    "sentence": "司直御事，我熙我盛；群公百僚，我嘉我慶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000126",
    "sentence": "于異卿士，非同我心，三事惟谡，莫我肯矜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000127",
    "sentence": "赫赫三事，力雖此畢，非吾所度，退其罔日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000128",
    "sentence": "昔我之隊，畏不此居，今我度茲，戚戚其懼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000129",
    "sentence": "嗟我後人，命其靡常，靖享爾位，瞻仰靡荒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000130",
    "sentence": "慎爾會同，戒爾車服，無惰爾儀，以保爾域。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000131",
    "sentence": "爾無我視，不慎不整；我之此復，惟祿之幸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000132",
    "sentence": "於戲後人，惟肅惟栗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000133",
    "sentence": "無忝顯祖，以蕃漢室！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000134",
    "sentence": "玄成為相七年，守正持重不及父賢，而文采過之。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000135",
    "sentence": "建昭三年薨，諡曰共侯。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000136",
    "sentence": "初，賢以昭帝時徙平陵，玄成別徙杜陵，病且死，因使者自白曰：「不勝父子恩，願乞骸骨，歸葬父墓。」上許焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000137",
    "sentence": "子頃侯寬嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000138",
    "sentence": "薨，子僖侯育嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000139",
    "sentence": "薨，子節侯沈嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000140",
    "sentence": "自賢傳國至玄孫乃絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000141",
    "sentence": "玄成兄高寢令方山子安世歷郡守，大鴻臚，長樂衛尉，朝廷稱有宰相之器，會其病終。",
    "entities": [
      {
        "text": "方山子安世歷郡",
        "label": "LOC",
        "start": 6,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000142",
    "sentence": "而東海太守弘子賞亦明詩。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000143",
    "sentence": "哀帝為定陶王時，賞為太傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000144",
    "sentence": "哀帝即位，賞以舊恩為大司馬車騎將軍，列為三公，賜爵關內侯，食邑千戶，亦年八十餘，以壽終。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "賜爵關",
        "label": "LOC",
        "start": 23,
        "end": 26
      },
      {
        "text": "食邑",
        "label": "LOC",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000145",
    "sentence": "宗族至吏二千石者十餘人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000146",
    "sentence": "初，高祖時，令諸侯王都皆立太上皇廟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000147",
    "sentence": "至惠帝尊高帝廟為太祖廟，景帝尊孝文廟為太宗廟，行所嘗幸郡國各立太祖、太宗廟。",
    "entities": [
      {
        "text": "行所嘗幸郡",
        "label": "LOC",
        "start": 23,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000148",
    "sentence": "至宣帝本始二年，復尊孝武廟為世宗廟，行所巡狩亦立焉。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000149",
    "sentence": "凡祖宗廟在郡國六十八，合百六十七所。",
    "entities": [
      {
        "text": "凡祖宗廟在郡",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000150",
    "sentence": "而京師自高祖下至宣帝，與太上皇、悼皇考各自居陵旁立廟，并為百七十六。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000151",
    "sentence": "又園中各有寢、便殿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000152",
    "sentence": "日祭於寢，月祭於廟，時祭於便殿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000153",
    "sentence": "寢，日四上食；廟，歲二十五祠；便殿，歲四祠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000154",
    "sentence": "又月一游衣冠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000155",
    "sentence": "而昭靈后、武哀王、昭哀后、孝文太后、孝昭太后、衛思后、戾太子、戾后各有寢園，與諸帝合，凡三十所。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000156",
    "sentence": "一歲祠，上食二萬四千四百五十五，用衛士四萬五千一百二十九人，祝宰樂人萬二千一百四十七人，養犧牲卒不在數中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_073_000157",
    "sentence": "至元帝時，貢禹奏言：「古者天子七廟，今孝惠、孝景廟皆親盡，宜毀。及郡國廟不應古禮，宜正定。」天子是其議，未及施行而禹卒。",
    "entities": [
      {
        "text": "及郡",
        "label": "LOC",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_006_073_000158",
    "sentence": "永光四年，乃下詔先議罷郡國廟，曰：「朕聞明王之御世也，遭時為法，因事制宜。往者天下初定，遠方未賓，因嘗所親以立宗廟，蓋建威銷萌，一民之至權也。今賴天地之靈，宗廟之福，四方同軌，蠻貊貢職，久遵而不定，令疏遠卑賤共承尊祀，殆非皇天祖宗之意，朕甚懼焉。傳不云乎？『吾不與祭，如不祭。』其與將軍、列侯、中二千石、二千石、諸大夫、博士、議郎議。」丞相玄成、御史大夫鄭弘、太子太傅嚴彭祖、少府歐陽地餘、諫大夫尹更始等七十人皆曰：「臣聞祭，非自外至者也，繇中出，生於心也。故唯聖人為能饗帝，孝子為能饗親。立廟京師之居，躬親承事，四海之內各以其職來助祭，尊親之大義，五帝三王所共，不易之道也。《詩》云：『有來雍雍，至止肅肅，相維辟公，天子穆穆。』春秋之義，父不祭於支庶之宅，君不祭於臣僕之家，王不祭於下土諸侯。臣等愚以為宗廟在郡國，宜無修，臣請勿復修。」奏可。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "乃下詔先議罷郡",
        "label": "LOC",
        "start": 5,
        "end": 12
      },
      {
        "text": "將軍",
        "label": "TITLE",
