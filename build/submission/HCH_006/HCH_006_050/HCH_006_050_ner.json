[
  {
    "sentence_id": "HCH_006_050_000001",
    "sentence": "張釋之",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000002",
    "sentence": "張釋之字季，南陽堵陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000003",
    "sentence": "與兄仲同居，以貲為騎郎，事文帝，十年不得調，亡所知名。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000004",
    "sentence": "釋之曰：「久宦減仲之產，不遂。」欲免歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000005",
    "sentence": "中郎將爰盎知其賢，惜其去，乃請徙釋之補謁者。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000006",
    "sentence": "釋之既朝畢，因前言便宜事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000007",
    "sentence": "文帝曰：「卑之，毋甚高論，令今可行也。」於是釋之言秦漢之間事，秦所以失，漢所以興者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000008",
    "sentence": "文帝稱善，拜釋之為謁者僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000009",
    "sentence": "從行，上登虎圈，問上林尉禽獸簿，十餘問，尉左右視，盡不能對。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000010",
    "sentence": "虎圈嗇夫從旁代尉對上所問禽獸簿甚悉，欲以觀其能口對嚮應亡窮者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000011",
    "sentence": "文帝曰：「吏不當如此邪？尉亡賴！」詔釋之拜嗇夫為上林令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000012",
    "sentence": "釋之前曰：「陛下以絳侯周勃何如人也？」上曰：「長者。」又復問：「東陽侯張相如何如人也？」上復曰：「長者。」釋之曰：「夫絳侯、東陽侯稱為長者，此兩人言事曾不能出口，豈效此嗇夫喋喋利口捷給哉！且秦以任刀筆之吏，爭以亟疾苛察相高，其敝徒文具，亡惻隱之實。以故不聞其過，陵夷至於二世，天下土崩。今陛下以嗇夫口辯而超遷之，臣恐天下隨風靡，爭口辯，亡其實。且下之化上，疾於景嚮，舉錯不可不察也。」文帝曰：「善。」乃止不拜嗇夫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000013",
    "sentence": "就車，召釋之驂乘，徐行，行問釋之秦之敝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000014",
    "sentence": "具以質言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000015",
    "sentence": "至宮，上拜釋之為公車令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000016",
    "sentence": "頃之，太子與梁王共車入朝，不下司馬門，於是釋之追止太子、梁王毌入殿門。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000017",
    "sentence": "遂劾不下公門不敬，奏之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000018",
    "sentence": "薄太后聞之，文帝免冠謝曰：「教兒子不謹。」薄太后使使承詔赦太子、梁王，然後得入。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000019",
    "sentence": "文帝繇是奇釋之，拜為中大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000020",
    "sentence": "頃之，至中郎將。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000021",
    "sentence": "從行至霸陵，上居外臨廁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000022",
    "sentence": "時慎夫人從，上指視慎夫人新豐道，曰：「此走邯鄲道也。」使慎夫人鼓瑟，上自倚瑟而歌，意悽愴悲懷，顧謂群臣曰：「嗟乎！以北山石為槨，用紵絮斮陳漆其間，豈可動哉！」左右皆曰：「善。」釋之前曰：「使其中有可欲，雖錮南山猶有隙；使其中亡可欲，雖亡石槨，又何戚焉？」文帝稱善。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000023",
    "sentence": "其後，拜釋之為廷尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000024",
    "sentence": "頃之，上行出中渭橋，有一人從橋下走，乘輿馬驚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000025",
    "sentence": "於是使騎捕之，屬廷尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000026",
    "sentence": "釋之治問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000027",
    "sentence": "曰：「縣人來，聞蹕，匿橋下。久，以為行過，既出，見車騎，即走耳。」釋之奏當：「此人犯蹕，當罰金。」上怒曰：「此人親驚吾馬，馬賴和柔，令它馬，固不敗傷我乎？而廷尉乃當之罰金！」釋之曰：「法者天子所與天下公共也。今法如是，更重之，是法不信於民也。且方其時，上使使誅之則已。今已下廷尉，廷尉，天下之平也，壹傾，天下用法皆為之輕重，民安所錯其手足？唯陛下察之。」上良久曰：「廷尉當是也。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000028",
    "sentence": "其後人有盜高廟座前玉環，得，文帝怒，下廷尉治。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000029",
    "sentence": "案盜宗廟服御物者為奏，當棄市。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000030",
    "sentence": "上大怒曰：「人亡道，乃盜先帝器！吾屬廷尉者，欲致之族，而君以法奏之，非吾所以共承宗廟意也。」釋之免冠頓首謝曰：「法如是足也。且罪等，然以逆順為基。今盜宗廟器而族之，有如萬分一，假令愚民取長陵一抔土，陛下且何以加其法虖？」文帝與太后言之，乃許廷尉當。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000031",
    "sentence": "是時，中尉條侯周亞夫與梁相山都侯王恬咸見釋之持議平，乃結為親友。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000032",
    "sentence": "張廷尉繇此天下稱之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000033",
    "sentence": "文帝崩，景帝立，釋之恐，稱疾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000034",
    "sentence": "欲免去，懼大誅至；欲見，則未知何如。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000035",
    "sentence": "用王生計，卒見謝，景帝不過也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000036",
    "sentence": "王生者，善為黃老言，處士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000037",
    "sentence": "嘗召居廷中，公卿盡會立，王生老人，曰「吾韤解」，顧謂釋之：「為我結韤！」釋之跪而結之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000038",
    "sentence": "既已，人或讓王生：「獨柰何廷辱張廷尉如此？」王生曰：「吾老且賤，自度終亡益於張廷尉。廷尉方天下名臣，吾故聊使結韤，欲以重之。」諸公聞之，賢王生而重釋之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000039",
    "sentence": "釋之事景帝歲餘，為淮南相，猶尚以前過也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000040",
    "sentence": "年老病卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000041",
    "sentence": "其子摯，字長公，官至大夫，免。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000042",
    "sentence": "以不能取容當世，故終身不仕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000043",
    "sentence": "馮唐",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000044",
    "sentence": "馮唐，祖父趙人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000045",
    "sentence": "父徙代。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000046",
    "sentence": "漢興徙安陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000047",
    "sentence": "唐以孝著，為郎中署長，事文帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000048",
    "sentence": "帝輦過，問唐曰：「父老何自為郎？家安在？」具以實言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000049",
    "sentence": "文帝曰：「吾居代時，吾尚食監高祛數為我言趙將李齊之賢，戰於鉅鹿下。吾每飲食，意未嘗不在鉅鹿也。父老知之乎？」唐對曰：「齊尚不如廉頗、李牧之為將也。」上曰：「何已？」唐曰：「臣大父在趙時，為官帥將，善李牧。臣父故為代相，善李齊，知其為人也。」上既聞廉頗、李牧為人，良說，乃拊髀曰：「嗟乎！吾獨不得廉頗、李牧為將，豈憂匈奴哉！」唐曰：「主臣！陛下雖有廉頗、李牧，不能用也。」上怒，起入禁中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000050",
    "sentence": "良久，召唐讓曰：「公眾辱我，獨亡間處虖？」唐謝曰：「鄙人不知忌諱。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000051",
    "sentence": "當是時，匈奴新大入朝那，殺北地都尉卬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000052",
    "sentence": "上以胡寇為意，乃卒復問唐曰：「公何以言吾不能用頗、牧也？」唐對曰：「臣聞上古王者遣將也，跪而推轂，曰：『闑以內寡人制之，闑以外將軍制之；軍功爵賞，皆決於外，歸而奏之。』此非空言也。臣大父言李牧之為趙將居邊，軍市之租皆自用饗士，賞賜決於外，不從中覆也。委任而責成功，故李牧乃得盡其知能，選車千三百乘，彀騎萬三千匹，百金之士十萬，是以北逐單于，破東胡，滅澹林，西抑彊秦，南支韓、魏。當是時，趙幾伯。後會趙王遷立，其母倡也，用郭開讒，而誅李牧，令顏聚代之。是以為秦所滅。今臣竊聞魏尚為雲中守，軍市租盡以給士卒，出私養錢，五日壹殺牛，以饗賓客軍吏舍人，是以匈奴遠避，不近雲中之塞。虜嘗一入，尚帥車騎擊之，所殺甚眾。夫士卒盡家人子，起田中從軍，安知尺籍伍符？終日力戰，斬首捕虜，上功莫府，一言不相應，文吏以法繩之。其賞不行，吏奉法必用。愚以為陛下法太明，賞太輕，罰太重。且雲中守尚坐上功首虜差六級，陛下下之吏，削其爵，罰作之。繇此言之，陛下雖得李牧，不能用也。臣誠愚，觸忌諱，死罪！」文帝說。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 63,
        "end": 65
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000053",
    "sentence": "是日，令唐持節赦魏尚，復以為雲中守，而拜唐為車騎都尉，主中尉及郡國車士。",
    "entities": [
      {
        "text": "主中尉及郡",
        "label": "LOC",
        "start": 27,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000054",
    "sentence": "十年，景帝立，以唐為楚相。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000055",
    "sentence": "武帝即位，求賢良，舉唐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000056",
    "sentence": "唐時年九十餘，不能為官，乃以子遂為郎。",
    "entities": [
      {
        "text": "唐",
        "label": "ORG",
        "start": 0,
        "end": 1
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000057",
    "sentence": "遂字王孫，亦奇士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000058",
    "sentence": "魏尚，槐里人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000059",
    "sentence": "汲黯",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000060",
    "sentence": "汲黯字長孺，濮陽人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000061",
    "sentence": "其先有寵於古之衛君也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000062",
    "sentence": "至黯十世，世為卿大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000063",
    "sentence": "以父任，孝景時為太子洗馬，以嚴見憚。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000064",
    "sentence": "武帝即位，黯為謁者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000065",
    "sentence": "東粵相攻，上使黯往視之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000066",
    "sentence": "至吳而還，報曰：「粵人相攻，固其俗，不足以辱天子使者。」河內失火，燒千餘家，上使黯往視之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000067",
    "sentence": "還報曰：「家人失火，屋比延燒，不足憂。臣過河內，河內貧人傷水旱萬餘家，或父子相食，臣謹以便宜，持節發河內倉粟以振貧民。請歸節，伏矯制罪。」上賢而釋之，遷為滎陽令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000068",
    "sentence": "黯恥為令，稱疾歸田里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000069",
    "sentence": "上聞，乃召為中大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000070",
    "sentence": "以數切諫，不得久留內，遷為東海太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000071",
    "sentence": "黯學黃老言，治官民，好清靜，擇丞史任之，責大指而已，不細苛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000072",
    "sentence": "黯多病，臥閤內不出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000073",
    "sentence": "歲餘，東海大治，稱之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000074",
    "sentence": "上聞，召為主爵都尉，列於九卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000075",
    "sentence": "治務在無為而已，引大體，不拘文法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000076",
    "sentence": "為人性倨，少禮，面折，不能容人之過。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000077",
    "sentence": "合己者善待之，不合者弗能忍見，士亦以此不附焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000078",
    "sentence": "然好游俠，任氣節，行修潔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000079",
    "sentence": "其諫，犯主之顏色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000080",
    "sentence": "常慕傅伯、爰盎之為人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000081",
    "sentence": "善灌夫、鄭當時及宗正劉棄疾。",
    "entities": [
      {
        "text": "鄭當時",
        "label": "PER",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000082",
    "sentence": "亦以數直諫，不得久居位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000083",
    "sentence": "是時，太后弟武安侯田蚡為丞相，中二千石拜謁，蚡弗為禮。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000084",
    "sentence": "黯見蚡，未嘗拜，揖之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000085",
    "sentence": "上方招文學儒者，上曰吾欲云云，黯對曰：「陛下內多欲而外施仁義，柰何欲效唐虞之治乎！」上怒，變色而罷朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000086",
    "sentence": "公卿皆為黯懼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000087",
    "sentence": "上退，謂人曰：「甚矣，汲黯之戇也！」群臣或數黯，黯曰：「天子置公卿輔弼之臣，寧令從諛承意，陷主於不誼虖？且已在其位，縱愛身，柰辱朝廷何！」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000088",
    "sentence": "黯多病，病且滿三月，上常賜告者數，終不瘉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000089",
    "sentence": "最後，嚴助為請告。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000090",
    "sentence": "上曰：「汲黯何如人也？」曰：「使黯任職居官，亡以瘉人，然至其輔少主守成，雖自謂賁育弗能奪也。」上曰：「然。古有社稷之臣，至如汲黯，近之矣。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000091",
    "sentence": "大將軍青侍中，上踞廁視之。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000092",
    "sentence": "丞相弘宴見，上或時不冠。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000093",
    "sentence": "至如見黯，不冠不見也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000094",
    "sentence": "上嘗坐武帳，黯前奏事，上不冠，望見黯，避帷中，使人可其奏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000095",
    "sentence": "其見敬禮如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000096",
    "sentence": "張湯以更定律令為廷尉，黯質責湯於上前，曰：「",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000097",
    "sentence": "公為正卿，上不能褒先帝之功業，下不能化天下之邪心，安國富民，使囹圄空虛，何空取高皇帝約束紛更之為？",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 40,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000098",
    "sentence": "而公以此無種矣！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000099",
    "sentence": "」黯時與湯論議，湯辯常在文深小苛，黯憤發，罵曰：「天下謂刀筆吏不可謂公卿，果然。必湯也，令天下重足而立，仄目而視矣！」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000100",
    "sentence": "是時，漢方征匈奴，招懷四夷，黯務少事，間常言與胡和親，毋起兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000101",
    "sentence": "上方鄉儒術，尊公孫弘，及事益多，吏民巧。",
    "entities": [
      {
        "text": "上方鄉",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "公孫弘",
        "label": "PER",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000102",
    "sentence": "上分別文法，湯等數奏決讞以幸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000103",
    "sentence": "而黯常毀儒，面觸弘等徒懷詐飾智以阿人主取容，而刀筆之吏專深文巧詆，陷人於罔，以自為功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000104",
    "sentence": "上愈益貴弘、湯，弘、湯心疾黯，雖上亦不說也，欲誅之以事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000105",
    "sentence": "弘為丞相，乃言上曰：「右內史界部中多貴人宗室，難治，非素重臣弗能任，請徙黯為右內史。」數歲，官事不廢。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000106",
    "sentence": "大將軍青既益尊，姊為皇后，然黯與亢禮。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 0,
        "end": 3
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000107",
    "sentence": "或說黯曰：「自天子欲令群臣下大將軍，大將軍尊貴，誠重，君不可以不拜。」黯曰：「夫以大將軍有揖客，反不重耶？」大將軍聞，愈賢黯，數請問以朝廷所疑，遇黯加於平日。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 14,
        "end": 17
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 18,
        "end": 21
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 41,
        "end": 44
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 54,
        "end": 57
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000108",
    "sentence": "淮南王謀反，憚黯，曰：「黯好直諫，守節死義；至說公孫弘等，如發蒙耳。」",
    "entities": [
      {
        "text": "公孫弘",
        "label": "PER",
        "start": 24,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000109",
    "sentence": "上既數征匈奴有功，黯言益不用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000110",
    "sentence": "始黯列九卿矣，而公孫弘、張湯為小吏。",
    "entities": [
      {
        "text": "公孫弘",
        "label": "PER",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000111",
    "sentence": "及弘、湯稍貴，與黯同位，黯又非毀弘、湯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000112",
    "sentence": "已而弘至丞相封侯，湯御史大夫，黯時丞史皆與同列，或尊用過之。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000113",
    "sentence": "黯褊心，不能無少望，見上，言曰：「",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000114",
    "sentence": "陛下用群臣如積薪耳，後來者居上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000115",
    "sentence": "」黯罷，上曰：「人果不可以無學，觀汲黯之言，日益甚矣。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000116",
    "sentence": "居無何，匈奴渾邪王帥眾來降，漢發車二萬乘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000117",
    "sentence": "縣官亡錢，從民貰馬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000118",
    "sentence": "民或匿馬，馬不具。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000119",
    "sentence": "上怒，欲斬長安令。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000120",
    "sentence": "黯曰：「長安令亡罪，獨斬臣黯，民乃肯出馬。且匈奴畔其主而降漢，徐以縣次傳之，何至令天下騷動，罷中國，甘心夷狄之人乎！」上默然。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "徐以縣",
        "label": "LOC",
        "start": 31,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000121",
    "sentence": "後渾邪王至，賈人與市者，坐當死五百餘人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000122",
    "sentence": "黯入，請間，見高門，曰：「夫匈奴攻當路塞，絕和親，中國舉兵誅之，死傷不可勝計，而費以鉅萬百數。臣愚以為陛下得胡人，皆以為奴婢，賜從軍死者家；鹵獲，因與之，以謝天下，塞百姓之心。今縱不能，渾邪帥數萬之眾來，虛府庫賞賜，發良民侍養，若奉驕子。愚民安知市買長安中而文吏繩以為闌出財物如邊關乎？陛下縱不能得匈奴之贏以謝天下，又以微文殺無知者五百餘人，臣竊為陛下弗取也。」上弗許，曰：「吾久不聞汲黯之言，今又復妄發矣。」後數月，黯坐小法，會赦，免官。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 125,
        "end": 127
      },
      {
        "text": "闌出財物如邊關",
        "label": "LOC",
        "start": 134,
        "end": 141
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000123",
    "sentence": "於是黯隱於田園者數年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000124",
    "sentence": "會更立五銖錢，民多盜鑄錢者，楚地尤甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000125",
    "sentence": "上以為淮陽，楚地之郊也，召黯拜為淮陽太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000126",
    "sentence": "黯伏謝不受印綬，詔數強予，然後奉詔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000127",
    "sentence": "召上殿，黯泣曰：「臣自以為填溝壑，不復見陛下，不意陛下復收之。臣常有狗馬之心，今病，力不能任郡事。臣願為中郎，出入禁闥，補過拾遺，臣之願也。」上曰：「君薄淮陽邪？吾今召君矣。顧淮陽吏民不相得，吾徒得君重，臥而治之。」黯既辭，過大行李息，曰：「黯棄逐居郡，不得與朝廷議矣。然御史大夫湯智足以距諫，詐足以飾非，非肯正為天下言，專阿主意。主意所不欲，因而毀之；主意所欲，因而譽之。好興事，舞文法，內懷詐以御主心，外挾賊吏以為重。公列九卿不早言之何？公與之俱受其戮矣！」息畏湯，終不敢言。",
    "entities": [
      {
        "text": "力不能任郡",
        "label": "LOC",
        "start": 42,
        "end": 47
      },
      {
        "text": "黯棄逐居郡",
        "label": "LOC",
        "start": 121,
        "end": 126
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 136,
        "end": 138
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 138,
        "end": 140
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000128",
    "sentence": "黯居郡如其故治，淮陽政清。",
    "entities": [
      {
        "text": "黯居郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000129",
    "sentence": "後張湯敗，上聞黯與息言，抵息罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000130",
    "sentence": "令黯以諸侯相秩居淮陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000131",
    "sentence": "居淮陽十歲而卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000132",
    "sentence": "卒後，上以黯故，官其弟仁至九卿，子偃至諸侯相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000133",
    "sentence": "黯姊子司馬安亦少與黯為太子洗馬。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000134",
    "sentence": "安文深巧善宦，四至九卿，以河南太守卒。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000135",
    "sentence": "昆弟以安故，同時至二千石十人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000136",
    "sentence": "濮陽段宏始事蓋侯信，信任宏，官亦再至九卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000137",
    "sentence": "然衛人仕者皆嚴憚汲黯，出其下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000138",
    "sentence": "鄭當時",
    "entities": [
      {
        "text": "鄭當時",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000139",
    "sentence": "鄭當時字莊，陳人也。",
    "entities": [
      {
        "text": "鄭當時",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000140",
    "sentence": "其先鄭君嘗事項籍，籍死而屬漢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000141",
    "sentence": "高祖令諸故項籍臣名籍，鄭君獨不奉詔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000142",
    "sentence": "詔盡拜名籍者為大夫，而逐鄭君。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000143",
    "sentence": "鄭君死孝文時。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000144",
    "sentence": "當時以任俠自喜，脫張羽於阨，聲聞梁楚間。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000145",
    "sentence": "孝景時，為太子舍人。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000146",
    "sentence": "每五日洗沐，常置驛馬長安諸郊，請謝賓客，夜以繼日，至明旦，常恐不遍。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000147",
    "sentence": "當時好黃老言，其慕長者，如恐不稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000148",
    "sentence": "自見年少官薄，然其知友皆大父行，天下有名之士也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000149",
    "sentence": "武帝即位，當時稍遷為魯中尉，濟南太守，江都相，至九卿為右內史。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000150",
    "sentence": "以武安魏其時議，貶秩為詹事，遷為大司農。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000151",
    "sentence": "當時為大吏，戒門下：「客至，亡貴賤亡留門下者。」執賓主之禮，以其貴下人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000152",
    "sentence": "性廉，又不治產，卬奉賜給諸公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000153",
    "sentence": "然其餽遺人，不過具器食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000154",
    "sentence": "每朝，候上間說，未嘗不言天下長者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000155",
    "sentence": "其推轂士及官屬丞史，誠有味其言也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000156",
    "sentence": "常引以為賢於己。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000157",
    "sentence": "未嘗名吏，與官屬言，若恐傷之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000158",
    "sentence": "聞人之善言，進之上，唯恐後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000159",
    "sentence": "山東諸公以此翕然稱鄭莊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000160",
    "sentence": "使視決河，自請治行五日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000161",
    "sentence": "上曰：「吾聞鄭莊行，千里不齎糧，治行者何也？」然當時在朝，常趨和承意，不敢甚斥臧否。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000162",
    "sentence": "漢征匈奴，招四夷，天下費多，財用益屈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000163",
    "sentence": "當時為大司農，任人賓客僦，入多逋負。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000164",
    "sentence": "司馬安淮陽太守，發其事，當時以此陷罪，贖為庶人。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000165",
    "sentence": "頃之，守長史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000166",
    "sentence": "遷汝南太守，數歲，以官卒。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000167",
    "sentence": "昆弟以當時故，至二千石者六七人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000168",
    "sentence": "當時始與汲黯列為九卿，內行修。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000169",
    "sentence": "兩人中廢，賓客益落。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000170",
    "sentence": "當時死，家亡餘財。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000171",
    "sentence": "先是下邽翟公為廷尉，賓客亦填門，及廢，門外可設爵羅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000172",
    "sentence": "後復為廷尉，客欲往，翟公大署其門曰：「一死一生，乃知交情；一貧一富，乃知交態；一貴一賤，交情乃見。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000173",
    "sentence": "贊曰：張釋之之守法，馮唐之論將，汲黯之正直，鄭當時之推士，不如是，亦何以成名哉！",
    "entities": [
      {
        "text": "鄭當時",
        "label": "PER",
        "start": 22,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_006_050_000174",
    "sentence": "揚子以為孝文親詘帝尊以信亞夫之軍，曷為不能用頗、牧？",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000175",
    "sentence": "彼將有激云爾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_050_000176",
    "sentence": "本東漢作品在全世界都属于 公有领域 ，因为作者逝世已经遠遠超过100年。",
    "entities": [
      {
        "text": "100年",
        "label": "TME",
