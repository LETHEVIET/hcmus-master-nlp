  {
    "sentence_id": "HCH_006_055_000031",
    "sentence": "是後匈奴仍侵犯邊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000032",
    "sentence": "語在匈奴傳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000033",
    "sentence": "元朔元年 春，衛夫人有男，立為皇后。",
