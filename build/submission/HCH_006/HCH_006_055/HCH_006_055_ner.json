      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000029",
    "sentence": "賀亦無功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000030",
    "sentence": "唯青賜爵關內侯。",
