[
  {
    "sentence_id": "HCH_006_055_000001",
    "sentence": "衛青",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000002",
    "sentence": "衛青字仲卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000003",
    "sentence": "其父鄭季，河東平陽人也，以縣吏給事侯家。",
    "entities": [
      {
        "text": "以縣",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000004",
    "sentence": "平陽侯曹壽尚武帝姊陽信長公主。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000005",
    "sentence": "季與主家僮衛媼通，生青。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000006",
    "sentence": "青有同母兄衛長及姊子夫，子夫自平陽公主家得幸武帝，故青冒姓為衛氏。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000007",
    "sentence": "衛媼長女君孺，次女少兒，次女則子夫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000008",
    "sentence": "子夫男弟步廣，皆冒衛氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000009",
    "sentence": "衛青為侯家人，少時歸其父，父使牧羊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000010",
    "sentence": "民母之子皆奴畜之，不以為兄弟數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000011",
    "sentence": "青嘗從人至甘泉居室，有一鉗徒相青曰：「貴人也，官至封侯。」青笑曰：「人奴之生，得無笞罵即足矣，安得封侯事乎！」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000012",
    "sentence": "青壯，為侯家騎，從平陽主。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000013",
    "sentence": "建元二年春，青姊子夫得入宮幸上。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000014",
    "sentence": "皇后，大長公主女也，無子，妒。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000015",
    "sentence": "大長公主聞衛子夫幸，有身，妒之，乃使人捕青。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000016",
    "sentence": "青時給事建章，未知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000017",
    "sentence": "大長公主執囚青，欲殺之。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000018",
    "sentence": "其友騎郎公孫敖與壯士往篡之，故得不死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000019",
    "sentence": "上聞，乃召青為建章監，侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000020",
    "sentence": "及母昆弟貴，賞賜數日間累千金。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000021",
    "sentence": "君孺為太僕公孫賀妻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000022",
    "sentence": "少兒故與陳掌通，上召貴掌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000023",
    "sentence": "公孫敖由此益顯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000024",
    "sentence": "子夫為夫人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000025",
    "sentence": "青為太中大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
