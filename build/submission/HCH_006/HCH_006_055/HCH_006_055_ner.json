    "entities": [
      {
        "text": "青至籠城",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000028",
    "sentence": "騎將軍敖亡七千騎，衛尉廣為虜所得，得脫歸，皆當斬，贖為庶人。",
    "entities": [
