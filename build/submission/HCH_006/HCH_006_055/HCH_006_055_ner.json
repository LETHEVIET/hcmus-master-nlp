      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 33,
        "end": 35
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 37,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000160",
    "sentence": "凡三為將軍，其後常為大行。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000161",
    "sentence": "公孫敖",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000162",
    "sentence": "公孫敖，義渠人，以郎事景帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000163",
    "sentence": "至武帝立十二歲，為騎將軍，出代，亡卒七千人，當斬，贖為庶人。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000164",
    "sentence": "後五歲，以校尉從大將軍，封合騎侯。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000165",
    "sentence": "後一歲，以中將軍從大將軍再出定襄，無功。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000166",
    "sentence": "後二歲，以將軍出北地，後票騎，失期當斬，贖為庶人。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000167",
    "sentence": "後二歲，以校尉從大將軍，無功。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000168",
    "sentence": "後十四歲，以因杅將軍築受降城。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000169",
    "sentence": "七歲，復以因杅將軍再出擊匈奴，至余吾，亡士多，下吏，當斬，詐死，亡居民間五六歲。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000170",
    "sentence": "後覺，復繫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000171",
    "sentence": "坐妻為巫蠱，族。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000172",
    "sentence": "凡四為將軍。",
    "entities": [
      {
        "text": "將軍",
