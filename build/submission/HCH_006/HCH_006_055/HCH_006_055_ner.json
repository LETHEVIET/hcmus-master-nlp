        "text": "河南地為朔方郡",
        "label": "LOC",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_055_000038",
    "sentence": "以三千八百戶封青為長平侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_055_000039",
    "sentence": "青校尉蘇建為平陵侯，張次公為岸頭侯。",
    "entities": [
