[
  {
    "sentence_id": "HCH_006_079_000001",
    "sentence": "馮奉世",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000002",
    "sentence": "馮奉世字子明，上黨潞人也，徙杜陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000003",
    "sentence": "其先馮亭，為韓上黨守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000004",
    "sentence": "秦攻上黨，絕太行道，韓不能守，馮亭乃入上黨城守於趙。",
    "entities": [
      {
        "text": "馮亭乃入上黨城",
        "label": "LOC",
        "start": 15,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000005",
    "sentence": "趙封馮亭為華陽君，與趙將括距秦，戰死於長平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000006",
    "sentence": "宗族由是分散，或留潞，或在趙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000007",
    "sentence": "在趙者為官帥將，官帥將子為代相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000008",
    "sentence": "及秦滅六國，而馮亭之後馮毋擇、馮去疾、馮劫皆為秦將相焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000009",
    "sentence": "漢興，文帝時馮唐顯名，即代相子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000010",
    "sentence": "至武帝末，奉世以良家子選為郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000011",
    "sentence": "昭帝時，以功次補武安長。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000012",
    "sentence": "失官，年三十餘矣，乃學《春秋》涉大義，讀兵法明習，前將軍韓增奏以為軍司空令。",
    "entities": [
      {
        "text": "《春秋》",
        "label": "TITLE",
        "start": 11,
        "end": 15
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000013",
    "sentence": "本始中，從軍擊匈奴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000014",
    "sentence": "軍罷，復為郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000015",
    "sentence": "先是時，漢數出使西域，多辱命不稱，或貪污，為外國所苦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000016",
    "sentence": "是時，烏孫大有擊匈奴之功，而西域諸國新輯，漢方善遇，欲以安之，選可使外國者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000017",
    "sentence": "前將軍增舉奉世以衛候使持節送大宛諸國客。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000018",
    "sentence": "至伊脩城，都尉宋將言莎車與旁國共攻殺漢所置莎車王萬年，並殺漢使者奚充國。",
    "entities": [
      {
        "text": "至伊脩城",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000019",
    "sentence": "時，匈奴又發兵攻車師城，不能下而去。",
    "entities": [
      {
        "text": "又發兵攻車師城",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000020",
    "sentence": "莎車遣使揚言北道諸國已屬匈奴矣，於是攻劫南道，與歃盟畔漢，從鄯善以西皆絕不通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000021",
    "sentence": "都護鄭吉、校尉司馬意皆在北道諸國間。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000022",
    "sentence": "奉世與其副嚴昌計，以為不亟擊之則莎車日強，其勢難制，必危西域。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000023",
    "sentence": "遂以節諭告諸國王，因發其兵，南北道合萬五千人進擊莎車，攻拔其城。",
    "entities": [
      {
        "text": "攻拔其城",
        "label": "LOC",
        "start": 27,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000024",
    "sentence": "莎車王自殺，傳其首詣長安。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000025",
    "sentence": "諸國悉平，威振西域。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000026",
    "sentence": "奉世乃罷兵以聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000027",
    "sentence": "宣帝召見韓增，曰：「賀將軍所舉得其人。」奉世遂西至大苑。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000028",
    "sentence": "大苑聞其斬莎車王，敬之異於它使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000029",
    "sentence": "得其名馬象龍而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000030",
    "sentence": "上甚說，下議封奉世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000031",
    "sentence": "丞相、將軍皆曰：「《春秋》之義，大夫出疆，有可以安國家，則顓之可也。奉世功傚尤著，宜加爵士之賞。」少府蕭望之獨以奉世奉使有指，而擅矯制違命，發諸國兵，雖有功效，不可以為後法。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "《春秋》",
        "label": "TITLE",
        "start": 9,
        "end": 13
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000032",
    "sentence": "即封奉世，開後奉使者利，以奉世為比，爭逐發兵，要功萬里之外，為國家生事於夷狄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000033",
    "sentence": "漸不可長，奉世不宜受封。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000034",
    "sentence": "上善望之議，以奉世為光祿大夫、水衡都尉。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000035",
    "sentence": "元帝即位，為執金吾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000036",
    "sentence": "上郡屬國歸義降胡萬餘人反去。",
    "entities": [
      {
        "text": "上郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000037",
    "sentence": "初，昭帝末，西河屬國胡伊酋若王亦將眾數千人畔，奉世輒持節將兵追擊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000038",
    "sentence": "右將軍典屬國常惠薨，奉世代為右將軍典屬國，加諸吏之號。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 1,
        "end": 3
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000039",
    "sentence": "數歲，為光祿勳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000040",
    "sentence": "永光二年 秋，隴西羌彡姐旁種反，詔召丞相韋玄成、御史大夫鄭弘、大司馬車騎將軍王接、左將軍許嘉、右將軍奉世入議。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 24,
        "end": 26
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 26,
        "end": 28
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 32,
        "end": 34
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 36,
        "end": 38
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 42,
        "end": 44
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 48,
        "end": 50
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000041",
    "sentence": "是時，歲比不登，京師谷石二百餘，邊郡四百，關東五百。",
    "entities": [
      {
        "text": "邊郡",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000042",
    "sentence": "四方饑饉，朝廷方以為憂，而遭羌變。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000043",
    "sentence": "玄成等漠然莫有對者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000044",
    "sentence": "奉世曰：「羌虜近在境內背畔，不以時誅，亡以威制遠蠻。臣願帥師討之。」上問用兵之數，對曰：「臣聞善用兵者，役不再興，糧不三載，故師不久暴而天誅亟決。往者數不料敵，而師至於折傷；再三發軵，則曠日煩費，威武虧矣。今反虜無慮三萬人，法當倍用六萬人。然羌戎弓矛之兵耳，器不犀利，可用四萬人，一月足以決。」丞相、御史、兩將軍皆以為民方收斂時，未可多發；萬人屯守之，且足。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 147,
        "end": 149
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 150,
        "end": 152
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 154,
        "end": 156
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000045",
    "sentence": "奉世曰：「不可。天下被饑饉，士馬羸秏，守戰之備久廢不簡，夷狄皆有輕邊吏之心，而羌首難。今以萬人分屯數外，虜見兵少，必不畏懼，戰則挫兵病師，守則百姓不救。如此，怯弱之形見，羌人乘利，諸種並和，相扇而起，臣恐中國之役不得止於四萬，非財幣所能解也。故少發師而曠日，與一舉而疾決，利害相萬也。」固爭之，不能得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000046",
    "sentence": "有詔益二千人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000047",
    "sentence": "於是遣奉世將萬二千人騎，以將屯為名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000048",
    "sentence": "典屬國任立、護軍都尉韓昌為偏裨，到隴西，分屯三處。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000049",
    "sentence": "典屬國為右軍，屯白石；護軍都尉為前軍，屯臨洮；奉世為中軍，屯首陽西極上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000050",
    "sentence": "前軍到降同阪，先遣校尉在前與羌爭地利，又別遣校尉救民於廣陽谷。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000051",
    "sentence": "羌虜盛多，皆為所破，殺兩校尉。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000052",
    "sentence": "奉世具上地形部眾多少之計，願益三萬六千人乃足以決事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000053",
    "sentence": "書奏，天子大為發兵六萬餘人，拜太常弋陽侯任千秋為奮武將軍以助焉。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_006_079_000054",
    "sentence": "奉世上言：「願得其眾，不須煩大將。」因陳轉輸之費。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_079_000055",
    "sentence": "上於是以璽書勞奉世，且讓之，曰：「皇帝問將兵右將軍，甚苦暴露。羌虜侵邊境，殺吏民，甚逆天道，故遣將軍帥士大夫行天誅。以將軍材質之美，奮精兵，誅不軌，百下百全之道也。今乃有畔敵之名，大為中國羞。以昔不閑習之故邪？以恩厚未洽，信約不明也？朕甚怪之。上書言羌虜依深山，多徑道，不得不多分部遮要害，須得後發營士，足以決事，部署已定，勢不可復置大將，聞之。前為將軍兵少，不足自守，故發近所騎，日夜詣，非為擊也。今發三輔、河東、弘農越騎、跡射、佽飛、彀者、羽林孤兒及呼速累、嗕種，方急遣。且兵，凶器也，必有成敗者，患策不豫定，料敵不審也，故復遣奮武將軍。兵法曰大將軍出必有偏裨，所以揚威武，參計策，將軍又何疑焉？夫愛吏士，得眾心，舉而無悔，禽敵必全，將軍之職也。若乃轉輸之費，則有司存，將軍勿憂。須奮武將軍兵到，合擊羌虜。」",
    "entities": [
