      }
    ]
  },
  {
    "sentence_id": "HCH_006_078_000094",
    "sentence": "有詔加恩，長子伋嗣為關內侯。",
    "entities": [
      {
        "text": "長子伋嗣為關",
        "label": "LOC",
        "start": 5,
