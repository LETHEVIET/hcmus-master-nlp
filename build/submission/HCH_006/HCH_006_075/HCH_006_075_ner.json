[
  {
    "sentence_id": "HCH_006_075_000001",
    "sentence": "眭弘",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000002",
    "sentence": "眭弘字孟，魯國蕃人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000003",
    "sentence": "少時好俠，鬥雞走馬，長乃變節，從嬴公受春秋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000004",
    "sentence": "以明經為議郎，至符節令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000005",
    "sentence": "孝昭 元鳳三年 正月，泰山萊蕪山南匈匈有數千人聲，民視之，有大石自立，高丈五尺，大四十八圍，入地深八尺，三石為足。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000006",
    "sentence": "石立後有白烏數千下集其旁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000007",
    "sentence": "是時昌邑有枯社木臥復生，又上林苑中大柳樹斷枯臥地，亦自立生，有蟲食樹葉成文字，曰「公孫病已立」，孟推春秋之意，以為「石柳皆陰類，下民之象，而泰山者岱宗之嶽，王者易姓告代之處。今大石自立，僵柳復起，非人力所為，此當有從匹夫為天子者。枯社木復生，故廢之家公孫氏當復興者也。」孟意亦不知其所在，即說曰：「先師董仲舒有言，雖有繼體守文之君，不害聖人之受命。漢家堯後，有傳國之運。漢帝宜誰差天下，求索賢人，襢以帝位，而退自封百里，如殷周二王後，以承順天命。」孟使友人內官長賜上此書。",
    "entities": [
      {
        "text": "是時昌邑",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "漢",
        "label": "ORG",
        "start": 174,
        "end": 175
      },
      {
        "text": "漢",
        "label": "ORG",
        "start": 185,
        "end": 186
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000008",
    "sentence": "時，昭帝幼，大將軍霍光秉政，惡之，下其書廷尉。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000009",
    "sentence": "奏賜、孟妄設祅言惑眾，大逆不道，皆伏誅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000010",
    "sentence": "後五年，孝宣帝興於民間，即位，徵孟子為郎。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000011",
    "sentence": "夏侯始昌",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000012",
    "sentence": "夏侯始昌，魯人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000013",
    "sentence": "通五經，以齊詩、尚書教授。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000014",
    "sentence": "自董仲舒、韓嬰死後，武帝得始昌，甚重之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000015",
    "sentence": "始昌明於陰陽，先言柏梁臺災日，至期日果災。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000016",
    "sentence": "時昌邑王以少子愛，上為選師，始昌為太傅。",
    "entities": [
      {
        "text": "時昌邑",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000017",
    "sentence": "年老，以壽終。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000018",
    "sentence": "族子勝亦以儒顯名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000019",
    "sentence": "夏侯勝",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000020",
    "sentence": "夏侯勝字長公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000021",
    "sentence": "初，魯共王分魯西寧鄉以封子節侯，別屬大河，大河後更名東平，故勝為東平人。",
    "entities": [
      {
        "text": "共王分魯西寧鄉",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000022",
    "sentence": "勝少孤，好學，從始昌受尚書及洪範五行傳，說災異。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000023",
    "sentence": "後事蕑卿，又從歐陽氏問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000024",
    "sentence": "為學精孰，所問非一師也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000025",
    "sentence": "善說禮服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000026",
    "sentence": "徵為博士、光祿大夫。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000027",
    "sentence": "會昭帝崩，昌邑王嗣立，數出。",
    "entities": [
      {
        "text": "昌邑",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000028",
    "sentence": "勝當乘輿前諫曰：「天久陰而不雨，臣下有謀上者，陛下出欲何之？」王怒，謂勝為祅言，縛以屬吏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000029",
    "sentence": "吏白大將軍霍光，光不舉法。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000030",
    "sentence": "是時，光與車騎將軍張安世謀欲廢昌邑王。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "安世謀欲廢昌邑",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000031",
    "sentence": "光讓安世以為泄語，安世實不言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000032",
    "sentence": "乃召問勝，勝對言：「在洪範傳曰『皇之不極，厥罰常陰，時則下人有伐上者』，惡察察言，故云臣下有謀。」光、安世大驚，以此益重經術士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000033",
    "sentence": "後十餘日，光卒與安世共白太后，廢昌邑王，尊立宣帝。",
    "entities": [
      {
        "text": "廢昌邑",
        "label": "LOC",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000034",
    "sentence": "光以為群臣奏事東宮，太后省政，宜知經術，白令勝用尚書授太后。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000035",
    "sentence": "遷長信少府，賜爵關內侯，以與謀廢立，定策安宗廟，益千戶。",
    "entities": [
      {
        "text": "賜爵關",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000036",
    "sentence": "宣帝初即位，欲褒先帝，詔丞相御史曰：「朕以眇身，蒙遺德，承聖業，奉宗廟，夙夜惟念。孝武皇帝躬仁誼，厲威武，北征匈奴，單于遠遁，南平氐羌、昆明、甌駱兩越，東定薉、貉、朝鮮，廓地斥境，立郡縣，百蠻率服，款塞自至，珍貢陳於宗廟；協音律，造樂歌，薦上帝，封太山，立明堂，改正朔，易服色；明開聖緒，尊賢顯功，興滅繼絕，褒周之後；備天地之禮，廣道術之路。上天報況，符瑞並應，寶鼎出，白麟獲，海效鉅魚，神人並見，山稱萬歲。功德茂盛，不能盡宣，而廟樂未稱，朕甚悼焉。其與列侯、二千石、博士議。」於是群臣大議廷中，皆曰：「宜如詔書。」長信少府勝獨曰：「武帝雖有攘四夷廣土斥境之功，然多殺士眾，竭民財力，奢泰亡度，天下虛耗，百姓流離，物故者過半。蝗蟲大起，赤地數千里，或人民相食，畜積至今未復。亡德澤於民，不宜為立廟樂。」公卿共難勝曰：「此詔書也。」勝曰：「詔書不可用也。人臣之誼，宜直言正論，非苟阿意順指。議已出口，雖死不悔。」於是丞相義、御史大夫廣明劾奏勝非議詔書，毀先帝，不道，及丞相長史黃霸阿縱勝，不舉劾，俱下獄。",
