      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000056",
    "sentence": "勝子兼為左曹太中大夫，孫堯至長信少府、司農、鴻臚，曾孫蕃郡守、州牧、長樂少府。",
    "entities": [
      {
        "text": "大夫",
