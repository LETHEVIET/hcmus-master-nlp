        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_075_000061",
    "sentence": "治易，事梁人焦延壽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000062",
    "sentence": "延壽字贛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_075_000063",
    "sentence": "贛貧賤，以好學得幸梁王，王共其資用，令極意學。",
    "entities": []
  },
