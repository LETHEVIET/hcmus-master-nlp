  },
  {
    "sentence_id": "HCH_006_003_000006",
    "sentence": "乃立兄子呂台、產、祿、台子通四人為王，封諸呂六人為列侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_003_000007",
