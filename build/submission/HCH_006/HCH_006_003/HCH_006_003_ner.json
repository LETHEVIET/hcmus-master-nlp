    "sentence_id": "HCH_006_003_000034",
    "sentence": "秩長陵令二千石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_003_000035",
    "sentence": "六月，城長陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_003_000036",
    "sentence": "匈奴寇狄道，攻阿陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_003_000037",
