        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_003_000022",
    "sentence": "三年夏，江水、溢，流民四千餘家。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_003_000023",
    "sentence": "秋，星晝見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_003_000024",
    "sentence": "四年",
    "entities": [
