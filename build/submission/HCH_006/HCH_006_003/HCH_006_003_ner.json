      }
    ]
  },
  {
    "sentence_id": "HCH_006_003_000043",
    "sentence": "六月，趙王恢自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_003_000044",
    "sentence": "秋九月，燕王建薨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_003_000045",
    "sentence": "南越侵盜長沙，遣隆慮侯灶將兵擊之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_003_000046",
