      }
    ]
  },
  {
    "sentence_id": "HCH_006_003_000010",
    "sentence": "二月，賜民爵，戶一級。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_003_000011",
    "sentence": "初置孝弟力田二千石者一人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_003_000012",
    "sentence": "夏五月丙申，趙王宮叢臺災。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_003_000013",
    "sentence": "立孝惠後宮子強為淮陽王，不疑為恆山王，弘為襄城侯，朝為軹侯，武為壺關侯。",
    "entities": [
      {
        "text": "弘為襄城",
        "label": "LOC",
        "start": 19,
        "end": 23
      },
      {
        "text": "武為壺關",
        "label": "LOC",
        "start": 30,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_006_003_000014",
    "sentence": "秋，桃李華。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_003_000015",
    "sentence": "二年",
    "entities": [
