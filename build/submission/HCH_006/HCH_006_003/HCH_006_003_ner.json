    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_003_000048",
    "sentence": "諸中官、宦者令丞皆賜爵關內侯，食邑。",
    "entities": [
      {
