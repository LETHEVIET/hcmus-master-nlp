      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000023",
    "sentence": "尊皇太后曰太皇太后，皇后曰皇太后。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000024",
    "sentence": "大赦天下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000025",
    "sentence": "賜宗室王子有屬者馬各一駟，吏民爵，百戶牛酒，三老、孝弟力田、鰥寡孤獨帛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000026",
    "sentence": "太皇太后詔尊定陶恭王為恭皇。",
    "entities": []
  },
