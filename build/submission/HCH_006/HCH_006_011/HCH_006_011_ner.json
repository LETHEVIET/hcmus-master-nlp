        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000057",
    "sentence": "博自殺，玄減死二等論，晏削戶四分之一。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000058",
    "sentence": "語在博傳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000059",
    "sentence": "三年春正月，立廣德夷王弟廣漢為廣平王。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000060",
    "sentence": "癸卯，帝太太后所居桂宮正殿火。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000061",
    "sentence": "三月己酉，丞相當薨。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000062",
    "sentence": "有星孛于河鼓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000063",
    "sentence": "夏六月，立魯頃王子郚鄉侯閔為王。",
    "entities": [
      {
        "text": "立魯頃王子郚鄉",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000064",
    "sentence": "冬十一月壬子，復甘泉泰畤、汾陰后土祠，罷南北郊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000065",
    "sentence": "東平王雲、雲后謁、安成恭侯夫人放皆有罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000066",
    "sentence": "雲自殺，謁、放棄市。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000067",
    "sentence": "四年春，大旱。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000068",
    "sentence": "關東民傳行西王母籌，經歷郡國，西入關至京師。",
    "entities": [
      {
        "text": "經歷郡",
        "label": "LOC",
        "start": 10,
        "end": 13
      },
      {
        "text": "西入關",
