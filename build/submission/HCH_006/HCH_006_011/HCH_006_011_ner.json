[
  {
    "sentence_id": "HCH_006_011_000001",
    "sentence": "哀帝",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000002",
    "sentence": "孝哀皇帝，元帝庶孫，定陶恭王子也。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000003",
    "sentence": "母曰丁姬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000004",
    "sentence": "年三歲嗣立為王，長好文辭法律。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000005",
    "sentence": "元延四年 入朝，盡從傅、相、中尉。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000006",
    "sentence": "時成帝少弟中山孝王亦來朝，獨從傅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000007",
    "sentence": "上怪之，以問定陶王，對曰：「令，諸侯王朝，得從其國二千石。傅、相、中尉皆國二千石，故盡從之。」上令誦詩，通習，能說。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000008",
    "sentence": "他日問中山王：「",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000009",
    "sentence": "獨從傅在何法令？",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000010",
    "sentence": "」不能對。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000011",
    "sentence": "令誦尚書，又廢。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000012",
    "sentence": "及賜食於前，後飽；起下，陉係解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000013",
    "sentence": "成帝由此以為不能，而賢定陶王，數稱其材。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000014",
    "sentence": "時王祖母傅太后隨王來朝，私賂遺上所幸趙昭儀及帝舅票騎將軍曲陽侯王根。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000015",
    "sentence": "昭儀及根見上亡子，亦欲豫自結為長久計，皆更稱定陶王，勸帝以為嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000016",
    "sentence": "成帝亦自美其材，為加元服而遣之，時年十七矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000017",
    "sentence": "明年，使執金吾任宏守大鴻臚，持節徵定陶王，立為皇太子。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000018",
    "sentence": "謝曰：「臣幸得繼父守藩為諸侯王，材質不足以假充太子之宮。陛下聖德寬仁，敬承祖宗，奉順神祇，宜蒙福祐子孫千億之報。臣願且得留國邸，旦夕奉問起居，俟有聖嗣，歸國守藩。」書奏，天子報聞。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000019",
    "sentence": "後月餘，立楚孝王孫景為定陶王，奉恭王祀，所以獎厲太子專為後之誼。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000020",
    "sentence": "語在外戚傳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_011_000021",
    "sentence": "綏和二年 三月，成帝崩。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_011_000022",
    "sentence": "四月丙午，太子即皇帝位，謁高廟。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
