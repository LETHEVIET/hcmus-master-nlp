        "start": 353,
        "end": 354
      }
    ]
  },
  {
    "sentence_id": "HCH_006_024a_000185",
    "sentence": "武帝末年，悔征伐之事，乃封丞相為富民侯。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_024a_000186",
    "sentence": "下詔曰：「",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000187",
    "sentence": "方今之務，在於力農。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000188",
    "sentence": "」以趙過為搜粟都尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000189",
    "sentence": "過能為代田，一畝三甽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000190",
    "sentence": "歲代處，故曰代田，古法也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000191",
    "sentence": "后稷始甽田，以二耜為耦，廣尺深尺曰甽，長終畝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000192",
    "sentence": "一畝三甽，一夫三百甽，而播種於甽中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000193",
    "sentence": "苗生葉以上，稍耨隴草，因隤其土以附根苗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000194",
    "sentence": "故其詩曰：「或芸或芓，黍稷儗儗。」芸，除草也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000195",
    "sentence": "刭，附根也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000196",
    "sentence": "言苗稍壯，每耨輒附根，比盛暑，隴盡而根深，能風與旱，故儗儗而盛也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000197",
    "sentence": "其耕耘下種田器，皆有便巧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000198",
    "sentence": "率十二夫為田一井一屋，故具五頃，用耦犁，二牛三人，一歲之收常過縵田具一斛以上，善者倍之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000199",
    "sentence": "過使教田太常、三輔，大農置工巧奴與從事，為作田器。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000200",
    "sentence": "二千石遣令長、三老、力田及里父老善田者受田器，學耕種養苗狀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000201",
    "sentence": "民或苦少牛，亡以趨澤，故平都令光教過以人輓犁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000202",
    "sentence": "過奏光以為丞，教民相與庸輓犁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000203",
    "sentence": "率多人者田日三十畝，少者十三畝，以故田多墾闢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000204",
    "sentence": "過試以離宮卒田其宮壖地，課得穀皆多其旁田畝一斛以上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000205",
    "sentence": "令命家田三輔公田，又教邊郡及居延城。",
    "entities": [
      {
        "text": "又教邊郡",
        "label": "LOC",
        "start": 9,
        "end": 13
      },
      {
        "text": "及居延城",
        "label": "LOC",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_024a_000206",
    "sentence": "是後邊城、河東、弘農、三輔、太常民皆便代田，用力少而得穀多。",
    "entities": [
      {
        "text": "是後邊城",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_024a_000207",
    "sentence": "至昭帝時，流民稍還，田野益闢，頗有畜積。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000208",
    "sentence": "宣帝即位，用吏多選賢良，百姓安土，歲數豐穰，穀至石五錢，農人少利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000209",
    "sentence": "時大司農中丞耿壽昌以善為算能商功利得幸於上，五鳳中奏言：「",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_024a_000210",
    "sentence": "故事，歲漕關東穀四百萬斛以給京師，用卒六萬人。",
    "entities": [
      {
        "text": "歲漕關",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
