[
  {
    "sentence_id": "HCH_006_092_000001",
    "sentence": "古者天子建國，諸侯立家，自卿大夫以至于庶人各有等差，是以民服事其上，而下無覬覦。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000002",
    "sentence": "孔子曰：「天下有道，政不在大夫。」百官有司奉法承令，以脩所職，失職有誅，侵官有罰。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000003",
    "sentence": "夫然，故上下相順，而庶事理焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000004",
    "sentence": "周室既微，禮樂征伐自諸侯出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000005",
    "sentence": "桓文之後，大夫世權，陪臣執命。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000006",
    "sentence": "陵夷至於戰國，合從連衡，力政爭彊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000007",
    "sentence": "繇是列國公子，魏有信陵，趙有平原，齊有孟嘗，楚有春申，皆藉王公之勢，競為游俠，雞鳴狗盜，無不賓禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000008",
    "sentence": "而趙相虞卿棄國捐君，以周窮交魏齊之厄；信陵無忌竊符矯命，戮將專師，以赴平原之急：皆以取重諸侯，顯名天下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000009",
    "sentence": "搤腕而游談者，以四豪為稱首。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000010",
    "sentence": "於是背公死黨之議成，守戰奉上之義廢矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000011",
    "sentence": "及至漢興，禁網疏闊，未之匡改也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000012",
    "sentence": "是故代相陳豨從車千乘，而吳濞、淮南皆招賓客以千數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000013",
    "sentence": "外戚大臣魏其、武安之屬競逐於京師，布衣游俠劇孟、郭解之徒馳騖於閭閻，權行州域，力折公侯。",
    "entities": [
      {
        "text": "權行州",
        "label": "LOC",
        "start": 34,
        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000014",
    "sentence": "眾庶榮其名跡，覬而慕之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000015",
    "sentence": "雖其陷於刑辟，自與殺身成名，若季路、仇牧，死而不悔也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000016",
    "sentence": "故曾子曰：「上失其道，民散久矣。」非明王在上，視之以好惡，齊之以禮法，民曷繇知禁而反正乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000017",
    "sentence": "古之正法：五伯，三王之罪人也；而六國，五伯之罪人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000018",
    "sentence": "夫四豪者，又六國之罪人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000019",
    "sentence": "況於郭解之倫，以匹夫之細，竊殺生之權，其罪已不容於誅矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000020",
    "sentence": "觀其溫良泛愛，振窮周急，謙退不伐，亦皆有絕異之姿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000021",
    "sentence": "惜乎不入於道德，苟放縱於末流，殺身亡宗，非不幸也！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000022",
    "sentence": "自魏其、武安、淮南之後，天子切齒，衛、霍改節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000023",
    "sentence": "然郡國豪桀處處各有，京師親戚冠蓋相望，亦古今常道，莫足言者。",
    "entities": [
      {
        "text": "然郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000024",
    "sentence": "唯成帝時，外家王氏賓客為盛，而樓護為帥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000025",
    "sentence": "及王莽時，諸公之間陳遵為雄，閭里之俠原涉為魁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000026",
    "sentence": "朱家",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000027",
    "sentence": "朱家，魯人，高祖同時也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000028",
    "sentence": "魯人皆以儒教，而朱家用俠聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000029",
    "sentence": "所臧活豪士以百數，其餘庸人不可勝言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000030",
    "sentence": "然終不伐其能，飲其德，諸所嘗施，唯恐見之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000031",
    "sentence": "振人不贍，先從貧賤始。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000032",
    "sentence": "家亡餘財，衣不兼采，食不重味，乘不過軥牛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000033",
    "sentence": "專趨人之急，甚於己私。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000034",
    "sentence": "既陰脫季布之厄，及布尊貴，終身不見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000035",
    "sentence": "自關以東，莫不延頸願交。",
    "entities": [
      {
        "text": "自關",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000036",
    "sentence": "田仲",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000037",
    "sentence": "楚田仲以俠聞，父事朱家，自以為行弗及也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000038",
    "sentence": "田仲死後，有劇孟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000039",
    "sentence": "劇孟",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000040",
    "sentence": "劇孟者，洛陽人也。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000041",
    "sentence": "周人以商賈為資，劇孟以俠顯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000042",
    "sentence": "吳楚反時，條侯為太尉，乘傳東，將至河南，得劇孟，喜曰：「吳楚舉大事而不求劇孟，吾知其無能為已。」天下騷動，大將軍得之若一敵國云。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 53,
        "end": 56
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000043",
    "sentence": "劇孟行大類朱家，而好博，多少年之戲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000044",
    "sentence": "然孟母死，自遠方送喪蓋千乘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000045",
    "sentence": "及孟死，家無十金之財。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000046",
    "sentence": "而符離王孟，亦以俠稱江淮之間。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000047",
    "sentence": "是時，濟南瞷氏、陳周膚亦以豪聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000048",
    "sentence": "景帝聞之，使使盡誅此屬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000049",
    "sentence": "其後，代諸白、梁韓毋辟、陽翟薛況、陝寒孺，紛紛復出焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000050",
    "sentence": "郭解",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000051",
    "sentence": "郭解，河內軹人也，溫善相人許負外孫也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000052",
    "sentence": "解父任俠，孝文時誅死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000053",
    "sentence": "解為人靜悍，不飲酒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000054",
    "sentence": "少時陰賊感概，不快意，所殺甚眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000055",
    "sentence": "以軀耤友報仇，臧命作姦剽攻，休乃鑄錢掘冢，不可勝數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000056",
    "sentence": "適有天幸，窘急常得脫，若遇赦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000057",
    "sentence": "及解年長，更折節為儉，以德報怨，厚施而薄望。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000058",
    "sentence": "然其自喜為俠益甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000059",
    "sentence": "既已振人之命，不矜其功，其陰賊著於心本發於睚眥如故云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000060",
    "sentence": "而少年慕其行，亦輒為報讎，不使知也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000061",
    "sentence": "解姊子負解之勢，與人飲，使之釂，非其任，彊灌之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000062",
    "sentence": "人怒，刺殺解姊子，去亡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000063",
    "sentence": "解姊怒曰：「以翁伯時人殺吾子，賊不得！」棄其尸道旁，弗葬，欲以辱解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000064",
    "sentence": "解使人微知賊處。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000065",
    "sentence": "賊窘自歸，具以實告解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000066",
    "sentence": "解曰：「公殺之當，吾兒不直。」遂去其賊，罪其姊子，收而葬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000067",
    "sentence": "諸公聞之，皆多解之義，益附焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000068",
    "sentence": "解出，人皆避，有一人獨箕踞視之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000069",
    "sentence": "解問其姓名，客欲殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000070",
    "sentence": "解曰：「居邑屋不見敬，是吾德不脩也，彼何罪！」乃陰請尉史曰：「是人吾所重，至踐更時脫之。」每至直更，數過，吏弗求。",
    "entities": [
      {
        "text": "居邑",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000071",
    "sentence": "怪之，問其故，解使脫之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000072",
    "sentence": "箕踞者乃肉袒謝罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000073",
    "sentence": "少年聞之，愈益慕解之行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000074",
    "sentence": "洛陽人有相仇者，邑中賢豪居間以十數，終不聽。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000075",
    "sentence": "客乃見解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000076",
    "sentence": "解夜見仇家，仇家曲聽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000077",
    "sentence": "解謂仇家：「吾聞洛陽諸公在間，多不聽。今子幸而聽解，解奈何從它縣奪人邑賢大夫權乎！」乃夜去，不使人知，曰：「且毋庸，待我去，令洛陽豪居間乃聽。」",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 8,
        "end": 10
      },
      {
        "text": "解奈何從它縣",
        "label": "LOC",
        "start": 26,
        "end": 32
      },
      {
        "text": "奪人邑",
        "label": "LOC",
        "start": 32,
        "end": 35
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 36,
        "end": 38
      },
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 63,
        "end": 65
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000078",
    "sentence": "解為人短小，恭儉，出未嘗有騎，不敢乘車入其縣庭。",
    "entities": [
      {
        "text": "不敢乘車入其縣",
        "label": "LOC",
        "start": 15,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000079",
    "sentence": "之旁郡國，為人請求事，事可出，出之；不可者，各令厭其意，然後乃敢嘗酒食。",
    "entities": [
      {
        "text": "之旁郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000080",
    "sentence": "諸公以此嚴重之，爭為用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000081",
    "sentence": "邑中少年及旁近縣豪夜半過門，常十餘車，請得解客舍養之。",
    "entities": [
      {
        "text": "中少年及旁近縣",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000082",
    "sentence": "及徙豪茂陵也，解貧，不中訾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000083",
    "sentence": "吏恐，不敢不徙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000084",
    "sentence": "衛將軍為言「郭解家貧，不中徙」。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000085",
    "sentence": "上曰：「解布衣，權至使將軍，此其家不貧！」解徙，諸公送者出千餘萬。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000086",
    "sentence": "軹人楊季主子為縣掾，鬲之，解兄子斷楊掾頭。",
    "entities": [
      {
        "text": "人楊季主子為縣",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000087",
    "sentence": "解入關，關中賢豪知與不知，聞聲爭交驩。",
    "entities": [
      {
        "text": "解入關",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000088",
    "sentence": "邑人又殺楊季主，季主家上書人又殺闕下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000089",
    "sentence": "上聞，乃下吏捕解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000090",
    "sentence": "解亡，置其母家室夏陽，身至臨晉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000091",
    "sentence": "臨晉籍少翁素不知解，因出關。",
    "entities": [
      {
        "text": "因出關",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000092",
    "sentence": "籍少翁已出解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000093",
    "sentence": "解傳太原，所過輒告主人處。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000094",
    "sentence": "吏逐跡至籍少翁，少翁自殺，口絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000095",
    "sentence": "久之得解，窮治所犯為，而解所殺，皆在赦前。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000096",
    "sentence": "軹有儒生侍使者坐，客譽郭解，生曰：「解專以姦犯公法，何謂賢？」解客聞之，殺此生，斷舌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000097",
    "sentence": "吏以責解，解實不知殺者，殺者亦竟莫知為誰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000098",
    "sentence": "吏奏解無罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000099",
    "sentence": "御史大夫公孫弘議曰：「解布衣為任俠行權，以睚眥殺人，解不知，此罪甚於解知殺之。當大逆無道。」遂族解。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "公孫弘",
        "label": "PER",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000100",
    "sentence": "自是之後，俠者極眾，而無足數者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000101",
    "sentence": "然關中長安樊中子，槐里趙王孫，長陵高公子，西河郭翁中，太原魯翁孺，臨淮兒長卿，東陽陳君孺，雖為俠而恂恂有退讓君子之風。",
    "entities": [
      {
        "text": "然關",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000102",
    "sentence": "至若北道姚氏，西道諸杜，南道仇景，東道佗羽公子，南陽趙調之徒，盜跖而居民間者耳，曷足道哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000103",
    "sentence": "此乃鄉者朱家所羞也。",
    "entities": [
      {
        "text": "此乃鄉",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000104",
    "sentence": "萭章",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000105",
    "sentence": "萭章字子夏，長安人也。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000106",
    "sentence": "長安熾盛，街閭各有豪俠，章在城西柳市，號曰「城西萭子夏」。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "章在城",
        "label": "LOC",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000107",
    "sentence": "為京兆尹門下督，從至殿中，侍中諸侯貴人爭欲揖章，莫與京兆尹言者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000108",
    "sentence": "章逡循甚懼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000109",
    "sentence": "其後京兆不復從也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000110",
    "sentence": "與中書令石顯相善，亦得顯權力，門車常接轂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000111",
    "sentence": "至成帝初，石顯坐專權擅勢免官，徙歸故郡。",
    "entities": [
      {
        "text": "徙歸故郡",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000112",
    "sentence": "顯貲巨萬，當去，留床席器物數百萬直，欲以與章，章不受。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000113",
    "sentence": "賓客或問其故，章歎曰：「吾以布衣見哀於石君，石君家破，不能有以安也，而受其財物，此為石氏之禍，萭氏反當以為福邪！」諸公以是服而稱之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000114",
    "sentence": "河平中，王尊為京兆尹，捕擊豪俠，殺章及箭張回、酒市趙君都、賈子光，皆長安名豪，報仇怨養刺客者也。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 34,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000115",
    "sentence": "樓護",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000116",
    "sentence": "樓護字君卿，齊人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000117",
    "sentence": "父世醫也，護少隨父為醫長安，出入貴戚家。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000118",
    "sentence": "護誦醫經、本草、方術數十萬言，長者咸愛重之，共謂曰：「以君卿之材，何不宦學乎？」繇是辭其父，學經傳，為京兆吏數年，甚得名譽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000119",
    "sentence": "是時王氏方盛，賓客滿門，五侯兄弟爭名，其客各有所厚，不得左右，唯護盡入其門，咸得其驩心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000120",
    "sentence": "結士大夫，無所不傾，其交長者，尤見親而敬，眾以是服。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000121",
    "sentence": "為人短小精辯，論議常依名節，聽之者皆竦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000122",
    "sentence": "與谷永俱為五侯上客，長安號曰「谷子雲筆札，樓君卿脣舌」，言其見信用也。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000123",
    "sentence": "母死，送葬者致車二三千兩，閭里歌之曰：「五侯治喪樓君卿。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000124",
    "sentence": "久之，平阿侯舉護方正，為諫大夫，使郡國。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "使郡",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000125",
    "sentence": "護假貸，多持幣帛，過齊，上書求上先人冢，因會宗族故人，各以親疏與束帛，一日散百金之費。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000126",
    "sentence": "使還，奏事稱意，擢為天水太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000127",
    "sentence": "數歲免，家長安中。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000128",
    "sentence": "時成都侯商為大司馬衛將軍，罷朝，欲候護，其主簿諫：「將軍至尊，不宜入閭巷。」商不聽，遂往至護家。",
    "entities": [
      {
        "text": "成都",
        "label": "LOC",
        "start": 1,
        "end": 3
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000129",
    "sentence": "家狹小，官屬立車下，久住移時，天欲雨，主簿謂西曹諸掾曰：「不肯彊諫，反雨立閭巷！」商還，或白主簿語，商恨，以他職事去主簿，終身廢錮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000130",
    "sentence": "後護復以薦為廣漢太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000131",
    "sentence": "元始中，王莽為安漢公，專政，莽長子宇與妻兄呂寬謀以血塗莽第門，欲懼莽令歸政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000132",
    "sentence": "發覺，莽大怒，殺宇，而呂寬亡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000133",
    "sentence": "寬父素與護相知，寬至廣漢過護，不以事實語也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000134",
    "sentence": "到數日，名捕寬詔書至，護執寬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000135",
    "sentence": "莽大喜，徵護入為前煇光，封息鄉侯，列於九卿。",
    "entities": [
      {
        "text": "封息鄉",
        "label": "LOC",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000136",
    "sentence": "莽居攝，槐里大賊趙朋、霍鴻等群起，延入前煇光界，護坐免為庶人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000137",
    "sentence": "其居位，爵祿賂遺所得亦緣手盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000138",
    "sentence": "既退居里巷，時五侯皆已死，年老失勢，賓客益衰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000139",
    "sentence": "至王莽篡位，以舊恩召見護，封為樓舊里附城。",
    "entities": [
      {
        "text": "封為樓舊里附城",
        "label": "LOC",
        "start": 13,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000140",
    "sentence": "而成都侯商子邑為大司空，貴重，商故人皆敬事邑，唯護自安如舊節，邑亦父事之，不敢有闕。",
    "entities": [
      {
        "text": "而成都侯商子邑",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "商故人皆敬事邑",
        "label": "LOC",
        "start": 15,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000141",
    "sentence": "時請召賓客，邑居樽下，稱「賤子上壽」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000142",
    "sentence": "坐者百數，皆離席伏，護獨東鄉正坐，字謂邑曰：「公子貴如何！」",
    "entities": [
      {
        "text": "護獨東鄉",
        "label": "LOC",
        "start": 10,
        "end": 14
      },
      {
        "text": "字謂邑",
        "label": "LOC",
        "start": 17,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000143",
    "sentence": "初，護有故人呂公，無子，歸護。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000144",
    "sentence": "護身與呂公、妻與呂嫗同食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000145",
    "sentence": "及護家居，妻子頗厭呂公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000146",
    "sentence": "護聞之，流涕責其妻子曰：「呂公以故舊窮老託身於我，義所當奉。」遂養呂公終身。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000147",
    "sentence": "護卒，子嗣其爵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000148",
    "sentence": "陳遵",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000149",
    "sentence": "陳遵字孟公，杜陵人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000150",
    "sentence": "祖父遂，字長子，宣帝微時與有故，相隨博弈，數負進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000151",
    "sentence": "及宣帝即位，用遂，稍遷至太原太守，乃賜遂璽書曰：「制詔太原太守：官尊祿厚，可以償博進矣。妻君寧時在旁，知狀。」遂於是辭謝，因曰：「事在元平元年赦令前。」其見厚如此。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 29,
        "end": 31
      },
      {
        "text": "元年",
        "label": "TME",
        "start": 69,
        "end": 71
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000152",
    "sentence": "元帝時，徵遂為京兆尹，至廷尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000153",
    "sentence": "遵少孤，與張竦伯松俱為京兆史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000154",
    "sentence": "竦博學通達，以廉儉自守，而遵放縱不拘，操行雖異，然相親友，哀帝之末俱著名字，為後進冠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000155",
    "sentence": "並入公府，公府掾史率皆羸車小馬，不上鮮明，而遵獨極輿馬衣服之好，門外車騎交錯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000156",
    "sentence": "又日出醉歸，曹事數廢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000157",
    "sentence": "西曹以故事適之，侍曹輒詣寺舍白遵曰：「陳卿今日以某事適。」遵曰：「滿百乃相聞。」故事，有百適者斥，滿百，西曹白請斥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000158",
    "sentence": "大司徒馬宮大儒優士，又重遵，謂西曹：「此人大度士，奈何以小文責之？」乃舉遵能治三輔劇縣，補郁夷令。",
    "entities": [
      {
        "text": "遵能治三輔劇縣",
        "label": "LOC",
        "start": 36,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000159",
    "sentence": "久之，與扶風相失，自免去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000160",
    "sentence": "槐里大賊趙朋、霍鴻等起，遵為校尉，擊朋、鴻有功，封嘉威侯。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000161",
    "sentence": "居長安中，列侯近臣貴戚皆重貴之。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000162",
    "sentence": "牧守當之官，及郡國豪桀至京師者，莫不相因到遵門。",
    "entities": [
      {
        "text": "及郡",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000163",
    "sentence": "遵耆酒，每大飲，賓客滿堂，輒關門，取客車轄投井中，雖有急，終不得去。",
    "entities": [
      {
        "text": "輒關",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000164",
    "sentence": "嘗有部刺史奏事，過遵，值其方飲，刺史大窮，候遵霑醉時，突入見遵母，叩頭自白當對尚書有期會狀，母乃令從從閤出去。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 39,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000165",
    "sentence": "遵大率常醉，然事亦不廢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000166",
    "sentence": "長八尺餘，長頭大鼻，容貌甚偉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000167",
    "sentence": "略涉傳記，贍於文辭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000168",
    "sentence": "性善書，與人尺牘，主皆藏去以為榮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000169",
    "sentence": "請求不敢逆，所到，衣冠懷之，唯恐在後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000170",
    "sentence": "時列侯有與遵同姓字者，每至人門，曰陳孟公，坐中莫不震動，既至而非，因號其人曰陳驚坐云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000171",
    "sentence": "王莽素奇遵材，在位多稱譽者，繇是起為河南太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000172",
    "sentence": "既至官，當遣從史西，召善書吏十人於前，治私書謝京師故人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000173",
    "sentence": "遵馮几，口占書吏，且省官事，書數百封，親疏各有意，河南大驚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000174",
    "sentence": "數月免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000175",
    "sentence": "初，遵為河南太守，而弟級為荊州牧，當之官，俱過長安富人故淮陽王外家左氏飲食作樂。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "而弟級為荊州",
        "label": "LOC",
        "start": 9,
        "end": 15
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000176",
    "sentence": "後司直陳崇聞之，劾奏「遵兄弟幸得蒙恩超等歷位，遵爵列侯，備郡守，級州牧奉使，皆以舉直察枉宣揚聖化為職，不正身自慎。始遵初除，乘藩車入閭巷，過寡婦左阿君置酒歌謳，遵起舞跳梁，頓仆坐上，暮因留宿，為侍婢扶臥。遵知飲酒飫宴有節，禮不入寡婦之門，而湛酒溷肴，亂男女之別，輕辱爵位，羞汙印韍，惡不可忍聞。臣請皆免。」遵既免，歸長安，賓客愈盛，飲食自若。",
    "entities": [
      {
        "text": "備郡",
        "label": "LOC",
        "start": 28,
        "end": 30
      },
      {
        "text": "級州",
        "label": "LOC",
        "start": 32,
        "end": 34
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 158,
        "end": 160
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000177",
    "sentence": "久之，復為九江及河內都尉，凡三為二千石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000178",
    "sentence": "而張竦亦至丹陽太守，封淑德侯。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000179",
    "sentence": "後俱免官，以列侯歸長安。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000180",
    "sentence": "竦居貧，無賓客，時時好事者從之質疑問事，論道經書而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000181",
    "sentence": "而遵晝夜呼號，車騎滿門，酒肉相屬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000182",
    "sentence": "先是黃門郎揚雄作酒箴以諷諫成帝，其文為酒客難法度士，譬之於物，曰：「子猶瓶矣。觀瓶之居，居井之眉，處高臨深，動常近危。酒醪不入口，臧水滿懷，不得左右，牽於纆徽。一旦赙礙，為瓽所轠，身提黃泉，骨肉為泥。自用如此，不如鴟夷。鴟夷滑稽，腹如大壺，盡日盛酒，人復借酤。常為國器，託於屬車，出入兩宮，經營公家。繇是言之，酒何過乎！」遵大喜之，常謂張竦：「吾與爾猶是矣。足下諷誦經書，苦身自約，不敢差跌，而我放意自恣，浮湛俗間，官爵功名，不減於子，而差獨樂，顧不優邪！」竦曰：「人各有性，長短自裁。子欲為我亦不能，吾而效子亦敗矣。雖然，學我者易持，效子者雖將，吾常道也。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000183",
    "sentence": "及王莽敗，二人俱客於池陽，竦為賊兵所殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000184",
    "sentence": "更始至長安，大臣薦遵為大司馬護軍，與歸德侯劉颯俱使匈奴。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000185",
    "sentence": "單于欲脅詘遵，遵陳利害，為言曲直，單于大奇之，遣還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000186",
    "sentence": "會更始敗，遵留朔方，為賊所敗，時醉見殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000187",
    "sentence": "原涉",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000188",
    "sentence": "原涉字巨先。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000189",
    "sentence": "祖父武帝時以豪桀自陽翟徙茂陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000190",
    "sentence": "涉父哀帝時為南陽太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000191",
    "sentence": "天下殷富，大郡二千石死官，賦斂送葬皆千萬以上，妻子通共受之，以定產業。",
    "entities": [
      {
        "text": "大郡",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000192",
    "sentence": "時又少行三年喪者。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000193",
    "sentence": "及涉父死，讓還南陽賻送，行喪冢廬三年，繇是顯名京師。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000194",
    "sentence": "禮畢，扶風謁請為議曹，衣冠慕之輻輳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000195",
    "sentence": "為大司徒史丹舉能治劇，為谷口令，時年二十餘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000196",
    "sentence": "谷口聞其名，不言而治。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000197",
    "sentence": "先是涉季父為茂陵秦氏所殺，涉居谷口半歲所，自劾去官，欲報仇。",
    "entities": [
      {
        "text": "秦氏",
        "label": "ORG",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000198",
    "sentence": "谷口豪桀為殺秦氏，亡命歲餘，逢赦出。",
    "entities": [
      {
        "text": "秦氏",
        "label": "ORG",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000199",
    "sentence": "郡國諸豪及長安、五陵諸為氣節者皆歸慕之。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000200",
    "sentence": "涉遂傾身與相待，人無賢不肖闐門，在所閭里盡滿客。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000201",
    "sentence": "或譏涉曰：「子本吏二千石之世，結髮自修，以行喪推財禮讓為名，正復讎取仇，猶不失仁義，何故遂自放縱，為輕俠之徒乎？」涉應曰：「子獨不見家人寡婦邪？始自約敕之時，意乃慕宋伯姬及陳孝婦，不幸壹為盜賊所汙，遂行淫失，知其非禮，然不能自還。吾猶此矣！」",
    "entities": [
      {
        "text": "陳孝婦",
        "label": "PER",
        "start": 86,
        "end": 89
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000202",
    "sentence": "涉自以為前讓南陽賻送，身得其名，而令先人墳墓儉約，非孝也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000203",
    "sentence": "乃大治起冢舍，周閣重門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000204",
    "sentence": "初，武帝時，京兆尹曹氏葬茂陵，民謂其道為京兆仟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000205",
    "sentence": "涉慕之，乃買地開道，立表署曰南陽仟，人不肯從，謂之原氏仟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000206",
    "sentence": "費用皆卬富人長者，然身衣服車馬纔具，妻子內困。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000207",
    "sentence": "專以振施貧窮赴人之急為務。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000208",
    "sentence": "人嘗置酒請涉，涉入里門，客有道涉所知母病避疾在里宅者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000209",
    "sentence": "涉即往候，叩門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000210",
    "sentence": "家哭，涉因入弔，問以喪事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000211",
    "sentence": "家無所有，涉曰：「但絜埽除沐浴，待涉。」還至主人，對賓客歎息曰：「人親臥地不收，涉何心鄉此！願徹去酒食。」賓客爭問所當得，涉乃側席而坐，削牘為疏，具記衣被棺木，下至飯含之物，分付諸客。",
    "entities": [
      {
        "text": "涉何心鄉",
        "label": "LOC",
        "start": 40,
        "end": 44
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000212",
    "sentence": "諸客奔走市買，至日昳皆會。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000213",
    "sentence": "涉親閱視已，謂主人：「願受賜矣。」既共飲食，涉獨不飽，乃載棺物，從賓客往至喪家，為棺斂勞來畢葬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000214",
    "sentence": "其周急待人如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000215",
    "sentence": "後人有毀涉者曰「姦人之雄也」，喪家子即時刺殺言者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000216",
    "sentence": "賓客多犯法，罪過數上聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000217",
    "sentence": "王莽數收繫欲殺，輒復赦出之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000218",
    "sentence": "涉懼，求為卿府掾史，欲以避客。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000219",
    "sentence": "文母太后喪時，守復土校尉。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000220",
    "sentence": "已為中郎，后免官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000221",
    "sentence": "涉欲上冢，不欲會賓客，密獨與故人期會。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000222",
    "sentence": "涉單車敺上茂陵，投暮，入其里宅，因自匿不見人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000223",
    "sentence": "遣奴至市買肉，奴乘涉氣與屠爭言，斫傷屠者，亡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000224",
    "sentence": "是時，茂陵守令尹公新視事，涉未謁也，聞之大怒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000225",
    "sentence": "知涉名豪，欲以示眾厲俗，遣兩吏脅守涉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000226",
    "sentence": "至日中，奴不出，吏欲便殺涉去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000227",
    "sentence": "涉迫窘不知所為。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000228",
    "sentence": "會涉所與期上冢者車數十乘到，皆諸豪也，共說尹公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000229",
    "sentence": "尹公不聽，諸豪則曰：「原巨先奴犯法不得，使肉袒自縛，箭貫耳，詣廷門謝罪，於君威亦足矣。」尹公許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000230",
    "sentence": "涉如言謝，復服遣去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000231",
    "sentence": "初，涉與新豐富人祁太伯為友，太伯同母弟王游公素嫉涉，時為縣門下掾，說尹公曰：「君以守令辱原涉如是，一旦真令至，君復單車歸為府吏，涉刺客如雲，殺人皆不知主名，可為寒心。涉治冢舍，奢僭踰制，罪惡暴著，主上知之。今為君計，莫若墮壞涉冢舍，條奏其舊惡，君必得真令。如此，涉亦不敢怨矣。」尹公如其計，莽果以為真令。",
    "entities": [
      {
        "text": "時為縣",
        "label": "LOC",
        "start": 26,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000232",
    "sentence": "涉繇此怨王游公，選賓客，遣長子初從車二十乘劫王游公家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000233",
    "sentence": "游公母即祁太伯母也，諸客見之皆拜，傳曰「無驚祁夫人」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000234",
    "sentence": "遂殺游公父及子，斷兩頭去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000235",
    "sentence": "涉性略似郭解，外溫仁謙遜，而內隱好殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000236",
    "sentence": "睚眥於塵中，獨死者甚多。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000237",
    "sentence": "王莽末，東方兵起，諸王子弟多薦涉能得士死，可用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000238",
    "sentence": "莽乃召見，責以罪惡，赦貰，拜鎮戎大尹天水太守。",
    "entities": [
      {
        "text": "拜鎮",
        "label": "LOC",
        "start": 13,
        "end": 15
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000239",
    "sentence": "涉至官無幾，長安敗，郡縣諸假號起兵攻殺二千石長吏以應漢。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 6,
        "end": 8
      },
      {
        "text": "郡縣",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000240",
    "sentence": "諸假號素聞涉名，爭問原尹何在，拜謁之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000241",
    "sentence": "時莽州牧使者依附涉者皆得活。",
    "entities": [
      {
        "text": "時莽州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000242",
    "sentence": "傳送致涉長安，更始西屏將軍申屠建請涉與相見，大重之。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_092_000243",
    "sentence": "故茂陵令尹公壞涉冢舍者為建主簿，涉本不怨也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000244",
    "sentence": "涉從建所出，尹公故遮拜涉，謂曰：「易世矣，宜勿復相怨！」涉曰：「尹君，何壹魚肉涉也！」涉用是怒，使客刺殺主簿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_092_000245",
    "sentence": "涉欲亡去，申屠建內恨恥之，陽言「吾欲與原巨先共鎮三輔，豈以一吏易之哉！」賓客通言，令涉自繫獄謝，建許之。",
    "entities": [
      {
        "text": "欲與原巨先共鎮",
