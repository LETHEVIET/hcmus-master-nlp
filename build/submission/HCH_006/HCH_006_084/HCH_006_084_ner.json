  {
    "sentence_id": "HCH_006_084_000102",
    "sentence": "所居著名，有父風烈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_084_000103",
    "sentence": "徙為東郡太守。",
    "entities": [
