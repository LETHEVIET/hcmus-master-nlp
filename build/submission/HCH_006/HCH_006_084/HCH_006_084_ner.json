        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_084_000002",
    "sentence": "翟方進字子威，汝南上蔡人也。",
    "entities": [
      {
        "text": "翟方進",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_084_000003",
    "sentence": "家世微賤，至方進父翟公，好學，為郡文學。",
    "entities": [
      {
        "text": "為郡",
        "label": "LOC",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_084_000004",
    "sentence": "方進年十二三，失父孤學，給事太守府為小史，號遲頓不及事，數為掾史所詈辱。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_084_000005",
    "sentence": "方進自傷，乃從汝南蔡父相問己能所宜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_084_000006",
    "sentence": "蔡父大奇其形貌，謂曰：「小史有封侯骨，當以經術進，努力為諸生學問。」方進既厭為小史，聞蔡父言，心喜，因病歸家，辭其後母，欲西至京師受經。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_084_000007",
    "sentence": "母憐其幼，隨之長安，織屨以給方進讀，經博士受春秋。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 7,
        "end": 9
      },
      {
        "text": "博士",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_006_084_000008",
    "sentence": "積十餘年，經學明習，徒眾日廣，諸儒稱之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_084_000009",
    "sentence": "以射策甲科為郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_084_000010",
    "sentence": "二三歲，舉明經，遷議郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_084_000011",
    "sentence": "是時宿儒有清河胡常，與方進同經。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_084_000012",
    "sentence": "常為先進，名譽出方進下，心害其能，論議不右方進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_084_000013",
    "sentence": "方進知之，候伺常大都授時，遣門下諸生至常所問大義疑難，因記其說。",
    "entities": [
      {
        "text": "大都",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_084_000014",
    "sentence": "如是者久之，常知方進之宗讓己，內不自得，其後居士大夫之間未嘗不稱述方進，遂相親友。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_006_084_000015",
    "sentence": "河平中，方進轉為博士。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_084_000016",
    "sentence": "數年，遷朔方刺史，居官不煩苛，所察應條輒舉，甚有威名。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_084_000017",
    "sentence": "再三奏事，遷為丞相司直。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_084_000018",
    "sentence": "從上甘泉，行馳道中，司隸校尉陳慶劾奏方進，沒入車馬。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_084_000019",
    "sentence": "既至甘泉宮，會殿中，慶與廷尉范延壽語，時慶有章劾，自道：「行事以贖論，今尚書持我事來，當於此決。前我為尚書時，嘗有所奏事，忽忘之，留月餘。」方進於是舉劾慶曰：「案慶奉使刺舉大臣，故為尚書，知機事周密壹統，明主躬親不解。慶有罪未伏誅，無恐懼心，豫自設不坐之比。又暴揚尚書事，言遲疾無所在，虧損聖德之聰明，奉詔不謹，皆不敬，臣謹以劾。」慶坐免官。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 36,
        "end": 38
      },
      {
        "text": "尚書",
        "label": "TITLE",
