      }
    ]
  },
  {
    "sentence_id": "HCH_006_084_000020",
    "sentence": "會北地浩商為義渠長所捕，亡，長取其母，與豭豬連繫都亭下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_084_000021",
    "sentence": "商兄弟會賓客，自稱司隸掾、長安縣尉，殺義渠長妻子六人，亡。",
    "entities": [
      {
        "text": "長安縣",
        "label": "LOC",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_084_000022",
    "sentence": "丞相、御史請遣掾史與司隸校尉、部刺史并力逐捕，察無狀者，奏可。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "御史",
