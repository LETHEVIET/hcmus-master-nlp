      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000038",
    "sentence": "賜帝女弟四人號皆曰君，食邑各二千戶。",
    "entities": [
      {
        "text": "食邑",
        "label": "LOC",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000039",
    "sentence": "封周公後公孫相如為褒魯侯，孔子後孔均為褒成侯，奉其祀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000040",
    "sentence": "追諡孔子曰褒成宣尼公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000041",
    "sentence": "罷明光宮及三輔馳道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000042",
    "sentence": "天下女徒已論，歸家，顧山錢月三百。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000043",
    "sentence": "復貞婦，鄉一人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000044",
    "sentence": "置少府海丞、果丞各一人；大司農部丞十三人，人部一州，勸農桑。",
