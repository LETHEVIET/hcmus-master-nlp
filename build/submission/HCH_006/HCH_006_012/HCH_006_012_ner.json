      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000054",
    "sentence": "安漢公、四輔、三公、卿大夫、吏民為百困乏獻其田宅者二百三十人，以口賦貧民。",
    "entities": [
      {
        "text": "大夫",
