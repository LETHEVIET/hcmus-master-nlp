      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000072",
    "sentence": "四輔、公卿、大夫、博士、郎、吏家屬皆以禮娶，親迎立軺併馬。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "博士",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000073",
    "sentence": "夏，安漢公奏車服制度，吏民養生、送終、嫁娶、奴婢、田宅、器械之品。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000074",
    "sentence": "立官稷及學官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000075",
    "sentence": "郡國曰學，縣、道、邑、侯國曰校。",
    "entities": [
      {
        "text": "侯國",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000076",
    "sentence": "校、學置經師一人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000077",
    "sentence": "鄉曰庠，聚曰序。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000078",
    "sentence": "序、庠置孝經師一人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000079",
    "sentence": "陽陵任橫等自稱將軍，盜庫兵，攻官寺，出囚徒。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000080",
    "sentence": "大司徒掾督逐，皆伏辜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000081",
    "sentence": "安漢公世子宇與帝外家衛氏有謀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000082",
    "sentence": "宇下獄死，誅衛氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000083",
    "sentence": "四年春正月，郊祀高祖以配天，宗祀孝文以配上帝。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000084",
    "sentence": "改殷紹嘉公曰宋公，周承休公曰鄭公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000085",
    "sentence": "詔曰：「蓋夫婦正則父子親，人倫定矣。前詔有司復貞婦，歸女徒，誠欲以防邪辟，全貞信。及眊悼之人刑罰所不加，聖王之所制也。惟苛暴吏多拘繫犯法者親屬，婦女老弱，搆怨傷化，百姓苦之。其明敕百寮，婦女非身犯法，及男子年八十以上七歲以下，家非坐不道，詔所名捕，它皆無得繫。其當驗者，即驗問。定著令。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000086",
    "sentence": "二月丁未，立皇后王氏，大赦天下。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000087",
    "sentence": "遣太僕王惲等八人置副，假節，分行天下，覽觀風俗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000088",
    "sentence": "賜九卿已下至六百石、宗室有屬籍者爵，自五大夫以上各有差。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000089",
    "sentence": "賜天下民爵一級，鰥寡孤獨高年帛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000090",
    "sentence": "夏，皇后見于高廟。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000091",
    "sentence": "加安漢公號曰「宰衡」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000092",
    "sentence": "賜公太夫人號曰功顯君。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000093",
    "sentence": "封公子安、臨皆為列侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000094",
    "sentence": "安漢公奏立明堂、辟廱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000095",
    "sentence": "尊孝宣廟為中宗，孝元廟為高宗，天子世世獻祭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000096",
    "sentence": "置西海郡，徙天下犯禁者處之。",
    "entities": [
      {
        "text": "置西海郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000097",
    "sentence": "梁王立有罪，自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000098",
    "sentence": "分京師置前煇光、後丞烈二郡。",
    "entities": [
      {
        "text": "後丞烈二郡",
        "label": "LOC",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000099",
    "sentence": "更公卿、大夫、八十一元士官名位次及十二州名。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "名位次及十二州",
        "label": "LOC",
        "start": 13,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000100",
    "sentence": "分界郡國所屬，罷置改易，天下多事，吏不能紀。",
    "entities": [
      {
        "text": "分界郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000101",
    "sentence": "冬，大風吹長安城東門屋瓦且盡。",
    "entities": [
      {
        "text": "大風吹長安城",
        "label": "LOC",
        "start": 2,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000102",
    "sentence": "五年春正月，祫祭明堂。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000103",
    "sentence": "諸侯王二十八人、列侯百二十人、宗室子九百餘人徵助祭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000104",
    "sentence": "禮畢，皆益戶，賜爵及金帛，增秩補吏，各有差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000105",
    "sentence": "詔曰：「蓋聞帝王以德撫民，其次親親以相及也。昔堯睦九族，舜惇敘之。朕以皇帝幼年，且統國政，惟宗室子皆太祖高皇帝子孫及兄弟吳頃、楚元之後，漢元至今，十有餘萬人，雖有王侯之屬，莫能相糾，或陷入刑罪，教訓不至之咎也。傳不云乎？『君子篤於親，則民興於仁。』其為宗室自太上皇以來族親，各以世氏，郡國置宗師以糾之，致教訓焉。二千石選有德義者以為宗師。考察不從教令有冤失職者，宗師得因郵亭書言宗伯，請以聞。常以歲正月賜宗師帛各十匹。」",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 35,
        "end": 37
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 53,
        "end": 55
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000106",
    "sentence": "羲和劉歆等四人使治明堂、辟廱，令漢與文王靈臺、周公作洛同符。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000107",
    "sentence": "太僕王惲等八人使行風俗，宣明德化，萬國齊同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000108",
    "sentence": "皆封為列侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000109",
    "sentence": "徵天下通知逸經、古記、天文、曆算、鍾律、小學、史篇、方術、本草及以五經、論語、孝經、爾雅教授者，在所為駕一封軺傳，遣詣京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000110",
    "sentence": "至者數千人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000111",
    "sentence": "閏月，立梁孝王玄孫之耳孫音為王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000112",
    "sentence": "冬十二月丙午，帝崩于未央宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000113",
    "sentence": "大赦天下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000114",
    "sentence": "有司議曰：「禮，臣不殤君。皇帝年十有四歲，宜以禮斂，加元服。」奏可。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000115",
    "sentence": "葬康陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000116",
    "sentence": "詔曰：「皇帝仁惠，無不顧哀，每疾一發，氣輒上逆，害於言語，故不及有遺詔。其出媵妾，皆歸家得嫁，如孝文時故事。」",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000117",
    "sentence": "【贊】",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000118",
    "sentence": "贊曰：孝平之世，政自莽出，褒善顯功，以自尊盛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000119",
    "sentence": "觀其文辭，方外百蠻，亡思不服；休徵嘉應，頌聲並作。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000120",
    "sentence": "至乎變異見於上，民怨於下，莽亦不能文也。",
    "entities": []
  }
]
