        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000006",
    "sentence": "新都侯王莽為大司馬，領尚書事。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 7,
        "end": 9
