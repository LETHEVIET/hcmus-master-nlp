      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000062",
    "sentence": "秋，舉勇武有節明兵法，郡一人，詣公車。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000063",
    "sentence": "九月戊申晦，日有蝕之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000064",
    "sentence": "赦天下徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000065",
    "sentence": "使謁者大司馬掾四十四人持節行邊兵。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000066",
    "sentence": "遣執金吾候陳茂假以鉦鼓，募汝南、南陽勇敢吏士三百人，諭說江湖賊成重等二百餘人皆自出，送家在所收事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000067",
    "sentence": "重徙雲陽，賜公田宅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000068",
    "sentence": "冬，中二千石舉治獄平，歲一人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000069",
    "sentence": "三年春，詔有司為皇帝納采安漢公莽女。",
    "entities": [
