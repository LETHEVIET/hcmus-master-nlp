  },
  {
    "sentence_id": "HCH_006_012_000046",
    "sentence": "秋九月，赦天下徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000047",
    "sentence": "以中山苦陘縣為中山孝王后湯沐邑。",
