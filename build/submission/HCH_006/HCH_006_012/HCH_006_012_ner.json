      }
    ]
  },
  {
    "sentence_id": "HCH_006_012_000003",
    "sentence": "母曰衛姬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000004",
    "sentence": "年三歲嗣立為王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000005",
    "sentence": "元壽二年 六月，哀帝崩，太皇太后詔曰：「大司馬賢年少，不合眾心。其上印綬，罷。」賢即日自殺。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "司馬",
