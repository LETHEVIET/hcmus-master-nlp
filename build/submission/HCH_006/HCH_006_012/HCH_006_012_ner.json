    ]
  },
  {
    "sentence_id": "HCH_006_012_000021",
    "sentence": "又令諸侯王、公、列侯、關內侯亡子而有孫若子同產子者，皆得以為嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000022",
    "sentence": "公、列侯嗣子有罪，耐以上先請。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000023",
    "sentence": "宗室屬未盡而以罪絕者，復其屬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000024",
    "sentence": "其為吏舉廉佐史，補四百石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000025",
    "sentence": "天下吏比二千石以上年老致仕者，參分故祿，以一與之，終其身。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_012_000026",
    "sentence": "遣諫大夫行三輔，舉籍吏民，以元壽二年倉卒時橫賦斂者，償其直。",
    "entities": [
      {
        "text": "大夫",
