[
  {
    "sentence_id": "HCH_006_060_000001",
    "sentence": "杜周 杜延年 杜緩 杜欽 杜業",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000002",
    "sentence": "杜周",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000003",
    "sentence": "杜周，南陽杜衍人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000004",
    "sentence": "義縱為南陽太守，以周為爪牙，薦之張湯，為廷尉史。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000005",
    "sentence": "使案邊失亡，所論殺甚多。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000006",
    "sentence": "奏事中意，任用，與減宣更為中丞者十餘歲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000007",
    "sentence": "周少言重遲，而內深次骨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000008",
    "sentence": "宣為左內史，周為廷尉，其治大抵放張湯，而善候司。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000009",
    "sentence": "上所欲擠者，因而陷之；上所欲釋，久系待問而微見其冤狀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000010",
    "sentence": "客有謂周曰：「君為天下決平，不循三尺法，專以人主意指為獄，獄者固如是乎？」周曰：「三尺安出哉？前主所是著為律，後主所是疏為令；當時為是，何古之法乎！」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000011",
    "sentence": "至周為廷尉，詔獄亦益多矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000012",
    "sentence": "二千石系者新故相因，不減百餘人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000013",
    "sentence": "郡吏大府舉之延尉，一歲至千餘章。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000014",
    "sentence": "章大者連逮證案數百，小者數十人；遠者數千里，近者數百里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000015",
    "sentence": "會獄，吏因責如章告劾，不服，以掠笞定之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000016",
    "sentence": "於是聞有逮證，皆亡匿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000017",
    "sentence": "獄久者至更數赦十餘歲而相告言，大氐盡詆以不道，以上延尉及中都官，詔獄逮至六七萬人，吏所增加十有餘萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000018",
    "sentence": "周中廢，後為執金吾，逐捕桑弘羊、衛皇后昆弟子刻深，上以為盡力無私，遷為御史大夫。",
    "entities": [
      {
        "text": "周",
        "label": "ORG",
        "start": 0,
        "end": 1
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 17,
        "end": 19
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 35,
        "end": 37
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 37,
        "end": 39
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000019",
    "sentence": "始周為廷史，有一馬，及久任事，列三公，而兩子夾河為郡守，家訾累巨萬矣。",
    "entities": [
      {
        "text": "而兩子夾河為郡",
        "label": "LOC",
        "start": 19,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000020",
    "sentence": "治皆酷暴，唯少子延年行寬厚雲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000021",
    "sentence": "子 延年",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000022",
    "sentence": "延年字幼公，亦明法律。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000023",
    "sentence": "昭帝初立，大將軍霍光秉政，以延年三公子，吏材有餘，補軍司空。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000024",
    "sentence": "始元四年，益州蠻夷反，延年以校尉將南陽士擊益州，還，為諫大夫。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "益州",
        "label": "LOC",
        "start": 5,
        "end": 7
      },
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "將南陽士擊益州",
        "label": "LOC",
        "start": 16,
        "end": 23
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000025",
    "sentence": "左將軍上官桀父子與蓋主、燕王謀為逆亂。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000026",
    "sentence": "假稻田使者燕倉知其謀，以告大司農楊敞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000027",
    "sentence": "敝惶懼，移病，以語延年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000028",
    "sentence": "延年以聞，桀等伏辜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000029",
    "sentence": "延年封為建平侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000030",
    "sentence": "延年本大將軍霍光吏，首發大奸，有忠節，由是擢為太僕、右曹、給事中。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000031",
    "sentence": "光持刑罰嚴，延年輔之以寬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000032",
    "sentence": "治燕王獄時，御史大夫桑弘羊子遷亡，過父故吏侯史吳。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000033",
    "sentence": "後遷捕得，伏法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000034",
    "sentence": "會赦，侯史吳自出繫獄，廷尉王平與少府徐仁雜治反事，皆以為桑遷坐父謀反而侯史吳臧之，非匿反者，乃匿為隨者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000035",
    "sentence": "即以赦令除吳罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000036",
    "sentence": "後侍御史治實，以桑遷通經術，知父謀反而不諫爭，與反者身無異；侯史吳故三百石吏，首匿遷，不與庶人匿隨從者等，吳不得赦。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000037",
    "sentence": "奏請復治，劾廷尉、少府縱反者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000038",
    "sentence": "少府徐仁即丞相車千秋女婿也，故千秋數為侯史吳言。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000039",
    "sentence": "恐光不聽，千秋即召中二千石、博士會公車門，議問吳法。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000040",
    "sentence": "議者知大將軍指，皆執吳為不道。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000041",
    "sentence": "明日，千秋封上眾議，光於是以千秋擅召中二千石以下，外內異言，遂下廷尉平、少府仁獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000042",
    "sentence": "朝廷皆恐丞相坐之。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000043",
    "sentence": "延年乃奏記光爭，以為「吏縱罪人，有常法，今更詆吳為不道，恐於法深。又丞相素無所守持，而為好言於下，盡其素行也。至擅召中二千石，甚無狀。延年愚，以為丞相久故，及先帝用事，非有大故，不可棄也。間者民頗言獄深，吏為峻詆，今丞相所議，又獄事也，如是以及丞相，恐不合眾心。群下言雚嘩，庶人私議，流言四布，延年竊重將軍失此名於天下也！」光以廷尉、少府弄法輕重，皆論棄市，而不以及丞相，終與相竟。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 34,
        "end": 36
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 73,
        "end": 75
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 108,
        "end": 110
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 122,
        "end": 124
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 151,
        "end": 153
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 183,
        "end": 185
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000044",
    "sentence": "延年論議持平，合和朝廷，皆此類也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000045",
    "sentence": "見國家承武帝奢侈師旅之後，數為大將軍光言：「年歲比不登，流民未盡還，宜修孝文明政，示以儉約寬和，順天心，說民意，年歲宜應。」光納其言，舉賢良，議罷酒榷、鹽、鐵，皆自延年發之。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000046",
    "sentence": "吏民上書言便宜，有異，輒下延年平處復奏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000047",
    "sentence": "言可官試者，至為縣令，或丞相、御史除用，滿歲以狀聞，或抵其罪法，常與兩府及廷尉分章。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000048",
    "sentence": "昭帝末，寢疾，征天下名醫，延年典領方藥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000049",
    "sentence": "帝崩，昌邑王即位，廢，大將軍光、車騎將軍張安世與大臣議所立。",
    "entities": [
      {
        "text": "昌邑",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 11,
        "end": 14
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000050",
    "sentence": "時，宣帝養於掖廷，號皇曾孫，與延年中子佗相愛善，延年知曾孫德美，勸光、安世立焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000051",
    "sentence": "宣帝即位，褒賞大臣，延年以定策安宗廟，益戶二千三百，與始封所食邑凡四千三百戶。",
    "entities": [
      {
        "text": "與始封所食邑",
        "label": "LOC",
        "start": 26,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000052",
    "sentence": "詔有司論定策功：大司馬大將軍光功德過太尉絳侯周勃；車騎將軍安世、丞相楊敞功比丞相陳平；前將軍韓增、御史大夫蔡誼功比穎陰侯灌嬰；太僕杜延年功比硃虛侯劉章；後將軍趙充國、大司農田延年、少府史樂成功比典客劉揭，皆封侯益土。",
    "entities": [
      {
