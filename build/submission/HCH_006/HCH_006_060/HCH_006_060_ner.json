      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 77,
        "end": 79
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000053",
    "sentence": "延年為人安和，備於諸事，久典朝政，上任信之，出即奉駕，入給事中，居九卿位十餘年，賞賜賂遺，訾數千萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000054",
    "sentence": "霍光薨後，子禹與宗族謀反，誅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000055",
    "sentence": "上以延年霍氏舊人，欲退之，而丞相魏相奏延年素貴用事，官職多奸。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000056",
    "sentence": "遣吏考案，但得苑馬多死，官奴婢乏衣食，延年坐免官，削戶二千。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000057",
    "sentence": "後數月，復召拜為北地太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000058",
    "sentence": "延年以故九卿外為邊吏，治郡不進，上以璽書讓延年。",
    "entities": [
      {
        "text": "治郡",
        "label": "LOC",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000059",
    "sentence": "延年乃選用良吏，捕擊豪強，郡中清靜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000060",
    "sentence": "居歲餘，上使謁者賜延年璽書，黃金二千斤，徙為西河太守，治甚有名。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000061",
    "sentence": "五鳳中，征入為御史大夫。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000062",
    "sentence": "延年居父官府，不敢當舊位，坐臥皆易其處。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000063",
    "sentence": "是時，四夷和，海內平，延年視事三歲，以老病乞骸骨，天子優之，使光祿大夫持節賜延年黃金百斤、酒，加致醫藥，延年遂稱病篤。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_006_060_000064",
    "sentence": "賜安車駟馬，罷就第。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_060_000065",
    "sentence": "後數月薨，謚曰敬侯，子緩嗣。",
    "entities": []
  },
