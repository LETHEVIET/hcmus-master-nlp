      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000113",
    "sentence": "王、王后計欲毋遣太子，遂發兵。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000114",
    "sentence": "計未定，猶與十餘日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000115",
    "sentence": "會有詔即訊太子，淮南相怒壽春丞留太子逮不遣，劾不敬。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "太子",
