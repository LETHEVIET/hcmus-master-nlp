      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000194",
    "sentence": "后怒，以告王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000195",
    "sentence": "王乃召，欲縛笞之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000196",
    "sentence": "太子知王常欲廢己而立孝，乃謂王曰：「孝與王御者姦，無采與奴姦，王強食，請上書。」即背王去。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000197",
    "sentence": "王使人止之，莫能禁，王乃自追捕太子。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000198",
    "sentence": "太子妄惡言，王械繫宮中。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000199",
    "sentence": "孝日益以親幸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000200",
    "sentence": "王奇孝材能，乃佩之王印，號曰將軍，今居外家，多給金錢，招致賓客。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000201",
    "sentence": "賓客來者，微知淮南、衡山有逆計，皆將養勸之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000202",
    "sentence": "王乃使孝客江都人枚赫、陳喜作輣車鍛矢，刻天子璽，將、相、軍吏印。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000203",
    "sentence": "王日夜求壯士如周丘等，數稱引吳楚反時計畫約束。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000204",
    "sentence": "衡山王非敢效淮南王求即天子位，畏淮南起并其國，以為淮南已西，發兵定江淮間而有之，望如是。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000205",
    "sentence": "元朔五年秋，當朝，六年，過淮南。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "六年",
        "label": "TME",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000206",
    "sentence": "淮南王乃昆弟語，除前隙，約束反具。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000207",
    "sentence": "衡山王即上書謝病，上賜不朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000208",
    "sentence": "乃使人上書請廢太子爽，立孝為太子。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000209",
    "sentence": "爽聞，即使所善白嬴之長安上書，言衡山王與子謀逆，言孝作兵車鍛矢，與王御者姦。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000210",
    "sentence": "至長安未及上書，即吏捕嬴，以淮南事繫。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000211",
    "sentence": "王聞之，恐其言國陰事，即上書告太子，以為不道。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000212",
    "sentence": "事下沛郡治。",
    "entities": [
      {
        "text": "事下沛郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000213",
    "sentence": "元狩元年冬，有司求捕與淮南王謀反者，得陳喜於孝家。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000214",
    "sentence": "吏劾孝首匿喜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000215",
    "sentence": "孝以為陳喜雅數與王計反，恐其發之，聞律先自告除其罪，又疑太子使白嬴上書發其事，即先自告所與謀反者枚赫、陳喜等。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000216",
    "sentence": "廷尉治，事驗，請逮捕衡山王治。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000217",
    "sentence": "上曰：「勿捕。」遣中尉安、大行息即問王，王具以情實對。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000218",
    "sentence": "吏皆圍王宮守之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000219",
    "sentence": "中尉、大行還，以聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000220",
    "sentence": "公卿請遣宗正、大行與沛郡雜治王。",
    "entities": [
      {
        "text": "大行與沛郡",
        "label": "LOC",
        "start": 7,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000221",
    "sentence": "王聞，即自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000222",
    "sentence": "孝先自告反，告除其罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000223",
    "sentence": "孝坐與王御婢姦，及后徐來坐蠱前后乘舒，及太子爽坐告王父不孝，皆棄市。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000224",
    "sentence": "諸坐與王謀反者皆誅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000225",
    "sentence": "國除為郡。",
    "entities": [
      {
        "text": "國除為郡",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000226",
    "sentence": "濟北王",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000227",
    "sentence": "濟北貞王勃者，景帝四年徙。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000228",
    "sentence": "徙二年，因前王衡山，凡十四年薨。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 1,
        "end": 3
      },
      {
        "text": "十四年",
        "label": "TME",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000229",
    "sentence": "子式王胡嗣，五十四年薨。",
    "entities": [
      {
        "text": "五十四年",
        "label": "TME",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000230",
    "sentence": "子寬嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000231",
    "sentence": "十二年，寬坐與父式王后光、姬孝兒姦，誖人倫，又祠祭祝詛上，有司請誅。",
    "entities": [
      {
        "text": "十二年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000232",
    "sentence": "上遣大鴻臚利召王，王以刃自剄死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000233",
    "sentence": "國除為北安縣，屬泰山郡。",
    "entities": [
      {
        "text": "國除為北安縣",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "屬泰山郡",
