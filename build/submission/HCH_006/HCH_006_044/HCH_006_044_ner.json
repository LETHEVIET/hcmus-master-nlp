      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000103",
    "sentence": "妃求去，王乃上書謝歸之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000104",
    "sentence": "后荼、太子遷及女陵擅國權，奪民田宅，妄致繫人。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000105",
    "sentence": "太子學用劍，自以為人莫及，聞郎中雷被巧，召與戲。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000106",
    "sentence": "被壹再辭讓，誤中太子。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000107",
    "sentence": "太子怒，被恐。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000108",
    "sentence": "此時有欲從軍者輒詣長安，被即願奮擊匈奴。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000109",
    "sentence": "太子數惡被，王使郎中令斥免，欲以禁後。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000110",
    "sentence": "元朔五年，被遂亡之長安，上書自明。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "長安",
