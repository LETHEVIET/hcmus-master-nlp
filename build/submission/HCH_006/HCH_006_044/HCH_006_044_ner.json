      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000121",
    "sentence": "王視漢中尉顏色和，問斥雷被事耳，自度無何，不發。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 2,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000122",
    "sentence": "中尉還，以聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000123",
    "sentence": "公卿治者曰：「淮南王安雍閼求奮擊匈奴者雷被等，格明詔，當棄市。」詔不許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000124",
    "sentence": "請廢勿王，上不許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000125",
    "sentence": "請削五縣，可二縣。",
    "entities": [
      {
        "text": "請削五縣",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "可二縣",
