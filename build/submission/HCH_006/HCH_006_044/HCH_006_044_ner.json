      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000111",
    "sentence": "事下廷尉、河南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000112",
    "sentence": "河南治，逮淮南太子。",
