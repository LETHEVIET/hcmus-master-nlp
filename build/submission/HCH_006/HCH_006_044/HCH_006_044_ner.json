      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000187",
    "sentence": "元朔四年中，人有賊傷后假母者，王疑太子使人傷之，笞太子。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "太子",
