[
  {
    "sentence_id": "HCH_006_044_000001",
    "sentence": "淮南王",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000002",
    "sentence": "淮南厲王長，高帝少子也，其母故趙王張敖美人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000003",
    "sentence": "高帝八年，從東垣過趙，趙王獻美人，厲王母也，幸，有身。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000004",
    "sentence": "趙王不敢內宮，為築外宮舍之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000005",
    "sentence": "及貫高等謀反事覺，并逮治王，盡捕王母兄弟美人，繫之河內。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000006",
    "sentence": "厲王母亦繫，告吏曰：「日得幸上，有子。」吏以聞，上方怒趙，未及理厲王母，厲王母弟趙兼因辟陽侯言呂后，呂后妒，不肯白，辟陽侯不強爭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000007",
    "sentence": "厲王母已生厲王，恚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000008",
    "sentence": "即自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000009",
    "sentence": "吏奉厲王詣上，上悔，令呂后母之，而葬其母真定。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000010",
    "sentence": "真定，厲王母家縣也。",
    "entities": [
      {
        "text": "厲王母家縣",
        "label": "LOC",
        "start": 3,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000011",
    "sentence": "十一年，淮南王布反，上自將擊滅布，即立子長為淮南王。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000012",
    "sentence": "王早失母，常附呂后，孝惠、呂后時以故得幸無患，然常心怨辟陽侯，不敢發。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000013",
    "sentence": "及孝文初即位，自以為最親，驕蹇，數不奉法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000014",
    "sentence": "上寬赦之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000015",
    "sentence": "三年，入朝，甚橫。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000016",
    "sentence": "從上入苑獵，與上同輦，常謂上「大兄」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000017",
    "sentence": "厲王有材力，力扛鼎，乃往請辟陽侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000018",
    "sentence": "辟陽侯出見之，即自袖金椎椎之，命從者刑之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000019",
    "sentence": "馳詣闕下，肉袒而謝曰：「臣母不當坐趙時事，辟陽侯力能得之呂后，不爭，罪一也。趙王如意子母無罪，呂后殺之，辟陽侯不爭，罪二也。呂后王諸呂，欲以危劉氏，辟陽侯不爭，罪三也。臣謹為天下誅賊，報母之仇，伏闕下請罪。」文帝傷其志，為親故不治，赦之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000020",
    "sentence": "當是時，自薄太后及太子諸大臣皆憚厲王。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000021",
    "sentence": "厲王以此歸國益恣，不用漢法，出入警蹕，稱制，自作法令，數上書不遜順。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000022",
    "sentence": "文帝重自切責之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000023",
    "sentence": "時帝舅薄昭為將軍，尊重，上令昭予厲王書諫數之，曰：",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000024",
    "sentence": "竊聞大王剛直而勇，慈惠而厚，貞信多斷，是天以聖人之資奉大王也甚盛，不可不察。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000025",
    "sentence": "今大王所行，不稱天資。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000026",
    "sentence": "皇帝初即位，易侯邑在淮南者，大王不肯。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "易侯邑",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000027",
    "sentence": "皇帝卒易之，使大王得三縣之實，甚厚。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "使大王得三縣",
        "label": "LOC",
        "start": 6,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000028",
    "sentence": "大王以未嘗與皇帝相見，求入朝見，未畢昆弟之歡，而殺列侯以自為名。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000029",
    "sentence": "皇帝不使吏與其間，赦大王，甚厚。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000030",
    "sentence": "漢法，二千石缺，輒言漢補，大王逐漢所置，而請自置相、二千石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000031",
    "sentence": "皇帝骫天下正法而許大王，甚厚。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000032",
    "sentence": "大王欲屬國為布衣，守冢真定。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000033",
    "sentence": "皇帝不許，使大王毋失南面之尊，甚厚。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000034",
    "sentence": "大王宜日夜奉法度，修貢職，以稱皇帝之厚德，今乃輕言恣行，以負謗於天下，甚非計也。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000035",
    "sentence": "夫大王以千里為宅居，以萬民為臣妾，此高皇帝之厚德也。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000036",
    "sentence": "高帝蒙霜露，沬風雨，赴矢石，野戰次城，身被創痍，以為子孫成萬世之業，艱難危苦甚矣。",
    "entities": [
      {
        "text": "野戰次城",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000037",
    "sentence": "大王不思先帝之艱苦，日夜怵惕，修身正行，養犧牲，豐潔粢盛，奉祭祀，以無忘先帝之功德，而欲屬國為布衣，甚過。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000038",
    "sentence": "且夫貪讓國土之名，輕廢先帝之業，不可以言孝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000039",
    "sentence": "父為之基，而不能守，不賢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000040",
    "sentence": "不求守長陵，而求之真定，先母後父，不誼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000041",
    "sentence": "數逆天子之令，不順。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000042",
    "sentence": "言節行以高兄，無禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000043",
    "sentence": "幸臣有罪，大者立斷，小者肉刑，不仁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000044",
    "sentence": "貴布衣一劍之任，賤王侯之位，不知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000045",
    "sentence": "不好學問大道，觸情妄行，不詳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000046",
    "sentence": "此八者，危亡之路也，而大王行之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000047",
    "sentence": "棄南面之位，奮諸、賁之勇，常出入危亡之路，臣之所見，高皇帝之神必不廟食於大王之手，明白。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000048",
    "sentence": "昔者，周公誅管叔，放蔡叔，以安周；齊桓殺其弟，以反國；秦始皇殺兩弟，遷其母，以安秦；頃王亡代，高帝奪之國，以便事；濟北舉兵，皇帝誅之，以安漢。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 62,
        "end": 64
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000049",
    "sentence": "故周、齊行之於古，秦、漢用之於今，大王不察古今之所以安國便事，而欲以親戚之意望於太上，不可得也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000050",
    "sentence": "亡之諸侯，游宦事人，及舍匿者，論皆有法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000051",
    "sentence": "其在王所，吏主者坐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000052",
    "sentence": "今諸侯子為吏者，御史主；為軍吏者，中尉主；客出入殿門者，衛尉大行主；諸從蠻夷來歸誼及以亡名數自古者，內史縣令主。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 52,
        "end": 54
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000053",
    "sentence": "相欲委下吏，無與其禍，不可得也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000054",
    "sentence": "王若不改，漢繫大王邸，論相以下，為之奈何？",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000055",
    "sentence": "夫墮父大業，退為布衣所哀，幸臣皆伏法而誅，為天下笑，以羞先帝之德，甚為大王不取也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000056",
    "sentence": "宜急改操易行，上書謝罪，曰：「臣不幸早失先帝，少孤，呂氏之世，未嘗忘死。陛下即位，臣怙恩德驕盈，行多不軌。追念罪過，恐懼，伏地待誅不敢起。」皇帝聞之必喜。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 70,
        "end": 72
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000057",
    "sentence": "大王昆弟歡欣於上，群臣皆得延壽於下；上下得宜，海內常安。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000058",
    "sentence": "願孰計而疾行之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000059",
    "sentence": "行之有疑，禍如發矢，不可追已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000060",
    "sentence": "王得書不說。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000061",
    "sentence": "六年，令男子但等七十人與棘蒲侯柴武太子奇謀，以輦車四十乘反谷口，令人使閩越、匈奴。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_006_044_000062",
    "sentence": "事覺，治之，乃使使召淮南王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_044_000063",
    "sentence": "王至長安，丞相張蒼，典客馮敬行御史大夫事，與宗正、廷尉雜奏：「長廢先帝法，不聽天子詔，居處無度，為黃屋蓋儗天子，擅為法令，不用漢法。及所置吏，以其郎中春為丞相，收聚漢諸侯人及有罪亡者，匿與居，為治家室，賜與財物爵祿田宅，爵或至關內侯，奉以二千石所當得。大夫但、士伍開章等七十人與棘蒲侯太子奇謀反，欲以危宗廟社稷，謀使閩越及匈奴發其兵。事覺，長安尉奇等往捕開章，長匿不予，與故中尉蕑忌謀，殺以閉口，為棺槨衣衾，葬之肥陵，謾吏曰『不知安在』。又陽聚土，樹表其上曰『開章死，葬此下』。及長身自賊殺無罪者一人；令吏論殺無罪者六人；為亡命棄市詐捕命者以除罪；擅罪人，無告劾繫治城旦以上十四人；敗免罪人死罪十八人，城旦舂以下五十八人；賜人爵關內侯以下九十四人。前日長病，陛下心憂之，使使者賜棗脯，長不肯見拜使者。南海民處廬江界中者反，淮南吏卒擊之。陛下遣使者齎帛五十匹，以賜吏卒勞苦者。長不欲受賜，謾曰『無勞苦者』。南海王織上書獻璧帛皇帝，忌擅燔其書，不以聞。吏請召治忌，長不遣，謾曰『忌病』。長所犯不軌，當棄市，臣請論如法。」",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 2,
        "end": 4
      },
      {
