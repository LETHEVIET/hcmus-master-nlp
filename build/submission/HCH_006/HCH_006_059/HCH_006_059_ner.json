[
  {
    "sentence_id": "HCH_006_059_000001",
    "sentence": "張湯 張安世 張延壽 張勃 張臨 張放 張純",
    "entities": [
      {
        "text": "張安世",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000002",
    "sentence": "張湯",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000003",
    "sentence": "張湯，杜陵人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000004",
    "sentence": "父為長安丞，出，湯為兒守舍。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000005",
    "sentence": "還，鼠盜肉，父怨，笞湯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000006",
    "sentence": "湯掘熏得鼠及餘肉，劾鼠掠治，傳爰書，訊鞫論報，並取鼠與肉，具獄磔堂下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000007",
    "sentence": "父見之，視文辭如老獄吏，大驚，遂使書獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000008",
    "sentence": "父死後，湯為長安吏。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000009",
    "sentence": "周陽侯為諸卿時，嘗繫長安，湯傾身事之。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000010",
    "sentence": "及出為侯，大與湯交，遍見貴人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000011",
    "sentence": "湯給事內史，為甯成掾，以湯為無害，言大府，調茂陵尉，治方中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000012",
    "sentence": "武安侯為丞相，徵湯為史，薦補侍御史。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000013",
    "sentence": "治陳皇后巫蠱獄，深竟黨與，上以為能，遷太史大夫。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000014",
    "sentence": "與趙禹共定諸律令，務在深文，拘守職之吏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000015",
    "sentence": "已而禹至少府，湯為廷尉，兩人交歡，兄事禹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000016",
    "sentence": "禹志在奉公孤立，而湯舞知以御人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000017",
    "sentence": "始為小吏，干沒，與長安富賈田甲、魚翁叔之屬交私。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000018",
    "sentence": "及列九卿，收接天下名士大夫，己內心雖不合，然陽浮道與之。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000019",
    "sentence": "是時，上方鄉文學，湯決大獄，欲傅古義，乃請博士弟子治《尚書》、《春秋》，補廷尉史，平亭疑法。",
    "entities": [
      {
        "text": "上方鄉",
        "label": "LOC",
        "start": 3,
        "end": 6
      },
      {
        "text": "博士",
        "label": "TITLE",
        "start": 21,
        "end": 23
      },
      {
        "text": "《春秋》",
        "label": "TITLE",
        "start": 31,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000020",
    "sentence": "奏讞疑，必奏先為上分別其原，上所是，受而著讞法廷尉挈令，揚主之明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000021",
    "sentence": "奏事即譴，湯摧謝，鄉上意所便，必引正監掾史賢者，曰：「固為臣議，如上責臣，臣弗用，愚抵此。」罪常釋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000022",
    "sentence": "間即奏事，上善之，曰：「臣非知為此奏，乃監、掾、史某所為。」其欲薦吏，揚人之善、解人之過如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000023",
    "sentence": "所治即上意所欲罪，予監吏深刻者；即上意所欲釋，予監吏輕平者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000024",
    "sentence": "所治即豪，必舞文巧詆；即下戶羸弱，時口言「雖文致法，上裁察。」於是往往釋湯所言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000025",
    "sentence": "湯至於大吏，內行修，交通賓客飲食，於故人子弟為吏及貧昆弟，調護之尤厚，其造請諸公，不避寒暑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000026",
    "sentence": "是以湯雖文深意忌不專平，然得此聲譽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000027",
    "sentence": "而深刻吏多為爪牙用者，依於文學之士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000028",
    "sentence": "丞相弘數稱其美。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000029",
    "sentence": "及治淮南、衡山、江都反獄，皆窮根本。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000030",
    "sentence": "嚴助、伍被，上欲釋之，湯爭曰：「伍被本造反謀，而助親幸出入禁闥，腹心之臣，乃交私諸侯如此，弗誅，後不可治。」上可論之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000031",
    "sentence": "其治獄所巧排大臣自以為功，多此類。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000032",
    "sentence": "繇是益尊任，遷御史大夫。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000033",
    "sentence": "會渾邪等降，漢大興兵伐匈奴，山東水旱，貧民流徙，皆卬給縣官，縣官空虛。",
    "entities": [
      {
        "text": "皆卬給縣",
        "label": "LOC",
        "start": 24,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000034",
    "sentence": "湯承上指，請造白金及五銖錢，籠天下鹽鐵，排富商大賈，出告緡令，鋤豪強並兼之家，舞文巧詆以輔法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000035",
    "sentence": "湯每朝奏事，語國家用，日旰，天子忘食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000036",
    "sentence": "丞相取充位，天子事皆決湯。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000037",
    "sentence": "百姓不安其生，騷動，縣官所興未獲其利，奸吏並侵漁，於是痛繩以罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000038",
    "sentence": "自公卿以下至於庶人咸指湯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000039",
    "sentence": "湯嘗病，上自至捨視，其隆貴如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000040",
    "sentence": "匈奴求和親，群臣議前，博士狄山曰：「和親便。」上問其便，山曰：「兵，凶器，未易數動。高帝欲伐匈奴，大困平城，乃遂結和親。孝惠、高后時，天下安樂，及文帝欲事匈奴，北邊蕭然苦兵。孝景時，吳、楚七國反，景帝往來東宮間，天下寒心數月。吳、楚已破，竟景帝不言兵，天下富實。今自陛下興兵擊匈奴，中國以空虛，邊大困貧。由是觀之，不如和親。」上問湯，湯曰：「此愚儒無知。」狄山曰：「臣固愚忠，若御史大夫湯，乃詐忠。湯之治淮南、江都，以深文痛詆諸侯，別疏骨肉，使籓臣不自安，臣固知湯之詐忠。」於是上作色曰：「吾使生居一郡，能無使虜入盜乎？」山曰：「不能。」曰：「居一縣？」曰：「不能。」復曰：「居一鄣間？」山自度辯窮且下吏，曰：「能。」乃譴山乘鄣。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "大困平城",
        "label": "LOC",
        "start": 49,
        "end": 53
      },
      {
        "text": "吳",
        "label": "ORG",
        "start": 113,
        "end": 114
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 189,
        "end": 191
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 191,
        "end": 193
      },
      {
        "text": "吾使生居一郡",
        "label": "LOC",
        "start": 245,
        "end": 251
      },
      {
        "text": "居一縣",
        "label": "LOC",
        "start": 272,
        "end": 275
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000041",
    "sentence": "至月餘，匈奴斬山頭而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000042",
    "sentence": "是後群臣震讋。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000043",
    "sentence": "湯客田甲雖賈人，有賢操，始湯為小吏，與錢通，及為大吏，而甲所以責湯行義，有烈士之風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000044",
    "sentence": "湯為御史大夫七歲，敗。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000045",
    "sentence": "河東人李文，故嘗與湯有隙，已而為御史中丞，薦數從中文事有可以傷湯者，不能為地。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000046",
    "sentence": "湯有所愛史魯謁居，知湯弗平，使人上飛變告文奸事，事下湯，湯治論殺文，而湯心知謁居為之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000047",
    "sentence": "上問：「變事從跡安起？」湯陽驚曰：「此殆文故人怨之。」謁居病臥閭里主人，湯自往視病，為謁居摩足，趙國以冶鑄為業，王數訟鐵官事，湯常排趙王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000048",
    "sentence": "趙王求湯陰事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000049",
    "sentence": "謁居嘗案趙王，趙王怨之，並上書告：「湯大臣也，史謁居有病，湯至為摩足，疑與為大奸。」事下廷尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000050",
    "sentence": "謁居病死，事連其弟，弟繫導官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000051",
    "sentence": "湯亦治它囚導官，見謁居弟，欲陰為之，而陽不省。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000052",
    "sentence": "謁居弟不知而怨湯，使人上書，告湯與謁居謀，共變李文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000053",
    "sentence": "事下減宣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000054",
    "sentence": "宣嘗與湯有隙，及得此事，窮竟其事，未奏也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000055",
    "sentence": "會人有盜發孝文園瘞錢，丞相青翟朝，與湯約俱謝，至前，湯念獨丞相以四時行園，當謝，湯無與也，不謝。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000056",
    "sentence": "丞相謝，上使御史案其事。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000057",
    "sentence": "湯欲致其文丞相見知，丞相患之。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000058",
    "sentence": "三長史皆害湯，欲陷之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000059",
    "sentence": "始，長史硃買臣素怨湯，語在其傳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000060",
    "sentence": "王朝，齊人，以術至右內史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000061",
    "sentence": "邊通學短長，剛暴人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000062",
    "sentence": "官至濟南相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000063",
    "sentence": "故皆居湯右，已而失官，守長史，詘體於湯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000064",
    "sentence": "湯數行丞相事，知此三長史素貴，常陵折之。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000065",
    "sentence": "故三長史合謀曰：「始湯約與君謝，已而賣君；今欲劾君以宗廟事，此欲代君耳。吾知湯陰事。」使吏捕案湯左田信等，曰湯且欲為請奏，信輒先知之，居物致富，與湯分之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000066",
    "sentence": "及它奸事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000067",
    "sentence": "事辭頗聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000068",
    "sentence": "上問湯曰：「吾所為，賈人輒知，益居其物，是類有以吾謀告之者。」湯不謝，又陽驚曰：「固宜有。」減宜亦奏謁居事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000069",
    "sentence": "上以湯懷詐面欺，使使八輩簿責湯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000070",
    "sentence": "湯具自道無此，不服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000071",
    "sentence": "於是上使趙禹責湯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000072",
    "sentence": "禹至，讓湯曰：「君何不知分也！君所治，夷滅者幾何人矣！今人言君皆有狀，天子重致君獄，欲令君自為計，何多以對為？」湯乃為書謝曰：「湯無尺寸之功，起刀筆吏，陛下幸致位三公，無以塞責。然謀陷湯者，三長史也。」遂自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000073",
    "sentence": "湯死，家產直不過五百金，皆所得奉賜，無它贏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000074",
    "sentence": "昆弟諸子欲厚葬湯，湯母曰：「湯為天子大臣，被惡言而死，何厚葬為！」載以牛車，有棺而無槨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000075",
    "sentence": "上聞之，曰：「非此母不生此子。」乃盡按誅三長史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000076",
    "sentence": "丞相青翟自殺。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000077",
    "sentence": "出田信。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000078",
    "sentence": "上惜湯，復稍進其子安世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000079",
    "sentence": "子 安世",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000080",
    "sentence": "安世字子孺，少以父任為郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000081",
    "sentence": "用善書給事尚書，精力於職，休沐未嘗出。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_059_000082",
    "sentence": "上行幸河東，嘗亡書三篋，詔問莫能知，唯安世識之，具作其事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000083",
    "sentence": "後購求得書，以相校無所遺失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_059_000084",
    "sentence": "上奇其材，擢為尚書令，遷光祿大夫。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
