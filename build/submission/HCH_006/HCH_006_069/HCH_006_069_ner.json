        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_069_000170",
    "sentence": "詔舉可護羌校尉者，時充國病，四府舉辛武賢小弟湯。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
