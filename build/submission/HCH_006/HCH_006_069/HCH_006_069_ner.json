      }
    ]
  },
  {
    "sentence_id": "HCH_006_069_000199",
    "sentence": "辛慶忌字子真，少以父任爲右校丞，隨長羅侯常惠屯田烏孫赤谷城，與歙侯戰，陷陳卻敵。",
    "entities": [
      {
        "text": "辛慶忌",
