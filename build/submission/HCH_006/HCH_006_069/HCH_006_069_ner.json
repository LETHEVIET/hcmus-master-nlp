      }
    ]
  },
  {
    "sentence_id": "HCH_006_069_000020",
    "sentence": "元康三年，先零遂與諸羌種豪二百餘人解仇交質盟詛。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
