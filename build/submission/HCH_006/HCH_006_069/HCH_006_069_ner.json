    ]
  },
  {
    "sentence_id": "HCH_006_069_000035",
    "sentence": "遂西至西部都尉府，日饗軍士，士皆欲爲用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000036",
