      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 131,
        "end": 133
      }
    ]
  },
  {
    "sentence_id": "HCH_006_069_000097",
    "sentence": "臣聞兵者，所以明德除害也，故舉得於外，則福生於內，不可不慎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000098",
    "sentence": "臣所將吏士馬牛食，月用糧穀十九萬九千六百三十斛，鹽千六百九十三斛，茭卧二十五萬二百八十六石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000099",
    "sentence": "難久不解，繇役不息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000100",
    "sentence": "又恐它夷卒有不虞之變，相因並起，爲明主憂，誠非素定廟勝之冊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000101",
    "sentence": "且羌虜易以計破，難用兵碎也，故臣愚以爲擊之不便。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000102",
    "sentence": "計度臨羌東至浩亹，羌虜故田及公田，民所未墾，可二千頃以上，其間郵亭多壞敗者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000103",
    "sentence": "臣前部士入山，伐材木大小六萬餘枚，皆在水次。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000104",
    "sentence": "願罷騎兵，留弛刑應募，及淮陽、汝南步兵與吏士私從者，合凡萬二百八十一人，用穀月二萬七千三百六十三斛，鹽三百八斛，分屯要害處。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000105",
    "sentence": "冰解漕下，繕鄉亭，浚溝渠，治湟骥以西道橋七十所，令可至鮮水左右。",
    "entities": [
      {
        "text": "繕鄉",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_069_000106",
    "sentence": "田事出，賦人二十畝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000107",
    "sentence": "至四月草生，發郡騎及屬國胡騎伉健各千，倅馬什二，就草，爲田者遊兵。",
    "entities": [
      {
        "text": "發郡",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_069_000108",
    "sentence": "以充入金城郡，益積畜，省大費。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000109",
    "sentence": "今大司農所轉穀至者，足支萬人一歲食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000110",
    "sentence": "謹上田處及器用簿，唯陛下裁許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000111",
    "sentence": "上報曰：「皇帝問後將軍，言欲罷騎兵萬人留田，即如將軍之計，虜當何時伏誅，兵當何時得決？孰計其便，復奏。」充國上狀曰：",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_006_069_000112",
    "sentence": "臣聞帝王之兵，以全取勝，是以貴謀而賤戰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000113",
    "sentence": "戰而百勝，非善之善者也，故先爲不可勝，以待敵之可勝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000114",
    "sentence": "蠻夷習俗雖殊於禮義之國，然其欲避害就利，愛親戚，畏死亡，一也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000115",
    "sentence": "今虜亡其美地薦草，愁於寄託遠遯，骨肉離心，人有畔志，而明主般師罷兵，萬人留田，順天時，因地利，以待可勝之虜，雖未即伏辜，兵決可期月而望。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000116",
    "sentence": "羌虜瓦解，前後降者萬七百餘人，及受言去者凡七十輩，此坐支解羌虜之具也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000117",
    "sentence": "臣謹條不出兵留田便宜十二事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000118",
    "sentence": "步兵九校，吏士萬人，留屯以爲武備，因田致穀，威德並行，一也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000119",
    "sentence": "又因排折羌虜，令不得歸肥饒之墬，貧破其眾，以成羌虜相畔之漸，二也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000120",
    "sentence": "居民得並田作，不失農業，三也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000121",
    "sentence": "軍馬一月之食，度支田士一歲，罷騎兵以省大費，四也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000122",
    "sentence": "至春省甲士卒，循河湟漕穀至臨羌，以斈羌虜，揚威武，傳世折衝之具，五也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000123",
    "sentence": "以閒暇時下所伐材，繕治郵亭，充入金城，六也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000124",
    "sentence": "兵出，乘危徼幸，不出，令反畔之虜竄於風寒之地，離霜露疾疫瘃墯之患，坐得必勝之道，七也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000125",
    "sentence": "亡經阻遠追死傷之害，八也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000126",
    "sentence": "內不損威武之重，外不令虜得乘間之勢，九也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000127",
    "sentence": "又亡驚動河南大腾、小腾使生它變之憂，十也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000128",
    "sentence": "治湟骥中道橋，令可至鮮水，以制西域，信威千里，從枕席上過師，十一也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000129",
    "sentence": "大費既省，繇役豫息，以戒不虞，十二也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000130",
    "sentence": "留屯田得十二便，出兵失十二利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000131",
    "sentence": "臣充國材下，犬馬齒衰，不識長冊，唯明詔博詳公卿議臣採擇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000132",
    "sentence": "上復賜報曰：「皇帝問後將軍，言十二便，聞之。虜雖未伏誅，兵決可期月而望，期月而望者，謂今冬邪，謂何時也？將軍獨不計虜聞兵頗罷，且丁壯相聚，攻擾田者及道上屯兵，復殺略人民，將何以止之？又大腾、小腾前言曰：『我告漢軍先零所在，兵不往擊，久留，得亡效五年時不分別人而并擊我？』其意常恐。今兵不出，得亡變生，與先零爲一？將軍孰計復奏。」充國奏曰：",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 52,
        "end": 54
      },
      {
        "text": "五年",
        "label": "TME",
        "start": 122,
        "end": 124
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 156,
        "end": 158
      }
    ]
  },
  {
    "sentence_id": "HCH_006_069_000133",
    "sentence": "臣聞兵以計爲本，故多算勝少算。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000134",
    "sentence": "先零羌精兵今餘不過七八千人，失地遠客，分散飢凍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000135",
    "sentence": "罕、腾、莫須又頗暴略其羸弱畜產，畔還者不絶，皆聞天子明令相捕斬之賞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000136",
    "sentence": "臣愚以爲虜破壞可日月冀，遠在來春，故曰兵決可期月而望。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000137",
    "sentence": "竊見北邊自敦煌至遼東萬一千五百餘里，乘塞列隧有吏卒數千人，虜數大眾攻之而不能害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000138",
    "sentence": "今留步士萬人屯田，地勢平易，多高山遠望之便，部曲相保，爲塹壘木樵，校聯不絶，便兵弩，飭鬥具。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000139",
    "sentence": "烽火幸通，勢及并力，以逸待勞，兵之利者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000140",
    "sentence": "臣愚以爲屯田內有亡費之利，外有守禦之備。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000141",
    "sentence": "騎兵雖罷，虜見萬人留田爲必禽之具，其土崩歸德，宜不久矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000142",
    "sentence": "從今盡三月，虜馬羸瘦，必不敢捐其妻子於他種中，遠涉河山而來爲寇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000143",
    "sentence": "又見屯田之士精兵萬人，終不敢復將其累重還歸故地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000144",
    "sentence": "是臣之愚計，所以度虜且必瓦解其處，不戰而自破之冊也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000145",
    "sentence": "至於虜小寇盜，時殺人民，其原未可卒禁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000146",
    "sentence": "臣聞戰不必勝，不苟接刃；攻不必取，不苟勞眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000147",
    "sentence": "誠令兵出，雖不能滅先零，亶能令虜絶不爲小寇，則出兵可也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000148",
    "sentence": "即今同是而釋坐勝之道，從乘危之勢，往終不見利，空內自罷敝，貶重而自損，非所以視蠻夷也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000149",
    "sentence": "又大兵一出，還不可復留，湟中亦未可空，如是，繇役復發也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000150",
    "sentence": "且匈奴不可不備，烏桓不可不憂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000151",
    "sentence": "今久轉運煩費，傾我不虞之用以澹一隅，臣愚以爲不便。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000152",
    "sentence": "校尉臨眾幸得承威德，奉厚幣，拊循眾羌，諭以明詔，宜皆鄉風。",
    "entities": [
      {
        "text": "校尉",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "宜皆鄉",
        "label": "LOC",
        "start": 24,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_006_069_000153",
    "sentence": "雖其前辭嘗曰「得亡效五年」，宜亡它心，不足以故出兵。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_069_000154",
    "sentence": "臣竊自惟念，奉詔出塞，引軍遠擊，窮天子之精兵，散車甲於山野，雖亡尺寸之功，媮得避慊之便，而亡後咎餘責，此人臣不忠之利，非明主社稷之福也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000155",
    "sentence": "臣幸得奮精兵，討不義，久留天誅，罪當萬死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000156",
    "sentence": "陛下寬仁，未忍加誅，今臣數得孰計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000157",
    "sentence": "愚臣伏計孰甚，不敢避斧鉞之誅，昧死陳愚，唯陛下省察。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000158",
    "sentence": "充國奏每上，輒下公卿議臣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000159",
    "sentence": "初是充國計者什三，中什五，最後什八。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000160",
    "sentence": "有詔詰前言不便者，皆頓首服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_069_000161",
    "sentence": "丞相魏相曰：「臣愚不習兵事利害，後將軍數畫軍冊，其言常是，臣任其計可必用也。」上於是報充國曰：「皇帝問後將軍，上書言羌虜可勝之道，今聽將軍，將軍計善。其上留屯田及當罷者人馬數。將軍強食，慎兵事，自愛！」上以破羌、強弩將軍數言當擊，又用充國屯田處離散，恐虜犯之，於是兩從其計，詔兩將軍與中郎將卬出擊。",
