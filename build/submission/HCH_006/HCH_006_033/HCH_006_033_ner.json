[
  {
    "sentence_id": "HCH_006_033_000001",
    "sentence": "魏豹",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000002",
    "sentence": "魏豹，故魏諸公子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000003",
    "sentence": "其兄魏咎，故魏時封為甯陵君，秦滅魏，為庶人。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 6,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000004",
    "sentence": "陳勝之王也，咎往從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000005",
    "sentence": "勝使魏人周市徇魏地，魏地已下，欲立周市為魏王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000006",
    "sentence": "市曰：「天下昏亂，忠臣乃見。今天下共畔秦，其誼必立魏王後乃可。」齊、趙使車各五十乘，立市為王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000007",
    "sentence": "市不受，迎魏咎於陳，五反，陳王乃遣立咎為魏王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000008",
    "sentence": "章邯已破陳王，進兵擊魏王於臨濟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000009",
    "sentence": "魏王使周市請救齊、楚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000010",
    "sentence": "齊、楚遣項它、田巴將兵，隨市救魏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000011",
    "sentence": "章邯遂擊破殺周市等軍，圍臨濟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000012",
    "sentence": "咎為其民約降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000013",
    "sentence": "約降定，咎自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000014",
    "sentence": "魏豹亡走楚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000015",
    "sentence": "楚懷王予豹數千人，復徇魏地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000016",
    "sentence": "項羽己破秦兵，降章邯，豹下魏二十餘城，立為魏王。",
    "entities": [
      {
        "text": "豹下魏二十餘城",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000017",
    "sentence": "豹引精兵從項羽入關。",
    "entities": [
      {
        "text": "精兵從項羽入關",
        "label": "LOC",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000018",
    "sentence": "羽封諸侯，欲有梁地，乃徙豹於河東，都平陽，為西魏王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000019",
    "sentence": "漢王還定三秦，渡臨晉，豹以國屬焉，遂從擊楚於彭城。",
    "entities": [
      {
        "text": "遂從擊楚於彭城",
        "label": "LOC",
        "start": 17,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000020",
    "sentence": "漢王敗，還至滎陽，豹請視親病，至國，則絕河津畔漢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000021",
    "sentence": "漢王謂酈生曰：「緩頰往說之。」酈生至，豹謝曰：「人生一世間，如白駒過隙。今漢王嫚侮人，罵詈諸侯群臣如奴耳，非有上下禮節，吾不忍復見也。」漢王遣韓信擊豹，遂虜之，傳豹詣滎陽，以其地為河東、太原、上黨郡。",
    "entities": [
      {
        "text": "上黨郡",
        "label": "LOC",
        "start": 96,
        "end": 99
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000022",
    "sentence": "漢王令豹守滎陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000023",
    "sentence": "楚圍之急，周苛曰：「反國之王，難與共守。」遂殺豹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000024",
    "sentence": "田儋",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000025",
    "sentence": "田儋，狄人也，故齊王田氏之族也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000026",
    "sentence": "儋從弟榮，榮弟橫，皆豪桀，宗彊，能得人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000027",
    "sentence": "陳涉使周市略地，北至狄，狄城守。",
    "entities": [
      {
        "text": "狄城",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000028",
    "sentence": "儋陽為縛其奴，從少年之廷，欲謁殺奴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000029",
    "sentence": "見狄令，因擊殺令，而召豪吏子弟曰：「諸侯皆反秦自立，齊，古之建國，儋，田氏，當王。」遂自立為齊王，發兵擊周市。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000030",
    "sentence": "市軍還去，儋因率兵東略定齊地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000031",
    "sentence": "秦將章邯圍魏王咎於臨濟，急。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000032",
    "sentence": "魏王請救於齊，儋將兵救魏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000033",
    "sentence": "章邯夜銜枚擊，大破齊、楚軍，殺儋於臨濟下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000034",
    "sentence": "儋從弟榮收儋餘兵東走東阿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000035",
    "sentence": "齊人聞儋死，乃立故齊王建之弟田假為王，田角為相，田閒為將，以距諸侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000036",
    "sentence": "榮之走東阿，章邯追圍之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000037",
    "sentence": "項梁聞榮急，乃引兵擊破章邯東阿下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000038",
    "sentence": "章邯走而西，項梁因追之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000039",
    "sentence": "而榮怒齊之立假，乃引兵歸，擊逐假。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000040",
    "sentence": "假亡走楚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000041",
    "sentence": "相角亡走趙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000042",
    "sentence": "角弟閒前救趙，因不敢歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000043",
    "sentence": "榮乃立儋子市為王，榮相之，橫為將，平齊地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000044",
    "sentence": "項梁既追章邯，章邯兵益盛，項梁使使趣齊兵共擊章邯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000045",
    "sentence": "榮曰：「楚殺田假，趙殺角、閒，乃出兵。」楚懷王曰：「田假與國之王，窮而歸我，殺之不誼。」趙亦不殺田角、田閒以市於齊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000046",
    "sentence": "齊王曰：「蝮酿手則斬手，酿足則斬足。何者？為害於身也。田假、田角、田閒於楚、趙，非手足戚，何故不殺？且秦復得志於天下，則齮齕首用事者墳墓矣。」楚、趙不聽齊，齊亦怒，終不肯出兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000047",
    "sentence": "章邯果敗殺項梁，破楚兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000048",
    "sentence": "楚兵東走，而章邯渡河圍趙於鉅鹿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000049",
    "sentence": "項羽由此怨榮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000050",
    "sentence": "羽既存趙，降章邯，西滅秦，立諸侯王，乃徙齊王市更王膠東，治即墨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000051",
    "sentence": "齊將田都從共救趙，因入關，故立都為齊王，治臨菑。",
    "entities": [
      {
        "text": "因入關",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000052",
    "sentence": "故齊王建孫田安，項羽方渡河救趙，安下濟北數城，引兵降項羽，羽立安為濟北王，治博陽。",
    "entities": [
      {
        "text": "安下濟北數城",
        "label": "LOC",
        "start": 16,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000053",
    "sentence": "榮以負項梁，不肯助楚攻秦，故不得王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000054",
    "sentence": "趙將陳餘亦失職，不得王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000055",
    "sentence": "二人俱怨項羽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000056",
    "sentence": "榮使人將兵助陳餘，令反趙地，而榮亦發兵以距擊田都，都亡走楚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000057",
    "sentence": "榮留齊王市毋之膠東。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000058",
    "sentence": "市左右曰：「項王強暴，王不就國，必危。」市懼，乃亡就國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000059",
    "sentence": "榮怒，追擊殺市於即墨，還攻殺濟北王安，自立為王，盡并三齊之地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000060",
    "sentence": "項王聞之，大怒，乃北伐齊。",
    "entities": [
      {
        "text": "齊",
        "label": "ORG",
        "start": 11,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000061",
    "sentence": "榮發兵距之城陽。",
    "entities": [
      {
        "text": "榮發兵距之城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000062",
    "sentence": "榮兵敗，走平原，平原民殺榮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000063",
    "sentence": "項羽遂燒夷齊城郭，所過盡屠破。",
    "entities": [
      {
        "text": "項羽遂燒夷齊城",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000064",
    "sentence": "齊人相聚畔之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000065",
    "sentence": "榮弟橫收齊散兵，得數萬人，反擊項羽於城陽。",
    "entities": [
      {
        "text": "反擊項羽於城",
        "label": "LOC",
        "start": 13,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000066",
    "sentence": "而漢王帥諸侯敗楚，入彭城。",
    "entities": [
      {
        "text": "入彭城",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000067",
    "sentence": "項羽聞之，乃釋齊而歸擊漢於彭城，因連與漢戰，相距滎陽。",
    "entities": [
      {
        "text": "而歸擊漢於彭城",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000068",
    "sentence": "以故橫復收齊城邑，立榮子廣為王，而橫相之，政事無巨細皆斷於橫。",
    "entities": [
      {
        "text": "以故橫復收齊城",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000069",
    "sentence": "定齊三年，聞漢將韓信引兵且東擊齊，齊使華毋傷、田解軍歷下以距漢。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000070",
    "sentence": "會漢使酈食其往說王廣及相橫，與連和。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000071",
    "sentence": "橫然之，乃罷歷下守備，縱酒，且遣使與漢平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000072",
    "sentence": "韓信乃渡平原，襲破齊歷下軍，因入臨菑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000073",
    "sentence": "王廣、相橫以酈生為賣己而亨之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000074",
    "sentence": "廣東走高密，橫走博，守相田光走城陽，將軍田既軍於膠東。",
    "entities": [
      {
        "text": "守相田光走城",
        "label": "LOC",
        "start": 10,
        "end": 16
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000075",
    "sentence": "楚使龍且救齊，齊王與合軍高密。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000076",
    "sentence": "漢將韓信、曹參破殺龍且，虜齊王廣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000077",
    "sentence": "漢將灌嬰追得守相光，至博。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000078",
    "sentence": "而橫聞王死，自立為王，還擊嬰，嬰敗橫軍於贏下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000079",
    "sentence": "橫亡走梁，歸彭越。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000080",
    "sentence": "越時居梁地，中立，且為漢，且為楚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000081",
    "sentence": "韓信已殺龍且，因進兵破殺田既於膠東，灌嬰破殺齊將田吸於千乘，遂平齊地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000082",
    "sentence": "漢滅項籍，漢王立為皇帝，彭越為梁王。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000083",
    "sentence": "橫懼誅，而與其徒屬五百餘人入海，居闯中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000084",
    "sentence": "高帝聞之，以橫兄弟本定齊，齊人賢者多附焉，今在海中不收，後恐有亂，乃使使赦橫罪而召之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000085",
    "sentence": "橫謝曰：「臣亨陛下之使酈食其，今聞其弟商為漢將而賢，臣恐懼，不敢奉詔，請為庶人，守海闯中。」使還報，高帝乃詔衛尉酈商曰：「齊王橫即至，人馬從者敢動搖者致族夷！」乃復使使持節具告以詔意，曰：「橫來，大者王，小者乃侯耳；不來，且發兵加誅。」橫乃與其客二人乘傳詣雒陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000086",
    "sentence": "至尸鄉廄置，橫謝使者曰：「人臣見天子，當洗沐。」止留。",
    "entities": [
      {
        "text": "至尸鄉",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000087",
    "sentence": "謂其客曰：「橫始與漢王俱南面稱孤，今漢王為天子，而橫乃為亡虜，北面事之，其媿固已甚矣。又吾亨人之兄，與其弟併肩而事主，縱彼畏天子之詔，不敢動搖，我獨不媿於心乎？且陛下所以欲見我，不過欲壹見我面貌耳。陛下在雒陽，今斬吾頭，馳三十里間，形容尚未能敗，猶可知也。」遂自剄，令客奉其頭，從使者馳奏之高帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000088",
    "sentence": "高帝曰：「嗟乎，有以！起布衣，兄弟三人更王，豈非賢哉！」為之流涕，而拜其二客為都尉，發卒二千，以王者禮葬橫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000089",
    "sentence": "既葬，二客穿其冢旁，皆自剄從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000090",
    "sentence": "高帝聞而大驚，以橫之客皆賢者，吾聞其餘尚五百人在海中，使使召至，聞橫死，亦皆自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000091",
    "sentence": "於是乃知田橫兄弟能得士也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000092",
    "sentence": "韓王信",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000093",
    "sentence": "韓王信，故韓襄王孽孫也，長八尺五寸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000094",
    "sentence": "項梁立楚懷王，燕、齊、趙、魏皆已前王，唯韓無有後，故立韓公子橫陽城君為韓王，欲以撫定韓地。",
    "entities": [
      {
        "text": "立韓公子橫陽城",
        "label": "LOC",
        "start": 26,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000095",
    "sentence": "項梁死定陶，成奔懷王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000096",
    "sentence": "沛公引兵擊陽城，使張良以韓司徒徇韓地，得信，以為韓將，將其兵從入武關。",
    "entities": [
      {
        "text": "沛公引兵擊陽城",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "將其兵從入武關",
        "label": "LOC",
        "start": 27,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000097",
    "sentence": "沛公為漢王，信從入漢中，乃說漢王曰：「項王王諸將，王獨居此，遷也。士卒皆山東人，竦而望歸，及其蠭東鄉，可以爭天下。」漢王還定三秦，乃許王信，先拜為韓太尉，將兵略韓地。",
    "entities": [
      {
        "text": "沛",
        "label": "LOC",
        "start": 0,
        "end": 1
      },
      {
        "text": "漢",
        "label": "ORG",
        "start": 9,
        "end": 10
      },
      {
        "text": "及其蠭東鄉",
        "label": "LOC",
        "start": 45,
        "end": 50
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000098",
    "sentence": "項籍之封諸王皆就國，韓王成以不從無功，不遣之國，更封為穰侯，後又殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000099",
    "sentence": "聞漢遣信略韓地，乃令故籍游吳時令鄭昌為韓王距漢。",
    "entities": [
      {
        "text": "吳",
        "label": "ORG",
        "start": 13,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000100",
    "sentence": "漢二年，信略定韓地十餘城。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 1,
        "end": 3
      },
      {
        "text": "略定韓地十餘城",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000101",
    "sentence": "漢王至河南，信急擊韓王昌，昌降漢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000102",
    "sentence": "乃立信為韓王，常將韓兵從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000103",
    "sentence": "漢王使信與周苛等守滎陽，楚拔之，信降楚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000104",
    "sentence": "已得亡歸漢，漢復以為韓王，竟從擊破項籍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000105",
    "sentence": "五年春，與信剖符，王潁川。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000106",
    "sentence": "六年春，上以為信壯武，北近鞏、雒，南迫宛、葉，東有淮陽，皆天下勁兵處也，乃更以太原郡為韓國，徙信以備胡，都晉陽。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "乃更以太原郡",
        "label": "LOC",
        "start": 36,
        "end": 42
      },
      {
        "text": "晉",
        "label": "ORG",
        "start": 53,
        "end": 54
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000107",
    "sentence": "信上書曰：「國被邊，匈奴數入，晉陽去塞遠，請治馬邑。」上許之。",
    "entities": [
      {
        "text": "請治馬邑",
        "label": "LOC",
        "start": 21,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000108",
    "sentence": "秋，匈奴冒頓大入圍信，信數使使胡求和解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000109",
    "sentence": "漢發兵救之，疑信數間使，有二心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000110",
    "sentence": "上賜信書責讓之曰：「專死不勇，專生不任，寇攻馬邑，君王力不足以堅守乎？安危存亡之地，此二者朕所以責於君王。」信得書，恐誅，因與匈奴約共攻漢，以馬邑降胡，擊太原。",
    "entities": [
      {
        "text": "寇攻馬邑",
        "label": "LOC",
        "start": 20,
        "end": 24
      },
      {
        "text": "以馬邑",
        "label": "LOC",
        "start": 70,
        "end": 73
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000111",
    "sentence": "七年冬，上自往擊破信軍銅鞮，斬其將王喜。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000112",
    "sentence": "信亡走匈奴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000113",
    "sentence": "與其將白土人曼丘臣、王黃立趙苗裔趙利為王，復收信散兵，而與信及冒頓謀攻漢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000114",
    "sentence": "匈奴使左右賢王將萬餘騎與王黃等屯廣武以南，至晉陽，與漢兵戰，漢兵大破之，追至于離石，復破之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000115",
    "sentence": "匈奴復聚兵樓煩西北。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000116",
    "sentence": "漢令車騎擊匈奴，常敗走，漢乘勝追北。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000117",
    "sentence": "聞冒頓居代谷，上居晉陽，使人視冒頓，還報曰「可擊」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000118",
    "sentence": "上遂至平城，上白登。",
    "entities": [
      {
        "text": "上遂至平城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000119",
    "sentence": "匈奴騎圍上，上乃使人厚遺閼氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000120",
    "sentence": "閼氏說冒頓曰：「今得漢地，猶不能居，且兩主不相厄。」居七日，胡騎稍稍引去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000121",
    "sentence": "天霧，漢使人往來，胡不覺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000122",
    "sentence": "護軍中尉陳平言上曰：「胡者全兵，請令彊弩傅兩矢外鄉，徐行出圍。」入平城，漢救兵亦至。",
    "entities": [
      {
        "text": "彊弩傅兩矢外鄉",
        "label": "LOC",
        "start": 18,
        "end": 25
      },
      {
        "text": "入平城",
        "label": "LOC",
        "start": 32,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000123",
    "sentence": "胡騎遂解去，漢亦罷兵歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000124",
    "sentence": "信為匈奴將兵往來擊邊，令王黃等說誤陳豨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_033_000125",
    "sentence": "十一年春，信復與胡騎入居參合。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_033_000126",
    "sentence": "漢使柴將軍擊之，遺信書曰：「陛下寬仁，諸侯雖有叛亡，而後歸，輒復故位號，不誅也。大王所知。今王以敗亡走胡，非有大罪，急自歸。」信報曰：「陛下擢僕閭巷，南面稱孤，此僕之幸也。滎陽之事，僕不能死，囚於項籍，此一罪也。寇攻馬邑，僕不能堅守，以城降之，此二罪也。今為反寇，將兵與將軍爭一旦之命，此三罪也。夫種、蠡無一罪，身死亡；僕有三罪，而欲求活，此伍子胥所以僨於吳世也。今僕亡匿山谷間，旦暮乞貣蠻夷，僕之思歸，如痿人不忘起，盲者不忘視，勢不可耳。」遂戰。",
    "entities": [
