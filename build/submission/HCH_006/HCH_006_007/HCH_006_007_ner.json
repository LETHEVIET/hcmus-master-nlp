        "end": 9
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000035",
    "sentence": "以宗室毋在位者，舉茂才劉辟彊、劉長樂皆為光祿大夫，辟彊守長樂衛尉。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000036",
    "sentence": "三月，遣使者振貸貧民毋種、食者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000037",
    "sentence": "秋八月，詔曰：「往年災害多，今年蠶麥傷，所振貸種、食勿收責，毋令民出今年田租。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000038",
    "sentence": "冬，發習戰射士詣朔方，調故吏將屯田張掖郡。",
    "entities": [
      {
        "text": "吏將屯田張掖郡",
        "label": "LOC",
        "start": 13,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000039",
    "sentence": "三年春二月，有星孛于西北。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000040",
    "sentence": "秋，募民徙雲陵，賜錢田宅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000041",
    "sentence": "冬十月，鳳皇集東海，遣使者祠其處。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000042",
    "sentence": "十一月壬辰朔，日有蝕之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000043",
    "sentence": "四年春三月甲寅，立皇后上官氏。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "皇后",
