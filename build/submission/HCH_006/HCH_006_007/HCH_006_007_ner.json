        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000044",
    "sentence": "赦天下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000045",
    "sentence": "辭訟在後二年前，皆勿聽治。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000046",
    "sentence": "夏六月，皇后見高廟。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000047",
    "sentence": "賜長公主、丞相、將軍、列侯、中二千石以下及郎吏宗室錢帛各有差。",
    "entities": [
      {
        "text": "公主",
