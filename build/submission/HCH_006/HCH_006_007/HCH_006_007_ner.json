      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000010",
    "sentence": "大將軍光秉政，領尚書事，車騎將軍金日磾、左將軍上官桀副焉。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
