        "end": 26
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 37,
        "end": 39
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000006",
    "sentence": "以侍中奉車都尉霍光為大司馬大將軍，受遺詔輔少主。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "大將軍",
