[
  {
    "sentence_id": "HCH_006_007_000001",
    "sentence": "昭帝",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000002",
    "sentence": "孝昭皇帝，武帝少子也。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000003",
    "sentence": "母曰趙婕妤，本以有奇異得幸，及生帝，亦奇異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000004",
    "sentence": "語在外戚傳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000005",
    "sentence": "武帝末，戾太子 敗，燕王旦、廣陵王胥行驕嫚，後元二年二月上疾病，遂立昭帝為太子，年八歲。",
    "entities": [
      {
        "text": "太子",
