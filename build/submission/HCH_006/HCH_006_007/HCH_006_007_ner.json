        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000007",
    "sentence": "明日，武帝崩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000008",
    "sentence": "戊辰，太子 即皇帝位，謁高廟。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "皇帝",
