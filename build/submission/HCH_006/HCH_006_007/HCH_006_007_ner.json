        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000011",
    "sentence": "夏六月，赦天下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000012",
    "sentence": "秋七月，有星孛于東方。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000013",
    "sentence": "濟北王寬有罪，自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000014",
    "sentence": "賜長公主及宗室昆弟各有差。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000015",
    "sentence": "追尊趙婕妤為皇太后，起雲陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000016",
    "sentence": "冬，匈奴入朔方，殺略吏民。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000017",
    "sentence": "發軍屯西河，左將軍桀行北邊。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000018",
    "sentence": "始元元年 春二月，黃鵠下建章宮太液池中。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000019",
    "sentence": "公卿上壽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000020",
    "sentence": "賜諸侯王、列侯、宗室金錢各有差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000021",
    "sentence": "己亥，上耕于鉤盾弄田。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000022",
    "sentence": "益封燕王、廣陵王及鄂邑長公主各萬三千戶。",
    "entities": [
      {
        "text": "廣陵王及鄂邑",
        "label": "LOC",
        "start": 5,
        "end": 11
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000023",
    "sentence": "夏，為太后起園廟雲陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000024",
    "sentence": "益州廉頭、姑繒、牂柯談指、同並二十四邑皆反。",
    "entities": [
      {
        "text": "益州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "同並二十四邑",
        "label": "LOC",
        "start": 13,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000025",
    "sentence": "遣水衡都尉呂破胡募吏民及發犍為、蜀郡奔命擊益州，大破之。",
    "entities": [
      {
        "text": "蜀郡奔命擊益州",
        "label": "LOC",
        "start": 16,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000026",
    "sentence": "有司請河內屬冀州，河東屬并州。",
    "entities": [
      {
        "text": "司請河內屬冀州",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "河東屬并州",
        "label": "LOC",
        "start": 9,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000027",
    "sentence": "秋七月，赦天下，賜民百戶牛酒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000028",
    "sentence": "大雨，渭橋絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000029",
    "sentence": "八月，齊孝王孫劉澤謀反，欲殺青州刺史雋不疑，發覺，皆伏誅。",
    "entities": [
      {
        "text": "欲殺青州",
        "label": "LOC",
        "start": 12,
        "end": 16
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "雋不疑",
        "label": "PER",
        "start": 18,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000030",
    "sentence": "遷不疑為京兆尹，賜錢百萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000031",
    "sentence": "九月丙子，車騎將軍日磾薨。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000032",
    "sentence": "閏月，遣故廷尉王平等五人持節行郡國，舉賢良，問民所疾苦、冤、失職者。",
    "entities": [
      {
        "text": "等五人持節行郡",
        "label": "LOC",
        "start": 9,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_007_000033",
    "sentence": "冬，無冰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_007_000034",
    "sentence": "二年春正月，大將軍光、左將軍桀皆以前捕斬反虜重合侯馬通功封，光為博陸侯，桀為安陽侯。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "大將軍",
