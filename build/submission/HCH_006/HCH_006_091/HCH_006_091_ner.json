[
  {
    "sentence_id": "HCH_006_091_000001",
    "sentence": "昔先王之制，自天子、公、侯、卿、大夫、士至於皂隸、抱關、擊还者，其爵祿、奉養、宮室、車服、棺槨、祭祀、死生之制各有差品，小不得僭大，賤不得逾貴。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "抱關",
        "label": "LOC",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000002",
    "sentence": "夫然，故上下序而民志定。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000003",
    "sentence": "於是辯其土地、川澤、丘陵、衍沃、原隰之宜，教民種樹畜養；五穀六畜及至魚鱉、鳥獸、雚蒲、材干、器械之資，所以養生送終之具，靡不皆育。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000004",
    "sentence": "育之以時，而用之有節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000005",
    "sentence": "草木未落，斧斤不入於山林；豺獺未祭，罝網不佈於野澤；鷹隼未擊，矰弋不施於徯隧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000006",
    "sentence": "既順時而取物，然猶山不茬薛，澤不伐夭，蟓魚麛卵，咸有常禁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000007",
    "sentence": "所以順時宣氣，蕃阜庶物，蓄足功用，如此之備也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000008",
    "sentence": "然後四民因其土宜，各任智力，夙興夜寐，以治其業，相與通功易事，交利而俱贍，非有征發期會，而遠近咸足。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000009",
    "sentence": "故《易》曰「後以財成輔相天地之宜，以左右民」，「備物致用，立成器以為天下利，莫大乎聖人」。",
    "entities": [
      {
        "text": "《易》",
        "label": "TITLE",
        "start": 1,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000010",
    "sentence": "此之謂也《管子》雲古之四民不得雜處。",
    "entities": [
      {
        "text": "《管子》",
        "label": "TITLE",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000011",
    "sentence": "士相與言仁誼於閒宴，工相與議技巧於官府，商相與語財利於市井，農相與謀稼穡於田野，朝夕從事，不見異物而遷焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000012",
    "sentence": "故其父兄之教不肅而成，子弟之學不勞而能，各安其居而樂其業，甘其食而美其服，雖見奇麗紛華，非其所習，辟猶戎翟之與於越，不相入矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000013",
    "sentence": "是以欲寡而事節，財足而不爭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000014",
    "sentence": "於是在民上者，道之以德，齊之以禮，故民有恥而且敬，貴誼而賤利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000015",
    "sentence": "此三代之所以直道而行，不嚴而治之大略也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000016",
    "sentence": "周",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000017",
    "sentence": "及周室衰，禮法墮，諸侯刻桷丹楹，大夫山節藻棁，八佾舞於庭，《雍》徹於堂。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "《雍》",
        "label": "TITLE",
        "start": 29,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000018",
    "sentence": "其流至乎士庶人，莫不離制而棄本，稼穡之民少，商旅之民多，谷不足而貨有餘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000019",
    "sentence": "陵夷至乎桓、文之後，禮誼大壞，上下相冒，國異政，家殊俗，嗜欲不制，僭差亡極。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000020",
    "sentence": "於是商通難得之貨，工作亡用之器，士設反道之行，以追時好而取世資。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000021",
    "sentence": "偽民背實而要名，姦夫犯害而求利，篡弒取國者為王公，圉奪成家者為雄桀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000022",
    "sentence": "禮誼不足以拘君子，刑戮不足以威小人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000023",
    "sentence": "富者木土被文錦，犬馬余肉粟，而貧者短褐不完，含菽飲水。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000024",
    "sentence": "其為編戶齊民，同列而以財力相君，雖為僕虜，猶亡慍色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000025",
    "sentence": "故夫飾變詐為奸軌者，自足乎一世之間；守道循理者，不免於饑寒之患。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000026",
    "sentence": "其教自上興，由法度之無限也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000027",
    "sentence": "故列其行事，以傳世變雲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000028",
    "sentence": "昔粵王勾踐困於會稽之上，乃用范蠡、計然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000029",
    "sentence": "計然曰：「知斗則修備，時用則知物，二者形則萬貨之情可得見矣。故旱則資舟，水則資車，物之理也。」推此類而修之，十年國富，厚賂戰士，遂報強吳，刷會稽之恥。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 54,
        "end": 56
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000030",
    "sentence": "范蠡歎曰：「計然之策，十用其五而得意。既以施國，吾欲施之家。」乃乘扁舟，浮江湖，變名姓，適齊為鴟夷子皮，之陶為硃公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000031",
    "sentence": "以為陶天下之中，諸侯四通，貨物所交易也，乃治產積居，與時逐而不責於人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000032",
    "sentence": "故善治產者，能擇人而任時。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000033",
    "sentence": "十九年之間三致千金，再散分與貧友昆弟。",
    "entities": [
      {
        "text": "十九年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000034",
    "sentence": "後年衰老，聽子孫修業而息之，遂至巨萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000035",
    "sentence": "故言富者稱陶硃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000036",
    "sentence": "子贛既學於仲尼，退而仕衛，發貯鬻財曹、魯之間。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000037",
    "sentence": "七十子之徒，賜最為饒，而顏淵簞食瓢飲，在於陋巷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000038",
    "sentence": "子贛結駟連騎，束帛之幣聘享諸侯，所至，國君無不分庭與之抗禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000039",
    "sentence": "然孔子賢顏淵而譏子贛，曰：「回也其庶乎，屢空。賜不受命，而貨殖焉，意則屢中。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000040",
    "sentence": "白圭，周人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000041",
    "sentence": "當魏文侯時，李史務盡地力，而白圭樂觀時變，故人棄我取，人取我予。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000042",
    "sentence": "能薄飲食，忍嗜欲，節衣服，與用事僮僕同苦樂，趨時若猛獸摯鳥之發。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000043",
    "sentence": "故曰：「吾治生猶伊尹、呂尚之謀，孫、吳用兵，商鞅行法是也。故智不足與權變，勇不足以決斷，仁不能以取予，強不能以有守，雖欲學吾術，終不告也。」蓋天下言治生者祖白圭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000044",
    "sentence": "猗頓用盬鹽起，邯鄲郭縱以鑄冶成業，與王者埒富。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000045",
    "sentence": "烏氏蠃畜牧，及眾，斥賣，求奇繒物，間獻戎王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000046",
    "sentence": "戎王十倍其償，予畜，畜至用谷量牛馬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000047",
    "sentence": "秦始皇令蠃比封君，以時與列臣朝請。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000048",
    "sentence": "巴寡婦清，其先得丹穴，而擅其利數世，家亦不訾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000049",
    "sentence": "清寡婦能守其業，用財自衛，人不敢犯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000050",
    "sentence": "始皇以為貞婦而客之，為築女懷清台。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000051",
    "sentence": "秦漢",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000052",
    "sentence": "秦漢之制，列侯封君食租稅，歲率戶二百。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000053",
    "sentence": "千戶之君則二十萬，朝覲聘享出其中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000054",
    "sentence": "庶民農工商賈，率亦歲萬息二千，百萬之家即二十萬，而更徭租賦出其中，衣食好美矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000055",
    "sentence": "故曰陸地牧馬二百蹄，牛千蹄角，千足羊，澤中千足彘，水居千石魚波，山居千章之萩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000056",
    "sentence": "安邑千樹棗；燕、秦千樹栗；蜀、漢、江陵千樹橘；淮北滎南河濟之間千樹萩；陳、夏千畝漆；齊、魯千畝桑麻；渭川千畝竹；及名國萬家之城，帶郭千畝畝鐘之田，若千畝卮茜，千畦姜韭：此其人皆與千戶侯等。",
    "entities": [
      {
        "text": "安邑",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "及名國萬家之城",
        "label": "LOC",
        "start": 56,
        "end": 63
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000057",
    "sentence": "諺曰：「以貧求富，農不如工，工不如商，刺繡文不如倚市門。」此言末業，貧者之資也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000058",
    "sentence": "通邑大都酤一歲千釀，醯醬千瓨，漿千儋，屠牛、羊、彘千皮，谷糴千鐘，薪槁千車，舩長千丈，木千章，竹竿萬個，軺車百乘，牛車千兩；木器漆者千枚，銅器千鈞，素木鐵器若卮茜千石，馬蹄噭千，牛千足，羊、彘千雙，童手指千，筋角丹沙千斤，其帛絮細布千鈞，文采千匹，答布皮革千石，漆千大鬥，薛曲鹽豉千合，鮐鮆千斤，鮿鮑千鈞，棗栗千石者三之，狐貂裘千皮，羔羊裘千石，旃席千具，它果采千種，子貸金錢千貫，節駔儈，貪賈三之，廉賈五之，亦比千乘之家，此其大率也。",
    "entities": [
      {
        "text": "通邑",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000059",
    "sentence": "各地",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000060",
    "sentence": "蜀",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000061",
    "sentence": "蜀卓氏之先，趙人也，用鐵冶富。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000062",
    "sentence": "秦破趙，遷卓氏之蜀，夫妻推輦行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000063",
    "sentence": "諸遷虜少有餘財，急與吏，求近處，處葭萌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000064",
    "sentence": "唯卓氏曰：「此地狹薄。吾聞崏山之下沃野，下有踆鴟，至死不饑。民工作布，易賈。」乃求遠遷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000065",
    "sentence": "致之臨邛，大喜，即鐵山鼓鑄，運籌算，賈滇、蜀民，富至童八百人，田池射獵之樂擬於人君。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000066",
    "sentence": "程鄭，山東遷虜也，亦冶鑄，賈魋結民，富埒卓氏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000067",
    "sentence": "程、卓既衰，至成、哀間，成都羅裒訾至巨萬。",
    "entities": [
      {
        "text": "成都",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000068",
    "sentence": "初，裒賈京師，隨身數十百萬，為平陵石氏持錢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000069",
    "sentence": "其人強力。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000070",
    "sentence": "石氏訾次如、苴，親信，厚資遣之，令往來巴、蜀，數年間致千餘萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000071",
    "sentence": "裒舉其半賂遺曲陽、定陵侯，依其權力，賒貸郡國，人莫敢負。",
    "entities": [
      {
        "text": "賒貸郡",
        "label": "LOC",
        "start": 18,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000072",
    "sentence": "擅鹽井之利，期年所得自倍，遂殖其貨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000073",
    "sentence": "宛",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000074",
    "sentence": "宛孔氏之先，梁人也，用鐵冶為業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000075",
    "sentence": "秦滅魏，遷孔氏南陽，大鼓鑄，規陂田，連騎游諸侯，因通商賈之利，有游閒公子之名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000076",
    "sentence": "然其贏得過當，愈於孅嗇，家致數千金，故南陽行賈盡法孔氏之雍容。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000077",
    "sentence": "魯",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000078",
    "sentence": "魯人俗儉嗇，而丙氏尤甚，以鐵冶起，富至巨萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000079",
    "sentence": "然家自父兄子弟約，俯有拾，仰有取，貰貸行賈遍郡國。",
    "entities": [
      {
        "text": "貰貸行賈遍郡",
        "label": "LOC",
        "start": 17,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000080",
    "sentence": "鄒、魯以其故，多去文學而趨利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000081",
    "sentence": "齊",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000082",
    "sentence": "齊俗賤奴虜，而刀間獨愛貴之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000083",
    "sentence": "桀黠奴，人之所患，唯刀間收取，使之逐魚鹽商賈之利，或連車騎交守相，然愈益任之，終得其力，起數千萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000084",
    "sentence": "故曰「寧爵無刀」，言能使豪奴自饒，而盡其力也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000085",
    "sentence": "刀間既衰，至成、哀間，臨淄姓偉訾五千萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000086",
    "sentence": "周",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000087",
    "sentence": "周人既孅，而師史尤甚，轉轂百數，賈郡國，無所不至。",
    "entities": [
      {
        "text": "賈郡",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000088",
    "sentence": "雒陽街居在齊、秦、楚、趙之中，富家相矜以久賈，過邑不入門。",
    "entities": [
      {
        "text": "過邑",
        "label": "LOC",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000089",
    "sentence": "設用此等，故師史能致十千萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000090",
    "sentence": "師史既衰，至成、哀、王莽時，雒陽張長叔、薛子促訾亦十千萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000091",
    "sentence": "莽皆以為納言士，欲法武帝，然不能得其利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000092",
    "sentence": "關中",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000093",
    "sentence": "宣曲任氏，其先為督道倉吏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000094",
    "sentence": "秦之敗也，豪桀爭取金玉，任氏獨窖倉粟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000095",
    "sentence": "楚、漢相距滎陽，民不得耕種，米石至萬，而豪桀金玉盡歸任氏，任氏以此起富。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000096",
    "sentence": "富人奢侈，而任氏折節為力田畜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000097",
    "sentence": "人爭取賤賈，任氏獨取貴善，富者數世。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000098",
    "sentence": "然任公家約，非田畜所生不衣食，公事不畢則不得飲酒食肉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000099",
    "sentence": "以此為閭里率，故富而主上重之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000100",
    "sentence": "塞之斥也，唯橋桃以致馬千匹，牛倍之，羊萬，粟以萬鐘計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000101",
    "sentence": "吳、楚兵之起，長安中列侯封君行從軍旅，繼貣子錢家，子錢家以為關東成敗未決，莫肯予；唯毋鹽氏出捐千金貸，其息十之。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 7,
        "end": 9
      },
      {
        "text": "子錢家以為關",
        "label": "LOC",
        "start": 25,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000102",
    "sentence": "三月，吳、楚平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000103",
    "sentence": "一歲之中，則毋鹽氏息十倍，用此富關中。",
    "entities": [
      {
        "text": "用此富關",
        "label": "LOC",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000104",
    "sentence": "關中富商大賈，大氐盡諸田，田牆、田蘭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000105",
    "sentence": "韋家栗氏、安陵杜氏亦巨萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000106",
    "sentence": "前富者既衰，自元、成訖王莽，京師富人杜陵樊嘉，茂陵摯網，平陵如氏、苴氏，長安丹王君房，豉樊少翁、王孫大卿，為天下高訾。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 36,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000107",
    "sentence": "樊嘉五千萬，其餘皆巨萬矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000108",
    "sentence": "王孫卿以財養士，與雄桀交，王莽以為京司市師，漢司東市令也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000109",
    "sentence": "此其章章尤著者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000110",
    "sentence": "其餘郡國富民兼業顓利，以貨賂自行，取重於鄉里者，不可勝數。",
    "entities": [
      {
        "text": "其餘郡",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "取重於鄉",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000111",
    "sentence": "故秦楊以田農而甲一州，翁伯以販脂而傾縣邑，張氏以賣醬而隃侈，質氏以灑削而鼎食，濁氏以胃脯而連騎，張裡以馬醫而擊鐘，皆越法矣。",
    "entities": [
      {
        "text": "以田農而甲一州",
        "label": "LOC",
        "start": 3,
        "end": 10
      },
      {
        "text": "伯以販脂而傾縣",
        "label": "LOC",
        "start": 12,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_006_091_000112",
    "sentence": "然常循守事業，積累贏利，漸有所起。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000113",
    "sentence": "至於蜀卓，宛孔，齊之刀間，公擅山川銅鐵魚鹽市井之入，運其籌策，上爭王者之利，下錮齊民之業，皆陷不軌奢僭之惡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000114",
    "sentence": "又況掘塚搏掩，犯奸成富，曲叔、稽發、雍樂成之徒，猶夏齒列，傷化敗俗，大亂之道也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_091_000115",
    "sentence": "本東漢作品在全世界都属于 公有领域 ，因为作者逝世已经遠遠超过100年。",
    "entities": [
      {
        "text": "100年",
        "label": "TME",
        "start": 31,
        "end": 35
      }
    ]
  }
]
