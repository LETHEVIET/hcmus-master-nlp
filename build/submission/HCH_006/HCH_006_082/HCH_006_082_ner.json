        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000069",
    "sentence": "哀王者，帝之少弟，與太子遊學相長大。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
