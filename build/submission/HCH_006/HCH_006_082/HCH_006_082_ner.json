  },
  {
    "sentence_id": "HCH_006_082_000109",
    "sentence": "莽賜謚曰貞侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000110",
    "sentence": "子嗣，莽敗乃絶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000111",
    "sentence": "贊",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000112",
    "sentence": "贊曰：自宜、元、成、哀外戚興者，許、史、三王、丁、傅之家，皆重侯累將，窮貴極富，見其位矣，未見其人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000113",
    "sentence": "陽平之王多有材能，好事慕名，其勢尤盛，曠貴最久。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000114",
    "sentence": "然至於莽，亦以覆國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000115",
    "sentence": "王商有剛毅節，廢黜以憂死，非其罪也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000116",
    "sentence": "史丹父子相繼，高以重厚，位至三公。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000117",
    "sentence": "丹之輔道副主，掩惡揚美，傅會善意，雖宿儒達士無以加焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000118",
    "sentence": "及其歷房闥，入臥內，推至誠，犯顏色，動寤萬乘，轉移大謀，卒成太子，安母后之位。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000119",
    "sentence": "「無言不讎」，終獲忠貞之報。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000120",
    "sentence": "傅喜守節不傾，亦蒙後凋之賞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000121",
    "sentence": "哀、平際會，禍福速哉！",
    "entities": []
  }
]
