[
  {
    "sentence_id": "HCH_006_082_000001",
    "sentence": "王商",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000002",
    "sentence": "王商字子威，涿郡蠡吾人也，徙杜陵。",
    "entities": [
      {
        "text": "涿郡",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000003",
    "sentence": "商公武、武兄無故，皆以宣帝舅封。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000004",
    "sentence": "無故爲平昌侯，武爲樂昌侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000005",
    "sentence": "語在《外戚傳》。",
    "entities": [
      {
        "text": "《外戚傳》",
        "label": "TITLE",
        "start": 2,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000006",
    "sentence": "商少爲太子中庶子，以肅敬敦厚稱。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000007",
    "sentence": "父薨，商嗣爲侯，推財以分異母諸弟，身無所受，居喪哀戚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000008",
    "sentence": "於是大臣薦商行可以厲群臣，義足以厚風俗，宜備近臣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000009",
    "sentence": "繇是擢爲諸曹、侍中、中郎將。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000010",
    "sentence": "元帝時，至右將軍、光祿大夫。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000011",
    "sentence": "是時，定陶共王愛幸，幾代太子。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000012",
    "sentence": "商爲外戚重臣輔政，擁佑太子，頗有力焉。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000013",
    "sentence": "元帝崩，成帝即位，甚敬重商，徙爲左將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000014",
    "sentence": "而帝元舅大司馬大將軍王鳳顓權，行多驕僭。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000015",
    "sentence": "商論議不能平鳳，鳳知之，亦疏商。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000016",
    "sentence": "建始三年秋，京師民無故相驚，言大水至，百姓奔走相蹂躪、老弱號呼，長安中大亂。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000017",
    "sentence": "天子親御前殿，召公卿議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000018",
    "sentence": "大將軍鳳以爲太后與上及後宮可御船，令吏民上長安城以避水。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 0,
        "end": 3
      },
      {
        "text": "令吏民上長安城",
        "label": "LOC",
        "start": 17,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000019",
    "sentence": "群臣皆從鳳議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000020",
    "sentence": "左將軍商獨曰：「自古無道之國，水猶不冒城郭。今政治和平，世無兵革，上下相安，何因當有大水一日暴至？此必訛言也，不宜令上城，重驚百姓。」上乃止。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 1,
        "end": 3
      },
      {
        "text": "水猶不冒城",
        "label": "LOC",
        "start": 15,
        "end": 20
      },
      {
        "text": "不宜令上城",
        "label": "LOC",
        "start": 55,
        "end": 60
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000021",
    "sentence": "有頃，長安中稍定，問之，果訛言。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000022",
    "sentence": "上於是美壯商之固守，數稱其議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000023",
    "sentence": "而鳳大慚，自恨失言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000024",
    "sentence": "明年，商代匡衡爲丞相，益封千戶，天子甚尊任之。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000025",
    "sentence": "爲人多質有威重，長八尺餘，身體鴻大，容貌甚過絶人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000026",
    "sentence": "河平四年，單于來朝，引見白虎殿。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000027",
    "sentence": "丞相商坐未央廷中，單于前，拜謁商。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000028",
    "sentence": "商起，離席與言，單于仰視商貌，大畏之，遷延卻退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000029",
    "sentence": "天子聞而歎曰：「此真漢相矣！」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000030",
    "sentence": "初，大將軍鳳連昏楊肜爲琅邪太守，其郡有災害十四，已上。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 2,
        "end": 5
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "其郡",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000031",
    "sentence": "商部屬按問，鳳以曉商曰：「災異天事，非人力所爲。肜素善吏，宜以爲後。」商不聽，竟奏免肜，奏果寢不下，鳳重以是怨商，陰求其短，使人上書言商閨門內事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000032",
    "sentence": "天子以爲暗昧之過，不足以傷大臣，鳳固爭，下其事司隸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000033",
    "sentence": "先是，皇太后嘗詔問商女，欲以備後宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000034",
    "sentence": "時女病，商意亦難之，以病對，不入。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000035",
    "sentence": "及商以閨門事見考，自知爲鳳所中，惶怖，更欲內女爲援，乃因新幸李婕妤家白見其女。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_082_000036",
    "sentence": "會日有蝕之，太中大夫蜀郡張匡，其人佞巧，上書願對近臣陳日蝕咎。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_082_000037",
    "sentence": "下朝者左將軍丹等問匡，對曰：「竊見丞相商作威作福，從外制中，取必於上，性殘賊不仁，遣票輕吏微求人罪，欲以立威，天下患苦之。前頻陽耿定上書言商與父傅通，及女弟淫亂，奴殺其私夫，疑商教使。章下有司，商私怨懟。商子俊欲上書告商，俊妻左將軍丹女，持其書以示丹，丹惡其父子乘迕，爲女求去。商不盡忠納善以輔至德，知聖主崇孝，遠別不親，後庭之事皆受命皇太后，太后前聞商有女，欲以備後宮，商言有固疾，後有耿定事，更詭道因李貴人家內女，執左道以亂政，誣罔悖大臣節，故應是而日蝕。《周書》曰：『以左道事君者誅。』《易》曰：『日中見昧，則折其右肱。』往者丞相周勃再建大功，及孝文時纖介怨恨，而日爲之蝕，於是退勃使就國，卒無怵惕憂。今商無尺寸之功，而有三世之寵，身位三公，宗族爲列侯、吏二千石、侍中諸曹，給事禁門內，連昏諸侯王，權寵至盛。審有內亂殺人怨懟之端，宜究竟考問。臣聞秦丞相呂不韋見王無子，意欲有秦國，即求好女以爲妻，陰知其有身而獻之王，產始皇帝。及楚相春申君亦見王無子，心利楚國，即獻有身妻而產懷王。自漢興幾遭呂、霍之患，今商有不仁之性，乃因怨以內女，其奸謀未可測度。前孝景世七國反，將軍周亞夫以爲即得雒陽劇孟，關東非漢之有。今商宗族權勢，合貲巨萬計，私奴以千數，非特劇孟匹夫之徒也。且失道之至，親戚畔之，閨門內亂，父子相訐，而欲使之宜明聖化，調和海內，豈不謬哉！商視事五年，官職陵夷而大惡著於百姓，甚虧損盛德，有鼎折足之凶。臣愚以爲聖主富於春秋，即位以來，未有懲奸之威，加以繼嗣未立，大異並見，尤宜誅討不忠，以遏未然。行之一人，則海內震動，百奸之路塞矣。」",
