        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_064c_000106",
    "sentence": "時氾鄉侯何武為僮子，選在歌中。",
    "entities": [
      {
        "text": "時氾鄉",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_064c_000107",
    "sentence": "久之，武等學長安，歌太學下，轉而上聞。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_064c_000108",
    "sentence": "宣帝召見武等觀之，皆賜帛，謂曰：「此盛德之事，吾何足以當之！」",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_064c_000109",
    "sentence": "褒既為刺史作頌，又作其傳，益州刺史因奏褒有軼材。",
    "entities": [
      {
        "text": "刺史",
