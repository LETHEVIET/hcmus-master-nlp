[
  {
    "sentence_id": "HCH_006_035_000001",
    "sentence": "劉賈",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000002",
    "sentence": "荊王劉賈，高帝從父兄也，不知其初起時。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000003",
    "sentence": "漢元年，還定三秦，賈為將軍，定塞地，從東擊項籍。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 1,
        "end": 3
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000004",
    "sentence": "漢王敗成皋，北度河，得張耳、韓信軍，軍脩武，深溝高壘，使賈將二萬人，騎數百，擊楚，度白馬津入楚地，燒其積聚，以破其業，無以給項王軍食。",
    "entities": [
      {
        "text": "楚",
        "label": "ORG",
        "start": 46,
        "end": 47
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000005",
    "sentence": "已而楚兵擊之，賈輒避不肯與戰，而與彭越相保。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000006",
    "sentence": "漢王追項籍至固陵，使賈南度淮圍壽春。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000007",
    "sentence": "還至，使人間招楚大司馬周殷。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000008",
    "sentence": "周殷反楚，佐賈舉九江，迎英布兵，皆會垓下，誅項籍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000009",
    "sentence": "漢王因使賈將九江兵，與太尉盧綰西南擊臨江王共尉，尉死，以臨江為南郡。",
    "entities": [
      {
        "text": "以臨江為南郡",
        "label": "LOC",
        "start": 27,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000010",
    "sentence": "賈既有功，而高祖子弱，昆弟少，又不賢，欲王同姓以填天下，乃下詔曰：「將軍劉賈有功，及擇子弟可以為王者。」群臣皆曰：「立劉賈為荊王，王淮東。」立六年而淮南王黥布反，東擊荊。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 34,
        "end": 36
      },
      {
        "text": "六年",
        "label": "TME",
        "start": 71,
        "end": 73
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000011",
    "sentence": "賈與戰，弗勝，走富陵，為布軍所殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000012",
    "sentence": "劉澤",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000013",
    "sentence": "燕王劉澤，高祖從祖昆弟也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000014",
    "sentence": "高祖三年，澤為郎中。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000015",
    "sentence": "十一年，以將軍擊陳豨將王黃，封為營陵侯。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000016",
    "sentence": "高后時，齊人田生游乏資，以畫奸澤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000017",
    "sentence": "澤大說之，用金二百斤為田生壽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000018",
    "sentence": "田生已得金，即歸齊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000019",
    "sentence": "二歲，澤使人謂田生曰：「弗與矣。」田生如長安，不見澤，而假大宅，令其子求事呂后所幸大謁者張卿。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000020",
    "sentence": "居數月，田生子請張卿臨，親脩具。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000021",
    "sentence": "張卿往，見田生帷帳具置如列侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000022",
    "sentence": "張卿驚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000023",
    "sentence": "酒酣，乃屏人說張卿曰：「臣觀諸侯邸第百餘，皆高帝一切功臣。今呂氏雅故本推轂高帝就天下，功至大，又有親戚太后之重。太后春秋長，諸呂弱，太后欲立呂產為呂王，王代。呂后又重發之，恐大臣不聽。今卿最幸，大臣所敬，何不風大臣以聞太后，太后必喜。諸呂以王，萬戶侯亦卿之有。太后心欲之，而卿為內臣，不急發，恐過及身矣。」張卿大然之，乃風大臣語太后。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000024",
    "sentence": "太后朝，因問大臣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000025",
    "sentence": "大臣請立呂產為呂王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000026",
    "sentence": "太后賜張卿千金，張卿以其半進田生。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000027",
    "sentence": "田生弗受，因說之曰：「呂產王也，諸大臣未大服。今營陵侯澤，諸劉長，為大將軍，獨此尚觖望。今卿言太后，裂十餘縣王之，彼得王喜，於諸呂王益固矣。」張卿入言之。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 34,
        "end": 37
      },
      {
        "text": "裂十餘縣",
        "label": "LOC",
        "start": 50,
        "end": 54
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000028",
    "sentence": "又太后女弟呂須女亦為營陵侯妻，故遂立營陵侯澤為琅邪王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000029",
    "sentence": "琅邪王與田生之國，急行毋留。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000030",
    "sentence": "出關，太后果使人追之。",
    "entities": [
      {
        "text": "出關",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000031",
    "sentence": "已出，即還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000032",
    "sentence": "澤王琅邪二年，而太后崩，澤乃曰：「帝少，諸呂用事，諸劉孤弱。」引兵與齊王合謀西，欲誅諸呂。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000033",
    "sentence": "至梁，聞漢灌將軍屯滎陽，澤還兵備西界，遂跳驅至長安。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000034",
    "sentence": "代王亦從代至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000035",
    "sentence": "諸將相與琅邪王共立代王，是為孝文帝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000036",
    "sentence": "文帝元年，徙澤為燕王，而復以琅邪歸齊。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000037",
    "sentence": "澤王燕二年，薨，諡曰敬王。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000038",
    "sentence": "子康王嘉嗣，九年薨。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000039",
    "sentence": "子定國嗣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000040",
    "sentence": "定國與父康王姬姦，生子男一人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000041",
    "sentence": "奪弟妻為姬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000042",
    "sentence": "與子女三人姦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000043",
    "sentence": "定國有所欲誅殺臣肥如令郢人，郢人等告定國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000044",
    "sentence": "定國使謁者以它法劾捕格殺郢人滅口。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000045",
    "sentence": "至元朔中，郢人昆弟復上書具言定國事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000046",
    "sentence": "下公卿，皆議曰：「定國禽獸行，亂人倫，逆天道，當誅。」上許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000047",
    "sentence": "定國自殺，立四十二年，國除。",
    "entities": [
      {
        "text": "四十二年",
        "label": "TME",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000048",
    "sentence": "哀帝時繼絕世，乃封敬王澤玄孫之孫無終公士歸生為營陵侯，更始中為兵所殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000049",
    "sentence": "吳王濞",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000050",
    "sentence": "吳王濞，高帝兄仲之子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000051",
    "sentence": "高帝立仲為代王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000052",
    "sentence": "匈奴攻代，仲不能堅守，棄國間行，走雒陽，自歸，天子不忍致法，廢為合陽侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000053",
    "sentence": "子濞，封為沛侯。",
    "entities": [
      {
        "text": "沛",
        "label": "LOC",
        "start": 5,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000054",
    "sentence": "黥布反，高祖自將往誅之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000055",
    "sentence": "濞年二十，以騎將從破布軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000056",
    "sentence": "荊王劉賈為布所殺，無後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000057",
    "sentence": "上患吳會稽輕悍，無壯王填之，諸子少，乃立濞於沛，為吳王，王三郡五十三城。",
    "entities": [
      {
        "text": "沛",
        "label": "LOC",
        "start": 22,
        "end": 23
      },
      {
        "text": "王三郡五十三城",
        "label": "LOC",
        "start": 28,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000058",
    "sentence": "已拜受印，高祖召濞相之，曰：「若狀有反相。」獨悔，業已拜，因拊其背，曰：「漢後五十年東南有亂，豈若邪？然天下同姓一家，慎無反！」濞頓首曰：「不敢。」",
    "entities": [
      {
        "text": "五十年",
        "label": "TME",
        "start": 39,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000059",
    "sentence": "會孝惠、高后時天下初定，郡國諸侯各務自拊循其民。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000060",
    "sentence": "吳有豫章郡銅山，即招致天下亡命者盜鑄錢，東煮海水為鹽，以故無賦，國用饒足。",
    "entities": [
      {
        "text": "吳有豫章郡",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000061",
    "sentence": "孝文時，吳太子入見，得侍皇太子飲博。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000062",
    "sentence": "吳太子師傅皆楚人，輕悍，又素驕。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000063",
    "sentence": "博爭道，不恭，皇太子引博局提吳太子，殺之。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000064",
    "sentence": "於是遣其喪歸葬吳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000065",
    "sentence": "吳王慍曰：「天下一宗，死長安即葬長安，何必來葬！」復遣喪之長安葬。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 12,
        "end": 14
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 16,
        "end": 18
      },
      {
        "text": "長安",
        "label": "LOC",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000066",
    "sentence": "吳王由是怨望，稍失藩臣禮，稱疾不朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000067",
    "sentence": "京師知其以子故，驗問實不病，諸吳使來，輒繫責治之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000068",
    "sentence": "吳王恐，所謀滋甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000069",
    "sentence": "及後使人為秋請，上復責問吳使者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000070",
    "sentence": "使者曰：「察見淵中魚，不祥。今吳王始詐疾，反覺，見責急，愈益閉，恐上誅之，計乃無聊。唯上與更始。」於是天子皆赦吳使者歸之，而賜吳王几杖，老，不朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000071",
    "sentence": "吳得釋，其謀亦益解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000072",
    "sentence": "然其居國以銅鹽故，百姓無賦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000073",
    "sentence": "卒踐更，輒予平賈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000074",
    "sentence": "歲時存問茂材，賞賜閭里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000075",
    "sentence": "它郡國吏欲來捕亡人者，頌共禁不與。",
    "entities": [
      {
        "text": "它郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000076",
    "sentence": "如此者三十餘年，以故能使其眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000077",
    "sentence": "朝錯為太子家令，得幸皇太子，數從容言吳過可削。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_035_000078",
    "sentence": "數上書說之，文帝寬，不忍罰，以此吳王日益橫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_035_000079",
    "sentence": "及景帝即位，錯為御史大夫，說上曰：「昔高帝初定天下，昆弟少，諸子弱，大封同姓，故孽子悼惠王王齊七十二城，庶弟元王王楚四十城，兄子王吳五十餘城。封三庶孽，分天下半。今吳王前有太子之隙，詐稱病不朝，於古法當誅。文帝不忍，因賜几杖，德至厚也。不改過自新，乃益驕恣，公即山鑄錢，煮海為鹽，誘天下亡人謀作亂逆。今削之亦反，不削亦反。削之，其反亟，禍小；不削之，其反遲，禍大。」三年冬，楚王來朝，錯因言楚王戊往年為薄太后服，私姦服舍，請誅之。",
