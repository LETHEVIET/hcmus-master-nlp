      }
    ]
  },
  {
    "sentence_id": "HCH_006_002_000006",
    "sentence": "賜民爵一級。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_002_000007",
    "sentence": "中郎、郎中滿六歲爵三級，四歲二級。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_002_000008",
    "sentence": "外郎滿六歲二級。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_002_000009",
    "sentence": "中郎不滿一歲一級。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_002_000010",
    "sentence": "外郎不滿二歲賜錢萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_002_000011",
    "sentence": "宦官尚食比郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_002_000012",
    "sentence": "謁者、執楯、執戟、武士、騶比外郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_002_000013",
    "sentence": "太子御驂乘賜爵五大夫，舍人滿五歲二級。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_002_000014",
    "sentence": "賜給喪事者，二千石錢二萬，六百石以上萬，五百石、二百石以 下至佐史五千。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_002_000015",
    "sentence": "視作斥上者，將軍四十金，二千石二十金，六百石以上六金，五百石以下至佐史二金。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_002_000016",
    "sentence": "減田租，復十五稅一。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_002_000017",
    "sentence": "爵五大夫、吏六百石以上及宦皇帝而知 名者有罪當盜械者，皆頌繫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_006_002_000018",
    "sentence": "上造以上及內外公孫耳孫有罪當刑及當為城旦舂者，皆耐為鬼薪白粲。",
    "entities": [
      {
        "text": "罪當刑及當為城",
        "label": "LOC",
        "start": 12,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_006_002_000019",
    "sentence": "民年七十以上若不滿十歲有罪當刑者，皆完之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_002_000020",
    "sentence": "又曰：「吏所以 治民也，能盡其治則民賴之，故重其祿，所以為民也。今吏六百石以上父母妻子與同居，及故吏嘗佩將軍都尉印將兵及佩二千石官印者，家唯給軍賦，他無有所與。令郡諸侯王立高廟。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
