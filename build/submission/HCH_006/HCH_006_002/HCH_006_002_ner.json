      }
    ]
  },
  {
    "sentence_id": "HCH_006_002_000022",
    "sentence": "元年冬十二月，趙隱王如意薨。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_002_000023",
    "sentence": "民有罪，得買爵三十級以免死罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_002_000024",
    "sentence": "賜民爵，戶一級。",
    "entities": []
  },
  {
