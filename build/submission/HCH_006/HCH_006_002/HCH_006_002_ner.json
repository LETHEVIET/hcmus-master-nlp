  },
  {
    "sentence_id": "HCH_006_002_000002",
    "sentence": "帝年五歲，高祖初為漢王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_002_000003",
    "sentence": "二年，立為太子。",
