        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_002_000005",
    "sentence": "五月丙寅，太子即皇帝位，尊皇后曰皇太后。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "皇帝",
