        "text": "遂西入武關",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000009",
    "sentence": "沛公立為漢王，入漢中，還定三秦。",
    "entities": [
      {
        "text": "沛",
