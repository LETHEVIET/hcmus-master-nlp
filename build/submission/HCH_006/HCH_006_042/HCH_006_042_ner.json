        "end": 20
      },
      {
        "text": "食邑",
        "label": "LOC",
        "start": 23,
        "end": 25
      },
      {
        "text": "而嘉食邑",
        "label": "LOC",
        "start": 30,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000103",
    "sentence": "十六年，遷為御史大夫。",
    "entities": [
      {
        "text": "十六年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
