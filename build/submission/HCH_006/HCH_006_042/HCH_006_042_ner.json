  },
  {
    "sentence_id": "HCH_006_042_000064",
    "sentence": "及高祖初起，敖以客從為御史，守豐二歲。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000065",
    "sentence": "高祖立為漢王，東擊項羽，遨遷為上黨守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000066",
    "sentence": "陳豨反，敖堅守，封為廣阿侯，食邑千八百戶。",
    "entities": [
      {
        "text": "食邑",
        "label": "LOC",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000067",
    "sentence": "高后 時為御史大夫，三歲免。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000068",
    "sentence": "孝文元年薨，諡曰懿侯。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000069",
    "sentence": "傳子至曾孫越人，坐為太常廟酒酸不敬，國除。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000070",
    "sentence": "初任敖免，平陽侯曹窋代敖為御史大夫。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000071",
    "sentence": "高后崩，與大臣共誅諸呂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000072",
    "sentence": "後坐事免，以淮南相張蒼為御史大夫。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000073",
    "sentence": "蒼來絳侯等尊立孝文皇帝，四年，代灌嬰為丞相。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "四年",
        "label": "TME",
        "start": 12,
        "end": 14
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000074",
    "sentence": "漢興二十餘年，天下初定，公卿皆軍吏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000075",
    "sentence": "蒼為計相時，緒正律曆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000076",
    "sentence": "以高祖十月始至霸上，故因秦時本十月為歲首，不革。",
    "entities": [
      {
        "text": "秦",
        "label": "ORG",
        "start": 12,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000077",
    "sentence": "推五德之運，以為漢當水德之時，上黑如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000078",
    "sentence": "吹律調樂，入之音聲，及以比定律令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000079",
    "sentence": "若百工，天下作程品。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000080",
    "sentence": "至於為丞相，卒就之。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000081",
    "sentence": "故漢家言律曆者本張蒼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000082",
    "sentence": "蒼凡好書，無所不觀，無所不通，而尤邃律曆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000083",
    "sentence": "蒼德安國侯王陵，及貴，父事陵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000084",
    "sentence": "陵死後，蒼為丞相，洗沐，常先朝陵夫人上食，然後敢歸家。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000085",
    "sentence": "蒼為丞相十餘年，魯人公孫臣上書，陳終始五德傳，言「漢土德時，其符黃龍見，當改正朔，易服色」。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000086",
    "sentence": "事下蒼，蒼以為非是，罷之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000087",
    "sentence": "其後黃龍見成紀，於是文帝召公孫臣以為博士，草立土德時曆制度，更元年。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "元年",
        "label": "TME",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000088",
    "sentence": "蒼由此自絀，謝病稱老。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000089",
    "sentence": "蒼任人為中候，大為奸利，上以為讓，蒼遂病免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000090",
    "sentence": "孝景五年薨，諡曰文侯。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_042_000091",
    "sentence": "傳子至孫類，有罪，國除。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000092",
    "sentence": "初蒼父長不滿五尺，蒼長八尺餘，蒼子復長八尺，及孫類長六尺餘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000093",
    "sentence": "蒼免相後，口中無齒，食乳，女子為乳母。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000094",
    "sentence": "妻妾以百數，嘗孕者不復幸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000095",
    "sentence": "年百餘歲乃卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000096",
    "sentence": "著書十八篇，言陰陽律曆事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000097",
    "sentence": "申屠嘉",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000098",
    "sentence": "申屠嘉，梁人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000099",
    "sentence": "以材官蹶張從高帝擊項籍，遷為隊率。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000100",
    "sentence": "從擊黥布，為都尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000101",
    "sentence": "孝惠時，為淮陽守。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_042_000102",
    "sentence": "孝文元年，舉故以二千石從高祖者，悉以為關內侯，食邑二十四人，而嘉食邑五百戶。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "悉以為關",
        "label": "LOC",
