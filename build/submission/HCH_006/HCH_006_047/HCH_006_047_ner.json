[
  {
    "sentence_id": "HCH_006_047_000001",
    "sentence": "孝文皇帝四男：竇皇后生孝景帝、梁孝王武，諸姬生代孝王參、梁懷王揖。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000002",
    "sentence": "梁孝王武",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000003",
    "sentence": "梁孝王武以孝文二年與太原王參、梁王揖同日立。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000004",
    "sentence": "武為代王，四年徙為淮陽王，十二年徙梁，自初王通歷已十一年矣。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 5,
        "end": 7
      },
      {
        "text": "十二年",
        "label": "TME",
        "start": 13,
        "end": 16
      },
      {
        "text": "十一年",
        "label": "TME",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000005",
    "sentence": "孝王十四年，入朝。",
    "entities": [
      {
        "text": "十四年",
        "label": "TME",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000006",
    "sentence": "十七年，十八年，比年入朝，留。",
    "entities": [
      {
        "text": "十七年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "十八年",
        "label": "TME",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000007",
    "sentence": "其明年，乃之國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000008",
    "sentence": "二十一年，入朝。",
    "entities": [
      {
        "text": "二十一年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000009",
    "sentence": "二十二年，文帝崩。",
    "entities": [
      {
        "text": "二十二年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000010",
    "sentence": "二十四年，入朝。",
    "entities": [
      {
        "text": "二十四年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000011",
    "sentence": "二十五年，復入朝。",
    "entities": [
      {
        "text": "二十五年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000012",
    "sentence": "是時，上未置太子，與孝王宴飲，從容言曰：「千秋萬歲後傳於王。」王辭謝。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000013",
    "sentence": "雖知非至言，然心內喜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000014",
    "sentence": "太后亦然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000015",
    "sentence": "其春，吳、楚、齊、趙七國反，先擊梁棘壁，殺數萬人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000016",
    "sentence": "梁王城守睢陽，而使韓安國、張羽等為將軍以距吳、楚。",
    "entities": [
      {
        "text": "梁王城",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000017",
    "sentence": "吳、楚以梁為限，不敢過而西，與太尉亞夫等相距三月。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000018",
    "sentence": "吳、楚破，而梁所殺虜略與漢中分。",
    "entities": [
      {
        "text": "漢",
        "label": "ORG",
        "start": 12,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000019",
    "sentence": "明年，漢立太子。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000020",
    "sentence": "梁最親，有功，又為大國，居天下膏腴地，北界泰山，西至高陽，四十餘城，多大縣。",
    "entities": [
      {
        "text": "四十餘城",
        "label": "LOC",
        "start": 29,
        "end": 33
      },
      {
        "text": "多大縣",
        "label": "LOC",
        "start": 34,
        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000021",
    "sentence": "孝王，太后少子，愛之，賞賜不可勝道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000022",
    "sentence": "於是孝王築東苑，方三百餘里，廣睢陽城七十里，大治宮室，為復道，自宮連屬於平臺三十餘里。",
    "entities": [
      {
        "text": "廣睢陽城",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000023",
    "sentence": "得賜天子旌旗，從千乘萬騎，出稱警，入言旧，儗於天子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000024",
    "sentence": "招延四方豪桀，自山東游士莫不至：齊人羊勝、公孫詭、鄒陽之屬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000025",
    "sentence": "公孫詭多奇邪計，初見日，王賜千金，官至中尉，號曰公孫將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000026",
    "sentence": "多作兵弩弓數十萬，而府庫金錢且百鉅萬，珠玉寶器多於京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000027",
    "sentence": "二十九年十月，孝王入朝。",
    "entities": [
      {
        "text": "二十九年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000028",
    "sentence": "景帝使使持乘輿駟，迎梁王於關下。",
    "entities": [
      {
        "text": "迎梁王於關",
        "label": "LOC",
        "start": 9,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000029",
    "sentence": "既朝，上疏，因留。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000030",
    "sentence": "以太后故，入則侍帝同輦，出則同車遊獵上林中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000031",
    "sentence": "梁之侍中、郎、謁者著引籍出入天子殿門，與漢宦官亡異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000032",
    "sentence": "十一月，上廢栗太子，太后心欲以梁王為嗣。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000033",
    "sentence": "大臣及爰盎等有所關說於帝，太后議格，孝王不敢復言太后以嗣事。",
    "entities": [
      {
        "text": "及爰盎等有所關",
        "label": "LOC",
        "start": 2,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000034",
    "sentence": "事祕，世莫知，乃辭歸國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000035",
    "sentence": "其夏，上立膠東王為太子。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000036",
    "sentence": "梁王怨爰盎及議臣，乃與羊勝、公孫詭之屬謀，陰使人刺殺爰盎及他議臣十餘人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000037",
    "sentence": "賊未得也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000038",
    "sentence": "於是天子意梁，逐賊，果梁使之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000039",
    "sentence": "遣使冠蓋相望於道，覆案梁事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000040",
    "sentence": "捕公孫詭、羊勝，皆匿王後宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000041",
    "sentence": "使者責二千石急，梁相軒丘豹及內史安國皆泣諫王，王乃令勝、詭皆自殺，出之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000042",
    "sentence": "上由此怨望於梁王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000043",
    "sentence": "梁王恐，乃使韓安國因長公主謝罪太后，然後得釋。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000044",
    "sentence": "上怒稍解，因上書請朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000045",
    "sentence": "既至關，茅蘭說王，使乘布車，從兩騎入，匿於長公主園。",
    "entities": [
      {
        "text": "既至關",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000046",
    "sentence": "漢使迎王，王已入關，車騎盡居外，外不知王處。",
    "entities": [
      {
        "text": "王已入關",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000047",
    "sentence": "太后泣曰：「帝殺吾子！」弟憂恐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000048",
    "sentence": "於是梁王伏斧質，之闕下謝罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000049",
    "sentence": "然後太后、帝皆大喜，相與泣，復如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000050",
    "sentence": "悉召王從官入關。",
    "entities": [
      {
        "text": "悉召王從官入關",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000051",
    "sentence": "然帝益疏王，不與同車輦矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000052",
    "sentence": "三十五年冬，復入朝。",
    "entities": [
      {
        "text": "三十五年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000053",
    "sentence": "上疏欲留，上弗許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000054",
    "sentence": "歸國，意忽忽不樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000055",
    "sentence": "北獵梁山，有獻牛，足上出背上，孝王惡之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000056",
    "sentence": "六月中，病熱，六日薨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000057",
    "sentence": "孝王慈孝，每聞太后病，口不能食，常欲留長安侍太后。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000058",
    "sentence": "太后亦愛之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000059",
    "sentence": "及聞孝王死，竇太后泣極哀，不食，曰：「帝果殺吾子！」帝哀懼，不知所為。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000060",
    "sentence": "與長公主計之，乃分梁為五國，盡立孝王男五人為王，女五人皆令食湯沐邑。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "人皆令食湯沐邑",
        "label": "LOC",
        "start": 26,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000061",
    "sentence": "奏之太后，太后乃說，為帝壹餐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000062",
    "sentence": "孝王未死時，財以鉅萬計，不可勝數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000063",
    "sentence": "及死，藏府餘黃金尚四十餘萬斤，他財物稱是。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000064",
    "sentence": "代孝王參",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000065",
    "sentence": "代孝王參初立為太原王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000066",
    "sentence": "四年，代王武徙為淮陽王，而參徙為代王，並得復太原，都晉陽如故。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "晉",
        "label": "ORG",
        "start": 26,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000067",
    "sentence": "五年一朝，凡三朝。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000068",
    "sentence": "十七年薨，子共王登嗣。",
    "entities": [
      {
        "text": "十七年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000069",
    "sentence": "二十九年薨，子義嗣。",
    "entities": [
      {
        "text": "二十九年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000070",
    "sentence": "元鼎中，漢廣關，以常山為阻，徙代王於清河，是為剛王。",
    "entities": [
      {
        "text": "漢廣關",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000071",
    "sentence": "並前在代凡立四十年薨，子頃王湯嗣。",
    "entities": [
      {
        "text": "四十年",
        "label": "TME",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000072",
    "sentence": "二十四年薨，子年嗣。",
    "entities": [
      {
        "text": "二十四年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000073",
    "sentence": "地節中，冀州刺史林奏年為太子時與女弟則私通。",
    "entities": [
      {
        "text": "冀州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000074",
    "sentence": "及年立為王後，則懷年子，其婿使勿舉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000075",
    "sentence": "則曰：「自來殺之。」婿怒曰：「為王生子，自令王家養之。」則送兒頃太后所。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000076",
    "sentence": "相聞知，禁止則，令不得入宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000077",
    "sentence": "年使從季父往來送迎則，連年不絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_047_000078",
    "sentence": "有司奏年淫亂，年坐廢為庶人，徙房陵，與湯沐邑百戶。",
    "entities": [
      {
        "text": "與湯沐邑",
        "label": "LOC",
        "start": 18,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000079",
    "sentence": "立三年，國除。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_006_047_000080",
    "sentence": "元始二年，新都侯王莽興滅繼絕，白太皇太后，立年弟子如意為廣宗王，奉代孝王後。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
