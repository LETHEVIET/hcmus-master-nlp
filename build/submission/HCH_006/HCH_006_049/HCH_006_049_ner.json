      }
    ]
  },
  {
    "sentence_id": "HCH_006_049_000051",
    "sentence": "及晁錯已誅，盎以泰常使吳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_049_000052",
    "sentence": "吳王欲使將，不肯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_049_000053",
