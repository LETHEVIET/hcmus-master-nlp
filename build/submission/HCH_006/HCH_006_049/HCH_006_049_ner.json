        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_006_049_000039",
    "sentence": "盎還，媿其吏，乃之丞相舍上謁，求見丞相。",
    "entities": [
      {
        "text": "丞相",
        "label": "TITLE",
