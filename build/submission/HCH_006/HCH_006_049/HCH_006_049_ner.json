      }
    ]
  },
  {
    "sentence_id": "HCH_006_049_000049",
    "sentence": "兩人素相善。",
    "entities": []
  },
  {
    "sentence_id": "HCH_006_049_000050",
    "sentence": "是時，諸陵長安中賢大夫爭附兩人，車騎者日數百乘。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
