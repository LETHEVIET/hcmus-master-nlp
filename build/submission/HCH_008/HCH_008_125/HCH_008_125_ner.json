      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000138",
    "sentence": "德宗怒，幽主於別第，李萬決殺，升貶嶺南，蕭鼎、韋恪決四十，長流嶺表。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000139",
    "sentence": "又言公主行厭禱，其子位為禱文，位弟佩、儒、偲及異父兄駙馬都尉裴液，並長流端州。",
    "entities": [
