      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000088",
    "sentence": "尋贈尚書左僕射，葬事官給。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000089",
    "sentence": "興元元年，贈太子少傅。",
    "entities": [
      {
        "text": "元",
