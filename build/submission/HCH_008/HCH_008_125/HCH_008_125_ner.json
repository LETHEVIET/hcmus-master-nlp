  },
  {
    "sentence_id": "HCH_008_125_000090",
    "sentence": "劉從一",
    "entities": [
      {
        "text": "劉從一",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000091",
    "sentence": "劉從一，中書侍郎林甫之玄孫也。",
    "entities": [
      {
        "text": "劉從一",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000092",
    "sentence": "祖令植，禮部侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000093",
    "sentence": "父孺之，京兆府少尹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000094",
    "sentence": "從一少舉進士，大歷中宏詞，授秘書省校書郎，以調中第，補渭南尉，雅為常袞所推重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000095",
    "sentence": "及袞為相，遷監察御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000096",
    "sentence": "居無何，丁母憂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000097",
    "sentence": "服除，宰相盧杞薦之，超遷侍御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000098",
    "sentence": "居數月，以親避除刑部員外郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000099",
    "sentence": "建中末，普王之為元帥也，遷吏部郎中、兼御史中丞，為元帥判官。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000100",
    "sentence": "德宗居奉天，拜刑部侍郎、平章事，從幸梁州。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "從幸梁州",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000101",
    "sentence": "明年六月，改中書侍郎、平章事。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000102",
    "sentence": "歲中，加集賢殿大學士、修史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000103",
    "sentence": "上遇之甚厚，以容身遠罪而已，不能有所匡輔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000104",
    "sentence": "無幾，以疾請告，至是，病甚辭位，章疏六上，乃許，除戶部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000105",
    "sentence": "尋卒，年四十四，輟朝三日，贈太子太傅。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000106",
    "sentence": "初，林甫生祥道，麟德初為右相，祥道即從一曾伯祖也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000107",
    "sentence": "令植從父兄齊賢，弘道初為侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000108",
    "sentence": "自祥道至從一，劉氏凡三相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000109",
    "sentence": "蕭復",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000110",
    "sentence": "蕭復，字履初，太子太師嵩之孫，新昌公主之子。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "公主",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000111",
    "sentence": "父衡，太仆卿、駙馬都尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000112",
    "sentence": "少秉清操，其群從兄弟，競飾輿馬，以侈靡相尚，復衣浣濯之衣，獨居一室，習學不倦，非詞人儒士不與之遊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000113",
    "sentence": "伯華每嘆異之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000114",
    "sentence": "以主廕，初為宮門郎，累至太子仆。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000115",
    "sentence": "廣德中，連歲不稔，谷價翔貴，家貧，將鬻昭應別業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000116",
    "sentence": "時宰相王縉聞其林泉之美，心欲之，乃使弟竑誘焉，曰：「足下之才，固宜居右職，如以別業奉家兄，當以要地處矣。」復對曰：「仆以家貧而鬻舊業，將以拯濟孀幼耳，倘以易美職於身，令門內凍餒，非鄙夫之心也。」縉憾之，乃罷復官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000117",
    "sentence": "沈廢數年，復處之自若。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000118",
    "sentence": "後累至尚書郎。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000119",
    "sentence": "大歷十四年，自常州刺史為潭州刺史、湖南觀察使。",
    "entities": [
      {
        "text": "十四年",
        "label": "TME",
