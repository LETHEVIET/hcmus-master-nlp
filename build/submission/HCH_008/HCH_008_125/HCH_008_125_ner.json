        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000132",
    "sentence": "四年，終於饒州，時年五十七。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
