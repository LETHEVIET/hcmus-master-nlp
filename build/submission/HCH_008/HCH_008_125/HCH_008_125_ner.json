[
  {
    "sentence_id": "HCH_008_125_000001",
    "sentence": "張鎰",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000002",
    "sentence": "張鎰，蘇州人，朔方節度使齊丘之子也。",
    "entities": [
      {
        "text": "蘇州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000003",
    "sentence": "以門廕授左衛兵曹參軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000004",
    "sentence": "郭子儀為關內副元帥，以嘗伏事齊丘，辟鎰為判官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000005",
    "sentence": "授大理評事，遷殿中侍御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000006",
    "sentence": "乾元初，華原令盧樅以公事呵責邑人內侍齊令詵，令詵銜之，構誣。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "樅以公事呵責邑",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000007",
    "sentence": "外發鎰按驗，樅當降官，及下有司，樅當杖死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000008",
    "sentence": "鎰其公服白其母曰：「上疏理樅，樅必免死，鎰必坐貶。若以私則鎰負於當官，貶則以太夫人為憂，敢問所安？」母曰：爾無累於道，吾所安也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000009",
    "sentence": "」遂執奏正罪，樅獲配流，鎰貶撫州司戶。",
    "entities": [
      {
        "text": "鎰貶撫州",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000010",
    "sentence": "量移晉陵令，未之官，洪吉觀察張鎬辟為判官，奏授殿中侍御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000011",
    "sentence": "遷屯田員外郎，轉祠部、右司二員外。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000012",
    "sentence": "母憂居喪有聞，免喪，除司勛員外。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000013",
    "sentence": "交遊不雜，與楊綰、崔祐甫相善。",
    "entities": [
      {
        "text": "崔祐甫",
        "label": "PER",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000014",
    "sentence": "大歷五年，除濠州刺史，為政清凈，州事大理。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "除濠州",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000015",
    "sentence": "乃招經術之士，講訓生徒，比去郡，升明經者四十余人。",
    "entities": [
      {
        "text": "比去郡",
        "label": "LOC",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000016",
    "sentence": "撰《三禮圖》九卷、《五經微旨》十四卷、《孟子音義》三卷。",
    "entities": [
      {
        "text": "《三禮圖》",
        "label": "TITLE",
        "start": 1,
        "end": 6
      },
      {
        "text": "《五經微旨》",
        "label": "TITLE",
        "start": 9,
        "end": 15
      },
      {
        "text": "《孟子音義》",
        "label": "TITLE",
        "start": 19,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000017",
    "sentence": "李靈曜反於汴州，鎰訓練鄉兵，嚴守禦之備，詔書褒異，加侍御史、沿淮鎮守使。",
    "entities": [
      {
        "text": "李靈曜反於汴州",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "鎰訓練鄉",
        "label": "LOC",
        "start": 8,
        "end": 12
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 27,
        "end": 29
      },
      {
        "text": "沿淮鎮",
        "label": "LOC",
        "start": 30,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000018",
    "sentence": "尋遷壽州刺史，使如故。",
    "entities": [
      {
        "text": "尋遷壽州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000019",
    "sentence": "德宗即位，除江南西道都團練觀察使、洪州刺史、兼御史中丞，征拜吏部侍郎，尋除河中晉絳都防禦觀察使。",
    "entities": [
      {
        "text": "洪州",
        "label": "LOC",
        "start": 17,
        "end": 19
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 19,
        "end": 21
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 23,
        "end": 25
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000020",
    "sentence": "到官數日，改汴滑節度觀察使、汴州刺史、兼御史大夫，以疾辭，逗留於中路，征入，養疾私第。",
    "entities": [
      {
        "text": "汴州",
        "label": "LOC",
        "start": 14,
        "end": 16
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 20,
        "end": 22
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000021",
    "sentence": "未幾，拜中書侍郎、平章事、集賢殿學士，修國史。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000022",
    "sentence": "建中三年正月，太仆卿趙縱為奴當千發其陰事，縱下御史臺，貶循州司馬，留當千於內侍省。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 23,
        "end": 25
      },
      {
        "text": "貶循州",
        "label": "LOC",
        "start": 27,
        "end": 30
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000023",
    "sentence": "鎰上疏論之曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000024",
    "sentence": "伏見趙縱為奴所告下獄，人皆震懼，未測聖情。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000025",
    "sentence": "貞觀二年，太宗謂侍臣曰：比有奴告其主謀逆，此極弊法，特須禁斷。",
    "entities": [
      {
        "text": "貞觀二年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000026",
    "sentence": "假令有謀反者，必不獨成，自有他人論之，豈藉其奴告也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000027",
    "sentence": "自今已後，奴告主者皆不受，盡令斬決。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000028",
    "sentence": "」由是賤不得幹貴，下不得陵上，教化之本既正，悖亂之漸不生。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000029",
    "sentence": "為國之經，百代難改，欲全其事體，實在防微。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000030",
    "sentence": "頃者長安令李濟得罪因奴，萬年令霍晏得罪因婢，愚賤之輩，悖慢成風，主反畏之，動遭誣告，充溢府縣，莫能斷決。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 2,
        "end": 4
      },
      {
        "text": "充溢府縣",
        "label": "LOC",
        "start": 42,
        "end": 46
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000031",
    "sentence": "建中元年五月二十八日，詔曰：準鬥競律，諸奴婢告主，非謀叛已上者，同自首法，並準律處分。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000032",
    "sentence": "」自此奴婢復順，獄訴稍息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000033",
    "sentence": "今趙縱非叛逆，奴實奸兇，奴在禁中，縱獨下獄，考之於法，或恐未正。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000034",
    "sentence": "將帥之功，莫大於子儀；人臣之位，莫大於尚父。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000035",
    "sentence": "歿身未幾，墳土僅乾，兩婿先已當辜，趙縱今又下獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000036",
    "sentence": "設令縱實抵法，所告非奴，才經數月，連罪三婿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000037",
    "sentence": "錄勛念舊，猶或可容，況在章程，本宜宥免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000038",
    "sentence": "陛下方誅群賊，大用武臣，雖見寵於當時，恐息望於他日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000039",
    "sentence": "太宗之令典尚在，陛下之明詔始行，一朝偕違，不與眾守，於教化恐失，於刑法恐煩，所益悉無，所傷至廣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000040",
    "sentence": "臣非私趙縱，非惡此奴，叨居股肱，職在匡弼，斯昌大體，敢不極言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000041",
    "sentence": "伏乞聖慈，納臣愚懇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000042",
    "sentence": "上深納之，縱於是左貶而已，當千杖殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000043",
    "sentence": "鎰乃令召子儀家僮數百人，以死奴示之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000044",
    "sentence": "盧杞忌鎰名重道直，無以陷之，以方用兵西邊，杞乃偽請行，上固以不可，因薦鎰以中書侍郎為鳳翔隴右節度使代硃泚，與吐蕃相尚結贊等盟於清水。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 39,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000045",
    "sentence": "將盟，鎰與結贊約各以二千人赴壇所，執兵者半之，列於壇外二百步；散從者半之，分立壇下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000046",
    "sentence": "鎰與賓佐齊映、齊抗及盟官崔漢衡、樊澤、常魯、於頔等七人，皆朝服；結贊與其本國將相論悉頰藏、論臧熱、論利陁、斯官者、論力徐等亦七人，俱升壇為盟。",
    "entities": [
      {
        "text": "崔漢衡",
        "label": "PER",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000047",
    "sentence": "初，約漢以牛，蕃以馬為牲，鎰恥與之盟，將殺其禮，乃請結贊曰：「漢非牛不田，蕃非馬不行，今請以羊豕犬三物代之。」結贊許諾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000048",
    "sentence": "時塞外無豕，結贊請以羝羊，鎰出犬、白羊，乃坎於壇北刑之，雜血一器而歃，盟文曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000049",
    "sentence": "唐有天下，恢奄禹跡，舟車所至，莫不率俾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000050",
    "sentence": "以累聖重光，卜年惟永，恢王者之丕業，被四海以聲教。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000051",
    "sentence": "與吐蕃贊普，代為婚姻，因結鄰好，安危同體，甥舅之國，將二百年。",
    "entities": [
      {
        "text": "二百年",
        "label": "TME",
        "start": 27,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000052",
    "sentence": "其間或因小忿，棄惠為仇，封疆騷然，靡有寧歲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000053",
    "sentence": "皇帝踐阼，湣茲黎元，乃釋俘囚悉歸蕃落。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000054",
    "sentence": "二國展禮，同茲協和，行人往復，累布成命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000055",
    "sentence": "是必詐謀不起，兵革不用矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000056",
    "sentence": "彼猶以兩國之要，求之永久，古有結盟，今請用之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000057",
    "sentence": "國家務息邊人，外其故地，棄利蹈義，堅盟從約。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000058",
    "sentence": "今國家所守界：涇州西至彈箏峽西口，隴州西至清水縣，鳳州西至同谷縣，暨劍南西山、大渡河東，為漢界。",
    "entities": [
      {
        "text": "涇州",
        "label": "LOC",
        "start": 7,
        "end": 9
      },
      {
        "text": "隴州西至清水縣",
        "label": "LOC",
        "start": 17,
        "end": 24
      },
      {
        "text": "鳳州西至同谷縣",
        "label": "LOC",
        "start": 25,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000059",
    "sentence": "蕃國守鎮在蘭、渭、原、會，西至臨洮，又東至成州，抵劍南西界磨些諸蠻、大渡水西南，為蕃界。",
    "entities": [
      {
        "text": "蕃國守鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "又東至成州",
        "label": "LOC",
        "start": 18,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000060",
    "sentence": "其兵馬鎮守之處州縣見有居人，彼此兩邊見屬漢諸蠻，以今所分見住處依前所有不載者，蕃有兵馬處蕃守，漢有兵馬處漢守，不得侵越。",
    "entities": [
      {
        "text": "其兵馬鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "守之處州縣",
        "label": "LOC",
        "start": 4,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000061",
    "sentence": "其先未有兵馬處，不得雜置並築城堡耕種。",
    "entities": [
      {
        "text": "不得雜置並築城",
        "label": "LOC",
        "start": 8,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000062",
    "sentence": "今二國將相受辭而會，齋戒將事，告天地山川之神，惟神昭臨，無得衍墜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000063",
    "sentence": "其盟文藏於郊廟，副在有司，二國之誠，其永保之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000064",
    "sentence": "結贊亦出盟文，不加於坎，但埋牲而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000065",
    "sentence": "盟畢，結贊請鎰就壇之西南隅佛幄中焚香為誓，誓畢，復升壇飲酒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000066",
    "sentence": "獻酬之禮，各用其物，以將厚意而歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000067",
    "sentence": "德宗將幸奉天，鎰竊知之，將迎鑾駕，具財貨服用獻行在。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000068",
    "sentence": "李楚琳者，嘗事硃泚，得其心。",
    "entities": [
      {
        "text": "李楚琳",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000069",
    "sentence": "軍司馬齊映等密謀曰：「楚琳不去，必為亂。」乃遣楚琳屯於隴州。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 1,
        "end": 3
      },
      {
        "text": "遣楚琳屯於隴州",
        "label": "LOC",
        "start": 22,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000070",
    "sentence": "楚琳知其謀，乃托故不時發。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000071",
    "sentence": "鎰始以迎駕心憂惑，以楚琳承命去矣，殊不促其行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000072",
    "sentence": "鎰修飾邊幅，不為軍士所悅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000073",
    "sentence": "是夜，楚琳遂與其黨王汾、李卓、牛僧伽等作亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000074",
    "sentence": "鎰夜縋而走，判官齊映自水竇出，齊抗為傭保負荷而逃，皆獲免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000075",
    "sentence": "鎰出鳳翔三十里，及二子皆為候騎所得，楚琳俱殺之；判官王沼、張元度、柳遇、李漵被殺。",
    "entities": [
      {
        "text": "張元度",
        "label": "PER",
        "start": 29,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000076",
    "sentence": "尋贈太子太傅，葬事官給。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000077",
    "sentence": "附 馮河清",
    "entities": [
      {
        "text": "馮河清",
        "label": "PER",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000078",
    "sentence": "馮河清者，京兆人也。",
    "entities": [
      {
        "text": "馮河清",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000079",
    "sentence": "初以武藝從軍，隸朔方節度郭子儀，以戰功授左衛大將軍同正；隸涇原節度馬璘，頻以偏師禦吐蕃，甚有殺獲之功。",
    "entities": [
      {
        "text": "郭子儀",
        "label": "PER",
        "start": 12,
        "end": 15
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 22,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000080",
    "sentence": "歷試太子詹事、兼御史中丞，充兵馬使。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000081",
    "sentence": "建中四年，節度使姚令言奉詔率兵赴關東，以河清知兵馬留後，判官、殿中侍御史姚況知州事。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 34,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000082",
    "sentence": "及令言至京師，所統兵叛，上幸奉天，河清與況聞之，乃集三軍大哭，因共激勵將吏，誓敦誠節，眾頗義之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000083",
    "sentence": "即時發甲仗、器械、車百余輛，連夜送行在所。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_125_000084",
    "sentence": "時駕初遷幸，六軍雖集，蒼黃之際，都無戎器，及涇州甲仗至，軍士大振，特詔褒其誠效，拜四鎮北庭行軍涇原節度使、兼御史大夫；姚況兼御史中丞、行軍司馬。",
    "entities": [
      {
        "text": "及涇州",
        "label": "LOC",
        "start": 21,
        "end": 24
      },
      {
