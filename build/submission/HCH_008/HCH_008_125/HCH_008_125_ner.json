        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000120",
    "sentence": "及為同州刺史，州人阻饑，有京畿觀察使儲廩在境內，復輒以賑貸，為有司所劾，削階。",
    "entities": [
      {
        "text": "及為同州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
