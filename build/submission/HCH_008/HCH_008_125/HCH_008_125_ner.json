        "start": 69,
        "end": 71
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000085",
    "sentence": "俄加河清檢校工部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000086",
    "sentence": "賊泚及姚令言累遣間諜招誘，河清輒拘而戮焉。",
    "entities": [
      {
        "text": "姚令言",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_125_000087",
    "sentence": "及駕幸梁州，其將田希鑒潛通泚，使結兇黨害河清。",
    "entities": [
