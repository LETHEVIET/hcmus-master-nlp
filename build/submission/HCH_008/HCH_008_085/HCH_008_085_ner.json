      {
        "text": "蔣欽緒",
        "label": "PER",
        "start": 28,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000078",
    "sentence": "又則天父母二陵各置守戶五百人，武三思及子崇訓墓各置守戶六十人。",
    "entities": [
      {
        "text": "武三思",
        "label": "PER",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000079",
    "sentence": "以武氏外戚乃與昭陵禮同，三思等復逾親王之製，又上疏切諫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000080",
    "sentence": "當時雖皆不從，深為議者所美。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000081",
    "sentence": "睿宗即位，又數陳時政損益，累轉給事中，仍知禮儀事。",
    "entities": [
      {
        "text": "陳",
        "label": "ORG",
        "start": 7,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000082",
    "sentence": "先天二年 冬，今上講武於驪山，紹以修儀注不合旨，坐斬。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000083",
    "sentence": "時今上既怒講武失儀，坐紹於纛下，右金吾將軍李邈遽請宣敕，遂斬之。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000084",
    "sentence": "時人既痛惜紹，而深咎於邈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000085",
    "sentence": "尋有敕罷邈官，遂擯廢終其身。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000086",
    "sentence": "張文瓘",
    "entities": [
      {
        "text": "張文瓘",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000087",
    "sentence": "張文瓘，貝州武城人。",
    "entities": [
      {
        "text": "張文瓘",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "貝州武城",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000088",
    "sentence": "大業末徙家魏州之昌樂。",
    "entities": [
      {
        "text": "大業末徙家魏州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000089",
    "sentence": "瓘幼孤，事母兄以孝友聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000090",
    "sentence": "貞觀初，舉明經，補并州參軍。",
    "entities": [
      {
        "text": "補并州",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000091",
    "sentence": "時英國公李勣為長史，深禮之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000092",
    "sentence": "累遷水部員外郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000093",
    "sentence": "時兄文琮為戶部侍郎，舊制兄弟不許並居台閣，遂出為雲陽令。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000094",
    "sentence": "龍朔年，累授東西台舍人、參知政事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000095",
    "sentence": "尋遷東台侍郎、同東西台三品，兼知左史事。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000096",
    "sentence": "時初造蓬萊、上陽、合璧等宮，又征討四夷，廄馬有萬匹，倉庫漸虛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000097",
    "sentence": "文瓘因進諫曰：“人力不可不惜，百姓不可不養，養之逸則富以康，使之勞則怨以叛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000098",
    "sentence": "秦皇、漢武，廣事四夷，多造宮室，使士崩瓦解，戶口減半。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000099",
    "sentence": "臣聞製化於未亂，保邦於未危，人罔常懷，懷於有仁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000100",
    "sentence": "陛下不製於未亂之前，安能救於既危之後？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000101",
    "sentence": "百姓不堪其弊，必構禍難，殷鑒不遠，近在隋朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000102",
    "sentence": "臣願稍安撫之，無使生怨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000103",
    "sentence": "”上深納其言，於是節減廄馬數千匹，賜文瓘繒錦百段。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000104",
    "sentence": "咸亨三年 ，官名復舊，改授黃門侍郎，兼太子左庶子。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000105",
    "sentence": "俄遷大理卿，依舊知政事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000106",
    "sentence": "文瓘至官旬日，決遣疑事四百餘條，無不允當，自是人有抵罪者，皆無怨言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000107",
    "sentence": "文瓘常有疾，係囚相與齋禱，願其視事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000108",
    "sentence": "當時咸稱其執法平恕，以比戴胄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000109",
    "sentence": "上元二年 ，拜侍中，兼太子賓客。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000110",
    "sentence": "大理諸囚聞文瓘改官，一時慟哭，其感人心如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000111",
    "sentence": "文瓘性嚴正，諸司奏議，多所糾駁，高宗甚委之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000112",
    "sentence": "或時臥疾在家，朝廷每有大事，上必問諸宰臣曰：“與文瓘議未？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000113",
    "sentence": "”奏雲未者，則遣共籌之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000114",
    "sentence": "奏雲已議者，皆報可從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000115",
    "sentence": "其後，新羅外叛，高宗將發兵討除。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000116",
    "sentence": "時文瓘疾病在家，乃輿疾請見，奏曰：“比為吐蕃犯邊，兵屯寇境，新羅雖未即順，師不內侵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000117",
    "sentence": "若東西俱事征討，臣恐百姓不堪其弊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000118",
    "sentence": "請息兵修德以安百姓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000119",
    "sentence": "”高宗從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000120",
    "sentence": "儀鳳二年 卒，年七十三，贈幽州都督，諡曰懿。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "贈幽州",
        "label": "LOC",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000121",
    "sentence": "以其經事孝敬皇帝，特敕陪葬恭陵。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000122",
    "sentence": "四子：潛、沛、洽、涉。",
    "entities": [
      {
        "text": "沛",
        "label": "LOC",
        "start": 5,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000123",
    "sentence": "中宗時，潛官至魏州刺史，沛同州刺史，洽衛尉卿，涉殿中監。",
    "entities": [
      {
        "text": "潛官至魏州",
        "label": "LOC",
        "start": 4,
        "end": 9
      },
      {
        "text": "刺史",
