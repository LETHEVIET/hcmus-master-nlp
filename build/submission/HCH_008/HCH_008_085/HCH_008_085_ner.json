  {
    "sentence_id": "HCH_008_085_000002",
    "sentence": "唐臨",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000003",
    "sentence": "唐臨，京兆長安人，周內史瑾孫也。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000004",
    "sentence": "其先自北海徙關中。",
    "entities": [
      {
        "text": "其先自北海徙關",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000005",
    "sentence": "伯父令則，開皇末為左庶子，坐諂事太子勇誅死。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000006",
    "sentence": "臨少與兄皎俱有令名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000007",
    "sentence": "武德初，隱太子總兵東征，臨詣軍獻平王世充之策，太子引直典書坊，尋授右衛率府鎧曹參軍。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000008",
    "sentence": "宮殿廢，出為萬泉丞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000009",
    "sentence": "縣有輕囚十數人，會春暮時雨，臨白令請出之，令不許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000010",
    "sentence": "臨曰：“明公若有所疑，臨請自當其罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000011",
    "sentence": "”令因請假，臨召囚悉令歸家耕種，與之約，令歸係所。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000012",
    "sentence": "囚等皆感恩貸，至時畢集詣獄，臨因是知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000013",
    "sentence": "再遷侍御史，奉使嶺外，按交州刺史李道彥等申叩冤係三千餘人。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "按交州",
        "label": "LOC",
        "start": 11,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "李道彥",
        "label": "PER",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000014",
    "sentence": "累轉黃門侍郎，加銀青光祿大夫。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000015",
    "sentence": "儉薄寡欲，不治第宅，服用簡素，寬於待物。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000016",
    "sentence": "嚐欲吊喪，令家童自歸家取白衫，家僮誤將餘衣，懼未敢進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000017",
    "sentence": "臨察知之，使召謂曰：“今日氣逆，不宜哀泣，向取白衫，且止之也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000018",
    "sentence": "”又嚐令人煮藥，失製。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000019",
    "sentence": "潛知其故，謂曰：“陰暗不宜服藥，宜即棄之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000020",
    "sentence": "”竟不揚言其過，其寬恕如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000021",
    "sentence": "高宗即位，檢校吏部侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000022",
    "sentence": "其年，遷大理卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000023",
    "sentence": "高宗嚐問臨在獄係囚之數，臨對詔稱旨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000024",
    "sentence": "帝喜曰：“朕昔在東宮，卿已事朕，朕承大位，卿又居近職，以疇昔相委，故授卿此任。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000025",
    "sentence": "然為國之要，在於刑法，法急則人殘，法寬則失罪，務令折中，稱朕意焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000026",
    "sentence": "”高宗又嚐親錄死囚，前卿所斷者號叫稱冤，臨所入者獨無言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000027",
    "sentence": "帝怪問狀，囚曰：“罪實自犯，唐卿所斷，既非冤濫，所以絕意耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000028",
    "sentence": "” 帝歎息良久曰：“為獄者不當如此耶！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000029",
    "sentence": "”",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000030",
    "sentence": "永徽元年 ，為御史大夫。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000031",
    "sentence": "明年，華州刺史蕭齡之以前任廣州都督贓事發，製付群官集議。",
    "entities": [
      {
        "text": "華州",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000032",
    "sentence": "及議奏，帝怒，令於朝堂處置。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000033",
    "sentence": "臨奏曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000034",
    "sentence": "臣聞國家大典，在於賞刑，古先聖王，惟刑是釁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000035",
    "sentence": "《 虞書 》曰：“罪疑惟輕，功疑惟重，與其殺弗辜，寧失弗經。",
    "entities": [
      {
        "text": "《 虞書 》",
        "label": "TITLE",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000036",
    "sentence": "”《 周禮 》：“刑平國用中典，刑亂國用重典。",
    "entities": [
      {
        "text": "《 周禮 》",
        "label": "TITLE",
        "start": 1,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000037",
    "sentence": "”天下太平，應用堯、舜之典。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000038",
    "sentence": "比來有司多行重法，敘勳必須刻削，論罪務從重科，非是憎惡前人，止欲自為身計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000039",
    "sentence": "今議蕭齡之事，有輕有重，重者流死，輕者請除名。",
    "entities": [
      {
        "text": "蕭齡之",
        "label": "PER",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000040",
    "sentence": "以齡之受委大藩，贓罪狼籍，原情取事，死有餘辜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000041",
    "sentence": "然既遣詳議，終須近法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000042",
    "sentence": "竊惟議事群官，未盡識議刑本意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000043",
    "sentence": "律有八議，並依《周禮》舊文，矜其異於眾臣，所以特製議法。",
    "entities": [
      {
        "text": "《周禮》",
        "label": "TITLE",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000044",
    "sentence": "禮：王族刑於隱者，所以議親；刑不上大夫，所以議貴。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000045",
    "sentence": "知重其親貴，議欲緩刑，非為嫉其賢能，謀致深法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000046",
    "sentence": "今既許議，而加重刑，是與堯、舜相反，不可為萬代法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000047",
    "sentence": "高宗從其奏，齡之竟得流於嶺外。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000048",
    "sentence": "尋遷刑部尚書，加金紫光祿大夫，復曆兵部、度支、吏部三尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000049",
    "sentence": "顯慶四年 ，坐事，貶為潮州刺史。",
    "entities": [
      {
        "text": "顯慶四年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "貶為潮州",
        "label": "LOC",
        "start": 9,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000050",
    "sentence": "卒官，年六十。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000051",
    "sentence": "所撰《冥報記》二卷，大行於世。",
    "entities": [
      {
        "text": "《冥報記》",
        "label": "TITLE",
        "start": 2,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000052",
    "sentence": "兄皎，武德初為秦府記室，從太宗征討，專掌書檄，深見親待。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000053",
    "sentence": "貞觀中，累轉吏部侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000054",
    "sentence": "先是，選集無限，隨到補職，時漸太平，選人稍眾，皎始請以冬初一時大集，終季春而畢，至今行之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000055",
    "sentence": "曆遷益州長史。",
    "entities": [
      {
        "text": "曆遷益州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000056",
    "sentence": "卒，贈太常卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000057",
    "sentence": "子之奇，調露中為給事中，坐嚐為章懷太子僚屬徙邊。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000058",
    "sentence": "文明元年 ，起為括蒼令，與徐敬業作亂伏誅。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "徐敬業",
        "label": "PER",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000059",
    "sentence": "臨孫紹，博學，善《三禮》。",
    "entities": [
      {
        "text": "《三禮》",
        "label": "TITLE",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000060",
    "sentence": "神龍中為太常博士。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000061",
    "sentence": "景龍二年 ，韋庶人上言：“自妃、主及命婦、宮官，葬日請給鼓吹。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000062",
    "sentence": "”中宗特製許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000063",
    "sentence": "紹上疏諫曰：“竊聞鼓吹之樂，本為軍容。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000064",
    "sentence": "昔黃帝涿鹿有功，以為警衛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000065",
    "sentence": "故鼓曲有《靈夔吼》、《雕鶚爭》、《石墜崖》、《壯士怒》之類，自昔功臣備禮，適得用之。",
    "entities": [
      {
        "text": "《靈夔吼》",
        "label": "TITLE",
        "start": 5,
        "end": 10
      },
      {
        "text": "《雕鶚爭》",
        "label": "TITLE",
        "start": 11,
        "end": 16
      },
      {
        "text": "《石墜崖》",
        "label": "TITLE",
        "start": 17,
        "end": 22
      },
      {
        "text": "《壯士怒》",
        "label": "TITLE",
        "start": 23,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000066",
    "sentence": "丈夫有四方之功，以恩加寵錫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000067",
    "sentence": "假如郊天祀地，誠是重儀，惟有宮懸，本無案據。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000068",
    "sentence": "故知軍樂所備，尚不洽於神祇；鉦鼓之音，豈能接於閨閫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000069",
    "sentence": "準式，公主、王妃已下葬禮，惟有團扇、方扇、彩帷、錦鄣之色。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000070",
    "sentence": "加之鼓吹，曆代未聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000071",
    "sentence": "又準令，五品官婚葬，元無鼓吹，惟京官五品，得借四品鼓吹為儀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000072",
    "sentence": "令特給五品以上母妻，五品官則不當給限，便是班秩本因夫子，儀飾乃復過之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000073",
    "sentence": "事非倫次，難為定制，參詳義理，不可常行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000074",
    "sentence": "請停前敕，各依常典。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000075",
    "sentence": "”疏奏不納。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000076",
    "sentence": "紹尋遷左台侍御史，兼太常博士。",
    "entities": [
      {
