      },
      {
        "text": "沛同州",
        "label": "LOC",
        "start": 12,
        "end": 15
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000124",
    "sentence": "父子兄弟五人皆至三品官，時人謂之“萬石張家”。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000125",
    "sentence": "及韋溫等被誅之際，涉為亂兵所殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000126",
    "sentence": "兄文琮，貞觀中為持書侍御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000127",
    "sentence": "三遷毫州刺史，為政清簡，百姓安之。",
    "entities": [
      {
        "text": "三遷毫州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000128",
    "sentence": "永徽初，表獻《太宗文皇帝頌》，優製褒美，賜絹百匹，征拜戶部侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000129",
    "sentence": "從母弟房遺愛以罪貶授房州刺史，文琮作詩祖餞。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000130",
    "sentence": "及遺愛誅，坐是出為建州刺史。",
    "entities": [
      {
        "text": "坐是出為建州",
        "label": "LOC",
        "start": 5,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000131",
    "sentence": "州境素尚淫祀，不修社稷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000132",
    "sentence": "文琮下教書曰：“春秋二社，蓋本為農，惟獨此州，廢而不立。",
    "entities": [
      {
        "text": "惟獨此州",
        "label": "LOC",
        "start": 18,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000133",
    "sentence": "禮典既闕，風俗何觀？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000134",
    "sentence": "近年已來，田多不熟，抑不祭先農所致乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000135",
    "sentence": "神在於敬，何以邀福？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000136",
    "sentence": "”於是示其節限條製，百姓欣而行之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000137",
    "sentence": "尋卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000138",
    "sentence": "文集二十卷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000139",
    "sentence": "子戩，官至江州刺史，撰《喪儀纂要》七卷，行於時。",
    "entities": [
      {
        "text": "官至江州",
        "label": "LOC",
        "start": 3,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "《喪儀纂要》",
        "label": "TITLE",
        "start": 11,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000140",
    "sentence": "戩弟錫，則天時為鳳閣侍郎、同鳳閣鸞台平章事。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000141",
    "sentence": "先是，姊子李嶠知政事，錫拜官，而嶠罷相出為國子祭酒，舅甥相代為相，時人榮之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000142",
    "sentence": "錫與鄭杲俱知天官選事，坐贓，則天將斬之以徇，臨刑而特赦之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000143",
    "sentence": "中宗時，累遷工部尚書，兼修國史，尋令於東都留守。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000144",
    "sentence": "中宗崩，韋庶人臨朝，詔錫與刑部尚書裴談並同中書門下三品。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000145",
    "sentence": "旬日，出為絳州刺史。",
    "entities": [
      {
        "text": "出為絳州",
        "label": "LOC",
        "start": 3,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000146",
    "sentence": "累封平原郡公，以年老致仕而卒。",
    "entities": [
      {
        "text": "累封平原郡",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000147",
    "sentence": "文琮從父弟文收，隋內史舍人虔威子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000148",
    "sentence": "尤善音律，嚐覽蕭吉《樂譜》，以為未甚詳悉，更博采群言及曆代沿革，裁竹為十二律吹之，備盡旋宮之義。",
    "entities": [
      {
        "text": "《樂譜》",
        "label": "TITLE",
        "start": 9,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000149",
    "sentence": "時太宗將創製禮樂，召文收於太常，令與少卿祖孝孫參定雅樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000150",
    "sentence": "太樂有古鍾十二，近代惟用其七，餘有五，俗號啞鍾，莫能通者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000151",
    "sentence": "文收吹律調之，聲皆響徹，時人咸服其妙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000152",
    "sentence": "尋授協律郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000153",
    "sentence": "十一年，文收表請厘正太樂，上謂侍臣曰：“樂本緣人，人和則樂和。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000154",
    "sentence": "至如隋煬帝末年，天下喪亂，縱令改張音律，知其終不和諧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000155",
    "sentence": "若使四海無事，百姓安樂，音律自然調和，不藉更改。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000156",
    "sentence": "”竟不依其請。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000157",
    "sentence": "十四年，景雲見，河水清，文收采《朱雁天馬》之義，製《景雲河清》樂，名曰“燕樂”，奏之管弦，為樂之首，今元會第一奏者是也。",
    "entities": [
      {
        "text": "十四年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "《朱雁天馬》",
        "label": "TITLE",
        "start": 15,
        "end": 21
      },
      {
        "text": "《景雲河清》",
        "label": "TITLE",
        "start": 25,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000158",
    "sentence": "咸亨元年 ，遷太子率更令，卒官。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000159",
    "sentence": "撰《新樂書》十二卷。",
    "entities": [
      {
        "text": "《新樂書》",
        "label": "TITLE",
        "start": 1,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000160",
    "sentence": "徐有功",
    "entities": [
      {
        "text": "徐有功",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000161",
    "sentence": "徐有功，國子博士文遠孫也。",
    "entities": [
      {
        "text": "徐有功",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "博士",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000162",
    "sentence": "舉明經，累轉蒲州司法參軍，紹封東莞男。",
    "entities": [
      {
        "text": "累轉蒲州",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000163",
    "sentence": "為政寬仁，不行杖罰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000164",
    "sentence": "吏人感其恩信，遞相約曰：“若犯徐司法杖者，眾必斥罰之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000165",
    "sentence": "”由是人爭用命，終於代滿，不戮一人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000166",
    "sentence": "載初元年 ，累遷司刑丞。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000167",
    "sentence": "時酷吏周興、來俊臣、丘神勣、王弘義等構陷無辜，皆抵極法，公卿震恐，莫敢正言。",
    "entities": [
      {
        "text": "來俊臣",
        "label": "PER",
        "start": 6,
        "end": 9
      },
      {
        "text": "丘神勣",
        "label": "PER",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000168",
    "sentence": "有功獨存平恕，詔下大理者，有功皆議出之，前後濟活數十百家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000169",
    "sentence": "常於殿庭論奏曲直，則天厲色詰之，左右莫不悚栗，有功神色不撓，爭之彌切。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000170",
    "sentence": "尋轉秋官員外郎，轉郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000171",
    "sentence": "俄而鳳閣侍郎任知古、冬官尚書裴行本等七人被構陷當死，則天謂公卿曰：“古人以殺止殺，我今以恩止殺。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "裴行本",
        "label": "PER",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000172",
    "sentence": "就群公乞知古等，賜以再生，各授以官，佇申來效。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000173",
    "sentence": "”俊臣、張知默等又抗表請申大法，則天不許之。",
    "entities": [
      {
        "text": "張知默",
        "label": "PER",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000174",
    "sentence": "俊臣乃獨引行本，重驗前罪，奏曰：“行本潛行悖逆，告張知蹇與廬陵王反不實，罪當處斬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000175",
    "sentence": "”有功駁奏曰：“俊臣乖明主再生之賜，虧聖人恩信之道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000176",
    "sentence": "為臣雖當嫉惡，然事君必將順其美。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000177",
    "sentence": "”行本竟以免死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000178",
    "sentence": "道州刺史李仁褒及弟榆次令長沙，又為唐奉一所構，高宗末私議吉凶，謀復李氏，將誅之。",
    "entities": [
      {
        "text": "道州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "唐奉一",
        "label": "PER",
        "start": 17,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000179",
    "sentence": "有功又固爭之，不能得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000180",
    "sentence": "秋官侍郎周興奏有功曰：“臣聞兩漢故事，附下罔上者腰斬，麵欺者亦斬。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000181",
    "sentence": "又《禮》云：析言破律者殺。",
    "entities": [
      {
        "text": "《禮》",
        "label": "TITLE",
        "start": 1,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000182",
    "sentence": "有功故出反囚，罪當不赦，請推按其罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000183",
    "sentence": "”則天雖不許係問，然竟坐免官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000184",
    "sentence": "久之，起為左台侍御史，則天特褒異之。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000185",
    "sentence": "時遠近聞有功授職，皆欣然相賀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000186",
    "sentence": "有功嚐上疏論天官、秋官及朝堂三司理匭使愆失，其略曰：“陛下即位已來，海內職員一定，而天下選人漸多。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000187",
    "sentence": "掌選之曹用舍不平，補擬乖次，囑請公行，顏麵罔懼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000188",
    "sentence": "遂使囂謗滿路，怨讟盈朝，浸以為常，殊無愧憚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000189",
    "sentence": "又往屬唐朝季年，時多逆節，鞫訊結斷，刑獄至嚴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000190",
    "sentence": "革命以來，載祀遽積，餘風未殄，用法猶深。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000191",
    "sentence": "今推鞫者猶行酷法，妄劾斷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000192",
    "sentence": "臣即按驗，奏而劾之，獲其枉狀，請即付法斷罪，亦奪祿貶考，以慚其德。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000193",
    "sentence": "其三司受表及理匭申冤使，不速與奪，致令擁塞，有理不為申者，亦望準前彈奏，貶考奪祿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000194",
    "sentence": "臣昔處法司，緣蒙擢用，臣無以上答至造，願以執法酬恩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000195",
    "sentence": "無縱詭隨，不避強禦，猛噬鷙擊，是臣之分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000196",
    "sentence": "如蒙允納，請降敕施行，庶不越旬時，亦可以除殘革弊，刑措不用，天下幸甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000197",
    "sentence": "”",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000198",
    "sentence": "後潤州刺史竇孝諶妻龐氏為奴誣告，雲夜解祈福，則天令給事中薛季昶鞫之。",
    "entities": [
      {
        "text": "後潤州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "竇孝諶",
        "label": "PER",
        "start": 5,
        "end": 8
      },
      {
        "text": "薛季昶",
        "label": "PER",
        "start": 28,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000199",
    "sentence": "季昶鍛練成其罪，龐氏當坐斬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000200",
    "sentence": "有功獨明其無罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000201",
    "sentence": "而季昶等返陷有功黨援惡逆，奏付法，法司結刑當棄市。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000202",
    "sentence": "有功方視事，令史垂泣以告，有功曰：“豈吾獨死，而諸人長不死耶？",
    "entities": [
      {
        "text": "令史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000203",
    "sentence": "”乃徐起而歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000204",
    "sentence": "則天覽奏，召有功詰之曰：“卿比斷獄，失出何多？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000205",
    "sentence": "”對曰：“失出，臣下之小過；好生，聖人之大德。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000206",
    "sentence": "願陛下弘大德，則天下幸甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000207",
    "sentence": "”則天默然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000208",
    "sentence": "於是龐氏減死，流於嶺表，有功除名為庶人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000209",
    "sentence": "尋起為左司郎中，累遷司刑少卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000210",
    "sentence": "有功謂所親曰：“今身為大理，人命所懸，必不能順旨詭辭以求苟免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000211",
    "sentence": "”故前後為獄官，以諫奏枉誅者，三經斷死，而執誌不渝，酷吏由是少衰，時人比漢之於、張焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000212",
    "sentence": "或曰：“若獄官皆然，刑措何遠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000213",
    "sentence": "”久之，轉司仆少卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000214",
    "sentence": "長安二年 卒，年六十二，贈司刑卿。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000215",
    "sentence": "中宗即位，製曰：“忠正之臣，自昔攸尚；褒贈之典，舊章所重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000216",
    "sentence": "故贈大理卿徐有功，節操貞勁，器懷亮直，徇古人之誌業，實一代之賢良，司彼刑書，深存敬慎。",
    "entities": [
      {
        "text": "徐有功",
        "label": "PER",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000217",
    "sentence": "周興、來俊臣等性惟殘酷，務在誅夷，不順其情，立加誣害。",
    "entities": [
      {
        "text": "來俊臣",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000218",
    "sentence": "有功卓然守法，雖死不移，無屈撓之心，有忠烈之議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000219",
    "sentence": "當其執斷，並遇平反，定國、釋之，何以加此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000220",
    "sentence": "朕惟新庶政，追想前跡，其人既歿，其德可稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000221",
    "sentence": "追往贈終，慰茲泉壤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000222",
    "sentence": "可贈越州刺史，仍遣使就家吊祭，賜物百段，授一子官。",
    "entities": [
      {
        "text": "可贈越州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000223",
    "sentence": "”今上踐祚，竇孝諶之子希瑊等請以身之官爵讓有功子惀，以報舊恩。",
    "entities": [
      {
        "text": "竇孝諶",
        "label": "PER",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000224",
    "sentence": "惀由是自太子司議郎、恭陵令累遷申王府司馬，卒。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000225",
    "sentence": "【論贊】",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000226",
    "sentence": "史臣曰：文法，理具之大者，故舜命皋陶為士，昌言誡敕，勤亦至焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000227",
    "sentence": "蓋人命所懸，一失其平，冤不可復，聖王所以疚心也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000228",
    "sentence": "如臨之守法，文瓘之議刑，時屬哲王，可以理奪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000229",
    "sentence": "當賊後遷鼎之際，酷吏羅織之辰，徐有功獨抗群邪，持平不撓，此所以為難也。",
    "entities": [
      {
        "text": "徐有功",
        "label": "PER",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_085_000230",
    "sentence": "比釋之、定國，徐又過之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000231",
    "sentence": "希瑊讓爵酬恩，可知遺愛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000232",
    "sentence": "讚曰：聽訟惟明，持法惟平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000233",
    "sentence": "二者或爽，人何以生？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000234",
    "sentence": "猗歟徐公，獬豸之精。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000235",
    "sentence": "世皆紛濁，不改吾清。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_085_000236",
    "sentence": "本五代作品在全世界都属于 公有领域 ，因为作者逝世已经遠遠超过100年。",
    "entities": [
      {
        "text": "100年",
        "label": "TME",
        "start": 31,
        "end": 35
      }
    ]
  }
]
