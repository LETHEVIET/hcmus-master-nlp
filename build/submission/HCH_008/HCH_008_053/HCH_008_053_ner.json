      }
    ]
  },
  {
    "sentence_id": "HCH_008_053_000249",
    "sentence": "及世充軍至，密候騎不時覺，比將出戰，世充軍已濟矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_053_000250",
    "sentence": "密自度不能支，引騎而遁，徑赴武牢，元真竟以城降於世充。",
    "entities": [
      {
        "text": "元真竟以城",
        "label": "LOC",
