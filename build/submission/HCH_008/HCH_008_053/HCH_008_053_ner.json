      }
    ]
  },
  {
    "sentence_id": "HCH_008_053_000231",
    "sentence": "密將與化及相抗，恐前後受敵，因卑辭以報謝焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_053_000232",
    "sentence": "化及至黎陽，與密相遇，密知其軍少食，利在急戰，故不與交鋒，又遏其歸路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_053_000233",
    "sentence": "密遣徐世勣守倉城，化及攻之不能下。",
    "entities": [
      {
        "text": "遣徐世勣守倉城",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_053_000234",
    "sentence": "密知化及糧且盡，因偽與和，以弊其眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_053_000235",
    "sentence": "化及弗之悟，大喜，恣其兵食，冀密饋之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_053_000236",
    "sentence": "後知其計，化及怒，與密大戰于衛州之童山下，密為流矢所中，頓於汲縣。",
    "entities": [
      {
