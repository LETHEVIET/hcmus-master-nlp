        "end": 21
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000051",
    "sentence": "累遷給事中、兵部侍郎、大理卿。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000052",
    "sentence": "性深厚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000053",
    "sentence": "誌尚簡淡，在職不務求名，因循而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000054",
    "sentence": "大歷初，叛臣周智光伏誅，詔選循良為近輔，以括為同州刺史。",
    "entities": [
      {
        "text": "周智光",
        "label": "PER",
        "start": 6,
        "end": 9
      },
      {
        "text": "以括為同州",
        "label": "LOC",
        "start": 20,
        "end": 25
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000055",
    "sentence": "歲餘，入為御史大夫。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000056",
    "sentence": "遲重推誠於下，未嘗以私害公，士頗稱焉；而從容養望，不舉綱紀，士亦以此少之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000057",
    "sentence": "大歷六年三月卒。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000058",
    "sentence": "韋元甫",
    "entities": [
      {
        "text": "韋元甫",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000059",
    "sentence": "韋元甫，少修謹，敏於學行。",
    "entities": [
      {
        "text": "韋元甫",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000060",
    "sentence": "初任滑州白馬尉，以吏術知名。",
    "entities": [
      {
        "text": "初任滑州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000061",
    "sentence": "本道采訪使韋涉深器之，奏充支使，與同幕判官員錫齊名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000062",
    "sentence": "元甫精於簡牘，錫詳於訊覆，涉推誠待之，時謂「員推韋狀。」元甫有器局，所蒞有聲，累遷蘇州刺史、浙江西道都團練觀察等使。",
    "entities": [
      {
        "text": "累遷蘇州",
        "label": "LOC",
        "start": 39,
        "end": 43
      },
      {
        "text": "刺史",
