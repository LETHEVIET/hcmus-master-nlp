        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000065",
    "sentence": "在揚州三年，政尚不擾，事亦粗理。",
    "entities": [
      {
        "text": "在揚州",
        "label": "LOC",
        "start": 0,
        "end": 3
