      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000133",
    "sentence": "承亦使腹心臧叔雅往來許、蔡，厚結希烈腹心周曾、王玢、姚憺等。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000134",
    "sentence": "及曾等謀殺希烈，以眾歸朝，多承首建謀也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000135",
    "sentence": "累賜密詔褒美之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000136",
    "sentence": "承尋改檢校工部尚書，兼潭州刺史、湖南都團練觀察使。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "兼潭州",
