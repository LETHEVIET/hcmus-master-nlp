        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000137",
    "sentence": "建中四年七月，卒於位，年六十二，贈吏部尚書。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
