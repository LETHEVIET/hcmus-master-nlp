[
  {
    "sentence_id": "HCH_008_115_000001",
    "sentence": "崔器",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000002",
    "sentence": "崔器，深州安平人也。",
    "entities": [
      {
        "text": "深州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000003",
    "sentence": "曾祖恭禮，狀貌豐碩，飲酒過鬥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000004",
    "sentence": "貞觀中，拜駙馬都尉，尚神堯館陶公主。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000005",
    "sentence": "父肅然，平陰丞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000006",
    "sentence": "器有吏才，性介而少通，舉明經，歷官清謹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000007",
    "sentence": "天寶六載，為萬年尉，逾月拜監察御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000008",
    "sentence": "中丞宋渾為東畿采訪使，引器為判官；渾坐贓流貶嶺南，器亦隨貶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000009",
    "sentence": "十三年，量移京兆府司錄，轉都官員外郎，出為奉先令。",
    "entities": [
      {
        "text": "十三年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000010",
    "sentence": "逆胡陷西京．器沒於賊，仍守奉先。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000011",
    "sentence": "居無何，屬賊黨同羅叛賊，長安守將安守忠、張通儒並亡匿。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 12,
        "end": 14
      },
      {
        "text": "張通儒",
        "label": "PER",
        "start": 20,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000012",
    "sentence": "又渭上義兵起，一朝聚徒數萬，器懼，所受賊文牒符敕，一時焚之，榜召義師，欲應渭上軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000013",
    "sentence": "及渭上軍破，賊將崔乾祐先鎮蒲、同，使麾下騎三十人捉器，器遂北走靈武。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000014",
    "sentence": "器素與呂諲善，諲引為御史中丞、兼戶部侍郎。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000015",
    "sentence": "從肅宗至鳳翔，加禮儀使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000016",
    "sentence": "克復二京，為三司使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000017",
    "sentence": "器草儀註，駕入城，令陷賊官立於含元殿前，露頭跣足，撫膺頓首請罪，以刀杖環衛，令扈從群官宰臣已下視之。",
    "entities": [
      {
        "text": "駕入城",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000018",
    "sentence": "及收東京，令陳希烈已下數百人如西京之儀。",
    "entities": [
      {
        "text": "陳希烈",
        "label": "PER",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000019",
    "sentence": "器性陰刻樂禍，殘忍寡恩，希旨奏陷賊官準律並合處死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000020",
    "sentence": "肅宗將從其議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000021",
    "sentence": "三司使、梁國公李峴執奏，固言不可，乃六等定罪，多所原宥，唯陳希烈、達奚珣斬於獨柳樹下。",
    "entities": [
      {
        "text": "梁國",
        "label": "ORG",
        "start": 4,
        "end": 6
      },
      {
        "text": "陳希烈",
        "label": "PER",
        "start": 29,
        "end": 32
      },
      {
        "text": "達奚珣",
        "label": "PER",
        "start": 33,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000022",
    "sentence": "後蕭華自相州賊中仕賊官歸闕，奏云：「賊中仕官等重為安慶緒所驅，脅至相州，初聞廣平王奉宣恩命，釋放陳希烈已下，皆相顧曰：『我等國家見待如此，悔恨何及。』及聞崔器議刑太重，眾心復搖。」肅宗曰：「朕幾為崔器所誤。」",
    "entities": [
      {
        "text": "後蕭華自相州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "安慶緒",
        "label": "PER",
        "start": 25,
        "end": 28
      },
      {
        "text": "脅至相州",
        "label": "LOC",
        "start": 31,
        "end": 35
      },
      {
        "text": "陳希烈",
        "label": "PER",
        "start": 48,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000023",
    "sentence": "呂諲驟薦器為吏部侍郎、御史大夫。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000024",
    "sentence": "上元元年七月，器病腳腫，月余疾亟，瞑目則見達奚珣，叩頭曰：「大尹不自由。」左右問之，器答曰：「達奚大尹嘗訴冤於我，我不之許。」如是三日而器卒。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "達奚珣",
        "label": "PER",
        "start": 21,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000025",
    "sentence": "趙國珍",
    "entities": [
      {
        "text": "趙國珍",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000026",
    "sentence": "趙國珍，牂柯之苗裔也。",
    "entities": [
      {
        "text": "趙國珍",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000027",
    "sentence": "天寶中，以軍功累遷黔府都督，兼本管經略等使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000028",
    "sentence": "時南蠻閣羅鳳叛，宰臣楊國忠兼劍南節度，遙制其務，屢喪師徒。",
    "entities": [
      {
        "text": "楊國忠",
        "label": "PER",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000029",
    "sentence": "中書舍人張漸薦國珍有武略，習知南方地形，國忠遂奏用之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000030",
    "sentence": "在五溪凡十余年，中原興師，唯黔中封境無虞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000031",
    "sentence": "代宗踐祚，特嘉之，召拜工部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000032",
    "sentence": "大歷三年九月，以疾終，贈太子太傅。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000033",
    "sentence": "崔瓘",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000034",
    "sentence": "崔瓘，博陵人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000035",
    "sentence": "以士行聞，蒞職清謹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000036",
    "sentence": "累遷至澧州刺史，下車削去煩苛，以安人為務。",
    "entities": [
      {
        "text": "累遷至澧州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000037",
    "sentence": "居二年，風化大行，流亡繈負而至，增戶數萬。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000038",
    "sentence": "有司以聞，優詔特加五階，至銀青光祿大夫，以甄能政。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000039",
    "sentence": "遷潭州刺史、兼御史中丞，充湖南都團練觀察處置使。",
    "entities": [
      {
        "text": "遷潭州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000040",
    "sentence": "瓘到官，政在簡肅，恭守禮法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000041",
    "sentence": "將吏自經時艱，久不奉法，多不便之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000042",
    "sentence": "大歷五年四月，會月給糧儲，兵馬使臧玠與判官達奚覯忿爭，覯曰：「今幸無事。」玠曰：「有事何逃？」厲色而去。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000043",
    "sentence": "是夜，玠遂構亂，犯州城，以殺達奚覯為名。",
    "entities": [
      {
        "text": "犯州城",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000044",
    "sentence": "瓘惶遽走，逢玠兵至，遂遇害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000045",
    "sentence": "代宗聞其事，悼惜久之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000046",
    "sentence": "敬括",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000047",
    "sentence": "敬括，河東人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000048",
    "sentence": "少以文詞稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_115_000049",
    "sentence": "鄉舉進士，又應制登科，再遷右拾遺、內供奉、殿中侍御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_115_000050",
    "sentence": "天寶末，宰臣楊國忠出不附己者，括以例為果州刺史。",
    "entities": [
      {
        "text": "楊國忠",
        "label": "PER",
        "start": 6,
        "end": 9
      },
      {
