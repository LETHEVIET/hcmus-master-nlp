        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_137_000010",
    "sentence": "安祿山反，出為襄陽太守、本郡防禦使，賜以金紫之服。",
    "entities": [
      {
        "text": "太守",
