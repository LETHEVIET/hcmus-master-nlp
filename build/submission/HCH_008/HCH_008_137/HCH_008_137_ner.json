      }
    ]
  },
  {
    "sentence_id": "HCH_008_137_000038",
    "sentence": "南史以官閑冗，放吏歸，納其紙筆錢六十余千。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_137_000039",
    "sentence": "刺史姚驥劾奏南史，以為贓，又劾南史買鉛燒黃丹。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
