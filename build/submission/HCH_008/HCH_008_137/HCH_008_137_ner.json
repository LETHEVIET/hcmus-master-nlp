      }
    ]
  },
  {
    "sentence_id": "HCH_008_137_000051",
    "sentence": "又常敘少遊勛績，擬之桓、文，大招物論。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_137_000052",
    "sentence": "貞元五年，貶信州刺史，到州尋卒。",
