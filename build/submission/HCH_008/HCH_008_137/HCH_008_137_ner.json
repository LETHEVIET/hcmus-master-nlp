  {
    "sentence_id": "HCH_008_137_000191",
    "sentence": "李益，肅宗朝宰相揆之族子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_137_000192",
    "sentence": "登進士第，長為歌詩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_137_000193",
    "sentence": "貞元末，與宗人李賀齊名。",
