      }
    ]
  },
  {
    "sentence_id": "HCH_008_137_000011",
    "sentence": "肅宗即位，召拜中書舍人，時天下事殷，詔令多出于浩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_137_000012",
    "sentence": "浩屬詞贍給，又工楷隸，肅宗悅其能，加兼尚書左丞。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_137_000013",
    "sentence": "玄宗傳位誥冊，皆浩為之，參兩宮文翰，寵遇罕與為比。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_137_000014",
    "sentence": "除國子祭酒，坐事貶廬州長史。",
    "entities": [
      {
