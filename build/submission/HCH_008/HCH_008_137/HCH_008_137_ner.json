      }
    ]
  },
  {
    "sentence_id": "HCH_008_137_000045",
    "sentence": "涉學，善屬文，少師事詞人蕭穎士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_137_000046",
    "sentence": "天寶末，舉進士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_137_000047",
    "sentence": "大歷中，為淮南節度使陳少遊掌書記，征拜起居郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_137_000048",
