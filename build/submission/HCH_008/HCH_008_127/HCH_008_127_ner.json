[
  {
    "sentence_id": "HCH_008_127_000001",
    "sentence": "姚令言",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000002",
    "sentence": "姚令言，河中人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000003",
    "sentence": "少應募，起於卒伍，隸涇原節度馬璘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000004",
    "sentence": "以戰功累授金吾大將軍同正，為衙前兵馬使，改試太常卿、兼御史中丞。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 7,
        "end": 10
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000005",
    "sentence": "建中元年，孟暤為涇原節度留後，自以文吏進身，不樂軍旅，頻表薦令言謹肅，堪任將帥。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000006",
    "sentence": "暤尋歸朝廷，遂拜令言為四鎮北庭行營涇原節度使、涇州刺史、兼御史大夫。",
    "entities": [
      {
        "text": "遂拜令言為四鎮",
        "label": "LOC",
        "start": 6,
        "end": 13
      },
      {
        "text": "涇州",
        "label": "LOC",
        "start": 23,
        "end": 25
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 25,
        "end": 27
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 29,
        "end": 31
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000007",
    "sentence": "建中四年，李希烈叛，寇陷汝州，詔哥舒曜率師攻之，營於襄城。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "寇陷汝州",
        "label": "LOC",
        "start": 10,
        "end": 14
      },
      {
        "text": "營於襄城",
        "label": "LOC",
        "start": 24,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000008",
    "sentence": "希烈兵數萬圍襄城，勢甚危急。",
    "entities": [
      {
        "text": "烈兵數萬圍襄城",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000009",
    "sentence": "十月，詔令言率本鎮兵五萬赴援。",
    "entities": [
      {
        "text": "詔令言率本鎮",
        "label": "LOC",
        "start": 3,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000010",
    "sentence": "涇師離鎮，多攜子弟而來，望至京師以獲厚賞，及師上路，一無所賜。",
    "entities": [
      {
        "text": "涇師離鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000011",
    "sentence": "時詔京兆尹王翃犒軍士，唯糲食菜啖而已，軍士覆而不顧，皆憤怒，揚言曰：「吾輩棄父母妻子，將死於難，而食不得飽，安能以草命捍白刃耶！國家瓊林、大盈，寶貨堆積，不取此以自活，何往耶？」行次滻水，乃返戈，大呼鼓噪而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000012",
    "sentence": "令言曰：「比約東都有厚賞，兒郎勿草草，此非求活之良圖也。」眾不聽，以戈環令言請退，令言急奏之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000013",
    "sentence": "上恐，令內庫出繒彩二十車馳賜之，軍聲浩浩，令言不能戢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000014",
    "sentence": "街市居人狼狽走竄，亂兵呼曰：「勿走，不稅汝間架矣！」德宗令普王與學士姜公輔往撫勞之，才出內門，賊已斬關，陣於丹鳳樓下。",
    "entities": [
      {
        "text": "賊已斬關",
        "label": "LOC",
        "start": 47,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000015",
    "sentence": "是日，德宗倉卒出幸，賊縱入府庫輦運，極力而止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000016",
    "sentence": "時太尉朱泚罷鎮居晉昌里第，是夜，叛卒謀曰：「朱太尉久囚於宅，若迎為主，大事濟矣。」泚嘗節制涇州，眾知其失權，廢居怏怏，又幸泚寬和，乃請令言率騎迎泚於晉昌里。",
    "entities": [
      {
        "text": "時太尉朱泚罷鎮",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "泚嘗節制涇州",
        "label": "LOC",
        "start": 41,
        "end": 47
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000017",
    "sentence": "泚初遲疑，以食飼之，徐觀眾意，既而諸校齊至，乃自第張炬火入居含元殿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000018",
    "sentence": "既僭號，乃以令言為侍中，與源休同知賊政事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000019",
    "sentence": "既以身先逆亂，頗盡心於賊，害宗室，圍奉天，皆令言為首帥也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000020",
    "sentence": "群兇宴樂，既醉，令言與源休論功，令言自比蕭何，源休曰：「帷幄之謀，成秦之業，無出予之右者。吾比蕭何無讓，子當曹參可矣。」時朝士在賊廷者，聞之皆笑，謂源休為火迫酇侯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000021",
    "sentence": "朱泚敗，令言與張廷芝尚有眾萬人，從泚將入吐蕃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000022",
    "sentence": "至涇州，欲投田希鑒，希鑒偽致禮誘之，與泚俱斬首來獻。",
    "entities": [
      {
        "text": "至涇州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000023",
    "sentence": "張光晟",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000024",
    "sentence": "張光晟，京兆盩厔人，起於行間。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000025",
    "sentence": "天寶末，哥舒翰兵敗潼關，大將王思禮所乘馬中流矢而斃，光晟時在騎卒之中，因下，以馬授思禮。",
    "entities": [
      {
        "text": "哥舒翰兵敗潼關",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000026",
    "sentence": "思禮問其姓名，不告而退，思禮陰記其形貌，常使人密求之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000027",
    "sentence": "無何，思禮為河東節度使，其偏將辛雲京為代州刺史，屢為將校譖毀，思禮怒焉。",
    "entities": [
      {
        "text": "將辛雲京為代州",
        "label": "LOC",
        "start": 14,
        "end": 21
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000028",
    "sentence": "雲京惶懼，不知所出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000029",
    "sentence": "光晟時隸雲京麾下，因間進曰：「光晟素有德於王司空，比不言諸，恥以舊恩受賞。今使君憂迫，光晟請奉命一見司空，則使君之難可解。」雲京然其計，即令之太原。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000030",
    "sentence": "乃謁思禮，未及言舊，思禮識之，遽曰：「爾豈非吾故人乎？何相見之晚也！」光晟遂陳潼關之事，思禮大喜，因執其手感泣曰：「吾有今日，子之力也。求子頗久，竟此相遇，何慰如之？」命同榻而坐，結為兄弟。",
    "entities": [
      {
        "text": "光晟遂陳潼關",
        "label": "LOC",
        "start": 35,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000031",
    "sentence": "光晟遂述雲京之屈，思禮曰：「雲京比涉謗言，過亦不細，今為故人，特舍之矣。」即日擢光晟為兵馬使，賚田宅、縑帛甚厚，累奏特進，試太常少卿，委以心腹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000032",
    "sentence": "及雲京為河東節度使，又奏光晟為代州刺史。",
    "entities": [
      {
        "text": "又奏光晟為代州",
        "label": "LOC",
        "start": 10,
        "end": 17
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000033",
    "sentence": "大曆末，遷單于都護、兼御史中丞、振武軍使。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000034",
    "sentence": "代宗密謂之曰：「北蕃縱橫日久，當思所禦之計。」光晟既受命，至鎮，威令甚行。",
    "entities": [
      {
        "text": "至鎮",
        "label": "LOC",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000035",
    "sentence": "建中元年，回紇突董梅錄領眾並雜種胡等自京師還國，輿載金帛，相屬於道。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000036",
    "sentence": "光晟訝其裝橐頗多，潛令驛吏以長錐刺之，則皆輦歸所誘致京師婦人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000037",
    "sentence": "遂給突董及所領徒悉令赴宴，酒酣，光晟伏甲盡拘而殺之，死者千餘人，唯留二胡歸國復命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000038",
    "sentence": "遂部其婦人，給糧還京，收其金帛，賞賚軍士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000039",
    "sentence": "後回紇遣使來訴，上不欲甚阻蕃情，徵拜右金吾將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000040",
    "sentence": "回紇猶怨懟不已，又降為睦王傅，尋改太僕卿，負才怏怏不得志。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000041",
    "sentence": "賊泚僭逆，署光晟偽節度使兼宰相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000042",
    "sentence": "及泚眾頻敗，遂擇精兵五千配光晟，營於九曲，去東渭橋凡十餘里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000043",
    "sentence": "光晟潛使於李晟，有歸順之意。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000044",
    "sentence": "晟進兵入苑，光晟勸賊泚宜速西奔，光晟以數千人送泚出城，因率眾回降於晟。",
    "entities": [
      {
        "text": "數千人送泚出城",
        "label": "LOC",
        "start": 19,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000045",
    "sentence": "晟以其誠款，又愛其材，欲奏用之，俾令歸私第，表請特減其罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000046",
    "sentence": "每大宴會，皆令就坐，華州節度使駱元光詬之曰：「吾不能與反虜同席！」拂衣還營。",
    "entities": [
      {
        "text": "華州",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000047",
    "sentence": "晟不得已，拘之私第，後有詔言其狀跡不可原，乃斬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000048",
    "sentence": "源休",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000049",
    "sentence": "源休，相州臨漳人，京兆尹光輿之子也。",
    "entities": [
      {
        "text": "相州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000050",
    "sentence": "休以幹局，累授監察御史、殿中侍御史、青苗使判官，遷虞部員外郎，出潭州刺史，入為主客郎中，遷給事中、御史中丞、左庶子。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "出潭州",
        "label": "LOC",
        "start": 31,
        "end": 34
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 34,
        "end": 36
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 49,
        "end": 51
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000051",
    "sentence": "其妻即吏部侍郎王翊女也。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000052",
    "sentence": "因小忿而離，妻族上訴，下御史臺驗理，休遲留不答款狀，除名，配流溱州。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "配流溱州",
        "label": "LOC",
        "start": 29,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000053",
    "sentence": "久之，移岳州。",
    "entities": [
      {
        "text": "移岳州",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000054",
    "sentence": "建中初，楊炎執政，以京兆尹嚴郢威名稍著，心欲傾之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000055",
    "sentence": "郢，即王翊甥婿也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000056",
    "sentence": "休與王氏離絕之時，炎風聞休、郢有隙，遂擢休自流人為京兆少尹，俾令伺郢過失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000057",
    "sentence": "休既職久，與郢親善，炎怒之，奏令以本官兼御史中丞，奉使回紇。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000058",
    "sentence": "休至振武，軍使張光晟已殺回紇突董等，上初欲遂絕其使，令休還，待命於太原。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000059",
    "sentence": "久之方遣，仍令休歸其突董、翳密施大小梅錄等四屍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000060",
    "sentence": "突董者，即武義可汗之叔父也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000061",
    "sentence": "屍既至，可汗令宰臣已下具彩服車馬來迎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000062",
    "sentence": "其宰相頡於思迦坐大帳，立休等於帳外雪中，詰殺突董等故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000063",
    "sentence": "休曰：「突董等自與張光晟忿鬥而死，非天子命也。」又問：「使者背唐國，負罪當死，不能自戮耶？不然，何假手於我殺之也？」凡將殺者數矣，言頗悖慢，乃引去，供餼甚薄，留之五十餘日，乃得還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000064",
    "sentence": "可汗使謂休曰：「我國人皆欲殺汝，唯我不然。汝國已殺突董等，吾又殺汝，猶以血洗血，汙益甚爾。吾今以水洗血，不亦善乎！所欠吾馬直絹一百八十萬疋，當速歸之。」遣散支將軍康赤心等隨休來朝，休竟不得見其可汗。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 79,
        "end": 81
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000065",
    "sentence": "尋遣赤心等歸，與之帛十萬疋、金銀十萬兩，償其馬直。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000066",
    "sentence": "休履危而還，宰相盧杞又恐復命之日以口辯結恩，將至太原，遽奏為光祿卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000067",
    "sentence": "休以其還使賞薄，居常怨望。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000068",
    "sentence": "會涇原兵叛，立朱泚為主。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000069",
    "sentence": "初但稱太尉，朝官謁泚者，悉勸奏迎鑾駕，既不合泚意而退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000070",
    "sentence": "及休至，遂屏人移時，言多悖逆，盛陳成敗，稱述符命，勸令僭號。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000071",
    "sentence": "泚悅其言，以休為宰相，判度支。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000072",
    "sentence": "休遂為謀主，至於兵食軍資，遷除補擬，內外咨謀，一稟休畫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000073",
    "sentence": "故時人云：「源休之逆，甚於朱泚。」朝廷大臣之奔竄不獲者，多為休所誘致，以至戮辱，職休而為，蓋非一焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000074",
    "sentence": "又勸泚鋤翦宗室，以絕人望，命萬年縣賊曹尉楊偡專其斷決，諸王子孫遇害不可勝數。",
    "entities": [
      {
        "text": "命萬年縣",
        "label": "LOC",
        "start": 13,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000075",
    "sentence": "泚敗走，休隨至寧州。",
    "entities": [
      {
        "text": "休隨至寧州",
        "label": "LOC",
        "start": 4,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000076",
    "sentence": "泚死，休走鳳翔，為其部曲所殺，傳首來獻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000077",
    "sentence": "休三子並斬於東市，籍沒其家。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000078",
    "sentence": "喬琳",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000079",
    "sentence": "喬琳，太原人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000080",
    "sentence": "少孤貧志學，以文詞稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000081",
    "sentence": "天寶初，舉進士，補成武尉，累授興平尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000082",
    "sentence": "朔方節度郭子儀辟為掌書記，尋拜監察御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000083",
    "sentence": "琳倜儻疏誕，好談諧，侮謔僚列，頗無禮檢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000084",
    "sentence": "同院御史畢耀初與琳嘲誚往復，因成釁隙，遂以公事互相告訴，坐貶巴州員外司戶。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "坐貶巴州",
        "label": "LOC",
        "start": 28,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000085",
    "sentence": "遂起為南郭令，改殿中侍御史，充山南節度張獻誠行軍司馬。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000086",
    "sentence": "使罷，為劍南東川節度鮮于叔明判官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000087",
    "sentence": "改檢校駕部郎中、果綿遂三州刺史、兼御史中丞。",
    "entities": [
      {
        "text": "果綿遂三州",
        "label": "LOC",
        "start": 8,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000088",
    "sentence": "入為大理少卿、國子祭酒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000089",
    "sentence": "出為懷州刺史。",
    "entities": [
      {
        "text": "出為懷州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000090",
    "sentence": "琳素與張涉友善，上在春宮，涉嘗為侍讀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000091",
    "sentence": "及嗣位，多以政事詢訪於涉，盛稱琳識度材略，堪備大用，因拜御史大夫、平章事。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 28,
        "end": 30
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000092",
    "sentence": "琳本粗材，又年高有耳疾，上每顧問，對答失次，論奏不合時。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000093",
    "sentence": "幸居相位凡八十餘日，除工部尚書，罷知政事，尋加迎皇太后副使。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000094",
    "sentence": "朱泚之亂，扈從至奉天，轉吏部尚書，遷太子少師。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000095",
    "sentence": "再幸梁、洋，從至盩厔，托以馬乏遲留，上以琳舊老，心敬重之，慰諭頗至，以御馬一匹給焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000096",
    "sentence": "又懇辭以老疾不堪山阻登頓，上悵然，賜之所執策曰：「勉為良圖，與卿決矣。」後數日，乃削髮為僧，止仙遊寺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000097",
    "sentence": "賊泚聞之，遂令數十騎追至京城，俾為偽吏部尚書。",
    "entities": [
      {
        "text": "數十騎追至京城",
        "label": "LOC",
        "start": 7,
        "end": 14
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000098",
    "sentence": "令源休被公服，饋肉食，琳雖辭讓，而僧言求施。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000099",
    "sentence": "琳掌賊中吏部，選人前請曰：「所註某官不穩便。」琳謂之曰：「足下謂此選竟穩便乎？」及官軍收京師，當處極刑，時琳已七十餘，李晟憫其衰老，表請減死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000100",
    "sentence": "上以其累經重任，頓虧臣節，自受逆命，頗聞譏諧悖慢之言，背義負恩，固不可舍，命斬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000101",
    "sentence": "臨刑嘆曰：「喬琳以七月七日生，亦以此日死，豈非命歟！」",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000102",
    "sentence": "張涉",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000103",
    "sentence": "張涉者，蒲州人，家世儒者。",
    "entities": [
      {
        "text": "蒲州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000104",
    "sentence": "涉依國學為諸生講說，稍遷國子博士，亦能為文，嘗請有司日試萬言，時呼張萬言。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000105",
    "sentence": "德宗在春宮，受經於涉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000106",
    "sentence": "及即位之夕，召涉入宮，訪以庶政，大小之事皆咨之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000107",
    "sentence": "翌日，詔居翰林，恩禮甚厚，親重莫比。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000108",
    "sentence": "自博士遷散騎常侍。",
    "entities": [
      {
        "text": "博士",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000109",
    "sentence": "上方屬意宰輔，唯賢是擇，故求人於不次之地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000110",
    "sentence": "涉舉懷州刺史喬琳為相，上授之不疑，天下聞之者皆愕然。",
    "entities": [
      {
        "text": "涉舉懷州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000111",
    "sentence": "數月，琳以不稱職罷，上由是疏涉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000112",
    "sentence": "俄受前湖南都團練使辛京杲贓事發，詔曰：「尊師之道，禮有所加；議故之法，恩有所掩。張涉賄賂交通，頗駭時聽，常所親重，良深嘆惜。宜放歸田里。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000113",
    "sentence": "蔣鎮",
    "entities": [
      {
        "text": "蔣鎮",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000114",
    "sentence": "蔣鎮，常州義興人，尚書左丞洌之子也。",
    "entities": [
      {
        "text": "蔣鎮",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "常州",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000115",
    "sentence": "與兄鍊並以文學進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000116",
    "sentence": "天寶末舉賢良，累授左拾遺、司封員外郎，轉諫議大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000117",
    "sentence": "時戶部侍郎、判度支韓滉上言：「河中鹽池生瑞鹽，實土德之上瑞。」上以秋霖稍多，水潦為患，不宜生瑞，命鎮馳驛檢行之。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "命鎮",
        "label": "LOC",
        "start": 48,
        "end": 50
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000118",
    "sentence": "鎮奏與滉同，仍上表賀，請宣付史館，並請置神祠，錫其嘉號寶應靈慶池。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000119",
    "sentence": "地霖潦彌月，壞居人廬舍非一，鹽池為潦水所入，其味多苦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000120",
    "sentence": "韓滉慮鹽戶減稅，詐奏雨不壞池，池生瑞鹽，鎮庇之飾詐，識者醜之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000121",
    "sentence": "轉給事中、工部侍郎，以簡儉稱於時。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000122",
    "sentence": "其妹婿源溥，即休之弟也，以姻媾之故，與休交好。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000123",
    "sentence": "涇師之叛，鎮潛竄，夜至鄠縣西，馬躓墮溝澗中，傷足不能進。",
    "entities": [
      {
        "text": "夜至鄠縣",
        "label": "LOC",
        "start": 9,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000124",
    "sentence": "時兄鍊已與源休相率受賊偽官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000125",
    "sentence": "鎮僕人有逃歸投鍊，云鎮病足在鄠。",
    "entities": [
      {
        "text": "云鎮",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000126",
    "sentence": "鍊與源休聞之大喜，遂言於賊泚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000127",
    "sentence": "泚素慕鎮清名，即令騎二百求之鄠縣西。",
    "entities": [
      {
        "text": "泚素慕鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "騎二百求之鄠縣",
        "label": "LOC",
        "start": 9,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000128",
    "sentence": "明日，擁鎮而至，署為偽宰相。",
    "entities": [
      {
        "text": "擁鎮",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000129",
    "sentence": "既知不免，每憂沮，常懷刃將自裁，多為兄鍊所救而罷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000130",
    "sentence": "數日後，復謀竄匿，竟以性懦畏怯，計終不果。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000131",
    "sentence": "然源休與泚頻議，欲逼脅潛藏衣冠，大加殺戮，鎮輒力爭救，獲全者甚眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000132",
    "sentence": "至是，與兄鍊等並授偽職，斬於東市西北街。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000133",
    "sentence": "初鎮父洌，叔渙，當祿山、思明之亂，並授偽職，然以家風修整，為士大夫所稱。",
    "entities": [
      {
        "text": "初鎮",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 31,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000134",
    "sentence": "鎮兄弟亦以教義禮法為己任，而貪祿愛死，節隳身戮，為天下笑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000135",
    "sentence": "洪經綸",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000136",
    "sentence": "洪經綸，建中初為黜陟使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000137",
    "sentence": "至東都，訪聞魏州田悅食糧兵凡七萬人，經綸素昧時機，先以符停其兵四萬人，令歸農畝。",
    "entities": [
      {
        "text": "訪聞魏州",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000138",
    "sentence": "田悅偽順命，即依符罷之；而大集所罷兵士，激怒之曰：「爾等在軍旅，各有父母妻子，既為黜陟使所罷，如何得衣食？」遂大哭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000139",
    "sentence": "悅乃盡出家財衣服厚給之，各令還其部伍，自此人堅叛心，由是罷職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000140",
    "sentence": "及朱泚反，偽授太常少卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000141",
    "sentence": "彭偃",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000142",
    "sentence": "彭偃，少負俊才，銳於進取，為當塗者所抑，形於言色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000143",
    "sentence": "大曆末，為都官員外郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000144",
    "sentence": "時劍南東川觀察使李叔明上言，以「佛、道二教，無益於時，請粗加澄汰。其東川寺觀，請定為二等：上寺留僧二十一人；上觀留道士十四人，降殺以七，皆精選有道行者，餘悉令返初。蘭若、道場無名者皆廢。」德宗曰：「叔明此奏，可為天下通制，不唯劍南一道。」下尚書集議。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 120,
        "end": 122
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000145",
    "sentence": "偃獻議曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000146",
    "sentence": "王者之政，變人心為上，因人心次之，不變不因，循常守固者為下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000147",
    "sentence": "故非有獨見之明，不能行非常之事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000148",
    "sentence": "今陛下以惟新之政，為萬代法，若不革舊風，令歸正道者，非也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000149",
    "sentence": "當今道士，有名無實，時俗鮮重，亂政猶輕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000150",
    "sentence": "唯有僧尼，頗為穢雜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000151",
    "sentence": "自西方之教，被於中國，去聖日遠，空門不行五濁，比丘但行粗法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000152",
    "sentence": "爰自後漢，至於陳、隋，僧之廢滅，其亦數乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000153",
    "sentence": "或至坑殺，殆無遺餘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000154",
    "sentence": "前代帝王，豈惡僧道之善如此之深耶？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000155",
    "sentence": "蓋其亂人亦已甚矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000156",
    "sentence": "且佛之立教，清凈無為，若以色見，即是邪法，開示悟入，唯有一門，所以三乘之人，比之外道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000157",
    "sentence": "況今出家者皆是無識下劣之流，縱其戒行高潔，在於王者，已無用矣，況是茍避征徭，於殺盜淫，無所不犯者乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000158",
    "sentence": "今叔明之心甚善，然臣恐其奸吏詆欺，而去者未必非，留者不必是，無益於國，不能息奸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000159",
    "sentence": "既不變人心，亦不因人心，強制力持，難致遠耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000160",
    "sentence": "臣聞天生烝人，必將有職，遊行浮食，王制所禁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000161",
    "sentence": "故有才者受爵祿，不肖者出租征，此古之常道也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000162",
    "sentence": "今天下僧道，不耕而食，不織而衣，廣作危言險語，以惑愚者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000163",
    "sentence": "一僧衣食，歲計約三萬有餘，五丁所出，不能致此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000164",
    "sentence": "舉一僧以計天下，其費可知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000165",
    "sentence": "陛下日旰憂勤，將去人害，此而不救，奚其為政？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000166",
    "sentence": "臣伏請僧道未滿五十者，每年輸絹四疋；尼及女道士未滿五十者，每年輸絹二疋；其雜色役與百姓同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000167",
    "sentence": "有才智者令入仕，請還俗為平人者聽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000168",
    "sentence": "但令就役輸課，為僧何傷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000169",
    "sentence": "臣竊料其所出，不下今之租賦三分之一，然則陛下之國富矣，蒼生之害除矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000170",
    "sentence": "其年過五十者，請皆免之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000171",
    "sentence": "夫子曰：「五十而知天命。」列子曰：「不班白，不知道。」人年五十，嗜欲巳衰，縱不出家，心已近道，況戒律檢其情性哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000172",
    "sentence": "臣以為此令既行，僧道規避還俗者固已太半。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000173",
    "sentence": "其年老精修者，必盡為人師，則道、釋二教益重明矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000174",
    "sentence": "議者是之，上頗善其言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000175",
    "sentence": "大臣以二教行之已久，列聖奉之，不宜頓擾，宜去其太甚，其議不行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000176",
    "sentence": "偃以才地當掌文誥，以躁求為時論所抑，鬱鬱不得志。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000177",
    "sentence": "涇師之亂，從駕不及，匿於田家，為賊所得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000178",
    "sentence": "朱泚素知之，得偃甚喜，偽署中書舍人，僭號辭令，皆偃為之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000179",
    "sentence": "賊敗，與偽中丞崔宣、賊將杜如江、吳希光等十三人，李晟收之，俱斬於安國寺前。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000180",
    "sentence": "【贊】",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000181",
    "sentence": "史臣曰：肇分陰陽，爰有生死，修短二事，賢愚一途。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000182",
    "sentence": "故君子遇夷險之機，不易其節；小人昧逆順之道，而陷於刑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000183",
    "sentence": "鴻毛泰山，斯為至論。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000184",
    "sentence": "令言遠總師徒，首為叛逆；光晟初當委任，危輸款誠；源休雖曰士流，甚於元惡；喬琳巧辭真主，俯就偽官；蔣鎮貪祿隳節，皆曰小人。",
    "entities": [
      {
        "text": "蔣鎮",
        "label": "LOC",
        "start": 48,
        "end": 50
      }
    ]
  },
  {
    "sentence_id": "HCH_008_127_000185",
    "sentence": "經綸之徒，不足言爾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000186",
    "sentence": "贊曰：時爭逆順，命繫死生。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000187",
    "sentence": "君子守節，小人正刑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_127_000188",
    "sentence": "本五代作品在全世界都属于 公有领域 ，因为作者逝世已经遠遠超过100年。",
    "entities": [
      {
        "text": "100年",
        "label": "TME",
        "start": 31,
        "end": 35
      }
    ]
  }
]
