        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_114_000063",
    "sentence": "十一載，為左贊善大夫、殿中侍御史，充伊西、北庭行軍司馬。",
    "entities": [
