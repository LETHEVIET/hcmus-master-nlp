        "text": "鄭義宗",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000085",
    "sentence": "鄭義宗妻盧氏，幽州范陽人，盧彥衡之女也。",
    "entities": [
      {
        "text": "鄭義宗",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "幽州",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000086",
    "sentence": "略涉書史，事舅姑甚得婦道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000087",
    "sentence": "嘗夜有強盜數十人，持杖鼓噪，逾垣而入，家人悉奔竄，唯有姑獨在室。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000088",
    "sentence": "盧冒白刃往至姑側，為賊捶擊之，幾至於死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000089",
    "sentence": "賊去後，家人問曰：「群兇擾橫，人盡奔逃，何獨不懼？」答曰：「人所以異於禽獸者，以其仁義也。昔宋伯姬守義赴火，流稱至今。吾雖不敏，安敢忘義！且鄰里有急，尚相赴救，況在於姑，而可委棄！若萬一危禍，豈宜獨生！」其姑每嘆云：「古人稱歲寒然後知松柏之後雕也，吾今乃知盧新婦之心矣！」貞觀中卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000090",
    "sentence": "劉寂妻夏侯氏",
    "entities": [
      {
        "text": "夏侯氏",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000091",
    "sentence": "劉寂妻夏侯氏，滑州胙城人，字碎金。",
    "entities": [
      {
        "text": "夏侯氏",
        "label": "PER",
        "start": 3,
        "end": 6
      },
      {
        "text": "滑州胙城",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000092",
    "sentence": "父長雲，為鹽城縣丞，因疾喪明。",
    "entities": [
      {
        "text": "為鹽城縣",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000093",
    "sentence": "碎金乃求離其夫，以終侍養。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000094",
    "sentence": "經十五年，兼事後母，以至孝聞。",
    "entities": [
      {
        "text": "十五年",
        "label": "TME",
        "start": 1,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000095",
    "sentence": "及父卒，毀瘠殆不勝喪，被髮徒跣，負土成墳，廬於墓側，每日一食，如此者積年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000096",
    "sentence": "貞觀中，有制表其門閭，賜以粟帛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000097",
    "sentence": "楚王靈龜妃上官氏",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000098",
    "sentence": "楚王靈龜妃上官氏，秦州上邽人。",
    "entities": [
      {
        "text": "秦州",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000099",
    "sentence": "父懷仁，右金吾將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000100",
    "sentence": "上官年十八，歸於靈龜，繼楚哀王後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000101",
    "sentence": "本生具存，朝夕侍奉，恭謹彌甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000102",
    "sentence": "凡有新味，非舅姑啖訖，未曾先嘗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000103",
    "sentence": "經數載，靈龜薨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000104",
    "sentence": "及將葬，其前妃閻氏，嫁不逾年而卒，又無近族，眾議欲不舉之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000105",
    "sentence": "上官氏曰：「必神而靈，寧可使孤魂無托！」於是備禮同葬，聞者莫不嘉嘆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000106",
    "sentence": "服終，諸兄姊謂曰：「妃年尚少，又無所生，改醮異門，禮儀常範，妃可思之。」妃掩泣對曰：「丈夫以義烈標名，婦人以守節為行。未能即先犬馬，以殉溝壑，寧可復飾妝服，有他志乎！」遽將刀截鼻割耳以自誓，諸兄姊知其志不可奪，嘆息而止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000107",
    "sentence": "尋卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000108",
    "sentence": "楊紹宗妻王氏",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000109",
    "sentence": "楊紹宗妻王氏，華州華陰人也。",
    "entities": [
      {
        "text": "華州",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000110",
    "sentence": "初，年二歲，所生母亡，為繼母鞠養。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000111",
    "sentence": "至年十五，父又征遼而歿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000112",
    "sentence": "繼母尋亦卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000113",
    "sentence": "王乃收所生及繼母屍柩，並立父形像，招魂遷葬訖，廬於墓側，陪其祖父母及父母墳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000114",
    "sentence": "永徽中，詔曰：「故楊紹宗妻王氏，因心為孝，率性成道。年迫桑榆，筋力衰謝。以往在隋朝，父歿遼左，招魂遷葬，負土成墳，又葬其祖父母等，遏此老年，親加板築。痛結晨昏，哀感行路。永言志行，嘉尚良深。宜標其門閭，用旌敏德。」賜物三十段、粟五十石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000115",
    "sentence": "于敏直妻張氏",
    "entities": [
