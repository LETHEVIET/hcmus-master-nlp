      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000076",
    "sentence": "濮州孝女賈氏",
    "entities": [
      {
        "text": "濮州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000077",
    "sentence": "孝女賈氏，濮州鄄城人也。",
    "entities": [
      {
        "text": "濮州鄄城",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000078",
    "sentence": "年始十五，其父為宗人玄基所害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000079",
    "sentence": "其弟強仁年幼，賈氏撫育之，誓以不嫁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000080",
    "sentence": "及強仁成童，思共報復，乃俟玄基殺之；取其心肝，以祭父墓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000081",
    "sentence": "遣強仁自列於縣，司斷以極刑。",
    "entities": [
      {
        "text": "遣強仁自列於縣",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000082",
    "sentence": "賈氏詣闕自陳己為，請代強仁死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000083",
    "sentence": "高宗哀之，特下制賈氏及強仁免罪，移其家於洛陽。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000084",
    "sentence": "鄭義宗妻盧氏",
    "entities": [
