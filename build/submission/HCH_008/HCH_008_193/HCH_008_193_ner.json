      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000070",
    "sentence": "初，其父為鄉人衛長則所殺。",
    "entities": [
      {
        "text": "其父為鄉",
        "label": "LOC",
        "start": 2,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000071",
    "sentence": "無忌年六歲，母又改嫁，無兄弟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000072",
    "sentence": "及長，常思復仇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000073",
    "sentence": "無忌從伯常設宴為樂，長則時亦預坐，無忌以磚擊殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000074",
    "sentence": "既而詣吏，稱父仇既報，請就刑戮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000075",
    "sentence": "巡察大使、黃門侍郎褚遂良以聞，太宗嘉其孝烈，特令免罪，給傳乘徙於雍州，並給田宅，仍令州縣以禮嫁之。",
    "entities": [
      {
        "text": "侍郎",
