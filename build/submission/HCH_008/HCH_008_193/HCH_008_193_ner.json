      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000237",
    "sentence": "程氏力不能免，乃抑其哀，如非冤者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000238",
    "sentence": "昌齡雅不疑慮，聽其歸葬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000239",
    "sentence": "程氏故得以徒行詣闕，截耳於右銀臺門，告夫被殺之冤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000240",
    "sentence": "御史臺鞫之，得實，諫官亦有章疏，故昌齡再受譴逐。",
