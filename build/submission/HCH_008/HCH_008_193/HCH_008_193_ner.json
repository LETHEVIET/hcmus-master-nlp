      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000164",
    "sentence": "繪早終，盧既年少，諸兄常欲嫁之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000165",
    "sentence": "盧輒稱病固辭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000166",
    "sentence": "盧亡姊之夫李思沖，神龍初為工部侍郎，又求續親。",
    "entities": [
      {
        "text": "侍郎",
