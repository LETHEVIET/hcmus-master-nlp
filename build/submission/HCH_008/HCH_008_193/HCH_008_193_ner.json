    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000128",
    "sentence": "每晝營田業，夜便紡績，衣食所須，無非阿足出者，如此二十餘年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000129",
    "sentence": "及姊喪，葬送以禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000130",
    "sentence": "鄉人莫不稱其節行，競令妻女求與相識。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000131",
    "sentence": "後數歲，竟終於家。",
    "entities": []
  },
