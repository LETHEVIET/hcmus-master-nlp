[
  {
    "sentence_id": "HCH_008_193_000001",
    "sentence": "女子稟陰柔之質，有從人之義。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000002",
    "sentence": "前代誌貞婦烈女，蓋善其能以禮自防。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000003",
    "sentence": "至若失身賊庭，不汙非義；臨白刃而慷慨，誓丹衷而激發；粉身不顧，視死如歸，雖在壯夫，恐難守節，窈窕之操，不其賢乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000004",
    "sentence": "其次梁鴻之妻，無辭偕隱，共姜之誓，不踐二庭，婦道母儀，克彰圖史，又其長也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000005",
    "sentence": "末代風靡，貞行寂寥，聊播椒蘭，以貽閨壺，彤管之職，幸無忽焉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000006",
    "sentence": "李德武妻裴氏",
    "entities": [
      {
        "text": "李德武",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000007",
    "sentence": "李德武妻裴氏，字淑英，戶部尚書、安邑公矩之女也。",
    "entities": [
      {
        "text": "李德武",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 13,
        "end": 15
      },
      {
        "text": "安邑",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000008",
    "sentence": "性婉順有容德，事父母以孝聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000009",
    "sentence": "適德武，經一年而德武坐從父金才事徙嶺表。",
    "entities": [
      {
        "text": "一年",
        "label": "TME",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000010",
    "sentence": "矩時為黃門侍郎，奏請德武離婚，煬帝許之。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000011",
    "sentence": "德武將與裴別，謂曰：「燕婉始爾，便事分離，方遠投瘴癘，恐無還理。尊君奏留，必欲改嫁耳，於此即事長訣矣！」裴泣而對曰：「婦人事夫，無再醮之禮。夫者，天也，何可背乎！守之以死，必無他志！」因操刀欲割耳自誓，保者禁之，乃止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000012",
    "sentence": "裴與德武別後，容貌毀悴，常讀佛經，不御膏澤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000013",
    "sentence": "李氏之姊妹在都邑者，歲時朔望，必命左右致敬而省焉。",
    "entities": [
      {
        "text": "氏之姊妹在都邑",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000014",
    "sentence": "裴又嘗讀《烈女傳》，見稱述不改嫁者，乃謂所親曰：「不踐二庭，婦人常理，何為以此載於記傳乎？」後十餘年間，與德武音信斷絕。",
    "entities": [
      {
        "text": "《烈女傳》",
        "label": "TITLE",
        "start": 4,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000015",
    "sentence": "矩欲奪其志。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000016",
    "sentence": "時有柳直求婚，許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000017",
    "sentence": "期有定日，乃以翦刀斷其髮，悲泣絕粒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000018",
    "sentence": "矩不可奪，乃止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000019",
    "sentence": "德武已於嶺表娶爾硃氏為妻，及遇赦得還，至襄州，聞裴守節，乃出其後妻，重與裴合。",
    "entities": [
      {
        "text": "至襄州",
        "label": "LOC",
        "start": 19,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000020",
    "sentence": "生三男四女。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000021",
    "sentence": "貞觀中，德武終於鹿城令，裴歲餘亦卒。",
    "entities": [
      {
        "text": "德武終於鹿城",
        "label": "LOC",
        "start": 4,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000022",
    "sentence": "楊慶妻王氏 〈 獨孤師仁乳母王氏附 〉",
    "entities": [
      {
        "text": "獨孤師仁",
        "label": "PER",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000023",
    "sentence": "楊慶妻王氏，世充兄之女也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000024",
    "sentence": "慶即隋河間王弘之子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000025",
    "sentence": "大業末，封郇王，為滎陽太守。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000026",
    "sentence": "後陷於世充。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000027",
    "sentence": "世充以兄女妻之，授管州刺史。",
    "entities": [
      {
        "text": "授管州",
        "label": "LOC",
        "start": 8,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000028",
    "sentence": "及太宗攻圍洛陽，慶謀背世充，欲與其妻俱來歸國。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000029",
    "sentence": "妻謂慶曰：「鄭國以妾奉箕帚於公者，所以結公心耳。今既二三其行，負恩背義，自為身謀，妾將奈何？若至長安，則公家之婢耳！願送至東都，公之惠也。」慶不聽。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 48,
        "end": 50
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000030",
    "sentence": "伺慶出後，謂侍者曰：「唐兵若勝，我家則戚。鄭國無危，吾夫又死，進退維谷。何以生焉？」乃飲藥而卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000031",
    "sentence": "慶既入朝，官至宜州刺史。",
    "entities": [
      {
        "text": "官至宜州",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000032",
    "sentence": "時又有獨孤武都，謀叛王世充歸國，事覺誅死。",
    "entities": [
      {
        "text": "獨孤武都",
        "label": "PER",
        "start": 3,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000033",
    "sentence": "武都子師仁，年始三歲，世充以其年幼不殺，使禁掌之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000034",
    "sentence": "乳母王氏，號蘭英，請髡鉗，求入保養，世充許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000035",
    "sentence": "蘭英撫育提攜，備盡筋力。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000036",
    "sentence": "時喪亂年饑，人多鋨死，蘭英扶路乞丐捃拾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000037",
    "sentence": "遇有所得，便歸與師仁；蘭英唯啖土飲水而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000038",
    "sentence": "後詐采拾，乃竊師仁歸於京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000039",
    "sentence": "高祖嘉其義，下詔曰：「師仁乳母王氏，慈惠有聞，撫鞠無倦，提攜遺幼，背逆歸朝。宜有褒隆，以錫其號。可封永壽郡君」。",
    "entities": [
      {
        "text": "可封永壽郡",
        "label": "LOC",
        "start": 48,
        "end": 53
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000040",
    "sentence": "楊三安妻李氏",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000041",
    "sentence": "楊三安妻李氏，雍州涇陽人也。",
    "entities": [
      {
        "text": "雍州",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000042",
    "sentence": "事舅姑以孝聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000043",
    "sentence": "及舅姑亡沒，三安亦死，二子孩童，家至貧窶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000044",
    "sentence": "李晝則力田，夜紡緝，數年間葬舅姑及夫之叔侄兄弟者七喪，深為遠近所嗟尚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000045",
    "sentence": "太宗聞而異之，賜帛二百段，遣州縣所在存恤之。",
    "entities": [
      {
        "text": "遣州縣",
        "label": "LOC",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000046",
    "sentence": "魏衡妻王氏",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000047",
    "sentence": "魏衡妻王氏，梓州郪人也。",
    "entities": [
      {
        "text": "梓州",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000048",
    "sentence": "武德初，薛仁杲舊將房企地侵掠梁郡，因獲王氏，逼而妻之。",
    "entities": [
      {
        "text": "房企地侵掠梁郡",
        "label": "LOC",
        "start": 9,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000049",
    "sentence": "後企地漸強盛，衡謀以城應賊。",
    "entities": [
      {
        "text": "衡謀以城",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000050",
    "sentence": "企地領眾將趨梁州，未至數十里，飲酒醉臥。",
    "entities": [
      {
        "text": "地領眾將趨梁州",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000051",
    "sentence": "王氏取其佩刀斬之，攜其首入城，賊眾乃散。",
    "entities": [
      {
        "text": "攜其首入城",
        "label": "LOC",
        "start": 9,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000052",
    "sentence": "高祖大悅，封為崇義夫人，舍衡同賊之罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000053",
    "sentence": "樊會仁母敬氏",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000054",
    "sentence": "樊會仁母敬氏，字像子，蒲州河東人也。",
    "entities": [
      {
        "text": "蒲州",
        "label": "LOC",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_193_000055",
    "sentence": "年十五，適樊氏，生會仁而夫喪，事舅姑姊姒以謹順聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000056",
    "sentence": "及服終，母兄以其盛年，將奪其志。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000057",
    "sentence": "微加諷諭，便悲恨嗚咽，如此者數四。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000058",
    "sentence": "母兄乃潛許人為婚，矯稱母患以召之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000059",
    "sentence": "凡所營具，皆寄之鄰里。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000060",
    "sentence": "像子既至，省母無疾，鄰家復具肴善，像子知為所欺，佯為不悟者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000061",
    "sentence": "其嫂復請像子沐浴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000062",
    "sentence": "像子私謂會仁曰：「吾不幸孀居，誓與汝父同穴。所以不死者，徒以我母羸老，汝身幼弱。今汝舅欲奪吾志，將加逼迫，於汝何如！」會仁失聲啼泣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000063",
    "sentence": "像子撫之曰：「汝勿啼。吾向偽不覺者，令汝舅不我為意。聞汝啼，知吾覺悟，必加妨備，則吾難為計矣！」會仁便佯睡，像子於是伺隙攜之遁歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000064",
    "sentence": "中路，兄使追及之，將逼與俱返。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000065",
    "sentence": "像子誓以必死，辭情甚切，其兄感嘆而止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000066",
    "sentence": "後會仁年十八病卒，時像子母已終。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000067",
    "sentence": "既葬，像子謂其所親曰：「吾老母不幸，又夫死子亡，義無久活。」於是號慟不食，數日而死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_193_000068",
    "sentence": "絳州孝女衛氏",
