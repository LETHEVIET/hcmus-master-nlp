    ]
  },
  {
    "sentence_id": "HCH_008_180_000002",
    "sentence": "朱克融，賊泚之從孫也。",
    "entities": [
      {
        "text": "朱克融",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000003",
    "sentence": "祖滔，父洄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000004",
    "sentence": "克融少為幽州軍校，事節度使劉總。",
    "entities": [
      {
        "text": "克融少為幽州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000005",
    "sentence": "總將歸朝，慮其有變，籍軍中素有異志者，薦之闕下，時克融亦在籍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000006",
    "sentence": "宰相崔植、杜元穎不知兵，且無遠略，謂兩河無虞，遂奏勒歸鎮。",
    "entities": [
      {
        "text": "杜元穎",
        "label": "PER",
        "start": 5,
        "end": 8
      },
      {
        "text": "遂奏勒歸鎮",
        "label": "LOC",
        "start": 23,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000007",
    "sentence": "長慶初，幽州軍亂，囚其帥張弘靖。",
    "entities": [
      {
        "text": "幽州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "張弘靖",
        "label": "PER",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000008",
    "sentence": "時洄廢疾於家，軍中素伏其謀略，至是眾欲立之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000009",
    "sentence": "洄自以老且病，推克融統軍務焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000010",
    "sentence": "朝廷尋加檢校左散騎常侍，授以符節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000011",
    "sentence": "寶曆二年 ，遣使送方鎮及三軍時服，克融怒所賜疏弱，執中使以聞。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "遣使送方鎮",
        "label": "LOC",
        "start": 6,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000012",
    "sentence": "上特優容，別命中使宣諭，仍改賜衣物，流其使楊文端等。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000013",
    "sentence": "先是，克融執中使，奏稱：「竊聞陛下欲幸東都，請將兵馬並丁匠五千人，修理宮闕，迎候車駕。」又上言無衣，擬於朝廷請三十萬端疋，以備一歲所費，不然則三軍不安。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000014",
    "sentence": "天子怒其悖慢，取宰臣裴度謀，優容之，語見別卷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000015",
    "sentence": "克融官至檢校司空、吳興郡王。",
    "entities": [
      {
        "text": "吳興郡",
        "label": "LOC",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000016",
    "sentence": "其年五月，本州軍亂，殺之，子延齡亦遇害。",
    "entities": [
      {
        "text": "本州",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000017",
    "sentence": "次子延嗣竊立，尋為大將李載義所殺。",
    "entities": [
      {
        "text": "李載義",
        "label": "PER",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000018",
    "sentence": "李載義",
    "entities": [
      {
        "text": "李載義",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000019",
    "sentence": "李載義，字方谷，常山湣王之後。",
    "entities": [
      {
        "text": "李載義",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000020",
    "sentence": "代以武力稱，繼為幽州屬郡守。",
    "entities": [
      {
        "text": "繼為幽州屬郡",
        "label": "LOC",
        "start": 6,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000021",
    "sentence": "載義少孤，與鄉曲之不令者遊。",
    "entities": [
      {
        "text": "與鄉",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000022",
    "sentence": "有勇力，善挽強角牴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000023",
    "sentence": "劉濟為幽州節度使，見而偉之，致於親軍，從征伐。",
    "entities": [
      {
        "text": "劉濟為幽州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000024",
    "sentence": "以功遷衙前都知兵馬使，檢校光祿大夫、兼監察御史。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000025",
    "sentence": "寶歷中，幽師殺硃克融。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000026",
    "sentence": "其子延嗣竊襲父位，不遵朝旨，虐用其人；載義遂殺之，數其罪以聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000027",
    "sentence": "敬宗嘉之，拜檢校戶部尚書、兼御史大夫，封武威郡王，充幽州盧龍等軍節度副大使，知節度事。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "御史",
