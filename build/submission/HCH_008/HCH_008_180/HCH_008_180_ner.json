      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000046",
    "sentence": "虜知其心為下，無敢犯令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000047",
    "sentence": "九年，加侍中。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000048",
    "sentence": "開成二年 卒，年五十，贈太尉。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000049",
    "sentence": "載義晚年驕恣，慘暴一方。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000050",
    "sentence": "以楊志誠復為部下所逐，過太原，載義躬身毆擊，遂欲殺之，賴從事救解以免。",
    "entities": [
