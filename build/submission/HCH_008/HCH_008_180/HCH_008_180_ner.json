  {
    "sentence_id": "HCH_008_180_000063",
    "sentence": "朝廷納裴度言，務以含垢，下詔諭之，因再遣使加尚書右僕射。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000064",
    "sentence": "八年，為三軍所逐，則立史元忠。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "史元忠",
        "label": "PER",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000065",
    "sentence": "元忠進志誠所造袞龍衣二副及被服鞍韉，皆繡飾鸞鳳日月之形，或為王字。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000066",
    "sentence": "因付御史臺按問，流嶺南。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000067",
    "sentence": "行至商州，殺之。",
    "entities": [
      {
        "text": "行至商州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000068",
    "sentence": "初，元忠既逐志誠，詔以通王淳遙領節度，授元忠左散騎常侍、幽州大都督府左司馬、知府事，充節度留後。",
    "entities": [
      {
        "text": "幽州",
        "label": "LOC",
        "start": 28,
        "end": 30
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 30,
        "end": 32
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 35,
        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000069",
    "sentence": "明年，轉檢校工部尚書、節度副大使，知節度事。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000070",
    "sentence": "後為偏將陳行泰所殺。",
    "entities": [
      {
        "text": "陳行泰",
        "label": "PER",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000071",
    "sentence": "張仲武",
    "entities": [
      {
        "text": "張仲武",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000072",
    "sentence": "張仲武，范陽人也。",
    "entities": [
      {
        "text": "張仲武",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000073",
    "sentence": "仲武少業《左氏春秋》，擲筆為薊北雄武軍使。",
    "entities": [
      {
        "text": "《左氏春秋》",
        "label": "TITLE",
        "start": 4,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000074",
    "sentence": "會昌初，陳行泰殺節度使史元忠，權主留後。",
    "entities": [
      {
        "text": "陳行泰",
        "label": "PER",
        "start": 4,
        "end": 7
      },
      {
        "text": "史元忠",
        "label": "PER",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000075",
    "sentence": "俄而，行泰又為次將張絳所殺，令三軍上表，請降符節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000076",
    "sentence": "時仲武遣軍吏吳仲舒表請以本軍伐叛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000077",
    "sentence": "上遣宰臣詢其事，仲舒曰：「絳與行泰，皆是遊客，主軍人心不附。仲武是軍中舊將張光朝之子，年五十餘，兼曉儒書，老於戎事，性抱忠義，願歸心闕廷。」李德裕因奏：「陳行泰、張絳皆令大將上奏，邀求節旄，所以必不可與。今仲武上表布誠，先陳密款，因而拔用，即似有名。」許之，乃授兵馬留後，詔撫王纮遙領節度。",
    "entities": [
      {
        "text": "張光朝",
        "label": "PER",
        "start": 37,
        "end": 40
      },
      {
        "text": "李德裕",
        "label": "PER",
        "start": 70,
        "end": 73
      },
      {
        "text": "陳行泰",
        "label": "PER",
        "start": 77,
        "end": 80
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000078",
    "sentence": "尋改仲武節度副大使、知節度事，檢校工部尚書、幽州大都督府長史、兼御史大夫、蘭陵郡王。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 19,
        "end": 21
      },
      {
        "text": "幽州",
        "label": "LOC",
        "start": 22,
        "end": 24
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 24,
        "end": 26
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 32,
        "end": 34
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 34,
        "end": 36
      },
      {
        "text": "蘭陵郡",
        "label": "LOC",
        "start": 37,
        "end": 40
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000079",
    "sentence": "俄而回鶻擾邊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000080",
    "sentence": "時回鶻有將勒那頡啜擁赤心宰相一族七千帳，東逼漁陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000081",
    "sentence": "仲武遣其弟仲至與裨將遊奉寰、王如清等，率銳兵三萬人大破之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000082",
    "sentence": "前後收其侯王貴族千餘人，降三萬人，獲牛馬、橐駝、旗纛、罽幕不可勝計。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000083",
    "sentence": "遣從事李周瞳、牙門將國從  ，相次獻捷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000084",
    "sentence": "詔加檢校兵部尚書，兼東面招撫回鶻使。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000085",
    "sentence": "先是，奚、契丹皆有回鶻監護使，督以歲貢，且為漢諜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000086",
    "sentence": "至是，遣裨將石公緒等諭意兩部，凡戮八百餘人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000087",
    "sentence": "又回鶻初遣宣門將軍等四十七人，詭詞結歡，潛伺邊隙。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000088",
    "sentence": "仲武使密賂其下，盡得陰謀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000089",
    "sentence": "且欲馳入五原，驅掠雜虜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000090",
    "sentence": "遂逗遛其使，緩彼師期。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000091",
    "sentence": "人馬病死，竟不遣之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000092",
    "sentence": "回鶻烏介可汗既敗，不敢近邊，乃依康居求活，盡徙餘種，寄托黑車子部。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000093",
    "sentence": "仲武由是威加北狄，表請於薊北立《紀聖功銘》，敕李德裕為之文，其銘曰：",
    "entities": [
      {
        "text": "《紀聖功銘》",
        "label": "TITLE",
        "start": 15,
        "end": 21
      },
      {
        "text": "李德裕",
        "label": "PER",
        "start": 23,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000094",
    "sentence": "太和之初，赤氣宵興；開成之末，彤雲暮凝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000095",
    "sentence": "異鳥南來，胡滅之征。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000096",
    "sentence": "北夷飈掃，厥國土崩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000097",
    "sentence": "逼迫遷徙，震我邊鄙；長蛇去穴，奔鯨失水。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000098",
    "sentence": "上都薊門，兵連千里；曾不畏天，猶為驕子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000099",
    "sentence": "丐我邊谷，邀我王師，假我一城，建彼幡旗。",
    "entities": [
      {
        "text": "假我一城",
        "label": "LOC",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000100",
    "sentence": "歸計強漢，郅支嫚辭；狼顧朔野，伏莽見羸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000101",
    "sentence": "雁門之北，羌戎雜處，濈々群羊，茫茫大鹵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000102",
    "sentence": "縱其梟騎，驚我牧圉；暴若豺狼，疾如風雨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000103",
    "sentence": "皇赫斯怒，羽檄征兵；謀而泉默，斷乃霆聲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000104",
    "sentence": "沈機變化，動合神明，沙漠之外，虜無隱情。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000105",
    "sentence": "漁陽突騎，燕歌壯氣，赳赳元戎，眈眈虎視。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000106",
    "sentence": "金鼓誓眾，幹旄蔽地，爰命其弟，屬之大事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000107",
    "sentence": "翩翩飛將，董我三軍；稟兄之制，代帥之勤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000108",
    "sentence": "威略火烈，胡馬星分，戈回白日，劍薄浮云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000109",
    "sentence": "天街之北，旄頭已落；絕轡之野，蚩尤未縛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000110",
    "sentence": "俾我元侯，恢弘遠略；終取單於，系之徽索。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000111",
    "sentence": "陰山寢鋒，亭僥弢弓，萬里昆夷，九譯而通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000112",
    "sentence": "蠻夷既同，天子之功；儒臣篆美，刊石垂鴻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000113",
    "sentence": "仲武歷官至司徒、中書門下平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000114",
    "sentence": "大中年卒，謚曰莊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000115",
    "sentence": "子 直方",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000116",
    "sentence": "子直方，以幽州節度副使襲父位。",
    "entities": [
      {
        "text": "以幽州",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000117",
    "sentence": "動多不法，慮為將卒所圖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000118",
    "sentence": "三年冬，托以遊獵，奔赴闕庭，尋授金吾將軍。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000119",
    "sentence": "直方性率暴，行豪奪之事，以罪累貶柳州司馬。",
    "entities": [
      {
        "text": "以罪累貶柳州",
        "label": "LOC",
        "start": 12,
        "end": 18
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000120",
    "sentence": "十一年，遷右驍衛將軍，分司東都。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000121",
    "sentence": "咸通中，位至羽林統軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000122",
    "sentence": "中和歲，賊巢犯闕，公卿恃其豪，多隱藏於第。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000123",
    "sentence": "直方納招亡命，謀欲劫巢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000124",
    "sentence": "或有告者，由是以兵圍而害之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000125",
    "sentence": "張允伸",
    "entities": [
      {
        "text": "張允伸",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000126",
    "sentence": "張允伸，字逢昌，范陽人也。",
    "entities": [
      {
        "text": "張允伸",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000127",
    "sentence": "曾祖秀，檀州刺史。",
    "entities": [
      {
        "text": "檀州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000128",
    "sentence": "祖巖，納降軍使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000129",
    "sentence": "父朝掖，贈太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000130",
    "sentence": "允申世仕幽州軍門，累職至押衙，兼馬步都知兵馬使。",
    "entities": [
      {
        "text": "允申世仕幽州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000131",
    "sentence": "大中四年，戎帥周綝寢疾，表允伸為留後，朝廷可其奏，加右散騎常侍。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000132",
    "sentence": "其年冬，詔賜旌節，遷檢校工部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000133",
    "sentence": "咸通九年 ，累加至光祿大夫、檢校司徒、兼太傅、同中書門下平章事、燕國公。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000134",
    "sentence": "十年，徐人作亂，請以弟允臯領兵伐叛，懿宗不允。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000135",
    "sentence": "進助軍米五十萬石，鹽二萬石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000136",
    "sentence": "詔嘉之，賜以錦彩、玉帶、金銀器等。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000137",
    "sentence": "冬，又加特進，兼侍中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000138",
    "sentence": "十二年，以風恙拜章請就醫藥，詔許之。",
    "entities": [
      {
        "text": "十二年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000139",
    "sentence": "以子簡會檢校工部尚書，充節度副大使。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000140",
    "sentence": "十三年，允伸再上表進納所賜旌節。",
    "entities": [
      {
        "text": "十三年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000141",
    "sentence": "朝命未至，其年正月二十五日卒，年八十八。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000142",
    "sentence": "再贈太尉，謚曰忠烈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000143",
    "sentence": "允伸領鎮凡二十三年，克勤克儉，比歲豐登。",
    "entities": [
      {
        "text": "允伸領鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "二十三年",
        "label": "TME",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000144",
    "sentence": "邊鄙無虞，軍民用乂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000145",
    "sentence": "至今談者美之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000146",
    "sentence": "有子十四人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000147",
    "sentence": "簡真，幽府左司馬，先允伸卒。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000148",
    "sentence": "簡壽，右領軍衛大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000149",
    "sentence": "餘或升朝籍，或為刺史、郡佐。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000150",
    "sentence": "張公素",
    "entities": [
      {
        "text": "張公素",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000151",
    "sentence": "張公素，范陽人。",
    "entities": [
      {
        "text": "張公素",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000152",
    "sentence": "咸通中，為幽州軍校。",
    "entities": [
      {
        "text": "為幽州",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000153",
    "sentence": "事張允伸，累遷至平州刺史。",
    "entities": [
      {
        "text": "張允伸",
        "label": "PER",
        "start": 1,
        "end": 4
      },
      {
        "text": "累遷至平州",
        "label": "LOC",
        "start": 5,
        "end": 10
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000154",
    "sentence": "允伸卒，子簡會權主留後事，公素領本郡兵赴焉。",
    "entities": [
      {
        "text": "公素領本郡",
        "label": "LOC",
        "start": 13,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000155",
    "sentence": "三軍素畏公素威望，簡會知力不能制，即時出奔，遂立為帥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000156",
    "sentence": "朝廷尋授旌節，累加至中書門下平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000157",
    "sentence": "無幾，李茂勛奪其位，公素歸闕，貶復州司戶參軍。",
    "entities": [
      {
        "text": "貶復州",
        "label": "LOC",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000158",
    "sentence": "李可舉",
    "entities": [
      {
        "text": "李可舉",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000159",
    "sentence": "李可舉，本回鶻阿布思之族也。",
    "entities": [
      {
        "text": "李可舉",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000160",
    "sentence": "張仲武破回鶻，可舉父茂勛與本部侯王降焉。",
    "entities": [
      {
        "text": "張仲武",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000161",
    "sentence": "茂勛善騎射，性沈毅，仲武器之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000162",
    "sentence": "常遣拓邊，以功封郡王，賜姓名。",
    "entities": [
      {
        "text": "以功封郡",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000163",
    "sentence": "咸通末，納降軍使陳貢言者，幽之宿將，人所信服。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000164",
    "sentence": "茂勛密謀劫而殺之，聲雲貢言舉兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000165",
    "sentence": "張公素以兵逆擊不利，公素走，茂勛入城，軍民方知其非貢言也。",
    "entities": [
      {
        "text": "張公素",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "茂勛入城",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000166",
    "sentence": "既有其眾，遂推而立之，朝廷即降符節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000167",
    "sentence": "無幾，以疾告老，授右僕射致仕，表可舉自節度副使、幽州左司馬加右散騎常侍，為節度留後。",
    "entities": [
      {
        "text": "幽州",
        "label": "LOC",
        "start": 24,
        "end": 26
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000168",
    "sentence": "中和中，累官至檢校太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000169",
    "sentence": "中和末，以太原李克用兵勢方盛，與定州王處存密相締結。",
    "entities": [
      {
        "text": "李克用",
        "label": "PER",
        "start": 7,
        "end": 10
      },
      {
        "text": "與定州",
        "label": "LOC",
        "start": 15,
        "end": 18
      },
      {
        "text": "王處存",
        "label": "PER",
        "start": 18,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000170",
    "sentence": "可舉慮其窺伺山東，終為己患，遂遣使構雲中赫連鐸乘其背，則與鎮州合謀舉兵，兼言易、定是燕、趙之餘，雲得其地則正其疆理而分之。",
    "entities": [
      {
        "text": "赫連鐸",
        "label": "PER",
        "start": 20,
        "end": 23
      },
      {
        "text": "則與鎮州",
        "label": "LOC",
        "start": 27,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000171",
    "sentence": "時可舉遣將李全忠攻易州。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000172",
    "sentence": "有次將劉仁恭者，多權數；攻之彌月不下，乃穴地道以入。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000173",
    "sentence": "其城既下，易州士卒稍驕。",
    "entities": [
      {
        "text": "其城",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "易州",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000174",
    "sentence": "王處存引輕軍三千，以羊皮蒙之，夜伏於城外，仍別於間道以騎士伺之。",
    "entities": [
      {
        "text": "王處存",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "夜伏於城",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000175",
    "sentence": "燕軍望見，謂之群羊，爭趨焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000176",
    "sentence": "處存乘其無部伍，一擊大敗之，尋復其城。",
    "entities": [
      {
        "text": "尋復其城",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000177",
    "sentence": "全忠遁歸，懼可舉罪之，收其餘眾，反攻幽州。",
    "entities": [
      {
        "text": "反攻幽州",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000178",
    "sentence": "可舉危急，收集其族，登樓自燔而死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000179",
    "sentence": "李全忠",
    "entities": [
      {
        "text": "李全忠",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000180",
    "sentence": "李全忠，范陽人。",
    "entities": [
      {
        "text": "李全忠",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000181",
    "sentence": "廣明中，為棣州司馬。",
    "entities": [
      {
        "text": "明",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "為棣州",
        "label": "LOC",
        "start": 4,
        "end": 7
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000182",
    "sentence": "有蘆生於室，一尺三節，心惡之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000183",
    "sentence": "謂別駕張建曰：「吾室生蘆，無乃怪歟？」建曰：「蘆，茅類，得澤而滋，公家有茅土之慶，殆天意乎！其生三節，必傳節鉞者三人。公勉樹功名，無忘斯言。」全忠秩滿還鄉里，事節度使李可舉為牙將。",
    "entities": [
      {
        "text": "全忠秩滿還鄉",
        "label": "LOC",
        "start": 71,
        "end": 77
      },
      {
        "text": "李可舉",
        "label": "PER",
        "start": 83,
        "end": 86
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000184",
    "sentence": "時可舉兵鋒方盛，欲與鎮人分易、定，遣全忠將兵攻之，為定州軍大敗於易水。",
    "entities": [
      {
        "text": "欲與鎮",
        "label": "LOC",
        "start": 8,
        "end": 11
      },
      {
        "text": "為定州",
        "label": "LOC",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000185",
    "sentence": "全忠懼，率其餘眾掩攻幽州。",
    "entities": [
      {
        "text": "其餘眾掩攻幽州",
        "label": "LOC",
        "start": 5,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000186",
    "sentence": "可舉死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000187",
    "sentence": "三軍推全忠為留後，朝廷因以節鉞授之， 光啟元年 春也。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000188",
    "sentence": "全忠卒，子匡威自襲父位，稱留後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000189",
    "sentence": "匡威素稱豪爽，屬遇亂離，繕甲燕薊，有吞四海之志。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000190",
    "sentence": "赫連鐸據雲中，屢引匡威與河東爭雲、代，並兵積年。",
    "entities": [
      {
        "text": "赫連鐸",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000191",
    "sentence": "景福初，鎮州王鎔誘河東將李存孝。",
    "entities": [
      {
        "text": "鎮州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "李存孝",
        "label": "PER",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000192",
    "sentence": "克用怒，加兵討之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000193",
    "sentence": "時鎔童幼，求援於燕；匡威親率軍應之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000194",
    "sentence": "二年春，河東復出師井陘，再乞師，匡威來援。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000195",
    "sentence": "匡威弟匡籌，妻張氏有國色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000196",
    "sentence": "師將發，家人會別，匡威酒酣，留張氏報之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000197",
    "sentence": "匡籌私懷忿怒，匡威軍至博野，匡籌乃據城自為節度。",
    "entities": [
      {
        "text": "匡籌乃據城",
        "label": "LOC",
        "start": 14,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000198",
    "sentence": "匡威部下聞之，亡歸者半。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000199",
    "sentence": "匡威退無歸路，將入覲京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000200",
    "sentence": "時匡威留於深州，遣判官李抱貞奉章以聞。",
    "entities": [
      {
        "text": "時匡威留於深州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000201",
    "sentence": "屬京師大亂之後，聞匡威來朝，市人震恐，咸曰「金頭王來謀社稷」，士庶有亡竄山谷者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000202",
    "sentence": "匡威其實不行，欲圖鎮州，示無留意。",
    "entities": [
      {
        "text": "欲圖鎮州",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000203",
    "sentence": "鎔以匡威再來援己，致其失師，遣使迎歸府第，父事之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000204",
    "sentence": "匡威為鎔城郛繕甲，指陳方略，視鎔如子。",
    "entities": [
      {
        "text": "匡威為鎔城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000205",
    "sentence": "每陰謀驟施，以悅人心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000206",
    "sentence": "鎮之三軍，素忠於王氏，惡其所為。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000207",
    "sentence": "會鎔過匡威第慰忌辰，匡威縞衣裹甲，伏兵劫鎔入牙城。",
    "entities": [
      {
        "text": "伏兵劫鎔入牙城",
        "label": "LOC",
        "start": 17,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000208",
    "sentence": "鎔兵逆戰，燔東偏門，軍士呼噪登屋，矢下如雨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000209",
    "sentence": "鎔僕墨君和亂中扶鎔登屋免難，而斬匡威以徇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000210",
    "sentence": "是歲，匡籌出師攻鎮之樂壽、武強以報恥。",
    "entities": [
      {
        "text": "匡籌出師攻鎮",
        "label": "LOC",
        "start": 3,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000211",
    "sentence": "匡威部曲劉仁恭歸於河東。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000212",
    "sentence": "乾寧元年 冬，河東聽仁恭之謀，出師進討。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000213",
    "sentence": "二月，敗燕軍於居庸，匡籌挈其族遁去，將赴京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000214",
