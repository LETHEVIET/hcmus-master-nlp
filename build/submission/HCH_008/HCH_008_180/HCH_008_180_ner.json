      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000051",
    "sentence": "然而擅殺志誠之妻孥及將卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000052",
    "sentence": "朝廷錄其功，屈法不問。",
