        "end": 23
      },
      {
        "text": "充幽州",
        "label": "LOC",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000028",
    "sentence": "未幾，李同捷據滄景以邀襲父爵。",
    "entities": [
      {
        "text": "李同捷",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000029",
    "sentence": "載義上表，請討同捷以自效。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000030",
    "sentence": "上嘉其誠懇，特加檢校右僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000031",
    "sentence": "累破賊軍，以功加司空，進階金紫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_180_000032",
    "sentence": "太和三年 ，平滄景，策勛加平章事，仍賜實封三百戶。",
    "entities": [
      {
        "text": "太和三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000033",
    "sentence": "四年，契丹寇邊，以兵擊走之，仍虜其名王，就加太保。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_180_000034",
    "sentence": "五年春，為其部下楊志誠所逐，因入覲。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "楊志誠",
