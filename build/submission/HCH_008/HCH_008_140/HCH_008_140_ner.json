      }
    ]
  },
  {
    "sentence_id": "HCH_008_140_000005",
    "sentence": "建中四年 ，涇師犯闕，德宗幸奉天，鳳翔兵馬使李楚琳殺張鎰，以府城叛歸於硃泚，隴州刺史郝通奔於楚琳。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "以府城",
        "label": "LOC",
        "start": 29,
