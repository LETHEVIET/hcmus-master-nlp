[
  {
    "sentence_id": "HCH_008_181_000001",
    "sentence": "史憲誠 子:孝章 何進滔 子:弘敬 韓允忠 子:簡 樂彥禎 子:從訓 羅弘信 子:威",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000002",
    "sentence": "列傳第一百三十一",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000003",
    "sentence": "史憲誠",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000004",
    "sentence": "史憲誠，其先出於奚虜，今爲靈武建康人。",
    "entities": [
      {
        "text": "建康",
        "label": "LOC",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000005",
    "sentence": "祖道德，開府儀同三司、試太常卿、上柱國、懷澤郡王。",
    "entities": [
      {
        "text": "懷澤郡",
        "label": "LOC",
        "start": 20,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000006",
    "sentence": "父周洛，爲魏博軍校，事田季安，至兵馬大使、銀青光祿大夫、檢校太子賓客、兼御史中丞、柱國、北海郡王。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 25,
        "end": 27
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 30,
        "end": 32
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 36,
        "end": 38
      },
      {
        "text": "北海郡",
        "label": "LOC",
        "start": 44,
        "end": 47
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000007",
    "sentence": "憲誠始以材勇，隨父歷軍中右職，兼監察御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000008",
    "sentence": "元和中，田弘正討李師道，令憲誠以先鋒四千人濟河，累下其城柵。",
    "entities": [
      {
        "text": "累下其城",
        "label": "LOC",
        "start": 24,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000009",
    "sentence": "復以大軍齊進，乘勢逐北，魏之全師迫於鄆之城下。",
    "entities": [
      {
        "text": "全師迫於鄆之城",
        "label": "LOC",
        "start": 14,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000010",
    "sentence": "師道窮蹙，劉悟斬首投魏軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000011",
    "sentence": "錄功，超授憲誠兼中丞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000012",
    "sentence": "鎮州王承宗死，弘正自魏移領鎮州。",
    "entities": [
      {
        "text": "鎮州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "弘正自魏移領鎮",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000013",
    "sentence": "居數月，爲王廷湊所殺，遂以兵叛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000014",
    "sentence": "朝廷以弘正子布爲魏博節度使，領兵討伐，俾復父冤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000015",
    "sentence": "時幽州硃克融援助廷湊，布不能制，因自引決，軍情囂然。",
    "entities": [
      {
        "text": "時幽州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000016",
    "sentence": "憲誠爲中軍都知兵馬使，乘亂以河朔舊事動其人心，諸軍即擁而歸魏，共立爲帥，國家因而命之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000017",
    "sentence": "時克融、廷湊並據兵爲亂，憲誠喜得旄節，雖外順朝旨，而中與硃、王爲輔車之勢，長慶二年正月也。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 39,
        "end": 41
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000018",
    "sentence": "尋遣司門郎中韋文恪宣慰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000019",
    "sentence": "時李㝏爲亂，與憲誠書問交通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000020",
    "sentence": "憲誠表請與㝏節鉞，仍於黎陽艤舟，示欲渡河。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000021",
    "sentence": "及見文恪，舉止驕倨，其言甚悖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000022",
    "sentence": "旋聞絺爲帳下所殺，乃從改過，謂文恪曰：「憲誠蕃人，猶狗也，唯能識主。雖被棒打，終不忍離。」其狡譎如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000023",
    "sentence": "朝廷每爲優容，尋加左僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000024",
    "sentence": "敬宗即位，進秩司空。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000025",
    "sentence": "太和二年，滄景節度使李全略卒，其子同捷竊據軍城，表邀符節，舉兵伐之。",
    "entities": [
      {
        "text": "太和二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "子同捷竊據軍城",
        "label": "LOC",
        "start": 16,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000026",
    "sentence": "先是，憲誠與全略婚媾，及同捷叛，復潛以糧餉爲助。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000027",
    "sentence": "上屢發使申諭，尋又就加平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000028",
    "sentence": "憲誠嘗遣驍將至闕下，恣爲張大，宰相韋處厚以語折剉之，憲誠不敢復與同捷爲應。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000029",
    "sentence": "時憲誠示出師共討同捷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000030",
    "sentence": "及滄景平，加司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000031",
    "sentence": "憲誠心不自安，乃遣子孝章入覲，又飛章願以所管奉命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000032",
    "sentence": "上嘉之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000033",
    "sentence": "乃加侍中，移鎮河中。",
    "entities": [
      {
        "text": "移鎮",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000034",
    "sentence": "憲誠素懷向背，不能以忠誠感激其眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000035",
    "sentence": "未及出城，太和三年六月二十六日夜，爲軍眾所害，冊贈太尉。",
    "entities": [
      {
        "text": "未及出城",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "太和三年",
        "label": "TME",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000036",
    "sentence": "憲誠子 孝章",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000037",
    "sentence": "孝章，幼聰悟好學。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000038",
    "sentence": "元和中，李醞爲魏帥，取大將子弟列於軍籍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000039",
    "sentence": "孝章倡言願效文職，醞奇之，令攝府參軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000040",
    "sentence": "及憲誠領節鉞，改士曹參軍、兼監察御史，賜緋。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000041",
    "sentence": "孝章以父在鎮多違朝旨，嘗雪涕極諫，備陳逆順之理。",
    "entities": [
      {
        "text": "孝章以父在鎮",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000042",
    "sentence": "朝廷聞而嘉之，乃授檢校太子左諭德、兼侍御史，充節度副使。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000043",
    "sentence": "累遷至散騎常侍、兼御史大夫，賜紫。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000044",
    "sentence": "領本道兵同平滄景，加工部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000045",
    "sentence": "尋請赴闕，文宗慰勞甚厚，憲誠亦因懇乞朝覲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000046",
    "sentence": "上知憲誠之入覲，自孝章之謀，遂加禮部尚書，分相、衞、澶三州別爲一鎮，俾孝章領之。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "澶三州別爲一鎮",
        "label": "LOC",
        "start": 26,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000047",
    "sentence": "孝章未到鎮，憲誠遇害。",
    "entities": [
      {
        "text": "孝章未到鎮",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000048",
    "sentence": "上以孝章有忠節，起復爲右金吾衞將軍。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000049",
    "sentence": "間歲，授鄜坊節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000050",
    "sentence": "居四年，遷於滑。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000051",
    "sentence": "一歲，入爲右領軍大將軍，改右金吾大將軍，俄授邠寧節度。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 8,
        "end": 11
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000052",
    "sentence": "孝章歷三鎮，雖無異績，而謹身畏法，以保初終。",
    "entities": [
      {
        "text": "孝章歷三鎮",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000053",
    "sentence": "開成三年十月卒，贈右僕射。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000054",
    "sentence": "何進滔",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000055",
    "sentence": "何進滔，靈武人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000056",
    "sentence": "曾祖孝物，祖俊，並本州軍校。",
    "entities": [
      {
        "text": "並本州",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000057",
    "sentence": "父默，夏州衙前兵馬使，檢校太子賓客，試太常卿。",
    "entities": [
      {
        "text": "夏州",
        "label": "LOC",
        "start": 3,
        "end": 5
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000058",
    "sentence": "以進滔之貴，贈左散騎常侍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000059",
    "sentence": "進滔客寄於魏，委質軍門，事節度使田弘正。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000060",
    "sentence": "弘正奉詔討鄆州，破李師道，時進滔爲衙內都知兵馬使，以功授兼侍御史。",
    "entities": [
      {
        "text": "弘正奉詔討鄆州",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000061",
    "sentence": "太和三年，軍眾害史憲誠，連聲而呼曰：「得衙內都知兵馬使何端公知留後，即三軍安矣。」推而立之。",
    "entities": [
      {
        "text": "太和三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000062",
    "sentence": "朝廷因授進滔左散騎常侍、魏博等州節度觀察處置等使。",
    "entities": [
      {
        "text": "魏博等州",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000063",
    "sentence": "爲魏帥十餘年，大得民情，累官至司徒、平章事卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000064",
    "sentence": "進滔子 弘敬",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000065",
    "sentence": "子弘敬襲其位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000066",
    "sentence": "朝廷時遣河中帥李執方、滄州帥劉約各遣使勸令歸闕，別俟朝旨。",
    "entities": [
      {
        "text": "滄州",
        "label": "LOC",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000067",
    "sentence": "弘敬不從，竟就加節制。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000068",
    "sentence": "及劉稹反，不時起兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000069",
    "sentence": "鎮州王元逵下邢、洺二州，兵次上黨，弘敬方出師壓境。",
    "entities": [
      {
        "text": "鎮州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "洺二州",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000070",
    "sentence": "大中後，宣宗務其姑息，繼加官爵，亦至使相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000071",
    "sentence": "咸通初，卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000072",
    "sentence": "子全皞嗣之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000073",
    "sentence": "朝廷尋降符節，累官亦至同平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000074",
    "sentence": "十一年，爲軍人所害。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000075",
    "sentence": "子孫相繼，四十餘年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000076",
    "sentence": "韓允忠",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000077",
    "sentence": "韓允忠，魏州人也。",
    "entities": [
      {
        "text": "魏州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000078",
    "sentence": "舊名君雄，懿宗改賜今名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000079",
    "sentence": "父國昌，歷本州右職。",
    "entities": [
      {
        "text": "歷本州",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000080",
    "sentence": "會昌中，從何弘敬破劉稹，以功爲貝州刺史、兼御史中丞。",
    "entities": [
      {
        "text": "以功爲貝州",
        "label": "LOC",
        "start": 12,
        "end": 17
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 17,
        "end": 19
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000081",
    "sentence": "以允忠故，累贈兵部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000082",
    "sentence": "允忠少仕軍門，繼升裨校。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000083",
    "sentence": "潞州之役，亦與其行。",
    "entities": [
      {
        "text": "潞州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000084",
    "sentence": "咸通十一年，何全皞爲軍眾所殺，推允忠爲帥。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000085",
    "sentence": "時僖宗爲普王，即降詔遙領節度，授允忠左散騎常侍、兼御史中丞，充節度觀察留後。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000086",
    "sentence": "不數月，轉檢校工部尚書、魏州大都督府長史、充魏博節度觀察等使。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "魏州",
        "label": "LOC",
