        "label": "LOC",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000087",
    "sentence": "累加至檢校司空、同平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000088",
    "sentence": "乾符元年十一月卒，年六十一。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000089",
    "sentence": "累贈太尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000090",
    "sentence": "允忠子 簡",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000091",
    "sentence": "子簡，自允忠初授戎帥，便爲節度副使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000092",
    "sentence": "乾符初，累官至檢校工部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000093",
    "sentence": "允忠卒，即起復爲節度觀察留後。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000094",
    "sentence": "逾月，加檢校右僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000095",
    "sentence": "其後累加至侍中，封昌黎郡王。",
    "entities": [
      {
        "text": "封昌黎郡",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000096",
    "sentence": "賊巢之亂，諸葛爽受其偽命河陽節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000097",
    "sentence": "時僖宗在蜀，寇盜蜂起，簡據有六州，甲兵強盛，竊懷僭亂之志，且欲啟其封疆，乃舉兵攻河陽，爽棄城而走。",
    "entities": [
      {
        "text": "簡據有六州",
        "label": "LOC",
        "start": 11,
        "end": 16
      },
      {
        "text": "爽棄城",
        "label": "LOC",
        "start": 43,
        "end": 46
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000098",
    "sentence": "簡遂留兵保守，因北掠邢、洺而歸，遂移軍攻鄆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000099",
    "sentence": "鄆帥曹全晸出戰，爲簡所敗，死之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000100",
    "sentence": "鄆將崔君裕收合殘眾，保鄆州。",
    "entities": [
      {
        "text": "保鄆州",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000101",
    "sentence": "簡進攻其城，半年不下，河陽復爲諸葛爽所襲。",
    "entities": [
      {
        "text": "簡進攻其城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000102",
    "sentence": "簡因欲先討君裕，次及河陽，乃舉兵至鄆，君裕請降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000103",
    "sentence": "尋移軍復攻河陽，行及新鄕，爲爽軍逆擊，敗之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000104",
    "sentence": "簡單騎奔回，憂憤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000105",
    "sentence": "疽發背而卒，時中和元年十一月也。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000106",
    "sentence": "樂彥禎",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000107",
    "sentence": "樂彥禎，魏州人也。",
    "entities": [
      {
        "text": "魏州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000108",
    "sentence": "父少寂，歷澶、博、貝三州刺史，贈工部尚書。",
    "entities": [
      {
        "text": "貝三州",
        "label": "LOC",
        "start": 9,
        "end": 12
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000109",
    "sentence": "彥禎少爲本州軍校。",
    "entities": [
      {
        "text": "彥禎少爲本州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000110",
    "sentence": "韓簡之領節旄也，以彥禎爲馬歩軍都虞候，轉博州刺史。",
    "entities": [
      {
        "text": "轉博州",
        "label": "LOC",
        "start": 19,
        "end": 22
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000111",
    "sentence": "下河陽，走諸葛爽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000112",
    "sentence": "有功，遷澶州刺史。",
    "entities": [
      {
        "text": "遷澶州",
        "label": "LOC",
        "start": 3,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000113",
    "sentence": "簡再討河陽之敗也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000114",
    "sentence": "彥禎以一軍先歸，魏人遂共立之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000115",
    "sentence": "朝廷尋授檢校工部尚書，知魏博留後。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000116",
    "sentence": "俄加戸部尚書，充節度觀察處置等使。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000117",
    "sentence": "中和四年，累加至尚書左僕射、同平章事。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000118",
    "sentence": "僖宗自蜀回，加開府儀同三司，冊拜司徒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000119",
    "sentence": "彥禎志滿驕大，動多不法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000120",
    "sentence": "一旦征六州之眾，板築羅城，約河門舊堤，周八十里，月餘而畢，人用怨咨。",
    "entities": [
      {
        "text": "一旦征六州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "板築羅城",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000121",
    "sentence": "彥禎子 從訓",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000122",
    "sentence": "又其子從訓天資悖逆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000123",
    "sentence": "王鐸自滑移鎮滄州，過魏郊，從訓見其女妓，利之，先伏兵於漳南高雞泊，俟鐸之至，圍而害之，掠其所有。",
    "entities": [
      {
        "text": "王鐸自滑移鎮",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "滄州",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000124",
    "sentence": "時朝廷微弱，不能詰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000125",
    "sentence": "魏人素知鐸名望，議者惜之，而罪從訓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000126",
    "sentence": "從訓又召亡命之徒五百餘輩，出入臥內，號爲「子將」，委以腹心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000127",
    "sentence": "軍人籍籍，各有異議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000128",
    "sentence": "從訓聞而忌之，易服遁出，止於近縣。",
    "entities": [
      {
        "text": "止於近縣",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000129",
    "sentence": "彥禎因命爲六州都指揮使。",
    "entities": [
      {
        "text": "彥禎因命爲六州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000130",
    "sentence": "未幾，又兼相州刺史。",
    "entities": [
      {
        "text": "又兼相州",
        "label": "LOC",
        "start": 3,
        "end": 7
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000131",
    "sentence": "到任之後，般輦軍器，取索錢帛，使人來往，交午塗路，軍府疑貳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000132",
    "sentence": "彥禎危憤而卒，眾推都將趙文㺹知留後事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000133",
    "sentence": "從訓自相州領兵三萬餘人至城下，文㺹按兵不出。",
    "entities": [
      {
        "text": "從訓自相州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "兵三萬餘人至城",
        "label": "LOC",
        "start": 6,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000134",
    "sentence": "眾懷疑懼，復害文㺹，推羅弘信爲帥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000135",
    "sentence": "弘信以兵出戰，敗之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000136",
    "sentence": "從訓招集餘眾，次於洹水。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000137",
    "sentence": "弘信遣將程公佐領兵討擊，大敗之，梟從訓首於軍門，時文德元年春也。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000138",
    "sentence": "羅弘信",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000139",
    "sentence": "羅弘信，字德孚，魏州貴鄕人。",
    "entities": [
      {
        "text": "魏州",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000140",
    "sentence": "曾祖秀，祖珍，父讓，皆爲本州軍校。",
    "entities": [
      {
        "text": "皆爲本州",
        "label": "LOC",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000141",
    "sentence": "弘信少從戎役，歷事節度使韓簡、樂彥禎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000142",
    "sentence": "光啟末，彥禎子從訓忌牙軍，出居於外，軍眾廢彥禎，推趙文㺹權主軍州事。",
    "entities": [
      {
        "text": "趙文㺹權主軍州",
        "label": "LOC",
        "start": 25,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000143",
    "sentence": "眾復以爲不便，因推弘信爲帥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000144",
    "sentence": "先是，有鄰人密謂弘信曰：「某嘗夜遇一白鬚翁，相告雲，君當爲土地主。如是者再三。」弘信竊異之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000145",
    "sentence": "及廢文㺹，軍人聚呼曰：「孰願爲節度使者？」弘信即應之曰：「白鬚翁早以命我。」眾乃環而視之，曰：「可也。」由是立之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000146",
    "sentence": "僖宗聞之，文德元年四月，詔加工部尚書，權知節度留後。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 7,
        "end": 9
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000147",
    "sentence": "七月，復加金紫光祿大夫、檢校尚書右僕射，充魏博節度觀察處置等使。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000148",
    "sentence": "龍紀中，加檢校司空、同平章事，封豫章郡公。",
    "entities": [
      {
        "text": "封豫章郡",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000149",
    "sentence": "乾寧中，朱全忠急攻兗鄆，朱瑄求援於太原。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000150",
    "sentence": "太原發軍，假道於魏，令大將李存信屯莘縣。",
    "entities": [
      {
        "text": "將李存信屯莘縣",
        "label": "LOC",
        "start": 12,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000151",
    "sentence": "存信御軍無法，侵魏之芻牧，弘信不平之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000152",
    "sentence": "全忠復遣人謂之曰：「太原志吞河朔，回戈之日，貴道堪憂。」弘信乃托好於汴，出師三萬攻存信，敗之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000153",
    "sentence": "太原怒，舉兵攻魏，營於觀音門外。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000154",
    "sentence": "汴將葛從周援之，屯於洹水。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000155",
    "sentence": "李克用子落落時爲鐵林軍使，爲從周所擒，乃退歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000156",
    "sentence": "自是太原之師，每歲侵擾相、魏，魏人患之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000157",
    "sentence": "朱全忠方事兗鄆，懼弘信離貳，每歲時賂遺，必卑辭厚禮答貺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000158",
    "sentence": "全忠對魏使北面拜而受之，曰：「六兄比予倍年已上，兄弟之國，安得以常鄰遇之。」弘信以爲厚己，亦推心焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000159",
    "sentence": "弘信累官至檢校太師、守侍中、臨清王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000160",
    "sentence": "光化元年九月卒，年六十三，贈太師，追封北平王，謚曰莊肅。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000161",
    "sentence": "子威。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000162",
    "sentence": "弘信子 威",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000163",
    "sentence": "威，字端己。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000164",
    "sentence": "文德初，授左散騎常侍，充天雄軍節度副使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000165",
    "sentence": "自龍紀至乾寧，十年之中，累加官爵。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000166",
    "sentence": "弘信卒，襲父位爲留後，朝廷從而命之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000167",
    "sentence": "天復末，累加至檢校太傅、兼侍中、長沙王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000168",
    "sentence": "天祐初，授檢校太尉、守侍中，進封鄴王，賜號「忠勤宣力致理功臣」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000169",
    "sentence": "魏之牙中軍者，自至德中，田承嗣盜據相、魏、澶、博、衞、貝等六州，召募軍中子弟置之部下，遂以爲號。",
    "entities": [
      {
        "text": "貝等六州",
        "label": "LOC",
        "start": 27,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000170",
    "sentence": "皆豐給厚賜，不勝驕寵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000171",
    "sentence": "年代浸遠，父子相襲，親黨膠固。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000172",
    "sentence": "其凶戾者，強買豪奪，逾法犯令，長吏不能禁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000173",
    "sentence": "變易主帥，有同兒戲，如史憲誠、何進滔、韓君雄、樂彥禎，皆爲其所立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000174",
    "sentence": "優獎小不如意，則舉族被害。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000175",
    "sentence": "威懲其往弊，雖以貨賂姑息，而心銜之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000176",
    "sentence": "威嗣世之明年，正月，幽州劉仁恭擁兵十萬，謀亂河朔，進陷貝州，長驅攻魏。",
    "entities": [
      {
        "text": "幽州",
        "label": "LOC",
        "start": 10,
        "end": 12
      },
      {
        "text": "進陷貝州",
        "label": "LOC",
        "start": 25,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000177",
    "sentence": "威求援於汴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000178",
    "sentence": "朱全忠遣將李思安屯於洹水。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000179",
    "sentence": "葛從周自邢、洺引軍入魏。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 10,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000180",
    "sentence": "燕將劉守文、單可及攻汴軍於內黃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000181",
    "sentence": "思安逆戰，大敗之，乘勝追躡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000182",
    "sentence": "從周出會掩擊，覆敗燕軍，斬首三萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000183",
    "sentence": "三年，威引汴軍攻滄州以報之。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "威引汴軍攻滄州",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000184",
    "sentence": "自是，威感全忠援助之恩，合從景附。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000185",
    "sentence": "天祐二年七月十三日夜，牙軍裨校李公佺作亂，威僅以身免。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000186",
    "sentence": "公佺出奔滄州。",
    "entities": [
      {
        "text": "公佺出奔滄州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000187",
    "sentence": "自是愈懼，遣使求援於全忠，密謀破之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000188",
    "sentence": "全忠遣李思安會魏博軍，再攻滄州。",
    "entities": [
      {
        "text": "再攻滄州",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000189",
    "sentence": "全忠女妻威子廷規，先是卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000190",
    "sentence": "全忠遣長直軍校馬嗣勳選兵千人，密於輿中實兵甲入魏，言助女葬事。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 23,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000191",
    "sentence": "三年正月五日，嗣勳至，全忠親率大軍濟河，言視行營於滄景。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000192",
    "sentence": "威欲因而出迎，至期，即假全忠帳下銳卒入而夾攻之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000193",
    "sentence": "牙軍頗疑，堅請不出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000194",
    "sentence": "威恐洩其事，慰納之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000195",
    "sentence": "是月十四日夜，率廝養百十輩，與嗣勳合攻之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000196",
    "sentence": "時宿於牙城者千人，遲明殺之殆盡；凡八千家，皆破其族。",
    "entities": [
      {
        "text": "時宿於牙城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000197",
    "sentence": "魏軍攻滄州者，在歷亭聞有變，其將史仁遇擁之，保於高唐。",
    "entities": [
      {
        "text": "魏軍攻滄州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000198",
    "sentence": "六州之內，皆爲讎敵，累月平之。",
    "entities": [
      {
        "text": "六州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000199",
    "sentence": "威仕梁數年後卒，年三十四，位至守太師、兼中書令，贈尚書令，謚曰貞壯。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000200",
    "sentence": "威性明敏，達於吏道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000201",
    "sentence": "伏膺儒術，招納文人，聚書至萬卷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000202",
    "sentence": "每花朝月夕，與賓佐賦詠，甚有情致。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000203",
    "sentence": "錢塘人羅隱者，有當世詩名，自號「江東生」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000204",
    "sentence": "威遣使賂遺，敘其宗姓，推爲叔父。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000205",
    "sentence": "隱亦集其詩寄之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000206",
    "sentence": "威酷嗜其作，目己所爲曰《偷江東集》，凡五卷，今鄴中人士諷詠之。",
    "entities": [
      {
        "text": "《偷江東集》",
        "label": "TITLE",
        "start": 11,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000207",
    "sentence": "史臣曰",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000208",
    "sentence": "史臣曰：魏、鎮、燕三鎮，不能制之也久矣。",
    "entities": [
      {
        "text": "燕三鎮",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_181_000209",
    "sentence": "兵強地廣，合從連衡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000210",
    "sentence": "爵命雖假於朝廷，群臣自謀於元帥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000211",
    "sentence": "如史憲誠等五家，其初皆因此而得之，其後亦因此而失之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000212",
    "sentence": "蓋不知取之以權，守之以仁，則遠矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000213",
    "sentence": "若善繼者，史氏、羅氏之二子有焉，其餘不足觀也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000214",
    "sentence": "贊",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000215",
    "sentence": "贊曰：逆取順守，古亦有之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000216",
    "sentence": "如其逆守，滅亡必隨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000217",
    "sentence": "史、何、韓、樂，世數盛衰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000218",
    "sentence": "足以爲鑒，念茲在茲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_181_000219",
    "sentence": "本五代作品在全世界都属于 公有领域 ，因为作者逝世已经遠遠超过100年。",
    "entities": [
      {
        "text": "100年",
        "label": "TME",
        "start": 31,
        "end": 35
      }
    ]
  }
]
