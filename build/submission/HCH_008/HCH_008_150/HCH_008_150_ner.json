    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000163",
    "sentence": "史臣曰：夫聖人君臨宇縣，肇啟邦基，莫不受命上玄，膺名帝箓。",
    "entities": [
      {
        "text": "夫聖人君臨宇縣",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000164",
    "sentence": "自太昊已降，五運相推，迄於殷湯，歷數綿永。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000165",
    "sentence": "但設均平之化，未聞封建之名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000166",
    "sentence": "洎乎周、漢，始以子弟建侯樹屏，以作維城。",
    "entities": [
      {
        "text": "以作維城",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000167",
    "sentence": "及王室浸微，遂有莽、卓之亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000168",
    "sentence": "唐室自艱難已後，兩河兵革屢興，諸王雖封，竟不出閣，夫帝王居寰宇之尊，撫億兆之眾，但能平一理道，夙夜嚴恭，任賢使能，設官分職，自然四海樂推。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000169",
    "sentence": "天命所祐，縱無封建，亦鴻基永固，安俟嬰孺鎮重哉？",
    "entities": [
      {
        "text": "安俟嬰孺鎮",
        "label": "LOC",
        "start": 16,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000170",
    "sentence": "贊曰：孝文秉禮，道弘籓邸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000171",
    "sentence": "睦族展親，儀刑戚裏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000172",
    "sentence": "自閣臨籓，所謂周爰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000173",
    "sentence": "無如惡鳥，終懷籠樊。",
    "entities": []
  },
