        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000028",
    "sentence": "江西節度使嗣曹王臯為前軍兵馬使，鄂嶽團練使李兼為之副。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000029",
    "sentence": "山南東道節度使賈耽為中軍兵馬使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000030",
    "sentence": "荊南節度使張伯儀充後軍兵馬使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000031",
    "sentence": "以左神武軍使王價檢校太子賓客；左衛將軍高承謙檢校太子詹事；前司農少卿郭曙檢校左庶子，前秘書省著作郎常願為秘書少監，並充元帥府押衙。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 17,
        "end": 19
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000032",
    "sentence": "制下未行，涇原兵亂而止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000033",
    "sentence": "德宗初聞兵士出怨言，不得賞設，乃令誼與翰林學士姜公輔傳詔安撫，許以厚賞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000034",
    "sentence": "行及內門，兵已陣於闕前；誼狼狽而還，遂奉德宗出幸奉天。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000035",
    "sentence": "賊之攻城，誼晝夜傳詔，慰勞諸軍，僅不解帶者月餘。",
    "entities": [
      {
        "text": "賊之攻城",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000036",
    "sentence": "從車駕還宮，復封舒王、開府儀同三司，揚州大都督如故。",
    "entities": [
      {
        "text": "揚州",
        "label": "LOC",
        "start": 18,
        "end": 20
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000037",
    "sentence": "永貞元年十月薨，廢朝三日。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000038",
    "sentence": "通王諶，德宗第三子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000039",
    "sentence": "大曆十四年封，制授開府儀同三司。",
    "entities": [
      {
        "text": "十四年",
        "label": "TME",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000040",
    "sentence": "貞元九年十月，領宣武軍節度大使、汴宋等州觀察支度營田等使，以宣武都知兵馬使李萬榮為留後，王不出閣。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "汴宋等州",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000041",
    "sentence": "十一年，河東帥李自良卒，以諶為河東節度大使，以行軍司馬李說知府事，充留後，亦不出閣。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000042",
    "sentence": "虔王諒，德宗第四子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000043",
    "sentence": "大曆十四年封，授開府儀同三司。",
    "entities": [
      {
        "text": "十四年",
        "label": "TME",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000044",
    "sentence": "貞元二年，領蔡州節度大使、申光蔡觀察等使，以大將吳少誠為留後。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "領蔡州",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000045",
    "sentence": "十年，領朔方靈鹽節度大使、靈州大都督，以朔方行軍司馬李欒為靈府左司馬，知府事，朔方留後。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
