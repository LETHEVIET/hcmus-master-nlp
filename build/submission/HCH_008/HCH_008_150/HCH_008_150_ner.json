        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000046",
    "sentence": "十一年九月，橫海大將程懷信逐其帥懷直。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000047",
    "sentence": "十月，以諒領橫海節度大使、滄景觀察等使，以都知兵馬使程懷信為留後，王不出閣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000048",
    "sentence": "十六年，徐帥張建封卒，徐軍亂，又以諒領徐州節度大使、徐泗濠觀察處置等使，以建封子愔為留後。",
    "entities": [
      {
        "text": "十六年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "又以諒領徐州",
        "label": "LOC",
        "start": 15,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000049",
    "sentence": "肅王詳，德宗第五子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000050",
    "sentence": "大曆十四年六月封。",
    "entities": [
      {
        "text": "十四年",
        "label": "TME",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000051",
    "sentence": "建中三年十月薨，時年四歲，廢朝三日，贈揚州大都督。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "贈揚州",
        "label": "LOC",
        "start": 18,
        "end": 21
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000052",
    "sentence": "性聰惠，上尤憐之，追念無已，不令起墳墓，詔如西域法，議層磚造塔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000053",
    "sentence": "禮儀使判官、司門郎中李巖上言曰：「墳墓之義，經典有常，自古至今，無聞異制。層磚起塔，始於天竺，名曰『浮圖』，行之中華，竊恐非禮。況肅王天屬，名位尊崇，喪葬之儀，存乎簡冊，舉而不法，垂訓非輕。伏請準令造墳，庶遵典禮。」詔從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000054",
    "sentence": "文敬太子謜，順宗之子。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000055",
    "sentence": "德宗愛之，命為子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000056",
    "sentence": "貞元四年，封邕王，授開府儀同三司。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000057",
    "sentence": "七年，定州張孝忠卒，以謜領義武軍節度大使、易定觀察等使，以定州刺史張茂昭為留後。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "定州",
        "label": "LOC",
        "start": 3,
        "end": 5
