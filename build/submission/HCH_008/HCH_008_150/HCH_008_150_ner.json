  },
  {
    "sentence_id": "HCH_008_150_000002",
    "sentence": "德宗皇帝十一子：昭德皇后王氏生順宗皇帝；舒王誼，昭靖太子之子；文敬太子，順宗之子；諸妃生通王已下八王，本錄不載母氏。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 17,
        "end": 19
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 26,
        "end": 28
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000003",
    "sentence": "舒王誼，本名謨，代宗第三子昭靖太子邈之子也。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000004",
    "sentence": "以其最幼，德宗憐之，命之為子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000005",
    "sentence": "大曆十四年六月，封舒王，拜開府儀同三司，與通王、虔王同日封。",
    "entities": [
      {
        "text": "十四年",
        "label": "TME",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000006",
    "sentence": "仍詔所司，其開府俸料，逐月進內，尋以軍興罷支。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000007",
    "sentence": "建中元年，領四鎮北庭行軍、涇原節度大使；以涇州刺史孟皞為節度留後。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "領四鎮",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "以涇州",
        "label": "LOC",
        "start": 20,
        "end": 23
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000008",
    "sentence": "以誼愛弟之子，諸王之長，軍國大事，欲其更踐，必委試之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000009",
    "sentence": "明年，尚父郭子儀病篤，上御紫宸，命誼持制書省之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000010",
    "sentence": "誼冠遠遊冠，絳紗袍，乘象輅，駕駟馬，飛龍騎士三百人隨之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000011",
    "sentence": "國府之官，皆褲褶騎而導前，鹵簿備引而不樂，在遏密故也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000012",
    "sentence": "及門，郭氏子弟迎拜於外，王不答拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000013",
    "sentence": "子儀臥不能興，以手叩頭謝恩已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000014",
    "sentence": "王解冠珮，以常服傳詔勞問之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000015",
    "sentence": "三年，蔡帥李希烈叛，詔哥舒曜討之。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000016",
    "sentence": "八月，希烈自帥眾三萬，圍哥舒曜於襄城，又詔河南都統李勉援之。",
    "entities": [
      {
        "text": "圍哥舒曜於襄城",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000017",
    "sentence": "勉舍襄城，令大將唐漢臣等選勁兵，徑襲許州以解圍。",
    "entities": [
      {
        "text": "勉舍襄城",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "徑襲許州",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000018",
    "sentence": "漢臣未至許，上遣中使追之，責以違詔，亟旋師，為賊所乘，漢臣之眾大敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000019",
    "sentence": "勉恐東都危急，乃分兵數千赴洛，又為賊所隔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000020",
    "sentence": "賊眾急攻汴、滑，勉走宋州，朝廷大聳，乃詔誼為揚州大都督，持節荊襄、江西、沔鄂等道節度，兼諸軍行營兵馬元帥，改名誼。",
    "entities": [
      {
        "text": "勉走宋州",
        "label": "LOC",
        "start": 8,
        "end": 12
      },
      {
        "text": "乃詔誼為揚州",
        "label": "LOC",
        "start": 18,
        "end": 24
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000021",
    "sentence": "又以哥舒翰聲近，士卒竊議，改封普王，令統攝諸軍，進攻希烈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000022",
    "sentence": "仍以兵部侍郎蕭復為戶部尚書、兼御史大夫、元帥府統軍長史。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "尚書",
        "label": "TITLE",
