        "end": 13
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000023",
    "sentence": "舊例有行軍長史，以復父名衡，特更之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000024",
    "sentence": "又以新除潭州觀察使孔巢父為右庶子、兼御史大夫，充行軍司馬；以山南東道節度行軍司馬、檢校兵部郎中、兼御史中丞樊澤為諫議大夫、兼御史中丞、行軍右司馬。",
    "entities": [
      {
        "text": "又以新除潭州",
        "label": "LOC",
