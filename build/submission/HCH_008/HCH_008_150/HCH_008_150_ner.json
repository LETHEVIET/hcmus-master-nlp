      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000025",
    "sentence": "刑部員外郎劉從一為吏部郎中、兼中丞；侍御史韋儹為工部郎中、兼中丞，並充元帥府判官。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_150_000026",
    "sentence": "兵部員外郎高參為本司郎中，充元帥府掌書記。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_150_000027",
    "sentence": "以右金吾大將軍渾瑊檢校工部尚書、兼御史大夫，為中軍虞候。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
