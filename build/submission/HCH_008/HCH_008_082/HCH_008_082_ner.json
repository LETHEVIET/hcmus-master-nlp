        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_082_000082",
    "sentence": "寄切宗祧，事隆監撫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000083",
    "sentence": "思皇茂則，敬詢端輔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000084",
    "sentence": "業光啟、誦，藝優干羽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000085",
    "sentence": "九載崇儒，三朝問豎，歷選儲儀，遺文在斯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000086",
    "sentence": "望試登俎，高諭喬枝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000087",
    "sentence": "俯容思順，非禮無施。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000088",
    "sentence": "前修盛業，來哲通規。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000089",
    "sentence": "飭躬是蹈，則叡問風馳；立志或爽，則玄猷日虧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000090",
    "sentence": "無恃尊極，修途難測；無恃親賢，失德靡全。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000091",
    "sentence": "勿輕小善，積小而名自聞；勿輕微行，累微而身自正。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000092",
    "sentence": "佞諛有類，邪巧多方。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000093",
    "sentence": "其萌不絕，其害必彰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000094",
    "sentence": "監言斯屏，儲業攸昌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000095",
    "sentence": "竊惟令嗣，有殊前事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000096",
    "sentence": "雖以貴以賢，而非長非次。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000097",
    "sentence": "皇明眷德，超倫作貳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000098",
    "sentence": "匪懋聲華，莫酬恩異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000099",
    "sentence": "匪崇徽烈，莫符天志。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000100",
    "sentence": "勉之又勉，光茲守器。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000101",
    "sentence": "下臣司箴，敢告近侍。",
    "entities": []
  },
