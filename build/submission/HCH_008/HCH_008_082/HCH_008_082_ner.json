  },
  {
    "sentence_id": "HCH_008_082_000072",
    "sentence": "化昭淳樸，道映典墳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000073",
    "sentence": "功成揖讓，事極華、勳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000074",
    "sentence": "肇興夏啟，降及姬文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000075",
    "sentence": "咸資繼德，永樹高芬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000076",
    "sentence": "百代沿襲，千齡奉聖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000077",
    "sentence": "粵若我後，丕承寶命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000078",
    "sentence": "允穆三階，爰齊七政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000079",
    "sentence": "時雍化洽，風移俗盛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000080",
    "sentence": "載崇國本，式延家慶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000081",
    "sentence": "《震》維標德，《離》警體正。",
    "entities": [
