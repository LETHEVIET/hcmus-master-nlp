  },
  {
    "sentence_id": "HCH_008_082_000069",
    "sentence": "邃初冥昧，元氣氤氳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000070",
    "sentence": "二儀始闡，三才既分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_082_000071",
    "sentence": "司乾立宰，出《震》為君。",
