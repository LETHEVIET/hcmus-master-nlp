[
  {
    "sentence_id": "HCH_008_123_000001",
    "sentence": "劉晏",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000002",
    "sentence": "劉晏，字士安，曹州南華人。",
    "entities": [
      {
        "text": "曹州",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000003",
    "sentence": "年七歲，舉神童，授秘書省正字。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000004",
    "sentence": "累授夏縣令，有能名。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000005",
    "sentence": "歷殿中侍御史，遷度支郎中、杭隴華三州刺史，尋遷河南尹。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "杭隴華三州",
        "label": "LOC",
        "start": 13,
        "end": 18
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000006",
    "sentence": "時史朝義盜據東都，寄理長水。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000007",
    "sentence": "入為京兆尹，頃之，加戶部侍郎、兼御史中丞，判度支，委府事於司錄張群、杜亞，綜大體，議論號為稱職。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000008",
    "sentence": "無何，為酷吏敬羽所構，貶通州刺史。",
    "entities": [
      {
        "text": "貶通州",
        "label": "LOC",
        "start": 11,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000009",
    "sentence": "復入為京兆尹、戶部侍郎，判度支。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000010",
    "sentence": "時顏真卿以文學正直出為利州刺史，晏舉真卿自代為戶部，乃加國子祭酒。",
    "entities": [
      {
        "text": "學正直出為利州",
        "label": "LOC",
        "start": 6,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000011",
    "sentence": "寶應二年，遷吏部尚書、平章事，領度支鹽鐵轉運租庸使。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000012",
    "sentence": "坐與中官程元振交通，元振得罪，晏罷相，為太子賓客。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000013",
    "sentence": "尋授御史大夫，領東都、河南、江淮、山南等道轉運租庸鹽鐵使如故。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000014",
    "sentence": "時新承兵戈之後，中外艱食，京師米價鬥至一千，官廚無兼時之積，禁軍乏食，畿縣百姓乃挼穗以供之。",
    "entities": [
      {
        "text": "畿縣",
        "label": "LOC",
        "start": 35,
        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000015",
    "sentence": "晏受命後，以轉運為己任，凡所經歷，必究利病之由。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000016",
    "sentence": "至江淮，以書遺元載曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000017",
    "sentence": "浮於淮、泗，達於汴，入於河，西循底柱、硤石、少華，楚帆越客，直抵建章、長樂，此安社稷之奇策也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000018",
    "sentence": "晏賓於東朝，猶有官謗，相公終始故舊，不信流言，賈誼復召宣室，弘羊重興功利，敢不悉力以答所知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000019",
    "sentence": "驅馬陜郊，見三門渠津遺跡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000020",
    "sentence": "到河陰、鞏、洛，見宇文愷置梁公堰，分黃河水入通濟渠；大夫李傑新堤故事，飾像河廟，凜然如生。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000021",
    "sentence": "涉滎郊、浚澤，遙瞻淮甸，步步探討，知昔人用心，則潭、衡、桂陽必多積谷，關輔汲汲，只緣兵糧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000022",
    "sentence": "漕引瀟、湘、洞庭，萬里幾日，淪波卦席，西指長安。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000023",
    "sentence": "三秦之人，待此而飽；六軍之眾，待此而強。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000024",
    "sentence": "天子無側席之憂，都人見泛舟之役；四方旅拒者可以破膽，三河流離者於茲請命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000025",
    "sentence": "相公匡戴明主，為富人侯，此今之切務，不可失也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000026",
    "sentence": "使仆湔洗瑕穢，率罄愚懦，當憑經義，請護河堤，冥勤在官，不辭水死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000027",
    "sentence": "然運之利病，各有四五焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000028",
    "sentence": "晏自尹京入為計相，共五年矣。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000029",
    "sentence": "京師三輔百姓，唯苦稅畝傷多，若使江、湖米來每年三二十萬，即頓減徭賦，歌舞皇澤，其利一也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000030",
    "sentence": "東都殘毀，百無一存。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000031",
    "sentence": "若米運流通，則饑人皆附，村落邑厘，從此滋多。",
    "entities": [
      {
        "text": "村落邑",
        "label": "LOC",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000032",
    "sentence": "受命之日引海陵之倉以食鞏、洛，是計之得者，其利二也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000033",
    "sentence": "諸將有在邊者，諸戎有侵敗王略者，或聞三江、五湖，貢輸紅粒，雲帆桂楫，輸納帝鄉，軍誌曰：「先聲後實，可以震耀夷夏。」其利三也。",
    "entities": [
      {
        "text": "輸納帝鄉",
        "label": "LOC",
        "start": 34,
        "end": 38
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000034",
    "sentence": "自古帝王之盛，皆云書同文，車同軌，日月所照，莫不率俾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000035",
    "sentence": "今舟車既通，商賈往來，百貨雜集，航海梯山，聖神輝光，漸近貞觀、永徽之盛，其利四也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000036",
    "sentence": "所可疑者，函、陜雕殘，東周尤甚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000037",
    "sentence": "過宜陽、熊耳，至武牢、成臯，五百里中，編戶千余而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000038",
    "sentence": "居無尺椽，人無煙爨，蕭條淒慘，獸遊鬼哭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000039",
    "sentence": "牛必羸角，輿必說輹，棧車輓漕，亦不易求。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000040",
    "sentence": "今於無人之境，興此勞人之運，固難就矣，其病一也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000041",
    "sentence": "河、汴有初，不修則毀澱，故每年正月發近縣丁男，塞長茭，決沮淤，清明桃花已後，遠水自然安流，陽侯、宓妃，不復太息。",
    "entities": [
      {
        "text": "每年正月發近縣",
        "label": "LOC",
        "start": 13,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000042",
    "sentence": "頃因寇難，總不掏拓，澤滅水，岸石崩，役夫需於沙，津吏旋於濘，千里洄上，罔水舟行，其病二也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000043",
    "sentence": "東垣、底柱，澠池、二陵，北河運處五六百里，戍卒久絕，縣吏空拳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000044",
    "sentence": "奪攘奸宄，窟穴囊橐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000045",
    "sentence": "夾河為藪，豺狼狺狺，舟行所經，寇亦能往，其病三也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000046",
    "sentence": "東自淮陰，西臨蒲阪，亙三千里，屯戍相望。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000047",
    "sentence": "中軍皆鼎司元侯，賤卒儀同青紫，每雲食半菽，又雲無挾纊，輓漕所至，船到便留，即非單車使折簡書所能制矣，其病四也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000048",
    "sentence": "惟小子畢其慮奔走之，惟中書詳其利病裁成之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000049",
    "sentence": "晏累年已來，事缺名毀，聖慈含育，特賜生全。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000050",
    "sentence": "月余家居，遽即臨遣，恩榮感切，思殞百身。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000051",
    "sentence": "見一水不通，願荷鍤而先往；見一粒不運，願負米而先趨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000052",
    "sentence": "焦心苦形，期報明主，丹誠未克，漕引多虞，屏營中流，掩泣獻狀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000053",
    "sentence": "自此每歲運米數十萬石以濟關中。",
    "entities": [
      {
        "text": "數十萬石以濟關",
        "label": "LOC",
        "start": 6,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000054",
    "sentence": "又至德初，為國用不足，令第五琦於諸道榷鹽以助軍用，及晏代其任，法益精密，官無遺利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000055",
    "sentence": "初，歲入錢六十萬貫，季年所入逾十倍，而人無厭苦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000056",
    "sentence": "大歷末，通計一歲征賦所入總一千二百萬貫，而鹽利且過半。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000057",
    "sentence": "累遷吏部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000058",
    "sentence": "大歷四年六月，與右僕射裴遵慶同赴本曹視事，敕尚食增置儲供，許內侍魚朝恩及宰臣已下常朝官鹹詣省送上。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000059",
    "sentence": "八年，知三銓選事。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000060",
    "sentence": "十二年三月，誅宰臣元載，晏奉詔訊鞫。",
    "entities": [
      {
        "text": "十二年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000061",
    "sentence": "晏以載居任樹黨，布於天下，不敢專斷，請他官共事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000062",
    "sentence": "敕御史大夫李涵、右散騎常侍蕭昕、兵部侍郎袁傪、禮部侍郎常袞、諫議大夫杜亞同推，載皆款伏。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 1,
        "end": 3
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 25,
        "end": 27
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000063",
    "sentence": "初，晏承旨，門下侍郎、同平章事王縉亦處極法，晏謂涵等曰：重刑再覆，國之常典，況誅大臣，得不覆奏？",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000064",
    "sentence": "又法有首從，二人同刑，亦宜重取進止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000065",
    "sentence": "」涵等從命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000066",
    "sentence": "及晏等覆奏，代宗乃減縉罪從輕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000067",
    "sentence": "縉之生，晏平反之力也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000068",
    "sentence": "十三年十二月，為尚書左僕射。",
    "entities": [
      {
        "text": "十三年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000069",
    "sentence": "時宰臣常袞專政，以晏久掌銓衡，時議平允，兼司儲蓄，職舉功深，慮公望日崇，上心有屬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000070",
    "sentence": "竊忌之，乃奏晏朝廷舊德，宜為百吏師長，外示崇重，內實去其權。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000071",
    "sentence": "及奏上，以晏使務方理，代其任者難其人，使務、知三銓並如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000072",
    "sentence": "李靈曜之亂也，河南節帥所據，多不奉法令，征賦亦隨之；州縣雖益減，晏以羨余相補，人不加賦，所入仍舊，議者稱其能。",
    "entities": [
      {
        "text": "州縣",
        "label": "LOC",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000073",
    "sentence": "自諸道巡院距京師，重價募疾足，置遞相望，四方物價之上下，雖極遠不四五日知，故食貨之重輕，盡權在掌握，朝廷獲美利而天下無甚貴甚賤之憂，得其術矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000074",
    "sentence": "凡所任使，多收後進有幹能者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000075",
    "sentence": "其所總領，務乎急促，趨利者化之，遂以成風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000076",
    "sentence": "當時權勢，或以親戚為托，晏亦應之，俸給之多少，命官之遲速，必如其誌，然未嘗得親職事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000077",
    "sentence": "其所領要務，必一時之選，故晏沒後二十余年，韓洄、元琇、裴腆、包佶、盧征、李衡繼掌財賦，皆晏故吏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000078",
    "sentence": "其部吏居數千里之外，奉教令如在目前，雖寢興宴語，而無欺紿，四方動靜，莫不先知，事有可賀者，必先上章奏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000079",
    "sentence": "江淮茶、橘，晏與本道觀察使各歲貢之，皆欲其先至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000080",
    "sentence": "有土之官，或封山斷道，禁前發者，晏厚以財力致之，常先他司，由是甚不為籓鎮所便。",
    "entities": [
      {
        "text": "由是甚不為籓鎮",
        "label": "LOC",
        "start": 29,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000081",
    "sentence": "晏理家以儉約稱，而重交敦舊，頗以財貨遺天下名土，故人多稱之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000082",
    "sentence": "善訓諸子，鹹有學藝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000083",
    "sentence": "任事十余年，權勢之重，鄰於宰相，要官重職，頗出其門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000084",
    "sentence": "既有材力，視事敏速，乘機無滯，然多任數，挾權貴，固恩澤，有口者必利啖之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000085",
    "sentence": "當大歷時，事貴因循，軍國之用，皆仰於晏，未嘗檢轄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000086",
    "sentence": "德宗嗣位，言事者稱轉運可罷多矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000087",
    "sentence": "初，楊炎為吏部侍郎，晏為尚書，各恃權使氣，兩不相得。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000088",
    "sentence": "炎坐元載貶，晏快之，昌言於朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000089",
    "sentence": "及炎入相，追怒前事，且以晏與元載隙憾，時人言載之得罪，晏有力焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000090",
    "sentence": "炎將為載復仇，又時人風言代宗寵獨孤妃而又愛其子韓王迥，晏密啟請立獨孤為皇后。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 35,
        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000091",
    "sentence": "炎因對易攵流涕奏言：「賴祖宗福祐，先皇與陛下不為賊臣所間。不然，劉晏、黎幹之輩，搖動社稷，兇謀果矣。今幹以伏罪，晏猶領權，臣為宰相，不能正持此事，罪當萬死。」崔祐甫奏言：「此事曖昧，陛下以廓然大赦，不當究尋虛語。」硃泚、崔寧又從傍與祐甫救解之，寧言頗切，炎大怒，故斥寧令出鎮鄜坊以摧挫之。",
    "entities": [
      {
        "text": "故斥寧令出鎮",
        "label": "LOC",
        "start": 131,
        "end": 137
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000092",
    "sentence": "遂罷晏轉運等使，尋貶為忠州刺史。",
    "entities": [
      {
        "text": "尋貶為忠州",
        "label": "LOC",
        "start": 8,
        "end": 13
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000093",
    "sentence": "炎欲誣構其罪，知庾準與晏素有隙，舉為荊南節度，以伺晏動靜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000094",
    "sentence": "準乃奏晏與硃泚書祈救解，言多怨望，炎又證成其事，上以為然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000095",
    "sentence": "是月庚午，晏已受誅，使回奏報，誣晏以忠州謀叛，下詔暴言其罪，時年六十六，天下冤之。",
    "entities": [
      {
        "text": "誣晏以忠州",
        "label": "LOC",
        "start": 15,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000096",
    "sentence": "家屬徙嶺表，連累者數十人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000097",
    "sentence": "貞元五年，上悟，方錄晏子執經，授太常博士；少子宗經，秘書郎。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "博士",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000098",
    "sentence": "執經上請削官贈父，特追贈鄭州刺史。",
    "entities": [
      {
        "text": "特追贈鄭州",
        "label": "LOC",
        "start": 9,
        "end": 14
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000099",
    "sentence": "第五琦",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000100",
    "sentence": "第五琦，京兆長安人。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000101",
    "sentence": "少孤，事兄華，敬順過人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000102",
    "sentence": "及長，有吏才，以富國強兵之術自任。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000103",
    "sentence": "天寶初，事韋堅，堅敗貶官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000104",
    "sentence": "累至須江丞，時太守賀蘭進明甚重之。",
    "entities": [
      {
        "text": "太守",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000105",
    "sentence": "會安祿山反，進明遷北海郡太守，奏琦為錄事參軍。",
    "entities": [
      {
        "text": "進明遷北海郡",
        "label": "LOC",
        "start": 6,
        "end": 12
      },
      {
        "text": "太守",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000106",
    "sentence": "祿山已陷河間、信都等五郡，進明未有戰功，玄宗大怒，遣中使封刀促之，曰：「收地不得，即斬進明之首。」進明惶懼，莫知所出，琦乃勸令厚以財帛募勇敢士，出奇力戰，遂收所陷之郡。",
    "entities": [
      {
        "text": "信都等五郡",
        "label": "LOC",
        "start": 7,
        "end": 12
      },
      {
        "text": "遂收所陷之郡",
        "label": "LOC",
        "start": 77,
        "end": 83
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000107",
    "sentence": "令琦奏事，至蜀中，琦得謁見，奏言：「方今之急在兵，兵之強弱在賦，賦之所出，江淮居多。若假臣職任，使濟軍須，臣能使賞給之資，不勞聖慮。」玄宗大喜，即日拜監察御史，勾當江淮租庸使。",
    "entities": [
      {
        "text": "蜀",
        "label": "ORG",
        "start": 6,
        "end": 7
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 77,
        "end": 79
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000108",
    "sentence": "尋拜殿中侍御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000109",
    "sentence": "尋加山南等五道度支使，促辦應卒，事無違闕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000110",
    "sentence": "遷司金郎中、兼御史中丞，使如故。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000111",
    "sentence": "於是創立鹽法，就山海井竈收榷其鹽，官置吏出糶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000112",
    "sentence": "其舊業戶並浮人願為業者，免其雜徭，隸鹽鐵使，盜煮私市罪有差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000113",
    "sentence": "百姓除租庸外，無得橫賦，人不益稅而上用以饒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000114",
    "sentence": "遷戶部侍郎、兼御史丞，專判度支，領河南等道支度都勾當轉運租庸鹽鐵鑄錢、司農太府出納、山南東西江西淮南館驛等使。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000115",
    "sentence": "乾元二年，以本官加同中書門下平章事。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000116",
    "sentence": "初，琦以國用未足，幣重貨輕，乃請鑄乾元重寶錢，以一當十行用之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000117",
    "sentence": "及作相，又請更鑄重輪乾元錢，一當五十，與乾元錢及開元通寶錢三品並行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000118",
    "sentence": "既而谷價騰貴，餓殣死亡，枕藉道路，又盜鑄爭起，中外皆以琦變法之弊，封奏日聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000119",
    "sentence": "乾元二年十月，貶忠州長史，既在道，有告琦受人黃金二百兩者，遣御史劉期光追按之。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "貶忠州",
        "label": "LOC",
        "start": 7,
        "end": 10
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000120",
    "sentence": "琦對曰：二百兩金十三斤重，忝為宰相，不可自持。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000121",
    "sentence": "若其付受有憑，即請準法科罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000122",
    "sentence": "」期光以為此是琦伏罪也，遽奏之，請除名，配流夷州，馳驛發遣，仍差綱領送至彼。",
    "entities": [
      {
        "text": "配流夷州",
        "label": "LOC",
        "start": 20,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000123",
    "sentence": "寶應初，起為朗州刺史，甚有能政，入遷太子賓客。",
    "entities": [
      {
        "text": "起為朗州",
        "label": "LOC",
        "start": 4,
        "end": 8
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000124",
    "sentence": "屬吐蕃寇陷京師，代宗幸陜，關內副元帥郭子儀請琦為糧料使、兼御史大夫，充關內元帥副使。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 29,
        "end": 31
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 31,
        "end": 33
      },
      {
        "text": "充關",
        "label": "LOC",
        "start": 34,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000125",
    "sentence": "未幾，改京兆尹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000126",
    "sentence": "車駕克復，專判度支，兼諸道鑄錢鹽鐵轉運常平等使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000127",
    "sentence": "累封扶風郡公。",
    "entities": [
      {
        "text": "累封扶風郡",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000128",
    "sentence": "又加京兆尹，改戶部侍郎，判度支。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000129",
    "sentence": "前後領財賦十余年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000130",
    "sentence": "魚朝恩伏誅，琦坐與款狎，出為處州刺史，歷饒、湖二州。",
    "entities": [
      {
        "text": "出為處州",
        "label": "LOC",
        "start": 12,
        "end": 16
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "湖二州",
        "label": "LOC",
        "start": 22,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000131",
    "sentence": "入為太子賓客、東都留司。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000132",
    "sentence": "上以其材，將復任用，召還京師，信宿而卒，年七十，贈太子少保。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000133",
    "sentence": "子峰，峰婦鄭氏女，皆以孝著，旌表其門。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000134",
    "sentence": "班宏",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000135",
    "sentence": "班宏，衛州汲人也。",
    "entities": [
      {
        "text": "衛州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000136",
    "sentence": "祖思簡，春官員外郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000137",
    "sentence": "父景倩，秘書監。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000138",
    "sentence": "宏少舉進士，授右司禦胄曹，後為薛景先鳳翔掌書記，又為高適劍南觀察判官，累拜大理司直，攝監察御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 45,
        "end": 47
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000139",
    "sentence": "時青城山有妖賊張安居以左道惑眾，事覺，多誣引大將，冀以緩死，宏驗理而速殺之，人心乃安。",
    "entities": [
      {
        "text": "時青城",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000140",
    "sentence": "既而郭英乂代適，以厭人望，奏署秘書郎，兼雒令，以疾免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000141",
    "sentence": "大歷三年，遷起居舍人，尋兼理匭使，四遷至給事中。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000142",
    "sentence": "時李寶臣卒於其位，子惟嶽匿喪求位，上遣宏使成德問疾，且喻之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000143",
    "sentence": "惟嶽厚賂宏，皆不受，還報合旨，遷刑部侍郎，兼京官考使。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000144",
    "sentence": "時右僕射崔寧考兵部侍郎劉乃上下，宏駁曰：「夷荒靖難，專在節制，尺籍伍符，不校省司。夫上行宣美之名，則下開趨競之路；上行阿容，下必朋黨。」因削去之。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000145",
    "sentence": "乃知而謝曰：「乃雖不敏，敢掠一美以僥二罪乎？」尋除吏部侍郎，為汪蕃會盟使李揆之副。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000146",
    "sentence": "貞元初，仍歲旱蝗，上以賦調為急，改戶部侍郎，為度支使韓滉之副。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000147",
    "sentence": "遷尚書，復副竇參。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000148",
    "sentence": "參初為大理司直，宏已為刑部侍郎，及參為相，領度支，上以宏久司國計，因令副之。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000149",
    "sentence": "且曰：「朕藉參宰相以臨遠，眾務悉委於卿，勿以辭也。」參以先貴，常私解悅之曰：「參後來，一朝居尚書之上，甚不自安，一年之後，當歸此使。」宏心喜，歲餘，參絕不復言。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 46,
        "end": 48
      },
      {
        "text": "一年",
        "label": "TME",
        "start": 56,
        "end": 58
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000150",
    "sentence": "宏性剛愎，為人間之，且怒食言，公事多異。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000151",
    "sentence": "揚子院，鹽鐵轉運委藏也，宏以御史中丞徐粲主之，既不理，且以賄聞，參欲代之，宏執不可。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000152",
    "sentence": "參又選諸院吏，未嘗訪宏，乃疏參所用者過惡以聞，事輒留中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000153",
    "sentence": "無何，參以使勞加吏部尚書，而宏進封蕭國公，怨參以虛號寵之，間惡愈甚。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000154",
    "sentence": "每奉詔營建，宏必極壯麗，親程課役，又厚結權幸以傾參。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000155",
    "sentence": "張滂先善於宏，宏薦為司農少卿，及參欲以滂分掌江淮鹽鐵，詢之於宏，宏以滂嫉惡，慮以法繩徐粲，因曰：「滂強戾難制，不可用。」滂知之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000156",
    "sentence": "八年三月，參遂為上所疏，乃讓度支使，遂以宏專判，而參不欲使務悉歸於宏，問計京兆尹薛玨，玨曰：「二子交惡，而滂剛決，若分鹽鐵轉運於滂，必能制宏。」參乃薦滂為戶部侍郎、鹽鐵使、判轉運，尚隸於宏以悅之。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 79,
        "end": 81
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000157",
    "sentence": "江淮兩稅，悉宏主之，置巡院，然令宏、滂共擇其官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000158",
    "sentence": "滂請鹽鐵舊簿書於宏，宏不與之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000159",
    "sentence": "每署院官，宏、滂更相是非，莫有用者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000160",
    "sentence": "滂乃奏曰：「班宏與臣相戾，巡院多闕官。臣掌財賦，國家大計，職不修，無所逃罪。今宏若此，何以輯事？」遂令分掌之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000161",
    "sentence": "無幾，宏言於宰相趙憬、陸贄曰：「宏職轉運，年運江淮米五十萬斛，前年增七十萬斛，以實太倉，幸無過。今職移於人，不知何謂？」滂時在側，忿然曰：「尚書失言甚矣！若運務畢舉，朝廷固不奪之，蓋由喪公錢、縱奸吏故也。且凡為度支胥吏，不一歲，資累鉅萬，僮馬第宅，僭於王公，非盜官財何以致是？道呼喧喧，無不知之，聖上故令滂分掌。公向所言，無乃歸怨於上乎、」宏默然不對。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 70,
        "end": 72
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000162",
    "sentence": "是日，宏稱疾於第，滂往問之，宏不見，憬、贄乃以宏、滂之言上聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000163",
    "sentence": "由是遵大歷故事，如劉晏、韓滉所分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000164",
    "sentence": "滂至揚州按徐粲，逮仆妾子侄，得贓鉅萬，乃徙嶺表。",
    "entities": [
      {
        "text": "滂至揚州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_123_000165",
    "sentence": "故參得罪，宏頗有力焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000166",
    "sentence": "勤恪官署，晨入夕歸，下吏勞而未嘗厭苦，清白勤幹，稱之於時。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_123_000167",
    "sentence": "貞元八年七月卒，年七十三，廢朝，加贈，謚曰敬。",
    "entities": [
