      }
    ]
  },
  {
    "sentence_id": "HCH_008_095_000206",
    "sentence": "母隨琄，竟以憂死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000207",
    "sentence": "七載，琄於夜郎安置，後移南浦郡。",
    "entities": [
