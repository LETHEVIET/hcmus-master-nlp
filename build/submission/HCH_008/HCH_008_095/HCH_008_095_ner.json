      }
    ]
  },
  {
    "sentence_id": "HCH_008_095_000215",
    "sentence": "無子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000216",
    "sentence": "史臣曰",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000217",
    "sentence": "史臣曰：夫得天下而治者，其道舒而有變；讓天下而退者，其道卷而常存。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000218",
    "sentence": "何者？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000219",
    "sentence": "飛龍在天，舒也；亢龍有悔，變也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000220",
    "sentence": "讓皇帝守無咎於或躍，利終吉於勞謙，其用有光，其聞莫朽。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_095_000221",
    "sentence": "惠莊、惠文、惠宣、隋王等，或守常而獲免，終保皇枝；或過望而包羞，竟塵青史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000222",
    "sentence": "略陽公信魁偉之狀，起圖謀之心，福善禍淫，宜哉不令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000223",
    "sentence": "贊曰：謙而受益，讓以成賢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000224",
    "sentence": "唐屬之美，憲得其先。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000225",
    "sentence": "長不居震，剛不乘乾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000226",
    "sentence": "讓之大者，胡可比焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000227",
    "sentence": "捴、範已降，同氣連枝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000228",
    "sentence": "性習何遠，非革即睽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000229",
    "sentence": "有善有惡，禍福不欺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000230",
    "sentence": "本五代作品在全世界都属于 公有领域 ，因为作者逝世已经遠遠超过100年。",
    "entities": [
