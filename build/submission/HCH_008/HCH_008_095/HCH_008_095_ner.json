        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_095_000092",
    "sentence": "天寶初，終父喪，加特進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000093",
    "sentence": "九載卒，贈太子太師。",
    "entities": [
