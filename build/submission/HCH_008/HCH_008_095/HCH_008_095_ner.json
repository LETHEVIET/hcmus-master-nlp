      }
    ]
  },
  {
    "sentence_id": "HCH_008_095_000202",
    "sentence": "有子十一人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000203",
    "sentence": "瑗樂安郡王，  易宗正卿、滎陽郡王，琄封嗣薛王，珍嗣岐王。",
    "entities": [
      {
