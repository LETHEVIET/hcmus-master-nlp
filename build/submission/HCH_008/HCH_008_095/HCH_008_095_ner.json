      }
    ]
  },
  {
    "sentence_id": "HCH_008_095_000204",
    "sentence": "琄為金紫光祿大夫、鴻臚卿同正員。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_095_000205",
    "sentence": "天寶五載，坐舅刑部尚書韋堅為右相李林甫所構，貶夷陵郡別駕長任。",
    "entities": [
      {
