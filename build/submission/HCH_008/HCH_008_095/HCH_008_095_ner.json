        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_095_000011",
    "sentence": "中宗即位，改封蔡王，遷宗正員外卿，加賜實封四百戶，通舊為七百戶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000012",
    "sentence": "成器固辭不敢當大國，依舊為壽春郡王。",
