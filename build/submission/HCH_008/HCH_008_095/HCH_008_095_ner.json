  },
  {
    "sentence_id": "HCH_008_095_000209",
    "sentence": "隋王 隆悌",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000210",
    "sentence": "隋王隆悌，睿宗第六子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_095_000211",
