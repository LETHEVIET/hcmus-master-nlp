        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000123",
    "sentence": "百僚拜，答拜，辭亦如之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000124",
    "sentence": "王當闕不乘馬，步出木馬門而後乘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000125",
    "sentence": "管崇嗣為王都虞候，先王上馬，真卿進狀彈之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000126",
    "sentence": "肅宗曰：「朕兒子每出，諄諄教誡之，故不敢失禮。崇嗣老將，有足疾，姑欲優容之，卿勿復言。」乃以奏狀還真卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000127",
    "sentence": "雖天子蒙塵，典法不廢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000128",
    "sentence": "洎鑾輿將復宮闕，遣左司郎中李巽先行，陳告宗廟之禮，有司署祝文，稱「嗣皇帝」。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 34,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000129",
    "sentence": "真卿謂禮儀使崔器曰：「上皇在蜀，可乎？」器遽奏改之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000130",
    "sentence": "中旨宣勞，以為名儒深達禮體。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000131",
    "sentence": "時太廟為賊所毀，真卿奏曰：「春秋時，新宮災，魯成公三日哭。今太廟既為盜毀，請築壇於野，皇帝東向哭，然後遣使。」竟不能從。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 43,
        "end": 45
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000132",
    "sentence": "軍國之事，知無不言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000133",
    "sentence": "為宰相所忌，出為同州刺史，轉蒲州刺史。",
    "entities": [
      {
        "text": "出為同州",
        "label": "LOC",
        "start": 6,
        "end": 10
      },
      {
        "text": "刺史",
        "label": "TITLE",
