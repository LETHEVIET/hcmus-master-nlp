        "end": 12
      },
      {
        "text": "轉蒲州",
        "label": "LOC",
        "start": 13,
        "end": 16
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000134",
    "sentence": "為御史唐旻所構，貶饒州刺史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 1,
        "end": 3
      },
      {
        "text": "貶饒州",
        "label": "LOC",
        "start": 8,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000135",
    "sentence": "旋拜升州刺史、浙江西道節度使，征為刑部尚書。",
    "entities": [
      {
        "text": "旋拜升州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
