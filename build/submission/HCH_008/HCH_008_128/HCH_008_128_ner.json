        "end": 6
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000136",
    "sentence": "李輔國矯詔遷玄宗居西宮，真卿乃首率百僚上表請問起居，輔國惡之，奏貶蓬州長史。",
    "entities": [
      {
        "text": "奏貶蓬州",
        "label": "LOC",
        "start": 31,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000137",
    "sentence": "代宗嗣位，拜利州刺史，遷戶部侍郎，除荊南節度使，未行而罷，除尚書左丞。",
    "entities": [
      {
        "text": "拜利州",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "刺史",
