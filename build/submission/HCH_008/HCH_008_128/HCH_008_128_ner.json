[
  {
    "sentence_id": "HCH_008_128_000001",
    "sentence": "段秀實",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000002",
    "sentence": "段秀實，字成公，隴州汧陽人也。",
    "entities": [
      {
        "text": "隴州",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000003",
    "sentence": "祖達，左衛中郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000004",
    "sentence": "父行琛，洮州司馬，以秀實贈揚州大都督。",
    "entities": [
      {
        "text": "洮州",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "以秀實贈揚州",
        "label": "LOC",
        "start": 9,
        "end": 15
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000005",
    "sentence": "秀實性至孝，六歲，母疾，水漿不入口七日，疾有間，然後飲食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000006",
    "sentence": "及長，沈厚有斷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000007",
    "sentence": "天寶四載，安西節度馬靈察署為別將，從討護蜜有功，授安西府別將。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000008",
    "sentence": "七載，高仙芝代靈察，舉兵圍怛邏斯，黑衣救至，仙芝大衄，軍士相失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000009",
    "sentence": "夜中聞都將李嗣業之聲，因大呼責之曰：「軍敗而求免，非丈夫也。」嗣業甚慚，遂與秀實收合散卒，復得成軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000010",
    "sentence": "師還，嗣業請於仙芝，以秀實為判官，授斥候府果毅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000011",
    "sentence": "十二載，封常清代仙芝，討大勃律，師次賀薩勞城，戰而勝。",
    "entities": [
      {
        "text": "清",
        "label": "ORG",
        "start": 6,
        "end": 7
      },
      {
        "text": "師次賀薩勞城",
        "label": "LOC",
        "start": 16,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000012",
    "sentence": "常清逐之，秀實進曰：「賊兵羸，餌我也，請備左右，搜其山林。」遂殲其伏，改綏德府折衝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000013",
    "sentence": "肅宗即位於靈武，征安西兵節度使梁宰，宰潛懷異圖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000014",
    "sentence": "秀實謂嗣業曰：「豈有天子告急，臣下晏然，信浮妄之說，豈明公之意耶？」嗣業遂見宰，請發兵，從之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000015",
    "sentence": "乃出步騎五千，令嗣業統赴朔方，以秀實為援，累有戰功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000016",
    "sentence": "而秀實父歿，哀毀過禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000017",
    "sentence": "嗣業既授節制，思秀實如失左右手，表請起復，為義王友，充節度判官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000018",
    "sentence": "安慶緒奔鄴，嗣業與諸軍圍之，安西輜重委於河內。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000019",
    "sentence": "乃奏秀實為懷州長史，知軍州，加節度留後。",
    "entities": [
      {
        "text": "乃奏秀實為懷州",
        "label": "LOC",
        "start": 0,
        "end": 7
      },
      {
        "text": "知軍州",
        "label": "LOC",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000020",
    "sentence": "諸軍進戰於愁思岡，嗣業為流矢所中，卒於軍，眾推安西兵馬使荔非元禮代之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000021",
    "sentence": "秀實聞嗣業之喪，乃遺先鋒將白孝德書，令發卒護嗣業喪送河內。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000022",
    "sentence": "秀實率將吏哭待於境，傾私財以奉葬事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000023",
    "sentence": "元禮多其義，奏試光祿少卿，依前節度判官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000024",
    "sentence": "邙山之敗，軍徙翼城，元禮為麾下所殺，將佐亦多遇害，而秀實獨以智全。",
    "entities": [
      {
        "text": "軍徙翼城",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000025",
    "sentence": "眾推白孝德為節度使，人心稍定。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000026",
    "sentence": "又遷試光祿卿，為孝德判官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000027",
    "sentence": "孝德改鎮邠寧，奏秀實試太常卿、支度營田二副使。",
    "entities": [
      {
        "text": "孝德改鎮",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000028",
    "sentence": "大軍西遷，所過掠奪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000029",
    "sentence": "又以邠寧乏食，難於饋運，乃請軍於奉天。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000030",
    "sentence": "是時公廩亦竭，縣吏憂恐多逃匿，群行剽盜，孝德不能禁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000031",
    "sentence": "秀實私曰：「使我為軍候，當不如此。」軍司馬言之，遂以秀實為都虞候，權知奉天行營事，號令嚴一，軍府安泰，代宗聞而嗟賞久之。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000032",
    "sentence": "兵還於邠寧，復為都虞候，尋拜涇州刺史。",
    "entities": [
      {
        "text": "尋拜涇州",
        "label": "LOC",
        "start": 12,
        "end": 16
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000033",
    "sentence": "大曆元年，馬璘奏加開府儀同三司。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000034",
    "sentence": "軍中有能引二十四弓而犯盜者，璘欲免之，秀實曰：「將有私愛，則法令不一，雖韓、白復生，亦不能為理。」璘善其議，竟使殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000035",
    "sentence": "璘決事有不合理者，必固爭之，得璘引過乃已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000036",
    "sentence": "璘城涇州，秀實掌留後，歸還，加御史中丞。",
    "entities": [
      {
        "text": "璘城涇州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000037",
    "sentence": "璘既奉詔徙鎮涇州，其士眾嘗自四鎮、北庭赴難中原，僑居驟移，頗積勞怨。",
    "entities": [
      {
        "text": "璘既奉詔徙鎮",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "涇州",
        "label": "LOC",
        "start": 6,
        "end": 8
      },
      {
        "text": "其士眾嘗自四鎮",
        "label": "LOC",
        "start": 9,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000038",
    "sentence": "刀斧將王童之因人心動搖，導以為亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000039",
    "sentence": "或告其事，且曰：「候嚴，警鼓為約矣。」秀實乃召鼓人，陽怒失節，且戒之曰：「每更籌盡，必來報。」每白之，輒延數刻，四更畢而曙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000040",
    "sentence": "既差互，童之亂不能作。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000041",
    "sentence": "明日，告者復曰：「今夜將焚草場，期救火者同作亂。」秀實使嚴加警備。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000042",
    "sentence": "夜半火發，乃使令於軍中曰：「救火者斬。」童之居外營，請入救火，不許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000043",
    "sentence": "明日斬之，捕殺其黨凡十余人以徇，曰：「敢後徙者族！」於是遷涇州。",
    "entities": [
      {
        "text": "於是遷涇州",
        "label": "LOC",
        "start": 26,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000044",
    "sentence": "既至其理所，人煙夐絕，且無廩食。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000045",
    "sentence": "朝廷憂之，遂詔璘遙管鄭、潁二州，以贍涇原軍，俾秀實為留後，二州甚理。",
    "entities": [
      {
        "text": "潁二州",
        "label": "LOC",
        "start": 12,
        "end": 15
      },
      {
        "text": "二州",
        "label": "LOC",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000046",
    "sentence": "璘思其績用，又奏行軍司馬，兼都知兵馬使。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000047",
    "sentence": "八年，吐蕃來寇，戰於鹽倉，我軍不利。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000048",
    "sentence": "璘為寇戎所隔，逮暮未還，敗將潰兵爭道而入。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000049",
    "sentence": "時都將焦令諶與諸將四五輩狼狽而至，秀實召讓之曰：「兵法：失將，麾下當斬。公等忘其死而欲安其家耶！」令諶等恐懼，下拜數十。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000050",
    "sentence": "秀實乃悉驅城中士卒未出戰者，使驍將統之，東依古原，列奇兵示賊將戰，且以收合敗亡。",
    "entities": [
      {
        "text": "秀實乃悉驅城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000051",
    "sentence": "蕃眾望之，不敢逼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000052",
    "sentence": "及夜，璘方獲歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000053",
    "sentence": "十一年，璘疾甚，不能視事，請秀實攝節度副使兼左廂兵馬使。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000054",
    "sentence": "秀實乃以十將張羽飛為招召將，分兵按甲，以備非常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000055",
    "sentence": "璘卒，而軍中行哭赴喪事於內，李漢惠接賓客於外，非其親不得居喪側，族談離立者捕而囚之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000056",
    "sentence": "都虞候史廷幹、裨將崔珍張景華謀作亂，秀實乃送廷幹於京師，徙珍及景華外鎮，軍中遂定，不戮一人。",
    "entities": [
      {
        "text": "徙珍及景華外鎮",
        "label": "LOC",
        "start": 28,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000057",
    "sentence": "尋拜秀實涇州刺史、兼御史大夫，四鎮北庭行軍涇原鄭潁節度使。",
    "entities": [
      {
        "text": "尋拜秀實涇州",
        "label": "LOC",
        "start": 0,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "四鎮",
        "label": "LOC",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000058",
    "sentence": "三四年間，吐蕃不敢犯塞，清約率易，遠近稱之。",
    "entities": [
      {
        "text": "三四年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000059",
    "sentence": "非公會，不聽樂飲酒，私室無妓媵，無贏財，退公之後，端居靜慮而已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000060",
    "sentence": "德宗嗣位，就加檢校禮部尚書、張掖郡王。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "張掖郡",
        "label": "LOC",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000061",
    "sentence": "建中元年，宰相楊炎欲行元載舊志，築原州城，開陵陽渠，詔中使上聞，仍問秀實可否之狀。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "築原州城",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000062",
    "sentence": "秀實以為方春不可興土功，請俟農隙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000063",
    "sentence": "炎以其沮己之謀，遂除司農卿，以邠寧節度李懷光兼涇原節度使，以事西拓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000064",
    "sentence": "無何，劉文喜叛，亦不果城。",
    "entities": [
      {
        "text": "亦不果城",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000065",
    "sentence": "四年，朱泚盜據宮闕，源休教泚偽迎鑾駕，陰濟逆誌。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000066",
    "sentence": "泚乃遣其將韓旻領馬步三千疾趨奉天。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000067",
    "sentence": "時蒼黃之中，未有武備。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000068",
    "sentence": "泚以秀實嘗為涇原節度，頗得士心，後罷兵權，以為蓄憤且久，必肯同惡，乃召與謀議。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000069",
    "sentence": "秀實初詐從之，陰說大將劉海賓、何明禮、姚令言判官岐靈嶽同謀殺泚，以兵迎乘輿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000070",
    "sentence": "三人者，皆秀實夙所獎遇，遂皆許諾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000071",
    "sentence": "及韓旻追駕，秀實以為宗社之危，期於頃刻，乃使人走諭靈嶽，竊令言印。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000072",
    "sentence": "不遂，乃倒用司農印印符以追兵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000073",
    "sentence": "旻至駱驛得符，軍人亦莫辯其印文，惶遽而回。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000074",
    "sentence": "秀實謂海賓等曰：「旻之來，吾黨無遺類矣！我當直搏殺泚，不得則死，終不能向此賊稱臣。」乃與海賓約，事急為繼，而令明禮應於外。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000075",
    "sentence": "明日，泚召秀實議事，源休、姚令言、李忠臣、李子平皆在坐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000076",
    "sentence": "秀實戎服，與泚並膝，語至僭位，秀實勃然而起，執休腕奪其象笏，奮躍而前，唾泚面大罵曰：「狂賊，吾恨不斬汝萬段，我豈逐汝反耶！」遂擊之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000077",
    "sentence": "泚舉臂自捍，才中其顙，流血匍匐而走。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000078",
    "sentence": "兇徒愕然，初不敢動；而海賓等不至，秀實乃曰：「我不同汝反，何不殺我！」兇黨群至，遂遇害焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000079",
