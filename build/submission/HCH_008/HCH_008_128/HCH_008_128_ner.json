        "end": 16
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000138",
    "sentence": "車駕自陜將還，真卿請皇帝先謁五陵、九廟而後還宮。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000139",
    "sentence": "宰相元載謂真卿曰：「公所見雖美，其如不合事宜何？」真卿怒，前曰：「用舍在相公耳，言者何罪？然朝廷之事，豈堪相公再破除耶！」載深銜之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000140",
    "sentence": "旋改檢校刑部尚書知省事，累進封魯郡公。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "累進封魯郡",
        "label": "LOC",
        "start": 12,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000141",
    "sentence": "時元載引用私黨，懼朝臣論奏其短，乃請：百官凡欲論事，皆先白長官，長官白宰相，然後上聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000142",
    "sentence": "真卿上疏曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000143",
    "sentence": "御史中丞李進等傳宰相語，稱奉進止：「緣諸司官奏事頗多，朕不憚省覽，但所奏多挾讒毀；自今論事者，諸司官皆須先白長官，長官白宰相，宰相定可否，然後奏聞者。」臣自聞此語已來，朝野囂然，人心亦多衰退。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000144",
    "sentence": "何則？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000145",
    "sentence": "諸司長官皆達官也，言皆專達於天子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000146",
    "sentence": "郎官、御史者，陛下腹心耳目之臣也。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000147",
    "sentence": "故其出使天下，事無巨細得失，皆令訪察，回日奏聞，所以明四目、達四聰也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000148",
    "sentence": "今陛下欲自屏耳目，使不聰明，則天下何述焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000149",
    "sentence": "《詩》云：「營營青蠅，止於棘。讒言罔極，交亂四國。」以其能變白為黑，變黑為白也。",
    "entities": [
      {
        "text": "《詩》",
        "label": "TITLE",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000150",
    "sentence": "詩人深惡之，故曰：「取彼讒人，投畀豺虎。豺虎不食，投畀有北。」則夏之伯明、楚之無極、漢之江充，皆讒人也，孰不惡之？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000151",
    "sentence": "陛下惡之，深得君人之體矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000152",
    "sentence": "陛下何不深回聽察，其言虛誣者，則讒人也，因誅殛之；其言不虛者，則正人也，因獎勵之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000153",
    "sentence": "陛下舍此不為，使眾人皆謂陛下不能明察，倦於聽覽，以此為辭，拒其諫諍，臣竊為陛下痛惜之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000154",
    "sentence": "臣聞太宗勤於聽覽，庶政以理，故著《司門式》云：「其有無門籍人，有急奏者，皆令監門司與仗家引奏，不許關礙。」所以防壅蔽也。",
    "entities": [
      {
        "text": "《司門式》",
        "label": "TITLE",
        "start": 16,
        "end": 21
      },
      {
        "text": "不許關",
        "label": "LOC",
        "start": 47,
        "end": 50
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000155",
    "sentence": "並置立仗馬二匹，須有乘騎便往，所以平治天下，正用此道也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000156",
    "sentence": "天寶已後，李林甫威權日盛，群臣不先諮宰相輒奏事者，仍托以他故中傷，猶不敢明約百司，令先白宰相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000157",
    "sentence": "又閹官袁思藝日宣詔至中書，玄宗動靜，必告林甫，先意奏請，玄宗驚喜若神。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000158",
    "sentence": "以此權柄恩寵日甚，道路以目。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000159",
    "sentence": "上意不下宣，下情不上達，所以漸致潼關之禍，皆權臣誤主，不遵太宗之法故也。",
    "entities": [
      {
        "text": "所以漸致潼關",
        "label": "LOC",
        "start": 12,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000160",
    "sentence": "陵夷至於今日，天下之蔽，盡萃於聖躬，豈陛下招致之乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000161",
    "sentence": "蓋其所從來者漸矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000162",
    "sentence": "自艱難之初，百姓尚未彫弊，太平之理，立可便致。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000163",
    "sentence": "屬李輔國用權，宰相專政，遞相姑息，莫肯直言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000164",
    "sentence": "大開三司，不安反側，逆賊散落，將士北走党項，合集士賊，至今為患。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000165",
    "sentence": "偽將更相驚恐，因思明危懼，扇動卻反。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000166",
    "sentence": "又今相州敗散，東都陷沒，先帝由此憂勤，至於損壽，臣每思之，痛切心骨。",
    "entities": [
      {
        "text": "又今相州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000167",
    "sentence": "今天下兵戈未戢，瘡痏未平，陛下豈得不日聞讜言以廣視聽，而欲頓隔忠讜之路乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000168",
    "sentence": "臣竊聞陛下在陜州時，奏事者不限貴賤，務廣聞見，乃堯、舜之事也。",
    "entities": [
      {
        "text": "竊聞陛下在陜州",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000169",
    "sentence": "凡百臣庶以為太宗之理，可翹足而待也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000170",
    "sentence": "臣又聞君子難進易退，由此言之，朝廷開不諱之路，猶恐不言，況懷厭怠，令宰相宣進止，使御史臺作條目，不令直進。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 41,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_008_128_000171",
    "sentence": "從此人人不敢奏事，則陛下聞見，只在三數人耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000172",
    "sentence": "天下之士，方鉗口結舌，陛下後見無人奏事，必謂朝廷無事可論，豈知懼不敢進，即林甫、國忠復起矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000173",
    "sentence": "凡百臣庶，以為危殆之期，又翹足而至也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000174",
    "sentence": "如今日之事，曠古未有，雖李林甫、楊國忠猶不敢公然如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000175",
    "sentence": "今陛下不早覺悟，漸成孤立，後縱悔之無及矣！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000176",
    "sentence": "臣實知忤大臣者，罪在不測，不忍孤負陛下，無任懇迫之至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000177",
    "sentence": "其激切如此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000178",
    "sentence": "於是中人爭寫內本布於外。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_128_000179",
    "sentence": "後攝祭太廟，以祭器不修言於朝，載坐以誹謗，貶硤州別駕、撫州湖州刺史。",
    "entities": [
      {
        "text": "貶硤州",
        "label": "LOC",
        "start": 21,
        "end": 24
      },
      {
        "text": "撫州湖州",
        "label": "LOC",
        "start": 27,
        "end": 31
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 31,
