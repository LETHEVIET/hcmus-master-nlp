      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000032",
    "sentence": "是月乙丑，皇后矯詔召太子，程元振伺知之，告輔國。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "太子",
