        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000041",
    "sentence": "承天皇帝倓，肅宗第三子也。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000042",
    "sentence": "天寶中，封建寧郡王，授太常卿同正員。",
    "entities": [
      {
        "text": "封建寧郡",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000043",
    "sentence": "英毅有才略，善射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000044",
    "sentence": "祿山之亂，玄宗幸蜀，倓兄弟典親兵扈從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000045",
    "sentence": "車駕渡渭，百姓遮道乞留太子，太子諭之曰：「至尊奔播，吾不忍違離左右，俟吾見上奏聞。」倓於行宮謂太子曰：「逆胡犯順，四海分崩，不因人情，何以興復？夫有國家者，大孝莫若存社稷。今從至尊入蜀，則散關已東，非皇家所有，何以維屬人情？殿下宜購募豪傑，暫往河西，收拾戎馬，點集防邊將卒，不下十萬人，光弼、子儀，全軍河朔，謀為興復，計之上也。」廣平王亦贊成之，於是令李輔國奏聞。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "太子",
