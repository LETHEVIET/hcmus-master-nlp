  },
  {
    "sentence_id": "HCH_008_116_000128",
    "sentence": "方冀成立，豈期天喪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000129",
    "sentence": "瑤英始茂，遽摧於當春；隙駟俄遷，忽沈於厚夜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000130",
    "sentence": "興言痛悼，閔惜良深。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000131",
    "sentence": "宜賁寵於青宮，俾哀榮於玄穸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000132",
    "sentence": "可贈太子，謚曰恭懿。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000133",
    "sentence": "應緣喪葬，所司準式，仍令京兆尹劉晏充監護使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000134",
    "sentence": "詔宰臣李揆持節冊命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000135",
    "sentence": "十一月，葬於高陽原。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000136",
    "sentence": "其哀冊曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000137",
    "sentence": "維上元元年，太歲庚子，六月己未朔，二十六日甲申，皇第十二子、持節鳳翔等四州節度觀察大使興王佋，薨於中京內邸，殯於寢之西階。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 3,
        "end": 5
      },
      {
        "text": "持節鳳翔等四州",
        "label": "LOC",
        "start": 30,
        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000138",
    "sentence": "粵八月丁亥，冊贈皇太子，廟號恭懿。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000139",
    "sentence": "冬十一月庚寅，詔葬於長安之高陽原，禮也。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000140",
    "sentence": "燕隧開封，龍辒進轍，陳祖載而就位，儼塗芻以成列。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000141",
    "sentence": "皇帝哀玉林之悶景，憫璿萼之罹霜，瞻龍綍而增思，懷雁池而永傷。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000142",
    "sentence": "考謚惟古，褒崇有式。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000143",
    "sentence": "爰詔史司，恭宣懿德。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000144",
    "sentence": "其辭曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000145",
    "sentence": "惟天祚唐，累葉重光，中興宸景，再紐乾綱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000146",
    "sentence": "本枝建國，磐石疏疆，克開龍胤，實曰賢王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000147",
    "sentence": "驪源孕彩，日幹騰芳，深仁廣孝，蘊藝含章。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000148",
    "sentence": "秀發童年，惠彰齔齒，蹈禮知方，承尊葉旨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000149",
    "sentence": "對日流辯，占鳳擅美，魯、衛後塵，間、平絕軌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000150",
    "sentence": "胡孽初構，王師未班，爰從繈褓，載歷險艱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000151",
    "sentence": "愛備中掖，名崇懿籓，居常稟訓，動不違顏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000152",
    "sentence": "禮及佩觿，朝加分器，胙土延渥，登壇受帥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000153",
    "sentence": "玉質金聲，文經武緯，樂善為寶，崇儒是貴。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000154",
    "sentence": "浚哲外朗，溫文內深，閱書成誦，觀樂表音。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000155",
    "sentence": "《五經》在口，六律諧心，才優藝洽，絕古超今。",
    "entities": [
      {
        "text": "《五經》",
        "label": "TITLE",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000156",
    "sentence": "蛇豕猶梗，寰區未乂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000157",
    "sentence": "滌慮祈真，焚香演偈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000158",
    "sentence": "食去葷血，心依定惠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000159",
    "sentence": "庶福邦家，俾清兇穢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000160",
    "sentence": "霧露嬰疾，聰明害神，沈  彖始遘，彌曠盈旬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000161",
    "sentence": "止慮無擾，發言有倫，在膏方亟，問膳逾勤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000162",
    "sentence": "雲物告征，星辰變象，楚藥無救，秦醫莫仗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000163",
    "sentence": "靈儀窅而上賓，徽音邈其長往。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000164",
    "sentence": "違舊邸於青社，即幽陵於黃壤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000165",
    "sentence": "嗚呼哀哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000166",
    "sentence": "魂氣奪兮去何之，精靈存兮孝有思。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000167",
    "sentence": "念君親之永隔，托夢寐而來辭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000168",
    "sentence": "延桂宮而震悼，貫椒壸而纏悲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000169",
    "sentence": "旌遺芳於碣館，賁新命於儲闈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000170",
    "sentence": "鳴呼哀哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000171",
    "sentence": "先遠戒候，占龜獻吉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000172",
    "sentence": "指鶉野而西臨，背鳳城而右出。",
    "entities": [
      {
        "text": "背鳳城",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000173",
    "sentence": "天慘慘而苦霧，山蒼蒼而曀日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000174",
    "sentence": "望馳道而長辭，赴幽塗而永畢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000175",
    "sentence": "嗚呼哀哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000176",
    "sentence": "生為寵王兮宸愛所鐘，歿追上嗣兮朝典斯崇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000177",
    "sentence": "升玉笙於洞府，閱銀棨於泉宮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000178",
    "sentence": "金石誰固，人生有終，簡冊攸記兮德音無窮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000179",
    "sentence": "敢直詞於篆美，庶永代而成風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000180",
    "sentence": "鳴呼哀哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000181",
    "sentence": "佋薨時年八歲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000182",
    "sentence": "既薨之夕，肅宗、張後俱夢佋有如平昔，拜辭流涕而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000183",
    "sentence": "帝方寢疾，追念過深，故特以儲闈之贈寵之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000184",
    "sentence": "上疾累月方平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000185",
    "sentence": "定王",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000186",
    "sentence": "定王侗，肅宗第十三子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000187",
    "sentence": "亦張後所生，佋之母弟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000188",
    "sentence": "至德二載，封定王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000189",
    "sentence": "寶應初薨，時年甚幼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000190",
    "sentence": "宋王",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000191",
    "sentence": "宋王僖，肅宗第十四子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000192",
    "sentence": "初封淮陽王，早夭，追封宋王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000193",
    "sentence": "代宗子",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000194",
    "sentence": "代宗皇帝二十子：睿真皇后沈氏生德宗皇帝，崔妃生昭靖太子，獨孤皇后生韓王迥；余十七王，舊史不載母氏所出。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 17,
        "end": 19
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 25,
        "end": 27
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000195",
    "sentence": "昭靖太子邈，代宗第二子。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000196",
    "sentence": "寶應元年 ，封鄭王。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000197",
    "sentence": "大歷初，代皇太子為天下兵馬元帥。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000198",
    "sentence": "王好讀書，以儒行聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000199",
    "sentence": "大歷九年薨，廢朝三日，由是罷元帥之職。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000200",
    "sentence": "上惜其才早夭，冊贈昭靖太子，葬於萬年縣界。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "葬於萬年縣",
        "label": "LOC",
        "start": 14,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000201",
    "sentence": "均王遐，代宗第三子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000202",
    "sentence": "早夭， 貞元八年 追封。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000203",
    "sentence": "睦王述，代宗第四子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000204",
    "sentence": "大歷九年冬，田承嗣謀亂河朔，時鄭王居長，典兵師，不幸薨落，諸王皆幼，多未封建。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000205",
    "sentence": "大臣奏議請封親王，分領戎師，以威天下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000206",
    "sentence": "十年二月，詔曰：",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000207",
    "sentence": "虞、夏之制，諸子疏封；漢、魏以還，十連授律。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000208",
    "sentence": "是用錫珪班瑞，盤石開疆，信通邑之紀綱，為中都之屏翰。",
    "entities": [
      {
        "text": "信通邑",
        "label": "LOC",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000209",
    "sentence": "然則旌鉞之寄，推擇攸難，因親之任，各膺其命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000210",
    "sentence": "第四子述、第五子逾、第六子連、第七子迥、第八子遘、第十三子造、第十四子暹、第十五子運、第十六子遇、第十七子遹、第十八子通、第十九子逵、第二十子逸等，並敏茂純懿，稟於衷誠，溫良孝恭，形於進對，動皆合義，居必有常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000211",
    "sentence": "可以理眾靖人，撫封宣化，而總列城之賦，繕分閫之謀，克勤公家，允輔王室。",
    "entities": [
      {
        "text": "而總列城",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000212",
    "sentence": "今則均茅社之寵，盛槐庭之儀，授鉞登車，嗣茲朝典，維城之固，爾其懋哉。",
    "entities": [
      {
        "text": "維城",
        "label": "LOC",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000213",
    "sentence": "述可封睦王，充嶺南節度支度營田、五府經略觀察處置等大使；逾可封郴王，充渭北鄜、坊等州節度大使；連可封恩王；韓王迥可汴、宋等節度觀察處置等大使；遘可封鄜王；造可封忻王，充昭義軍節度觀察處置等大使；暹可封韶王，運可封嘉王，遇可封端王，遹可封循王，通可封恭王，逵可封原王，逸可封雅王：仍並可封開府儀同三司。",
    "entities": [
      {
        "text": "坊等州",
        "label": "LOC",
        "start": 39,
        "end": 42
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000214",
    "sentence": "是時，皇子勝衣者盡加王爵，不出閣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000215",
    "sentence": "德宗朝，述為諸王之長。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000216",
    "sentence": "時分命中使周行天下，求訪沈太后，詔以睦王為奉迎太后使，以工部尚書喬琳副之。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000217",
    "sentence": "貞元七年薨。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000218",
    "sentence": "丹王逾，代宗第五子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000219",
    "sentence": "大歷十年，封郴王，領渭北鄜坊節度大使。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000220",
    "sentence": "建中四年 ，改丹王。",
