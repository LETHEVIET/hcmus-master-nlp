  {
    "sentence_id": "HCH_008_116_000003",
    "sentence": "越王",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000004",
    "sentence": "越王係，本名儋，肅宗第二子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000005",
    "sentence": "天寶中，封南陽郡王，授特進。",
    "entities": [
      {
        "text": "封南陽郡",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000006",
    "sentence": "至德二年十二月，進封趙王。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000007",
    "sentence": "乾元二年三月，九節度之兵潰於河北，史思明僭號於相州，王師未集，朝廷震駭。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "思明僭號於相州",
        "label": "LOC",
        "start": 18,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000008",
    "sentence": "詔以李光弼握兵關東以代子儀。",
    "entities": [
      {
        "text": "以李光弼握兵關",
        "label": "LOC",
        "start": 1,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000009",
    "sentence": "光弼請以親賢統師，七月，詔曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000010",
    "sentence": "握兵之要，古先為重；命帥之道，心膂攸憑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000011",
    "sentence": "是知靖難夷兇，必資於金革；總戎授律，實仗於親賢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000012",
    "sentence": "蓋將底寧邦家，保息黎獻者矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000013",
    "sentence": "朕以薄德，纘承鴻緒，往屬元兇暴亂，中夏不寧。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000014",
    "sentence": "上憑宗社之靈，下藉熊羆之力，由是廓清鹹、洛，拯此生人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000015",
    "sentence": "頃以河朔殘妖，尚稽天討，蛇豕竊依於城堡，塗炭久被於齊氓，朕為人父母，寧忘閔念。",
    "entities": [
      {
        "text": "蛇豕竊依於城",
        "label": "LOC",
        "start": 12,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000016",
    "sentence": "雖好生息戰，每冀其歸降；而余孽昧恩，靡聞於悔禍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000017",
    "sentence": "所以軒後親征於獯鬻，周文致役於昆夷，古之用兵，蓋非獲已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000018",
    "sentence": "趙王係幼稟異操，夙懷韜略，負東平之文學，蘊任城之智勇。",
    "entities": [
      {
        "text": "蘊任城",
        "label": "LOC",
        "start": 20,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000019",
    "sentence": "性惟忠孝，持愛敬以立身；誌尚權謀，有經通之遠智。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000020",
    "sentence": "知子者父，方有屬於維城；擇能而授，俾克申於戎律。",
    "entities": [
      {
        "text": "方有屬於維城",
        "label": "LOC",
        "start": 5,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000021",
    "sentence": "且兇徒嘯聚，頗歷歲時，惡既貫盈，理當撲滅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000022",
    "sentence": "君親有命，可不敬乎！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000023",
    "sentence": "俾展龍豹之韜，永清梟獍之類。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000024",
    "sentence": "可充天下兵馬元帥，仍令司空、兼侍中、薊國公光弼副知節度行營事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000025",
    "sentence": "應緣軍司署置，所司準式。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000026",
    "sentence": "九月，史思明陷洛陽，光弼以副元帥董兵守河陽，王不出京師。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000027",
    "sentence": "十月，下詔車駕親征，諫官論奏乃止；王請行，不許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000028",
    "sentence": "三年四月，改封越王。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000029",
    "sentence": "寶應元年四月，肅宗寢疾彌留。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000030",
    "sentence": "皇后張氏與中官李輔國有隙，因皇太子監國，謀誅輔國，使人以肅宗命召太子入宮。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 0,
        "end": 2
      },
      {
        "text": "太子",
