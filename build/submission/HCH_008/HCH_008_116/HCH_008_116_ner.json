  },
  {
    "sentence_id": "HCH_008_116_000259",
    "sentence": "史臣曰：艷妻破國，孽子敗宗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000260",
    "sentence": "前代英傑之君，率不免於斯累者，何也？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000261",
    "sentence": "良以愛惡不由於義斷，毀譽遽逐於情移。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000262",
    "sentence": "雖申生孝己之仁，卒不能回君父之愛，悲哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000263",
    "sentence": "孝宣皇帝當屯剝之運，收忠義之心，忍行愛子之刑，終宥奸閹之罪，大雅君子，為之痛心。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_116_000264",
    "sentence": "張後卒以兇終，固其宜矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000265",
    "sentence": "贊曰：床簀之愛，人情易惑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000266",
    "sentence": "以義制情，哲王令德。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000267",
    "sentence": "李侯悟主，韻諧金石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_116_000268",
    "sentence": "褒謚建寧，良堪太息。",
    "entities": []
  },
