        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000183",
    "sentence": "及斬 建成 、 元吉 ，其黨來攻 玄武門 ，兵鋒甚盛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000184",
