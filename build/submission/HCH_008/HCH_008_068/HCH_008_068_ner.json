        "end": 5
      },
      {
        "text": "幽州",
        "label": "LOC",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000074",
    "sentence": "其年薨，年七十四。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000075",
    "sentence": "高宗 爲之舉哀，廢朝三日，令京官五品以上及朝集使赴宅哭，冊贈司徒、 并州 都督，謚曰 忠武 ，賜東園秘器，陪葬於 昭陵 。",
    "entities": [
      {
        "text": "并州",
        "label": "LOC",
        "start": 34,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000076",
    "sentence": "子 寶琳 嗣，官至衞尉卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000077",
    "sentence": "秦叔寶",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000078",
    "sentence": "秦叔寶 ，名 瓊 ， 齊州 歷城 人。",
    "entities": [
      {
        "text": "齊州",
        "label": "LOC",
        "start": 11,
        "end": 13
      },
      {
        "text": "歷城",
        "label": "LOC",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000079",
    "sentence": "大業 中，爲 隋 將 來護兒 帳內。",
    "entities": [
      {
        "text": "來護兒",
        "label": "PER",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000080",
    "sentence": "叔寶 喪母， 護兒 遣使弔之，軍吏怪曰：「士卒死亡及遭喪者多矣，將軍未嘗降問，獨弔 叔寶 何也？」答曰：「此人勇悍，加有志節，必當自取富貴，豈得以卑賤處之？」 隋 末群盜起，從通守 張須陀 擊賊帥 盧明月 於 下邳 。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000081",
    "sentence": "賊眾十餘萬， 須陀 所統纔萬人，力勢不敵，去賊六七里立柵，相持十餘日，糧盡將退，謂諸將士曰：「賊見兵卻，必輕來追我。其眾既出，營內即虛，若以千人襲營，可有大利。此誠危險，誰能去者？」人皆莫對，唯 叔寶 與 羅士信 請行。",
    "entities": [
      {
        "text": "羅士信",
        "label": "PER",
        "start": 103,
        "end": 106
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000082",
    "sentence": "於是 須陀 委柵遁，使二人分領千兵伏於蘆葦間。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000083",
    "sentence": "既而 明月 果悉兵追之， 叔寶 與 士信 馳至其柵，柵門閉不得入，二人超昇其樓，拔賊旗幟，各殺數人，營中大亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000084",
    "sentence": "叔寶 、 士信 又斬關以納外兵，因縱火焚其三十餘柵，煙焰漲天。",
    "entities": [
      {
        "text": "又斬關",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000085",
    "sentence": "明月 奔還， 須陀 又回軍奮擊，大破賊眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000086",
    "sentence": "明月 以數百騎遁去，餘皆虜之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000087",
    "sentence": "由是勇氣聞於遠近。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000088",
    "sentence": "又擊 孫宣雅 於 海曲 ，先登破之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000089",
    "sentence": "以前後累勳授建節尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000090",
    "sentence": "從 須陀 進擊 李密 於 滎陽 ，軍敗， 須陀 死之， 叔寶 以餘眾附 裴仁基 。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000091",
    "sentence": "會 仁基 以 武牢 降於 李密 ， 密 得 叔寶 大喜，以爲帳內驃騎，待之甚厚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000092",
    "sentence": "密 與 化及 大戰於 黎陽 童山 ，爲流矢所中，墮馬悶絶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000093",
    "sentence": "左右奔散，追兵且至，唯 叔寶 獨捍衞之， 密 遂獲免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000094",
    "sentence": "叔寶 又收兵與之力戰， 化及 乃退。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000095",
    "sentence": "後 密 敗，又爲 王世充 所得，署龍驤大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 19,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000096",
    "sentence": "叔寶 薄世充之多詐，因其出抗官軍，至於 九曲 ，與 程咬金 、 呉黑闥 、 牛進達 等數十騎西馳百許歩，下馬拜世充曰：「雖蒙殊禮，不能仰事，請從此辭。」 世充 不敢逼，於是來降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000097",
    "sentence": "高祖 令事 秦 府， 太宗 素聞其勇，厚加禮遇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000098",
    "sentence": "從鎮 長春宮 ，拜馬軍總管。",
    "entities": [
      {
        "text": "從鎮",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000099",
    "sentence": "又從征於 美良川 ，破 尉遲敬德 ，功最居多。",
    "entities": [
      {
        "text": "尉遲敬德",
        "label": "PER",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000100",
    "sentence": "高祖 遣使賜以金瓶，勞之曰：「卿不顧妻子，遠來投我，又立功效。朕肉可爲卿用者，當割以賜卿，況子女玉帛乎？卿當勉之。」尋授 秦王 右三統軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000101",
    "sentence": "又從破 宋金剛 於 介休 。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000102",
    "sentence": "録前後勳，賜黃金百斤、雜彩六千段，授上柱國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000103",
    "sentence": "從討 王世充 ，毎爲前鋒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000104",
    "sentence": "太宗 將拒 竇建德 於 武牢 ， 叔寶 以精騎數十先陷其陣。",
    "entities": [
      {
        "text": "竇建德",
        "label": "PER",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000105",
    "sentence": "世充 平，進封 翼國公 ，賜黃金百斤、帛七千段。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000106",
    "sentence": "從平 劉黑闥 ，賞物千段。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000107",
    "sentence": "叔寶 毎從 太宗 征伐，敵中有驍將銳卒，炫耀人馬，出入來去者， 太宗 頗怒之，輒命 叔寶 往取。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000108",
    "sentence": "叔寶 應命，躍馬負槍而進，必刺之萬眾之中，人馬辟易， 太宗 以是益重之， 叔寶 亦以此頗自矜尚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000109",
    "sentence": "六月四日，從誅 建成 、 元吉 。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000110",
    "sentence": "事寧，拜左武衞大將軍，食實封七百戸。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000111",
    "sentence": "其後毎多疾病，因謂人曰：「吾少長戎馬，所經二百餘陣，屢中重瘡。計吾前後出血亦數斛矣，安得不病乎？」十二年卒，贈 徐州 都督，陪葬 昭陵 。",
    "entities": [
      {
        "text": "十二年",
        "label": "TME",
