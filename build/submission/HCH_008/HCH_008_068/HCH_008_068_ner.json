        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000063",
    "sentence": "八年，累遷 同州 刺史。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "同州",
        "label": "LOC",
        "start": 6,
        "end": 8
      },
      {
