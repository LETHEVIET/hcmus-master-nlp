      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000112",
    "sentence": "太宗 特令所司就其塋內立石人馬，以旌戰陣之功焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_068_000113",
    "sentence": "十三年，改封 胡國公 。",
    "entities": [
      {
        "text": "十三年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_068_000114",
    "sentence": "十七年，與 長孫無忌 等圖形於 凌煙閣 。",
    "entities": [
      {
        "text": "十七年",
        "label": "TME",
        "start": 0,
