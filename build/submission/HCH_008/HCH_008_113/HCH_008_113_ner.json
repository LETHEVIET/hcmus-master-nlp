        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000085",
    "sentence": "元載秉政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000086",
    "sentence": "載為新平縣尉，王鉷辟在巡內，冕常引之，載頗德冕。",
    "entities": [
      {
        "text": "載為新平縣",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000087",
    "sentence": "會宰臣杜鴻漸卒，載遂舉冕代之。",
    "entities": [
      {
        "text": "杜鴻漸",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000088",
    "sentence": "冕時已衰瘵，載以其順己，引為同列。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000089",
    "sentence": "受命之際，蹈舞絕倒，載趨而扶起，代為謝詞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000090",
    "sentence": "冕兼掌兵權留守之任，俸錢每月二千余貫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000091",
    "sentence": "性本侈靡，好尚車服及營珍饌，名馬在櫪，直數百金者常十數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000092",
    "sentence": "每會賓友，滋味品數，坐客有昧於名者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000093",
    "sentence": "自創巾子，其狀新奇，市肆因而效之，呼為「僕射樣」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000094",
    "sentence": "初代鴻漸，小吏以俸錢文簿白之，冕顧子弟，喜見於色，其嗜利若此。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000095",
    "sentence": "拜職未盈月，卒，大歷四年十二月也。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000096",
    "sentence": "上悼之，輟朝三日，贈太尉，賻制五百匹、粟五百石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000097",
    "sentence": "裴遵慶",
    "entities": [
