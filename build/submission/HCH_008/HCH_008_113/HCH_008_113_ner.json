        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000098",
    "sentence": "裴遵慶，絳州聞喜人也。",
    "entities": [
      {
        "text": "裴遵慶",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "絳州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000099",
    "sentence": "代襲冠冕，為河東著族。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000100",
    "sentence": "遵慶志氣深厚，機鑒敏達，自幼強學，博涉載籍，謹身晦跡，不幹當世之務。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000101",
    "sentence": "以門廕累授潞府司法參軍，時年已老，未為人所知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000102",
    "sentence": "隨調吏部，授大理寺丞，剖斷刑獄，舉正綱條，理行始著。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000103",
    "sentence": "遷司門員外、吏部員外郎，專判南曹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000104",
    "sentence": "天寶中，海內無事，九流輻輳會府，每歲吏部選人，動盈萬數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000105",
    "sentence": "遵慶敏識強記，精核文簿，詳而不滯，時稱吏事第一，由是大知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000106",
    "sentence": "天寶末，楊國忠當國，出不附己者例為外官，遵慶亦出為郡守。",
    "entities": [
      {
        "text": "楊國忠",
