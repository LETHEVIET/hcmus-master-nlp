      },
      {
        "text": "元",
        "label": "ORG",
        "start": 138,
        "end": 139
      },
      {
        "text": "皆關",
        "label": "LOC",
        "start": 167,
        "end": 169
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000072",
    "sentence": "肅宗即位，以定策功，遷中書侍郎、同中書門下平章事，倚以為政。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000073",
    "sentence": "冕性忠勤，悉心奉公，稍得人心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000074",
    "sentence": "然不識大體，以聚人曰財，乃下令賣官鬻爵，度尼僧道士，以儲積為務。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000075",
    "sentence": "人不願者，科令就之，其價益賤，事轉為弊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000076",
    "sentence": "肅宗移幸鳳翔，罷冕知政事，遷右僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000077",
    "sentence": "兩京平，以功封冀國公，食實封五百戶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000078",
    "sentence": "尋加御史大夫、成都尹，充劍南西川節度使。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 2,
        "end": 4
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "成都",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000079",
    "sentence": "又入為右僕射。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000080",
    "sentence": "永泰元年，與裴遵慶等並集賢待制。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "裴遵慶",
        "label": "PER",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000081",
    "sentence": "代宗求舊，拜冕兼御史大夫，充護山陵使。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000082",
    "sentence": "冕以幸臣李輔國權盛，將附之，乃表輔國親昵術士中書舍人劉烜充山陵使判官。",
    "entities": [
      {
        "text": "李輔國",
        "label": "PER",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000083",
    "sentence": "烜坐法，冕坐貶施州刺史。",
    "entities": [
      {
        "text": "冕坐貶施州",
        "label": "LOC",
        "start": 4,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000084",
    "sentence": "數月，移澧州刺史，復征為左僕射。",
    "entities": [
      {
        "text": "移澧州",
        "label": "LOC",
