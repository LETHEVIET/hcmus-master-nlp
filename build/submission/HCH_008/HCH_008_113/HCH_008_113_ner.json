        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000133",
    "sentence": "入為京兆少尹，拜同州刺史，充本州防禦使。",
    "entities": [
      {
        "text": "拜同州",
        "label": "LOC",
