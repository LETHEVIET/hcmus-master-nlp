      },
      {
        "text": "充本州",
        "label": "LOC",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000134",
    "sentence": "入為大理寺卿，出遷陜虢都防禦、觀察使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000135",
    "sentence": "三歲，拜左散騎常侍，自常侍復為大理。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000136",
    "sentence": "向本以名相子，以學行自飭，謹守其門風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000137",
    "sentence": "歷官仁智推愛，利及於人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000138",
    "sentence": "至是，以年過致政，朝廷優異，乃以吏部尚書致仕於新昌裏第。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000139",
    "sentence": "內外支屬百余人，向所得俸祿，必同其費，及領外任，亦挈而隨之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000140",
    "sentence": "有孤煢疾苦不能自恤，向尤周給，至今稱其孝睦焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000141",
    "sentence": "大和四年九月卒，年八十。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000142",
    "sentence": "贈太子少保。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000143",
    "sentence": "向子 寅",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000144",
    "sentence": "子寅，登進士第，累官至御史大夫卒。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000145",
    "sentence": "子樞，字紀聖，咸通十二年登進士第。",
    "entities": [
      {
        "text": "十二年",
        "label": "TME",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000146",
    "sentence": "宰相杜審權出鎮河中，辟為從事，得秘書省校書郎，再遷藍田尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000147",
    "sentence": "直弘文館。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000148",
    "sentence": "大學士王鐸深知之，鐸罷相失職，樞亦久之不調。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000149",
    "sentence": "從僖宗幸蜀，中丞李煥奏為殿中侍御史，遷起居郎。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000150",
    "sentence": "中和初，王鐸復見用，以舊恩徙為鄭滑掌書記、檢校司封郎中，賜金紫，入朝歷兵、吏二員外郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000151",
    "sentence": "龍紀初，擢拜給事中，改京兆尹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000152",
    "sentence": "宰相孔緯尤深獎遇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000153",
    "sentence": "大順中，緯以用兵無功貶官，樞坐累為右庶子，尋出為歙州刺史。",
    "entities": [
      {
        "text": "尋出為歙州",
        "label": "LOC",
        "start": 21,
        "end": 26
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000154",
    "sentence": "乾寧初，入為右散騎常侍，從昭宗幸華州，為汴州宣諭使。",
    "entities": [
      {
        "text": "從昭宗幸華州",
        "label": "LOC",
        "start": 12,
        "end": 18
      },
      {
        "text": "為汴州",
        "label": "LOC",
        "start": 19,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000155",
    "sentence": "初，樞自歙州罷郡歸朝，路經大梁，時硃全忠兵威已振，樞以兄事之，全忠由是重之。",
    "entities": [
      {
        "text": "樞自歙州罷郡",
        "label": "LOC",
        "start": 2,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000156",
    "sentence": "及樞傳詔，全忠皆稟朝旨，獻奉相繼，昭宗甚悅，遷兵部侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000157",
    "sentence": "時崔胤專政，亦倚全忠，二人因是相結，改樞吏部侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000158",
    "sentence": "未幾，換戶部侍郎、同平章事。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000159",
    "sentence": "其年冬，昭宗幸華州，崔胤貶官，樞亦為工部尚書。",
    "entities": [
      {
        "text": "昭宗幸華州",
        "label": "LOC",
        "start": 4,
        "end": 9
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000160",
    "sentence": "天子自岐下還宮，以樞檢校右僕射、同平章事，出為廣南節度使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000161",
    "sentence": "制出，硃全忠保薦之，言樞有經世才，不可棄之嶺表，尋復拜門下侍郎，監修國史，累兼吏部尚書，判度支。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 29,
        "end": 31
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 41,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000162",
    "sentence": "崔胤誅，以全忠素厚，相位如故。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000163",
    "sentence": "從昭宗遷洛陽，駐蹕陜州，進右僕射、弘文館大學士、太清宮使，充諸道鹽鐵轉運使。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 4,
        "end": 6
      },
      {
        "text": "駐蹕陜州",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000164",
    "sentence": "哀帝初嗣位，柳璨用事，全忠嘗奏用牙將張廷範為太常卿，諸相議，樞曰：「廷範勛臣，幸有方鎮節鉞之命，何藉樂卿？恐非元帥梁王之旨。」乃持之不下。",
    "entities": [
      {
        "text": "張廷範",
        "label": "PER",
        "start": 18,
        "end": 21
      },
      {
        "text": "幸有方鎮",
        "label": "LOC",
        "start": 39,
        "end": 43
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000165",
    "sentence": "俄而全忠聞樞言，謂賓佐曰：「吾常以裴十四器識真純，不入浮薄之伍，觀此議論，本態露矣。」切齒含怒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000166",
    "sentence": "柳璨聞全忠言，尋希旨罷樞相位，和陵祔享，拜尚書左僕射。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000167",
    "sentence": "五月，責授朝散大夫、登州刺史，尋再貶瀧州司戶。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 7,
        "end": 9
      },
      {
        "text": "登州",
        "label": "LOC",
        "start": 10,
        "end": 12
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "尋再貶瀧州",
        "label": "LOC",
        "start": 15,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000168",
    "sentence": "六月十一日，行及滑州，全忠遣人殺之於白馬驛，投屍於河，時年六十五。",
    "entities": [
      {
        "text": "行及滑州",
        "label": "LOC",
        "start": 6,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000169",
    "sentence": "【贊】",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000170",
    "sentence": "史臣曰：晉卿謹身蒞事，足為純臣，避寇全忠，固彰大節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000171",
    "sentence": "然博達精審，豈不知寬猛之道哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000172",
    "sentence": "奉林甫之旨，順胥吏之意，悅附張倚，欺罔時君。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000173",
    "sentence": "生為重臣，諂林甫之勢也；歿改美謚，引元載之恩焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000174",
    "sentence": "或言晉卿不為巧宦者，誠不信也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000175",
    "sentence": "冕力贊中興，名居大位，奉公抱義，可以致身；賣官度僧，是何為政？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000176",
    "sentence": "及其老也，貪冒尤深。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000177",
    "sentence": "遵慶學術貞明，為國忠所出；恭儉謹密，遇蕭華素知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000178",
    "sentence": "位重行純，老而彌篤，彼二公固有慚德。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000179",
    "sentence": "向克荷堂構，不墜門風。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000180",
    "sentence": "樞因盜而振，盜憎而亡，宜哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000181",
    "sentence": "君子守道遠刑，蓋慮此也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000182",
    "sentence": "贊曰：奧矣晉卿，貪哉裴冕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000183",
    "sentence": "遵慶父子，及之者鮮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000184",
    "sentence": "本五代作品在全世界都属于 公有领域 ，因为作者逝世已经遠遠超过100年。",
    "entities": [
      {
        "text": "100年",
        "label": "TME",
        "start": 31,
        "end": 35
      }
    ]
  }
]
