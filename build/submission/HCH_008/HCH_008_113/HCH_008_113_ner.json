  {
    "sentence_id": "HCH_008_113_000122",
    "sentence": "子向，字傃仁，少以門廕歷官至太子司議郎。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000123",
    "sentence": "建中初，李紓為同州刺史，奏向為從事。",
    "entities": [
      {
        "text": "李紓為同州",
        "label": "LOC",
        "start": 4,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000124",
    "sentence": "硃泚反，李懷光又叛河中，使其將趙貴先築壘於同州，紓來奔奉天，向領州務。",
    "entities": [
      {
        "text": "李懷光",
        "label": "PER",
        "start": 4,
        "end": 7
      },
      {
        "text": "貴先築壘於同州",
        "label": "LOC",
        "start": 16,
        "end": 23
      },
      {
        "text": "向領州",
        "label": "LOC",
        "start": 30,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000125",
    "sentence": "貴先因脅縣尉林寶役徒板築，不及期，將斬之，吏人百姓奔竄。",
    "entities": [
      {
        "text": "貴先因脅縣",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000126",
    "sentence": "向即詣貴先軍壘，以逆順之理責之，貴先感悟，遂來降，故同州不陷。",
    "entities": [
      {
        "text": "故同州",
        "label": "LOC",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000127",
    "sentence": "向由是知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000128",
    "sentence": "累為京兆府戶曹，轉櫟陽、渭南縣令，奏課皆第一，朝廷亟聞其理行，擢為戶部員外郎。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000129",
    "sentence": "德宗季年，天下方鎮副倅多自選於朝，防一日有變，遂就而授之節制。",
    "entities": [
      {
        "text": "天下方鎮",
        "label": "LOC",
        "start": 5,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000130",
    "sentence": "向已選為太原少尹，德宗召見喻旨，尋用為行軍司馬、兼御史中丞，改汾州刺史，轉鄭州。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 21,
        "end": 23
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 25,
        "end": 27
      },
      {
        "text": "改汾州",
        "label": "LOC",
        "start": 30,
        "end": 33
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 33,
        "end": 35
      },
      {
        "text": "轉鄭州",
        "label": "LOC",
        "start": 36,
        "end": 39
      }
    ]
  },
  {
    "sentence_id": "HCH_008_113_000131",
    "sentence": "又復為太原少尹，兼河東節度副使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_113_000132",
    "sentence": "改晉州刺史，充本州防禦使，遷虢州刺史。",
    "entities": [
      {
        "text": "改晉州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
