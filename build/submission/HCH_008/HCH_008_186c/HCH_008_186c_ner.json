[
  {
    "sentence_id": "HCH_008_186c_000001",
    "sentence": "姚紹之",
    "entities": [
      {
        "text": "姚紹之",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000002",
    "sentence": "姚紹之，湖州武康人也。",
    "entities": [
      {
        "text": "姚紹之",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "湖州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000003",
    "sentence": "解褐典儀，累拜監察御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000004",
    "sentence": "中宗朝，武三思恃庶人勢，駙馬都尉王同皎謀誅之。",
    "entities": [
      {
        "text": "武三思",
        "label": "PER",
        "start": 4,
        "end": 7
      },
      {
        "text": "王同皎",
        "label": "PER",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000005",
    "sentence": "事泄，令紹之按問而誅同皎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000006",
    "sentence": "紹之初按問同皎，張仲之、祖延慶謀衣袖中發調弩射三思，伺其便，未果。",
    "entities": [
      {
        "text": "張仲之",
        "label": "PER",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000007",
    "sentence": "宋之遜以其外妹妻延慶，曰：「今日將行何事，而以妻為？」之遜固抑與延慶，且洽其心矣。",
    "entities": [
      {
        "text": "宋之遜",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000008",
    "sentence": "之遜子曇密發之，乃敕右臺大夫李承嘉與紹之按於新開門內。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "李承嘉",
        "label": "PER",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000009",
    "sentence": "初，紹之將直盡其事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000010",
    "sentence": "詔宰相李嶠等對問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000011",
    "sentence": "諸相懼三思威權，但僶俛佯不問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000012",
    "sentence": "仲之、延慶言曰：「宰相中有附會三思者。」嶠與承嘉耳言，復說誘紹之，其事乃變。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000013",
    "sentence": "遂密置人力十餘，命引仲之對問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000014",
    "sentence": "至，即為紹之所擒，塞口反接，送獄中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000015",
    "sentence": "紹之還，謂仲之曰：「張三，事不諧矣！」仲之固言三思反狀，紹之命棒之而臂折，大呼天者六七。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000016",
    "sentence": "謂紹之曰：「反賊，臂且折矣，命已輸汝，當訴爾於天帝！」因裂衫以束之，乃自誣反而遇誅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000017",
    "sentence": "紹之自此神氣自若，朝廷側目。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000018",
    "sentence": "累遷左臺侍御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000019",
    "sentence": "奉使江左，經汴州，辱錄事參軍魏傳弓。",
    "entities": [
      {
        "text": "經汴州",
        "label": "LOC",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000020",
    "sentence": "尋拜監察御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000021",
    "sentence": "紹之後坐贓汙，詔傳弓按之，獲贓五千餘貫以聞，當坐死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000022",
    "sentence": "韋庶人妹保持之，遂黜放為嶺南瓊山尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000023",
    "sentence": "傳弓初按紹之，紹之在揚州，色動，謂長吏盧萬石曰：「頃辱傳弓，今為所按，紹之死矣！」逃入西京，為萬年尉擒之，擊折其足，因授南陵令員外置。",
    "entities": [
      {
        "text": "紹之在揚州",
        "label": "LOC",
        "start": 7,
        "end": 12
      },
      {
        "text": "盧萬石",
        "label": "PER",
        "start": 19,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000024",
    "sentence": "開元十三年 ，累轉括州長史同正員，不預知州事，死。",
    "entities": [
      {
        "text": "開元十三年",
        "label": "TME",
        "start": 0,
        "end": 5
      },
      {
        "text": "累轉括州",
        "label": "LOC",
        "start": 7,
        "end": 11
      },
      {
        "text": "不預知州",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000025",
    "sentence": "周利貞",
    "entities": [
      {
        "text": "周利貞",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000026",
    "sentence": "周利貞，神龍初為侍御史。",
    "entities": [
      {
        "text": "周利貞",
        "label": "PER",
        "start": 0,
        "end": 3
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000027",
    "sentence": "附托權要，為桓彥範、敬暉等五王嫉之，出為嘉州司馬。",
    "entities": [
      {
        "text": "桓彥範",
        "label": "PER",
        "start": 6,
        "end": 9
      },
      {
        "text": "出為嘉州",
        "label": "LOC",
        "start": 18,
        "end": 22
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000028",
    "sentence": "時中書舍人崔湜與桓、敬善。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000029",
    "sentence": "武三思用事禁中，彥範憂之，托心腹於湜。",
    "entities": [
      {
        "text": "武三思",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000030",
    "sentence": "湜反露其計於三思，為三思所中，盡流嶺南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000031",
    "sentence": "湜勸盡殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000032",
    "sentence": "以絕其歸望。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000033",
    "sentence": "三思問：「誰可使者？」利貞即湜之表兄，因舉為此行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000034",
    "sentence": "利貞至，皆鴆殺之，因擢為左臺御史中丞。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000035",
    "sentence": "先天元年 ，為廣州都督。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "為廣州",
        "label": "LOC",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000036",
    "sentence": "時湜為中書令，與僕射劉幽求不葉，陷幽求徙於嶺表，諷利貞殺之，為桂州都督王晙護之，逗留獲免。",
    "entities": [
      {
        "text": "劉幽求",
        "label": "PER",
        "start": 10,
        "end": 13
      },
      {
        "text": "為桂州",
        "label": "LOC",
        "start": 30,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000037",
    "sentence": "無何，玄宗正位，利貞與薛季昶、宋之問同賜死於桂州驛。",
    "entities": [
      {
        "text": "薛季昶",
        "label": "PER",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000038",
    "sentence": "王旭",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000039",
    "sentence": "王旭，太原祁人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000040",
    "sentence": "曾祖珪，貞觀初為侍中，尚永寧公主。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000041",
    "sentence": "旭解褐鴻州參軍，轉兗州兵曹。",
    "entities": [
      {
        "text": "旭解褐鴻州",
        "label": "LOC",
        "start": 0,
        "end": 5
      },
      {
        "text": "轉兗州",
        "label": "LOC",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000042",
    "sentence": "神龍元年 正月，張柬之、桓彥範等誅張易之、昌宗兄弟，尊立孝和皇帝。",
    "entities": [
      {
        "text": "神龍元年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "張柬之",
        "label": "PER",
        "start": 8,
        "end": 11
      },
      {
        "text": "桓彥範",
        "label": "PER",
        "start": 12,
        "end": 15
      },
      {
        "text": "張易之",
        "label": "PER",
        "start": 17,
        "end": 20
      },
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 30,
        "end": 32
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000043",
    "sentence": "其兄昌儀先貶乾封尉，旭斬之，賫其首，赴於東都。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000044",
    "sentence": "遷并州錄事參軍。",
    "entities": [
      {
        "text": "遷并州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000045",
    "sentence": "唐隆元年，玄宗誅韋庶人等。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000046",
    "sentence": "并州長史周仁軌，韋氏之黨，有詔誅之。",
    "entities": [
      {
        "text": "并州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "周仁軌",
        "label": "PER",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000047",
    "sentence": "旭不覆敕，又斬其首，馳赴西京。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000048",
    "sentence": "開元二年 ，累遷左臺侍御史。",
    "entities": [
      {
        "text": "開元二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000049",
    "sentence": "時光祿少卿盧崇道以崔湜妻父，貶於嶺外。",
    "entities": [
      {
        "text": "盧崇道",
        "label": "PER",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000050",
    "sentence": "逃歸，匿於東都，為仇家所發，詔旭究其獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000051",
    "sentence": "旭欲擅其威權，因捕崇道親黨數十人，皆極其楚毒，然後結成其罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000052",
    "sentence": "崇道及三子並杖死於都亭驛，門生親友皆決杖流貶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000053",
    "sentence": "時得罪多是知名之士，四海冤之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000054",
    "sentence": "旭又與御史大夫李傑不葉，遞相糾訐，傑竟左遷衢州刺史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "傑竟左遷衢州",
        "label": "LOC",
        "start": 17,
        "end": 23
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000055",
    "sentence": "旭既得誌，擅行威福，由是朝廷畏而鄙之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000056",
    "sentence": "五年，遷左司郎中，常帶侍御史。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000057",
    "sentence": "旭為吏嚴苛，左右無敢支梧，每銜命推劾，一見無不輸款者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000058",
    "sentence": "時宋王憲府掾紀希虬兄任劍南縣令，被告有贓私，旭使至蜀鞫之。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000059",
    "sentence": "其妻美，旭威逼之，因奏決殺縣令，納贓數千萬。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000060",
    "sentence": "至六年，希虬遣奴詐為祗承人，受顧在臺，事旭累月。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000061",
    "sentence": "旭賞之，召入宅中，委以腹心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000062",
    "sentence": "其奴密記旭受饋遺囑托事，乃成數千貫，歸謁希虬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000063",
    "sentence": "希虬銜泣見憲，敘以家冤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000064",
    "sentence": "憲憫之，執其狀以奏，詔付臺司劾之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000065",
    "sentence": "贓私累巨萬，貶龍平尉，憤恚而死，甚為時人之所慶快。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000066",
    "sentence": "吉溫 〈 王鈞　嚴安之　盧鉉附 〉",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000067",
    "sentence": "吉溫，天官侍郎頊弟琚之孽子也。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000068",
    "sentence": "譎詭能諂事人，遊於中貴門，愛若親戚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000069",
    "sentence": "性禁害，果於推劾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000070",
    "sentence": "天寶初，為新豐丞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000071",
    "sentence": "時太子文學薛嶷承恩幸，引溫入對。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000072",
    "sentence": "玄宗目之而謂嶷曰：「是一不良漢，朕不要也。」時蕭炅為河南尹，河南府有事，京臺差溫推詰，事連炅，堅執不舍，賴炅與右相李林甫善，抑而免之。",
    "entities": [
      {
        "text": "李林甫",
        "label": "PER",
        "start": 57,
        "end": 60
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000073",
    "sentence": "及溫選，炅已為京兆尹，一唱萬年尉，即就其官，人為危之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000074",
    "sentence": "時驃騎高力士常止宿宮禁，或時出外第，炅必謁焉。",
    "entities": [
      {
        "text": "高力士",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000075",
    "sentence": "溫先馳與力士言謔甚洽，握手呼行第，炅覷之嘆伏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000076",
    "sentence": "及他日，溫謁炅於府庭，遽布心腹曰：「他日不敢隳國家法，今日已後，洗心事公。」炅復與盡歡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000077",
    "sentence": "會林甫與左相李適之、駙馬張垍不葉，適之兼兵部尚書，垍兄均為兵部侍郎，林甫遣人訐出兵部銓曹主簿事令史六十餘人偽濫事，圖覆其官長，詔出付京兆府與憲司對問。",
    "entities": [
      {
        "text": "李適之",
        "label": "PER",
        "start": 6,
        "end": 9
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 22,
        "end": 24
      },
      {
        "text": "侍郎",
