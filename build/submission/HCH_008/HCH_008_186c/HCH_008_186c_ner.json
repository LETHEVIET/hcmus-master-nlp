      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000090",
    "sentence": "使溫於東京收捕其兄少府少監慎餘、弟洛陽令慎名，於汝州捕其門客史敬忠。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 17,
        "end": 19
      },
      {
        "text": "於汝州",
        "label": "LOC",
        "start": 23,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000091",
    "sentence": "敬忠頗有學，嘗與朝貴遊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000092",
    "sentence": "蹉跎不進。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000093",
    "sentence": "與溫父琚情契甚密，溫孩孺時，敬忠嘗抱撫之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000094",
    "sentence": "溫令河南丞姚開就擒之，鎖其頸，布袂蒙面以見溫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000095",
    "sentence": "溫驅之於前，不交一言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000096",
    "sentence": "欲及京，使典誘之云：「楊慎矜今款招己成，須子一辨。若解人意，必活；忤之，必死。」敬忠回首曰：「七郎，乞一紙。」溫佯不與，見詞懇，乃於桑下令答，三紙辯皆符溫旨。",
    "entities": [
      {
        "text": "楊慎矜",
        "label": "PER",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000097",
    "sentence": "喜曰：「丈人莫相怪！」遂徐下拜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000098",
    "sentence": "及至溫湯，始鞫慎矜，以敬忠詞為證。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000099",
    "sentence": "及再搜其家，不得圖讖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000100",
    "sentence": "林甫恐事泄，危之，乃使御史盧鉉入搜。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000101",
    "sentence": "鉉乃袖讖書而入，於隱僻中詬而出曰：「逆賊牢藏秘記，今得之矣！」指於慎矜小妻韓珠團婢，見舉家惶懼，且行捶擊，誰敢忤焉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000102",
    "sentence": "獄乃成，慎矜兄弟賜死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000103",
    "sentence": "溫自是威振，衣冠不敢偶言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000104",
    "sentence": "溫早以嚴毒聞，頻知詔獄，忍行枉濫，推事未訊問，已作奏狀，計贓數。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000105",
    "sentence": "及被引問，便懾懼，即隨意而書，無敢惜其生者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000106",
    "sentence": "因不加栲擊，獄成矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000107",
    "sentence": "林甫深以溫為能，擢戶部郎中，常帶御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000108",
    "sentence": "林甫雖倚以爪牙，溫又見安祿山受主恩，驃騎高力士居中用事，皆附會其間，結為兄弟。",
    "entities": [
