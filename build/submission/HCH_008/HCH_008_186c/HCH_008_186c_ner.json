        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000221",
    "sentence": "又有裴升、畢曜同為御史，皆酷毒。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000222",
    "sentence": "人之陷刑，當時有毛、敬、裴、畢之稱。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000223",
    "sentence": "裴、畢尋又流黔中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000224",
    "sentence": "羽， 寶應元年 貶為道州刺史。",
