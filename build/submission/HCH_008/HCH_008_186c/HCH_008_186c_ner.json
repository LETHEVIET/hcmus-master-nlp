        "end": 33
      },
      {
        "text": "令史",
        "label": "TITLE",
        "start": 47,
        "end": 49
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000078",
    "sentence": "數日，竟不究其由。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000079",
    "sentence": "炅使溫劾之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000080",
    "sentence": "溫於院中分囚於兩處，溫於後廳佯取兩重囚訊之，或杖或壓，痛苦之聲，所不忍聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000081",
    "sentence": "即云：「若存性命，乞紙盡答。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000082",
    "sentence": "令史輩素諳溫，各自誣伏罪，及溫引問，無敢違者。",
    "entities": [
      {
        "text": "令史",
        "label": "TITLE",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000083",
    "sentence": "晷刻間事輯，驗囚無栲訊決罰處。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000084",
    "sentence": "常云：「若遇知己，南山白額獸不足縛也。」會李林甫將起刑獄，除不附己者，乃引之於門，與羅希奭同鍛煉詔獄。",
    "entities": [
      {
        "text": "李林甫",
        "label": "PER",
        "start": 21,
        "end": 24
      },
      {
        "text": "羅希奭",
        "label": "PER",
        "start": 42,
        "end": 45
      }
    ]
  },
  {
    "sentence_id": "HCH_008_186c_000085",
    "sentence": "五載，因中官納其外甥武敬一女為盛王琦妃，擢京兆府士曹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000086",
    "sentence": "時林甫專謀不利於東儲，以左驍衛兵曹柳湜杜良娣妹婿，令溫推之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000087",
    "sentence": "溫追著作郎王曾、前右司禦率府倉曹王修己、左武衛司戈盧寧、左威衛騎曹徐徵同就臺鞫，數日而獄成。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000088",
    "sentence": "勣等杖死，積屍於大理寺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_186c_000089",
    "sentence": "六載，林甫又以戶部侍郎、兼御史中丞楊慎矜違忤其旨，御史中丞王鉷與慎矜親而嫉之，同構其事，云：「蓄圖讖，以己是隋煬帝子孫，規於興復」，林甫又奏付溫鞫焉，慎矜下獄繫之。",
    "entities": [
