[
  {
    "sentence_id": "HCH_008_194c_000001",
    "sentence": "西突厥本與北突厥同祖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000002",
    "sentence": "初，木桿與沙缽略可汗有隙，因分為二。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000003",
    "sentence": "其國即烏孫之故地，東至突厥國，西至雷翥海，南至疏勒，北至瀚海，在長安北七千里。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 32,
        "end": 34
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000004",
    "sentence": "自焉耆國西北七日行，至其南庭；又正北八日行，至其北庭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000005",
    "sentence": "鐵勒、龜茲及西域諸胡國，皆歸附之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000006",
    "sentence": "其人雜有都陸及弩失畢、歌邏祿、處月、處密，伊吾等諸種。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000007",
    "sentence": "風俗大抵與突厥同，唯言語微差。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000008",
    "sentence": "其官有葉護，有特勒，常以可汗子弟及宗族為之；又有乙斤、屈利啜、閻洪達、頡利發、吐屯、俟斤等官，皆代襲其位。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000009",
    "sentence": "處羅可汗，隋煬帝大業中與其弟闕達設及特勒大奈入朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000010",
    "sentence": "仍從煬帝征高麗，賜號為曷薩那可汗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000011",
    "sentence": "遇江都之亂，從宇文化及至河北。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000012",
    "sentence": "化及敗，歸長安，高祖為之降榻，引與同坐，封歸義郡王。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 5,
        "end": 7
      },
      {
        "text": "封歸義郡",
        "label": "LOC",
        "start": 20,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000013",
    "sentence": "獻大珠於高祖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000014",
    "sentence": "高祖勞之曰：「珠信為寶，朕所重者赤心，珠無所用。」竟不受之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000015",
    "sentence": "先與始畢有隙，及在京師，始畢遣使請殺之，高祖不許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000016",
    "sentence": "群臣諫曰：「今若不與，則是存一人而失一國也，後必為患。」太宗曰：「人窮來歸我，殺之不義。」驟諫於高祖，由是遲回者久之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000017",
    "sentence": "不得已，乃引曷薩那於內殿，與之縱酒，既而送至中書省，縱北突厥使殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000018",
    "sentence": "太宗即位，令以禮改葬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000019",
    "sentence": "闕達設初居於會寧，有部落三千余騎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000020",
    "sentence": "至隋末，自稱闕達可汗。",
    "entities": [
      {
        "text": "隋",
        "label": "ORG",
        "start": 1,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000021",
    "sentence": "武德初，遣使內屬，拜吐烏過拔闕可汗，厚加撫慰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000022",
    "sentence": "尋為李軌所滅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000023",
    "sentence": "特勒大奈，隋大業中與曷薩那可汗同歸中國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000024",
    "sentence": "及從煬帝討遼東，以功授金紫光祿大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000025",
    "sentence": "後分其部落於樓煩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000026",
    "sentence": "會高祖舉兵，大奈率其眾以從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000027",
    "sentence": "隋將桑顯和襲義軍於飲馬泉，諸軍多已奔退，大奈將數百騎出顯和後，掩其不備，擊，大破之，諸軍復振。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000028",
    "sentence": "拜光祿大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000029",
    "sentence": "及平京城，以力戰功，賞物五千段，賜姓史氏。",
    "entities": [
      {
        "text": "及平京城",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000030",
    "sentence": "武德初，從太宗破薛舉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000031",
    "sentence": "又從平王世充，破竇建德、劉黑闥，並有殊功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000032",
    "sentence": "賜宮女三人，雜彩萬余段。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000033",
    "sentence": "貞觀三年，累遷右武衛大將軍、檢校豐州都督，封竇國公，實封三百戶。",
    "entities": [
      {
        "text": "貞觀三年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 10,
        "end": 13
      },
      {
        "text": "檢校豐州",
        "label": "LOC",
        "start": 14,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000034",
    "sentence": "十二年卒，贈輔國大將軍。",
    "entities": [
      {
        "text": "十二年",
        "label": "TME",
        "start": 0,
        "end": 3
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000035",
    "sentence": "初，曷薩那之朝隋也，為煬帝所拘，其國人遂立薩那之叔父，曰射匱可汗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000036",
    "sentence": "射匱可汗者，達頭可汗之孫也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000037",
    "sentence": "既立後，始開土宇，東至金山，西至海，自玉門已西諸國皆役屬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000038",
    "sentence": "遂與北突厥為敵，乃建庭於龜茲北三彌山，尋卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000039",
    "sentence": "弟統葉護可汗代立。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000040",
    "sentence": "統葉護可汗，勇而有謀，善攻戰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000041",
    "sentence": "遂北並鐵勒，西拒波斯，南接罽賓，悉歸之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000042",
    "sentence": "控弦數十萬，霸有西域，據舊烏孫之地。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000043",
    "sentence": "又移庭於石國北之千泉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000044",
    "sentence": "其西域諸國王悉授頡利發，並遣吐屯一人監統之，督其征賦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000045",
    "sentence": "西戎之盛，未之有也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000046",
    "sentence": "武德三年，遣使貢條支巨卵。",
    "entities": [
      {
        "text": "武德三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000047",
    "sentence": "時北突厥作患，高祖厚加撫結，與之並力以圖北蕃，統葉護許以五年冬。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000048",
    "sentence": "大軍將發，頡利可汗聞之，大懼，復與統葉護通和，無相征伐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000049",
    "sentence": "統葉護尋遣使來請婚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000050",
    "sentence": "高祖謂侍臣曰：「西突厥去我懸遠，急疾不相得力，今請婚，其計安在？」封德彜對曰：「當今之務，莫若遠交而近攻，正可權許其婚，以威北狄。待之數年後，中國盛全，徐思其宜。」高祖遂許之婚，令高平王道立至其國，統葉護大悅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000051",
    "sentence": "遇頡利可汗頻歲入寇，西蕃路梗，由是未果為婚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000052",
    "sentence": "貞觀元年，遣真珠統俟斤與高平王道立來獻萬釘寶鈿金帶，馬五千匹。",
    "entities": [
      {
        "text": "貞觀元年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000053",
    "sentence": "時統葉護自負強盛，無恩於國，部眾鹹怨，歌邏祿種多叛之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000054",
    "sentence": "頡利可汗不悅中國與之和親，數遣兵入寇，又遣人謂統葉護曰：「汝若迎唐家公主，要須經我國中而過。」統葉護患之，未克婚。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 34,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000055",
    "sentence": "為其伯父所殺而自立，是為莫賀咄侯屈利俟毗可汗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000056",
    "sentence": "太宗聞統葉護之死，甚悼之，遣賫玉帛至其死所祭而焚之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000057",
    "sentence": "會其國亂，不果至而止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000058",
    "sentence": "莫賀咄侯屈利俟毗可汗，先分統突厥種類為小可汗，及此自稱大可汗，國人不附。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000059",
    "sentence": "弩失畢部共推泥孰莫賀設為可汗，泥孰不從。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000060",
    "sentence": "時統葉護之子咥力特勒避莫賀咄之難，亡在康居，泥孰遂迎而立之，是為乙毗缽羅肆葉護可汗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000061",
    "sentence": "連兵不息，俱遣使來朝，各請婚於我。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000062",
    "sentence": "太宗答之曰：「汝國擾亂，君臣未定，戰爭不息，何得言婚！」竟不許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000063",
    "sentence": "仍諷令各保所部，無相征伐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000064",
    "sentence": "其西域諸國及鐵勒先役屬於西突厥者，悉叛之，國內虛耗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000065",
    "sentence": "肆葉護既是舊主之子，為眾心所歸，其西面都陸可汗及莫賀咄可汗部豪帥，多來附之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000066",
    "sentence": "又興兵以擊莫賀咄，大敗之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000067",
    "sentence": "莫賀咄遁於金山，尋為咄陸可汗所害，國人乃奉肆葉護為大可汗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000068",
    "sentence": "肆葉護可汗立，大發兵北征鐵勒，薛延陀逆擊之，反為所敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000069",
    "sentence": "肆葉護性猜狠信讒，無統馭之略。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000070",
    "sentence": "有乙利可汗者，於肆葉護功最多，由是授小可汗，以非罪族滅之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000071",
    "sentence": "群下震駭，莫能自固。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000072",
    "sentence": "肆葉護素憚泥孰，而陰欲圖之，泥孰遂適焉耆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000073",
    "sentence": "其後沒卑達幹與突厥弩失畢二部豪帥潛謀擊之，肆葉護以輕騎遁於康居，尋卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000074",
    "sentence": "國人迎泥孰於焉耆而立之，是為咄陸可汗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000075",
    "sentence": "咄陸可汗泥孰者，亦稱大渡可汗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000076",
    "sentence": "父莫賀設，本隸統葉護。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000077",
    "sentence": "武德中，嘗至京師。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000078",
    "sentence": "時太宗居籓，務加懷輯，與之結盟為兄弟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000079",
    "sentence": "既被推為可汗，遣使詣闕請降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000080",
    "sentence": "太宗遣使賜以名號及鼓纛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000081",
    "sentence": "貞觀七年，遣鴻臚少卿劉善因至其國，冊授為吞阿婁拔奚利邲咄陸可汗。",
    "entities": [
      {
        "text": "貞觀七年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000082",
    "sentence": "明年，泥孰卒，其弟同娥設立，是為沙缽羅咥利失可汗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000083",
    "sentence": "沙缽羅咥利失可汗，以貞觀九年上表請婚，獻馬五百疋。",
    "entities": [
      {
        "text": "貞觀九年",
        "label": "TME",
        "start": 10,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000084",
    "sentence": "朝廷唯厚加撫慰，未許其婚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000085",
    "sentence": "俄而其國分為十部，每部令一人統之，號為十設。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000086",
    "sentence": "每設賜以一箭，故稱十箭焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000087",
    "sentence": "又分十箭為左右廂，一廂各置五箭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000088",
    "sentence": "其左廂號五咄六部落，置五大啜，一啜管一箭；其右廂號為五弩失畢，置五大俟斤，一俟斤管一箭，都號為十箭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000089",
    "sentence": "其後或稱一箭為一部落，大箭頭為大首領。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000090",
    "sentence": "五咄六部落居於碎葉已東，五弩失畢部落居於碎葉已西，自是都號為十姓部落。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000091",
    "sentence": "咥利失既不為眾所歸，部眾攜貳，為其統吐屯所襲，麾下亡散。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000092",
    "sentence": "咥利失以左右百余騎拒之，戰數合，統吐屯不利而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000093",
    "sentence": "咥利失奔其弟步利設，與保焉耆。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000094",
    "sentence": "其阿悉吉闕俟斤與統吐屯等召國人，將立欲谷設為大可汗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000095",
    "sentence": "以咥利失為小可汗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000096",
    "sentence": "統吐屯為人所殺，欲谷設兵又為其俟斤所破，咥利失復得舊地，弩失畢、處密等並歸咥利失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000097",
    "sentence": "十二年，西部竟立欲谷設為乙毗咄陸可汗。",
    "entities": [
      {
        "text": "十二年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000098",
    "sentence": "乙毗咄陸可汗既立，與咥利失大戰，兩軍多死，各引去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000099",
    "sentence": "因與咥利失中分，自伊列河已西屬咄陸，已東屬咥利失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000100",
    "sentence": "咄陸可汗又建庭於鏃曷山西，謂為北庭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000101",
    "sentence": "自厥越失、拔悉彌、駁馬、結骨、火燅、觸水昆諸國皆臣之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000102",
    "sentence": "十三年，咥利失為其吐屯俟利發與欲谷設通謀作難，咥利失窮蹙，奔拔汗那而死。",
    "entities": [
      {
        "text": "十三年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000103",
    "sentence": "弩失畢部落酋帥迎咥利失弟伽那之子薄布特勒而立之，是為乙毗沙缽羅葉護可汗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000104",
    "sentence": "乙毗沙缽羅葉護可汗既立，建庭於睢合水北，謂之南庭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000105",
    "sentence": "東以伊列河為界，自龜茲、鄯善，且末、吐火羅、焉耆、石國、史國、何國、穆國、康國，皆受其節度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000106",
    "sentence": "累遣使朝貢，太宗降璽書慰勉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000107",
    "sentence": "貞觀十五年，令左領軍將軍張大師往授焉，賜以鼓纛。",
    "entities": [
      {
        "text": "貞觀十五年",
        "label": "TME",
        "start": 0,
        "end": 5
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000108",
    "sentence": "於時咄陸可汗與葉護頗相攻擊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000109",
    "sentence": "會咄陸遣使詣闕，太宗諭以敦睦之道。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000110",
    "sentence": "咄陸於時兵眾漸強，西域諸國復來歸附。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000111",
    "sentence": "未幾，咄陸遣石國吐屯攻葉護，擒之，送於咄陸，尋為所殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000112",
    "sentence": "咄陸可汗既並其國，弩失畢諸姓心不服咄陸，皆叛之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000113",
    "sentence": "咄陸復率兵擊吐火羅，破之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000114",
    "sentence": "自恃其強，專擅西域。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000115",
    "sentence": "遣兵寇伊州，安西都護郭恪率輕騎二千自烏骨邀擊，敗之。",
    "entities": [
      {
        "text": "遣兵寇伊州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000116",
    "sentence": "咄陸又遣處月、處密等圍天山縣，郭恪又擊走之。",
    "entities": [
      {
        "text": "處密等圍天山縣",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000117",
    "sentence": "恪乘勝進拔處月俟斤所居之城，追奔及於遏索山，斬首千余級，降其處密之眾而歸。",
    "entities": [
      {
        "text": "月俟斤所居之城",
        "label": "LOC",
        "start": 6,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000118",
    "sentence": "咄陸初以泥孰啜自擅取所部物，斬之以徇；尋為泥孰啜部將胡祿居所襲，眾多亡逸，其國大亂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000119",
    "sentence": "貞觀十五年，部下屋利啜等謀欲廢咄陸，各遣使詣闕，請立可汗。",
    "entities": [
      {
        "text": "貞觀十五年",
        "label": "TME",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000120",
    "sentence": "太宗遣使賫璽書立莫賀咄乙毗可汗之子，是為乙毗射匱可汗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000121",
    "sentence": "乙毗射匱可汗立，乃發弩失畢兵就白水擊咄陸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000122",
    "sentence": "自知不為眾所附，乃西走吐火羅國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000123",
    "sentence": "中國使人先為咄陸所拘者，射匱悉以禮資送歸長安，復遣使貢方物，請賜婚。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000124",
    "sentence": "太宗許之，詔令割龜茲、於闐、疏勒、硃俱波、蔥嶺等五國為聘禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000125",
    "sentence": "及太宗崩，賀魯反叛，射匱部落為其所並。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000126",
    "sentence": "阿史那賀魯者，曳步利設射匱特勒之子也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000127",
    "sentence": "初，阿史那步真既來歸國，咄陸可汗乃立賀魯為葉護，以繼步真。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000128",
    "sentence": "居於多邏斯川，在西州直北一千五百里，統處密、處月、姑蘇、歌羅祿、弩失畢五姓之眾。",
    "entities": [
      {
        "text": "在西州",
        "label": "LOC",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000129",
    "sentence": "其後，咄陸西走吐火羅國，射匱可汗遣兵迫逐，賀魯不常厥居。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000130",
    "sentence": "貞觀二十二年，乃率其部落內屬，詔居廷州。",
    "entities": [
      {
        "text": "貞觀二十二年",
        "label": "TME",
        "start": 0,
        "end": 6
      },
      {
        "text": "詔居廷州",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000131",
    "sentence": "尋授左驍衛將軍、瑤池都督。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000132",
    "sentence": "高宗即位，進拜左驍衛大將軍，瑤池都督如故。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000133",
    "sentence": "永徽二年，與其子咥運率眾西遁，據咄陸可汗之地，總有西域諸郡，建牙於雙河及千泉，自號沙缽羅可汗，統攝咄陸、弩失畢十姓。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "總有西域諸郡",
        "label": "LOC",
        "start": 23,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000134",
    "sentence": "其咄陸有五啜：一曰處木昆律啜；二曰胡祿居闕啜，賀魯以女妻之；三曰攝舍提暾啜；四曰突騎施賀邏施啜；五曰鼠尼施處半啜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000135",
    "sentence": "弩失畢有五俟斤：一曰阿悉結闕俟斤，最為強盛；二曰哥舒闕俟斤；三曰拔塞幹暾沙缽俟斤，四曰阿悉結泥孰俟斤；五曰哥舒處半俟斤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000136",
    "sentence": "各有所部，勝兵數十萬，並羈屬賀魯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000137",
    "sentence": "西域諸國，亦多附隸焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000138",
    "sentence": "賀魯尋立咥運為莫賀咄葉護，數侵擾西蕃諸部，又進寇廷州。",
    "entities": [
      {
        "text": "又進寇廷州",
        "label": "LOC",
        "start": 21,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000139",
    "sentence": "三年，詔遣左武候大將軍梁建方、右驍衛大將軍契苾何力率燕然都護所部回紇兵五萬騎討之，前後斬首五千級，虜渠帥六十余人。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 8,
        "end": 11
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 18,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000140",
    "sentence": "四年，咄陸可汗死，其子真珠護與五弩失畢請擊賀魯，破其牙帳，斬首千余級。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000141",
    "sentence": "顯慶二年，遣右屯衛將軍蘇定方，燕然都護任雅相，副都護蕭嗣業，左驍衛大將軍、瀚海都督回紇婆閏等率師討擊，仍使右武衛大將軍阿史那彌射、左屯衛大將軍阿史那步真為安撫大使。",
    "entities": [
      {
        "text": "顯慶二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 33,
        "end": 36
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 56,
        "end": 59
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 68,
        "end": 71
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000142",
    "sentence": "定方行至曳咥河西，賀魯率胡祿居闕啜等二萬余騎列陣而待。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000143",
    "sentence": "定方率副總管任雅相等與之交戰，賊眾大敗，斬大首領都搭達幹等二百余人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000144",
    "sentence": "賀魯及闕啜輕騎奔竄，渡伊麗河，兵馬溺死者甚眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000145",
    "sentence": "嗣業至千泉賀魯下牙之處，彌射進軍至伊麗水，處月、處密等部各率眾來降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000146",
    "sentence": "彌射又進次雙河，賀魯先使步失達幹鳩集散卒，據柵拒戰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000147",
    "sentence": "彌射、步真攻之，大潰；又與蘇定方攻賀魯於碎葉水，大破之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000148",
    "sentence": "賀魯與咥運欲投鼠耨設，至石國之蘇咄城傍，人馬饑乏，城主伊涅達幹詐將酒食出迎，賀魯信其言入城，遂被拘執。",
    "entities": [
      {
        "text": "至石國之蘇咄城",
        "label": "LOC",
        "start": 11,
        "end": 18
      },
      {
        "text": "賀魯信其言入城",
        "label": "LOC",
        "start": 38,
        "end": 45
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000149",
    "sentence": "蕭嗣業既至石國，鼠耨設乃以賀魯屬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000150",
    "sentence": "賀魯謂嗣業曰：「我破亡虜耳！先帝厚我，而我背之，今日之敗，天怒我也。舊聞漢法，殺人皆於都市，至京殺我，請向昭陵，使得謝罪於先帝，是本願也。」高宗聞而湣之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000151",
    "sentence": "及俘賀魯至京師，令獻於昭陵及太廟，詔特免死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000152",
    "sentence": "分其種落置昆陵、濛池二都護府，其所役屬諸國，皆分置州府，西盡於波斯，並隸安西都護府。",
    "entities": [
      {
        "text": "皆分置州",
        "label": "LOC",
        "start": 22,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000153",
    "sentence": "四年，賀魯卒。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000154",
    "sentence": "詔葬於頡利墓側，刻石以紀其事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000155",
    "sentence": "阿史那彌射者，室點密可汗五代孫也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000156",
    "sentence": "初，室點密從單於統領十大首領，有兵十萬眾，往平西域諸胡國，自為可汗，號十姓部落，世統其眾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000157",
    "sentence": "彌射在本蕃為莫賀咄葉護。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000158",
    "sentence": "貞觀六年，詔遣鴻臚少卿劉善因就蕃立為奚利邲咄陸可汗，賜以鼓纛、彩帛萬段。",
    "entities": [
      {
        "text": "貞觀六年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000159",
    "sentence": "其族兄步真欲自立為可汗，遂謀殺彌射弟侄二十余人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000160",
    "sentence": "彌射既與步真有隙，以貞觀十三年率所部處月、處密部落入朝，授右監門大將軍。",
    "entities": [
      {
        "text": "貞觀十三年",
        "label": "TME",
        "start": 10,
        "end": 15
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 32,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000161",
    "sentence": "其後步真遂自立為咄陸葉護，其部落多不服，委之遁去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000162",
    "sentence": "步真復攜家屬入朝，授左屯衛大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000163",
    "sentence": "彌射後從太宗征高麗有功，封平襄縣伯。",
    "entities": [
      {
        "text": "封平襄縣",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000164",
    "sentence": "顯慶二年，轉右武衛大將軍。",
    "entities": [
      {
        "text": "顯慶二年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000165",
    "sentence": "及討平賀魯，乃冊立彌射為興昔亡可汗兼右衛大將軍、昆陵都護，分押賀魯下五咄六部落。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 20,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000166",
    "sentence": "步真授繼往絕可汗，兼右衛大將軍、濛池都護，仍分押五弩失畢部落。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000167",
    "sentence": "因下詔曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000168",
    "sentence": "自西蕃罹亂，三十余年。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000169",
    "sentence": "比者賀魯猖狂，百姓重被劫掠。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000170",
    "sentence": "朕君臨四海，情均養育。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000171",
    "sentence": "不可使兇狡之虜，恣行侵漁，無辜之氓，久遭塗炭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000172",
    "sentence": "故遣右屯衛將軍蘇定方等統率騎勇，北路討逐。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000173",
    "sentence": "卿等宣暢朝風，南道撫育。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000174",
    "sentence": "遂使兇渠畏威，夷人慕德，伐叛柔服，西域總平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000175",
    "sentence": "賀魯父子既已擒獲，諸頭部落須有統領。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000176",
    "sentence": "卿早歸闕庭，久參宿衛，深感恩義，甚知法式，所以冊立卿等各為一部可汗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000177",
    "sentence": "但諸姓從賀魯，非其本情，卿等才至即降，亦是赤心向國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000178",
    "sentence": "卿宜與盧承慶等準其部落大小，位望高下，節級授刺史以下官。",
    "entities": [
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000179",
    "sentence": "龍朔中，又令彌射、步真率所部從釭海道大總管蘇海政討龜茲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000180",
    "sentence": "步真嘗欲並彌射部落，遂密告海政云：「彌射欲謀反，請以計誅之。」時海政兵才數千，懸師在彌射境內，遂集軍吏而謀曰：「彌射若反，我輩即無噍類。今宜先舉事，則可克捷。」乃偽稱有敕，令大總管賫物數百萬段分賜可汗及諸首領。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000181",
    "sentence": "由是彌射率其麾下，隨例請物，海政盡收斬之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000182",
    "sentence": "共後西蕃盛言彌射非反，為步真所誣，而海政不能審察，濫行誅戮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000183",
    "sentence": "則天臨朝，十姓無主數年，部落多散失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000184",
    "sentence": "垂拱初，遂擢授彌射子左豹韜衛翊府中郎將元慶為左玉鈐衛將軍兼昆陵都護，令襲興昔亡可汗，押五咄六部落。",
    "entities": [
      {
        "text": "中郎將",
        "label": "TITLE",
        "start": 16,
        "end": 19
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000185",
    "sentence": "步真子斛瑟羅為右玉鈐衛將軍，兼濛池都護，押五弩失畢部落。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000186",
    "sentence": "尋進授元慶左衛大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000187",
    "sentence": "如意元年，為來俊臣誣謀反被害。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000188",
    "sentence": "其子獻，配流崖州。",
    "entities": [
      {
        "text": "配流崖州",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000189",
    "sentence": "長安三年，召還。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000190",
    "sentence": "累授右驍衛大將軍，襲父興昔亡可汗，充安撫招慰十姓大使。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 5,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000191",
    "sentence": "獻本蕃漸為默啜及烏質勒所侵。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000192",
    "sentence": "遂不敢還國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000193",
    "sentence": "開元中，累遷右金吾大將軍。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 9,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000194",
    "sentence": "卒於長安。",
    "entities": [
      {
        "text": "長安",
        "label": "LOC",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000195",
    "sentence": "阿史那步真者，在本蕃授左屯衛大將軍。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000196",
    "sentence": "與彌射討平賀魯，加授驃騎大將軍、行右衛大將軍、濛池都護、繼往絕可汗，押五弩失畢部落。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 12,
        "end": 15
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 19,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000197",
    "sentence": "尋卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000198",
    "sentence": "其子斛瑟羅，本蕃為步利設，垂拱初，授右玉鈐衛將軍兼濛池都護、襲繼往絕可汗，押五弩失畢部落。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 22,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000199",
    "sentence": "天授元年，拜左衛大將軍，改封竭忠事主可汗，仍賜濛池都護。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000200",
    "sentence": "尋卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000201",
    "sentence": "子懷道，神龍年累授右屯衛大將軍、光祿卿，轉太仆卿兼濛池都護、十姓可汗。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000202",
    "sentence": "自垂拱已後，十姓部落頻被突厥默啜侵掠，死散殆盡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000203",
    "sentence": "及隨斛瑟羅才六七萬人，徙居內地，西突厥阿史那氏於是遂絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000204",
    "sentence": "突騎施烏質勒者，西突厥之別種也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000205",
    "sentence": "初隸在斛瑟羅下，號為莫賀達幹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000206",
    "sentence": "後以斛瑟羅用刑嚴酷，眾皆畏之，尤能撫恤其部落，由是為遠近諸胡所歸附。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000207",
    "sentence": "其下置都督二十員，各統兵七千人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000208",
    "sentence": "嘗屯聚碎葉西北界，後漸攻陷碎葉，徙其牙帳居之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000209",
    "sentence": "東北與突厥為鄰，西南與諸胡相接，東南至西廷州。",
    "entities": [
      {
        "text": "東南至西廷州",
        "label": "LOC",
        "start": 16,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000210",
    "sentence": "斛瑟羅以部眾削弱，自則天時入朝，不敢還蕃，其地並為烏質勒所並。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000211",
    "sentence": "景龍二年，詔封為西河郡王，令攝御史大夫，解琬就加冊立。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "詔封為西河郡",
        "label": "LOC",
        "start": 5,
        "end": 11
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000212",
    "sentence": "未至，烏質勒卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000213",
    "sentence": "其長子娑葛代統其眾，詔便立娑葛為金河郡王，仍賜以宮女四人。",
    "entities": [
      {
        "text": "立娑葛為金河郡",
        "label": "LOC",
        "start": 12,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000214",
    "sentence": "初，娑葛代父統兵，烏質勒下部將闕啜忠節甚忌之，以兵部尚書宗楚客當朝任勢，密遣使賫金七百兩以賂楚客，請停娑葛統兵。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000215",
    "sentence": "楚客乃遣御史中丞馮嘉賓充使至其境，陰與忠節籌其事，並自致書以申意。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000216",
    "sentence": "在路為娑葛遊兵所獲，遂斬嘉賓，仍進兵攻陷火燒等城，遣使上表以索楚客頭。",
    "entities": [
      {
        "text": "兵攻陷火燒等城",
        "label": "LOC",
        "start": 17,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000217",
    "sentence": "景龍三年，娑葛弟遮弩恨所分部落少於其兄，遂叛入突厥，請為鄉導，以討娑葛。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "請為鄉",
        "label": "LOC",
        "start": 26,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000218",
    "sentence": "默啜乃留遮弩，遣兵二萬人與其左右來討娑葛，擒之而還。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000219",
    "sentence": "默啜顧謂遮弩曰：「汝於兄弟尚不和協，豈能盡心於我。」遂與娑葛俱殺之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000220",
    "sentence": "默啜兵還，娑葛下部將蘇祿鳩集余眾，自立為可汗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000221",
    "sentence": "蘇祿者，突騎施別種也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000222",
    "sentence": "頗善綏撫，十姓部落漸歸附之，眾二十萬，遂雄西域之地，尋遣使來朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000223",
    "sentence": "開元三年，制授蘇祿為左羽林軍大將軍、金方道經略大使，進為特勒，遣侍御史解忠順賫璽書冊立為忠順可汗。",
    "entities": [
      {
        "text": "開元三年",
        "label": "TME",
        "start": 0,
        "end": 4
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 14,
        "end": 17
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000224",
    "sentence": "自是每年遣使朝獻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000225",
    "sentence": "上乃立史懷道女為金河公主以妻之。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000226",
    "sentence": "時杜暹為安西都護，公主遣牙官賫馬千疋詣安西互市。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000227",
    "sentence": "使者宣公主教與暹，暹怒曰：「阿史那氏女，豈合宣教與吾節度耶！」杖其使者，留而不遣，其馬經雪，寒死並盡。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000228",
    "sentence": "蘇祿大怒，發兵分寇四鎮。",
    "entities": [
      {
        "text": "發兵分寇四鎮",
        "label": "LOC",
        "start": 5,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000229",
    "sentence": "會杜暹入知政事，趙頤貞代為安西都護，城守久之，由是四鎮貯積及人畜並為蘇祿所掠，安西僅全。",
    "entities": [
      {
        "text": "由是四鎮",
        "label": "LOC",
        "start": 23,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000230",
    "sentence": "蘇祿既聞杜暹入相，稍引退，俄又遣使入朝獻方物。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000231",
    "sentence": "十八年，蘇祿使至京師，玄宗禦丹鳳樓設宴。",
    "entities": [
      {
        "text": "十八年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000232",
    "sentence": "突厥先遣使入朝，是日亦來預宴，與蘇祿使爭長。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000233",
    "sentence": "突厥使曰：「突騎施國小，本是突厥之臣，不宜居上。」蘇祿使曰：「今日此宴，乃為我設，不合居下。」於是中書門下及百僚議，遂於東西幕下兩處分坐，突厥使在東，突騎施使在西。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000234",
    "sentence": "宴訖，厚賫而遣之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000235",
    "sentence": "蘇祿性尤清儉，每戰伐，有所克獲，盡分與將士及諸部落。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000236",
    "sentence": "其下愛之，甚為其用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000237",
    "sentence": "潛又遣使南通吐蕃，東附突厥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000238",
    "sentence": "突厥及吐蕃亦嫁女與蘇祿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000239",
    "sentence": "既以三國女為可敦，又分立數子為葉護，費用漸廣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000240",
    "sentence": "先既不為積貯，晚年抄掠所得者，留不分之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000241",
    "sentence": "又因風病，一手攣縮，其下諸部，心始攜貳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000242",
    "sentence": "有大首領莫賀達幹、都摩度兩部落，最為強盛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000243",
    "sentence": "百姓又分為黃姓、黑姓兩種，互相猜阻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000244",
    "sentence": "二十六年夏，莫賀達幹勒兵夜攻蘇祿，殺之。",
    "entities": [
      {
        "text": "二十六年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000245",
    "sentence": "都摩度初與莫賀達幹連謀，俄又相背，立蘇祿之子咄火仙為可汗，以輯其余眾，與莫賀達幹自相攻擊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000246",
    "sentence": "莫賀達幹遣使告安西都護蓋嘉運。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000247",
    "sentence": "嘉運率兵討之，大敗都摩度之眾，臨陣擒咄火仙，並收得金河公主而還。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 27,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000248",
    "sentence": "又欲立史懷道之子昕為可汗以鎮撫之，莫賀達幹不肯，曰：「討平蘇祿，本是我之元謀，若立史昕為主，則國家何以酬賞於我？」乃不立史昕，便令莫賀達幹統眾。",
    "entities": [
      {
        "text": "子昕為可汗以鎮",
        "label": "LOC",
        "start": 7,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000249",
    "sentence": "二十七年二月，嘉運率將士詣闕獻俘，玄宗禦花萼樓以宴之，仍令將吐火仙獻於太廟。",
    "entities": [
      {
        "text": "二十七年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_194c_000250",
    "sentence": "俄又黃姓、黑姓自相屠殺，各遣使降附。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000251",
    "sentence": "史臣曰：中原多事，外國窺邊，周獫狁、漢匈奴之後，其類實繁，前史論之備矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000252",
    "sentence": "突厥自隋文修王道，肅軍容，示恩威以羈縻之；煬帝失政教，生戎心，肇亂離以啟發之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000253",
    "sentence": "高祖借其力而入平京師，群賊附其強而叠據河朔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000254",
    "sentence": "高祖同禦榻以延其使，太宗幸便橋以約其和。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000255",
    "sentence": "當其時焉，不其盛矣！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000256",
    "sentence": "竟滅其族而身死於國者，何也？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000257",
    "sentence": "咸謂太宗有馭夷狄之道，李勣著戡定之功。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000258",
    "sentence": "殊不知突厥之始也，賞罰明而將士戮力。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000259",
    "sentence": "遇煬帝之亂，亡命蓄怒者既附之，其興也宜哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000260",
    "sentence": "頡利之衰也，兄弟扌勾隙而部族離心。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000261",
    "sentence": "當太宗之理，謀臣猛將討逐之，其亡也宜哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000262",
    "sentence": "洎武後亂朝，默啜犯塞，玄宗纂嗣，傳首京師，東封太山，西戎扈蹕，開元之代，繼踵來降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000263",
    "sentence": "西突厥諸族，遇其理，則眾心悅附而甲兵興焉；遇其亂，則族類怨怒而本根破矣！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000264",
    "sentence": "理亂二道，華夷一途。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000265",
    "sentence": "或質言於盛衰倚伏，未為確論。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000266",
    "sentence": "贊曰：中國失政，邊夷幸災。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000267",
    "sentence": "理亂之道，取鑒將來。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_194c_000268",
    "sentence": "本五代作品在全世界都属于 公有领域 ，因为作者逝世已经遠遠超过100年。",
    "entities": [
      {
        "text": "100年",
        "label": "TME",
        "start": 31,
        "end": 35
      }
    ]
  }
]
