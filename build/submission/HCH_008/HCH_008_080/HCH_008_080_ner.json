  {
    "sentence_id": "HCH_008_080_000103",
    "sentence": "遂良復上疏諫曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_080_000104",
    "sentence": "臣聞周世問安，三至必退，漢儲視膳，五日乃來。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_080_000105",
