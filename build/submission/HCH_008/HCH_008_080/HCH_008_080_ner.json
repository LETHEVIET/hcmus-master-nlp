      }
    ]
  },
  {
    "sentence_id": "HCH_008_080_000201",
    "sentence": "貞觀初，楊仁恭為都督，深禮待之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_080_000202",
    "sentence": "舉進士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_080_000203",
    "sentence": "太宗聞其名，召授弘文館直學士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_080_000204",
    "sentence": "累遷秘書郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_080_000205",
    "sentence": "時太宗雅好屬文，每遣儀視草，又多令繼和，凡有宴集，儀嘗預焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_080_000206",
    "sentence": "俄又預撰《晉書》成，轉起居郎，加級賜帛。",
    "entities": [
