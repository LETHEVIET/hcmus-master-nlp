  },
  {
    "sentence_id": "HCH_008_080_000193",
    "sentence": "兄 亙",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_080_000194",
    "sentence": "濟兄亙，有學行，與濟齊名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_080_000195",
    "sentence": "上元中，官至黃門侍郎、同中書門下三品。",
