        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000069",
    "sentence": "遷晉州刺史，改同州刺史，未視事，又歷晉、鄭二州刺史。",
    "entities": [
