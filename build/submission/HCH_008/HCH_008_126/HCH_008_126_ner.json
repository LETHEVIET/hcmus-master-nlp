      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000080",
    "sentence": "仍加銀青光祿大夫，封潁川縣開國子。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 6,
        "end": 8
      },
      {
        "text": "封潁川縣",
        "label": "LOC",
        "start": 9,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000081",
    "sentence": "所在悉心綏輯，而多以任數為政，好行小惠，胥吏得職，人亦獲安。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000082",
    "sentence": "及朝廷多事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000083",
    "sentence": "奏請本道兩稅錢千增二百。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000084",
    "sentence": "因詔諸道悉如淮南，鹽每一斗更加一百文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000085",
    "sentence": "少遊十餘年間，三總大籓，皆天下殷厚處也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000086",
    "sentence": "以故征求貿易，且無虛日，斂積財寶，累巨億萬，多賂遺權貴，視文雅清流之士，蔑如也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000087",
    "sentence": "初結元載，每年饋金帛約十萬貫，又多納賂於用事中官駱奉先、劉清潭、吳承倩等，由是美聲達於中禁。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000088",
    "sentence": "後見元載在相位年深，以過犯漸見疑忌，少遊亦稍疏之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000089",
    "sentence": "無何，載子伯和貶官揚州，少遊外與之交結，而陰使人伺其過失，密以上聞。",
    "entities": [
      {
        "text": "子伯和貶官揚州",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000090",
    "sentence": "代宗以為忠，待之益厚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000091",
    "sentence": "上即位，累加檢校禮部、兵部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000092",
    "sentence": "建中三年，李納反叛，少遊以師收徐、海等州，尋棄之，退軍盱眙。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "海等州",
        "label": "LOC",
        "start": 17,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000093",
    "sentence": "又加檢校左僕射，賜實封三百戶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000094",
    "sentence": "其年，就加同平章事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000095",
    "sentence": "關播嘗為少遊賓僚，盧杞早年與之同在仆固懷恩使府，故驟加其官秩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000096",
    "sentence": "四年十月，駕幸奉天，度支汴東兩稅使包佶在揚州，尚未知也。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "稅使包佶在揚州",
        "label": "LOC",
        "start": 15,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000097",
    "sentence": "佶判官崔沅遽報少遊，佶時所總賦稅錢帛約八百萬貫在焉，少遊意以為賊據京師，未即收復，遂脅取其財物。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000098",
    "sentence": "先使判官崔就佶強索其納給文歷，並請供二百萬貫錢物以助軍費，佶答曰：「所用財帛，須承敕命。」未與之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000099",
    "sentence": "勃然曰：「中丞若得，為劉長卿；不爾，為崔眾矣。」長卿嘗任租庸使，為吳仲孺所困，崔眾供軍吝財，為光弼所殺，故言及之，佶大懼，不敢固護，財帛將轉輸入京師者，悉為少遊奪之。",
    "entities": [
      {
        "text": "劉長卿",
        "label": "PER",
        "start": 11,
        "end": 14
      },
      {
        "text": "吳仲孺",
        "label": "PER",
        "start": 33,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000100",
    "sentence": "佶自謁，少遊止焉，長揖而遣，既懼禍，奔往白沙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000101",
    "sentence": "少遊又遣判官房孺復召之，佶愈懼，托以巡檢，因急棹過江，妻子伏案牘中。",
    "entities": [
      {
        "text": "房孺復",
        "label": "PER",
        "start": 6,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000102",
    "sentence": "至上元，復為韓滉所拘留。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000103",
    "sentence": "佶先有兵三千，守禦財貨，令高越、元甫將焉，少遊盡奪之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000104",
    "sentence": "隨佶渡江者，又為韓滉所留，佶但領胥吏往江、鄂等州。",
    "entities": [
      {
        "text": "鄂等州",
        "label": "LOC",
        "start": 21,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000105",
    "sentence": "佶於彈丸中置表，以少遊脅取財帛事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000106",
    "sentence": "會少遊使繼至，上問曰：「少遊取包佶財帛，有之乎？」對曰：「臣發揚州後，非所知也。」上曰：「少遊國之守臣，或防他盜，供費軍旅，收亦何傷。」時方隅阻絕，國命未振，遠近聞之大驚，鹹以聖情達於變通，明見萬里。",
    "entities": [
      {
        "text": "臣發揚州",
        "label": "LOC",
        "start": 29,
        "end": 33
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000107",
    "sentence": "少遊後聞之，乃安。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000108",
    "sentence": "及李希烈陷汴州，聲言欲襲江淮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000109",
    "sentence": "少遊懼，乃使參謀溫述由壽州送款於希烈曰：「濠、壽、舒、廬，尋令罷壘，韜戈卷甲，佇候指揮。」少遊又遣巡官趙詵於鄆州結李納。",
    "entities": [
      {
        "text": "參謀溫述由壽州",
        "label": "LOC",
        "start": 6,
        "end": 13
      },
      {
        "text": "巡官趙詵於鄆州",
        "label": "LOC",
        "start": 49,
        "end": 56
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000110",
    "sentence": "其年，希烈僭號，遣其將楊豐賫偽赦書赴揚州，至壽州，為刺史張建封候騎所得，建封對中使二人及少遊判官許子瑞廷責豐而斬之。",
    "entities": [
      {
        "text": "賫偽赦書赴揚州",
