    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000002",
    "sentence": "李揆字端卿，隴西成紀人，而家於鄭州，代為冠族。",
    "entities": [
      {
        "text": "而家於鄭州",
        "label": "LOC",
        "start": 12,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000003",
    "sentence": "秦府學士、給事中玄道玄孫，秘書監、贈吏部尚書成裕之子。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 20,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000004",
    "sentence": "少聰敏好學，善屬文。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000005",
    "sentence": "開元末，舉進士，補陳留尉，獻書闕下，詔中書試文章，擢拜右拾遺。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 1,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000006",
    "sentence": "改右補闕、起居郎，知宗子表疏。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000007",
    "sentence": "遷司勛員外郎、考功郎中，並知制誥。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000008",
    "sentence": "扈從劍南，拜中書舍人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000009",
    "sentence": "乾元初，兼禮部侍郎。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "侍郎",
