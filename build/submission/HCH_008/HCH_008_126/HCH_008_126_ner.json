      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000060",
    "sentence": "時同列有私習經義者，期升坐日相問難。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000061",
    "sentence": "及會，少遊攝齊升坐，音韻清辯，觀者屬目。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000062",
    "sentence": "所引文句，悉兼他義，諸生不能對，甚為大學士陳希烈所嘆賞，又以同宗，遇之甚厚。",
    "entities": [
      {
        "text": "陳希烈",
        "label": "PER",
        "start": 21,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000063",
    "sentence": "既擢第，補渝州南平令，理甚有聲。",
    "entities": [
      {
        "text": "補渝州",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000064",
    "sentence": "至德中，河東節度王思禮奏為參謀，累授大理司直、監察殿中侍御史、節度判官。",
    "entities": [
      {
        "text": "王思禮",
        "label": "PER",
        "start": 8,
        "end": 11
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000065",
    "sentence": "寶應元年，入為金部員外郎。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000066",
    "sentence": "尋授侍御史、迥紇糧料使，改檢校職方員外郎。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_126_000067",
    "sentence": "充使檢校郎官，自少遊始也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_126_000068",
    "sentence": "明年，仆固懷恩奏為河北副元帥判官、兵部郎中、兼侍御史。",
    "entities": [
      {
        "text": "御史",
