        "label": "TITLE",
        "start": 55,
        "end": 57
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000143",
    "sentence": "平仲與考功員外陳歸當奉使，因辭得對，乃入近禦座，粗陳本事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000144",
    "sentence": "上察平仲意有所蓄，以歸在側不言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000145",
    "sentence": "及奏事畢退，平仲獨不退，欲有奏啟；上因兼留歸問之，聲色甚厲，雜以他語。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000146",
    "sentence": "平仲錯愕，都不得言因誤稱其名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000147",
    "sentence": "上怒，叱出之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000148",
    "sentence": "平仲蒼黃，又誤趨禦障後，歸下階連呼，乃得出。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000149",
    "sentence": "由是坐廢七年，然亦因此名顯。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000150",
    "sentence": "後除屯田膳部二員外郎、東都留守判官，累拜右司郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000151",
    "sentence": "元和初，遷諫議大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000152",
    "sentence": "內官吐突承璀為招討使，征鎮州，無功而還。",
    "entities": [
      {
        "text": "征鎮州",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000153",
    "sentence": "平仲與呂元膺抗疏論列，請加黜責。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000154",
    "sentence": "轉給事中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000155",
    "sentence": "自在要近，朝廷有得失，未嘗不論奏，時人推其狷直。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000156",
    "sentence": "轉尚書左丞，以疾改太子左庶子卒。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 1,
        "end": 3
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000157",
    "sentence": "薛存誠",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000158",
    "sentence": "薛存誠，字資明，河東人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000159",
    "sentence": "父勝，能文，嘗作《拔河賦》，詞致瀏亮，為時所稱。",
    "entities": [
      {
        "text": "《拔河賦》",
        "label": "TITLE",
        "start": 8,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000160",
    "sentence": "存誠進士擢第，累辟使府，入朝為監察御史，知館驛。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 17,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000161",
    "sentence": "元和初，王師討劉辟，郵傳多事，上特令中官為館驛使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000162",
    "sentence": "存誠密表論奏，以為有傷公體。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000163",
    "sentence": "會諫官亦論奏，上乃罷之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000164",
    "sentence": "轉殿中侍御史，遷度支員外郎。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000165",
    "sentence": "裴垍作相，用為起居郎，轉司勛員外、刑部郎中、兼侍御史、知雜事，改兵部郎中、給事中。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000166",
    "sentence": "瓊林庫使奏占工徒太廣，存誠以為此皆奸人竄名，以避征役，不可許。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000167",
    "sentence": "咸陽縣尉袁儋與軍鎮相競，軍人無理，遂肆侵誣，儋反受罰。",
    "entities": [
      {
        "text": "咸陽縣",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "尉袁儋與軍鎮",
        "label": "LOC",
        "start": 3,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000168",
    "sentence": "二敕繼至，存誠皆執之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000169",
    "sentence": "上聞甚悅，命中使嘉慰之，由是擢拜御史中丞。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000170",
    "sentence": "僧鑒虛者，自貞元中交結權倖，招懷賂遺，倚中人為城社，吏不敢繩。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 7,
        "end": 8
      },
      {
        "text": "倚中人為城",
        "label": "LOC",
        "start": 19,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000171",
    "sentence": "會於頔、杜黃裳家私事發，連逮鑒虛下獄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000172",
    "sentence": "存誠案鞫得奸贓數十萬，獄成，當大辟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000173",
    "sentence": "中外權要，更於上前保救，上宣令釋放，存誠不奉詔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000174",
    "sentence": "明日，又令中使詣臺宣旨曰：「朕要此僧面詰之，非赦之也。」存誠附中使奏曰：「鑒虛罪款已具，陛下若召而赦之，請先殺臣，然後可取。不然，臣期不奉詔。」上嘉其有守，從之，鑒虛竟笞死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000175",
    "sentence": "洪州監軍高重昌誣奏信州刺史李位謀大逆，追赴京師。",
    "entities": [
      {
        "text": "洪州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "高重昌誣奏信州",
        "label": "LOC",
        "start": 4,
        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000176",
    "sentence": "上令付仗內鞫問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000177",
    "sentence": "存誠一日三表，請付位於御史臺。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000178",
    "sentence": "及推案無狀，位竟得雪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000179",
    "sentence": "未幾，再授給事中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000180",
    "sentence": "數月，中丞闕，上思存誠前效，謂宰相持憲無以易存誠，遂復為御史中丞。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000181",
    "sentence": "未視事，暴卒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000182",
    "sentence": "憲宗深惜之，贈刑部侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000183",
    "sentence": "存誠性和易，於人無所不容，及當官禦事，即確乎不拔，士友以是稱重之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000184",
    "sentence": "子廷老。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000185",
    "sentence": "廷老謹正有父風，而性通銳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000186",
    "sentence": "寶歷中為右拾遺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000187",
    "sentence": "敬宗荒恣，宮中造清思院新殿，用銅鏡三千片、黃白金薄十萬番。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000188",
    "sentence": "廷老與同僚入閣奏事曰：「臣伏見近日除拜，往往不由中書進擬，或是宣出。伏恐綱紀漸壞，奸邪恣行。」敬宗厲聲曰：「更諫何事？」舒元褒對曰：「近日宮中修造太多。」上色變曰：「何處修造？」元褒不能對，廷老進曰：「臣等職是諫官，凡有所聞，即合論奏。莫知修造之所，但見運瓦木絕多，即知有用。乞陛下勿罪臣言。」帝曰：「所奏已知。」尋加史館修撰。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000189",
    "sentence": "時李逢吉秉權，惡廷老言太切直。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000190",
    "sentence": "鄭權因鄭註得廣州節度，權至鎮，盡以公家珍寶赴京師以酬恩地。",
    "entities": [
      {
        "text": "權因鄭註得廣州",
        "label": "LOC",
        "start": 1,
        "end": 8
      },
      {
        "text": "權至鎮",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000191",
    "sentence": "廷老上疏請按權罪，中人由是切齒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000192",
    "sentence": "又論逢吉黨人張權輿、程昔範不宜居諫列，逢吉大怒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000193",
    "sentence": "廷老告滿十旬，逢吉乃出廷老為臨晉縣令。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000194",
    "sentence": "文宗即位，入為殿中侍御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000195",
    "sentence": "太和四年，以本官充翰林學士，與同職李讓夷相善。",
    "entities": [
      {
        "text": "太和四年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000196",
    "sentence": "廷老之入內署，讓夷薦挈之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000197",
    "sentence": "廷老性放逸嗜酒，不持檢操，終日酣醉，文宗知之不悅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000198",
    "sentence": "五年，罷職，守本官，讓夷亦坐廷老罷職，守職方員外郎。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000199",
    "sentence": "廷老尋拜刑部員外郎，轉郎中，遷給事中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000200",
    "sentence": "開成三年卒。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000201",
    "sentence": "廷老當官舉職，不求虛譽，侃侃於公卿之間，甚有正人風望。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000202",
    "sentence": "贈刑部侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000203",
    "sentence": "子保遜，登進士第，位亦至給事中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000204",
    "sentence": "保遜子昭緯，乾寧中為禮部侍郎，貢舉得人，文章秀麗。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000205",
    "sentence": "為崔胤所惡，出為磎州刺史，卒。",
    "entities": [
      {
        "text": "出為磎州",
        "label": "LOC",
        "start": 6,
        "end": 10
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000206",
    "sentence": "盧坦",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000207",
    "sentence": "盧坦，字保衡，河南洛陽人，其先自范陽徙焉。",
    "entities": [
      {
        "text": "洛陽",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000208",
    "sentence": "父巒，贈鄭州刺史。",
    "entities": [
      {
        "text": "贈鄭州",
        "label": "LOC",
        "start": 3,
        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000209",
    "sentence": "坦嘗為義成軍判官，節度使李復疾篤，監軍使薛盈珍慮變，遽封府庫，入其麾下五百人於使牙，軍中恟々；坦密言於盈珍促收之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000210",
    "sentence": "及復卒，坦護喪歸東都。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000211",
    "sentence": "後為壽安令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000212",
    "sentence": "時河南尹征賦限窮，而縣人訴以機織未就；坦請延十日，府不許。",
    "entities": [
      {
        "text": "而縣",
        "label": "LOC",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000213",
    "sentence": "坦令戶人但織而輸，勿顧限也，違之不過罰令俸耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000214",
    "sentence": "既成而輸，坦亦坐罰，由是知名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000215",
    "sentence": "累遷至庫部員外郎、兼侍御史、知雜事。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000216",
    "sentence": "會李锜反，有司請毀锜祖父廟墓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000217",
    "sentence": "坦常為锜從事，乃上言曰：「淮安王神通有功於草昧。且古之父子兄弟，罪不相及，況以锜故累五代祖乎？」乃不毀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000218",
    "sentence": "因賜神通墓五戶，以備灑掃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000219",
    "sentence": "及武元衡為宰相，以坦為中丞，李元素為大夫，命坦分司東都，未幾歸臺。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000220",
    "sentence": "裴均為僕射，在班逾位，坦請退之，均不受。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000221",
    "sentence": "坦曰：「姚南仲為僕射，例如此。」均曰：「南仲何人？」坦曰：「南仲是守正而不交權幸者也。」尋罷為右庶子，時人歸咎於均。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000222",
    "sentence": "旬月，出為宣歙池觀察使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000223",
