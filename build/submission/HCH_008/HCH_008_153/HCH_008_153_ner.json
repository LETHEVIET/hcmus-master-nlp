[
  {
    "sentence_id": "HCH_008_153_000001",
    "sentence": "姚南仲",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000002",
    "sentence": "姚南仲，華州下邽人。",
    "entities": [
      {
        "text": "華州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000003",
    "sentence": "乾元初，制科登第，授太子校書，歷高陵、昭應、萬年三縣尉。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 10,
        "end": 12
      },
      {
        "text": "萬年三縣",
        "label": "LOC",
        "start": 22,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000004",
    "sentence": "遷右拾遺，轉右補闕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000005",
    "sentence": "大歷十三年，貞懿皇后獨孤氏崩，代宗悼惜不已，令於近城為陵墓，冀朝夕臨望於目前。",
    "entities": [
      {
        "text": "十三年",
        "label": "TME",
        "start": 2,
        "end": 5
      },
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "令於近城",
        "label": "LOC",
        "start": 22,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000006",
    "sentence": "南仲上疏諫曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000007",
    "sentence": "伏聞貞懿皇后今於城東章敬寺北以起陵廟，臣不知有司之請乎，陛下之意乎，陰陽家流希旨乎？",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000008",
    "sentence": "臣愚以為非所宜也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000009",
    "sentence": "謹具疏陳論，伏願暫留天睠而省察焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000010",
    "sentence": "臣聞人臣宅於家，君上宅於國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000011",
    "sentence": "長安城，是陛下皇居也，其可穿鑿興動，建陵墓於其側乎？",
    "entities": [
      {
        "text": "長安城",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000012",
    "sentence": "此非宜一也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000013",
    "sentence": "夫葬者藏也，欲人之不得見也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000014",
    "sentence": "是以古帝前王葬后妃，莫不憑丘原，遠郊郭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000015",
    "sentence": "今則西臨宮闕，南迫康莊，若使近而可見，死而復生，雖在西宮待之可也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000016",
    "sentence": "如骨肉歸土，魂無不之，章敬之北，竟何所益？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000017",
    "sentence": "視之兆庶，則彰溺愛；垂之萬代，則累明德，此非所宜二也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000018",
    "sentence": "夫帝王者，居高明，燭幽滯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000019",
    "sentence": "先皇所以因龍首建望春，蓋為此也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000020",
    "sentence": "今若起陵目前，動傷宸慮，天心一傷，數日不平。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000021",
    "sentence": "且匹夫向隅，滿堂為之不樂；萬乘不樂，人其可歡心乎？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000022",
    "sentence": "又暇日起歌，動鐘於內，此地皆聞，此非宜三也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000023",
    "sentence": "伏以貞懿皇后，坤德合天，母慈逮下，陛下以切軫旒扆，久俟蓍龜。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000024",
    "sentence": "始謚之以貞懿，終待之以褻近，臣竊惑焉，非所以稱述後德，光被下泉也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000025",
    "sentence": "今國人皆曰：「貞懿皇后之陵邇於城下者，主上將日省而時望焉。」斯有損於聖德，無益於貞懿。",
    "entities": [
      {
        "text": "皇后",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000026",
    "sentence": "將欲寵之，而反辱之，此非宜四也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000027",
    "sentence": "凡此數事，實玷大猷，天下鹹知，伏惟陛下熟計而取其長也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000028",
    "sentence": "陛下方將偃武靖人，一誤於此，其傷實多。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000029",
    "sentence": "臣恐君子是非，史官褒貶，大明忽虧於掩蝕，至德翻後於堯、舜，不其惜哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000030",
    "sentence": "今指日尚遙，改卜何害？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000031",
    "sentence": "抑皇情之殊眷，成貞懿之美號。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000032",
    "sentence": "疏奏，帝甚嘉之，賜緋魚袋，特加五品階，宣付史館。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000033",
    "sentence": "與宰相常袞善，袞貶官，南仲坐出為海鹽縣令。",
    "entities": [
      {
        "text": "縣令",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000034",
    "sentence": "浙江東、西道觀察使韓滉辟為推官，奏授殿中侍御史、內供奉，充支使。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000035",
    "sentence": "尋征還，歷左司兵部員外，轉郎中，遷御史中丞、給事中、同州刺史、陜虢觀察使。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 17,
        "end": 19
      },
      {
        "text": "同州",
        "label": "LOC",
        "start": 26,
        "end": 28
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000036",
    "sentence": "貞元十五年，代李復為鄭滑節度使。",
    "entities": [
      {
        "text": "十五年",
        "label": "TME",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000037",
    "sentence": "監軍薛盈珍恃勢奪軍政，南仲數為盈珍讒毀，德宗頗疑之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000038",
    "sentence": "十六年，盈珍遣小使程務盈馳驛奉表，誣奏南仲陰事。",
    "entities": [
      {
        "text": "十六年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000039",
    "sentence": "南仲裨將曹文洽亦入奏事京師，伺知盈珍表中語。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000040",
    "sentence": "文洽私懷憤怒，遂晨夜兼道追務盈，至長樂驛及之，與同舍宿；中夜殺務盈，沈盈珍表於廁中，乃自殺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000041",
    "sentence": "日旰，驛吏辟門，見血流塗地，旁得文洽二緘，一告於南仲，一表理南仲之冤，且陳首殺務盈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000042",
    "sentence": "上聞其事，頗駭異之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000043",
    "sentence": "南仲慮釁深，遂乞入朝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000044",
    "sentence": "德宗曰：「盈珍擾軍政耶？」南仲對曰：「勇珍不擾軍政，臣自隳陛下法耳。如盈珍輩所在有之，雖羊、杜復生，撫百姓，禦三軍，必不能成愷悌父母之政，師律善陣之制矣。」上默然久之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000045",
    "sentence": "授尚書右僕射。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000046",
    "sentence": "貞元十九年七月，終於位，年七十四，贈太子太保，謚曰貞。",
    "entities": [
      {
        "text": "十九年",
        "label": "TME",
        "start": 2,
        "end": 5
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000047",
    "sentence": "劉迺",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000048",
    "sentence": "劉迺，字永夷，洺州廣平人。",
    "entities": [
      {
        "text": "洺州",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000049",
    "sentence": "高祖武幹，武德初拜侍中，即中書侍郎林甫從祖兄子也。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000050",
    "sentence": "父如璠，昫山丞，以迺貴，贈民部郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000051",
    "sentence": "迺少聰穎誌學，暗記《六經》，日數千言。",
    "entities": [
      {
        "text": "《六經》",
        "label": "TITLE",
        "start": 9,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000052",
    "sentence": "及長，文章清雅，為當時推重。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000053",
    "sentence": "天寶中，舉進士，尋丁父艱，居喪以孝聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000054",
    "sentence": "既終制，從調選曹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000055",
    "sentence": "迺常以文部選才未為盡善，遂致書於知銓舍人宋昱曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000056",
    "sentence": "《虞書》稱：「知人則哲，能官人則惠。」巍巍唐、虞，舉以為難。",
    "entities": [
      {
        "text": "《虞書》",
        "label": "TITLE",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000057",
    "sentence": "今夫文部，既始之以掄材，終之以授位，是則知人官人，斯為重任。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000058",
    "sentence": "昔在禹、稷、臯陶之眾聖，猶曰載采有九德，考績以九載。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000059",
    "sentence": "近代主司，獨委一二小冢宰，察言於一幅之判，觀行於一揖之內，古今遲速，何不侔之甚哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000060",
    "sentence": "夫判者，以狹詞短韻，語有定規為體，亦猶以一小冶而鼓眾金，雖欲為鼎為鏞，不可得也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000061",
    "sentence": "故曰：判之在文，至局促者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000062",
    "sentence": "夫銓者，必以崇衣冠，自媒耀為賢，斯又士之醜行，君子所病。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000063",
    "sentence": "若引文公、尼父登之於銓廷，則雖圖書《易象》之大訓，以判體挫之，曾不及徐、庾。",
    "entities": [
      {
        "text": "《易象》",
        "label": "TITLE",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000064",
    "sentence": "雖有至德，以喋喋取之，曾不若嗇夫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000065",
    "sentence": "嗚呼！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000066",
    "sentence": "彼幹霄蔽日，誠巨樹也，當求尺寸之材，必後於椓杙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000067",
    "sentence": "龍吟武嘯，誠希聲也，若尚頰舌之感，必下於蛙黽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000068",
    "sentence": "觀察之際，猶不悲夫！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000069",
    "sentence": "執事慮過龜策，文合雅誥，豈拘以瑣瑣故事，曲折因循哉？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000070",
    "sentence": "誠能先資以政事，次征以文學，退觀其理家，進察其臨節，則厖鴻深沈之事，亦可以窺其門戶矣！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000071",
    "sentence": "其載，補剡縣尉，改會稽尉。",
    "entities": [
      {
        "text": "補剡縣",
        "label": "LOC",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000072",
    "sentence": "宣州觀察使殷日用奏為判官，宣慰使李季卿又以表薦，連授大理評事、兼監察御史。",
    "entities": [
      {
        "text": "宣州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 34,
        "end": 36
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000073",
    "sentence": "轉運使劉晏奏令巡覆江西，多所蠲免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000074",
    "sentence": "改殿中侍御史、檢校倉部員外、民部郎中，並充浙西留後。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000075",
    "sentence": "佐晏征賦，頗有裨益，晏甚任之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000076",
    "sentence": "大歷十二年，元載既誅，以迺久在職，召拜司門員外郎。",
    "entities": [
      {
        "text": "十二年",
        "label": "TME",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000077",
    "sentence": "十四年，崔祐甫秉政，素與迺友善。",
    "entities": [
      {
        "text": "十四年",
        "label": "TME",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000078",
    "sentence": "會加郭子儀尚父，以冊禮久廢，至是復行之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000079",
    "sentence": "祐甫令兩省官撰冊文，未稱旨；召迺至閣草之，立就。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000080",
    "sentence": "詞義典裁，祐甫嘆賞久之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000081",
    "sentence": "數日，擢為給事中，尋遷權知兵部侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_153_000082",
    "sentence": "及楊炎、盧杞為相，意多醜正，以故五歲不遷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_153_000083",
    "sentence": "建中四年夏，但真拜而已。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
