[
  {
    "sentence_id": "HCH_008_071_000001",
    "sentence": "魏徵",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000002",
    "sentence": "魏徵，字玄成，鉅鹿曲城人也。",
    "entities": [
      {
        "text": "鉅鹿曲城",
        "label": "LOC",
        "start": 7,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_071_000003",
    "sentence": "父長賢，北齊屯留令。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000004",
    "sentence": "徵少孤貧，落拓有大志，不事生業，出家爲道士。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000005",
    "sentence": "好讀書，多所通涉，見天下漸亂，尤屬意縱橫之説。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000006",
    "sentence": "大業末，武陽郡丞元寶藏舉兵以應李密，召徵使典書記。",
    "entities": [
      {
        "text": "武陽郡",
        "label": "LOC",
        "start": 4,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_071_000007",
    "sentence": "密毎見寶藏之疎，未嘗不稱善，既聞徵所爲，遽使召之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000008",
    "sentence": "徵進十策以干密，雖奇之而不能用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000009",
    "sentence": "及王世充攻密於洛口，徵説密長史鄭頲曰：「魏公雖驟勝，而驍將銳卒死傷多矣；又軍無府庫，有功不賞。戰士心惰，此二者難以應敵。未若深溝高壘，曠日持久，不過旬月，敵人糧盡，可不戰而退，追而擊之，取勝之道。且東都食盡，世充計窮，意欲死戰，可謂窮寇難與爭鋒，請慎無與戰。」頲曰：「此老生之常談耳！」徵曰：「此乃奇謀深策，何謂常談？」因拂衣而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000010",
    "sentence": "及密敗，徵隨密來降，至京師，久不見知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000011",
    "sentence": "自請安輯山東，乃授秘書丞，驅傳至黎陽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000012",
    "sentence": "時徐世勣尚爲李密擁眾，徵與世勣書曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000013",
    "sentence": "自隋末亂離，群雄競逐，跨州連郡，不可勝數。",
    "entities": [
      {
        "text": "隋",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "跨州連郡",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_071_000014",
    "sentence": "魏公起自叛徒，奮臂大呼，四方響應，萬里風馳，雲合霧聚，眾數十萬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000015",
    "sentence": "威之所被，將半天下，破世充於洛口，摧化及於黎山。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000016",
    "sentence": "方欲西蹈咸陽，北凌玄闕，揚旌瀚海，飲馬渭川，翻以百勝之威，敗於奔亡之虜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000017",
    "sentence": "固知神器之重，自有所歸，不可以力爭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000018",
    "sentence": "是以魏公思皇天之乃睠，入函谷而不疑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000019",
    "sentence": "公生於擾攘之時，感知己之遇。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000020",
    "sentence": "根本已拔，確乎不動，鳩合遺散，據守一隅。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000021",
    "sentence": "世充以乘勝餘勇，息其東略；建德因侮亡之勢，不敢南謀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000022",
    "sentence": "公之英聲，足以振於今古。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000023",
    "sentence": "然誰無善始，終之慮難。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000024",
    "sentence": "去就之機，安危大節。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000025",
    "sentence": "若策名得地，則九族廕其餘輝；委質非人，則一身不能自保。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000026",
    "sentence": "殷鑑不遠，公所聞見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000027",
    "sentence": "孟賁猶豫，童子先之，知幾其神，不俟終日。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000028",
    "sentence": "今公處必爭之地，乘宜速之機，更事遲疑，坐觀成敗，恐凶狡之輩，先人生心，則公之事去矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000029",
    "sentence": "世勣得書，遂定計遣使歸國，開倉運糧，以饋淮安王神通之軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000030",
    "sentence": "俄而建德悉眾南下，攻陷黎陽，獲徵，署爲起居舍人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000031",
    "sentence": "及建德就擒，與裴矩西入關。",
    "entities": [
      {
        "text": "與裴矩西入關",
        "label": "LOC",
        "start": 6,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_071_000032",
    "sentence": "隱太子聞其名，引直洗馬，甚禮之。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 1,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_071_000033",
    "sentence": "徵見太宗勳業日隆，毎勸建成早爲之所。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000034",
    "sentence": "及敗，太宗使召之，謂曰：「汝離間我兄弟，何也？」徵曰：「皇太子若從徵言，必無今日之禍。」太宗素器之，引爲詹事主簿。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_008_071_000035",
    "sentence": "及踐祚，擢拜諫議大夫，封鉅鹿縣男，使安輯河北，許以便宜從事。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "封鉅鹿縣",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_071_000036",
    "sentence": "徵至磁州，遇前宮千牛李志安、齊王護軍李思行錮送詣京師。",
    "entities": [
      {
        "text": "徵至磁州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_071_000037",
    "sentence": "徵謂副使李桐客曰：「吾等受命之日，前宮、齊府左右，皆令赦原不問。今復送思行，此外誰不自疑？徒遣使往，彼必不信，此乃差之毫釐，失之千里。且公家之利，知無不爲，寧可慮身，不可廢國家大計。今若釋遣思行，不問其罪，則信義所感，無遠不臻。古者，大夫出疆，苟利社稷，專之可也。況今日之行，許以便宜從事，主上既以國士見待，安可不以國士報之乎？」即釋遣思行等，仍以啟聞，太宗甚悅。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 117,
        "end": 119
      }
    ]
  },
  {
    "sentence_id": "HCH_008_071_000038",
    "sentence": "太宗新即位，勵精政道，數引徵入臥內，訪以得失。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000039",
    "sentence": "徵雅有經國之才，性又抗直，無所屈撓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000040",
    "sentence": "太宗與之言，未嘗不欣然納受。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000041",
    "sentence": "徵亦喜逢知己之主，思竭其用，知無不言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000042",
    "sentence": "太宗嘗勞之曰：「卿所陳諫，前後二百餘事，非卿至誠奉國，何能若是？」其年，遷尚書左丞。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 37,
        "end": 39
      }
    ]
  },
  {
    "sentence_id": "HCH_008_071_000043",
    "sentence": "或有言徵阿黨親戚者，帝使御史大夫溫彥博案驗無狀，彥博奏曰：「徵爲人臣，須存形跡，不能遠避嫌疑，遂招此謗。雖情在無私，亦有可責。」帝令彥博讓徵，且曰：「自今後不得不存形跡。」他日，徵入奏曰：「臣聞君臣協契，義同一體。不存公道，唯事形跡，若君臣上下，同遵此路，則邦之興喪，或未可知。」帝瞿然改容曰：「吾已悔之。」徵再拜曰：「願陛下使臣爲良臣，勿使臣爲忠臣。」帝曰：「忠、良有異乎？」徵曰：「良臣，稷、契、咎陶是也。忠臣，龍逢、比干是也。良臣使身獲美名，君受顯號，子孫傳世，福祿無疆。忠臣身受誅夷，君陷大惡，家國並喪，空有其名。以此而言，相去遠矣。」帝深納其言，賜絹五百匹。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_071_000044",
    "sentence": "貞觀三年，遷秘書監，參預朝政。",
    "entities": [
      {
        "text": "貞觀三年",
        "label": "TME",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_071_000045",
    "sentence": "徵以喪亂之後，典章紛雜，奏引學者校定四部書。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000046",
    "sentence": "數年之間，秘府圖籍，粲然畢備。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000047",
    "sentence": "時高昌王麹文泰將入朝，西域諸國咸欲因文泰遣使貢獻，太宗令文泰使人厭怛紇干往迎接之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_071_000048",
    "sentence": "徵諫曰：「中國始平，瘡痍未復，若微有勞役，則不自安。往年文泰入朝，所經州縣，猶不能供，況加於此輩。若任其商賈來往，邊人則獲其利；若爲賓客，中國即受其弊矣。漢建武二十二年，天下已寧。西域請置都護、送侍子，光武不許，蓋不以蠻夷勞弊中國也。今若許十國入貢，其使不下千人，欲使緣邊諸州何以取濟？人心萬端，後雖悔之，恐無所及。」上善其議。",
    "entities": [
