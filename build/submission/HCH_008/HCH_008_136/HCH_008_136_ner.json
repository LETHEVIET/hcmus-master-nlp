      },
      {
        "text": "武經鎮",
        "label": "LOC",
        "start": 25,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000044",
    "sentence": "竇申者，參之族子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000045",
    "sentence": "累遷至京兆少尹，轉給事中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000046",
    "sentence": "參特愛之，每議除授，多訪於申，申或泄之，以招權受賂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000047",
    "sentence": "申所至，人目之為喜鵲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000048",
    "sentence": "德宗頗聞其事，數誡參曰：「卿他日必為申所累，不如出之以掩物議。」參曰：「臣無強子侄，申雖疏屬，臣素親之，不忍遠出，請保無他犯。」帝曰：「卿雖自保，如眾人何？」參固如前對。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000049",
    "sentence": "申亦不悛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000050",
    "sentence": "兵部侍郎陸贄與參有隙。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000051",
    "sentence": "吳通微弟兄與贄同在翰林，俱承德宗顧遇，亦爭寵不協。",
    "entities": [
      {
        "text": "吳通微",
        "label": "PER",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000052",
    "sentence": "金吾大將軍、嗣虢王則之與申及通微、通玄善，遂相與傾。",
    "entities": [
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000053",
    "sentence": "贄考貢舉，言贄考貢不實。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000054",
    "sentence": "吳通玄取宗室女為外婦，德宗知其毀贄，且令察視，具得其奸狀，乃貶則之為昭州司馬，吳通玄為泉州司馬，竇申為道州司馬。",
    "entities": [
