  {
    "sentence_id": "HCH_008_136_000195",
    "sentence": "宰相蕭復為江淮宣慰使，以抗為判官。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000196",
    "sentence": "德宗還京，大盜之後，天下旱蝗，國用盡竭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000197",
    "sentence": "鹽鐵轉運使元琇以抗有才用，奏授倉部郎中，條理江淮鹽務。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000198",
    "sentence": "貞元初，為水陸運副使，督江淮漕運以給京師。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 1,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000199",
    "sentence": "遷諫議大夫。",
    "entities": [
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000200",
    "sentence": "歷處州刺史，轉潭州刺史、湖南都團練觀察使。",
    "entities": [
      {
        "text": "歷處州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
