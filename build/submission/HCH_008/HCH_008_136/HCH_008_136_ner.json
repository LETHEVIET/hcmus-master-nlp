      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000043",
    "sentence": "參時為左右中官深怒，謗沮不已，未至驩州，賜死於邕州武經鎮，時年六十。",
    "entities": [
      {
        "text": "未至驩州",
        "label": "LOC",
        "start": 15,
        "end": 19
      },
      {
        "text": "賜死於邕州",
