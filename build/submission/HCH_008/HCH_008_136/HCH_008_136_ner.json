      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000055",
    "sentence": "不旬日貶參郴州別駕，即日以陸贄為宰相。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000056",
    "sentence": "明年，竇參再貶驩州。",
    "entities": [
      {
        "text": "竇參再貶驩州",
        "label": "LOC",
        "start": 3,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000057",
    "sentence": "德宗謂陸贄曰：「竇申、竇榮、李則之首末同惡，無所不至，又並細微，不比竇參，便宜商量處置，所有親密，並發遣於遠惡處。」贄奏曰：",
    "entities": [
      {
        "text": "李則之",
        "label": "PER",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000058",
    "sentence": "竇參罪犯，誠合誅夷，聖德含弘，務全事體，特寬嚴憲，俯貸余生。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000059",
    "sentence": "始終之恩，實足感於庶品；仁煦之惠，不獨幸於斯人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000060",
    "sentence": "所議貶官，謹具別狀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000061",
    "sentence": "其竇申、竇榮、李則之等，即皆同惡，固亦難容；然以得罪相因，法有首從，首當居重，從合從輕。",
    "entities": [
      {
        "text": "李則之",
        "label": "PER",
        "start": 7,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000062",
    "sentence": "參既蒙恩矜全，申等亦宜減降。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000063",
    "sentence": "又於黨與之內，亦有淑慝之殊，稍示區分，足彰沮勸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000064",
    "sentence": "竇榮與參雖非近屬，亦甚相親，然於款密之中，都無邪僻之事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000065",
    "sentence": "仍聞激憤，屢有直言，因此漸構猜嫌，晚年頗見疏忌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000066",
    "sentence": "若論今者陰事，則尚未究端由，如據比來所行，應不至兇險，恐須差異，以表詳明。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000067",
    "sentence": "臣等商量，竇榮更貶遠官，竇申、則之並除名配流，庶允從輕之典，以洽好生之恩。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000068",
    "sentence": "夫趨勢附權，時俗常態，茍無高節出眾，何能特立不群？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000069",
    "sentence": "竇參久塵鈞衡，特承寵渥，君之所任，孰敢不從？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000070",
    "sentence": "或遊於門庭，或序以中表，或偏被接引，或驟與薦延，如此之徒，十常八九。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000071",
    "sentence": "若聽流議，皆謂黨私，自非甚與交親，安可悉從貶累？",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000072",
    "sentence": "況竇參罷黜，殆欲周星，應是私黨近親，當時並已連坐，人心久定，不可復搖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000073",
    "sentence": "臣等商量，除與竇參陰謀邪事處，一切不問。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000074",
    "sentence": "詔從之，由是申等得配流嶺南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000075",
    "sentence": "既賜參死，乃杖殺申，諸竇皆貶，榮得免死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000076",
    "sentence": "齊映",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000077",
    "sentence": "齊映，瀛州高陽人。",
    "entities": [
      {
        "text": "瀛州",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000078",
    "sentence": "父圮，試太常少卿，兼檢校工部郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000079",
    "sentence": "映登進士第，應博學宏辭，授河南府參軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000080",
    "sentence": "滑亳節度使令狐彰辟為掌書記，累授監察御史。",
    "entities": [
      {
        "text": "令狐彰",
        "label": "PER",
        "start": 5,
        "end": 8
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000081",
    "sentence": "彰疾甚，映草遺表，因與謀後事，映說彰令上表請代，令子建歸京師，彰皆從之，因妻以女。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000082",
    "sentence": "彰卒後兵亂，映脫身歸東都，河陽三城使馬燧辟為判官，奏殿中侍御史。",
    "entities": [
      {
        "text": "河陽三城",
        "label": "LOC",
        "start": 13,
        "end": 17
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 29,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000083",
    "sentence": "建中初，盧杞為宰相，薦之，遷刑部員外郎，會張鎰出鎮鳳翔，奏為判官。",
    "entities": [
      {
        "text": "會張鎰出鎮",
        "label": "LOC",
        "start": 20,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000084",
    "sentence": "映口辯，頗更軍事，數以論奏合旨，尋轉行軍司馬、兼御史中丞。",
    "entities": [
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 20,
        "end": 22
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 24,
        "end": 26
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000085",
    "sentence": "德宗在奉天，鳳翔逼於賊泚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000086",
    "sentence": "鎰懦緩不曉兵家事，部將有李楚琳者，慓悍兇暴，軍中畏之，乘間將謀亂。",
    "entities": [
      {
        "text": "李楚琳",
        "label": "PER",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000087",
    "sentence": "先數日，映與同列齊抗覺其謀，乃言於鎰，請早圖之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000088",
    "sentence": "鎰不從映言，乃示其寬大，召楚琳語之曰：「欲令公使於外。」楚琳恐，是夜作亂，乃殺鎰以應泚；軍中多為映指道，故得免。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000089",
    "sentence": "因赴奉天行在，除御史中丞。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000090",
    "sentence": "興元初，從幸梁州，每過險，映常執轡。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "從幸梁州",
        "label": "LOC",
        "start": 4,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000091",
    "sentence": "會禦馬遽駭，奔跳頗甚，帝懼傷映，令舍轡，映堅執久之，乃止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000092",
    "sentence": "帝問其故，曰：「馬奔蹶，不過傷臣；如舍之，或犯清塵，雖臣萬死，何以塞責？」上嘉獎無已。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000093",
    "sentence": "在梁州，拜給事中。",
    "entities": [
      {
        "text": "在梁州",
        "label": "LOC",
        "start": 0,
        "end": 3
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000094",
    "sentence": "映白晰長大，言音高朗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000095",
    "sentence": "上自山南還京，常令映侍左右，或令前馬，至城邑州鎮，俾映宣詔令，帝益親信之。",
    "entities": [
      {
        "text": "至城邑州鎮",
        "label": "LOC",
        "start": 19,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000096",
    "sentence": "其年冬，轉中書舍人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000097",
    "sentence": "貞元二年，以本官與左散騎常侍劉滋、給事中崔造同拜平章事。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000098",
    "sentence": "滋以端默雅重寡言，映謙和美言悅下，無所是非，政事多決於造。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000099",
    "sentence": "無幾，造疾病，映當國政，乘間亦敢言事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000100",
    "sentence": "時吐蕃數入寇，人情搖動，且言帝欲行幸避狄。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000101",
    "sentence": "映奏曰：「戎狄亂華，臣之罪也。今人情恟懼，謂陛下理裝具糗糧，臣聞大福不再，奈何不與臣等熟計之？」因俯伏流涕，上亦為之感動。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000102",
    "sentence": "時給事中袁高忤旨，映連請為左丞、御史大夫。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000103",
    "sentence": "映於東都舉進士及宏詞時，張延賞為河南尹、東都留守，厚映。",
    "entities": [
      {
        "text": "張延賞",
        "label": "PER",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000104",
    "sentence": "及映為相，延賞罷相為左僕射，數畫時事令映行之，及為所親求官，映多不應。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000105",
    "sentence": "延賞怒，言映非宰相器。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000106",
    "sentence": "三年正月，貶映夔州刺史，又轉衡州。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "貶映夔州",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      },
      {
        "text": "又轉衡州",
        "label": "LOC",
        "start": 12,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000107",
    "sentence": "七年，授御史中丞、桂管觀察使，又改洪州刺史、江西觀察使。",
    "entities": [
      {
        "text": "七年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "又改洪州",
        "label": "LOC",
        "start": 15,
        "end": 19
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000108",
    "sentence": "映常以頃為相輔，無大過而罷，冀其復入用，乃掊斂貢奉，及大為金銀器以希旨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000109",
    "sentence": "先是，銀瓶高者五尺余，李兼為江西觀察使，乃進六尺者，至是，因帝誕日端午，映為瓶高八尺者以獻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000110",
    "sentence": "貞元十一年七月卒，時年四十八，贈禮部尚書。",
    "entities": [
      {
        "text": "十一年",
        "label": "TME",
        "start": 2,
        "end": 5
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000111",
    "sentence": "劉滋",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000112",
    "sentence": "劉滋，字公茂，左散騎常侍子玄之孫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000113",
    "sentence": "父貺，開元初為左拾遺，父子仍代為史官。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 4,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000114",
    "sentence": "貺依劉向《說苑》撰《續說苑》一十卷以獻，玄宗嘉之。",
    "entities": [
      {
        "text": "《說苑》",
        "label": "TITLE",
        "start": 4,
        "end": 8
      },
      {
        "text": "《續說苑》",
        "label": "TITLE",
        "start": 9,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000115",
    "sentence": "滋少以門廕，調授太子正字，歷漣水令。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000116",
    "sentence": "吏部侍郎楊綰薦滋堪為諫官，拜左補闕，改太常卿，復為左補闕。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000117",
    "sentence": "辭官侍親還東都，河南尹李廙署奏功曹參軍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000118",
    "sentence": "無幾，丁母喪，服除，遷屯田員外郎，轉司勛員外郎，判南曹，勤於吏職，孜孜奉法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000119",
    "sentence": "遷司勛郎中，累拜給事中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000120",
    "sentence": "從幸奉天，轉太常少卿，掌禮儀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000121",
    "sentence": "興元元年，改吏部侍郎，往洪州知選事。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "往洪州",
        "label": "LOC",
        "start": 11,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000122",
    "sentence": "時京師寇盜之後，天下蝗旱，谷價翔貴，選人不能赴調，乃命滋江南典選，以便江、嶺之人，時稱舉職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000123",
    "sentence": "貞元二年，遷左散騎常侍、同中書門下平章事，在相位無所啟奏，但多謙退，廉謹畏慎而已。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000124",
    "sentence": "三年正月，守本官，罷知政事。",
    "entities": [
      {
        "text": "三年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000125",
    "sentence": "四年，復為吏部侍郎。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000126",
    "sentence": "六年，遷吏部尚書。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000127",
    "sentence": "竇參以宰相為吏部尚書，換刑部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000128",
    "sentence": "無何，御史臺劾奏滋前在吏部選人渝濫，詔奪金紫階。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000129",
    "sentence": "滋有經學，善持論，性廉潔刻苦，嫉惡，掌選多所發扌適更代，詐偽者尤畏之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000130",
    "sentence": "十年十月卒，時年六十六，贈陜州大都督。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "贈陜州",
        "label": "LOC",
        "start": 12,
        "end": 15
      },
      {
        "text": "大都",
        "label": "LOC",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000131",
    "sentence": "滋從兄贊，大歷中左散騎常侍匯之子。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000132",
    "sentence": "少以資廕補吏，累授鄠縣丞，宰相杜鴻漸自南還朝，途出於鄠，贊儲供精辦。",
    "entities": [
      {
        "text": "累授鄠縣",
        "label": "LOC",
        "start": 7,
        "end": 11
      },
