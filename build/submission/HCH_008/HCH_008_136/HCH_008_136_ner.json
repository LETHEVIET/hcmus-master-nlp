[
  {
    "sentence_id": "HCH_008_136_000001",
    "sentence": "竇參",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000002",
    "sentence": "竇參，字時中，工部尚書誕之玄孫。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000003",
    "sentence": "父審言，聞喜尉，以參貴贈吏部尚書。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 14,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000004",
    "sentence": "參習法令，通政術，性矜嚴，強直而果斷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000005",
    "sentence": "少以門廕，累官至萬年尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000006",
    "sentence": "時同僚有直官曹者，將夕，聞親疾，請參代之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000007",
    "sentence": "會獄囚亡走，京兆尹按直簿，將奏，參遽請曰：「彼以不及狀謁，參實代之，宜當罪。」坐貶江夏尉，人多義之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000008",
    "sentence": "累遷奉先尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000009",
    "sentence": "縣人曹芬，名隸北軍，芬素兇暴，因醉毆其女弟，其父救之不得，遂投井死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000010",
    "sentence": "參捕理芬兄弟當死，眾官皆請俟免喪，參曰：「子因父生，父由子死，若以喪延罪，是殺父不坐也。」皆正其罪而杖殺之，一縣畏伏。",
    "entities": [
      {
        "text": "一縣",
        "label": "LOC",
        "start": 54,
        "end": 56
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000011",
    "sentence": "轉大理司直。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000012",
    "sentence": "按獄江淮，次揚州，節度使陳少遊驕蹇，不郊迎，令軍吏傳問，參正辭讓之，少遊悔懼，促詣參，參不俟濟江。",
    "entities": [
      {
        "text": "次揚州",
        "label": "LOC",
        "start": 5,
        "end": 8
      },
      {
        "text": "陳少遊",
        "label": "PER",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000013",
    "sentence": "還奏合旨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000014",
    "sentence": "時婺州刺史鄧珽坐贓八千貫，珽與執政有舊，以會赦，欲免贓。",
    "entities": [
      {
        "text": "時婺州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000015",
    "sentence": "詔百僚於尚書省雜議，多希執政意，參獨堅執正之於法，竟征贓。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000016",
    "sentence": "明年，除監察御史，奉使按湖南判官馬彜獄。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000017",
    "sentence": "時彜舉屬令贓罪至千貫，為得罪者之子因權幸誣奏彜，參竟白彜無罪。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000018",
    "sentence": "彜實能吏，後累佐曹王臯，以正直強幹聞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000019",
    "sentence": "參轉殿中侍御史，改金部員外郎、刑部郎中、侍御史、知雜事。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 21,
        "end": 23
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000020",
    "sentence": "無幾，遷御史中丞，不避權貴，理獄以嚴稱。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000021",
    "sentence": "數蒙召見，論天下事，又與執政多異同，上深器之，或參決大政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000022",
    "sentence": "時宰頗忌之，多所排抑，亦無以傷參。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000023",
    "sentence": "然多率情壞法。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000024",
    "sentence": "初定百官俸料，以嘗為司直，黨其官，故給俸多於本寺丞；又定百官班秩，初令太常少卿在左右庶子之上；又惡詹事李昇，遂移詹事班退居諸府尹之下，甚為有識所嗤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000025",
    "sentence": "尋兼戶部侍郎。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000026",
    "sentence": "時京師人家豕生兩首四足，有司欲奏；參曰：「此為豕禍，安可上聞！」命棄之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000027",
    "sentence": "是時，郊牛生犢有六足者，太仆卿周皓白宰相請奏，李泌亦戲答以遣之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000028",
    "sentence": "故淮南節度使陳少遊子正儀請襲封，參大署尚書省門曰：「陳少遊位兼將相之崇，節變艱危之際，君上含垢，未能發明，愚子何心，輒求傳襲。」正儀懼，不敢求封而去。",
    "entities": [
      {
        "text": "陳少遊",
        "label": "PER",
        "start": 6,
        "end": 9
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 19,
        "end": 21
      },
      {
        "text": "陳少遊",
        "label": "PER",
        "start": 26,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000029",
    "sentence": "時神策將軍孟華有戰功，為大將軍所誣奏，稱華謀反；有右龍武將軍李建玉，前陷吐蕃，久之自拔，為部曲誣告潛通吐蕃，皆當死，無以自白，參悉理出之，由是人皆屬望。",
    "entities": [
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 3,
        "end": 5
      },
      {
        "text": "大將軍",
        "label": "TITLE",
        "start": 12,
        "end": 15
      },
      {
        "text": "將軍",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000030",
    "sentence": "明年，拜中書侍郎、同平章事，領度支、鹽鐵轉運使。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000031",
    "sentence": "每宰相間日於延英召對，諸相皆出，參必居後久之，以度支為辭，實專大政。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000032",
    "sentence": "參無學術，但多引用親黨，使居要職，以為耳目，四方籓帥，皆畏懼之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000033",
    "sentence": "李納既憚參，饋遺畢至，外示敬參，實陰間之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000034",
    "sentence": "上所親信，多非毀參。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000035",
    "sentence": "竇申又與吳通玄通犯事覺，參任情好惡，恃權貪利，不知紀極，終以此敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000036",
    "sentence": "貶參郴州別駕，貞元八年四月也。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000037",
    "sentence": "參至郴州，汴州節度使劉士寧遺參絹五千匹。",
    "entities": [
      {
        "text": "參至郴州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "汴州",
        "label": "LOC",
        "start": 5,
        "end": 7
      },
      {
        "text": "劉士寧",
        "label": "PER",
        "start": 10,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000038",
    "sentence": "湖南觀察使李巽與參有隙，遂具以聞；又中使逢士寧使於路，亦奏其事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000039",
    "sentence": "德宗大怒，欲殺參。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000040",
    "sentence": "宰相陛贄曰：「竇參與臣無分，因事報怨，人之常情。然臣參宰衡，合存公體，以參罪犯，置之於死，恐用刑太過。」於是且止。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000041",
    "sentence": "尋又遣中使謂贄等曰：「卿等所奏，於大體雖好，然此人交結中外，其意難測，朕尋情狀，其事灼然。又竇參在彼，與諸戎帥交通，社稷事重，卿等速進文書處分。」贄奏曰：「臣面承德音，幸奉密旨，皆以社稷為言，又知根尋已審，敢不上同憂憤，內絕狐疑，豈願遲回，更貽念慮？但以參常經重任，斯謂大臣，進退之間，猶宜有禮，誅戮之際，不可無名。劉晏久掌貨財，當時亦招怨讟，及加罪責，事不分明，叛者既得以為辭，眾人亦為之懷湣。用刑曖昧，損累不輕，事例未遙，所宜重慎。竇參頃司鈞軸，頗怙恩私，貪受貨財，引縱親黨，此則朝廷同議，天下共傳。至於潛懷異圖，將起大惡，跡既未露，人皆莫知。臣等新奉天顏，議加刑辟，但聞兇險之意，尚昧結構之由。況在眾流，何由備悉，忽行峻罰，必謂冤誣，群情震驚，事亦非細。若不付外推鞫，則恐難定罪名，乞留睿聰，更少詳度。竇參於臣，素亦無分，陛下固已明知，有何顧懷，輒欲營救？良以事關國體，義絕私嫌，所冀典刑不濫於清時，君道免虧於聖德。」乃再貶為驩州司馬。",
    "entities": [
      {
        "text": "良以事關",
        "label": "LOC",
        "start": 381,
        "end": 385
      },
      {
        "text": "清",
        "label": "ORG",
        "start": 400,
        "end": 401
      },
      {
        "text": "乃再貶為驩州",
        "label": "LOC",
