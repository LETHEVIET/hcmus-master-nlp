        "end": 5
      },
      {
        "text": "轉潭州",
        "label": "LOC",
        "start": 6,
        "end": 9
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000201",
    "sentence": "入為給事中，又為河南尹，歷秘書監、太常卿，代鄭余慶為中書侍郎、同中書門下平章事。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 28,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000202",
    "sentence": "先是每年吏部選人試判，別奏官考覆，第其上下；既考，中書門下復奏擇官覆定，浸以為便。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000203",
    "sentence": "抗乃奏曰：「吏部尚書、侍郎，已是朝廷精選，不宜別差考官重覆。」其年他官考判訖，俾吏部侍郎自覆，一歲遂除考判官，蓋抗所論奏也。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 8,
        "end": 10
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 42,
        "end": 44
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000204",
    "sentence": "故事，禮部侍郎掌貢舉，其親故即試於考功。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000205",
    "sentence": "謂之「別頭舉人」，抗亦奏罷之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000206",
    "sentence": "尋奏省諸州府別駕、田曹、司田官及判司之雙曹者，復省中書省驅使官及諸胥吏。",
    "entities": [
      {
        "text": "尋奏省諸州",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000207",
    "sentence": "尋加修國史。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000208",
    "sentence": "抗雖讀書，無遠智大略，凡為官，必求至精，末乃滋彰，物論薄其隘刻。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000209",
    "sentence": "遇疾，上表請罷，改太子賓客，竟不任朝謝。",
    "entities": [
      {
        "text": "太子",
        "label": "TITLE",
        "start": 9,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000210",
    "sentence": "貞元二十年卒，時年六十五，贈戶部尚書，又賜其家絹二百匹。",
    "entities": [
      {
        "text": "二十年",
        "label": "TME",
        "start": 2,
        "end": 5
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_136_000211",
    "sentence": "【贊】",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000212",
    "sentence": "史臣曰：竇參朋黨，不顧君上之誡，斯為悖矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000213",
    "sentence": "齊映曲貢希用甚謬，而愛君蒞事，往往有長者之言。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000214",
    "sentence": "滋、邁家行修謹，臨事可稱，器雖齷齪，無廢為君子矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000215",
    "sentence": "而損、抗之比，夫何足雲，遽汙臺槐，蓋時主之容易耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000216",
    "sentence": "贊曰：物之同器，貴於弘通。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000217",
    "sentence": "竇阿齊佞，偏诐斯同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000218",
    "sentence": "滋、邁之行，可以飾躬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000219",
    "sentence": "康濟蒸民，胡為厥中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_136_000220",
    "sentence": "本五代作品在全世界都属于 公有领域 ，因为作者逝世已经遠遠超过100年。",
    "entities": [
      {
        "text": "100年",
        "label": "TME",
