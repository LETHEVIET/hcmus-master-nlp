      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000049",
    "sentence": "憬保護救解之，故多從輕貶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000050",
    "sentence": "初，憬廉察湖南，令狐峘、崔儆並為巡屬刺史。",
    "entities": [
      {
