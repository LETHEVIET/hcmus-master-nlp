        "end": 18
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000129",
    "sentence": "德宗移幸梁州。",
    "entities": [
      {
        "text": "德宗移幸梁州",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000130",
    "sentence": "興元元年二月，耽使行軍司馬樊澤奏事於行在，澤既復命，方大宴諸將，有急牒至，言澤代耽為節度使，而召耽為工部尚書。",
    "entities": [
      {
        "text": "元",
        "label": "ORG",
        "start": 1,
        "end": 2
      },
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 52,
        "end": 54
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000131",
    "sentence": "耽得牒內懷中，宴飲不改容。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000132",
    "sentence": "及散，召樊澤，以詔授之曰：「詔以行軍為節度使，耽今即上路。」因告將吏使謁澤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000133",
    "sentence": "牙將張獻甫曰：「天子巡幸山南，尚書使行軍奉表起居，而行軍敢自圖節鉞，潛奪尚書土地，此可謂事人不忠。軍中皆不伏，請殺樊澤。」耽曰：「公是何言歟！天子有命，即為節度使矣。耽今赴行在，便與公偕行。」即日離鎮，以獻甫自隨，軍中乃安。",
    "entities": [
      {
        "text": "張獻甫",
        "label": "PER",
        "start": 2,
        "end": 5
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 15,
        "end": 17
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 36,
        "end": 38
      },
      {
        "text": "即日離鎮",
        "label": "LOC",
        "start": 96,
        "end": 100
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000134",
    "sentence": "尋以本官為東都留守、東畿汝南防禦使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000135",
    "sentence": "貞元二年，改檢校右僕射、兼滑州刺史、義成軍節度使。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "兼滑州",
        "label": "LOC",
        "start": 12,
        "end": 15
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000136",
    "sentence": "是時淄青節度使李納雖去偽王號，外奉朝旨，而心常蓄並吞之謀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000137",
    "sentence": "納兵士數千人自行營歸，路由滑州，大將請城外館之。",
    "entities": [
      {
        "text": "路由滑州",
        "label": "LOC",
        "start": 11,
        "end": 15
      },
      {
        "text": "大將請城",
        "label": "LOC",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000138",
    "sentence": "耽曰：「與人鄰道，奈何野處其兵？」命館之城內，淄青將士皆心服之。",
    "entities": [
      {
        "text": "命館之城",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000139",
    "sentence": "耽善射好獵，每出畋不過百騎，往往獵於李納之境。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000140",
    "sentence": "納聞之，大喜，心畏其度量，不敢異圖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000141",
    "sentence": "九年，征為右僕射、同中書門下平章事。",
    "entities": [
      {
        "text": "九年",
        "label": "TME",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000142",
    "sentence": "耽好地理學，凡四夷之使及使四夷還者，必與之從容，訊其山川土地之終始。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000143",
    "sentence": "是以九州之夷險，百蠻之土俗，區分指畫，備究源流。",
    "entities": [
      {
        "text": "是以九州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000144",
    "sentence": "自吐蕃陷隴右積年，國家守於內地，舊時鎮戍，不可復知。",
    "entities": [
      {
        "text": "舊時鎮",
        "label": "LOC",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000145",
    "sentence": "耽乃畫隴右、山南圖，兼黃河經界遠近，聚其說為書十卷，表獻曰：",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000146",
    "sentence": "臣聞楚左史倚相能讀《九丘》，晉司空裴秀創為六體；《九丘》乃成賦之古經，六體則為圖之新意。",
    "entities": [
      {
        "text": "《九丘》",
        "label": "TITLE",
        "start": 9,
        "end": 13
      },
      {
        "text": "《九丘》",
        "label": "TITLE",
        "start": 24,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000147",
    "sentence": "臣雖愚昧，夙嘗師範，累蒙拔擢，遂忝臺司。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000148",
    "sentence": "雖歷踐職任，誠多曠闕，而率土山川，不忘寤寐。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000149",
    "sentence": "其大圖外薄四海，內別九州，必藉精詳，乃可摹寫，見更纘集，續冀畢功。",
    "entities": [
      {
        "text": "內別九州",
        "label": "LOC",
        "start": 8,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000150",
    "sentence": "然而隴右一隅，久淪蕃寇，職方失其圖記，境土難以區分。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000151",
    "sentence": "輒扣課虛微，采掇輿議，畫《關中隴右及山南九州等圖》一軸。",
    "entities": [
      {
        "text": "《關中隴右及山南九州等圖》",
        "label": "TITLE",
        "start": 12,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000152",
    "sentence": "伏以洮、湟舊墟，連接監牧；甘、涼右地，控帶朔陲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000153",
    "sentence": "岐路之偵候交通，軍鎮之備禦沖要，莫不匠意就實，依稀像真。",
    "entities": [
      {
        "text": "軍鎮",
        "label": "LOC",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000154",
    "sentence": "如聖恩遣將護邊，新書授律，則靈、慶之設險在目，原、會之封略可知。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000155",
    "sentence": "諸州諸軍，須論里數人額；諸山諸水，須言首尾源流。",
    "entities": [
      {
        "text": "諸州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000156",
    "sentence": "圖上不可備書，憑據必資記註，謹撰《別錄》六卷。",
    "entities": [
      {
        "text": "《別錄》",
        "label": "TITLE",
        "start": 16,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000157",
    "sentence": "又黃河為四瀆之宗，西戎乃群羌之帥，臣並研尋史牒，翦棄浮詞，罄所聞知，編為四卷，通錄都成十卷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000158",
    "sentence": "文義鄙樸，伏增慚悚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000159",
    "sentence": "德宗覽之稱善，賜廄馬一匹、銀采百匹、銀瓶盤各一。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000160",
    "sentence": "至十七年，又撰成《海內華夷圖》及《古今郡國縣道四夷述》四十卷，表獻之，曰：",
    "entities": [
      {
        "text": "十七年",
        "label": "TME",
        "start": 1,
        "end": 4
      },
      {
        "text": "《海內華夷圖》",
        "label": "TITLE",
        "start": 8,
        "end": 15
      },
      {
        "text": "《古今郡國縣道四夷述》",
        "label": "TITLE",
        "start": 16,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000161",
    "sentence": "臣聞地以博厚載物，萬國棋布；海以委輸環外，百蠻繡錯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000162",
    "sentence": "中夏則五服、九州，殊俗則七戎、六狄，普天之下，莫非王臣。",
    "entities": [
      {
        "text": "九州",
        "label": "LOC",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000163",
    "sentence": "昔毋丘出師，東銘不耐；甘英奉使，西抵條支；奄蔡乃大澤無涯，罽賓則懸度作險。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000164",
    "sentence": "或道理回遠，或名號改移，古來通儒，罕遍詳究。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000165",
    "sentence": "臣弱冠之歲，好聞方言，筮仕之辰，註意地理，究觀研考，垂三十年。",
    "entities": [
      {
        "text": "三十年",
        "label": "TME",
        "start": 27,
        "end": 30
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000166",
    "sentence": "絕域之比鄰，異蕃之習俗，梯山獻琛之路，乘舶來朝之人，鹹究竟其源流，訪求其居處。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000167",
    "sentence": "阛阓之行賈，戎貊之遺老，莫不聽其言而掇其要。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000168",
    "sentence": "閭閻之瑣語，風謠之小說，亦收其是而芟其偽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000169",
    "sentence": "然殷、周以降，封略益明，承歷數者八家，渾區宇者五姓，聲教所及，惟唐為大。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000170",
    "sentence": "秦皇罷侯置守，長城起於臨洮；孝武卻地開邊，障塞限於雞鹿；東漢則哀牢請吏；西晉則裨離結轍；隋室列四郡於卑和海西，創三州於扶南江北，遼陽失律，因而棄之。",
    "entities": [
      {
        "text": "長城",
        "label": "LOC",
        "start": 7,
        "end": 9
      },
      {
        "text": "隋室列四郡",
        "label": "LOC",
        "start": 44,
        "end": 49
      },
      {
        "text": "創三州",
        "label": "LOC",
        "start": 55,
        "end": 58
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000171",
    "sentence": "高祖神堯皇帝誕膺天命，奄有四方。",
    "entities": [
      {
        "text": "皇帝",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000172",
    "sentence": "太宗繼明重熙，柔遠能邇，逾大磧通道，北至仙娥，於骨利幹置玄闕州。",
    "entities": [
      {
        "text": "骨利幹置玄闕州",
        "label": "LOC",
        "start": 24,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000173",
    "sentence": "高宗嗣守丕績，克廣前烈，遣單車賫詔，西越蔥山，於波刺斯立疾陵府。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000174",
    "sentence": "中宗復配天之業，不失舊物。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000175",
    "sentence": "睿宗含先天之量，惟新永圖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000176",
    "sentence": "玄宗以大孝清內，以無為理外，大宛驥錄，歲充內廄，與貳師之窮兵黷武，豈同年哉！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000177",
    "sentence": "肅宗掃平氛昆，潤澤生人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000178",
    "sentence": "代宗刬除殘孽，彜倫攸敘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000179",
