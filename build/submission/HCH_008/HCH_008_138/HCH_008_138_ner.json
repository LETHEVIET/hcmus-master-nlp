[
  {
    "sentence_id": "HCH_008_138_000001",
    "sentence": "趙憬",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000002",
    "sentence": "趙憬，字退翁，天水隴西人也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000003",
    "sentence": "總章中吏部侍郎、同東西臺三品仁本之曾孫。",
    "entities": [
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000004",
    "sentence": "祖諠歷左司郎中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000005",
    "sentence": "父道先，洪州錄事參軍。",
    "entities": [
      {
        "text": "洪州",
        "label": "LOC",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000006",
    "sentence": "憬少好學，誌行修潔，不求聞達。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000007",
    "sentence": "寶應中，玄宗、肅宗梓宮未祔，有司議山陵制度。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000008",
    "sentence": "時西蕃入寇，天下饑饉，憬以褐衣上疏，宜遵儉制，時人稱之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000009",
    "sentence": "後連為州從事，試江夏尉。",
    "entities": [
      {
        "text": "後連為州",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000010",
    "sentence": "累遷監察御史，隨牒籓府，歷殿中侍御史、太子舍人。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 16,
        "end": 18
      },
      {
        "text": "太子",
        "label": "TITLE",
        "start": 19,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000011",
    "sentence": "居母憂，哀毀幾絕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000012",
    "sentence": "服除，建中初，擢授水部員外郎。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000013",
    "sentence": "未拜，會湖南觀察使李承請為副使、檢校工部郎中，充職。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000014",
    "sentence": "歲餘，承卒，遂知留後事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000015",
    "sentence": "尋授潭州刺史、兼御史中丞、湖南觀察使，仍賜金紫。",
    "entities": [
      {
        "text": "尋授潭州",
        "label": "LOC",
        "start": 0,
        "end": 4
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 8,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000016",
    "sentence": "居二歲，受代歸京師，闔門靜居，不與人交。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000017",
    "sentence": "久之，特召對於別殿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000018",
    "sentence": "憬多學問，有辭辯，敷奏稱旨，上悅，拜給事中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000019",
    "sentence": "貞元四年，回紇請結和親。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000020",
    "sentence": "詔以鹹安公主降回紇，命檢校右僕射關播充使。",
    "entities": [
      {
        "text": "公主",
        "label": "TITLE",
        "start": 4,
        "end": 6
      },
      {
        "text": "命檢校右僕射關",
        "label": "LOC",
        "start": 10,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000021",
    "sentence": "憬以本官兼御史中丞為副。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000022",
    "sentence": "前後使回紇者，多私賫繒絮，蕃中市馬回以規利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000023",
    "sentence": "憬一無所市，人嘆美之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000024",
    "sentence": "使還，遷尚書左丞，綱轄省務，清勤奉職。",
    "entities": [
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 4,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000025",
    "sentence": "竇參為宰相，惡其能，請出為同州刺史，上不從。",
    "entities": [
      {
        "text": "請出為同州",
        "label": "LOC",
        "start": 10,
        "end": 15
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 15,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000026",
    "sentence": "八年四月，竇參罷黜，憬與陸贄並拜中書侍郎、同中書門下平章事。",
    "entities": [
      {
        "text": "八年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "侍郎",
        "label": "TITLE",
        "start": 18,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000027",
    "sentence": "憬深於理道，常言：「為政之本，在於選賢能，務節儉，薄賦斂，寬刑罰。」對揚之際，必以此為言，乃獻《審官六議》曰：",
    "entities": [
      {
        "text": "《審官六議》",
        "label": "TITLE",
        "start": 47,
        "end": 53
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000028",
    "sentence": "臣謬登宰府，四年於茲，恭承德音，未嘗不以求賢為切。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000029",
    "sentence": "至於延薦，職在愚臣，雖當代天之工，且乏知人之鑒；漸積歲月，負於聖明，無補王猷，有妨賢路。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000030",
    "sentence": "況多疾恙，兼慮闕遺，頃奉表章，備陳肝膈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000031",
    "sentence": "陛下以臣性拙直，身病可矜，不棄孱微，尚加委任。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000032",
    "sentence": "自此思省，報效尤難，莫副堯、舜之心，空懷屍素之懼。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000033",
    "sentence": "伏惟陛下法象應期，聖神廣運，雲行雨施，皆發自然，訓誥典謨，悉經睿覽。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000034",
    "sentence": "臣所以不敢援引古昔，上煩天聰，且以用人之要，願伸鄙見。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000035",
    "sentence": "復念稽顙丹陛，仰對宸嚴，謇訥易窮，遽數難辯，理詳則塵瀆頗甚，言略則利害未宣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000036",
    "sentence": "若默以求容，茍而竊位，縱天地之仁幸免，而中外之責何逃！",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000037",
    "sentence": "非陛下用臣之意也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000038",
    "sentence": "其所欲言者，皆陛下聖慮之內。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000039",
    "sentence": "臣以頂戴恩造，不知所為，身被風毒，漸覺沈痼，是以勤勤懇懇，切於愚誠也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000040",
    "sentence": "臣聞貞觀、開元之際，宰輔論事，或多上書，所冀獲盡情理。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000041",
    "sentence": "今臣酌前代之損益，體當時之通變，謹獻《審官六議》，伏惟閑宴時賜省覽。",
    "entities": [
      {
        "text": "《審官六議》",
        "label": "TITLE",
        "start": 18,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000042",
    "sentence": "其大指，議相，則曰：「宜博采眾賢，用為輔弼。今中外知其賢者，伏願陛下用之，識其能者任之，求其全材，恐不可得。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000043",
    "sentence": "議進用庶官，則曰：「異同之論，是非難辨。由考課難於實效，好惡雜於眾聲，所以訪之彌多，得之彌少。選士古今為難，拔十得五，賢愚猶半。陛下謂臣曰：『何必五也？十得二三斯可矣！』聖主思賢至是，而宰臣不能進之，臣之罪也。進賢在於廣任用，明殿最，舉大節，棄其小瑕，隨其所能，試之以事，用人之大綱也。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000044",
    "sentence": "議京諸司闕官，則曰：「當今要官多闕，閑官十無一二。文武任用，資序遞遷，要官本以材行，閑官多由恩澤。朝廷或將任，多擬要官則人少闕多，閑官則人多闕少；明當選拔者轉少，在優容者轉多，宜補闕員，務育材用。大廈永固，是棟梁榱桷之全也；聖朝致理，亦庶官群吏之能也。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000045",
    "sentence": "議中外考課官，則曰：「漢以數易長吏，謂之弊政。其有能理者，輒增秩賜金，或八九年、十余年，乃入為九卿，或遷三輔。功績茂異，遂至丞相，其間不隔數官。今陛下內選庶僚，外委州府，課績高者，不次超升，致理之法，無逾於此。臣愚以為黜陟且立年限，若所居要重，未當遷移，就加爵秩。其余進退，令知褒貶之必應，遲速之有常。如課績在中，年考及限，與之平轉。中外叠處，歷試其能，使無茍且之心，又無滯淹之慮。」",
    "entities": [
      {
        "text": "八九年",
        "label": "TME",
        "start": 36,
        "end": 39
      },
      {
        "text": "丞相",
        "label": "TITLE",
        "start": 62,
        "end": 64
      },
      {
        "text": "外委州",
        "label": "LOC",
        "start": 80,
        "end": 83
      }
    ]
  },
  {
    "sentence_id": "HCH_008_138_000046",
    "sentence": "議舉遺滯，則曰：「官司既廣，必委宰輔以舉之；宰輔不能遍知，又詢於庶官；庶官不能遍知，又訪於眾人。眾聲囂然，互有臧否，十人舉之未信，一人毀之可疑，迨至於今，茲弊未改。其所以然者，非盡為愛憎也，苦於不審實而承聲言之。大凡常人之心，以稱人之善為清，以攻人之過為直，茍有除授，多生橫議。由是宰臣每將薦用，亦自重難，日往月來，未副聖意。宜須采聽時論，以所舉多者先用，必非大故，皆不棄之。」",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_138_000047",
    "sentence": "議擢用諸使府僚屬，則曰：「諸使辟吏，各自精求，務於得人，將重府望。既經試效，能否可知，擢其賢能，置之朝列。或曰外使須才，固不可奪。臣知必不然也。屬者使府賓介，每有登朝，本使殊以為榮，自喜知人，且明公選。大凡才能之士，名位未達，多在方鎮。日月在上，誰不知之，思登闕庭，如望霄漢，宜須博采，無宜久滯。」上優詔答之。",
    "entities": [
      {
        "text": "多在方鎮",
        "label": "LOC",
        "start": 113,
        "end": 117
      }
    ]
  },
  {
