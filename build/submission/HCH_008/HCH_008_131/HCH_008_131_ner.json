      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000039",
    "sentence": "詔勉與李忠臣、馬燧等攻討，大破之，悅僅以身免。",
    "entities": [
      {
        "text": "李忠臣",
        "label": "PER",
        "start": 3,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000040",
    "sentence": "靈曜北走，勉騎將杜如江擒之以獻，代宗褒賞甚厚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000041",
    "sentence": "既而李忠臣代鎮汴州，而勉仍舊鎮。",
    "entities": [
      {
        "text": "汴州",
        "label": "LOC",
