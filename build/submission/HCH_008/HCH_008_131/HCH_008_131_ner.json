        "end": 11
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 11,
        "end": 13
      },
      {
        "text": "安德郡",
        "label": "LOC",
        "start": 14,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000004",
    "sentence": "在漢州，張嘉貞為益州長史、判都督事，性簡貴，待管內刺史禮隔，而引擇言同榻，坐談政理，時人榮之。",
    "entities": [
      {
        "text": "在漢州",
        "label": "LOC",
        "start": 0,
        "end": 3
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 25,
        "end": 27
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000005",
    "sentence": "勉幼勤經史，長而沉雅清峻，宗於虛玄，以近屬陪位，累授開封尉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000006",
    "sentence": "時升平日久，且汴州水陸所湊，邑居龐雜，號為難理，勉與聯尉盧成軌等，並有擒奸擿伏之名。",
    "entities": [
      {
        "text": "且汴州",
        "label": "LOC",
        "start": 6,
        "end": 9
      },
      {
        "text": "盧成軌",
        "label": "PER",
        "start": 28,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000007",
    "sentence": "至德初，從至靈武，拜監察御史。",
    "entities": [
      {
        "text": "御史",
        "label": "TITLE",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000008",
    "sentence": "屬朝廷右武，勳臣恃寵，多不知禮。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000009",
    "sentence": "大將管崇嗣於行在朝堂背闕而坐，言笑自若，勉劾之，拘於有司，肅宗特原之，歎曰：「吾有李勉，始知朝廷尊也。」遷司膳員外郎。",
    "entities": [
      {
        "text": "管崇嗣",
        "label": "PER",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000010",
    "sentence": "時關東獻俘百餘，詔並處斬，囚有仰天歎者，勉過問之，對曰：「某被脅制守官，非逆者。」勉乃哀之，上言曰：「元惡未殄，遭點污者半天下，皆欲澡心歸化。若盡殺之，是驅天下以資兇逆也。」肅宗遽令奔騎宥釋，由是歸化日至。",
    "entities": [
      {
        "text": "時關",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000011",
    "sentence": "克復西京，累歷清要，四遷至河南少尹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000012",
    "sentence": "累為河東節度王思禮、朔方河東都統李國貞行軍司馬，尋遷梁州都督、山南西道觀察使。",
    "entities": [
      {
        "text": "王思禮",
        "label": "PER",
        "start": 6,
        "end": 9
      },
      {
        "text": "李國貞",
        "label": "PER",
        "start": 16,
        "end": 19
      },
      {
        "text": "司馬",
        "label": "TITLE",
        "start": 21,
        "end": 23
      },
      {
        "text": "尋遷梁州",
        "label": "LOC",
        "start": 24,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000013",
    "sentence": "勉以故吏前密縣尉王晬勤干，俾攝南鄭令，俄有詔處死，勉問其故，乃為權幸所誣。",
    "entities": [
      {
        "text": "勉以故吏前密縣",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000014",
    "sentence": "勉詢將吏曰：「上方藉牧宰為人父母，豈以譖言而殺不辜乎！」即停詔拘晬，飛表上聞，晬遂獲宥，而勉竟為執政所非，追入為大理少卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000015",
    "sentence": "謁見，面陳王晬無罪，政事條舉，盡力吏也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000016",
    "sentence": "肅宗嘉其守正，乃除太常少卿。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000017",
    "sentence": "王晬後以推擇拜大理評事、龍門令，終有能名，時稱知人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000018",
    "sentence": "肅宗將大用勉，會李輔國寵任，意欲勉降禮於己。",
    "entities": [
      {
        "text": "李輔國",
        "label": "PER",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000019",
    "sentence": "勉不為之屈，竟為所抑，出歷汾州、虢州刺史，改京兆尹、檢校右庶子、兼御史中丞、都畿觀察使。",
    "entities": [
      {
        "text": "出歷汾州",
        "label": "LOC",
        "start": 11,
        "end": 15
      },
      {
        "text": "虢州",
        "label": "LOC",
        "start": 16,
        "end": 18
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 18,
        "end": 20
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 33,
        "end": 35
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000020",
    "sentence": "尋兼河南尹，明年罷尹，以中丞歸西台，又除江西觀察使。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000021",
    "sentence": "賊帥陳莊連陷江西州縣，偏將呂太一、武日升相繼背叛，勉與諸道力戰，悉攻平之。",
    "entities": [
      {
        "text": "陳莊連陷江西州",
        "label": "LOC",
        "start": 2,
        "end": 9
      },
      {
        "text": "呂太一",
        "label": "PER",
        "start": 13,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000022",
    "sentence": "部人有父病，以蠱道為木偶人，署勉名位，瘞於其隴，或以告，曰：「為父禳災，亦可矜也。」捨之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000023",
    "sentence": "大歷二年，來朝，拜京兆尹、兼御史大夫，政尚簡肅。",
    "entities": [
      {
        "text": "二年",
        "label": "TME",
        "start": 2,
        "end": 4
      },
      {
        "text": "御史",
        "label": "TITLE",
        "start": 14,
        "end": 16
      },
      {
        "text": "大夫",
        "label": "TITLE",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000024",
    "sentence": "宦官魚朝恩為觀軍容使，仍知國子監事，恃寵含威，天憲在舌。",
    "entities": [
      {
        "text": "魚朝恩",
        "label": "PER",
        "start": 2,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000025",
    "sentence": "前尹黎干寫心候事，動必求媚，每朝恩入監，傾府人吏具數百人之餼以待之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000026",
    "sentence": "及勉蒞職旬月，朝恩入監，府吏先期有請，勉曰：「軍容使判國子監事，勉候太學，軍容宜厚具主禮。勉忝京尹，軍容倘惠顧府廷，豈敢不具蔬饌。」朝恩聞而銜之，因不復至太學，勉亦尋受代。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000027",
    "sentence": "四年，除廣州刺史，兼嶺南節度觀察使。",
    "entities": [
      {
        "text": "四年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "除廣州",
