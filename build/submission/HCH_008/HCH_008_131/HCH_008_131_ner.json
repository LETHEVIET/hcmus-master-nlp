[
  {
    "sentence_id": "HCH_008_131_000001",
    "sentence": "李勉",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000002",
    "sentence": "李勉，字玄卿，鄭王元懿曾孫也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000003",
    "sentence": "父擇言，為漢褒相岐四州刺史、安德郡公，所歷皆以嚴干聞。",
    "entities": [
      {
        "text": "為漢褒相岐四州",
