        "end": 6
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000028",
    "sentence": "番禺賊帥馮崇道、桂州叛將硃濟時等阻洞為亂，前後累歲，陷沒十餘州。",
    "entities": [
      {
        "text": "桂州",
        "label": "LOC",
        "start": 8,
        "end": 10
      },
      {
        "text": "陷沒十餘州",
        "label": "LOC",
        "start": 26,
        "end": 31
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000029",
    "sentence": "勉至，遣將李觀與容州刺史王翃人並力招討，悉斬之，五嶺平。",
    "entities": [
      {
        "text": "遣將李觀與容州",
        "label": "LOC",
        "start": 3,
        "end": 10
      },
      {
        "text": "刺史",
        "label": "TITLE",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000030",
    "sentence": "前後西域舶泛海至者歲才四五，勉性廉潔，舶來都不檢閱，故末年至者四十餘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000031",
    "sentence": "在官累年，器用車服無增飾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000032",
    "sentence": "及代歸，至石門停舟，悉搜家人所貯南貨犀象諸物，投之江中，耆老以為可繼前朝宋璟、盧奐、李朝隱之徒。",
    "entities": [
      {
        "text": "李朝隱",
        "label": "PER",
        "start": 42,
        "end": 45
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000033",
    "sentence": "人吏詣闕請立碑，代宗許之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_008_131_000034",
    "sentence": "十年，拜工部尚書。",
    "entities": [
      {
        "text": "十年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "尚書",
        "label": "TITLE",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000035",
    "sentence": "及滑亳永平軍節度令狐彰卒，遺表舉勉自代，因除之。",
    "entities": [
      {
        "text": "令狐彰",
        "label": "PER",
        "start": 8,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_008_131_000036",
    "sentence": "在鎮八年，以舊德清重，不嚴而理，東諸侯雖暴驁者，亦宗敬之。",
    "entities": [
      {
        "text": "在鎮",
        "label": "LOC",
