[
  {
    "sentence_id": "HCH_001_000c_000001",
    "sentence": "腦子",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000002",
    "sentence": "腦子出渤泥國， 〈 一作佛泥。 〉 又出賓窣國，世謂三佛齊亦有之，非也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000003",
    "sentence": "但其國據諸蕃來往之要津，遂截斷諸國之物，聚於其國，以俟蕃舶貿易耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000004",
    "sentence": "腦之樹如杉，生於深山窮谷中，經千百年，支幹不曾損動，則賸有之，否則腦隨氣泄。",
    "entities": [
      {
        "text": "千百年",
        "label": "TME",
        "start": 15,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000005",
    "sentence": "土人入山採腦，須數十為羣，以木皮為衣，賫沙糊為糧，分路而去。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000006",
    "sentence": "遇腦樹則以斧斫記，至十餘株，然後截段均分，各以所得，解作板段，隨其板傍橫裂而成縫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000007",
    "sentence": "腦出於縫中，劈而取之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000008",
    "sentence": "其成片者謂之梅花腦，以狀似梅花也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000009",
    "sentence": "次謂之金脚腦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000010",
    "sentence": "其碎者謂之米腦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000011",
    "sentence": "碎與木屑相雜者，謂之蒼腦。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000012",
    "sentence": "取腦已淨，其杉片謂之腦札。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000013",
    "sentence": "今人碎之，與鋸屑相和，置瓷器中，以器覆之，封固其縫，煨以熱灰，氣蒸結而成塊，謂之聚腦，可作婦人花環等用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000014",
    "sentence": "又有一種如油者，謂之腦油，其氣勁而烈，秪可浸香合油。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000015",
    "sentence": "乳香",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000016",
    "sentence": "乳香一名薰陸香，出大食之麻囉拔、施曷、奴發三國深山窮谷中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000017",
    "sentence": "其樹大槩類榕，以斧斫株，脂溢於外，結而成香，聚而成塊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000018",
    "sentence": "以象輦之至于大食，大食以舟載易他貨于三佛齊，故香常聚於三佛齊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000019",
    "sentence": "番商貿易至，舶司視香之多少為殿最。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000020",
    "sentence": "而香之為品十有三，其最上者為揀香，圓大如指頭，俗所謂滴乳是也；次曰缾乳，其色亞於揀香；又次曰缾香，言收時貴重之置於缾中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000021",
    "sentence": "缾香之中又有上中下三等之別；又次曰袋香，言收時止置袋中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000022",
    "sentence": "其品亦有三如缾香焉；又次曰乳榻，蓋香之雜於砂石者也；又次曰黑榻，蓋香色之黑者也；又次曰水濕黑榻，蓋香在舟中，為水所浸漬而氣變色敗者也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000023",
    "sentence": "品雜而碎者曰斫削，簸揚為塵者曰纏末，皆乳香之別也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000024",
    "sentence": "沒藥",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000025",
    "sentence": "沒藥出大食麻囉抹國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000026",
    "sentence": "其樹高大，如中國之松，皮厚一二寸，採時先掘樹下為坎，用斧伐其皮，脂溢於坎中，旬餘方取之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000027",
    "sentence": "血碣",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000028",
    "sentence": "血碣亦出大食國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000029",
    "sentence": "其樹畧與沒藥同，但葉差大耳，採取亦如之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000030",
    "sentence": "有瑩如鏡面者，乃樹老脂自流溢，不犯斧鑿，此為上品。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000031",
    "sentence": "其夾插柴屑者，乃降眞香之脂，俗號假血碣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000032",
    "sentence": "金顏香",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000033",
    "sentence": "金顏香正出眞臘，大食次之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000034",
    "sentence": "所謂三佛齊有此香者，特自大食販運至三佛齊，而商人又自三佛齊轉販入中國耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000035",
    "sentence": "其香乃木之脂，有淡黃色者，有黑色者，拗開雪白為佳，有砂石為下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000036",
    "sentence": "其氣勁，工於聚衆香，今之為龍涎軟香佩帶者，多用之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000037",
    "sentence": "番人亦以和香而塗其身。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000038",
    "sentence": "篤耨香",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000039",
    "sentence": "篤耨香出眞臘國，其香樹脂也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000040",
    "sentence": "其樹狀如杉檜之類，而香藏於皮，樹老而自然流溢者，色白而瑩，故其香雖盛暑不融，名白篤耨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000041",
    "sentence": "至夏月以火環其株而炙之，令其脂液再溢，冬月因其凝而取之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000042",
    "sentence": "故其香夏融而冬凝，名黑篤耨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000043",
    "sentence": "土人盛之以瓢，舟人易之以瓷器，香之味清而長，黑者易融，滲漉於瓢，碎瓢而爇之，亦得其髣髴，今所謂篤耨瓢是也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000044",
    "sentence": "蘇合香油",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000045",
    "sentence": "蘇合香油，出大食國，氣味大抵類篤耨，以濃而無滓為上，番人多用以塗身。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000046",
    "sentence": "閩人患大風者亦倣之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000047",
    "sentence": "可合軟香，及人醫用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000048",
    "sentence": "安息香",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000049",
    "sentence": "安息香出三佛齊國，其香迺樹之脂也，其形色類核桃瓤，而不宜於燒，然能發衆香，故人取之以和香焉。",
    "entities": [
      {
        "text": "齊國",
        "label": "ORG",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000050",
    "sentence": "《通典》敍西戎有安息國。",
    "entities": [
      {
        "text": "《通典》",
        "label": "TITLE",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000051",
    "sentence": "後周天和、隋大業中曾朝貢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000052",
    "sentence": "恐以此得名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000053",
    "sentence": "而轉貨於三佛齊。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000054",
    "sentence": "梔子花",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000055",
    "sentence": "梔子花出大食啞巴閑、囉施美二國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000056",
    "sentence": "狀如中國之紅花，其色淺紫，其香清越而有醞藉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000057",
    "sentence": "土人採花曬乾，藏之琉璃缾中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000058",
    "sentence": "花赤希有，卽佛書所謂薝葡是也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000059",
    "sentence": "薔薇水",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000060",
    "sentence": "薔薇水，大食國花露也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000061",
    "sentence": "五代時番使蒲謌散以十五缾效貢，厥後罕有至者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000062",
    "sentence": "今多採花浸水，蒸取其液以代焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000063",
    "sentence": "其水多偽雜，以疏璃缾試之，翻搖數四，其抱周上下者為眞。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000064",
    "sentence": "其花與中國薔薇不同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000065",
    "sentence": "沉香",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000066",
    "sentence": "沉香所出非一，眞臘為上，占城次之，三佛齊、闍婆等為下。",
    "entities": [
      {
        "text": "占城",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000067",
    "sentence": "俗分諸國為上下岸，以眞臘、占城為上岸，大食、三佛齊、闍婆為下岸。",
    "entities": [
      {
        "text": "占城",
        "label": "LOC",
        "start": 13,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000068",
    "sentence": "香之大槩生結者為上，熟脱者次之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000069",
    "sentence": "堅黑者為上，黃者次之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000070",
    "sentence": "然諸沉之形多異而名亦不一，有如犀角者，謂之西角沉，如燕口者謂之燕口沉，如附子者謂之附子沉，如梭者謂之梭沉，文堅而理緻者謂之橫隔沉，大抵以所產氣味為高下，不以形體為優劣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000071",
    "sentence": "世謂渤泥亦產，非也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000072",
    "sentence": "一説其香生結成以刀修出者為生縮沉，自然脱落者為熟沉，產於下岸者謂之番沉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000073",
    "sentence": "氣哽味辣而烈，能治冷氣，故亦謂之藥沉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000074",
    "sentence": "海南亦產沉香，其氣清而長，謂之蓬萊沉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000075",
    "sentence": "箋香",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000076",
    "sentence": "箋香乃沉香之次者，氣味與沉香相類，然帶木而不甚堅實，故其品次於沉香，而優於熟速。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000077",
    "sentence": "速暫香",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000078",
    "sentence": "生速出於眞臘、占城，而熟速所出非一，眞臘為上，占城次之，闍婆為下。",
    "entities": [
      {
        "text": "占城",
        "label": "LOC",
        "start": 7,
        "end": 9
      },
      {
        "text": "占城",
        "label": "LOC",
        "start": 23,
        "end": 25
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000079",
    "sentence": "伐樹去木而取者，謂之生速，樹仆於地，木腐而香存者，謂之熟速。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000080",
    "sentence": "生速氣味長，熟速氣味易焦，故生者為上，熟者次之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000081",
    "sentence": "熟速之次者謂之暫香，其所產之高下與熟速同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000082",
    "sentence": "但脱者謂之熟速，而木之半存者謂暫香。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000083",
    "sentence": "半生熟，商人以刀刳其木而出其香，擇其上者雜於熟速而貨之，市者亦莫之辨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000084",
    "sentence": "黃熟香",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000085",
    "sentence": "黃熟香諸番皆出，而眞臘為上，其香黃而熟，故名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000086",
    "sentence": "若皮堅而中腐者，其形如桶，謂之黃熟桶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000087",
    "sentence": "其夾箋而通黑者，其氣尤勝，謂之夾箋黃熟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000088",
    "sentence": "夾箋者迺其香之上品。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000089",
    "sentence": "生香",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000090",
    "sentence": "生香出占城、眞臘，海南諸處皆有之。",
    "entities": [
      {
        "text": "生香出占城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000091",
    "sentence": "其直下於烏香，乃是斫倒香株之未老者，若香已生在木內，則謂之生香，結皮三分為暫香，五分為速香，七八分為箋香，十分卽為沉香也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000092",
    "sentence": "檀香",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000093",
    "sentence": "檀香出闍婆之打綱、底勿二國，三佛齊亦有之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000094",
    "sentence": "其樹如中國之荔支，其葉亦然，土人斫而陰乾，氣清勁而易泄，爇之能奪衆香。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000095",
    "sentence": "色黃者謂之黃檀，紫者謂之紫檀，輕而脆者謂之沙檀，氣味大卒相類。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000096",
    "sentence": "樹之老者，其皮薄，其香滿，此上品也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000097",
    "sentence": "次則有七八分香者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000098",
    "sentence": "其下者謂之點星香，為雨滴漏者謂之破漏香。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000099",
    "sentence": "其根謂之香頭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000100",
    "sentence": "丁香",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000101",
    "sentence": "丁香出大食、闍婆諸國，其狀似丁字，因以名之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000102",
    "sentence": "能辟口氣，郞官咀以奏事。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000103",
    "sentence": "其大者謂之丁香母。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000104",
    "sentence": "丁香母印鷄舌香也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000105",
    "sentence": "或曰鷄舌香，千年棗實也。",
    "entities": [
      {
        "text": "千年",
        "label": "TME",
        "start": 6,
        "end": 8
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000106",
    "sentence": "肉豆蔲",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000107",
    "sentence": "肉豆蔲出黃麻駐、牛崘等深番。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000108",
    "sentence": "樹如中國之柏，高至十丈，枝幹條枚蕃衍，敷廣蔽四五十人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000109",
    "sentence": "春季花開，採而曬乾，今豆蔲花是也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000110",
    "sentence": "其實如榧子，去其殼，取其肉，以灰藏之，可以耐久，接《本草》，其性温。",
    "entities": [
      {
        "text": "《本草》",
        "label": "TITLE",
        "start": 25,
        "end": 29
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000111",
    "sentence": "降眞香",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000112",
    "sentence": "降眞香出三佛齊、闍婆、蓬豐，廣東、西諸郡亦有之。",
    "entities": [
      {
        "text": "西諸郡",
        "label": "LOC",
        "start": 17,
        "end": 20
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000113",
    "sentence": "氣勁而遠，能辟邪氣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000114",
    "sentence": "泉人歲除，家無貧富，皆爇之如燔柴然，其直甚廉，以三佛齊者為上，以其氣味清遠也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000115",
    "sentence": "一名曰紫藤香。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000116",
    "sentence": "麝香木",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000117",
    "sentence": "麝香木出占城、眞臘，樹老仆湮沒於土而腐，以熟脱者為上，其氣依稀似麝，故謂之麝香。",
    "entities": [
      {
        "text": "麝香木出占城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000118",
    "sentence": "若伐生木取之，則氣勁而惡，是為下品。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000119",
    "sentence": "泉人多以為器用，如花梨木之類。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000120",
    "sentence": "波羅蜜",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000121",
    "sentence": "波羅蜜大如東瓜，外膚礧砢如佛髻，生靑熟黃，削其膚食之，味極甘。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000122",
    "sentence": "其樹如榕，其花叢生，花褪結子，惟一成實，餘各蘸死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000123",
    "sentence": "出蘇吉丹，廣州南海廟亦有之。",
    "entities": [
      {
        "text": "廣州",
        "label": "LOC",
        "start": 5,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000124",
    "sentence": "檳榔",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000125",
    "sentence": "檳榔產諸番國及海南四州，交趾亦有之。",
    "entities": [
      {
        "text": "番國及海南四州",
        "label": "LOC",
        "start": 4,
        "end": 11
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000126",
    "sentence": "木如棕櫚，結子葉間如柳條，顆顆叢綴其上，春取之為軟檳榔，俗號檳榔，鮮極可口。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000127",
    "sentence": "夏秋採而乾之為米檳榔，潰之以鹽為鹽檳榔。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000128",
    "sentence": "小而尖者為鷄心檳榔，大而匾者為大腹子，食之可以下氣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000129",
    "sentence": "三佛齊取其汁為酒，商舶興販，泉廣税務歲收數萬緡，惟海南最多。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000130",
    "sentence": "鮮檳榔、鹽檳榔皆出海南，雞心、大腹子多出麻逸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000131",
    "sentence": "椰子",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000132",
    "sentence": "椰子本身，葉悉類棕櫚、檳榔之屬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000133",
    "sentence": "子生葉間，一穗數枚，大如五升器，菓之大者惟此與波羅蜜耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000134",
    "sentence": "初採皮甚靑嫩，已而變黃，久則枯乾。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000135",
    "sentence": "皮中子殼可為器，子中穰白如玉，味美如牛乳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000136",
    "sentence": "穰中酒新者極清芳，久則渾濁不堪飲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000137",
    "sentence": "南毗諸國取其樹花汁用蜜糖和之為酒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000138",
    "sentence": "沒石子",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000139",
    "sentence": "沒石子出大食勿厮離。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000140",
    "sentence": "其樹如樟，歲一開花，結實如中國之茅栗，名曰沙沒律，亦名蒲蘆，可採食之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000141",
    "sentence": "次年再生，名曰麻茶，麻茶沒子石也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000142",
    "sentence": "明年又生沙沒律，間歲方生沒石子，所以貴售。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000143",
    "sentence": "一根而異產，亦可怪也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000144",
    "sentence": "烏樠木",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000145",
    "sentence": "烏樠木似棕櫚，靑綠聳直，高十餘丈，蔭綠茂盛。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000146",
    "sentence": "其木堅實如鐵，可為器用，光澤如漆，世以為珍木。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000147",
    "sentence": "蘇木",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000148",
    "sentence": "蘇木出眞臘國，樹如松栢，葉如冬靑，山谷郊野在在有之，聽民採取，去皮曬乾，其色紅赤，可染緋紫，俗號曰窊木。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000149",
    "sentence": "吉貝",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000150",
    "sentence": "吉貝樹類小桑，萼類芙蓉，絮長半寸許，宛如鵝毳，有子數十，南人取其茸絮，以鐵筯碾去其子，卽以手握茸就紡，不煩緝績，以之為布。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000151",
    "sentence": "最堅厚者謂之兠羅綿，次曰番布，次曰木棉，又次曰吉布，或染以雜色，異紋炳然，幅有闊至五六尺者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000152",
    "sentence": "椰心簟",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000153",
    "sentence": "椰心簟出丹戎武囉，番商運至三佛齊、凌牙門及闍婆貿易。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000154",
    "sentence": "又出三嶼、蒲哩嚕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000155",
    "sentence": "山產草，其狀似藤，長丈餘，紋縷端膩，無節目，名曰椰心草。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000156",
    "sentence": "番之婦女採而絲破，織以為簟，或用色染紅黑相間者日花簟，冬温而夏涼，便於出入。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000157",
    "sentence": "以三佛齊者為上，三嶼者最為下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000158",
    "sentence": "木香",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000159",
    "sentence": "木香出大食麻囉抹國，施曷、奴發亦有之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000160",
    "sentence": "樹如中國絲瓜，冬月取其根，剉長一二寸，曬乾，以狀如鷄骨者為上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000161",
    "sentence": "白豆蔲",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000162",
    "sentence": "白豆蔲出眞臘、闍婆等番，惟眞臘最多，樹如絲瓜，實如葡萄，蔓衍山谷，春花夏實，聽民從便採取。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000163",
    "sentence": "胡椒",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000164",
    "sentence": "胡椒出闍婆之蘇吉丹、打板、白花園、麻東、戎牙路，以新拖者為上，打板者次之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000165",
    "sentence": "胡椒生於郊野村落間，亦有界 〈 闕 〉 中國之葡萄，土人以竹木為棚 〈 闕 〉 開花，四月結實。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000166",
    "sentence": "花如鳳尾，其色靑紫，五月收採，曬乾藏之倉廩，次歲方發出，以牛車運載博易。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000167",
    "sentence": "其實不禁日而耐雨，旱則所入者寡，潦則所入倍常。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000168",
    "sentence": "〈 或曰南毗無離拔國至多，番商之販於闍婆，來自無離拔也。 〉",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000169",
    "sentence": "蓽澄茄",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000170",
    "sentence": "蓽澄茄樹藤蔓衍，春花夏實，類牽牛子，花白而實黑，曬乾入包，出闍婆之蘇吉丹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000171",
    "sentence": "阿魏",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000172",
    "sentence": "阿魏出大食木倶蘭國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000173",
    "sentence": "其樹不甚高大，脂多流溢，土人以繩束其梢，去其尾，納以竹筒，脂滿其中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000174",
    "sentence": "冬月破筒取脂，以皮袋收之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000175",
    "sentence": "或曰其脂最毒，人不敢近，每採阿魏時，繫羊於樹下，自遠射之，脂之毒着放羊，羊斃，卽以羊之腐為阿魏。",
    "entities": [
      {
        "text": "魏",
        "label": "ORG",
        "start": 15,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000176",
    "sentence": "未知熟是，姑兩存之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000177",
    "sentence": "蘆薈",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000178",
    "sentence": "蘆薈出大食奴發國，草屬也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000179",
    "sentence": "其狀如鱟尾，土人採而以玉器搗研之，熬而成膏，置諸皮袋中，名曰蘆薈。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000180",
    "sentence": "珊瑚樹",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000181",
    "sentence": "珊瑚樹出大食毗喏耶圃。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000182",
    "sentence": "樹生於海之至深處，初生色白，漸漸畏苗拆甲，歷一歲許，色間變黃，支格交錯，高極三四尺，大者圍尺。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000183",
    "sentence": "土人以絲繩繫五爪鐵錨兒，用烏鉛為墜，抛擲海中，發其根，以索繫於舟上，絞車搭起，不能常有，驀得一枝，肌理敷膩，見風則乾硬，變為乾紅色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000184",
    "sentence": "以最高者為貴，若失時不舉，則致蠹敗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000185",
    "sentence": "琉璃",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000186",
    "sentence": "琉璃出大食緒國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000187",
    "sentence": "燒煉燎之法與中國同。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000188",
    "sentence": "其法用鈆硝石膏燒成，大食則添入南鵬砂，故滋潤不烈，最耐寒暑，宿水不壞，以此貴重與中國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000189",
    "sentence": "猫兒睛",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000190",
    "sentence": "猫兒睛狀如母指大，卽小石也，瑩潔明透如猫兒睛，故名。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000191",
    "sentence": "出南毗國，國有江曰淡水江，諸流匜匯，深山碎石，為暴雨淜流，悉萃於此，官以小舸漉取，其圓瑩者卽猫兒睛也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000192",
    "sentence": "或曰有星照其地，秀氣鐘結而成。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000193",
    "sentence": "珠子",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000194",
    "sentence": "眞珠出大食國之海島上，又出西灘、監篦二國，廣西湖北亦有之，但不若大食、監篦之明淨耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000195",
    "sentence": "每採珠，用船三四十隻，船數十人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000196",
    "sentence": "其採珠人以麻繩繫身，以黃蠟塞耳鼻，入水約二三十餘丈，繩纏於船上，繩搖動則引而上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000197",
    "sentence": "先煮毳衲極熱，出水則急覆之，不然寒慄致死。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000198",
    "sentence": "或遇大魚蛟鼇諸海恠鬐鬣所觸，往往潰腹拆支，人見血一縷浮水面，則知已葬魚腹。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000199",
    "sentence": "嘗有採珠者繩動，而引之不上，衆極力舉之，足已為蛟鼉所斷矣。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000200",
    "sentence": "所採者曰珠母，番有官監視，隨其所採，籍其名掘地為坎，置諸坎中月餘，珠母殼腐，取珠淘淨，與採珠者均之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000201",
    "sentence": "珠大率以圓潔明淨者為上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000202",
    "sentence": "圓者置諸盤中終日不停，番商多置夾襦內及傘柄中，規免抽解。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000203",
    "sentence": "硨磲",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000204",
    "sentence": "硨磲出交趾國，狀似大蚌，沿海人磨治其殼，因其形為荷葉杯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000205",
    "sentence": "膚理瑩潔如珂玉，其最大者琢其根柢為杯。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000206",
    "sentence": "有厚三寸者，脱落碎𤨏，猶為環珮諸玩物。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000207",
    "sentence": "按佛書以此為至寶，今乃海錯耳，未審是古硨磲否？",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000208",
    "sentence": "象牙",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000209",
    "sentence": "象牙出大食緒國及眞臘、占城二國，以大食者為上，眞臘、占城者為下。",
    "entities": [
      {
        "text": "占城",
        "label": "LOC",
        "start": 11,
        "end": 13
      },
      {
        "text": "占城",
        "label": "LOC",
        "start": 26,
        "end": 28
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000210",
    "sentence": "大食諸國惟麻囉抹最多。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000211",
    "sentence": "象生於深山窮谷中，時出野外蹂踐，人莫敢近，獵者用神勁弓，以藥箭射之，象負箭而遁，未及一二里許，藥發卽斃，獵者隨斃取其牙埋諸土中，積至十餘株，方搬至大食，以舟運載與三佛齊、日囉亭交易。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000212",
    "sentence": "大者重五十斤至百斤。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000213",
    "sentence": "其株端直，其色潔白，其紋細籀者，大食出也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000214",
    "sentence": "眞臘、占城所產，株小色紅，重不過十數斤至二三十斤。",
    "entities": [
      {
        "text": "占城",
        "label": "LOC",
        "start": 3,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000215",
    "sentence": "又有牙尖，止可作小香疊用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000216",
    "sentence": "或曰象媒誘致，恐此乃馴象也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000217",
    "sentence": "犀角",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000218",
    "sentence": "犀狀如黃牛，只有一角，皮黑毛稀，舌如栗殼，其性鷙悍，其走如飛，專食竹木等刺，人不敢近。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000219",
    "sentence": "獵人以硬箭自遠射之，遂取其角，韶之生角。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000220",
    "sentence": "或有自斃者，謂之倒山角。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000221",
    "sentence": "角之紋如泡，以白多黑少者為上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000222",
    "sentence": "膃肭臍",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000223",
    "sentence": "膃肭臍出大食伽力吉國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000224",
    "sentence": "其形如猾，脚高如犬，其色或紅或黑，其走如飛，獵者張網於海濱捕之，取其腎而漬以油，名膃肭臍。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000225",
    "sentence": "番惟渤泥最多。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000226",
    "sentence": "翠毛",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000227",
    "sentence": "翠毛，眞臘最多，產於深山澤間，巢於水次，一壑之水止一雌雄，外有一焉，必出而死鬭，人用其機，飼媒擎諸左手以行，巢中者見之，就手格鬭，不愎知有人也，右手卽以羅掩之，無能脱者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000228",
    "sentence": "邕州右江亦產一種茸翠，其背毛悉是翠茸。",
    "entities": [
      {
        "text": "邕州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000229",
    "sentence": "窮侈者多以撚織，如毛段然。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000230",
    "sentence": "比年官雖厲禁，貴人家服用不廢，故番商冒法販鬻，多寘布襦袴中。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000231",
    "sentence": "鸚鵡",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000232",
    "sentence": "鸚鵡產占城，有五色。",
    "entities": [
      {
        "text": "鸚鵡產占城",
        "label": "LOC",
        "start": 0,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000233",
    "sentence": "唐太宗時環王所獻是也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000234",
    "sentence": "案傳謂能訴寒，有詔還之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000235",
    "sentence": "環王國卽占城也。",
    "entities": [
      {
        "text": "環王國卽占城",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000236",
    "sentence": "欽州有白鸚鵡、紅鸚鵡，大如小鵝，羽毛有粉，如蝴蝶翅，謂之白鸚鵡；其色正紅，尾如烏鳶之尾，謂之紅鸚鵡",
    "entities": [
      {
        "text": "欽州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000237",
    "sentence": "龍涎",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000238",
    "sentence": "龍涎，大食西海多龍，枕石一睡，涎沫浮水，積而能堅，鮫人採之以為至寶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000239",
    "sentence": "新者色白，稍久則紫，甚久則黑，不薰不蕕，似浮石而輕也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000240",
    "sentence": "人云龍涎有異香，或云能涎氣腥，能發衆香，皆非也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000241",
    "sentence": "龍涎放香，本無損益，但能聚煙耳，和香而眞用龍涎焚之，一縷翠煙浮空結而不散，座客可用一剪分煙縷，此其所以然者，蜃氣樓臺之餘烈也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000242",
    "sentence": "瑇瑁",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000243",
    "sentence": "瑇瑁形似龜黿，背甲十三片，黑白斑紋間錯，邊襴缺齧如鋸，無足而有四鬣，前長後短，以鬣掉水而行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000244",
    "sentence": "鬣與首斑文如甲，老者甲厚而黑白分明，少者甲薄而花字模糊，世傳鞭血成斑，妄也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000245",
    "sentence": "漁者以秋間月夜採捕，肉亦可喫。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000246",
    "sentence": "出渤泥、三嶼、蒲哩嚕、闍婆諸國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000247",
    "sentence": "黃蠟",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000248",
    "sentence": "黃蠟出三嶼、麻逸、眞臘、三佛齊等國。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000249",
    "sentence": "蜂生於深山窮谷中，或窠老樹，或窠芭蕉樹，或窠巖穴，較諸中國之蜂差大而黑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000250",
    "sentence": "番民以皮輓軀，先用惡草作煙，迫逐羣蜂飛散，隨取其窠，擠去蜜，其滓卽臘也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000251",
    "sentence": "鎔範成𥓮，或雜灰粉鹽石。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000252",
    "sentence": "以三佛齊者為上，眞臘次之，三嶼、麻逸、蒲哩嚕為下。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000253",
    "sentence": "海南",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000254",
    "sentence": "海南，漢朱崖、儋耳也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000255",
    "sentence": "武帝平南粤，遣使自徐聞 〈 今雷州徐文縣。 〉 渡海略地，置朱崖、儋耳二郡。",
    "entities": [
      {
        "text": "今雷州徐文縣",
        "label": "LOC",
        "start": 14,
        "end": 20
      },
      {
        "text": "儋耳二郡",
        "label": "LOC",
        "start": 33,
        "end": 37
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000256",
    "sentence": "昭帝省儋耳併為朱崖郡。",
    "entities": [
      {
        "text": "儋耳併為朱崖郡",
        "label": "LOC",
        "start": 3,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000257",
    "sentence": "元帝從賈捐之議，罷朱崖。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000258",
    "sentence": "至梁、隋復置。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000259",
    "sentence": "唐貞觀元年，析為崖、儋、振三州，隸嶺南道。",
    "entities": [
      {
        "text": "貞觀元年",
        "label": "TME",
        "start": 1,
        "end": 5
      },
      {
        "text": "振三州",
        "label": "LOC",
        "start": 12,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000260",
    "sentence": "五年分崖之瓊山置郡，陞萬安縣為州，今萬安軍是也，儋、振則今之吉陽、昌化軍是也。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 0,
        "end": 2
      },
      {
        "text": "分崖之瓊山置郡",
        "label": "LOC",
        "start": 2,
        "end": 9
      },
      {
        "text": "陞萬安縣為州",
        "label": "LOC",
        "start": 10,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000261",
    "sentence": "貞元五年以瓊為督府，今因之。",
    "entities": [
      {
        "text": "五年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000262",
    "sentence": "徐聞有遞角塲，與瓊對峙，相去約三百六十餘里，順風半日可濟，中流號三合溜，涉此無風濤，則舟人舉手相賀。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000263",
    "sentence": "至吉陽，迺海之極，亡復陸塗。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000264",
    "sentence": "外有洲曰烏里、曰蘇密、曰吉浪，南對占城，西望眞臘，東則千里長沙、萬里石床，渺茫無際，天水一色，舟舶來往，惟以指南針為則，晝夜守視唯謹，毫釐之差，生死繫焉。",
    "entities": [
      {
        "text": "南對占城",
        "label": "LOC",
        "start": 15,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000265",
    "sentence": "四郡凡十一縣，悉隸廣西西路，環拱黎母山，黎獠蟠踞其中，有生黎、熟黎之別。",
    "entities": [
      {
        "text": "四郡凡十一縣",
        "label": "LOC",
        "start": 0,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000266",
    "sentence": "地多荒田，所種杭稌，不足於食，乃以 𧄔 〈 時諸切。 〉 芋雜米作粥糜以取飽，故俗以貿香為業。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000267",
    "sentence": "土産沉香、蓬萊香、鷓鴣斑香、箋香、生香、丁香、檳榔、椰子、吉貝、苧麻、楮皮、赤白藤、花縵、黎幙、靑桂木、花梨木、海梅脂、瓊枝菜、海漆、蓽撥、高良薑、魚鰾、黃蠟、石蠏之屬，其貨多出於黎峒。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000268",
    "sentence": "省民以鹽、鐵、魚、米轉博，與商賈貿易。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000269",
    "sentence": "泉舶以酒、米、麪粉、紗絹、漆器、瓷器等為貨，歲杪或正月發舟，五六月間囘舶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000270",
    "sentence": "若載鮮檳榔纔先，則四月至。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000271",
    "sentence": "瓊州在黎母山之東北，郡治卽古崖州也。",
    "entities": [
      {
        "text": "瓊州",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "郡治卽古崖州",
        "label": "LOC",
        "start": 10,
        "end": 16
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000272",
    "sentence": "政和間陞為節鎮，以靖海軍為額。",
    "entities": [
      {
        "text": "政和間陞為節鎮",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000273",
    "sentence": "瀕海少山，秋霖春旱，夏不極熱，冬不甚寒，多颶風，常以五六月發，有暈如虹者，謂之颶母。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000274",
    "sentence": "按《隋志》謂「人性輕悍，椎髻卉裳，刻木為符，力穡朴野，父子別業。豪黠共鑄銅為大皷，初成懸於庭，鳴皷以招同類，至者如雲，羣情趨服者，號為都老人。着紬緶，以土為釜，瓠匏為器，無麯蘗，以安石榴花醞釀為酒」。",
    "entities": [
      {
        "text": "《隋志》",
        "label": "TITLE",
        "start": 1,
        "end": 5
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000275",
    "sentence": "今之上衣無異中土，惟下裳男子用布縵，女子用裙。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000276",
    "sentence": "以紡吉貝為生，土釜至今用之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000277",
    "sentence": "瓠瓢間以𨟉水，酒用薯糧以變色。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000278",
    "sentence": "雖無富民，向俗尚儉約，故無惸獨，凶年不見匄者。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000279",
    "sentence": "丁晉公嘗貶為州司戶，敎民讀書著文。",
    "entities": [
      {
        "text": "丁晉公嘗貶為州",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000280",
    "sentence": "慶曆間，宋侯貫之創郡庠，嘉定庚午，趙侯汝厦新之，祠東坡蘇公、澹庵胡公於講堂之東西偏，扁其堂日「明道」。",
    "entities": [
      {
        "text": "宋侯貫之創郡",
        "label": "LOC",
        "start": 4,
        "end": 10
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000281",
    "sentence": "海口有漢兩伏波廟，路博德、馬援祠也，過海者必禱於是，得杯珓之吉而後敢濟。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000282",
    "sentence": "屬邑五：瓊山、澄邁、臨高、文昌、樂會，皆有市舶，於舶舟之中分三等，上等為舶，中等為包頭，下等名蛋舶，至則津務申州，差官打量丈尺，有經册以格税錢，本州官吏兵卒仰此以贍。",
    "entities": [
      {
        "text": "屬邑",
        "label": "LOC",
        "start": 0,
        "end": 2
      },
      {
        "text": "至則津務申州",
        "label": "LOC",
        "start": 50,
        "end": 56
      },
      {
        "text": "本州",
        "label": "LOC",
        "start": 72,
        "end": 74
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000283",
    "sentence": "西二百三十六里，抵昌化軍治。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000284",
    "sentence": "昌化在黎母山之西北，卽古儋州也，子城高一丈四尺，周廻二百二十步，舊經以為儋耳夫人驅鬼工，供畚鍤，一夕而就。",
    "entities": [
      {
        "text": "卽古儋州",
        "label": "LOC",
        "start": 10,
        "end": 14
      },
      {
        "text": "子城",
        "label": "LOC",
        "start": 16,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000285",
    "sentence": "或謂土人耳長至肩，故有儋耳之號。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000286",
    "sentence": "今昌化卽無大耳兒，葢黎俗慕佛，以大鐶墜耳，俾下垂至肩故也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000287",
    "sentence": "地無烟瘴水潦之患，氣候與中州異，羣花皆早發，至春時已盡，獨荷花自四五月開至窮臘，與梅菊相接。",
    "entities": [
      {
        "text": "氣候與中州",
        "label": "LOC",
        "start": 9,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000288",
    "sentence": "俗尚淳朴儉約，婦人不曳羅綺，不施粉黛，婚姻喪祭皆循典禮，無饑寒之民。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000289",
    "sentence": "學在東南隅，後遷于西，紹興間復遷于城東，參政李公光為之記。",
    "entities": [
      {
        "text": "紹興間復遷于城",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000290",
    "sentence": "去州十五里，地名蜑塲，忠簡趙公鼎謫吉陽，嘗過斯地，盛暑苦旱，井泉枯竭，鑿井不數尺得泉，至今不涸，號曰「相泉」。",
    "entities": [
      {
        "text": "去州",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000291",
    "sentence": "又有白馬井，泉味甘美，商舶囘日，汲載以供日用。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000292",
    "sentence": "靈濟廟在鎭安門內，卽儋耳夫人祠也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000293",
    "sentence": "紹興間封顯應夫人。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000294",
    "sentence": "海外黎峒多竊發，惟儋獨全，夫人之力也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000295",
    "sentence": "城西五十餘里，一石峯在海洲巨浸之間，形類獅子，俗呼獅子神，實貞利侯廟，商舶祈風于是。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000296",
    "sentence": "屬邑三：曰宜倫、曰昌化、曰感恩。",
    "entities": [
      {
        "text": "屬邑",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000297",
    "sentence": "南三百四十里抵吉陽軍界。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000298",
    "sentence": "吉陽軍在黎母山之西南，郡治州吉陽縣基也。",
    "entities": [
      {
        "text": "郡治州吉陽縣",
        "label": "LOC",
        "start": 11,
        "end": 17
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000299",
    "sentence": "瓊管雖有陸路可通，然隔越生黎必峒，再涉海而後至，胡澹庵謂再涉鯨波險是也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000300",
    "sentence": "郡治之南有海口驛，商人艤舟其下，前有小亭，為迎送之所，地狹民稀，氣候不正，春常苦旱，涉夏方雨。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000301",
    "sentence": "耕種不糞不耘，樵牧漁獵與黎獠錯雜。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000302",
    "sentence": "出人必持弓矢。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000303",
    "sentence": "婦人不事蠶桑，惟織吉貝、花被、縵布、黎幕，男子不喜營運，家無宿儲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000304",
    "sentence": "俗尚鬼，不事醫藥，病則宰牲牷，動鼓樂以祀，謂之作福。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000305",
    "sentence": "禁人造門，喪祭亦皆用樂。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000306",
    "sentence": "地多崇岡峻嶺，峯巒秀拔，故郡之士人間有能自立者。",
    "entities": [
      {
        "text": "故郡",
        "label": "LOC",
        "start": 12,
        "end": 14
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000307",
    "sentence": "學在郡城之東北。",
    "entities": [
      {
        "text": "學在郡城",
        "label": "LOC",
        "start": 0,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000308",
    "sentence": "去城十三里有石，面平如掌，非磨琢之工所能為，周圍數丈，可坐十客。",
    "entities": [
      {
        "text": "去城",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000309",
    "sentence": "林木茂密，澗水甘冽，周侯創結茅亭其上，扁日「清賞」。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000310",
    "sentence": "熟黎峒落稀少，距城五七里許，外卽生黎所居，不啻數百峒，時有侵擾之害。",
    "entities": [
      {
        "text": "距城",
        "label": "LOC",
        "start": 7,
        "end": 9
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000311",
    "sentence": "周侯遣熟黎峒首諭之，約定寅、酉二日為虛市，率皆肩擔背負，或乘桴而來，與民貿易，黎人和悅，民獲安息。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000312",
    "sentence": "領吉陽、寧遠二縣，政和間併為寧遠一縣。",
    "entities": [
      {
        "text": "寧遠二縣",
        "label": "LOC",
        "start": 4,
        "end": 8
      },
      {
        "text": "間併為寧遠一縣",
        "label": "LOC",
        "start": 11,
        "end": 18
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000313",
    "sentence": "東一百二十里抵萬安軍界。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000314",
    "sentence": "萬安軍在黎母山之東南。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000315",
    "sentence": "唐貞觀五年置萬安州，領縣三：曰萬安、富雲、博遼。",
    "entities": [
      {
        "text": "貞觀五年",
        "label": "TME",
        "start": 1,
        "end": 5
      },
      {
        "text": "領縣",
        "label": "LOC",
        "start": 10,
        "end": 12
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000316",
    "sentence": "天寶初更州為郡。",
    "entities": [
      {
        "text": "天寶初更州為郡",
        "label": "LOC",
        "start": 0,
        "end": 7
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000317",
    "sentence": "至德二載更為萬全。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000318",
    "sentence": "乾元初復為州。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000319",
    "sentence": "皇朝省富雲、博遼二縣，更萬安縣曰萬寧。",
    "entities": [
      {
        "text": "博遼二縣",
        "label": "LOC",
        "start": 6,
        "end": 10
      },
      {
        "text": "更萬安縣",
        "label": "LOC",
        "start": 11,
        "end": 15
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000320",
    "sentence": "熙寧六年更為軍，析萬寧為陵水，今萬寧、陵水是也。",
    "entities": [
      {
        "text": "六年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000321",
    "sentence": "民與黎蜑雜居。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000322",
    "sentence": "其俗質野而畏法，不喜為盜，牛羊被野，無敢冒認。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000323",
    "sentence": "居多茅竹，瓦屋絕少。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000324",
    "sentence": "婦媼以織貝為業，不事文刺繡。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000325",
    "sentence": "病不服藥，信尚巫鬼，殺牲而祭，以祈福佑。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000326",
    "sentence": "黃侯申首創藥局，人稍知服藥之利。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000327",
    "sentence": "城東有舶主都綱廟，人敬信，禱卜立應，舶舟往來，祭而後行。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000328",
    "sentence": "三郡士子，當歲大比，皆附試于瓊管。",
    "entities": [
      {
        "text": "三郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000329",
    "sentence": "黎，海南四郡島上蠻也。",
    "entities": [
      {
        "text": "海南四郡",
        "label": "LOC",
        "start": 2,
        "end": 6
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000330",
    "sentence": "島有黎母山，因祥光夜見、旁照四郡，按《晉書》分野屬婺女分，謂黎牛婺女星降現，故名黎婺，音訛為黎母。",
    "entities": [
      {
        "text": "旁照四郡",
        "label": "LOC",
        "start": 12,
        "end": 16
      },
      {
        "text": "《晉書》",
        "label": "TITLE",
        "start": 18,
        "end": 22
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000331",
    "sentence": "諸蠻環處，其山峻極，常在霧靄中，黎人自鮮識之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000332",
    "sentence": "秋朗氣清時，見翠尖浮插半空。",
    "entities": [
      {
        "text": "清",
        "label": "ORG",
        "start": 3,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000333",
    "sentence": "山有水泉湧流，派而為五，一入昌化，一入吉陽，一入萬安，一入瓊州，一流為大溪，有灘三十六，至長寮村，屬澄邁縣。",
    "entities": [
      {
        "text": "一入瓊州",
        "label": "LOC",
        "start": 27,
        "end": 31
      },
      {
        "text": "屬澄邁縣",
        "label": "LOC",
        "start": 49,
        "end": 53
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000334",
    "sentence": "一流為小溪，有灘二十四，至硃運村，屬樂會縣。",
    "entities": [
      {
        "text": "屬樂會縣",
        "label": "LOC",
        "start": 17,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000335",
    "sentence": "二水合流為三合水，屬瓊山縣。",
    "entities": [
      {
        "text": "屬瓊山縣",
        "label": "LOC",
        "start": 9,
        "end": 13
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000336",
    "sentence": "去省地遠者為生黎，近者為熟黎，各以所邇隸於四軍州。",
    "entities": [
      {
        "text": "所邇隸於四軍州",
        "label": "LOC",
        "start": 17,
        "end": 24
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000337",
    "sentence": "黎之峒落日以繁滋，不知其幾千百也，咸無統屬，峒自為雄長，止於王、符、張、李數姓。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000338",
    "sentence": "同姓為婚。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000339",
    "sentence": "省民之負罪者多逋逃歸之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000340",
    "sentence": "其人推髻跣足，插銀銅錫釵，婦人加銅環，耳墜垂肩，女及筓卽黥頰為細花紋，謂之繡面，女旣黥，集親客相賀慶，惟婢獲則不繡面。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000341",
    "sentence": "女工紡織，得中土綺綵，拆取色絲，加木棉，挑織為單幕。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000342",
    "sentence": "又純織木棉吉貝為布。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000343",
    "sentence": "祭神以牛犬雞彘，多至百牲。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000344",
    "sentence": "無鹽鐵魚蝦，以沉香、縵布、木棉、麻皮等，就省地博易。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000345",
    "sentence": "得錢無所用也。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000346",
    "sentence": "屋宇以竹為棚，下居牧畜，人處其上。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000347",
    "sentence": "男子常帶長靶刀、長弰，刀弓跬步不離。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000348",
    "sentence": "喜讐殺，謂之捉抝。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000349",
    "sentence": "其親為人所殺，後見仇家人及其峒中種類，卽擒取而械之，械用荔枝木，長六尺許，其狀如碓，要牛酒銀缾乃釋，謂之贖命。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000350",
    "sentence": "議婚姻折箭為質，聚會椎皷舞歌。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000351",
    "sentence": "死必殺牛以祭。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000352",
    "sentence": "土産沉水、蓬萊諸香，為香譜第一。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000353",
    "sentence": "漫山悉檳榔、椰子樹，小馬、翠羽、黃蠟之屬。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000354",
    "sentence": "閩商值風飄蕩，貲貨陷投，多人黎地耕種之。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000355",
    "sentence": "歸官吏及省民經由村峒，必舍其家，恃以為安。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000356",
    "sentence": "熟黎之外，海南四州軍鎭，其四隅地方千里，路如連環，欲歷其地，非一月不可遍。",
    "entities": [
      {
        "text": "海南四州",
        "label": "LOC",
        "start": 5,
        "end": 9
      },
      {
        "text": "方千里",
        "label": "PER",
        "start": 16,
        "end": 19
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000357",
    "sentence": "馬伏波之平海南也，命陶者作缶器，大者盛水數石，小者盛五斗至二三斗者，招到深峒歸降人，卽以遺之，任意選擇，以測其巢穴之險夷。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000358",
    "sentence": "黎人止取二三斗之小者，詰之云：來時皆懸崖，緣木而下，不取大者，恐將歸不得。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000359",
    "sentence": "以是知其峒穴深而險峻不可入。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000360",
    "sentence": "四郡之人多黎姓，葢其裔族。",
    "entities": [
      {
        "text": "四郡",
        "label": "LOC",
        "start": 0,
        "end": 2
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000361",
    "sentence": "而今黎人乃多姓王。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000362",
    "sentence": "淳熙元年。",
    "entities": [
      {
        "text": "元年",
        "label": "TME",
        "start": 2,
        "end": 4
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000363",
    "sentence": "五指山生黎洞首王仲期，率其傍八十洞，丁口千八百二十歸化。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000364",
    "sentence": "仲期與諸洞首王仲文等八十一人詣瓊管公參，就顯應廟研石歃血約誓改過，不復抄掠，犒賜遣歸。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000365",
    "sentence": "瓊守圖其形狀衣裘上經略司，髻露者以降帛約髻根，或以彩帛包髻，或戴小花笠，皆簪二銀篦，亦有着短織花裙者，惟王仲期靑巾紅錦袍束帶。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000366",
    "sentence": "自云祖父宣和中嘗納土補官，賜錦袍云。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000367",
    "sentence": "物貨，海南土産，諸番皆有之，顧有優劣耳。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000368",
    "sentence": "箋、沉等香，味清且長，敻出諸番之右，雖占城、眞臘亦居其次。",
    "entities": [
      {
        "text": "雖占城",
        "label": "LOC",
        "start": 18,
        "end": 21
      }
    ]
  },
  {
    "sentence_id": "HCH_001_000c_000369",
    "sentence": "黃蠟則迥不及三佛齊，較之三嶼，抑又劣焉。",
    "entities": []
  },
  {
    "sentence_id": "HCH_001_000c_000370",
    "sentence": "其餘物貨多與諸番同，惟檳榔、吉貝獨盛，泉商興販，大寧仰此。",
    "entities": []
  }
]
